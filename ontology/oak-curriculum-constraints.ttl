@prefix curric: <https://w3id.org/uk/oak/curriculum/ontology/> .
@prefix shapes: <https://w3id.org/uk/oak/curriculum/ontology/shapes/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <http://schema.org/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ======================================================================
# Oak Curriculum Ontology - SHACL Constraints
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/ontology/shapes>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Ontology - SHACL Constraints"@en ;
  dc:title "Oak Curriculum Ontology - SHACL Constraints"@en ;
  rdfs:comment "SHACL validation constraints for the Oak Curriculum Ontology."@en ;

  owl:versionInfo "0.1.3" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/ontology/shapes/0.1.3> ;

  dcterms:description """These SHACL constraints represent current rules and policies that may
  evolve over time, separate from the core ontology definitions."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2025-12-01T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-01T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-01T12:33:32Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Copyright © 2026 Oak National Academy."@en ;

  rdfs:seeAlso <https://thenational.academy/curriculum-ontology> ;
  vann:preferredNamespacePrefix "shapes" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/ontology/shapes/" .


# ----------------------------------------------------------------------
# Shape: Phase
# ----------------------------------------------------------------------

shapes:PhaseShape
  a sh:NodeShape ;
  sh:targetClass curric:Phase ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every phase must have exactly one rdfs:label." ;
    sh:message "Phases must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path rdfs:comment ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "comment" ;
    sh:description "Every phase must have exactly one rdfs:comment." ;
    sh:message "Phases must have exactly one rdfs:comment with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:lowerAgeBoundary ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "lower age boundary" ;
    sh:description "A phase must have exactly one lower age boundary." ;
    sh:message "Every phase must specify exactly one lower age boundary." ;
  ] ;

  sh:property [
    sh:path curric:upperAgeBoundary ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "upper age boundary" ;
    sh:description "A phase must have exactly one upper age boundary." ;
    sh:message "Every phase must specify exactly one upper age boundary." ;
  ] ;

  sh:sparql [
    sh:message "Lower age boundary must be less than upper age boundary" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:lowerAgeBoundary ?lower ;
              curric:upperAgeBoundary ?upper .
        FILTER (?lower >= ?upper)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "Age boundaries must be in reasonable range (0-25 years)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:lowerAgeBoundary ?lower ;
              curric:upperAgeBoundary ?upper .
        FILTER (?lower < 0 || ?upper > 25)
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: KeyStage
# ----------------------------------------------------------------------

shapes:KeyStageShape
  a sh:NodeShape ;
  sh:targetClass curric:KeyStage ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every key stage must have exactly one rdfs:label." ;
    sh:message "Key stages must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path rdfs:comment ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "comment" ;
    sh:description "Every key stage must have exactly one rdfs:comment." ;
    sh:message "Key stages must have exactly one rdfs:comment with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:isKeyStageOf ;
    sh:class curric:Phase ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is key stage of" ;
    sh:description "Every key stage must be part of exactly one phase." ;
    sh:message "Key stages must specify which phase they belong to." ;
  ] ;

  sh:property [
    sh:path curric:lowerAgeBoundary ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "lower age boundary" ;
    sh:description "A key stage must have exactly one lower age boundary." ;
    sh:message "Every key stage must specify exactly one lower age boundary." ;
  ] ;

  sh:property [
    sh:path curric:upperAgeBoundary ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "upper age boundary" ;
    sh:description "A key stage must have exactly one upper age boundary." ;
    sh:message "Every key stage must specify exactly one upper age boundary." ;
  ] ;

  sh:sparql [
    sh:message "Lower age boundary must be less than upper age boundary" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:lowerAgeBoundary ?lower ;
              curric:upperAgeBoundary ?upper .
        FILTER (?lower >= ?upper)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "Key stage age boundaries must fall within parent phase boundaries" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:isKeyStageOf ?phase ;
              curric:lowerAgeBoundary ?childLower ;
              curric:upperAgeBoundary ?childUpper .

        ?phase curric:lowerAgeBoundary ?parentLower ;
               curric:upperAgeBoundary ?parentUpper .

        FILTER (?childLower < ?parentLower || ?childUpper > ?parentUpper)
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: YearGroup
# ----------------------------------------------------------------------

shapes:YearGroupShape
  a sh:NodeShape ;
  sh:targetClass curric:YearGroup ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every year group must have exactly one rdfs:label." ;
    sh:message "Year groups must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path rdfs:comment ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "comment" ;
    sh:description "Every year group must have exactly one rdfs:comment." ;
    sh:message "Year groups must have exactly one rdfs:comment with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:isYearGroupOf ;
    sh:class curric:KeyStage ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is year group of" ;
    sh:description "Every year group must be part of exactly one key stage." ;
    sh:message "Year groups must specify which key stage they belong to." ;
  ] ;

  sh:property [
    sh:path curric:lowerAgeBoundary ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "lower age boundary" ;
    sh:description "A year group must have exactly one lower age boundary." ;
    sh:message "Every year group must specify exactly one lower age boundary." ;
  ] ;

  sh:property [
    sh:path curric:upperAgeBoundary ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "upper age boundary" ;
    sh:description "A year group must have exactly one upper age boundary." ;
    sh:message "Every year group must specify exactly one upper age boundary." ;
  ] ;

  sh:sparql [
    sh:message "Lower age boundary must be less than upper age boundary" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:lowerAgeBoundary ?lower ;
              curric:upperAgeBoundary ?upper .
        FILTER (?lower >= ?upper)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "Year group age boundaries must fall within parent key stage boundaries" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:isYearGroupOf ?keystage ;
              curric:lowerAgeBoundary ?childLower ;
              curric:upperAgeBoundary ?childUpper .

        ?keystage curric:lowerAgeBoundary ?parentLower ;
                  curric:upperAgeBoundary ?parentUpper .

        FILTER (?childLower < ?parentLower || ?childUpper > ?parentUpper)
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: SubjectGroup
# ----------------------------------------------------------------------

shapes:SubjectGroupShape
  a sh:NodeShape ;
  sh:targetClass curric:SubjectGroup ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every subject group must have exactly one rdfs:label." ;
    sh:message "Subject groups must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:coversDiscipline ;
    sh:class curric:Discipline ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "covers discipline" ;
    sh:description "Every subject group must relate to exactly one discipline." ;
    sh:message "Subject groups must specify which discipline they relate to." ;
  ] ;

  sh:sparql [
    sh:message "Subject group label must match its discipline's preferred label" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
      PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

      SELECT $this WHERE {
        $this a curric:SubjectGroup ;
              curric:coversDiscipline ?discipline ;
              rdfs:label ?subjectGroupLabel .

        ?discipline skos:prefLabel ?disciplineLabel .

        FILTER (?subjectGroupLabel != ?disciplineLabel)
      }
    """ ;
  ] .

shapes:SubjectGroupOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:SubjectGroup ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Subject group is not used in any subject (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:SubjectGroup .
        FILTER NOT EXISTS {
          ?subject a curric:Subject ;
                      curric:isSubjectOf $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: Subject
# ----------------------------------------------------------------------

shapes:SubjectShape
  a sh:NodeShape ;
  sh:targetClass curric:Subject ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every subject must have exactly one rdfs:label." ;
    sh:message "Subjects must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:hasAim ;
    sh:class curric:Aim ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "has aim" ;
    sh:description "Every subject should have at least one aim." ;
    sh:message "Subject should have at least one curric:Aim via curric:hasAim (WARNING)." ;
  ] ;

  sh:property [
    sh:path curric:isSubjectOf ;
    sh:class curric:SubjectGroup ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is subject of" ;
    sh:description "Every subject must be part of exactly one subject group." ;
    sh:message "Subjects must specify which subject group they belong to." ;
  ] ;

  sh:property [
    sh:path curric:coversStrand ;
    sh:class curric:Strand ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "covers strand" ;
    sh:description "Every subject should cover at least one strand." ;
    sh:message "Subject should cover at least one strand (WARNING)." ;
  ] .

shapes:SubjectOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:Subject ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Subject is not used in any scheme (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:Subject .
        FILTER NOT EXISTS {
          ?scheme a curric:Scheme ;
                  curric:isSchemeOf $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: Aim
# ----------------------------------------------------------------------

shapes:AimShape
  a sh:NodeShape ;
  sh:targetClass curric:Aim ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every aim must have exactly one rdfs:label." ;
    sh:message "Aims must have exactly one rdfs:label with English language tag." ;
  ] .

shapes:AimOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:Aim ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Aim is not linked to any subject via curric:hasAim (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:Aim .
        FILTER NOT EXISTS {
          ?subject a curric:Subject ;
                   curric:hasAim $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: Scheme
# ----------------------------------------------------------------------

shapes:SchemeShape
  a sh:NodeShape ;
  sh:targetClass curric:Scheme ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every scheme must have exactly one rdfs:label." ;
    sh:message "Schemes must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:isSchemeOf ;
    sh:class curric:Subject ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is scheme of" ;
    sh:description "Every scheme must be part of exactly one subject." ;
    sh:message "Schemes must specify exactly one subject they belong to." ;
  ] ;

  sh:property [
    sh:path curric:coversKeyStage ;
    sh:class curric:KeyStage ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "covers key stage" ;
    sh:description "A scheme must cover exactly one key stage." ;
    sh:message "Schemes must specify exactly which key stage they cover." ;
  ] .

shapes:SchemeOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:Scheme ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Scheme is not used in any progression (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:Scheme .
        FILTER NOT EXISTS {
          ?progression a curric:Progression ;
                  curric:isProgressionOf $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: Progression
# ----------------------------------------------------------------------

shapes:ProgressionShape
  a sh:NodeShape ;
  sh:targetClass curric:Progression ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every progression must have exactly one rdfs:label." ;
    sh:message "Progressions must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:isProgressionOf ;
    sh:class curric:Scheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is progression of" ;
    sh:description "Every progression must be part of exactly one scheme." ;
    sh:message "Progressions must specify which scheme they belong to." ;
  ] ;

  sh:property [
    sh:path curric:coversYearGroup ;
    sh:class curric:YearGroup ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:name "covers year group" ;
    sh:description "A scheme may cover exactly one year group." ;
    sh:message "Progressions may specify a year group that they cover." ;
  ] ;

  sh:property [
    sh:path curric:coversSubStrand ;
    sh:class curric:SubStrand ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "covers sub-strand" ;
    sh:description "Every progression must cover exactly one sub-strand." ;
    sh:message "Progressions must specify exactly which sub-strand they cover." ;
  ] ;

  sh:property [
    sh:path curric:includesContentDescriptor ;
    sh:class curric:ContentDescriptor ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "has content descriptor" ;
    sh:description "Every progression should relate to at least one content descriptor." ;
    sh:message "Progressions should relate to at least one content descriptor (WARNING)." ;
  ] .

# ----------------------------------------------------------------------
# Shape: KnowledgeTaxonomy
# ----------------------------------------------------------------------

shapes:KnowledgeTaxonomyShape                                                                                                                     
  a sh:NodeShape ;                                                                                                                                   
  sh:targetClass curric:KnowledgeTaxonomy ;
                                                                                                                                                      
  sh:property [                                                                                                                                      
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;                                                                                                                     
    sh:languageIn ( "en" ) ;                                                                                                                       
    sh:minCount 1 ;                                                                                                                                  
    sh:maxCount 1 ;
    sh:name "preferred label" ;                                                                                                                      
    sh:description "Every knowledge taxonomy must have exactly one skos:prefLabel." ;                                                                
    sh:message "Knowledge taxonomies must have exactly one skos:prefLabel with English language tag." ;
  ] ;                                                                                                                                                
                                                                                                                                                    
  sh:property [                                                                                                                                      
    sh:path skos:hasTopConcept ;                                                                                                                   
    sh:class curric:Discipline ;                                                                                                                  
    sh:minCount 1 ;                                                                                                                                
    sh:name "has top concept" ;
    sh:description "Every knowledge taxonomy must have at least one Discipline as its top concept." ;                                                
    sh:message "Knowledge taxonomies must have at least one Discipline via skos:hasTopConcept." ;
  ] .

# ----------------------------------------------------------------------
# Shape: ThemesTaxonomy
# ----------------------------------------------------------------------

shapes:ThemesTaxonomyShape                                                                                                                        
  a sh:NodeShape ;                                                                                                                                 
  sh:targetClass curric:ThemesTaxonomy ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;                                                                                                                     
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;                                                                                                                                  
    sh:maxCount 1 ;                                                                                                                                
    sh:name "preferred label" ;
    sh:description "Every themes taxonomy must have exactly one skos:prefLabel." ;
    sh:message "Themes taxonomies must have exactly one skos:prefLabel with English language tag." ;                                                 
  ] ;
                                                                                                                                                      
  sh:property [                                                                                                                                    
    sh:path skos:hasTopConcept ;
    sh:class curric:Theme ;
    sh:minCount 1 ;                                                                                                                                  
    sh:name "has top concept" ;
    sh:description "Every themes taxonomy must have at least one Theme as its top concept." ;                                                        
    sh:message "Themes taxonomies must have at least one Theme via skos:hasTopConcept." ;                                                          
  ] .

# ----------------------------------------------------------------------
# Shape: Discipline
# ----------------------------------------------------------------------

shapes:DisciplineShape
  a sh:NodeShape ;
  sh:targetClass curric:Discipline ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "preferred label" ;
    sh:description "Every discipline must have exactly one skos:prefLabel." ;
    sh:message "Disciplines must have exactly one skos:prefLabel for SKOS taxonomy with English language tag." ;
  ] ;

  sh:property [
    sh:path skos:inScheme ;
    sh:class skos:ConceptScheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "in scheme" ;
    sh:description "Every discipline must be part of exactly one concept scheme." ;
    sh:message "Disciplines must specify which concept scheme they belong to." ;
  ] ;

  sh:property [
    sh:path skos:narrower ;
    sh:class curric:Strand ;
    sh:minCount 1 ;
    sh:name "narrower" ;
    sh:description "A discipline must have at least one child strand." ;
    sh:message "Disciplines must have at least one strand." ;
  ] .

# ----------------------------------------------------------------------
# Shape: Strand
# ----------------------------------------------------------------------

shapes:StrandShape
  a sh:NodeShape ;
  sh:targetClass curric:Strand ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "preferred label" ;
    sh:description "Every strand must have exactly one skos:prefLabel." ;
    sh:message "Strands must have exactly one skos:prefLabel for SKOS taxonomy with English language tag." ;
  ] ;

  sh:property [
    sh:path skos:inScheme ;
    sh:class skos:ConceptScheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "in scheme" ;
    sh:description "Every strand must be part of exactly one concept scheme." ;
    sh:message "Strands must specify which concept scheme they belong to." ;
  ] ;

  sh:property [
    sh:path skos:broader ;
    sh:class curric:Discipline ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "broader" ;
    sh:description "Every strand must belong to exactly one discipline." ;
    sh:message "Strands must specify which discipline they belong to via skos:broader." ;
  ] ;

  sh:property [
    sh:path skos:narrower ;
    sh:class curric:SubStrand ;
    sh:minCount 1 ;
    sh:name "narrower" ;
    sh:description "A strand must have at least one child sub-strand." ;
    sh:message "Strands must have at least one sub-strand via skos:narrower." ;
  ] ;

  sh:sparql [
    sh:message "When a Strand is covered by more than one Subject, all those Subjects must belong to the same SubjectGroup." ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT DISTINCT $this WHERE {
        ?subject1 a curric:Subject ;
                  curric:coversStrand $this ;
                  curric:isSubjectOf ?group1 .
        ?subject2 a curric:Subject ;
                  curric:coversStrand $this ;
                  curric:isSubjectOf ?group2 .
        FILTER (?subject1 != ?subject2 && ?group1 != ?group2)
      }
    """ ;
  ] .

shapes:StrandOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:Strand ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Strand is not referenced by any subject (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:Strand .
        FILTER NOT EXISTS {
          ?subject a curric:Subject ;
                   curric:coversStrand $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: SubStrand
# ----------------------------------------------------------------------

shapes:SubStrandShape
  a sh:NodeShape ;
  sh:targetClass curric:SubStrand ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "preferred label" ;
    sh:description "Every sub-strand must have exactly one skos:prefLabel." ;
    sh:message "Sub-strands must have exactly one skos:prefLabel for SKOS taxonomy with English language tag." ;
  ] ;

  sh:property [
    sh:path skos:inScheme ;
    sh:class skos:ConceptScheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "in scheme" ;
    sh:description "Every sub-strand must be part of exactly one concept scheme." ;
    sh:message "Sub-strands must specify which concept scheme they belong to." ;
  ] ;

  sh:property [
    sh:path skos:broader ;
    sh:class curric:Strand ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "broader" ;
    sh:description "Every sub-strand must belong to exactly one strand." ;
    sh:message "Sub-strands must specify which strand they belong to via skos:broader." ;
  ] ;

  sh:property [
    sh:path skos:narrower ;
    sh:class curric:ContentDescriptor ;
    sh:minCount 1 ;
    sh:name "narrower" ;
    sh:description "A sub-strand must have at least one child content descriptor." ;
    sh:message "Sub-strands must have at least one content descriptor." ;
  ] .

# ----------------------------------------------------------------------
# Shape: ContentDescriptor
# ----------------------------------------------------------------------

shapes:ContentDescriptorShape
  a sh:NodeShape ;
  sh:targetClass curric:ContentDescriptor ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "preferred label" ;
    sh:description "Every content descriptor must have exactly one skos:prefLabel." ;
    sh:message "Content descriptors must have exactly one skos:prefLabel for SKOS taxonomy with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:supportingGuidance ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:name "supporting guidance" ;
    sh:description "Every content descriptor may have supporting guidance." ;
    sh:message "Content descriptors may have supporting guidance with English language tag." ;
  ] ;

  sh:property [
    sh:path skos:inScheme ;
    sh:class skos:ConceptScheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "in scheme" ;
    sh:description "Every content descriptor must be part of exactly one concept scheme." ;
    sh:message "Content descriptors must specify which concept scheme they belong to." ;
  ] ;

  sh:property [
    sh:path skos:broader ;
    sh:class curric:SubStrand ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "broader" ;
    sh:description "Every content descriptor must belong to exactly one sub-strand." ;
    sh:message "Content descriptors must specify which sub-strand they belong to via skos:broader." ;
  ] ;

  sh:property [
    sh:path skos:narrower ;
    sh:class curric:SubContentDescriptor ;
    sh:minCount 1 ;
    sh:name "narrower" ;
    sh:description "A content descriptor must have at least one child sub-content descriptor." ;
    sh:message "Content descriptors must have at least one sub-content descriptor via skos:narrower." ;
  ] .

shapes:ContentDescriptorOrphanWarningShape
  a sh:NodeShape ;
  sh:targetClass curric:ContentDescriptor ;
  sh:severity sh:Warning ;
  sh:sparql [
    sh:message "Content descriptor is not used in any progression (WARNING - orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:ContentDescriptor .
        FILTER NOT EXISTS {
          ?progression a curric:Progression ;
                  curric:includesContentDescriptor $this .
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: SubContentDescriptor
# ----------------------------------------------------------------------

shapes:SubContentDescriptorShape
  a sh:NodeShape ;
  sh:targetClass curric:SubContentDescriptor ;

  sh:property [
    sh:path skos:prefLabel ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "preferred label" ;
    sh:description "Every sub-content descriptor must have exactly one skos:prefLabel." ;
    sh:message "Sub-content descriptors must have exactly one skos:prefLabel for SKOS taxonomy." ;
  ] ;

  sh:property [
    sh:path curric:supportingGuidance ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:name "supporting guidance" ;
    sh:description "Every sub-content descriptor may have supporting guidance." ;
    sh:message "Sub-content descriptors may have supporting guidance with English language tag." ;
  ] ;

  sh:property [
    sh:path skos:inScheme ;
    sh:class skos:ConceptScheme ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "in scheme" ;
    sh:description "Every sub-content descriptor must be part of exactly one concept scheme." ;
    sh:message "Sub-content descriptors must specify which concept scheme they belong to." ;
  ] ;

  sh:property [
    sh:path skos:broader ;
    sh:class curric:ContentDescriptor ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "broader" ;
    sh:description "Every sub-content descriptor must belong to exactly one content descriptor." ;
    sh:message "Sub-content descriptors must specify which content descriptor they belong to via skos:broader." ;
  ] .
  
# ----------------------------------------------------------------------
# Shape: Programme
# ----------------------------------------------------------------------

shapes:ProgrammeShape
  a sh:NodeShape ;
  sh:targetClass curric:Programme ;

  sh:property [
    sh:path curric:coversYearGroup ;
    sh:class curric:YearGroup ;
    sh:minCount 1 ;
    sh:name "covers year group" ;
    sh:description "A programme must cover at least one year group." ;
    sh:message "Every programme must specify at least one year group." ;
  ] ;

  sh:property [
    sh:path curric:hasExamBoard ;
    sh:class curric:ExamBoard ;
    sh:maxCount 1 ;
    sh:name "has exam board" ;
    sh:description "A programme may have at most one exam board." ;
    sh:message "A programme can specify at most one exam board." ;
  ] ;

  sh:property [
    sh:path curric:hasTier ;
    sh:class curric:Tier ;
    sh:maxCount 1 ;
    sh:name "has tier" ;
    sh:description "A programme may have at most one tier." ;
    sh:message "A programme can specify at most one tier." ;
  ] ;

  sh:property [
    sh:path curric:hasUnitVariantInclusion ;
    sh:class curric:UnitVariantInclusion ;
    sh:minCount 1 ;
    sh:name "has unit variant inclusion" ;
    sh:description "A programme must have at least one unit variant inclusion." ;
    sh:message "A programme must include at least one unit variant inclusion to define its content." ;
  ] ;

  sh:property [
    sh:path curric:isNationalCurriculum ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is national curriculum" ;
    sh:description "Whether the programme delivers National Curriculum content." ;
  ] ;

  sh:property [
    sh:path curric:isRequired ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is required" ;
    sh:description "Whether the programme content is legally required for maintained schools." ;
  ] ;

  sh:property [
    sh:path curric:isExamined ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is examined" ;
    sh:description "Whether the programme is examined." ;
  ] ;

  sh:property [
    sh:path curric:examType ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "exam type" ;
    sh:description "Type of examination qualification. Present only for examined programmes." ;
  ] ;

  sh:property [
    sh:path curric:isProgrammeOf ;
    sh:class curric:Scheme ;
    sh:minCount 1 ;
    sh:name "is programme of" ;
    sh:description "Every programme must be part of at least one scheme." ;
    sh:message "Programmes must specify which scheme (e.g., English Key Stage 2) they belong to." ;
  ] ;

  sh:sparql [
    sh:message "isExamined=true → examType required" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:isExamined true .
        FILTER NOT EXISTS { $this curric:examType ?type }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "examType → isExamined=true" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:examType ?type .
        {
          $this curric:isExamined false .
        } UNION {
          FILTER NOT EXISTS { $this curric:isExamined ?examined }
        }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "hasExamBoard → isExamined=true" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:hasExamBoard ?board .
        {
          $this curric:isExamined false .
        } UNION {
          FILTER NOT EXISTS { $this curric:isExamined ?examined }
        }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "hasTier → isExamined=true" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:hasTier ?tier .
        {
          $this curric:isExamined false .
        } UNION {
          FILTER NOT EXISTS { $this curric:isExamined ?examined }
        }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "isExamined=false → examType not permitted" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:isExamined false .
        $this curric:examType ?type .
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "isExamined=false → hasExamBoard not permitted" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:isExamined false .
        $this curric:hasExamBoard ?board .
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: ExamBoard
# ----------------------------------------------------------------------

shapes:ExamBoardShape
  a sh:NodeShape ;
  sh:targetClass curric:ExamBoard ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every exam board must have exactly one rdfs:label." ;
    sh:message "Exam boards must have exactly one rdfs:label with English language tag." ;
  ] .

# ----------------------------------------------------------------------
# Shape: Tier
# ----------------------------------------------------------------------

shapes:TierShape
  a sh:NodeShape ;
  sh:targetClass curric:Tier ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every tier must have exactly one rdfs:label." ;
    sh:message "Tiers must have exactly one rdfs:label with English language tag." ;
  ] .

# ----------------------------------------------------------------------
# Shape: Unit
# ----------------------------------------------------------------------

shapes:UnitShape
  a sh:NodeShape ;
  sh:targetClass curric:Unit ;

  sh:property [
    sh:path curric:isUnitOf ;
    sh:class curric:Scheme ;
    sh:minCount 1 ;
    sh:name "is unit of" ;
    sh:description "Every unit must be part of at least one scheme (subject/key stage)." ;
    sh:message "Units must specify which scheme(s) they belong to." ;
  ] ;

  sh:property [
    sh:path [ sh:inversePath curric:isUnitVariantOf ] ;
    sh:class curric:UnitVariant ;
    sh:minCount 1 ;
    sh:name "has unit variant (via inverse)" ;
    sh:description "A unit must have at least one unit variant." ;
    sh:message "Every unit must have at least one unit variant to be teachable." ;
  ] ;

  sh:property [
    sh:path curric:includesThread ;
    sh:class curric:Thread ;
    sh:name "includes thread" ;
    sh:description "A unit may develop zero or more cross-cutting threads." ;
  ] ;

  sh:property [
    sh:path curric:includesContent ;
    sh:class curric:ContentDescriptor ;
    sh:name "includes content" ;
    sh:description "A unit may include zero or more content descriptors." ;
  ] ;

  sh:property [
    sh:path curric:whyThisWhyNow ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "why this why now" ;
    sh:description "Every unit must explain its pedagogical rationale." ;
    sh:message "Units must include a 'why this why now' explanation." ;
  ] ;

  sh:property [
    sh:path curric:hasPriorKnowledgeRequirement ;
    sh:class curric:PriorKnowledgeRequirement ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "has prior knowledge requirement" ;
    sh:description "Every unit should have at least one prior knowledge requirement." ;
    sh:message "Unit has no prior knowledge requirements (data may be missing upstream)." ;
  ] ;

  sh:property [
    sh:path curric:slug ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "slug" ;
    sh:description "Every unit must have exactly one URL-safe application slug." ;
    sh:message "Units must have exactly one curric:slug as a string." ;
  ] ;

  sh:sparql [
    sh:message "Unit is not used in any programme (all its unit variants are orphaned)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT DISTINCT $this WHERE {
        $this curric:hasUnitVariant ?unitvariant .
        FILTER NOT EXISTS {
          {
            ?inclusion curric:includesUnitVariant ?unitvariant .
          } UNION {
            ?choice curric:hasUnitVariantOption ?unitvariant .
          }
        }
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: UnitVariant
# ----------------------------------------------------------------------

shapes:UnitVariantShape
  a sh:NodeShape ;
  sh:targetClass curric:UnitVariant ;

  sh:property [
    sh:path curric:isUnitVariantOf ;
    sh:class curric:Unit ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "is unit variant of" ;
    sh:description "A unit variant must reference its parent unit." ;
  ] ;

  sh:property [
    sh:path curric:hasLessonInclusion ;
    sh:class curric:LessonInclusion ;
    sh:minCount 1 ;
    sh:name "has lesson inclusion" ;
    sh:description "A unit variant must have at least one lesson inclusion." ;
    sh:message "Every unit variant must include at least one lesson to be teachable." ;
  ] ;

  # Orphan check as a native constraint: at least one incoming reference via
  # either includesUnitVariant or hasUnitVariantOption. Equivalent to the
  # previous NOT EXISTS { ... UNION ... }, without a per-node SPARQL query.
  sh:property [
    sh:path [
      sh:alternativePath (
        [ sh:inversePath curric:includesUnitVariant ]
        [ sh:inversePath curric:hasUnitVariantOption ]
      )
    ] ;
    sh:minCount 1 ;
    sh:name "referenced by a programme" ;
    sh:description "A unit variant must be referenced by a unit variant inclusion or choice." ;
    sh:message "Unit variant is not used in any programme (not referenced by UnitVariantInclusion or UnitVariantChoice)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: UnitVariantInclusion
# ----------------------------------------------------------------------

shapes:UnitVariantInclusionShape
  a sh:NodeShape ;
  sh:targetClass curric:UnitVariantInclusion ;

  sh:property [
    sh:path curric:includesUnitVariant ;
    sh:class curric:UnitVariant ;
    sh:maxCount 1 ;
    sh:name "includes unit variant" ;
    sh:description "A unit variant inclusion may directly include at most one unit variant." ;
    sh:message "Use includesUnitVariant for single unit variants or includesUnitVariantChoice for multiple options, not both." ;
  ] ;

  sh:property [
    sh:path curric:includesUnitVariantChoice ;
    sh:class curric:UnitVariantChoice ;
    sh:maxCount 1 ;
    sh:name "includes unit variant choice" ;
    sh:description "A unit variant inclusion may include at most one unit variant choice group." ;
    sh:message "Use includesUnitVariantChoice for multiple options or includesUnitVariant for single unit variants, not both." ;
  ] ;

  sh:property [
    sh:path curric:sequencePosition ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "sequence position" ;
    sh:description "Every unit variant inclusion must have exactly one sequence position." ;
    sh:message "A unit variant inclusion must specify exactly one sequence position as a positive integer." ;
  ] ;

  # Sequence-position checks (unique + consecutive) are evaluated per programme
  # in shapes:ProgrammeSequenceShape rather than once per inclusion here — same
  # detection, far fewer focus nodes and no redundant per-sibling re-computation.

  sh:property [
    sh:path curric:minChoices ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:name "minimum choices" ;
    sh:description """Minimum number of unit variants to select from a choice. Only used with
    includesUnitVariantChoice.""" ;
  ] ;

  sh:property [
    sh:path curric:maxChoices ;
    sh:datatype xsd:positiveInteger ;
    sh:name "maximum choices" ;
    sh:description """Maximum number of unit variants to select from a choice. Only used with
    includesUnitVariantChoice.""" ;
  ] ;

  sh:sparql [
    sh:message "A unit variant inclusion must have either includesUnitVariant OR includesUnitVariantChoice, but not both" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this a curric:UnitVariantInclusion .

        # Count how many inclusion properties exist
        BIND(
          (IF(EXISTS { $this curric:includesUnitVariant ?v }, 1, 0) +
           IF(EXISTS { $this curric:includesUnitVariantChoice ?c }, 1, 0))
          AS ?count
        )

        # Must be exactly 1
        FILTER (?count != 1)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "minChoices should only be used when includesUnitVariantChoice is present" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:minChoices ?min .
        FILTER NOT EXISTS { $this curric:includesUnitVariantChoice ?choice }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "maxChoices should only be used when includesUnitVariantChoice is present" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:maxChoices ?max .
        FILTER NOT EXISTS { $this curric:includesUnitVariantChoice ?choice }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "When using includesUnitVariantChoice, minChoices is required" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:includesUnitVariantChoice ?choice .
        FILTER NOT EXISTS { $this curric:minChoices ?min }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "When using includesUnitVariantChoice, maxChoices is required" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:includesUnitVariantChoice ?choice .
        FILTER NOT EXISTS { $this curric:maxChoices ?max }
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "minChoices cannot be greater than maxChoices" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:minChoices ?min ;
              curric:maxChoices ?max .
        FILTER (?min > ?max)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "minChoices cannot exceed the number of available unit variant options" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        $this curric:includesUnitVariantChoice ?choice ;
              curric:minChoices ?min .

        # Count options in the choice, including $this
        {
          SELECT $this ?choice (COUNT(?option) AS ?numOptions) WHERE {
            $this curric:includesUnitVariantChoice ?choice .
            ?choice curric:hasUnitVariantOption ?option .
          }
          GROUP BY $this ?choice
        }

        FILTER (?min > ?numOptions)
      }
    """ ;
  ] ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?programme curric:hasUnitVariantInclusion $this }).
  sh:property [
    sh:path [ sh:inversePath curric:hasUnitVariantInclusion ] ;
    sh:minCount 1 ;
    sh:name "used by a programme" ;
    sh:description "A unit variant inclusion must be used by at least one programme." ;
    sh:message "Unit variant inclusion is not used in any programme (orphaned)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: LessonInclusion
# ----------------------------------------------------------------------

shapes:LessonInclusionShape
  a sh:NodeShape ;
  sh:targetClass curric:LessonInclusion ;

  sh:property [
    sh:path curric:includesLesson ;
    sh:class curric:Lesson ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "includes lesson" ;
    sh:description "A lesson inclusion must reference exactly one Lesson resource." ;
    sh:message "Every lesson inclusion must specify exactly one lesson." ;
  ] ;

  sh:property [
    sh:path curric:sequencePosition ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "sequence position" ;
    sh:description "Every lesson inclusion must have exactly one sequence position." ;
    sh:message "A lesson inclusion must specify exactly one sequence position as a positive integer." ;
  ] ;

  # Sequence-position checks (unique + consecutive) are evaluated per unit
  # variant in shapes:UnitVariantSequenceShape rather than once per inclusion
  # here — same detection, far fewer focus nodes and no redundant re-computation.

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?unitvariant curric:hasLessonInclusion $this }).
  sh:property [
    sh:path [ sh:inversePath curric:hasLessonInclusion ] ;
    sh:minCount 1 ;
    sh:name "used by a unit variant" ;
    sh:description "A lesson inclusion must be used by at least one unit variant." ;
    sh:message "Lesson inclusion is not used in any unit variant (orphaned)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: UnitVariantChoice
# ----------------------------------------------------------------------

shapes:UnitVariantChoiceShape
  a sh:NodeShape ;
  sh:targetClass curric:UnitVariantChoice ;

  sh:property [
    sh:path curric:hasUnitVariantOption ;
    sh:class curric:UnitVariant ;
    sh:minCount 2 ;
    sh:name "unit variant option" ;
    sh:description "A unit variant choice must have at least two unit variant options." ;
    sh:message "A unit variant choice must provide at least two options for selection." ;
  ] ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?inclusion curric:includesUnitVariantChoice $this }).
  sh:property [
    sh:path [ sh:inversePath curric:includesUnitVariantChoice ] ;
    sh:minCount 1 ;
    sh:name "used by a unit variant inclusion" ;
    sh:description "A unit variant choice must be used by at least one unit variant inclusion." ;
    sh:message "Unit variant choice is not used in any unit variant inclusion (orphaned)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: Thread
# ----------------------------------------------------------------------

shapes:ThreadShape
  a sh:NodeShape ;
  sh:targetClass curric:Thread ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?unit curric:includesThread $this }).
  sh:property [
    sh:path [ sh:inversePath curric:includesThread ] ;
    sh:minCount 1 ;
    sh:name "included by a unit" ;
    sh:description "A thread must be included by at least one unit." ;
    sh:message "Thread is not included by any unit (orphaned resource)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: Keyword
# ----------------------------------------------------------------------

shapes:KeywordShape
  a sh:NodeShape ;
  sh:targetClass curric:Keyword ;

  sh:property [
    sh:path schema:name ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "name" ;
    sh:description "Every keyword must have exactly one schema:name with a language tag." ;
    sh:message "Keywords must have exactly one schema:name with a language tag." ;
  ] ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?lesson curric:hasKeyword $this }).
  sh:property [
    sh:path [ sh:inversePath curric:hasKeyword ] ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "referenced by a lesson" ;
    sh:description "A keyword should be referenced by at least one lesson." ;
    sh:message "Keyword is not referenced by any lesson (WARNING - orphaned)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: Misconception
# ----------------------------------------------------------------------

shapes:MisconceptionShape
  a sh:NodeShape ;
  sh:targetClass curric:Misconception ;

  sh:property [
    sh:path curric:statement ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "statement" ;
    sh:description "Every misconception must have exactly one statement." ;
    sh:message "Misconceptions must have exactly one statement describing the misconception." ;
  ] ;

  sh:property [
    sh:path curric:correction ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "correction" ;
    sh:description "Every misconception must have exactly one correction." ;
    sh:message "Misconceptions must have exactly one correction explaining the correct understanding." ;
  ] ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?lesson curric:hasMisconception $this }).
  sh:property [
    sh:path [ sh:inversePath curric:hasMisconception ] ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "referenced by a lesson" ;
    sh:description "A misconception should be referenced by at least one lesson." ;
    sh:message "Misconception is not referenced by any lesson (WARNING - orphaned)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: KeyLearningPoint
# ----------------------------------------------------------------------

shapes:KeyLearningPointShape
  a sh:NodeShape ;
  sh:targetClass curric:KeyLearningPoint ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every key learning point must have exactly one rdfs:label." ;
    sh:message "Key learning points must have exactly one rdfs:label." ;
  ] ;

  # Orphan check as native inverse-path minCount: one index pass instead of a
  # SPARQL query per focus node. Equivalent to the previous
  # FILTER NOT EXISTS { ?lesson curric:hasKeyLearningPoint $this }.
  sh:property [
    sh:path [ sh:inversePath curric:hasKeyLearningPoint ] ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:name "referenced by a lesson" ;
    sh:description "A key learning point should be referenced by at least one lesson." ;
    sh:message "Key learning point is not referenced by any lesson (WARNING - orphaned)" ;
  ] .

