# ----------------------------------------------------------------------
# Shape: Lesson
# ----------------------------------------------------------------------

shapes:LessonShape
  a sh:NodeShape ;
  sh:targetClass curric:Lesson ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:languageIn ( "en" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "label" ;
    sh:description "Every lesson must have exactly one rdfs:label." ;
    sh:message "Lessons must have exactly one rdfs:label with English language tag." ;
  ] ;

  sh:property [
    sh:path curric:id ;
    sh:datatype xsd:positiveInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "identifier" ;
    sh:description "Every lesson must have exactly one numeric identifier." ;
    sh:message "Lessons must have exactly one curric:id as a positive integer." ;
  ] ;

  sh:property [
    sh:path curric:slug ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:name "slug" ;
    sh:description "Every lesson must have exactly one URL-safe application slug." ;
    sh:message "Lessons must have exactly one curric:slug as a string." ;
  ] ;

  sh:property [
    sh:path curric:hasKeyword ;
    sh:class curric:Keyword ;
    sh:minCount 1 ;
    sh:name "has keyword" ;
    sh:description "Every lesson must have at least one keyword." ;
    sh:message "Lessons must have at least one keyword." ;
  ] ;

  sh:property [
    sh:path curric:hasMisconception ;
    sh:class curric:Misconception ;
    sh:minCount 0 ;
    sh:name "has misconception" ;
    sh:description "Every lesson must address at least one misconception (RULE CURRENTLY DISABLED - CHANGE MINCOUNT TO 1 TO RE-ENABLE)." ;
    sh:message "Lessons must address at least one misconception (RULE CURRENTLY DISABLED - CHANGE MINCOUNT TO 1 TO RE-ENABLE)." ;
  ] ;

  sh:property [
    sh:path curric:hasKeyLearningPoint ;
    sh:class curric:KeyLearningPoint ;
    sh:minCount 1 ;
    sh:name "has key learning point" ;
    sh:description "Every lesson must have at least one key learning point." ;
    sh:message "Lessons must have at least one key learning point." ;
  ] ;

  sh:property [
    sh:path curric:hasPupilLessonOutcome ;
    sh:class curric:PupilLessonOutcome ;
    sh:minCount 1 ;
    sh:name "has pupil lesson outcome" ;
    sh:description "Every lesson must have at least one pupil lesson outcome." ;
    sh:message "Lessons must have at least one pupil lesson outcome." ;
  ] ;

  # Orphan check as native inverse-path minCount (was
  # FILTER NOT EXISTS { ?inclusion curric:includesLesson $this }).
  sh:property [
    sh:path [ sh:inversePath curric:includesLesson ] ;
    sh:minCount 1 ;
    sh:name "referenced by a lesson inclusion" ;
    sh:description "A lesson must be referenced by at least one lesson inclusion." ;
    sh:message "Lesson is not referenced by any lesson inclusion (orphaned resource)" ;
  ] .

# ----------------------------------------------------------------------
# Shape: UnitVariant sequence positions (container-scoped)
# ----------------------------------------------------------------------
# These checks are relational (they compare sibling inclusions), so they stay
# in SPARQL — but they are evaluated once per unit variant (the container),
# not once per lesson inclusion. This cuts focus nodes from ~15k inclusions to
# ~2k variants and removes the redundant re-scan of a variant once per sibling.

shapes:UnitVariantSequenceShape
  a sh:NodeShape ;
  sh:targetClass curric:UnitVariant ;

  sh:sparql [
    sh:message "Sequence positions must be unique within a unit variant" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT DISTINCT $this WHERE {
        $this curric:hasLessonInclusion ?a, ?b .
        ?a curric:sequencePosition ?pos .
        ?b curric:sequencePosition ?pos .
        FILTER (?a != ?b)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "Sequence positions must be consecutive within a unit variant (no gaps allowed)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        {
          SELECT $this (MIN(?pos) AS ?minPos) (MAX(?pos) AS ?maxPos) (COUNT(DISTINCT ?pos) AS ?count) WHERE {
            $this curric:hasLessonInclusion ?inclusion .
            ?inclusion curric:sequencePosition ?pos .
          }
          GROUP BY $this
        }
        FILTER (?count != (?maxPos - ?minPos + 1))
      }
    """ ;
  ] .

# ----------------------------------------------------------------------
# Shape: Programme sequence positions (container-scoped)
# ----------------------------------------------------------------------
# As above, evaluated once per programme rather than once per unit variant
# inclusion.

shapes:ProgrammeSequenceShape
  a sh:NodeShape ;
  sh:targetClass curric:Programme ;

  sh:sparql [
    sh:message "Sequence positions must be unique within a programme" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT DISTINCT $this WHERE {
        $this curric:hasUnitVariantInclusion ?a, ?b .
        ?a curric:sequencePosition ?pos .
        ?b curric:sequencePosition ?pos .
        FILTER (?a != ?b)
      }
    """ ;
  ] ;

  sh:sparql [
    sh:message "Sequence positions must be consecutive within a programme (no gaps allowed)" ;
    sh:select """
      PREFIX curric: <https://w3id.org/uk/oak/curriculum/ontology/>
      SELECT $this WHERE {
        {
          SELECT $this (MIN(?pos) AS ?minPos) (MAX(?pos) AS ?maxPos) (COUNT(DISTINCT ?pos) AS ?count) WHERE {
            $this curric:hasUnitVariantInclusion ?inclusion .
            ?inclusion curric:sequencePosition ?pos .
          }
          GROUP BY $this
        }
        FILTER (?count != (?maxPos - ?minPos + 1))
      }
    """ ;
  ] .
