  schema:description "A natural environment is a place that has not been changed by humans."@en ;
  dcterms:modified "2026-02-12T08:59:15.791635Z"^^xsd:dateTime .

oak:keyword-landscape
  a oakcurric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """A landscape is an area and its landforms and features that can be seen when viewed from another place."""@en ;
