  dcterms:modified "2026-02-12T08:59:15.817886Z"^^xsd:dateTime .

oak:keyword-farming
  a oakcurric:Keyword ;
  schema:name "farming"@en ;
  schema:description """Farming is the growing and harvesting of crops or rearing animals for food or raw materials."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818019Z"^^xsd:dateTime .

oak:keyword-farmer
  a oakcurric:Keyword ;
  schema:name "farmer"@en ;
  schema:description """A farmer is a person who grows and harvests crops or rears animals for food or raw materials."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818024Z"^^xsd:dateTime .

oak:keyword-crossroads
  a oakcurric:Keyword ;
