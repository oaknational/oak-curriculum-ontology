  schema:description """Water supply means the water from lakes, rivers and reservoirs that is carried by pipes to homes and businesses for daily use."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815320Z"^^xsd:dateTime .

oak:keyword-national-park
  a oakcurric:Keyword ;
