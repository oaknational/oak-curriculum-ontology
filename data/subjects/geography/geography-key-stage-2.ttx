  dcterms:modified "2026-02-12T08:59:15.791687Z"^^xsd:dateTime .

oak:keyword-settlement
  a oakcurric:Keyword ;
  schema:name "settlement"@en ;
  schema:description "A settlement is a place where people live and often work."@en ;
  dcterms:modified "2026-02-12T08:59:15.791738Z"^^xsd:dateTime .

oak:keyword-misconception
  a oakcurric:Keyword ;
