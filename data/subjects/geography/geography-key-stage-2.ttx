  dcterms:modified "2026-02-12T08:59:15.820250Z"^^xsd:dateTime .

oak:keyword-peak
  a oakcurric:Keyword ;
  schema:name "peak"@en ;
  schema:description "A peak is the highest point of a mountain."@en ;
  dcterms:modified "2026-02-12T08:59:15.820525Z"^^xsd:dateTime .

oak:keyword-arte
  a oakcurric:Keyword ;
  schema:name "arête"@en ;
  schema:description "An arête is a narrow ridge of rock between two valleys."@en ;
  dcterms:modified "2026-02-12T08:59:15.820529Z"^^xsd:dateTime .

oak:keyword-in-season
  a oakcurric:Keyword ;
  schema:name "in season"@en ;
  schema:description "In season means the time of year when a food is naturally ready for harvesting"@en ;
  dcterms:modified "2026-02-12T08:59:15.820621Z"^^xsd:dateTime .

oak:keyword-tropical-rainforest
  a oakcurric:Keyword ;
  schema:name "tropical rainforest"@en ;
  schema:description """areas of dense forest found close to the Equator where it is warm and there are high levels of rainfall"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820732Z"^^xsd:dateTime .

oak:keyword-interview
  a oakcurric:Keyword ;
  schema:name "interview"@en ;
  schema:description "An interview means talking to people to gather information."@en ;
  dcterms:modified "2026-02-12T08:59:15.820851Z"^^xsd:dateTime .

oak:keyword-solar-energy
  a oakcurric:Keyword ;
