  schema:description """Digital mapping tools allow us zoom in on places to investigate features using online maps."""@en ;
  dcterms:modified "2026-02-12T08:59:15.826909Z"^^xsd:dateTime .

oak:keyword-facilities
  a oakcurric:Keyword ;
  schema:name "facilities"@en ;
  schema:description """A facility is a building, piece of equipment or place that is used for an activity or purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827282Z"^^xsd:dateTime .

oak:keyword-tarn
