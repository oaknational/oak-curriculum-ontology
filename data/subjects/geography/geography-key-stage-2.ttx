  schema:description """The Prime Meridian is the line of longitude at 0 degrees, from which the other lines of longitude are measured east and west."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822235Z"^^xsd:dateTime .

oak:keyword-forest
  a oakcurric:Keyword ;
  schema:name "forest"@en ;
  schema:description "A forest is a large area full of trees"@en ;
  dcterms:modified "2026-02-12T08:59:15.822239Z"^^xsd:dateTime .

oak:keyword-conifer
  a oakcurric:Keyword ;
  schema:name "conifer"@en ;
  schema:description """Conifers are a group of trees and shrubs, usually evergreen, that have fruit called cones, and needle or scale-shaped leaves"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822246Z"^^xsd:dateTime .

oak:keyword-boundary
  a oakcurric:Keyword ;
  schema:name "boundary"@en ;
  schema:description """A boundary is a physical or imaginary line that marks the edge of a particular area"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822250Z"^^xsd:dateTime .

oak:keyword-aquifer
  a oakcurric:Keyword ;
  schema:name "aquifer"@en ;
  schema:description "Aquifers are porous rocks that can store and filter water."@en ;
  dcterms:modified "2026-02-12T08:59:15.822255Z"^^xsd:dateTime .

oak:keyword-pipeline
  a oakcurric:Keyword ;
  schema:name "pipeline"@en ;
  schema:description """Pipelines transfer something from one place to another, usually a liquid or a gas."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822261Z"^^xsd:dateTime .

oak:keyword-earths-crust
  a oakcurric:Keyword ;
  schema:name "Earth’s crust"@en ;
  schema:description "Earth’s crust is the outermost layer of our planet."@en ;
  dcterms:modified "2026-02-12T08:59:15.822313Z"^^xsd:dateTime .

oak:keyword-shock-waves
  a oakcurric:Keyword ;
  schema:name "shock waves"@en ;
  schema:description """Shock waves are areas of sudden high pressure or temperature that travel through water, air or the ground."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822320Z"^^xsd:dateTime .

oak:keyword-biased-data
  a oakcurric:Keyword ;
  schema:name "biased data"@en ;
  schema:description "data that has been unfairly influenced by someone's personal opinion or actions"@en ;
  dcterms:modified "2026-02-12T08:59:15.822325Z"^^xsd:dateTime .

oak:keyword-techniques
  a oakcurric:Keyword ;
  schema:name "techniques"@en ;
  schema:description "Techniques are the particular ways of doing things."@en ;
  dcterms:modified "2026-02-12T08:59:15.822329Z"^^xsd:dateTime .

oak:keyword-report
  a oakcurric:Keyword ;
  schema:name "report"@en ;
  schema:description """A report is a detailed written or spoken presentation, for example, of a geographical enquiry."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822338Z"^^xsd:dateTime .

oak:keyword-aid-organisation
  a oakcurric:Keyword ;
  schema:name "aid organisation"@en ;
  schema:description """Aid organisations are charities that respond to support countries following earthquakes, other natural disasters and wars."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822354Z"^^xsd:dateTime .

oak:keyword-dec
  a oakcurric:Keyword ;
  schema:name "DEC"@en ;
  schema:description """The Disaster Emergency Committee (DEC) brings together charities to provide support for countries affected by earthquakes and other disasters."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822359Z"^^xsd:dateTime .

oak:keyword-aftershock
  a oakcurric:Keyword ;
  schema:name "aftershock"@en ;
  schema:description """An aftershock is a smaller earthquake following after an initial larger earthquake."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822363Z"^^xsd:dateTime .

oak:keyword-strengths
  a oakcurric:Keyword ;
  schema:name "strengths"@en ;
  schema:description """areas of the fieldwork enquiry that went to plan and help answer the enquiry question"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822387Z"^^xsd:dateTime .

oak:keyword-weaknesses
  a oakcurric:Keyword ;
  schema:name "weaknesses"@en ;
  schema:description "areas of the fieldwork enquiry that did not go to plan"@en ;
  dcterms:modified "2026-02-12T08:59:15.822391Z"^^xsd:dateTime .

oak:keyword-deciduous
  a oakcurric:Keyword ;
  schema:name "deciduous"@en ;
  schema:description """Deciduous trees and shrubs lose all their leaves in autumn and winter and grow new leaves in spring"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822396Z"^^xsd:dateTime .

oak:keyword-climate-zone
  a oakcurric:Keyword ;
  schema:name "climate zone"@en ;
  schema:description """Climate zones are areas that have similar weather conditions and climate, e.g. the tropics"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822400Z"^^xsd:dateTime .

oak:keyword-evergreen
  a oakcurric:Keyword ;
  schema:name "evergreen"@en ;
  schema:description "Evergreen trees and shrubs keep their leaves all year round"@en ;
  dcterms:modified "2026-02-12T08:59:15.822404Z"^^xsd:dateTime .

oak:keyword-vegetation-belt
  a oakcurric:Keyword ;
