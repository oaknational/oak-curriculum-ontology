  dcterms:modified "2026-02-12T08:59:15.789740Z"^^xsd:dateTime .

oak:keyword-enquiry
  a oakcurric:Keyword ;
  schema:name "enquiry"@en ;
  schema:description """a way of learning new information about a place by following a set course of activities or tasks"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789900Z"^^xsd:dateTime .

oak:keyword-hypothesis
  a oakcurric:Keyword ;
