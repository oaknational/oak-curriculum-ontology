  dcterms:modified "2026-02-12T08:59:15.822093Z"^^xsd:dateTime .

oak:keyword-earthquake-proof
  a oakcurric:Keyword ;
  schema:name "earthquake-proof"@en ;
  schema:description "Something that is earthquake-proof can withstand the impact of earthquakes."@en ;
  dcterms:modified "2026-02-12T08:59:15.822097Z"^^xsd:dateTime .

oak:keyword-emergency-supplies
  a oakcurric:Keyword ;
  schema:name "emergency supplies"@en ;
