  schema:description "Vegetation belts are large areas in biomes that have similar plants"@en ;
  dcterms:modified "2026-02-12T08:59:15.822408Z"^^xsd:dateTime .

oak:keyword-seismic-waves
  a oakcurric:Keyword ;
  schema:name "seismic waves"@en ;
