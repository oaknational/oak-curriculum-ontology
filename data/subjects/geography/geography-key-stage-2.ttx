oak:keyword-tourist-attraction
  a oakcurric:Keyword ;
  schema:name "tourist attraction"@en ;
  schema:description "A tourist attraction is something that people travel to see or do."@en ;
  dcterms:modified "2026-02-12T08:59:15.822523Z"^^xsd:dateTime .

oak:keyword-human-geographical-feature
  a oakcurric:Keyword ;
  schema:name "human geographical feature"@en ;
