  dcterms:modified "2026-02-12T08:59:15.818243Z"^^xsd:dateTime .

oak:keyword-bridging-point
  a oakcurric:Keyword ;
  schema:name "bridging point"@en ;
  schema:description """A bridging point is the location on a river where it is possible to make a bridge to connect the two sides."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818247Z"^^xsd:dateTime .

oak:keyword-questionnaire
  a oakcurric:Keyword ;
