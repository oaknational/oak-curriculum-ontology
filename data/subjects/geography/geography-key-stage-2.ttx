oak:keyword-liquid
  a oakcurric:Keyword ;
  schema:name "liquid"@en ;
  schema:description """A liquid is a form of matter that can flow and does not have a specific shape like solid matter does."""@en ;
  dcterms:modified "2026-02-12T08:59:15.828235Z"^^xsd:dateTime .

oak:keyword-water-vapour
