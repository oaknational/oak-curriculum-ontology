  dcterms:modified "2026-02-12T08:59:15.822453Z"^^xsd:dateTime .

oak:keyword-futures
  a oakcurric:Keyword ;
  schema:name "futures"@en ;
  schema:description "Futures are periods of time that are yet to come."@en ;
  dcterms:modified "2026-02-12T08:59:15.822457Z"^^xsd:dateTime .

oak:keyword-northern-hemisphere
  a oakcurric:Keyword ;
  schema:name "northern hemisphere"@en ;
