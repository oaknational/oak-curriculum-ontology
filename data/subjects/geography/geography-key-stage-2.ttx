  schema:description """a natural source of energy that will never run out, such as flows of wind, water and solar energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791287Z"^^xsd:dateTime .

oak:keyword-sustainable
  a oakcurric:Keyword ;
  schema:name "sustainable"@en ;
