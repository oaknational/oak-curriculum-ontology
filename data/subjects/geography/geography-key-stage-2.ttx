  dcterms:modified "2026-02-12T08:59:15.789708Z"^^xsd:dateTime .

oak:keyword-migration
  a oakcurric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oak:keyword-globalisation
  a oakcurric:Keyword ;
