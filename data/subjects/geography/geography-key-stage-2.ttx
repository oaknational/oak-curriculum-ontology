  schema:description "Some farmers rear animals - they breed and raise them for food."@en ;
  dcterms:modified "2026-02-12T08:59:15.818549Z"^^xsd:dateTime .

oak:keyword-arable-farm
  a oakcurric:Keyword ;
  schema:name "arable farm"@en ;
  schema:description "Crops such as corn, vegetables, and rice are grown on arable farms."@en ;
  dcterms:modified "2026-02-12T08:59:15.818554Z"^^xsd:dateTime .

oak:keyword-pastoral-farm
  a oakcurric:Keyword ;
  schema:name "pastoral farm"@en ;
  schema:description "Animals are reared for products such as meat and dairy items on pastoral farms."@en ;
  dcterms:modified "2026-02-12T08:59:15.818558Z"^^xsd:dateTime .

oak:keyword-sustainable-farming
  a oakcurric:Keyword ;
  schema:name "sustainable farming"@en ;
  schema:description """Sustainable farming means growing crops and rearing animals in a way that damages the environment as little as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818562Z"^^xsd:dateTime .

oak:keyword-wildlife
  a oakcurric:Keyword ;
  schema:name "wildlife"@en ;
  schema:description """Wildlife refers to all living things that live in their natural habitat without human involvement."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818836Z"^^xsd:dateTime .

oak:keyword-generator
  a oakcurric:Keyword ;
  schema:name "generator"@en ;
  schema:description """A generator is a device that converts power      from motion (such as water) or fuel (such as fossil fuel) into electric power."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818849Z"^^xsd:dateTime .

oak:keyword-nuclear-power
  a oakcurric:Keyword ;
