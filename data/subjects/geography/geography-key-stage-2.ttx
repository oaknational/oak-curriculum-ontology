  schema:description """The course of a river is the path it takes from its source at the start to its mouth at the end"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815963Z"^^xsd:dateTime .

oak:keyword-climate-graph
  a oakcurric:Keyword ;
