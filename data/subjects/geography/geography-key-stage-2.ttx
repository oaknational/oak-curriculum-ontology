oak:keyword-climate
  a oakcurric:Keyword ;
  schema:name "climate"@en ;
  schema:description """the average weather conditions (such as rainfall and temperature) recorded over a 30-year period"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789680Z"^^xsd:dateTime .

oak:keyword-altitude
  a oakcurric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "the height above sea level"@en ;
  dcterms:modified "2026-02-12T08:59:15.789684Z"^^xsd:dateTime .

oak:keyword-biome
  a oakcurric:Keyword ;
  schema:name "biome"@en ;
  schema:description "a large-scale global ecosystem, for example, a tropical rainforest"@en ;
  dcterms:modified "2026-02-12T08:59:15.789699Z"^^xsd:dateTime .

oak:keyword-distribution
  a oakcurric:Keyword ;
  schema:name "distribution"@en ;
  schema:description """the spread (which may have a regular pattern) of, for example, a type of vegetation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789704Z"^^xsd:dateTime .

oak:keyword-latitude
  a oakcurric:Keyword ;
