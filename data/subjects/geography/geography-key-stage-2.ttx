  schema:description """The tourism industry is a term for the services provided for people who are on holiday, e.g. hotels, restaurants, tour guides, entertainment, transport, etc."""@en ;
  dcterms:modified "2026-02-12T08:59:15.791674Z"^^xsd:dateTime .

oak:keyword-tourist-destination
  a oakcurric:Keyword ;
