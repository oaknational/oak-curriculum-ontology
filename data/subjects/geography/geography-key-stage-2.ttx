oak:keyword-climate-zones
  a oakcurric:Keyword ;
  schema:name "climate zones"@en ;
  schema:description """Climate zones are areas that have similar weather conditions and climate, e.g. the tropics."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814579Z"^^xsd:dateTime .

oak:keyword-design
  a oakcurric:Keyword ;
  schema:name "design"@en ;
  schema:description "A design is a drawing or plan of something before it is made or built."@en ;
  dcterms:modified "2026-02-12T08:59:15.815097Z"^^xsd:dateTime .

oak:keyword-future
  a oakcurric:Keyword ;
  schema:name "future"@en ;
  schema:description "The future is a period of time that is yet to come."@en ;
  dcterms:modified "2026-02-12T08:59:15.815102Z"^^xsd:dateTime .

oak:keyword-fresh-water
  a oakcurric:Keyword ;
