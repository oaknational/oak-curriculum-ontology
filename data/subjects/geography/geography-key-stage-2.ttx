  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791137Z"^^xsd:dateTime .

oak:keyword-economy
  a oakcurric:Keyword ;
  schema:name "economy"@en ;
  schema:description "the economy is the way money in a particular area is made and spent"@en ;
  dcterms:modified "2026-02-12T08:59:15.791201Z"^^xsd:dateTime .

oak:keyword-inequality
  a oakcurric:Keyword ;
