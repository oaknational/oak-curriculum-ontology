  dcterms:modified "2026-02-12T08:59:15.822913Z"^^xsd:dateTime .

oak:keyword-human-features
  a oakcurric:Keyword ;
  schema:name "human features"@en ;
  schema:description "A human feature is something that humans have made or built."@en ;
  dcterms:modified "2026-02-12T08:59:15.822917Z"^^xsd:dateTime .

oak:keyword-physical-features
  a oakcurric:Keyword ;
