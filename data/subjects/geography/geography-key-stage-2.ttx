  schema:description """Greenwich Mean Time (GMT) is the time at the zero degree line of longitude, also known as the Prime Meridian."""@en ;
  dcterms:modified "2026-02-12T08:59:15.822231Z"^^xsd:dateTime .

oak:keyword-prime-meridian
