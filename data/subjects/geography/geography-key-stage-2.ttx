  dcterms:modified "2026-02-12T08:59:15.822206Z"^^xsd:dateTime .

oak:keyword-basemap
  a oakcurric:Keyword ;
  schema:name "basemap"@en ;
  schema:description "a background map in a GIS"@en ;
  dcterms:modified "2026-02-12T08:59:15.822210Z"^^xsd:dateTime .

oak:keyword-hectare
  a oakcurric:Keyword ;
  schema:name "hectare"@en ;
  schema:description "A hectare is a measurement of land. Each hectare is 10,000 square metres"@en ;
  dcterms:modified "2026-02-12T08:59:15.822214Z"^^xsd:dateTime .

oak:keyword-plate-boundaries
  a oakcurric:Keyword ;
  schema:name "plate boundaries"@en ;
  schema:description "The point where two tectonic plates meet is known as a plate boundary."@en ;
  dcterms:modified "2026-02-12T08:59:15.822218Z"^^xsd:dateTime .

oak:keyword-co-ordinated-universal-time
  a oakcurric:Keyword ;
