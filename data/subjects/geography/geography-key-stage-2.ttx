  dcterms:modified "2026-02-12T08:59:15.815312Z"^^xsd:dateTime .

oak:keyword-reservoir
  a oakcurric:Keyword ;
  schema:name "reservoir"@en ;
  schema:description "A reservoir is an artificial lake made by humans to store water."@en ;
