  dcterms:modified "2026-02-12T08:59:15.792413Z"^^xsd:dateTime .

oak:keyword-interpretation
  a oakcurric:Keyword ;
  schema:name "interpretation"@en ;
  schema:description "interpretation an explanation or opinion of what something means."@en ;
  dcterms:modified "2026-02-12T08:59:15.792432Z"^^xsd:dateTime .

oak:keyword-deposition
  a oakcurric:Keyword ;
