  schema:description "A physical geographical feature is natural and has not been built by humans."@en ;
  dcterms:modified "2026-02-12T08:59:15.822106Z"^^xsd:dateTime .

oak:keyword-time-zone
  a oakcurric:Keyword ;
  schema:name "time zone"@en ;
  schema:description "an area of the world that uses the same time"@en ;
  dcterms:modified "2026-02-12T08:59:15.822110Z"^^xsd:dateTime .

oak:keyword-timber
  a oakcurric:Keyword ;
  schema:name "timber"@en ;
  schema:description "Timber is wood that has been cut down and prepared for use in industries"@en ;
  dcterms:modified "2026-02-12T08:59:15.822184Z"^^xsd:dateTime .

oak:keyword-aerial-image
  a oakcurric:Keyword ;
