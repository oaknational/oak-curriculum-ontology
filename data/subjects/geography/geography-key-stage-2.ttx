# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oak:keylearningpoint-lesson-3229-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nearly a tenth (9%) of Great Britain is a National Park."@en ;
  dcterms:modified "2026-02-12T08:59:21.483240Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3229-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are 15 National Parks in the UK and each one is a protected landscape because of its special qualities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3229-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """National Parks are working landscapes as well as being environments of outstanding beauty and value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3229-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can be used to learn the locations of the National Parks of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.483252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9360-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Oceania has a range of physical features and landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.483295Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9360-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Oceania has some globally important tourist destinations."@en ;
  dcterms:modified "2026-02-12T08:59:21.483299Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9360-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tourism can provide many economic benefits but can also cause environmental problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483305Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3246-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A range of different sources of information is needed to develop a full picture of what a place is like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483380Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3246-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using different sources and types of information can help avoid misconceptions, stereotypes and misinformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483384Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3246-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are similarities and differences between northern Italy and my UK region."@en ;
  dcterms:modified "2026-02-12T08:59:21.483388Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3228-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Iceland is located on the Mid Atlantic Ridge where the North American and Eurasian tectonic plates diverge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3228-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The eruption of Eyjafjallajökull occurred on 14 April 2010 and continued for over one month."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483433Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3228-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Heat from the eruption caused the glacier covering Eyjafjallajökull to melt and the resulting flood water damaged roads."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3228-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ash from the eruption rose high into the atmosphere and grounded aircraft, impacting on the European economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483444Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3227-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One in twenty of the world’s population live close to an active volcano."@en ;
  dcterms:modified "2026-02-12T08:59:21.483586Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3227-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Advantages include the cultivation of fertile soils, income from tourism, mineral extraction and geothermal energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483591Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3227-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Disadvantages include the danger posed to people and communities from the eruption of lava, poisonous gases and ash."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483594Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3283-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sustainability can be defined as meeting the needs of today without preventing future generations from doing so."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483666Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3283-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is great inequality across the world about who gets what, where, when and why."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3283-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We have some power to enact some choices about where we go, how we get there, what we eat and what we do."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483674Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3245-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Venice is a city in north east Italy that is situated on 118 islands separated by canals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483698Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3245-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tourists are attracted to Venice because of its physical and human features."@en ;
  dcterms:modified "2026-02-12T08:59:21.483702Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3245-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Venice faces problems due to large numbers of tourists visiting."@en ;
  dcterms:modified "2026-02-12T08:59:21.483706Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3245-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There may be many different solutions to the threats facing Venice."@en ;
  dcterms:modified "2026-02-12T08:59:21.483710Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3195-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The longest river in the UK is the Severn and the largest flowing entirely in England is the Thames."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3195-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The longest rivers of England, Wales, Scotland and Northern Ireland can be found using the pages of an atlas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602978Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3195-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "OS map can be used to identify river features."@en ;
  dcterms:modified "2026-02-12T08:59:21.602990Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3195-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The River Severn has features such as waterfalls, meanders, towns and an estuary on its journey to the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603002Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3212-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historical maps can be used to find out the size of our local settlement in the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603326Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3212-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Maps can be used to find our settlement's current size and measure how much it has changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3212-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographical knowledge helps to explain why some parts of the locale have grown the most/least."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603341Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3216-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Places are not static and change over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.605299Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3216-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fieldwork carried out at different points during one day helps us understand change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3216-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Revisiting the same place early am, lunchtime and pm to gather data will show change over a day."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605318Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3281-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Activities at home and at school use different types and amounts of energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.606019Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3281-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Heating, lighting, cooking and heating water use lots of energy and can be monitored by meter readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606028Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3281-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different forms of transport use very differing amounts of energy, but active travel uses the least."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606036Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3281-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Reducing energy use can contribute to reducing the impacts of climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.606044Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20368-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "River flooding can cause short-term and long-term problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.607790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20368-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Digital maps can be used to show areas at risk from flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.607802Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20368-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The impacts of flooding can be reduced by warning people in advance."@en ;
  dcterms:modified "2026-02-12T08:59:21.607810Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20368-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The risks of river flooding can be reduced by building embankments and planting trees."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3324-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The UK has a range of landscapes,  settlement types, land uses and industries."@en ;
  dcterms:modified "2026-02-12T08:59:21.607855Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3324-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We can use maps and other data sources to investigate differences in life across the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607862Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3324-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We can use geographical skills to investigate differences across the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.607870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3295-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Natural resources are materials produced by the environment that humans can make use of."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608743Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3295-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """All of these natural resources are important to us and our daily lives, some are renewable and some are not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608750Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3295-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Natural resources are unequally distributed globally and people have unequal access to them, which can cause conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3295-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some resources, like food and water, are essential to life; others, like precious gem stones, are not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608765Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3275-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are potential costs and benefits to deforestation."@en ;
  dcterms:modified "2026-02-12T08:59:21.609401Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3275-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different stakeholders have different perspectives about whether to clear the rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609408Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3275-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A wide range of local and global factors influence decision making."@en ;
  dcterms:modified "2026-02-12T08:59:21.609415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3275-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Debates are a useful strategy for recognising and articulating different and conflicting points of view."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609422Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3319-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different types of goods are transported using different forms of transport."@en ;
  dcterms:modified "2026-02-12T08:59:21.617551Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3319-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different factors influence which mode of transport is used."@en ;
  dcterms:modified "2026-02-12T08:59:21.617557Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3319-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The place of origin, distance travelled, weight, perishability and value of products all influence transport choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617566Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3319-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Transporting goods long distances has costs as well as benefits."@en ;
  dcterms:modified "2026-02-12T08:59:21.617575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3319-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Greater food miles are worse for the environment and contribute towards global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9361-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are a range of landscapes, climates and biomes in Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.617851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9361-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Africa has a range of natural resources that are exported around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.617857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9361-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The mining and collection of Africa's natural resources is not always sustainable and ethical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9265-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The countries of the UK are divided into smaller areas known as regions and counties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9265-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can be used to identify the size and location of the UK's counties."@en ;
  dcterms:modified "2026-02-12T08:59:21.619078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9265-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The United Kingdom is made up of England, Scotland, Wales and Northern Ireland"@en ;
  dcterms:modified "2026-02-12T08:59:21.619084Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3225-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK's highest peaks are Ben Nevis (Scotland); Yr Wyddfa (Wales); Scafell Pike (England); Slieve Donard, (N. Ireland)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3225-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """OS maps depict key mountain features, e.g. the height of land, gradient, footpaths and tourist attractions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619235Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3316-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Global trade involves exporting goods from one country and importing them into other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3316-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Commodities are raw materials which can be bought and sold."@en ;
  dcterms:modified "2026-02-12T08:59:21.619795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3316-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Manufactured goods are things which have been made out of raw materials."@en ;
  dcterms:modified "2026-02-12T08:59:21.619804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3316-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Import and export data can be used to show the types and amounts of things different countries import and export."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3318-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Electronic devices have complex global supply chains."@en ;
  dcterms:modified "2026-02-12T08:59:21.620766Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3318-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The availability of natural resources, workers and transportation costs influence the location of manufacturing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620772Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3318-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The way some products are manufactured can lead to poor working conditions for people in different parts of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620778Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3204-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate is changing due to human activity releasing more greenhouse gases into the atmosphere, causing a climate crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621113Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3204-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate crisis means the world’s climate is changing faster than plants and animals (including humans) can adapt to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621119Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3204-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increased temperatures and changes to rainfall patterns threaten the food and freshwater supply for living things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621125Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3282-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Government can take action by passing laws and giving support and advice to individuals and businesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621456Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3282-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Businesses can take action by reducing their energy use, and through technological developments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621464Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3282-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Individuals can take lots of small actions which together add up to make a significant difference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621470Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3282-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Everyone, including children, can talk to other people and campaign for action to solve the energy problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3214-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fieldwork can include environmental assessment, e.g. what do we think about change here?"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3214-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Photographs can evidence changes that are happening."@en ;
  dcterms:modified "2026-02-12T08:59:21.621527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3214-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The work that people do can change the local area positively or negatively."@en ;
  dcterms:modified "2026-02-12T08:59:21.621532Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3214-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Changes spotted could be ranked as to how dramatic the effect is or will be."@en ;
  dcterms:modified "2026-02-12T08:59:21.621538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3307-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A coast is a strip of land made of rock, sand, mud or gravel, that meets the sea or ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3307-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK is surrounded by the North Atlantic Ocean, the North Sea, the Irish Sea, and the English Channel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622644Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3307-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK is a maritime nation which means the lives of people living here are connected to the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3307-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many large settlements around the world are on or near the coast."@en ;
  dcterms:modified "2026-02-12T08:59:21.622655Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3320-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are a number of ethical trading schemes, often identified by labelling on products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625097Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3320-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ethical trade aims to ensure the products that we buy don’t harm the environment, animals or people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625103Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3320-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ethical trade aims to make sure farmers are paid a fair price for their products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625111Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3320-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Governments, companies and consumers all have responsibility for ensuring ethical trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625116Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3315-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Contemporary global trade patterns are complex, linking us to people and places far away through everyday goods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625124Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3315-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Global trade connects us to other countries of the world. This is an example of globalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625130Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3315-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """World maps can be used to locate the countries where garments are made, and identify the spatial patterns revealed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3315-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The data collected, recorded and analysed can be communicated through a map and/or graphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625140Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3288-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most people now live in cities and by 2050, it is estimated more than two-thirds of the world will live in urban areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3288-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People generally have better access to energy, jobs and food in urban areas but human activity also causes pollution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626021Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3288-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cities can become more sustainable in their use of energy, transport, building and waste disposal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626026Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3288-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tiny, dense ‘Miyawaki’ forests are part of a movement aimed at restoring biodiversity and fighting the climate crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626032Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3284-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A carbon footprint is a measure of the carbon dioxide released into the atmosphere as a result of our activities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3284-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By adding more carbon dioxide to the atmosphere, people are supercharging the natural greenhouse effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626117Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3284-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Human activity is a major cause of rapid climate change; the main cause is burning fossil fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626122Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3284-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Calculating our carbon footprint helps us to measure our impact on the planet and plan our daily activities accordingly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3311-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The coastline is eroded by the actions of the wind, waves and human activity."@en ;
  dcterms:modified "2026-02-12T08:59:21.627131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3311-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Erosion can create landforms such as caves, arches and sea stacks."@en ;
  dcterms:modified "2026-02-12T08:59:21.627136Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3311-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hard rock is eroded slowly and creates headlands, soft rock erodes quickly and creates bays."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627141Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3311-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can be used to identify headlands and bays formed by hard and soft rock."@en ;
  dcterms:modified "2026-02-12T08:59:21.627146Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3232-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Milder winters and cooler summers than would normally be expected at this latitude (54-55 degrees north)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627151Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3232-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The climate is influenced by the sea, particularly the Gulf stream, with relief rainfall from prevailing westerlies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627156Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3232-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The climate and landscape suits hill farming with hardy sheep but it is hard to grow crops there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627161Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3232-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The temperature drops as altitude increases, meaning that the tops of the mountains are colder than the valleys."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627166Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3317-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Supermarkets have become the main way people shop for food."@en ;
  dcterms:modified "2026-02-12T08:59:21.627414Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3317-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many supermarkets in the UK are global companies which means they operate in different countries around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3317-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Supermarkets sell many different goods and food items, all of which have their own complex supply chains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627424Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3304-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The causes of insufficient access to food are complex."@en ;
  dcterms:modified "2026-02-12T08:59:21.629785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3304-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hunger can happen to people all over the world but there are more people going hungry in some countries than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3304-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are different ways to take action against hunger; some of these are short-term and some are long-term."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629794Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3304-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is important to listen to and consider the viewpoints of others when working in a group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3221-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migration is when people move from one place to another; the UK has a long history of people arriving and leaving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653410Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3221-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many reasons why people decide to move to a new country, or away from their country of birth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3221-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Net migration is the difference between immigration and emigration into the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.653420Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3221-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People from different backgrounds bring different cultural ideas and skills to their new home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653424Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3182-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Aerial images and maps can help us identify different types of land use; an easy example is housing"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3182-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Maps and keys help us identify industrial areas, fields, woods and built up areas with lots of roads"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657632Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3182-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Aerial images reveal patterns and colours in the landscape e.g. farmed areas may have uniform stripes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3182-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "OS maps at 1: 10000 and 1:25000 are useful scales to explore land use patterns"@en ;
  dcterms:modified "2026-02-12T08:59:21.657642Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3186-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK has lost on average about half of its biodiversity which is much more than many other countries in the world"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3186-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Biodiversity is the variety of all living things on Earth and how they fit together in the web of life"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657651Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3186-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Biodiversity is vital for food chains"@en ;
  dcterms:modified "2026-02-12T08:59:21.657655Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3186-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Something as simple as unmown verges can improve wildlife habitats for bees and other insects"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3203-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Animals and plants adapt to their environments."@en ;
  dcterms:modified "2026-02-12T08:59:21.657992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3203-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Animals and plants within a biome are interdependent."@en ;
  dcterms:modified "2026-02-12T08:59:21.657999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3203-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If a single plant or animal is removed from a biome, this will affect other plants and animals within the biome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3219-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The UK is linked to the rest of the world in many different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.659819Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3219-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Global links help to create the character of our local area."@en ;
  dcterms:modified "2026-02-12T08:59:21.659824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3219-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We can find global links in our own local area through fieldwork."@en ;
  dcterms:modified "2026-02-12T08:59:21.659828Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3189-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Humans need water to stay alive: for drinking, eating, washing, growing crops, energy production, trade and more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659832Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3189-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most settlements were built around rivers for access to fresh water and trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.659837Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3189-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People around the world do not have equal access to clean, safe water."@en ;
  dcterms:modified "2026-02-12T08:59:21.659841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3189-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lack of access to clean water has consequences for people including death and disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3181-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Human features are things that are made by people and physical features occur naturally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3181-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Human and physical features of the UK can be located using atlases and maps."@en ;
  dcterms:modified "2026-02-12T08:59:21.662493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3181-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Digital maps of the UK can be annotated by adding labels and photographs to show significant features."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662498Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3279-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy sources, e.g. fossil fuels, are those that cannot be replaced and will eventually run out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663158Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3279-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fossil fuels such as gas, oil and coal are transported across the globe by ships, lorries and pipelines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3279-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Burning fossil fuels releases carbon emissions into the atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.663167Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3279-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A way of reducing climate change is for countries to stop using non-renewable fossil fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663172Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3306-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Farming and food production have changed over time and there are advantages and disadvantages of these changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663177Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3306-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The world faces different challenges in producing enough food and these problems are being overcome in various ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663181Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3306-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Everyone can help make food systems fairer and better for our planet but some actions have a greater impact than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3306-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "It is useful to plan an action carefully before doing it."@en ;
  dcterms:modified "2026-02-12T08:59:21.663190Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3306-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are often different viewpoints about the causes and impacts of food issues, and potential solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663195Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3296-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sun, directly or indirectly, is the source of all energy on Earth: plants use energy to grow the food we eat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666100Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3296-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy sources are fossil fuels: coal, oil, natural gas, and the elements uranium and plutonium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666105Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3296-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Renewable energy sources include solar power, wind, wave and tidal energy, hydro-electric, biomass and geothermal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666109Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3296-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Non-renewable sources are unsustainable, polluting and a cause of rapid climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3285-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Energy use (electricity, heat and transport) account for more than 60% of carbon emissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667206Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3285-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Monitoring electricity usage around the school, i.e. where appliances are left on or on standby, can reduce energy use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667211Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3285-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Generating renewable energy creates far lower emissions than burning fossil fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3185-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The map of Great Britain is covered by grid squares measuring 100 kilometres across"""@en ;
  dcterms:modified "2026-02-12T08:59:21.669334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3185-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """OS maps have a series of grid lines that help you to pinpoint an exact location anywhere on the map"""@en ;
  dcterms:modified "2026-02-12T08:59:21.669339Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3185-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Vertical lines are called 'eastings' as they increase in value as you travel east on the map"""@en ;
  dcterms:modified "2026-02-12T08:59:21.669344Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3185-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The horizontal lines are called 'northings' as they increase in value as you travel north on the map"""@en ;
  dcterms:modified "2026-02-12T08:59:21.669349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3197-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Volga is in Russia and is the longest river in                                Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3197-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Major rivers in Europe include the Danube, the Dnieper, the Po, the Tagus, the Rhine and the Loire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671006Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3197-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rivers such as the Danube are important as they are a border between countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.671010Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3197-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers in Europe are important for transport, providing water and making hydro-electricity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671015Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3202-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some areas within a climate zone have similar plants and animals; we call this a biome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671106Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3202-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Biomes have a spatial pattern that can be mapped."@en ;
  dcterms:modified "2026-02-12T08:59:21.671110Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3202-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Key biomes of the world include rainforest, savannah, desert, temperate forest and tundra."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671115Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3210-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New settlements can be designed and built."@en ;
  dcterms:modified "2026-02-12T08:59:21.673647Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3210-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New settlements may need specific features to be fit for the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.673651Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3210-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographical ideas can be represented and shared by making maps and models."@en ;
  dcterms:modified "2026-02-12T08:59:21.673656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3210-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Settlements change and develop over time and will continue to change in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3312-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coastal habitats and their unique ecosystems are under threat from human activity and climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3312-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coastline settlements and industries impact on natural habitats affecting wildlife populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674817Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3312-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "River estuaries can be hot spots of pollution emptying into the oceans."@en ;
  dcterms:modified "2026-02-12T08:59:21.674822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3312-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eco-tourism is a way of trying to redress environmental damage by focusing on outcomes beneficial for wildlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674826Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6785-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Water resources across the world are unequal and influenced by patterns of climate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674831Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6785-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Global water use varies and is linked to latitude, climate, and amount of agriculture and industry in a place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674835Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6785-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Our use of water must be sustainable."@en ;
  dcterms:modified "2026-02-12T08:59:21.674840Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6785-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Existing water resources are becoming increasingly polluted through human activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3201-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate data can be presented in graphs in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.678963Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3201-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate graphs usually show rainfall and temperature over a period of time, often as monthly figures over a year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3201-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The climate in different climate zones has distinct patterns of rainfall and temperature throughout a year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678975Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3201-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate has an impact on where and how people live."@en ;
  dcterms:modified "2026-02-12T08:59:21.678980Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9867-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Families move within the UK for many different reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.681467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9867-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People often move to improve their quality of life, which can be measured in a number of ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681472Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9867-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People often move for economic reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.681477Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9867-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We can use maps to share stories about where we have moved."@en ;
  dcterms:modified "2026-02-12T08:59:21.681481Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3286-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Food production is responsible for about one-quarter of the world’s greenhouse gas emissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684450Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3286-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The highest carbon footprint per kilogram of food product comes from meat: beef, lamb then dairy top the list."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684457Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3286-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most food travels by boat not air."@en ;
  dcterms:modified "2026-02-12T08:59:21.684462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3286-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Wasting less food and lowering demand reduces carbon emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.684467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9868-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The census is a population survey carried out every ten years in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.684471Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9868-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The census shows that the UK's population changes all the time, partly due to migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9868-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People moving into the UK bring benefits to the country and change the nature of places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3191-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A rising population and growing industries mean demand for water increases but the amount of water on earth is the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3191-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nobody owns rainwater, but storing and transporting water, taking away wastewater and recycling it costs money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3191-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In many countries, like the UK, people have to pay for the water supply to their homes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3280-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Renewable sources of energy include solar, wind, wave and tidal energy, biomass, hydro-electric and geothermal energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687449Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3280-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different forms of renewable energy have advantages and disadvantages."@en ;
  dcterms:modified "2026-02-12T08:59:21.687454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3280-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Renewable energy sources can contribute to reducing carbon emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.687458Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3280-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some countries like Iceland and Costa Rica get nearly all their energy from renewable sources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3183-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Farmers in the UK use the seasons to plant their crops, and what they grow depends on weather conditions, land and soil"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688574Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3183-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "More than two thirds of land in the UK is used for farming"@en ;
  dcterms:modified "2026-02-12T08:59:21.688579Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3183-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK is colder in the north, warmer in the south and wetter in the west as most rain comes in from the Atlantic Ocean"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3183-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Poorer soils and colder conditions in hilly areas are best suited to sheep farming, and rich grassy soils to dairy"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688588Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3207-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many settlements have long histories, on sites chosen for resource access, for example: water, fertile land and wood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3207-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical geography can influence why settlements start, grow and change."@en ;
  dcterms:modified "2026-02-12T08:59:21.690264Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3207-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Human geography can influence why settlements start, grow and change."@en ;
  dcterms:modified "2026-02-12T08:59:21.690271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3278-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are big differences in the amount of energy used across the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.691049Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3278-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Manufacturing, farming, transport and domestic are all major areas of energy consumption."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691053Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3278-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are links between energy use, fossil fuels, carbon emissions and climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3305-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Farming and food production are major causes of climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.691547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3305-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """All of the stages of the journey of food, from where it is grown or made to our plates, have a carbon footprint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691551Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3305-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of food and stages of a food’s journey emit different amounts of greenhouse gases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691556Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3305-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many different ways to take action to reduce the carbon footprint of food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3230-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Lake District is a region of mountains and lakes in the north west of England and most of it is a National Park."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691567Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3230-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Park has all the land in England above 910 metres including the highest mountain in England, Scafell Pike."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691572Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3230-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wast Water, the deepest lake in England, and Windermere, the longest lake in England, are found here."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3194-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The width and depth of rivers get larger and the river gets faster as it flows from source to mouth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692557Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3194-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The rocks in the river usually get smaller as the river flows downstream."@en ;
  dcterms:modified "2026-02-12T08:59:21.692564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3194-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Landforms like waterfalls are usually found in the upper course of a river."@en ;
  dcterms:modified "2026-02-12T08:59:21.692570Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3194-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Landforms like meanders and floodplains are found in the middle and lower course of a river."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692574Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3298-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic minerals are useful or valuable solid substances that are found in the Earth's crust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692708Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3298-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Iron has been an important metal since ancient times; it is used for steel production but is now in short supply."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692713Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3298-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Non-metallic resources include feldspar and quartz, used for electronics, and sand which is used in construction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692717Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3298-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Extraction of these resources can pollute the ground and water supplies locally and damage landscapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692724Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3297-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The food we eat is derived from plants and animals and relies on other natural resources of energy, water, and soil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3297-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Large-scale food production can have a damaging effect on the planet."@en ;
  dcterms:modified "2026-02-12T08:59:21.692734Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3297-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """More sustainable farming practices are less harmful to the environment and plant and animal habitats."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692738Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3208-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """All settlements change and develop over time, with new roads, railway lines, homes and other buildings being developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693552Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3208-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Comparing old and modern photographs and maps of local streets and buildings reveal how they have changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693556Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3208-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers annotate maps and photographs to add information."@en ;
  dcterms:modified "2026-02-12T08:59:21.693561Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3208-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers make maps to show how some features of places have changed while other features have not changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693565Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3217-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Images of the UK can be used to investigate places and present geographical information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694928Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3217-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Images can show the similarities and differences between towns and cities across the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694937Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3217-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Images can show the similarities and differences between the physical landscape across the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694942Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3217-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stereotypical views are when people see a single story about people or places; they can be positive as well as negative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694946Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3184-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Houses and gardens take up 5% or just 5 out of our 100 squares"@en ;
  dcterms:modified "2026-02-12T08:59:21.694953Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3184-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Woods make up just 10% or one tenth, or ten of our hundred squares"@en ;
  dcterms:modified "2026-02-12T08:59:21.694958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3184-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """27%  or 27 squares out of the 100 are used for crops; half of this is fed to animals"""@en ;
  dcterms:modified "2026-02-12T08:59:21.694962Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3184-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """More than a quarter of land in the UK - 27% or 27 out of the 100 squares - is used for pasture for livestock"""@en ;
  dcterms:modified "2026-02-12T08:59:21.694967Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3277-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most electricity is produced in power stations and then cables deliver the energy to our houses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694991Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3277-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """About 40% of UK electricity was generated in power stations by burning fossil fuels, mainly gas, in 2022."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694996Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3277-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "About 16% of UK electricity was generated in nuclear power stations in 2022."@en ;
  dcterms:modified "2026-02-12T08:59:21.695000Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3277-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "About 37% of UK electricity was generated from renewable sources in 2022."@en ;
  dcterms:modified "2026-02-12T08:59:21.695005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3224-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A mountain is classified as over 600 metres high and groups of mountains form a range."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704232Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3224-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mountains have common physical features: peak, ridge or arete, tree line, snow line, glacier, scree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704236Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3224-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mount Everest, at 8848m, is the highest mountain on Earth and poses unique challenges for those who climb it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3300-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The foods routinely available in the UK have numerous places of origin around the world; many are imported."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3300-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Contemporary food production, processing and distribution systems are much more complex than those of the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704695Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3300-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are potential positive and negative impacts of contemporary food production, processing and distribution systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3199-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Earth rotates on a tilted axis as it orbits the sun."@en ;
  dcterms:modified "2026-02-12T08:59:21.707492Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3199-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sun’s energy is more concentrated near the Equator and spread out over a larger area near the poles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707497Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3199-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Average temperature across the Earth is related to how far from the Equator a place is located."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3199-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate is the average pattern of weather taken over a period of time, usually 30 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3199-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some areas of the world share a similar climate; we call these climate zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.707510Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3223-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earth’s crust is made from a series of tectonic plates, which constantly move, but so slowly that we don’t notice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707515Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3223-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mountains are formed when tectonic plates move towards each other, pushing the ground upwards, lifting and folding it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3223-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three common types of mountain: fold, fault-block and dome."@en ;
  dcterms:modified "2026-02-12T08:59:21.707524Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3223-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mountains are formed over millions of years during which time they are shaped by the action of weathering and erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707531Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3274-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different types of settlements are located in the Amazon rainforest."@en ;
  dcterms:modified "2026-02-12T08:59:21.707538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3274-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are similarities and differences between lifestyles in the Amazon rainforest and the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3274-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are a variety of challenges facing the Indigenous peoples living in the Amazon rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707548Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9359-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Antarctica and Asia have contrasting climates and are in different climate zones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9359-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Asia is the most populous continent on the planet whereas Antarctica has no permanent residents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708097Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9359-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate graphs can be used to investigate and compare different places."@en ;
  dcterms:modified "2026-02-12T08:59:21.708104Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3271-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The rainforest is a type of environment or biome, with a distinctive climate and ecosystem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710953Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3271-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The rainforest has four very different layers: forest floor, understory, canopy and emergent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710957Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3271-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The rainforest is a very important ecosystem and provides a habitat for millions of plant and animals, including humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710962Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3271-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different sources of information can be used to investigate the location and features of rainforests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710966Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3263-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Being prepared for an earthquake reduces its impact on people and the built environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712152Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3263-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many different ways that governments can prepare, e.g. with earthquake-proof buildings and warning systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712157Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3263-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Families and individuals can also be prepared by practising what to do in an earthquake and having emergency supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712161Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3263-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wealthier nations are more able than poorer nations to respond to the challenge of a major earthquake."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712166Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3267-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a diverse range of landscapes in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.712193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3267-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a diverse range of biomes in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.712197Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3267-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The key physical features of North and South America can be investigated using a variety of resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712202Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29798-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Digital maps on a GIS can be used to see different time zones around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.712207Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29798-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different layers, such as those showing temperature and rainfall, can be added on a GIS to help us investigate places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712211Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29798-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS can be used to plan trips as we can compare geographical data where we live with that of where we are going."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712215Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3256-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Without the influence of humans the UK would mainly be woodland and forest."@en ;
  dcterms:modified "2026-02-12T08:59:21.712372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3256-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Woodlands in 2023 covers 13% of UK land."@en ;
  dcterms:modified "2026-02-12T08:59:21.712376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3256-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Woodland has been cut down through history to make way for farming, settlements and transport links."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712381Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3256-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Old and new maps can be compared to identify changes in woodland over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.712386Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29796-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographic information systems (GIS) contain digital maps that allow us to visualise and analyse geographical patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712424Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29796-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographic information systems can be used to investigate different landscapes in North and South America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712429Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3198-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nile, Amazon, Yangtze, Mississippi, Murray and Volga are the longest rivers in each continent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712458Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3198-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Antarctica doesn’t have any permanent long rivers."@en ;
  dcterms:modified "2026-02-12T08:59:21.712462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3198-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nile is the longest river in the world and has two major tributaries the White Nile and the Blue Nile."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3198-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nile flows through Cairo and then the river splits into lots of different channels. We call this a delta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712471Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29705-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A geographic information system (GIS) is a type of digital map that helps us see and understand geographical patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29705-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We can use a GIS to investigate our local area."@en ;
  dcterms:modified "2026-02-12T08:59:21.712480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29705-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We can use a GIS to investigate changes in our local area over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.712487Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29705-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most villages, town and cities have grown in the last 120 years."@en ;
  dcterms:modified "2026-02-12T08:59:21.712492Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3257-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can give us information about the location and extent of forests globally."@en ;
  dcterms:modified "2026-02-12T08:59:21.712497Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3257-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some parts of the world, such as the Amazon, are experiencing deforestation."@en ;
  dcterms:modified "2026-02-12T08:59:21.712503Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3257-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Satellite imagery can be used to identify how much deforestation has happened."@en ;
  dcterms:modified "2026-02-12T08:59:21.712508Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3257-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Deforestation impacts on local and global communities in many different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.712513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3260-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Every 30 seconds there is an earthquake somewhere in the world - including in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712518Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3260-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can be investigated to locate major earthquake zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.712522Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3260-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earthquakes occur near the boundary of tectonic plates."@en ;
  dcterms:modified "2026-02-12T08:59:21.712527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3290-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Time zones to the east of the Prime Meridian are ‘UTC (or GMT) plus’; time zones to the west are ‘minus UTC (or GMT)'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3290-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Webcams are a useful source of information about what is happening in places which are in different time zones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712557Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3290-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earth is divided into 24 standard meridians, at intervals of 15˚, which are the basis for delineating 24 time zones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712562Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3290-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Time zones are measured from the Prime Meridian at 0˚ longitude, where the time is Universal Co-ordinated Time (UTC)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712566Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3255-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Maps provide a range of clues that can give us information about how land is and has been managed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712571Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3255-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tree symbols on maps are also useful in distinguishing broadleaf trees from conifer plantations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712577Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3255-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Semi-natural ancient woodlands are of high ecological and heritage value."@en ;
  dcterms:modified "2026-02-12T08:59:21.712582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3190-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the UK, water comes from surface water sources (rivers, lakes, reservoirs) and underground water sources (aquifers)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712600Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3190-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The greatest demand for water in the UK comes from areas that have the least water supply."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712608Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3190-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reservoirs collect water in the wettest parts of the UK, to pipe to cities and towns in other areas for drinking water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712612Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3200-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lines of latitude can help us understand the location of climate zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.712617Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3200-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate zones cross over national and international boundaries and also lie within them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712622Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3200-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Average temperature is a clue to identifying climate zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.712626Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3200-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Latitude and altitude are both related to climate zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.712631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3259-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earth is composed of four layers: the crust, mantle, outer core and inner core."@en ;
  dcterms:modified "2026-02-12T08:59:21.712827Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3259-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Movement in the tectonic plates that form Earth’s crust causes earthquakes."@en ;
  dcterms:modified "2026-02-12T08:59:21.712832Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3259-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earthquakes occur at plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.712836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29757-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Data on different variables can be collected in our school grounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.712841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29757-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Scores can be used to compare one variable with another or one place with another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29757-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Working together during fieldwork helps us to make better decisions and have clearer opinions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712850Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3248-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Questionnaires are a tool that geographers use to gather facts and opinions about places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712871Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3248-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In an interview one person asks another questions and they answer, so it’s important to choose questions carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3248-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers connect data to locations using maps."@en ;
  dcterms:modified "2026-02-12T08:59:21.712880Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3251-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers use sketch maps, paper and digital maps, grid references, and geographical vocabulary to locate fieldwork."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712917Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3251-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data can be shared in many different ways, such as through maps, tables, diagrams, graphs and reports."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712921Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3251-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data can be examined to think about what it is showing: it’s helpful to think about how reliable the answers might be."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3266-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is a diverse range of landscapes and several major river systems in North and South America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712960Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3266-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a diverse range of climate zones in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.712965Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3266-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is a diverse range of biomes and vegetation belts in North and South America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3266-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The key physical features of North and South America can be investigated using resources including atlases and maps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712974Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3264-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The scale of the earthquake in Turkey was huge in terms of land area, settlements and people affected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712996Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3264-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Impact responses occur in the short, medium and long term."@en ;
  dcterms:modified "2026-02-12T08:59:21.713000Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3264-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different people and countries respond to an earthquake in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.713005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29759-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers can compare the total scores for different sites to decide on the best location for something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713010Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29759-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers can compare the scores for different categories to understand where there are strengths and weaknesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713014Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29759-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers use all their data to answer their enquiry question."@en ;
  dcterms:modified "2026-02-12T08:59:21.713019Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3249-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Risk assessment involves identifying possible dangers and knowing what action to take to stay safe"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713173Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3249-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A fieldwork destination should be accessible and appropriate to help answer the questions in an enquiry"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713178Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3249-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Digital maps and aerial photos allow us to visit places virtually to identify opportunities and potential hazards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713182Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3249-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Staying safe is the responsibility of the individual as well as the fieldwork leader"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713187Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29760-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In every fieldwork enquiry there will be things that will go well."@en ;
  dcterms:modified "2026-02-12T08:59:21.713215Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29760-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In every fieldwork enquiry there will be other things that could have been improved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713219Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29760-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reflecting on a fieldwork enquiry helps geographers to plan better fieldwork in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713224Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3254-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are more than 60,000 species of tree across the world and forests cover about a third of its land mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3254-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Boreal, temperate and tropical are simple categorisations of the world’s forest biomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713233Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3254-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Deciduous trees lose their leaves in autumn and evergreen trees keep their leaves all the year around."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713238Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29795-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographic information systems (GIS) are digital maps that allow us to visualise and analyse geographical patterns"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713242Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29795-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographic information systems can be used to investigate the location of  forests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713247Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3262-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The focus of an earthquake is deep underground - seismic waves radiate out from the focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713287Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3262-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The epicentre is on the surface, directly above the focus and is where the earthquake is felt most strongly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713294Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3262-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The power of an earthquake is called its magnitude and is measured on the Richter scale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3261-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The earthquake was the fifth most powerful earthquake of all time."@en ;
  dcterms:modified "2026-02-12T08:59:21.713303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3261-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The epicentre was on the sea bed, 70km east of the Honshu coast."@en ;
  dcterms:modified "2026-02-12T08:59:21.713308Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3261-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The resulting tsunami wave was 40 metres high and came inland for 10km."@en ;
  dcterms:modified "2026-02-12T08:59:21.713312Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3261-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """More than 350,000 buildings collapsed or were damaged and over 15,000 people died."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713319Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3252-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fieldwork data can be used in purposeful ways, such as making informed recommendations for change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713324Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3252-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We can think about possible, probable and preferred futures: how can we apply this thinking to our locality?"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3252-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An effective enquiry cycle evaluates how useful it has been and what the next steps might be"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3265-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A continent is usually defined as a group of countries on a continuous landmass with associated islands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3265-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North and South America are huge continents, joined by central America."@en ;
  dcterms:modified "2026-02-12T08:59:21.713343Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3265-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """North and South America are huge and have a diverse range of environments; they are popular travel destinations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713350Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3265-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Paper and digital atlases and maps can be used to investigate the location of North and South America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713355Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29755-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Solar power is one type of renewable energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.713539Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29755-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Solar farms need certain conditions to work at their best."@en ;
  dcterms:modified "2026-02-12T08:59:21.713544Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29755-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A fieldwork enquiry can help us look at solar power in more detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.713549Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29797-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "GIS can be used to identify the patterns of earthquakes around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.713554Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29797-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Major earthquakes occur on or near plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.713558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29797-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "GIS can be used to predict the impact of earthquakes on humans."@en ;
  dcterms:modified "2026-02-12T08:59:21.713563Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29797-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The impact of earthquakes is affected by the power of the earthquake and how many people live nearby."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713567Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3250-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some data, like the location of local services, can remain the same for a period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3250-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some data, like traffic counts or temperature varies from hour to hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.713580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3250-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers use maps in the field to know exactly where they are and to locate specific features."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713585Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3250-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers note the time, location and conditions, such as weather, of a fieldwork enquiry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3243-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A range of resources, including photographs and climate data can be used to investigate what a locality is like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713594Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3243-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different factors such as climate, location and the physical landscape can affect what life in a village is like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3243-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There may be many different reasons why someone would like to live in a particular locality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713603Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29756-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A good geographical question can help us to learn more about solar power and our school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713608Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29756-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fieldwork enquiry questions can start with one of the 'W' question words."@en ;
  dcterms:modified "2026-02-12T08:59:21.713615Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29756-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers often try to predict or estimate what the answer to their enquiry question might be."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3253-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Trees provide a wide range of natural resources that are used by humans and wildlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3253-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Trees absorb carbon, helping to reduce climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.713632Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3253-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Trees have features that can help with species identification, including the location where they grow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9586-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People are attracted to visit places as tourists for different reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.713642Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9586-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are lots of different physical and human landmarks in the Americas and these can be mapped."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9586-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Physical features such as mountain ranges, rivers and the coastline can be part of a tourist itinerary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713651Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9586-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Major cities are often used as transport hubs which act as a starting point from which tourists can explore an area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713655Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3291-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """West of the Prime Meridian, you ‘lose’ four minutes for every degree of longitude, and east you ‘gain’ four minutes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3291-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The International Date Line is 180˚ east and 180˚ west of the Prime Meridian and is the place where the date changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713664Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3291-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Meridians are the basis for the 24 time zones; many deviate from the meridian to accommodate national/state borders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713669Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3291-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Antimeridian forms the basis of the International Date Line, with some deviations for national borders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713673Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3289-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Day and night result from Earth's rotation in relation to sun, which appears to rise in the east and set in the west."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3289-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lines of longitude are all the same length, and give our position in degrees east or west of the Prime Meridian."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3289-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Prime Meridian (0˚longitude) runs through London; the Antimeridian (180˚ longitude) runs through the Pacific Ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29758-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Data that we collect in fieldwork can be presented in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.713692Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29758-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can be used to show data that is about the differences between places."@en ;
  dcterms:modified "2026-02-12T08:59:21.713696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29758-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Graphs can help us to see patterns in our data."@en ;
  dcterms:modified "2026-02-12T08:59:21.713701Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3192-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Not all people around the world have access to clean, safe water or wastewater treatment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714056Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3192-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """One in three people live without basic sanitation, causing unnecessary disease and death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714061Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3192-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Global Goals are a plan agreed to by world leaders to build a greener, fairer, better world by 2030."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714068Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3192-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The aim of Global Goal 6, is to achieve access to safe water and sanitation for all by 2030."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714073Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3193-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers are used by humans to fill reservoirs, do activities, create hydroelectricity and transport things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714612Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3193-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rainwater that falls on the ground is drained by rivers."@en ;
  dcterms:modified "2026-02-12T08:59:21.714616Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3193-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The area of land drained by rivers is called a drainage basin."@en ;
  dcterms:modified "2026-02-12T08:59:21.714621Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3193-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers flow from their source in the hills or mountains to their mouth where they enter the sea or lake."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714625Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3196-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers flood when they can’t hold all the water that is entering into them from tributaries, the soil and the rock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714794Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3196-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Heavy rainfall or long-lasting rainfall is a common cause of flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.714798Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3196-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Steep slopes can cause flooding as rainwater will run quickly downhill to the river during a storm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714803Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3196-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Humans can make flooding more likely by deforestation and building tarmac and concrete surfaces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3226-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A volcano is a crack in Earth's crust from which lava is emitted."@en ;
  dcterms:modified "2026-02-12T08:59:21.715264Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3226-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Volcanoes are formed at the boundaries of tectonic plates."@en ;
  dcterms:modified "2026-02-12T08:59:21.715271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3226-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Volcanoes take different forms."@en ;
  dcterms:modified "2026-02-12T08:59:21.715276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3226-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Composite volcanoes share a common structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.715280Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3314-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increased greenhouse gases in the atmosphere as a result of human activity are causing rapid climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715359Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3314-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rapid climate change is a problem as people and animals can’t adapt quickly enough to change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3314-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sea level rise is one change caused by increased temperatures as ice caps melt and water expands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3314-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increased energy in the atmosphere and oceans increases the risk of extreme weather."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3268-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Settlements are established and grow for different reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.715377Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3268-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some areas of North and South America are more populated than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.715381Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3268-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are many major world cities in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.715385Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3268-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The key human features of North and South America can be investigated using a wide range of resources, atlases and maps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715390Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3269-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The rainforest is a type of environment or biome, with a distinctive climate and ecosystem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715394Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3269-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rainforests are located in tropical and temperate regions of the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.715398Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3269-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Weather and climate conditions in tropical and temperate rainforests are different because of their locations on Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715403Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3269-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate data can be used to investigate what rainforests are like."@en ;
  dcterms:modified "2026-02-12T08:59:21.715407Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3233-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People mainly work in tourism but farming is a traditional occupation"@en ;
  dcterms:modified "2026-02-12T08:59:21.715411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3233-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Beef cattle and sheep are the main livestock kept by hill farmers. Its famous Herdwick sheep often graze on common land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715418Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3233-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Traditional practices include hedge laying, coppicing of woodland and quarrying of local building materials"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715423Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3233-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tourism is vital to the economy of the area, providing employment and supporting services in local communities"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3292-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many flights cross time zones, leading to discrepancies between the time in the air and that of destination airports."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3292-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some flights cross the International Date Line moving between the western and eastern hemispheres of the globe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715484Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3292-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some countries, including the UK, adjust their time in certain seasons to maximise the hours of daylight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715489Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3292-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Interactive flight maps can be used to investigate the complex pattern of international flights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3308-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Maps can help us identify different human and physical features of coasts."@en ;
  dcterms:modified "2026-02-12T08:59:21.715516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3308-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK has a lot of coastlines as it includes one large island, part of another, and thousands of smaller islands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3308-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK coastline has a great diversity of features. This means that the land can be used in many different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715528Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3308-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Almost all of the UK coastlines can be walked."@en ;
  dcterms:modified "2026-02-12T08:59:21.715533Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3301-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many food crops can only be grown in places with the right climatic conditions"@en ;
  dcterms:modified "2026-02-12T08:59:21.715624Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3301-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some food crops grown in the UK are only ‘in season’ for part of the year because of the UK’s temperate climate"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715630Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3301-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Seasonal differences between the northern and southern hemispheres mean that some crops are imported out of season"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715634Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3301-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Atlases can be used to investigate the location and climate zones of the place of origin of imported food crops"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715639Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3270-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Asking questions is an important research skill."@en ;
  dcterms:modified "2026-02-12T08:59:21.715730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3270-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different sources of information can be used to investigate the location and features of the Amazon rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3270-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Amazon rainforest is located in South America and spans several countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.715742Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3270-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Amazon rainforest has a range of geographical features."@en ;
  dcterms:modified "2026-02-12T08:59:21.715746Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3247-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographical enquiry develops existing geographical knowledge by examining evidence and gathering data in the field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3247-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Previous studies of the local area are sources of evidence but can date quickly."@en ;
  dcterms:modified "2026-02-12T08:59:21.715758Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3247-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Evidence for local area change can be found in historical maps and current OS maps, which are refreshed annually."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715763Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3247-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Evidence for recent change or local issues can also be found in the news, from talking to people and through fieldwork."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715767Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3242-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Northern Italy has a diverse range of physical geographical features (mountains, rivers, climate and vegetation belts)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715772Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3242-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Northern Italy has a diverse range of human geographical features (cities, road/rail networks, farming, industry)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715777Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3242-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Digital mapping tools can be used to investigate the features of northern Italy."@en ;
  dcterms:modified "2026-02-12T08:59:21.715781Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3323-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are a range of magnificent physical features in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.715786Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3323-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """North and South America have some large areas of wilderness that are home to many different plants and animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3323-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People interact with the environment in North and South America; this can have positive and negative consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3310-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some people living on the coast are at risk of losing their homes because of coastal erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3310-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coastlines can be protected via hard or soft engineering techniques including sea walls, groynes and beach nourishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715853Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3310-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many points of view to consider when deciding whether installing coastal defences is cost-effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3234-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The beauty and tranquillity of the Lake District attracts lots of visitors who put pressure on the landscape"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715881Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3234-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increased property prices means locals can’t afford to buy or rent homes, threatening traditional ways of life"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715885Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3234-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increasing population puts pressure on water authorities with pollution of lakes and waterways"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715890Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3234-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate change causing extreme weather events threatens tourism and farming"@en ;
  dcterms:modified "2026-02-12T08:59:21.715894Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3234-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """National Parks have special protections in place and many programmes for making them more sustainable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.715899Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9585-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a diverse range of economic activities in North and South America."@en ;
  dcterms:modified "2026-02-12T08:59:21.715904Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9585-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are inequalities between the lives of people within and between countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.715908Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9585-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different indicators can be used to measure how well a country and its people are doing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715915Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9263-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Europe has diverse human geographical features (cities, road and rail networks, types of farming and industry)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715968Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9263-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The key human features of Europe can be investigated using a wide range of resources, atlases and maps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715973Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9263-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Comparing physical and human maps can reveal spatial patterns."@en ;
  dcterms:modified "2026-02-12T08:59:21.715978Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3258-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tools such as questionnaires, interviews and surveys can be used to collect data about tree planting sites."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715982Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3258-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Maps and grid references can be used to identify and locate areas that may be suitable for tree planting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715987Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3258-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Scoring different options helps us to make a decision on where to plant trees."@en ;
  dcterms:modified "2026-02-12T08:59:21.715991Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3302-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """All food has to travel to reach our plates and the distance it travels is known as food miles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720400Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3302-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The total food miles will depend on the different stages and route of a food’s journey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720404Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3302-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Maps or the internet can be used to calculate the approximate food miles of different food products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720409Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3302-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is debate about the relative positive and negative consequences of sourcing food locally versus importing it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720413Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9264-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Countries in Europe are popular tourist destinations for different reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.720445Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9264-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Physical features such as mountains and coastlines attract many tourists each year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720449Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9264-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tourism can provide many economic benefits but can have environmental problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.720456Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3287-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The demand for resources for land, water, food, and shelter shapes the environment for other wildlife too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720461Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3287-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many animal populations have become much smaller, but a few have increased, thanks to conservation and rewilding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720465Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3287-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Pollinator insects – bees, wasps, beetles, flies, ants and butterflies – play an important role in agriculture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720469Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3309-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coastal communities at risk are deeply affected by changes caused by erosion, flooding or sea level rise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721993Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3309-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sea transports sediment such as mud, sand and stones: these can create coastal patterns of erosion and deposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3309-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sediment patterns on beaches reflect wave energy and wind direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.722002Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3209-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some early settlements grew from villages into towns and cities, through trade or because of the goods they produced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3209-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During the industrial revolution, some towns and villages grew into cities because factories developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723484Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3209-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """OS maps and aerial photographs reveal clues about why towns have  grown and developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723489Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3209-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers compare places by analysing their similarities and differences"@en ;
  dcterms:modified "2026-02-12T08:59:21.723493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3322-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are a range of magnificent physical features and well-known landmarks in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723754Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3322-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers can use maps and images to investigate differences between countries in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723758Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3322-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographers can use statistics to investigate differences between countries in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723762Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3276-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rainforests regulate Earth’s climate and are important for life on Earth in many different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723802Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3276-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rainforests face a variety of threats."@en ;
  dcterms:modified "2026-02-12T08:59:21.723811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3276-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People are taking action to protect rainforests in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.723816Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3235-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Europe extends from the Atlantic Ocean (west) to Asia (east), to Arctic Circle (north) to the Mediterranean Sea (south)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725460Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3235-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Atlas maps and a globe can be used to identify the location of countries in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725465Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3272-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Temperate and tropical climate zones have different characteristics which are related to their location on Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728984Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3272-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some food products grow in temperate climate zones while others grow in the tropical climate zones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728989Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3272-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rainforest food products are important export crops and are exported around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728993Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3272-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "We are connected to people and places around the world in many different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.728997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3211-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Places change over time and we can investigate this change in a variety of ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.729109Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3211-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People have different opinions about a place and whether it is changing for the better or worse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729113Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3211-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Discussing views about change can help identify themes such as environment, services, travel and transport, pollution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729117Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3238-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Atlas maps can be used to investigate the key physical features of Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.729212Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3238-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Europe has a diverse range of physical geographical features such as mountains and rivers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3238-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Alps and the Pyrenees are major mountain ranges in Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.729223Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3238-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Europe is home to some major rivers including the Volga, the Danube and the Rhine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3238-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Mediterranean Sea and Atlantic Ocean both border countries in Europe but are very different in size and character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729232Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3236-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The climate in Europe is seasonal and very varied."@en ;
  dcterms:modified "2026-02-12T08:59:21.729258Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3236-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Southern areas of Europe around the Mediterranean are mild in winter and hot in summer, and attract a lot of tourists."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3236-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The west of Europe receives more rainfall than the east of Europe because it is close to the Atlantic Ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729267Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6784-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wood is a versatile material used for construction, making paper and board or as a biofuel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729874Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6784-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In parts of the world with no access to electricity wood is used to power cookstoves causing deforestation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729878Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6784-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Woods are a natural resource for recreation, support biodiversity, help combat pollution and absorb carbon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729884Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6784-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Countries like Canada have the right climate for boreal forests to thrive and produce a lot of timber."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729888Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3303-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most cocoa trees grow in a narrow belt between a latitude of ten degrees north and ten degrees south of the Equator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731068Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3303-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Various stages are involved in chocolate production, from growing and harvesting cocoa beans to manufacturing chocolate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3303-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Small-scale cocoa farmers face challenges with growing their crops and are adapting to these in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731076Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3303-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The challenges facing small-scale cocoa farmers, and the solutions to these, have direct and indirect consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731080Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3273-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Brazil nuts have a specific life cycle, to which there are some potential threats."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3273-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Agouti are small rainforest animals which are critical for the life cycle of Brazil nuts in the rainforest ecosystem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3273-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The plants and animals in the rainforest are interconnected and depend on each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731763Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3273-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A variety of information sources can be used to investigate Brazil nuts and threats to their production and trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731768Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3299-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """How food is produced, processed, distributed and consumed is complex but it all comes from plants and animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735764Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3299-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most food makes a journey from farms, where animals are reared and crops grown, to shops where people purchase it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735768Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3299-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Several different stages are involved in the commercial production of bread."@en ;
  dcterms:modified "2026-02-12T08:59:21.735771Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3237-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each European country has a capital city."@en ;
  dcterms:modified "2026-02-12T08:59:21.737076Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3237-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some major cities in Europe have global importance."@en ;
  dcterms:modified "2026-02-12T08:59:21.737080Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3237-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The locations and features of European cities can be investigated using a wide range of resources, atlases and maps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737084Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3244-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different sources of information can be used to investigate what a locality is like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737088Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3244-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Digital mapping tools can be used to investigate buildings and land use."@en ;
  dcterms:modified "2026-02-12T08:59:21.737093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3244-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There may be many different reasons why someone would like to live in a specific location."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737098Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3321-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geography is happening all around us every day."@en ;
  dcterms:modified "2026-02-12T08:59:21.739904Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3321-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "News stories often have geographical causes and geographical impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.739908Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3321-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographical knowledge and skills can help us to understand the news."@en ;
  dcterms:modified "2026-02-12T08:59:21.739912Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3205-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Settlements are places where people live and work, and often have a distinct community identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739919Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3205-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Settlements vary in size from small hamlets, to villages, towns, cities and megacities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739923Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3205-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Larger settlements tend to have a wider range of buildings and land uses, and more facilities and services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739927Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3205-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Photos, including aerial photos, show the main features of villages, towns and cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3215-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Facts and opinions can be added to a map along with supporting evidence such as photographs"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742364Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3215-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Using a map enables spatial patterns to be spotted more easily"@en ;
  dcterms:modified "2026-02-12T08:59:21.742368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3215-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Responses to surveys and interviews can be interpreted and presented as graphs, charts or emoticons with or on a map"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742374Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3215-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Simple grid references can be used to identify locations on a map"@en ;
  dcterms:modified "2026-02-12T08:59:21.742378Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3231-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rocks in the Lake District reveal changes over millions of years"@en ;
  dcterms:modified "2026-02-12T08:59:21.742787Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3231-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mountains, valleys and lakes here have been created by colliding continents, and forces of folding and uplift"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742791Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3231-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The rocks were shaped by ice sheets and the actions of glaciers"@en ;
  dcterms:modified "2026-02-12T08:59:21.742795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3231-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """High rainfall, and deep glacial valleys, means much water can be stored, volcanic rock stops water draining away"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3206-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Villages, towns and cities have different features."@en ;
  dcterms:modified "2026-02-12T08:59:21.743560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3206-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Atlas maps of the UK often use different symbols or text size to indicate the size of a settlement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3206-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Atlas maps  can be used to investigate the location and distribution  of  the UK’s significant cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743568Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3206-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Any settlement can be located on an OS map, and its features investigated using the key."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743572Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3188-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rainwater is collected by sloping roofs and gutters, and flows into drainpipes, waterbutts and drains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744481Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3188-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Water enters buildings at the stopcock and travels through pipes to be used for drinking, heating, toilets, etc."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744485Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3188-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wastewater from sinks, baths, washing machines and toilets goes into the drain and then to the main sewer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-21477-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geography is a diverse subject that helps us to make sense of the world around us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745777Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-21477-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Reflecting on prior learning can help us to develop new knowledge and skills."@en ;
  dcterms:modified "2026-02-12T08:59:21.745781Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-21477-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geography is important in many different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.745785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3241-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Italy is in southern Europe and borders Switzerland, France, Austria and Slovenia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3241-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Digital mapping tools can be used to locate Europe, Italy, and the main features of northern Italy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3241-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Investigations of travel to northern Italy include comparing route, distance and time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745797Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3187-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are four main processes in the water cycle. Evaporation of liquid water creates water vapour in the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746106Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3187-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Air containing water vapour rises, then cools down causing condensation which turns water vapour into droplets of water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746110Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3187-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Water droplets in clouds grow bigger and bigger until they fall from the clouds as wet weather called precipitation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746114Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3187-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Precipitation is then collected and stored in water bodies, or by vegetation, or soaks into the ground or down drains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746118Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3213-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Good enquiry questions will help find out what opinions other people have about current changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746922Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3213-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Interviews and surveys are useful tools, and good questions will get answers that allow patterns to show."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3213-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Surveys or questionnaires with yes / no answers or scores can be easily analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746929Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3213-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is possible to graph the survey results, making it easier for people to understand the findings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3313-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coastal areas are often tourist hotspots due to the landscape and range of activities possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748524Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3313-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tourism can bring economic benefits to coastal regions, but it can also lead to social and environmental problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748528Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3313-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cruise ships carry tourists around the world for weeks or even months at a time."@en ;
  dcterms:modified "2026-02-12T08:59:21.748532Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3313-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 2021, Venice, Italy, banned cruise ships from entering the city's waters declaring her lagoon a national monument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20096-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers move water and processes of erosion, transport and deposition create different landforms along a river’s course."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20096-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rocks pebbles and sediment carried by the river bash against the banks to crack and weaken them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20096-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Landforms like waterfalls, meanders and floodplains are created by rivers."@en ;
  dcterms:modified "2026-02-12T08:59:21.750645Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20096-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An estuary forms where fresh river water mixes with salty sea water."@en ;
  dcterms:modified "2026-02-12T08:59:21.750648Z"^^xsd:dateTime .

