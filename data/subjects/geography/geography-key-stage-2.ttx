  dcterms:modified "2026-02-12T08:59:15.791772Z"^^xsd:dateTime .

oak:keyword-meltwater
  a oakcurric:Keyword ;
  schema:name "meltwater"@en ;
  schema:description "Meltwater is water from the melting of snow or ice"@en ;
  dcterms:modified "2026-02-12T08:59:15.791776Z"^^xsd:dateTime .

oak:keyword-emission
  a oakcurric:Keyword ;
