oak:keyword-retailers
  a oakcurric:Keyword ;
  schema:name "retailers"@en ;
  schema:description "Retailers are people or businesses that sell goods"@en ;
  dcterms:modified "2026-02-12T08:59:15.826652Z"^^xsd:dateTime .

oak:keyword-commercially
  a oakcurric:Keyword ;
