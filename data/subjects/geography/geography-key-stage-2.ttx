  dcterms:modified "2026-02-12T08:59:15.816162Z"^^xsd:dateTime .

oak:keyword-vertical-axis
  a oakcurric:Keyword ;
  schema:name "vertical axis"@en ;
  schema:description "The vertical axis is a line of figures or data that is at the side of a graph."@en ;
  dcterms:modified "2026-02-12T08:59:15.816166Z"^^xsd:dateTime .

oak:keyword-emissions
  a oakcurric:Keyword ;
  schema:name "emissions"@en ;
  schema:description """An emission is something that is released into the world. An example is the release of carbon dioxide when we breathe out."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816858Z"^^xsd:dateTime .

oak:keyword-inhabitants
  a oakcurric:Keyword ;
  schema:name "inhabitants"@en ;
  schema:description "Inhabitants are the people who live in a defined area."@en ;
  dcterms:modified "2026-02-12T08:59:15.816863Z"^^xsd:dateTime .

oak:keyword-hazard
  a oakcurric:Keyword ;
  schema:name "hazard"@en ;
  schema:description "A danger associated with a substance or piece of apparatus."@en ;
  dcterms:modified "2026-02-12T08:59:15.817130Z"^^xsd:dateTime .

oak:keyword-turbine
  a oakcurric:Keyword ;
  schema:name "turbine"@en ;
  schema:description "rotated by high pressure steam in a power station"@en ;
  dcterms:modified "2026-02-12T08:59:15.817671Z"^^xsd:dateTime .

oak:keyword-tributary
  a oakcurric:Keyword ;
