  dcterms:modified "2026-02-12T08:59:15.791501Z"^^xsd:dateTime .

oak:keyword-protected
  a oakcurric:Keyword ;
  schema:name "protected"@en ;
  schema:description "If something is protected it is kept safe from harm."@en ;
  dcterms:modified "2026-02-12T08:59:15.791630Z"^^xsd:dateTime .

oak:keyword-natural-environment
  a oakcurric:Keyword ;
