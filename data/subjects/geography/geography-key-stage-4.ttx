oak:keylearningpoint-lesson-27914-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ecosystems are finely balanced and can be affected by changing one component."@en ;
  dcterms:modified "2026-02-12T08:59:21.673162Z"^^xsd:dateTime .

