  dcterms:modified "2026-02-12T08:59:21.707636Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24527-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographical conclusions are made through careful analysis of all the data geographers have collected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24420-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In March 2011, a massive 9.0 magnitude earthquake shook the Japanese island of Honshu."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707645Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24420-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sudden slippage occurred along a destructive plate margin between the Pacific plate and the Okhotsk plate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707650Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24420-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Primary and secondary effects of the disaster caused the deaths of more than 18 000 people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707654Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24420-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Japan's position as an HIC influenced its immediate and long-term responses and their effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707659Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28466-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "For the first time ever, humanity became ‘urban’ around 2007."@en ;
  dcterms:modified "2026-02-12T08:59:21.707663Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28466-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS can help us to manage and visualise big data about world cities using filters and pop-ups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707668Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28466-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS helps us to manage and visualise big data about trends in urbanisation using choropleth maps and pop-ups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707672Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28466-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS choropleth maps use shapefiles which are ‘joined’ to attribute using place identifiers in the shapefiles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707677Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28466-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS pop-us can be configured to visualise trends in big data about urban population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24533-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Atlases present the world at the smallest scale, showing the least detail but larger patterns and relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707722Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24533-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Atlases use latitude and longitude lines to locate particular places."@en ;
  dcterms:modified "2026-02-12T08:59:21.707727Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24533-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are many types of atlas map that are used to show specific information."@en ;
  dcterms:modified "2026-02-12T08:59:21.707732Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24542-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Spatial data can be shown on a map using points, lines and polygons."@en ;
  dcterms:modified "2026-02-12T08:59:21.707859Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24542-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographical Information Systems (GIS) create maps that can show many forms of spatial data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707864Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24542-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are some styles of maps that show spatial data in specific ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.707869Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24462-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Carlisle is located in northwest England. It lies at the confluence of three rivers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708109Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24462-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Carlisle has experienced several major flooding events."@en ;
  dcterms:modified "2026-02-12T08:59:21.708114Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24462-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """£25 million was invested in a flood management scheme, combining hard engineering and soft engineering strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708118Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24462-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were social, economic and environmental issues associated with the example flood management scheme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708123Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24460-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical and human factors increase flood risk."@en ;
  dcterms:modified "2026-02-12T08:59:21.708127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24460-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increased flood  risk is due to several factors including increased storm frequency (and intensity) and land use change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708132Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24460-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Increased river flooding threatens people and the environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.708137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22975-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are distinctive global biomes (large-scale ecosystems)."@en ;
  dcterms:modified "2026-02-12T08:59:21.708141Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22975-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical rainforests have distinctive abiotic characteristics that result from the equatorial climate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708146Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22975-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical rainforests have distinctive biotic characteristics, including the structure of vegetation into layers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708150Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24457-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical and human factors interact to affect river landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.708325Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24457-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical and human factors interact to affect sediment load."@en ;
  dcterms:modified "2026-02-12T08:59:21.708329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24457-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical and human factors interact to affect flood risk."@en ;
  dcterms:modified "2026-02-12T08:59:21.708334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22979-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The majority of Indonesia’s rainforests are located in Borneo, Papua and Sumatra."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709322Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22979-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Causes of deforestation in Indonesia include subsistence and commercial farming, logging, energy and population growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709326Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22979-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Impacts of deforestation in Indonesia include erosion, pollution, habitat loss, carbon emissions, economic development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709331Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24455-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """River erosion shapes distinctive landforms (interlocking spurs, waterfalls and gorges)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709337Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24455-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """River erosion and deposition combine to form distinctive landforms (meanders and oxbow lakes)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24455-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """River deposition forms distinctive landforms (levees, flood plains, estuaries and deltas)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709347Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24564-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages of 'top-down' strategies for managing water supply."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712716Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24564-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages of 'top-down' strategies for managing waste disposal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712721Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24564-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages of 'top-down' strategies for managing transport and air pollution in Jakarta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22981-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sustainable management means using resources in a way that allows future generations to use them in the same way too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22981-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Local actions, such as alternative livelihoods, enable tropical rainforests to be sustainably managed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712735Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22981-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Global actions can contribute to sustainable management of tropical rainforests."@en ;
  dcterms:modified "2026-02-12T08:59:21.712740Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24424-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Management can reduce the impacts of earthquake hazards."@en ;
  dcterms:modified "2026-02-12T08:59:21.715538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24424-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Management involves short-term relief and long-term planning, preparation and prediction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715542Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24424-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earthquake hazards may be managed differently at contrasting locations."@en ;
  dcterms:modified "2026-02-12T08:59:21.715547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24444-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rock type (hard/soft) affects the development of coastal landforms."@en ;
  dcterms:modified "2026-02-12T08:59:21.719041Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24444-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geological structure can result in concordant and discordant coastlines."@en ;
  dcterms:modified "2026-02-12T08:59:21.719046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24427-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical storms have significant effects on people and the environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.719441Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24427-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical storms have primary effects on people and the environment, such as strong winds, heavy rain and storm surges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719445Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24427-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical storms have secondary effects on people and the environment, such as coastal flooding and landslides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719450Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24427-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some countries are more vulnerable to the impacts (physically, socially and economically) of tropical storms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24565-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bottom-up strategies involving community and NGO-led can make Jakarta more sustainable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719459Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24565-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bottom-up housing projects have been successful in improving housing."@en ;
  dcterms:modified "2026-02-12T08:59:21.719463Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24565-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bottom-up housing projects have been successful in improving health and education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719468Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24565-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages of 'bottom-up' strategies for improving health and education services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719472Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24439-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The UK has upland and lowland landscapes and river systems."@en ;
  dcterms:modified "2026-02-12T08:59:21.719816Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24439-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geology affects the shape and type of UK landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.719821Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24439-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tectonic activity has helped form upland and lowland areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.719827Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24439-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Glacial erosion and deposition shaped upland and lowland landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.719832Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24439-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geology is the study of the Earth."@en ;
  dcterms:modified "2026-02-12T08:59:21.719836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24426-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical storms have distinctive structural characteristics and are widely distributed within the tropics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24426-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical storms are related to the atmospheric circulation and are formed by particular meteorological conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719845Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24426-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tropical storms form in source areas, intensify as they track over oceans and then dissipate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719849Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24426-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate change may affect the distribution, frequency and intensity of tropical storms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24430-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Location and track of Typhoon Rai."@en ;
  dcterms:modified "2026-02-12T08:59:21.720491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24430-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Typhoon Rai had primary and secondary effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.720496Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24430-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were immediate and long-term responses to Typhoon Rai."@en ;
  dcterms:modified "2026-02-12T08:59:21.720500Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24422-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People continue to live in areas at risk from a tectonic hazard."@en ;
  dcterms:modified "2026-02-12T08:59:21.720504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24422-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Monitoring and prediction can reduce the risks from a tectonic hazard."@en ;
  dcterms:modified "2026-02-12T08:59:21.720509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24422-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Protection and planning can reduce the risks from a tectonic hazard."@en ;
  dcterms:modified "2026-02-12T08:59:21.720513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22978-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are threatened by deforestation."@en ;
  dcterms:modified "2026-02-12T08:59:21.720721Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22978-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rates of deforestation are changing."@en ;
  dcterms:modified "2026-02-12T08:59:21.720725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22978-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are several causes of deforestation, such as commercial logging, agriculture and mineral resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24415-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a pattern in the global distribution of earthquakes."@en ;
  dcterms:modified "2026-02-12T08:59:21.723210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24415-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is a pattern in the global distribution of volcanoes."@en ;
  dcterms:modified "2026-02-12T08:59:21.723214Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24415-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The global distribution of earthquakes and volcanoes coincides with plate margins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24417-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Destructive/convergent plate margins involve two plates moving towards each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723223Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24417-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Distinctive processes occur at destructive/convergent plate margins."@en ;
  dcterms:modified "2026-02-12T08:59:21.723227Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24417-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earthquakes and volcanic eruptions occur at destructive/convergent plate margins and have distinctive characteristics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723232Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28464-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "3D GIS provides powerful ways to visualise what is physical at plate margins."@en ;
  dcterms:modified "2026-02-12T08:59:21.723236Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28464-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS transects can be used to create Elevation Profiles to visualise topography and bathymetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28464-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS Elevation Profiles can visualise physical processes at different plate margins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22970-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The biosphere regulates the composition of the atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.723516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22970-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The biosphere maintains soil health and regulates water within the hydrological cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22970-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The biosphere provides globally important services."@en ;
  dcterms:modified "2026-02-12T08:59:21.723525Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24454-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers erode landscapes through the processes of hydraulic action, abrasion, attrition and solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24454-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rivers transport sediment through the processes of traction, saltation, suspension and solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725565Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24454-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rivers deposit sediment in areas of low energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.725569Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24456-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The River Eden valley is located in the northwest of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.726628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24456-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The River Eden valley features landforms of erosion and deposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.726632Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24456-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It has erosional landforms in its upper course including a V-shaped valley, Hell Gill, and a waterfall, Hell Gill Force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24456-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It has depositional landforms in its middle and lower course including meanders across floodplains near to Carlisle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24432-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The weather in the UK can be hazardous."@en ;
  dcterms:modified "2026-02-12T08:59:21.726646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24432-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The UK is affected by a number of weather hazards, such as strong winds, torrential rain and snowfall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726650Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24432-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is evidence that weather in the UK is becoming more extreme."@en ;
  dcterms:modified "2026-02-12T08:59:21.726654Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28465-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ready-made tropical storm layers can be configured to visualise spatial patterns more effectively, e.g. using filters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726659Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28465-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical storms can be analysed using pop-up data."@en ;
  dcterms:modified "2026-02-12T08:59:21.726672Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28465-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Georeferenced data about a particular tropical storm can be mapped using GIS and configured to show selected attributes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726677Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28465-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A storm track can be visualised using temporal data, in a time-enabled GIS map."@en ;
  dcterms:modified "2026-02-12T08:59:21.726682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29566-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Primary impacts are immediate and caused directly by the tectonic hazard."@en ;
  dcterms:modified "2026-02-12T08:59:21.726688Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29566-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary impacts are indirect impacts and occur in the hours, days and weeks after the hazard."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726695Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29566-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is a range of reasons why primary and secondary impacts may differ between two volcanic eruptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29566-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different indicators can be considered to assess the significance of primary impacts and secondary impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726706Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24414-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earth's outer layer (lithosphere) is divided into a number of plates."@en ;
  dcterms:modified "2026-02-12T08:59:21.727037Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24414-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gravitational sliding, involving the processes of 'ridge-push' and 'slab-pull', contributes towards plate movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24414-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earth's surface provides evidence for plate tectonics theory."@en ;
  dcterms:modified "2026-02-12T08:59:21.727046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28408-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Global biomes can be easily mapped using shared GIS layers in webmaps."@en ;
  dcterms:modified "2026-02-12T08:59:21.727050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28408-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Basemaps can be selected to improve the visualisation and links to prior geographical knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727055Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28408-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS layers can help to visualise the spatial distribution of global biomes more clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727059Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28408-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Filters and transparency sliders can be used to toggle biome layers and explain their spatial distribution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28463-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate change impacts can be visualised and analysed using geospatial data."@en ;
  dcterms:modified "2026-02-12T08:59:21.728788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28463-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The impacts can be visualised with georeferenced data using the GIS tool called media layers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28463-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Configuration of media layers happens in a 2D webmap, which can be saved for even more powerful use in 3D maps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28463-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS tools can support analysis of media layers including measurement tools and the Elevation Profile tool."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24463-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ice covered large parts of the UK in the past."@en ;
  dcterms:modified "2026-02-12T08:59:21.728808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24463-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Glacial processes have been responsible for shaping the landscape of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.728813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24463-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Glacial processes include freeze-thaw weathering, erosion, movement, transportation and deposition (till and outwash)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728817Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24479-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban change has led to challenges with industrial and residential dereliction such as deterioration of buildings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24479-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban change has led to challenges in the redevelopment of brown and greenfield sites to meet housing demand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728826Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24479-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban change has led to challenges in waste disposal due to low rates of recycling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728830Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24479-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The environmental challenges have been and continue to be addressed by the Liverpool City Region local authorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728835Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24544-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Migration affects the rate of urbanisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.728839Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24544-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Economic change affects the rate of urbanisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.728843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24544-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Natural increase affects the rate of urbanisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.728847Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27576-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cold environments are home to a variety of plants and animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.729004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27576-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Animals in cold environments are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.729009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27576-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Plants in cold environments are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.729013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27576-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are issues related to biodiversity in cold environments."@en ;
  dcterms:modified "2026-02-12T08:59:21.729018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24458-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The storm hydrograph shows the relationship between precipitation and discharge."@en ;
  dcterms:modified "2026-02-12T08:59:21.729022Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24458-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical and human factors affect the shape of the storm hydrograph."@en ;
  dcterms:modified "2026-02-12T08:59:21.729026Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24550-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are social opportunities associated with urban growth in Jakarta."@en ;
  dcterms:modified "2026-02-12T08:59:21.729829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24550-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban growth creates access to services such as health and education."@en ;
  dcterms:modified "2026-02-12T08:59:21.729833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24550-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban growth creates access to resources, such as water supply and energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.729837Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24465-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Wales in the UK is an example of a glaciated landscape."@en ;
  dcterms:modified "2026-02-12T08:59:21.729843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24465-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Snowdonia in North Wales exhibits landforms of erosion."@en ;
  dcterms:modified "2026-02-12T08:59:21.729848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24465-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Snowdonia in North Wales exhibits landforms of deposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.729852Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24421-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In January 2010, a 7.0 magnitude earthquake struck Haiti in the Caribbean, one of the world's poorest countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24421-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The earthquake was caused by slippage at the conservative margin between the Caribbean plate and North American plate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24421-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Primary and secondary effects of the disaster caused the deaths of more than 220 000 people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731095Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24421-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Haiti's position as an LIC influenced its immediate and long-term responses and their effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731099Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24478-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban change has created social and economic challenges in Liverpool linked to high relative levels of deprivation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24478-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Index of Multiple Deprivation measures relative deprivation at local authority and smaller scales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731875Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24478-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The six local authorities in the Liverpool City Region are all in top 60 most deprived in England. Knowsley ranks 2nd."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24478-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Deprivation has a cause and effect link to inequalities in housing, health, employment and education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731883Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24478-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """High deprivation in Liverpool correlates with poor housing, poor health, unemployment and low educational attainment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731887Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24418-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Conservative plate margins involve two plates sliding alongside each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.731891Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24418-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Distinctive processes occur at conservative plate margins."@en ;
  dcterms:modified "2026-02-12T08:59:21.731899Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24418-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earthquakes occur at conservative plate margins but volcanoes do not."@en ;
  dcterms:modified "2026-02-12T08:59:21.731903Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24423-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Management can reduce the impacts of volcanic hazards."@en ;
  dcterms:modified "2026-02-12T08:59:21.731909Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24423-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Management involves short-term relief and long-term planning, preparation and prediction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24423-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Volcanic hazards may be managed differently at contrasting locations."@en ;
  dcterms:modified "2026-02-12T08:59:21.731917Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28468-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The GIS tool 'Trace Downstream' can be used to analyse the course of a river."@en ;
  dcterms:modified "2026-02-12T08:59:21.732452Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28468-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The GIS tool 'Create Watersheds' can be used to analyse the drainage basin (catchment) of a river."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732456Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28468-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The GIS tool 'Elevation Profile' can be used to find out if a river's long profile corresponds to a theoretical model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732460Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27575-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cold environments (polar and tundra) and located at high latitudes close to the poles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732464Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27575-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cold environments have distinctive physical characteristics."@en ;
  dcterms:modified "2026-02-12T08:59:21.732468Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27575-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The climate influences other physical characteristics of cold environments."@en ;
  dcterms:modified "2026-02-12T08:59:21.732489Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29408-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cold environment ecosystems exhibit interdependence of climate, water, soils, plants, animals and people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29408-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Food chains and food webs show how biotic and abiotic components are interdependent in a cold environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732497Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29408-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nutrient cycles show how biotic and abiotic components are interdependent in a cold environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732503Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24512-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rapid economic growth in Indonesia has had positive and negative impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.734736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24512-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rapid economic change has contributed to demographic change (fertility and death rates)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734740Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24512-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rapid economic change has caused urbanisation and created regional disparities in Indonesia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734744Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24512-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic development and globalisation have had positive and negative impacts on different age and gender groups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734748Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29565-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Primary impacts are immediate and caused directly by the tectonic hazard."@en ;
  dcterms:modified "2026-02-12T08:59:21.735020Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29565-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary impacts are indirect impacts and occur in the hours, days and weeks after the hazard."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735024Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29565-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is a range of reasons why primary and secondary impacts may differ between two earthquakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735027Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29585-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS can be used to visualise and configure primary georeferenced data attributes from human geography fieldwork."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29585-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS visualisations can use attributes including bearing data to create proportional, orientated symbols."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735035Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29585-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS visualisations can be time-enabled using temporal data attributes to enhance the visualisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735039Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29585-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """GIS visualisations of secondary data such as government data about deprivation can be used to support fieldwork enquiry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735043Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24482-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Balancing social, economic and environmental factors is necessary to achieve sustainability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24482-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The management of urban resources involves consideration of land, water, waste and energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24482-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The management of urban transport should aim to reduce emissions and congestion."@en ;
  dcterms:modified "2026-02-12T08:59:21.736017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24482-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sustainability is at the forefront of urban development in Liverpool."@en ;
  dcterms:modified "2026-02-12T08:59:21.736020Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24413-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earth has a layered structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.736024Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24413-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The layers of Earth have different physical properties (temperature, density, composition, physical state)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736028Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24474-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Liverpool is a coastal city in the north-west of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.736995Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24474-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Evidence of Liverpool’s importance can be categorised into historical, socio-economic, demographic and economic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24474-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is nationally important for its diversity, city economy, role in the Industrial Revolution and population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24474-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is globally important for trade, sporting and cultural events and its link to the slave trade and migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24554-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are environmental challenges in Jakarta."@en ;
