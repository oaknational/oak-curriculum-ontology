  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate (seasonality, storm frequency, prevailing winds) affects the rate of erosion along coastal landscapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485125Z"^^xsd:dateTime .

