  dcterms:modified "2026-02-12T08:59:15.804756Z"^^xsd:dateTime .

oak:keyword-decomposer
  a oakcurric:Keyword ;
  schema:name "decomposer"@en ;
  schema:description """A decomposer is an organism that feeds on the remains of other living organisms (organic matter)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804927Z"^^xsd:dateTime .

oak:keyword-core
  a oakcurric:Keyword ;
  schema:name "core"@en ;
  schema:description "the basic and most important part of something"@en ;
  dcterms:modified "2026-02-12T08:59:15.805363Z"^^xsd:dateTime .

oak:keyword-landlocked
  a oakcurric:Keyword ;
  schema:name "landlocked"@en ;
  schema:description "a country with no coastline"@en ;
  dcterms:modified "2026-02-12T08:59:15.806351Z"^^xsd:dateTime .

oak:keyword-gross-national-income-gni
  a oakcurric:Keyword ;
  schema:name "gross national income (GNI)"@en ;
  schema:description """a measure of goods and services produced by a country, including income earned abroad; may be divided by the total population to give ‘GNI per head’"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806474Z"^^xsd:dateTime .

oak:keyword-life-expectancy
  a oakcurric:Keyword ;
  schema:name "life expectancy"@en ;
  schema:description """average number of years an individual can expect to live at birth; worldwide this doubled from 1900 to 2021"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806478Z"^^xsd:dateTime .

oak:keyword-human-development-index-hdi
  a oakcurric:Keyword ;
  schema:name "Human Development Index (HDI)"@en ;
  schema:description """a UN measure of development calculated using education, life expectancy and income data"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806500Z"^^xsd:dateTime .

oak:keyword-ecological-footprint
  a oakcurric:Keyword ;
  schema:name "ecological footprint"@en ;
  schema:description """the impact of a person or community on the environment, expressed as the amount of land required to sustain their use of natural resources"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806504Z"^^xsd:dateTime .

oak:keyword-net-zero
  a oakcurric:Keyword ;
  schema:name "net zero"@en ;
  schema:description """balancing the amount of greenhouse gases emitted into the atmosphere with the amount removed from it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806509Z"^^xsd:dateTime .

oak:keyword-non-renewables
  a oakcurric:Keyword ;
  schema:name "non-renewables"@en ;
  schema:description """natural sources of energy that will run out because they cannot be reproduced, such as fossil fuels (coal, oil and natural gas) and nuclear power (uranium)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806513Z"^^xsd:dateTime .

oak:keyword-renewables
  a oakcurric:Keyword ;
  schema:name "renewables"@en ;
  schema:description """natural sources of energy that will never run out, such as wind, water and solar energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806517Z"^^xsd:dateTime .

oak:keyword-intermediate-technology
  a oakcurric:Keyword ;
  schema:name "intermediate technology"@en ;
  schema:description """technology suited to the needs, skills, knowledge and wealth of local people in the environment in which they live"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806522Z"^^xsd:dateTime .

oak:keyword-international-relations
  a oakcurric:Keyword ;
  schema:name "international relations"@en ;
  schema:description """the way in which nations interact with and regard each other, in relation to politics, economics and culture"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806526Z"^^xsd:dateTime .

oak:keyword-neo-colonialism
  a oakcurric:Keyword ;
  schema:name "neo-colonialism"@en ;
  schema:description """the indirect control of one country by another via economic power or cultural influence"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806531Z"^^xsd:dateTime .

oak:keyword-conventional
  a oakcurric:Keyword ;
  schema:name "conventional"@en ;
  schema:description "ordinary or typical, following common standards or practices"@en ;
  dcterms:modified "2026-02-12T08:59:15.806570Z"^^xsd:dateTime .

oak:keyword-vulnerable
  a oakcurric:Keyword ;
  schema:name "vulnerable"@en ;
  schema:description "able to be easily hurt, influenced, or attacked"@en ;
  dcterms:modified "2026-02-12T08:59:15.806583Z"^^xsd:dateTime .

oak:keyword-foreign-direct-investment
  a oakcurric:Keyword ;
  schema:name "foreign direct investment"@en ;
  schema:description """FDI is money invested by a company or country into businesses or infrastructure in another country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806702Z"^^xsd:dateTime .

oak:keyword-outsourcing
  a oakcurric:Keyword ;
  schema:name "outsourcing"@en ;
  schema:description """when a company hires another business, often in a different country, to carry out work such as manufacturing or customer service"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806706Z"^^xsd:dateTime .

oak:keyword-transnational-corporations
  a oakcurric:Keyword ;
  schema:name "transnational corporations"@en ;
  schema:description """TNCS are large companies that operate in several countries; they often have headquarters in one country and factories or offices in others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806711Z"^^xsd:dateTime .

oak:keyword-demography
  a oakcurric:Keyword ;
  schema:name "demography"@en ;
  schema:description "the study of population: its size, composition and change over time"@en ;
  dcterms:modified "2026-02-12T08:59:15.806730Z"^^xsd:dateTime .

oak:keyword-birth-rate
  a oakcurric:Keyword ;
  schema:name "birth rate"@en ;
  schema:description "the number of births for every 1000 people in a population per year"@en ;
  dcterms:modified "2026-02-12T08:59:15.806736Z"^^xsd:dateTime .

oak:keyword-population-pyramid
  a oakcurric:Keyword ;
  schema:name "population pyramid"@en ;
  schema:description """an age-sex graph used to present the structure of a population (that may resemble a pyramid)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806741Z"^^xsd:dateTime .

oak:keyword-demographic-transition-model
  a oakcurric:Keyword ;
  schema:name "demographic transition model"@en ;
  schema:description """a theoretical model that suggests how birth rate, death rate and total population change over time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806745Z"^^xsd:dateTime .

oak:keyword-undernutrition
  a oakcurric:Keyword ;
  schema:name "undernutrition"@en ;
  schema:description """not consuming enough calories (or nutrients) to maintain a normal, active, healthy life"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807118Z"^^xsd:dateTime .

oak:keyword-sanitation
  a oakcurric:Keyword ;
  schema:name "sanitation"@en ;
  schema:description """systems designed to protect public health, such as disposing of sewage and other waste products"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807123Z"^^xsd:dateTime .

oak:keyword-regional-power
  a oakcurric:Keyword ;
  schema:name "regional power"@en ;
  schema:description """a country that is strong and influential in its part of the world but not necessarily globally dominant"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807127Z"^^xsd:dateTime .

oak:keyword-geopolitical
  a oakcurric:Keyword ;
  schema:name "geopolitical"@en ;
  schema:description """the way geography, economics and politics influence a country’s power and relationships with other countries"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807131Z"^^xsd:dateTime .

oak:keyword-energy-futures
  a oakcurric:Keyword ;
  schema:name "energy futures"@en ;
  schema:description """different scenarios about ways in which energy might be produced, consumed and managed in the future"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807432Z"^^xsd:dateTime .

oak:keyword-infectious-disease
  a oakcurric:Keyword ;
  schema:name "infectious disease"@en ;
  schema:description "an illness that may be passed from one person to another"@en ;
  dcterms:modified "2026-02-12T08:59:15.807524Z"^^xsd:dateTime .

oak:keyword-economic-migrant
  a oakcurric:Keyword ;
  schema:name "economic migrant"@en ;
  schema:description "a person who moves to another country with better working or living conditions"@en ;
  dcterms:modified "2026-02-12T08:59:15.807528Z"^^xsd:dateTime .

oak:keyword-remittances
  a oakcurric:Keyword ;
  schema:name "remittances"@en ;
  schema:description "payments sent home by migrants to members of their family or community"@en ;
  dcterms:modified "2026-02-12T08:59:15.807532Z"^^xsd:dateTime .

oak:keyword-water-quality
  a oakcurric:Keyword ;
  schema:name "water quality"@en ;
  schema:description """whether what is in a supply of water (e.g. its chemical or biological contents) make it suitable for a particular kind of use"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807958Z"^^xsd:dateTime .

oak:keyword-life-satisfaction
  a oakcurric:Keyword ;
  schema:name "life satisfaction"@en ;
  schema:description "a subjective measure of happiness used to compare countries"@en ;
  dcterms:modified "2026-02-12T08:59:15.807963Z"^^xsd:dateTime .

oak:keyword-international-migration
  a oakcurric:Keyword ;
  schema:name "international migration"@en ;
  schema:description "the movement of people from one country to another"@en ;
  dcterms:modified "2026-02-12T08:59:15.807976Z"^^xsd:dateTime .

oak:keyword-landscape-scarring
  a oakcurric:Keyword ;
  schema:name "landscape scarring"@en ;
  schema:description """visible damage to a landscape caused by human activities such as mining or construction"""@en ;
  dcterms:modified "2026-02-12T08:59:15.807980Z"^^xsd:dateTime .

oak:keyword-sustainable-food-supply
  a oakcurric:Keyword ;
  schema:name "sustainable food supply"@en ;
  schema:description """when food is produced in ways that avoid damaging natural resources, provide social benefits and contribute to local economies"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808040Z"^^xsd:dateTime .

oak:keyword-organic-farming
  a oakcurric:Keyword ;
  schema:name "organic farming"@en ;
  schema:description """when food is grown without the use of artificial chemicals, such as fertiliser and pesticide"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808044Z"^^xsd:dateTime .

oak:keyword-permaculture
  a oakcurric:Keyword ;
  schema:name "permaculture"@en ;
  schema:description """a system of farming based upon or directly using patterns and features observed in natural ecosystems, such as increased biodiversity and intercropping"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808048Z"^^xsd:dateTime .

oak:keyword-urban-farming
  a oakcurric:Keyword ;
  schema:name "urban farming"@en ;
  schema:description """the growing of crops and the raising of animals in towns and cities; includes processing and distributing food, as well as collecting and reusing food waste"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808052Z"^^xsd:dateTime .

oak:keyword-food-insecurity
  a oakcurric:Keyword ;
  schema:name "food insecurity"@en ;
  schema:description "being without reliable access to sufficient, affordable, nutritious food"@en ;
  dcterms:modified "2026-02-12T08:59:15.808108Z"^^xsd:dateTime .

oak:keyword-goods
  a oakcurric:Keyword ;
  schema:name "goods"@en ;
  schema:description "things for sale, or the things that you own"@en ;
  dcterms:modified "2026-02-12T08:59:15.808112Z"^^xsd:dateTime .

oak:keyword-development-gap
  a oakcurric:Keyword ;
  schema:name "development gap"@en ;
  schema:description """the widening difference in standards of living and wellbeing between the world’s richest and poorest countries"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808180Z"^^xsd:dateTime .

oak:keyword-manufacturing-industries
  a oakcurric:Keyword ;
  schema:name "manufacturing industries"@en ;
  schema:description """the secondary economic sector, involving making goods from raw materials or other manufactured products (for example motor vehicles)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808184Z"^^xsd:dateTime .

oak:keyword-service-industries
  a oakcurric:Keyword ;
  schema:name "service industries"@en ;
  schema:description """the tertiary economic sector, which includes tourism, banking, education and health"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808189Z"^^xsd:dateTime .

oak:keyword-microfinance-loans
  a oakcurric:Keyword ;
  schema:name "microfinance loans"@en ;
  schema:description """the provision of small-scale loans given to people in LICs to help them start a small business"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808193Z"^^xsd:dateTime .

oak:keyword-primary-sector
  a oakcurric:Keyword ;
  schema:name "primary sector"@en ;
  schema:description """the part of an economy that involves using natural resources directly from the land or sea, for example, agriculture, fishing, forestry and mining"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808236Z"^^xsd:dateTime .

oak:keyword-secondary-sector
  a oakcurric:Keyword ;
  schema:name "secondary sector"@en ;
  schema:description """the part of an economy that involves manufacturing goods from raw materials or other  manufactured goods, for example factory work, construction and food processing"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808240Z"^^xsd:dateTime .

oak:keyword-tertiary-sector
  a oakcurric:Keyword ;
  schema:name "tertiary sector"@en ;
  schema:description """the part of an economy that provides services to people and businesses rather than goods, for example teachers, doctors, shop workers and delivery drivers"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808245Z"^^xsd:dateTime .

oak:keyword-oil-reserves
  a oakcurric:Keyword ;
  schema:name "oil reserves"@en ;
  schema:description "locations where oil is found in significant amounts"@en ;
  dcterms:modified "2026-02-12T08:59:15.808258Z"^^xsd:dateTime .

oak:keyword-emerging-countries
  a oakcurric:Keyword ;
  schema:name "emerging countries"@en ;
  schema:description """nations with social or business activities in the process of rapid growth and industrialisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808262Z"^^xsd:dateTime .

oak:keyword-post-industrial
  a oakcurric:Keyword ;
  schema:name "post-industrial"@en ;
  schema:description """an economic phase where employment in manufacturing is replaced by employment in services and knowledge economies"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808284Z"^^xsd:dateTime .

oak:keyword-hdi
  a oakcurric:Keyword ;
  schema:name "HDI"@en ;
  schema:description """the Human Development Index (HDI) is a composite measure of development using income, life expectancy and education, ranging between 0 and 1"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808289Z"^^xsd:dateTime .

oak:keyword-benchmark
  a oakcurric:Keyword ;
  schema:name "benchmark"@en ;
  schema:description """a data value supporting comparison within a data set, e.g. a category boundary or highest/lowest value for measures of development for different countries, such as HDI"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808293Z"^^xsd:dateTime .

oak:keyword-pop-up
  a oakcurric:Keyword ;
  schema:name "pop-up"@en ;
  schema:description """in GIS, a read-only display of attribute information (e.g. text, images, charts) often linked to a location"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808298Z"^^xsd:dateTime .

oak:keyword-hydroponics
  a oakcurric:Keyword ;
  schema:name "hydroponics"@en ;
  schema:description "growing plants using mineral nutrient solutions in water and without soil"@en ;
  dcterms:modified "2026-02-12T08:59:15.808332Z"^^xsd:dateTime .

oak:keyword-aeroponics
  a oakcurric:Keyword ;
  schema:name "aeroponics"@en ;
  schema:description "growing plants in a mist environment without the use of soil"@en ;
  dcterms:modified "2026-02-12T08:59:15.808336Z"^^xsd:dateTime .

oak:keyword-biotechnology
  a oakcurric:Keyword ;
  schema:name "biotechnology"@en ;
  schema:description """use of technology to modify organic products or processes, for example, genetically-engineering crops"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808341Z"^^xsd:dateTime .

oak:keyword-new-green-revolution
  a oakcurric:Keyword ;
  schema:name "new green revolution"@en ;
  schema:description """approach to boosting food production that seeks to benefit poor farmers bypassed by the original green revolution and conserve the environment"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808345Z"^^xsd:dateTime .

oak:keyword-appropriate-technology
  a oakcurric:Keyword ;
  schema:name "appropriate technology"@en ;
  schema:description """technology suited to the needs, skills, knowledge and wealth of local people in the environment in which they live"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808349Z"^^xsd:dateTime .

oak:keyword-attraction
  a oakcurric:Keyword ;
  schema:name "attraction"@en ;
  schema:description """feature of a place that makes people want to visit it or take part in an activity"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808408Z"^^xsd:dateTime .

oak:keyword-overtourism
  a oakcurric:Keyword ;
  schema:name "overtourism"@en ;
  schema:description """when too many people visit a place, so that it is spoiled and life becomes difficult for people who live there"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808412Z"^^xsd:dateTime .

oak:keyword-water-transfer
  a oakcurric:Keyword ;
  schema:name "water transfer"@en ;
  schema:description """the movement of water (through pipes or via canals or rivers) from areas of water surplus to areas of water deficit"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808417Z"^^xsd:dateTime .

oak:keyword-water-stress
  a oakcurric:Keyword ;
  schema:name "water stress"@en ;
  schema:description """when the demand for water exceeds the available amount during a certain period or when poor quality restricts its use"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808421Z"^^xsd:dateTime .

oak:keyword-commuter
  a oakcurric:Keyword ;
  schema:name "commuter"@en ;
  schema:description """someone who lives a distance from where they work and has to regularly travel between the two locations"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808425Z"^^xsd:dateTime .

oak:keyword-regional-inequality
  a oakcurric:Keyword ;
  schema:name "regional inequality"@en ;
  schema:description """differences in the standard of living and wealth between two areas of the same country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808442Z"^^xsd:dateTime .

oak:keyword-periphery
  a oakcurric:Keyword ;
  schema:name "periphery"@en ;
  schema:description """the area of a country or region that serves the core and therefore has a weaker economy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808448Z"^^xsd:dateTime .

oak:keyword-biodiversity-hotspot
  a oakcurric:Keyword ;
  schema:name "biodiversity hotspot"@en ;
  schema:description """an area with a very high number of different species, many of which are found nowhere else"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808496Z"^^xsd:dateTime .

oak:keyword-carbon-sink
  a oakcurric:Keyword ;
  schema:name "carbon sink"@en ;
  schema:description "a natural or artificial system that absorbs more carbon dioxide than it releases"@en ;
  dcterms:modified "2026-02-12T08:59:15.808500Z"^^xsd:dateTime .

oak:keyword-gni-per-capita
  a oakcurric:Keyword ;
  schema:name "GNI per capita"@en ;
  schema:description """the total income of a country divided by its population; shows average income per person"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808504Z"^^xsd:dateTime .

oak:keyword-water-conservation
  a oakcurric:Keyword ;
  schema:name "water conservation"@en ;
  schema:description """reducing waste, such as through leakages, and unnecessary use e.g. using drinking water to flush toilets"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808550Z"^^xsd:dateTime .

oak:keyword-groundwater-management
  a oakcurric:Keyword ;
  schema:name "groundwater management"@en ;
  schema:description """regulation and control of water levels, pollution, ownership and use of groundwater"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808554Z"^^xsd:dateTime .

oak:keyword-grey-water
  a oakcurric:Keyword ;
  schema:name "'grey' water"@en ;
  schema:description """water from sinks, showers and washing machines that, whilst not suitable for drinking, can be used for other purposes"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808558Z"^^xsd:dateTime .

oak:keyword-abstraction
  a oakcurric:Keyword ;
  schema:name "abstraction"@en ;
  schema:description "the extraction of water from a water source, such as a river or aquifer"@en ;
  dcterms:modified "2026-02-12T08:59:15.808577Z"^^xsd:dateTime .

oak:keyword-over-abstraction
  a oakcurric:Keyword ;
  schema:name "over-abstraction"@en ;
  schema:description "occurs when the extraction exceeds recharge by precipitation"@en ;
  dcterms:modified "2026-02-12T08:59:15.808582Z"^^xsd:dateTime .

oak:keyword-pre-release-material
  a oakcurric:Keyword ;
  schema:name "pre-release material"@en ;
  schema:description """resources that are released prior to an examination, which include maps, graphs and text that give information about a geographical issue"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808586Z"^^xsd:dateTime .

oak:keyword-tidal-barrage
  a oakcurric:Keyword ;
  schema:name "tidal barrage"@en ;
  schema:description """a dam built across a bay or estuary that uses the movement of the tides to generate electricity"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808590Z"^^xsd:dateTime .

oak:keyword-water-security
  a oakcurric:Keyword ;
  schema:name "water security"@en ;
  schema:description """the reliable availability of an acceptable quantity and quality of water for health, livelihoods and agricultural or industrial production"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808638Z"^^xsd:dateTime .

oak:keyword-water-insecurity
  a oakcurric:Keyword ;
  schema:name "water insecurity"@en ;
  schema:description """when water availability is not enought to ensure the population of an area enjoys good health and earnings; caused by lack of suppy or poor water quality"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808642Z"^^xsd:dateTime .

oak:keyword-waterborne-disease
  a oakcurric:Keyword ;
  schema:name "waterborne disease"@en ;
  schema:description """disease transmitted in contaminated water; contracted by bathing, washing, drinking or the consumption of infected food, e.g. cholera"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808646Z"^^xsd:dateTime .

oak:keyword-water-conflict
  a oakcurric:Keyword ;
  schema:name "water conflict"@en ;
  schema:description """dispute between regions or countries about the distribution and use of freshwater"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808651Z"^^xsd:dateTime .

oak:keyword-organic-produce
  a oakcurric:Keyword ;
  schema:name "organic produce"@en ;
  schema:description """food grown without the use of artificial chemicals, such as fertiliser and pesticide"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808668Z"^^xsd:dateTime .

oak:keyword-agribusiness
  a oakcurric:Keyword ;
  schema:name "agribusiness"@en ;
  schema:description """an intensive farming system often involving high capital costs to maximise profits"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808674Z"^^xsd:dateTime .

oak:keyword-contamination
  a oakcurric:Keyword ;
  schema:name "contamination"@en ;
  schema:description "the pollution of air, water or land with something that is unnatural and harmful"@en ;
  dcterms:modified "2026-02-12T08:59:15.808716Z"^^xsd:dateTime .

oak:keyword-energy-efficient
  a oakcurric:Keyword ;
  schema:name "energy efficient"@en ;
