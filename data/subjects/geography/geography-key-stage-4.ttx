  a oakcurric:KeyLearningPoint ;
  rdfs:label """Processes of transportation and deposition influences coastal landforms (spits, beaches, bars)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484387Z"^^xsd:dateTime .

