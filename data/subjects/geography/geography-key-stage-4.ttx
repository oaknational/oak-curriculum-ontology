  a oakcurric:KeyLearningPoint ;
  rdfs:label """Animals are well adapted to the physical conditions in the taiga, for example, by being migratory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22984-3
  a oakcurric:KeyLearningPoint ;
