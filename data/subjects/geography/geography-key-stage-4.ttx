  dcterms:modified "2026-02-12T08:59:21.638420Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24566-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There is overlap between regions in which many face hunger and those in which many lack safe water and/or electricity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638427Z"^^xsd:dateTime .

