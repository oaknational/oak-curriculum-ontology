  a oakcurric:KeyLearningPoint ;
  rdfs:label "The atmospheric circulation determines the location of global pressure belts."@en ;
  dcterms:modified "2026-02-12T08:59:21.685836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24425-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Global pressure belts affect surface winds and patterns of rainfall."@en ;
  dcterms:modified "2026-02-12T08:59:21.685840Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24441-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical processes shape landforms through interaction with geology."@en ;
  dcterms:modified "2026-02-12T08:59:21.687467Z"^^xsd:dateTime .

