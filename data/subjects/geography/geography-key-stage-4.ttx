  a oakcurric:KeyLearningPoint ;
  rdfs:label """Impacts of energy insecurity include exploration in sensitive areas, economic and environmental costs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643194Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24575-1
  a oakcurric:KeyLearningPoint ;
