oak:keylearningpoint-lesson-24579-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Globally, there are areas of surplus (security) and deficit (insecurity)."@en ;
  dcterms:modified "2026-02-12T08:59:21.643189Z"^^xsd:dateTime .

