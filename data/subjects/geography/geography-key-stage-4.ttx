  a oakcurric:KeyLearningPoint ;
  rdfs:label """Drawing a sketch from a photograph can be a good way of highlighting certain geographical features."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706975Z"^^xsd:dateTime .

