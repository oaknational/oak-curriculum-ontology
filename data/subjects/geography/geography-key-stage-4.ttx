  dcterms:modified "2026-02-12T08:59:21.674049Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22969-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An ecosystem is a natural system in which plants, animals and their non-living environment interact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675101Z"^^xsd:dateTime .

