  a oakcurric:KeyLearningPoint ;
  rdfs:label """Supply  (or lack of resources) limits consumption in some locations, as does poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638432Z"^^xsd:dateTime .

