  a oakcurric:Keyword ;
  schema:name "rock type"@en ;
  schema:description "the physical and chemical characteristics of rocks"@en ;
  dcterms:modified "2026-02-12T08:59:15.823741Z"^^xsd:dateTime .

oak:keyword-discordant-coastline
  a oakcurric:Keyword ;
  schema:name "discordant coastline"@en ;
  schema:description "where rock layers (hard and soft) run perpendicular to the coastline"@en ;
  dcterms:modified "2026-02-12T08:59:15.823747Z"^^xsd:dateTime .

oak:keyword-concordant-coastline
  a oakcurric:Keyword ;
  schema:name "concordant coastline"@en ;
  schema:description "where rock layers (hard and soft) run parallel to the coastline"@en ;
  dcterms:modified "2026-02-12T08:59:15.823754Z"^^xsd:dateTime .

oak:keyword-storm-surge
  a oakcurric:Keyword ;
  schema:name "storm surge"@en ;
  schema:description """the rising of the sea as a result of atmospheric pressure changes and wind associated with a storm"""@en ;
  dcterms:modified "2026-02-12T08:59:15.823846Z"^^xsd:dateTime .

oak:keyword-bottom-up-development
  a oakcurric:Keyword ;
  schema:name "bottom-up development"@en ;
  schema:description """small-scale projects led by local people to meet community needs, often supported by NGOs"""@en ;
  dcterms:modified "2026-02-12T08:59:15.823850Z"^^xsd:dateTime .

oak:keyword-cooperative
  a oakcurric:Keyword ;
  schema:name "cooperative"@en ;
  schema:description """a group of people working together to achieve shared goals. A housing cooperative is where residents help plan and manage their homes, often in partnership with local government or NGOs"""@en ;
  dcterms:modified "2026-02-12T08:59:15.823855Z"^^xsd:dateTime .

oak:keyword-wind-shear
  a oakcurric:Keyword ;
  schema:name "wind shear"@en ;
  schema:description "the change in wind speed and direction at different altitudes"@en ;
  dcterms:modified "2026-02-12T08:59:15.823943Z"^^xsd:dateTime .

oak:keyword-latent-heat
  a oakcurric:Keyword ;
  schema:name "latent heat"@en ;
  schema:description """the energy stored in water vapour when it evaporates, that is released when the vapour condenses back into liquid water"""@en ;
  dcterms:modified "2026-02-12T08:59:15.823947Z"^^xsd:dateTime .

oak:keyword-typhoon
  a oakcurric:Keyword ;
  schema:name "typhoon"@en ;
  schema:description "a tropical cyclone occurring in the western Pacific or Indian oceans"@en ;
  dcterms:modified "2026-02-12T08:59:15.824069Z"^^xsd:dateTime .

oak:keyword-primary-effects
  a oakcurric:Keyword ;
  schema:name "primary effects"@en ;
  schema:description "the immediate effects of a natural disaster"@en ;
  dcterms:modified "2026-02-12T08:59:15.824075Z"^^xsd:dateTime .

oak:keyword-secondary-effects
  a oakcurric:Keyword ;
  schema:name "secondary effects"@en ;
  schema:description """indirect impacts that arise after an event, they often happen because of the primary effects"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824079Z"^^xsd:dateTime .

oak:keyword-sediment
  a oakcurric:Keyword ;
  schema:name "sediment"@en ;
  schema:description "Sediment is material that is moved by water or air and settles in another place."@en ;
  dcterms:modified "2026-02-12T08:59:15.824311Z"^^xsd:dateTime .

oak:keyword-margin
  a oakcurric:Keyword ;
  schema:name "margin"@en ;
  schema:description "the boundary where tectonic plates meet"@en ;
  dcterms:modified "2026-02-12T08:59:15.824494Z"^^xsd:dateTime .

oak:keyword-subduction
  a oakcurric:Keyword ;
  schema:name "subduction"@en ;
  schema:description """the process at a destructive plate margin where a denser oceanic plate sinks beneath a less dense plate into the mantle"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824499Z"^^xsd:dateTime .

oak:keyword-bathymetry
  a oakcurric:Keyword ;
  schema:name "bathymetry"@en ;
  schema:description """the measurement of elevation for bodies of water, e.g. depth of oceans, seas, or lakes"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824505Z"^^xsd:dateTime .

oak:keyword-regulate
  a oakcurric:Keyword ;
  schema:name "regulate"@en ;
  schema:description """to control, for example, the flow of water in a pipe or the temperature in a room"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824529Z"^^xsd:dateTime .

oak:keyword-soil-health
  a oakcurric:Keyword ;
  schema:name "soil health"@en ;
  schema:description """the structure, composition and nutrient content of a soil; a measure of soil fertility"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824533Z"^^xsd:dateTime .

oak:keyword-river-discharge
  a oakcurric:Keyword ;
  schema:name "river discharge"@en ;
  schema:description """the volume of water that flows through a river at a given point over a specific period of time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.824838Z"^^xsd:dateTime .

oak:keyword-river-velocity
  a oakcurric:Keyword ;
  schema:name "river velocity"@en ;
  schema:description "the speed at which water flows in a river"@en ;
  dcterms:modified "2026-02-12T08:59:15.824844Z"^^xsd:dateTime .

oak:keyword-georeferenced-data
  a oakcurric:Keyword ;
  schema:name "georeferenced data"@en ;
  schema:description """information which has been tied to a particular location (geolocated), using an agreed system such as latitude and longitude"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825004Z"^^xsd:dateTime .

oak:keyword-primary-impact
  a oakcurric:Keyword ;
  schema:name "primary impact"@en ;
  schema:description "the immediate impacts of a tectonic hazard which are directly caused by it"@en ;
  dcterms:modified "2026-02-12T08:59:15.825008Z"^^xsd:dateTime .

oak:keyword-secondary-impact
  a oakcurric:Keyword ;
  schema:name "secondary impact"@en ;
  schema:description """indirect effects that occur as a consequence of a tectonic hazard’s primary impacts"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825015Z"^^xsd:dateTime .

oak:keyword-asthenosphere
  a oakcurric:Keyword ;
  schema:name "asthenosphere"@en ;
  schema:description "a semi-solid layer of Earth's upper mantle"@en ;
  dcterms:modified "2026-02-12T08:59:15.825053Z"^^xsd:dateTime .

oak:keyword-convection
  a oakcurric:Keyword ;
  schema:name "convection"@en ;
  schema:description """the transfer of heat through the movement of fluids: warmer, less dense material rises and cooler, denser material sinks, creating a circular flow"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825057Z"^^xsd:dateTime .

oak:keyword-webmap
  a oakcurric:Keyword ;
  schema:name "webmap"@en ;
  schema:description """a digital map which is available online. It will usually be interactive or can be created or saved by the user online (‘in the cloud’)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825062Z"^^xsd:dateTime .

oak:keyword-spatial-distribution
  a oakcurric:Keyword ;
  schema:name "spatial distribution"@en ;
  schema:description """the spread of information (data) across an area, creating spatial patterns which geographers attempt to describe, explain and analyse"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825066Z"^^xsd:dateTime .

oak:keyword-geospatial-data
  a oakcurric:Keyword ;
  schema:name "geospatial  data"@en ;
  schema:description """georeferenced information including quantitative data (e.g. numbers) or qualitative data (e.g. photos), which has been tied to a particular location (geolocated)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825407Z"^^xsd:dateTime .

oak:keyword-media-layers
  a oakcurric:Keyword ;
  schema:name "media layers"@en ;
  schema:description """overlays of scanned maps, aerial or satellite images which can be georeferenced to visually line up with other layers"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825412Z"^^xsd:dateTime .

oak:keyword-freeze-thaw-weathering
  a oakcurric:Keyword ;
  schema:name "freeze-thaw weathering"@en ;
  schema:description "the break up of rocks caused by water regularly freezing and thawing"@en ;
  dcterms:modified "2026-02-12T08:59:15.825419Z"^^xsd:dateTime .

oak:keyword-glacial-till
  a oakcurric:Keyword ;
  schema:name "glacial till"@en ;
  schema:description "a mixture of unsorted debris"@en ;
  dcterms:modified "2026-02-12T08:59:15.825424Z"^^xsd:dateTime .

oak:keyword-greenfield-site
  a oakcurric:Keyword ;
  schema:name "greenfield site"@en ;
  schema:description """land, often rural or on the edges of urban areas, which has not been built on before"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825428Z"^^xsd:dateTime .

oak:keyword-hibernation
  a oakcurric:Keyword ;
  schema:name "hibernation"@en ;
  schema:description """a state that certain animals enter to save energy during periods of unfavourable weather conditions or food shortages"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825457Z"^^xsd:dateTime .

oak:keyword-infiltration
  a oakcurric:Keyword ;
  schema:name "infiltration"@en ;
  schema:description "the process by which water on the ground surface enters the soil"@en ;
  dcterms:modified "2026-02-12T08:59:15.825461Z"^^xsd:dateTime .

oak:keyword-lag-time
  a oakcurric:Keyword ;
  schema:name "lag time"@en ;
  schema:description "the time between the peak rainfall and the peak discharge"@en ;
  dcterms:modified "2026-02-12T08:59:15.825468Z"^^xsd:dateTime .

oak:keyword-drainage-density
  a oakcurric:Keyword ;
  schema:name "drainage density"@en ;
  schema:description """a measure of how many rivers and streams there are within a given area. A high drainage density indicates many streams and rivers in the given area"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825473Z"^^xsd:dateTime .

oak:keyword-last-glacial-maximum-lgm
  a oakcurric:Keyword ;
  schema:name "Last Glacial Maximum (LGM)"@en ;
  schema:description """period when ice sheets were at their largest extent, during the last Ice Age about 26 000 years ago"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825592Z"^^xsd:dateTime .

oak:keyword-corrie-or-cwm
  a oakcurric:Keyword ;
  schema:name "corrie (or cwm)"@en ;
  schema:description """a bowl-shaped hollow eroded by a glacier, typically forming at the head of a valley"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825596Z"^^xsd:dateTime .

oak:keyword-analysis-tools
  a oakcurric:Keyword ;
  schema:name "analysis tools"@en ;
  schema:description """a range of GIS applications used to support the processing, analysing, and visualising of spatial data"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826127Z"^^xsd:dateTime .

oak:keyword-trace-downstream
  a oakcurric:Keyword ;
  schema:name "Trace Downstream"@en ;
  schema:description """a GIS tool which maps the course of a river from a location such as its source to the end of the river"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826133Z"^^xsd:dateTime .

oak:keyword-create-watersheds
  a oakcurric:Keyword ;
  schema:name "Create Watersheds"@en ;
  schema:description """a GIS tool which maps the drainage basin or catchment of a river and all of its tributaries"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826137Z"^^xsd:dateTime .

oak:keyword-cold-environments
  a oakcurric:Keyword ;
  schema:name "cold environments"@en ;
  schema:description """environments found at higher latitudes and higher altitudes; they include polar, tundra and alpine biomes"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826142Z"^^xsd:dateTime .

oak:keyword-tundra
  a oakcurric:Keyword ;
  schema:name "tundra"@en ;
  schema:description """a vast, flat, treeless Arctic region where vegetation growth is hindered by extreme low temperatures and short growing seasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826146Z"^^xsd:dateTime .

oak:keyword-fertility-rate
  a oakcurric:Keyword ;
  schema:name "fertility rate"@en ;
  schema:description "average number of children per woman in a population"@en ;
  dcterms:modified "2026-02-12T08:59:15.826458Z"^^xsd:dateTime .

oak:keyword-lithosphere
  a oakcurric:Keyword ;
  schema:name "lithosphere"@en ;
  schema:description "the rigid outer layer of Earth which includes the crust"@en ;
  dcterms:modified "2026-02-12T08:59:15.826727Z"^^xsd:dateTime .

oak:keyword-national
  a oakcurric:Keyword ;
  schema:name "national"@en ;
  schema:description "relating to a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.826892Z"^^xsd:dateTime .

oak:keyword-central-business-district-cbd
  a oakcurric:Keyword ;
  schema:name "Central Business District: CBD"@en ;
  schema:description """commonly, the centrally-located commercial and business district in a city with a dominance of offices and shops"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827047Z"^^xsd:dateTime .

oak:keyword-inner-city
  a oakcurric:Keyword ;
  schema:name "inner city"@en ;
  schema:description """located between the city centre and the suburbs and often an area of high density terraced housing"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827051Z"^^xsd:dateTime .

oak:keyword-urban-change
  a oakcurric:Keyword ;
  schema:name "urban change"@en ;
  schema:description "changes that occur in a city due to its growth or decline"@en ;
  dcterms:modified "2026-02-12T08:59:15.827107Z"^^xsd:dateTime .

oak:keyword-place-specific-details
  a oakcurric:Keyword ;
  schema:name "place-specific details"@en ;
  schema:description "facts and figures which are particular to a place"@en ;
  dcterms:modified "2026-02-12T08:59:15.827111Z"^^xsd:dateTime .

oak:keyword-cultural-mix
  a oakcurric:Keyword ;
  schema:name "cultural mix"@en ;
  schema:description """in population, a community of people from different backgrounds with their own beliefs and traditions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827116Z"^^xsd:dateTime .

oak:keyword-channel
  a oakcurric:Keyword ;
  schema:name "channel"@en ;
  schema:description "pathway through which water flows in a river or stream"@en ;
  dcterms:modified "2026-02-12T08:59:15.827299Z"^^xsd:dateTime .

oak:keyword-destructive-waves
  a oakcurric:Keyword ;
  schema:name "destructive waves"@en ;
  schema:description """high, steep waves, typically formed by local storms, that remove sediment from beaches"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827367Z"^^xsd:dateTime .

oak:keyword-constructive-waves
  a oakcurric:Keyword ;
  schema:name "constructive waves"@en ;
  schema:description """low waves, typically formed by distant storms, that deposit sediment onto beaches"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827372Z"^^xsd:dateTime .

oak:keyword-buffer
  a oakcurric:Keyword ;
  schema:name "buffer"@en ;
  schema:description """in GIS, an area generated by analysis tools for a specified distance around a point, line or polygon feature"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827397Z"^^xsd:dateTime .

oak:keyword-integrated-transport-system
  a oakcurric:Keyword ;
  schema:name "integrated transport system"@en ;
  schema:description """an interconnected urban transport network, with interchange hubs linking different forms of transport, such as bicycles, buses and cars"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827421Z"^^xsd:dateTime .

oak:keyword-urban-greening
  a oakcurric:Keyword ;
  schema:name "urban greening"@en ;
  schema:description """the greening of urban areas, involving planting trees and the creation of green areas and parks"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827426Z"^^xsd:dateTime .

oak:keyword-longshore-drift
  a oakcurric:Keyword ;
  schema:name "longshore drift"@en ;
  schema:description "movement of sediment along the coast by wave action in a zigzag pattern"@en ;
  dcterms:modified "2026-02-12T08:59:15.827520Z"^^xsd:dateTime .

oak:keyword-economic-impact
  a oakcurric:Keyword ;
  schema:name "economic impact"@en ;
  schema:description """the effect of an event on the financial conditions of an area, e.g. employment, income, investment"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827525Z"^^xsd:dateTime .

oak:keyword-glacial-landforms
  a oakcurric:Keyword ;
  schema:name "glacial landforms"@en ;
  schema:description """physical landscape features created by the action of glaciers during a glaciation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827704Z"^^xsd:dateTime .

oak:keyword-oblique-view
  a oakcurric:Keyword ;
  schema:name "oblique view"@en ;
  schema:description """a view over a landscape from one side at an angle (also known as ‘perspective view’)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827710Z"^^xsd:dateTime .

oak:keyword-orientation
  a oakcurric:Keyword ;
  schema:name "orientation"@en ;
  schema:description """rotation of a map in different dimensions (2D or 3D) to provide different viewpoints around the compass"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827715Z"^^xsd:dateTime .

oak:keyword-spot-height
  a oakcurric:Keyword ;
  schema:name "spot height"@en ;
  schema:description "a point marked on a map showing a particular height"@en ;
  dcterms:modified "2026-02-12T08:59:15.827868Z"^^xsd:dateTime .

oak:keyword-remote-sensing
  a oakcurric:Keyword ;
  schema:name "remote sensing"@en ;
  schema:description """the collection of data at a distance reflected or emitted by objects, living things or areas on different wavelengths of the electromagnetic spectrum, observed by satellite or aircraft"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827872Z"^^xsd:dateTime .

oak:keyword-satellite-imagery
  a oakcurric:Keyword ;
  schema:name "satellite imagery"@en ;
  schema:description """a type of remote sensing which uses observations by satellites of selected parts of the electromagnetic spectrum to monitor terrestrial, oceanic or atmospheric features and processes"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827877Z"^^xsd:dateTime .

oak:keyword-aerial-imagery
  a oakcurric:Keyword ;
  schema:name "aerial imagery"@en ;
  schema:description """a type of remote sensing which uses observations by aircraft of selected parts of the electromagnetic spectrum to monitor terrestrial, oceanic or atmospheric features and processes"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827881Z"^^xsd:dateTime .

oak:keyword-rift-valley
  a oakcurric:Keyword ;
  schema:name "rift valley"@en ;
  schema:description """a long, narrow depression formed when a tectonic plate stretches and fractures at a constructive margin, causing the land to sink between parallel fault lines"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828601Z"^^xsd:dateTime .

oak:keyword-shield-volcano
  a oakcurric:Keyword ;
  schema:name "shield volcano"@en ;
  schema:description """a broad, gently sloping volcano formed by basaltic lava that is runny and flows easily. Eruptions tend to be effusive rather than explosive - lava flows out"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828608Z"^^xsd:dateTime .

oak:keyword-flood-defences
  a oakcurric:Keyword ;
  schema:name "flood defences"@en ;
  schema:description "structures built to protect areas from flooding"@en ;
  dcterms:modified "2026-02-12T08:59:15.828700Z"^^xsd:dateTime .

oak:keyword-urban-regeneration
  a oakcurric:Keyword ;
  schema:name "urban regeneration"@en ;
  schema:description "planned improvements to an area of deprivation within a town or city"@en ;
  dcterms:modified "2026-02-12T08:59:15.828847Z"^^xsd:dateTime .

oak:keyword-coastal-erosion-landforms
  a oakcurric:Keyword ;
  schema:name "coastal erosion landforms"@en ;
  schema:description "landforms resulting from a dominance of coastal erosion"@en ;
  dcterms:modified "2026-02-12T08:59:15.828930Z"^^xsd:dateTime .

oak:keyword-coastal-deposition-landforms
  a oakcurric:Keyword ;
  schema:name "coastal deposition landforms"@en ;
  schema:description "landforms resulting from a dominance of coastal deposition"@en ;
  dcterms:modified "2026-02-12T08:59:15.828935Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oak:misconception-people-living-poverty-today-once
  a oakcurric:Misconception ;
  oakcurric:statement "There are more people living in poverty today than there once were."@en ;
  oakcurric:correction """The share of the global population living in extreme poverty has dramatically fallen in the past decades."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675448Z"^^xsd:dateTime .

oak:misconception-poorer-people-live-far-city
  a oakcurric:Misconception ;
  oakcurric:statement """Poorer people always live far away from the city centre, and richer people live near the centre."""@en ;
  oakcurric:correction """Jakarta is more complex. In Jakarta, many wealthy areas stretch from north to south along the central axis, but some low-income areas are found right next to rich districts, even in the inner city. Kampungs can develop wherever there’s space."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675513Z"^^xsd:dateTime .

oak:misconception-within-given-biome-plants-animals
  a oakcurric:Misconception ;
  oakcurric:statement "Within a given biome, the plants and animals are the same everywhere."@en ;
  oakcurric:correction "Small-scale variation occurs within global biomes due to local factors."@en ;
  dcterms:modified "2026-02-12T08:59:18.675518Z"^^xsd:dateTime .

oak:misconception-areas-within-same-biome-physically
  a oakcurric:Misconception ;
  oakcurric:statement "Areas within the same biome are physically connected."@en ;
  oakcurric:correction """A biome may occur on different continents at the same or similar latitude, such as the tropical rainforest biome."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675529Z"^^xsd:dateTime .

oak:misconception-rapid-urban-growth-jakarta-improved
  a oakcurric:Misconception ;
  oakcurric:statement """Rapid urban growth in Jakarta has improved living conditions for everyone, reducing inequality between rich and poor."""@en ;
  oakcurric:correction """Rapid urban growth in Jakarta has not improved life for everyone. While some benefit from new jobs and development, many poor migrants face rising living costs, limited job security and end up in squatter settlements."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675534Z"^^xsd:dateTime .

oak:misconception-global-shift-manufacturing-industries-developed
  a oakcurric:Misconception ;
  oakcurric:statement """The 'global shift' of manufacturing industries from developed to emerging and/or developing countries was a one-off movement of jobs."""@en ;
  oakcurric:correction """TNCs continue to seek locations with the lowest wages, meaning the loss of manufacturing jobs from emerging countries is possible; so some of the benefits of FDI may only be short-term."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675538Z"^^xsd:dateTime .

oak:misconception-environmental-impacts-economic-development-negative
  a oakcurric:Misconception ;
  oakcurric:statement "Environmental impacts from economic development are always negative."@en ;
  oakcurric:correction """Environmental impacts from development can be negative, but they can also be positive, such as increased environmental awareness and reduced use of agricultural chemicals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675565Z"^^xsd:dateTime .

oak:misconception-good-enquiry-question-answered-data
  a oakcurric:Misconception ;
  oakcurric:statement "A good enquiry question is answered in the data collection stage."@en ;
  oakcurric:correction """A good enquiry question guides you through all stages of the enquiry to help you find an answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675586Z"^^xsd:dateTime .

oak:misconception-urban-areas-experience-one-process
  a oakcurric:Misconception ;
  oakcurric:statement "Urban areas can only experience one process of urban change at a time."@en ;
  oakcurric:correction """While in theory urban changes appear to follow a logical order, in reality processes often overlap and it is best to avoid thinking of changes occurring along a set timeline."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675699Z"^^xsd:dateTime .

oak:misconception-coastal-management-positively-impacts-coastlines
  a oakcurric:Misconception ;
  oakcurric:statement "Coastal management always positively impacts coastlines."@en ;
  oakcurric:correction """Coastal management can sometimes harm coastlines by causing erosion in nearby areas. For example, building groynes may protect one section but increase erosion further down the coast."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675714Z"^^xsd:dateTime .

oak:misconception-pupils-think-focus-lesson-migration
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can think that as the focus of the lesson is about migration, that inflows and outflows are responsible for all population change."""@en ;
  oakcurric:correction """Migration is important to understand when addressing population change but changes to birth and death rates must also be considered alongside for complete understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675762Z"^^xsd:dateTime .

oak:misconception-regeneration-brings-positive-impacts
  a oakcurric:Misconception ;
  oakcurric:statement "Regeneration only brings positive impacts."@en ;
  oakcurric:correction """Whilst regeneration in Liverpool has been very positive for the CBD and inner city overall, it has brought a number of challenges such as negative impacts of studentification, gentrification and e-commerce developments."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675772Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-site-situation
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils can confuse site and situation."@en ;
  oakcurric:correction """The site of a settlement is its exact point on the surface of Earth and the situation describes it in relation to other human and physical features."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675777Z"^^xsd:dateTime .

oak:misconception-highlighting-flaws-geographical-enquiry-shows
  a oakcurric:Misconception ;
  oakcurric:statement """Highlighting the flaws in a geographical enquiry shows that I am a poor geographer."""@en ;
  oakcurric:correction """Good geographers take time to be deeply reflective of their work and will present their findings honestly and transparently, even if they show errors that affect the final outcome. Good geographers also show how a study can be improved and extended."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675793Z"^^xsd:dateTime .

oak:misconception-house-prices-decrease-further-one
  a oakcurric:Misconception ;
  oakcurric:statement "House prices will decrease the further one gets from the CBD."@en ;
  oakcurric:correction """The price per square metre may decrease as one moves further from the CBD, but as homes get larger with that distance, one cannot say that they get cheaper overall."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675803Z"^^xsd:dateTime .

oak:misconception-enough-issues-rural-areas-make
  a oakcurric:Misconception ;
  oakcurric:statement """There are not enough issues in rural areas to make it worth studying fieldwork enquiries there."""@en ;
  oakcurric:correction """Rural areas have a lot of issues around inequality and access to services as well as interesting cultural geography to study."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675809Z"^^xsd:dateTime .

oak:misconception-secondary-data-collected-geographical-experts
  a oakcurric:Misconception ;
  oakcurric:statement "Secondary data has to be collected by geographical experts."@en ;
  oakcurric:correction """Secondary data is often collected by experts or professional geographers but it can also be the data collected by other students in a different time frame."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675814Z"^^xsd:dateTime .

oak:misconception-indonesia-made-small-islands-small
  a oakcurric:Misconception ;
  oakcurric:statement "Indonesia is made up of small islands and has a small population."@en ;
  oakcurric:correction """In fact, Indonesia is the world's fourth most populous country and while its 17 000 islands do include many small islands, it has many large islands too: for example, Java is around the same size as England and Borneo's size is similar to France."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675849Z"^^xsd:dateTime .

oak:misconception-informal-employment-unskilled
  a oakcurric:Misconception ;
  oakcurric:statement "Those in informal employment are unskilled."@en ;
  oakcurric:correction """Just because work is unregulated it does not mean that the workers are unskilled. While some workers may not have official certification of skills, they still possess expertise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675854Z"^^xsd:dateTime .

oak:misconception-rank-index-multiple-deprivation-tells
  a oakcurric:Misconception ;
  oakcurric:statement """The rank on the Index of Multiple Deprivation tells you everything about the deprivation of an area."""@en ;
  oakcurric:correction """The Index of Multiple Deprivation is calculated by combining seven indicators. The overall rank is therefore an average and can mask significant variation in different aspects of deprivation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675858Z"^^xsd:dateTime .

oak:misconception-immigrants-asylum-seekers-refugees-same
  a oakcurric:Misconception ;
  oakcurric:statement "Immigrants, asylum seekers and refugees are all the same thing."@en ;
  oakcurric:correction """The three terms are often confused and misused. All asylum seekers are immigrants but not all immigrants are asylum seekers. Some people seeking asylum may be granted refugee status while others may not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675863Z"^^xsd:dateTime .

oak:misconception-uk-cautious-fdi-tncs
  a oakcurric:Misconception ;
  oakcurric:statement "The UK should be cautious of FDI and TNCs."@en ;
  oakcurric:correction """FDI and TNCs are crucial aspects of international business. Without FDI many businesses would not be able to operate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675867Z"^^xsd:dateTime .

oak:misconception-hot-countries-use-less-energy
  a oakcurric:Misconception ;
  oakcurric:statement """Hot countries use less energy because it is warm all year so they do not need to heat their houses."""@en ;
  oakcurric:correction """While people in hot countries may need to use less energy on heating, energy use depends most on how developed a country is - developed countries use more energy per person because they have more industries, transport and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675874Z"^^xsd:dateTime .

oak:misconception-managed-retreat-land-allowed-erode
  a oakcurric:Misconception ;
  oakcurric:statement "Managed retreat is when the land is allowed to erode without any direction."@en ;
  oakcurric:correction """Managed retreat allows for certain areas to erode or flood in a controlled manner. This approach is often chosen for low value land, where it can create natural habitats and reduce long term maintenance costs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675879Z"^^xsd:dateTime .

oak:misconception-rising-demand-energy-simply-worlds
  a oakcurric:Misconception ;
  oakcurric:statement "Rising demand for energy is simply down to the world's growing population."@en ;
  oakcurric:correction """This is one reason for the growing demand for energy, but economic development is another factor that affects demand. As people become richer, their consumption of energy increases, e.g. instead of using bicycles for transport, people use mopeds."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675907Z"^^xsd:dateTime .

oak:misconception-demand-oil-decreases-oil-prices
  a oakcurric:Misconception ;
  oakcurric:statement "If demand for oil decreases then oil prices will always decrease too."@en ;
  oakcurric:correction """Although oil prices may decrease if demand decreases, oil-producing countries can increase the price of oil by reducing the amount of oil they supply. This requires oil-producing countries to work together to reduce supply."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675912Z"^^xsd:dateTime .

oak:misconception-recyclable-energy-same-renewable-energy
  a oakcurric:Misconception ;
  oakcurric:statement "Recyclable energy is the same as renewable energy."@en ;
  oakcurric:correction """Renewable energy comes from natural processes that are constantly renewed, so they never run out. Recyclable energy comes from resources that are often finite (they can run out) but which can be reprocessed or reused to extend their use."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675922Z"^^xsd:dateTime .

oak:misconception-energy-efficiency-energy-conservation-mean
  a oakcurric:Misconception ;
  oakcurric:statement "Energy efficiency and energy conservation mean the same thing."@en ;
  oakcurric:correction """In fact, energy efficiency is about using technology to do the same task but with less use of energy, while energy conservation is about changing people's behaviour so they use less energy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675941Z"^^xsd:dateTime .

oak:misconception-indirect-effects-human-activities-less
  a oakcurric:Misconception ;
  oakcurric:statement "Indirect effects of human activities are less important than direct effects."@en ;
  oakcurric:correction """Indirect effects of human activities at the coast have very significant effects: for example, rising sea levels as a result of global warming are an indirect effect with globally important impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675951Z"^^xsd:dateTime .

oak:misconception-got-your-electricity-100-renewable
  a oakcurric:Misconception ;
  oakcurric:statement """If you got your electricity from 100% renewable energy sources, then your carbon footprint would be zero."""@en ;
  oakcurric:correction """Even if all your electricity comes from renewables, other parts of your lifestyle (like the manufacture of the clothes you wear, the food you eat, the technology you use) still produce carbon emissions elsewhere — often in other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675955Z"^^xsd:dateTime .

oak:misconception-biomass-renewable-source-energy-because
  a oakcurric:Misconception ;
  oakcurric:statement """Biomass is not a renewable source of energy because carbon dioxide is released when it is burned."""@en ;
  oakcurric:correction """Renewable energy comes from sources that don’t run out or are quickly renewed. Because plants are quickly replaced, biomass is a renewable energy source. Also, biomass is carbon neutral as CO2 released is the same CO2 absorbed during plant growth."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675978Z"^^xsd:dateTime .

oak:misconception-missing-small-step-procedural-knowledge
  a oakcurric:Misconception ;
  oakcurric:statement "Missing a small step in procedural knowledge for GIS."@en ;
  oakcurric:correction """Emphasise the most likely pitfalls e.g. toggling 'Time'; configuring symbols and pop-ups"""@en ;
  dcterms:modified "2026-02-12T08:59:18.676259Z"^^xsd:dateTime .

oak:misconception-spit-formation-occurs-solely-sediment
  a oakcurric:Misconception ;
  oakcurric:statement "Spit formation occurs solely from sediment deposition."@en ;
  oakcurric:correction """Longshore drift, wave and wind direction play an important role in the formation of spits, and a change in direction of the coastline is required."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676354Z"^^xsd:dateTime .

oak:misconception-swash-wave-moves-beach-sea
  a oakcurric:Misconception ;
  oakcurric:statement """Swash is when a wave moves down the beach to the sea and backwash is when a wave moves up the beach from the sea."""@en ;
  oakcurric:correction """The swash is the movement of the wave from the sea to the beach which brings sediment with it. Whereas the backwash is the movement of the wave from the beach to sea."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676543Z"^^xsd:dateTime .

oak:misconception-indigenous-people-cut-commercial-world
  a oakcurric:Misconception ;
  oakcurric:statement "Indigenous people are cut off from the commercial world."@en ;
  oakcurric:correction """Indigenous people are increasingly linked to the wider world through technology and are affected by large-scale commercial resource exploitation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677900Z"^^xsd:dateTime .

oak:misconception-individuals-cannot-make-significant-contributions
  a oakcurric:Misconception ;
  oakcurric:statement "Individuals cannot make significant contributions to mitigation."@en ;
  oakcurric:correction """Although national and international mitigation strategies are essential to achieve meaingful mitigation of climate change, individual actions, such as reducing energy use, collectively contribute to mitigation efforts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678314Z"^^xsd:dateTime .

oak:misconception-hard-engineering-better-soft-engineering
  a oakcurric:Misconception ;
  oakcurric:statement "Hard engineering is always better than soft engineering."@en ;
  oakcurric:correction """While hard engineering can be effective, it is not always the best choice due to cost and environmental impact. Soft engineering can be more sustainable and less intrusive."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678422Z"^^xsd:dateTime .

oak:misconception-white-space-map-means-nothing
  a oakcurric:Misconception ;
  oakcurric:statement "White space on a map means there is nothing there."@en ;
  oakcurric:correction "White space means that the land cover there is grassland or farmland."@en ;
  dcterms:modified "2026-02-12T08:59:18.678590Z"^^xsd:dateTime .

oak:misconception-tropical-storms-cannot-accurately-predicted
  a oakcurric:Misconception ;
  oakcurric:statement "Tropical storms cannot be accurately predicted."@en ;
  oakcurric:correction """While it is challenging, advances in technology and meteorology have improved the accuracy of tropical storm predictions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678805Z"^^xsd:dateTime .

oak:misconception-people-jakarta-equal-access-safe
  a oakcurric:Misconception ;
  oakcurric:statement "All people in Jakarta have equal access to safe housing with running water."@en ;
  oakcurric:correction """Not all people in Jakarta have equal access to safe housing with running water. Poorer communities, especially in informal settlements, often lack basic services, while wealthier areas have more reliable infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679501Z"^^xsd:dateTime .

oak:misconception-education-healthcare-jakarta-improve-wellbeing
  a oakcurric:Misconception ;
  oakcurric:statement """Education and healthcare in Jakarta only improve wellbeing, not economic opportunities."""@en ;
  oakcurric:correction """Both sectors also create job opportunities. Schools, hospitals, and research centres employ many people, and better education leads to higher-skilled, better-paid work."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679516Z"^^xsd:dateTime .

oak:misconception-jakarta-important-nationally-because-capital
  a oakcurric:Misconception ;
  oakcurric:statement "Jakarta is only important nationally because it is the capital city."@en ;
  oakcurric:correction """Jakarta is not just important because it’s the capital. It also plays a major role nationally as Indonesia’s economic centre and globally through its trade, transport links, and role as the ASEAN headquarters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679592Z"^^xsd:dateTime .

oak:misconception-jakartas-suburbs-poor-unplanned-informal
  a oakcurric:Misconception ;
  oakcurric:statement "Jakarta’s suburbs are poor and unplanned with informal settlements."@en ;
  oakcurric:correction """Jakarta’s suburbs include both wealthy and mid-income areas, many of which are well-planned and developed (e.g. Pondok Indah, Kelapa Gading)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679596Z"^^xsd:dateTime .

oak:misconception-people-jakarta-easily-access-good
  a oakcurric:Misconception ;
  oakcurric:statement """Most people in Jakarta can easily access good healthcare and education, no matter what income level they have."""@en ;
  oakcurric:correction """In poorer parts of Jakarta, schools often lack teachers, books, and resources. Although Jakarta has about 1 doctor for every 350 people, hospitals are still overcrowded, and poor families struggle to get care."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679689Z"^^xsd:dateTime .

oak:misconception-areas-jakarta-experiencing-same-kind
  a oakcurric:Misconception ;
  oakcurric:statement """All areas of Jakarta are experiencing the same kind of land use change and impacts."""@en ;
  oakcurric:correction """Different parts of Jakarta are changing in different ways. West Jakarta is losing green space to malls and housing, East Jakarta is growing with factories and roads, South Jakarta has gated communities, and Central Jakarta is focused on business."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679703Z"^^xsd:dateTime .

oak:misconception-land-use-conflicts-glacial-areas
  a oakcurric:Misconception ;
  oakcurric:statement """Land use conflicts in glacial areas only concern conservationists and developers."""@en ;
  oakcurric:correction """Land use conflicts are much more complex. While conservation groups and developers often have opposing views, there are other stakeholders involved, such as local communities, local governments, farmers, and tourism operators."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679901Z"^^xsd:dateTime .

oak:misconception-confusion-similar-sounding-gis-tools
  a oakcurric:Misconception ;
  oakcurric:statement """Confusion between similar sounding GIS tools in Esri Wayback; Use of 'Measure tools' in NLS Maps."""@en ;
  oakcurric:correction """CfU to clarify learning and procedures e.g. similar sounding GIS tools in Esri Wayback: ‘Toggle Animate Mode’ ‘Toggle Swipe Mode’; careful use of 'Measure distance' tool in NLS Maps along with 'Swipe', ensuring line is perpendicular."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680017Z"^^xsd:dateTime .

oak:misconception-desertification-occurs-existing-deserts
  a oakcurric:Misconception ;
  oakcurric:statement "Desertification only occurs in existing deserts."@en ;
  oakcurric:correction """Desertification can occur in any fertile land that becomes increasingly arid, not just in deserts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680022Z"^^xsd:dateTime .

oak:misconception-first-cities-become-megacities-now
  a oakcurric:Misconception ;
  oakcurric:statement "The first cities to become megacities are now the largest global cities."@en ;
  oakcurric:correction """Most of the world's largest cities are relatively young megacities that have only grown to a significant size since 2000."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680081Z"^^xsd:dateTime .

oak:misconception-climate-change-caused-human-activity
  a oakcurric:Misconception ;
  oakcurric:statement "Climate change is only caused by human activity."@en ;
  oakcurric:correction """Human activity has been significant in recent climate change, but natural factors have caused changes to the climate over millions of years."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680085Z"^^xsd:dateTime .

oak:misconception-changes-uk-economy-affected-regions
  a oakcurric:Misconception ;
  oakcurric:statement "The changes in the UK economy affected all regions equally and at the same time."@en ;
  oakcurric:correction """Some areas, such as the north east, continued to rely on traditional industries until the 1980s and 1990s. Other areas, like London, moved into tertiary industries long before others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680106Z"^^xsd:dateTime .

oak:misconception-six-figure-grid-reference-refers
  a oakcurric:Misconception ;
  oakcurric:statement "A six figure grid reference refers to only one point in the UK."@en ;
  oakcurric:correction """A six figure grid reference will be specific to a larger grid square in the OS National Grid. Each of these 100km2 squares are denoted by a two letter code, often seen in faint blue on the map. This means it refers to more than one point in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680136Z"^^xsd:dateTime .

oak:misconception-city-newly-emerging-economy-economic
  a oakcurric:Misconception ;
  oakcurric:statement """As it is a city in a Newly Emerging Economy, most economic opportunities in Jakarta are in the informal sector."""@en ;
  oakcurric:correction """A large majority of jobs in Jakarta are actually in the formal sector rather than in the informal sector, and the share of informal sector jobs is decreasing over time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680381Z"^^xsd:dateTime .

oak:misconception-litter-nutrient-cycle-considered-biotic
  a oakcurric:Misconception ;
  oakcurric:statement "Litter in the nutrient cycle is considered biotic."@en ;
  oakcurric:correction """Litter in the nutrient cycle is considered abiotic because it consists of non-living organic material, such as dead leaves and decomposing matter. Although it originated from living organisms, once it becomes litter, it is classified as non-living."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680456Z"^^xsd:dateTime .

oak:misconception-primary-effects-cause-damage
  a oakcurric:Misconception ;
  oakcurric:statement "Primary effects always cause the most damage."@en ;
  oakcurric:correction """Sometimes it is the secondary effects of a hazard that cause the most destruction, for example mudslides following a volcanic eruption."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680470Z"^^xsd:dateTime .

oak:misconception-adaptation-strategies-expensive-complex
  a oakcurric:Misconception ;
  oakcurric:statement "All adaptation strategies are expensive and complex."@en ;
  oakcurric:correction """Some adaptation strategies are cost-effective and simple, such as rainwater harvesting and crop rotation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680475Z"^^xsd:dateTime .

oak:misconception-regions-equally-affected-climate-change
  a oakcurric:Misconception ;
  oakcurric:statement "All regions will be equally affected by climate change."@en ;
  oakcurric:correction """Different regions experience the effects of climate change differently due to environmental, economic and social factors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680935Z"^^xsd:dateTime .

oak:misconception-camels-hump-stores-water
  a oakcurric:Misconception ;
  oakcurric:statement "A camel's hump stores water."@en ;
  oakcurric:correction """A camel's hump does not hold water at all – it actually stores fat. The camel uses it as nourishment when food is scarce. If a camel uses the fat inside the hump, the hump will become limp and droop, but with food and rest the hump will normalise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681005Z"^^xsd:dateTime .

oak:misconception-rains-hot-deserts
  a oakcurric:Misconception ;
  oakcurric:statement "It never rains in hot deserts."@en ;
  oakcurric:correction """While some deserts are exceptionally dry, a region can experience up to 250 mm of rain each year and still be categorised as a desert."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682028Z"^^xsd:dateTime .

oak:misconception-reducing-speed-limits-increase-traffic
  a oakcurric:Misconception ;
  oakcurric:statement "Reducing speed limits can increase traffic congestion."@en ;
  oakcurric:correction """Reducing speed limits is more likely to keep traffic flowing through a space rather than have prolonged congestion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682074Z"^^xsd:dateTime .

oak:misconception-glaciated-upland-areas-harsh-economic
  a oakcurric:Misconception ;
  oakcurric:statement "Glaciated upland areas are too harsh for any economic activity."@en ;
  oakcurric:correction """Even though conditions are harsh, economic activities such as tourism and sheep farming are prevalent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682227Z"^^xsd:dateTime .

oak:misconception-enquiries-focus-coastal-management-discuss
  a oakcurric:Misconception ;
  oakcurric:statement "Enquiries that focus on coastal management have to discuss effectiveness."@en ;
  oakcurric:correction """While many coastal enquiries focus on how effective management strategies are, the concept of effectiveness is far broader. Enquiries could study how coastal defences look, if they prevent access to the beach, or how sustainable it is to build them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682255Z"^^xsd:dateTime .

oak:misconception-pupils-fall-habit-writing-superficial
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can fall into the habit of writing superficial explanations or fail to extend them fully."""@en ;
  oakcurric:correction """An extended explanation would be: Regeneration and rebranding in Liverpool led to economic growth as a result of more businesses and tourism. This led to more diverse jobs and has contributed to a stronger and more resilient local economy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682262Z"^^xsd:dateTime .

oak:misconception-geographers-present-data-make-look
  a oakcurric:Misconception ;
  oakcurric:statement "Geographers present data to make it look more attractive."@en ;
  oakcurric:correction """Geographers present data so that it becomes more meaningful. It allows geographers to see patterns and relationships in the data that will help them answer their enquiry question."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682454Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-greenfield-greenbelt
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils can confuse greenfield and greenbelt."@en ;
  oakcurric:correction """Greenfield refers to land which has never been built on. Greenbelt is protected land around major cities in England and is a policy designed to prevent urban sprawl."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682479Z"^^xsd:dateTime .

oak:misconception-urban-areas-facilities-services-rural
  a oakcurric:Misconception ;
  oakcurric:statement """Urban areas have more facilities and services than rural areas. As a result, rural areas can offer cities little in return."""@en ;
  oakcurric:correction """Rural areas can offer the residents of urban areas a source of labour and produce. They can provide jobs in industries such as agriculture and opportunities for recreation and leisure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682762Z"^^xsd:dateTime .

oak:misconception-pupils-make-sweeping-statements-people
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils can make sweeping statements about people that live in places."@en ;
  oakcurric:correction """It is important that data is used as an average and not the characteristics of every individual. The word stereotype is useful to use in this instance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682777Z"^^xsd:dateTime .

oak:misconception-better-use-mean-value-rather
  a oakcurric:Misconception ;
  oakcurric:statement "It is better to use the mean value rather than the mode or the median values."@en ;
  oakcurric:correction """The mean, median and mode have different purposes but none of the methods produce a result that is thought of as more reliable than the others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682787Z"^^xsd:dateTime .

oak:misconception-secondary-crime-data-tells-us
  a oakcurric:Misconception ;
  oakcurric:statement "Secondary crime data tells us about the economic prosperity of a place."@en ;
  oakcurric:correction """Crime data can be misinterpreted. The data does not give any details about the economic status of the victim or the perpetrator. It is also assumes that the perpetrator lives in the area where they committed the crime, for which there is no evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682792Z"^^xsd:dateTime .

oak:misconception-systematic-stratified-sampling-better-random
  a oakcurric:Misconception ;
  oakcurric:statement "Systematic and stratified sampling are 'better' than a random sampling strategy."@en ;
  oakcurric:correction """There is no hierarchy of effectiveness in sampling strategies. The best strategy to use depends on the dynamics of the location, the size of the overall population of data, and what geographical conclusions one hopes to be able to make from the data."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682796Z"^^xsd:dateTime .

oak:misconception-river-processes-independent-variables-shape
  a oakcurric:Misconception ;
  oakcurric:statement "River processes are independent variables that shape river features."@en ;
  oakcurric:correction """Rivers are complex systems where processes and features both affect each other at different times. This means that students need to disengage with the idea that one variable is going to be independent of another as they present and analyse data."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682846Z"^^xsd:dateTime .

oak:misconception-counter-urbanisation-responsible-population-change
  a oakcurric:Misconception ;
  oakcurric:statement "Counter-urbanisation is responsible for all population change in a rural area."@en ;
  oakcurric:correction """Population change is a balance of inflows and outflows. Migration is one of these and counter-urbanisation is a process of migration but will not be responsible for all population change in an area."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682853Z"^^xsd:dateTime .

oak:misconception-forms-primary-secondary-industry-declined
  a oakcurric:Misconception ;
  oakcurric:statement "All forms of primary and secondary industry have declined in all areas."@en ;
  oakcurric:correction """While the general trend has been one of decline, some aspects of primary and secondary industries have become more successful such as organic farming."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682860Z"^^xsd:dateTime .

oak:misconception-sustainable-development-environment
  a oakcurric:Misconception ;
  oakcurric:statement "Sustainable development is all about the environment."@en ;
  oakcurric:correction """One pillar of sustainable development is the environment but sustainable development is only achieved when social and economic aspects are also considered."""@en ;
  dcterms:modified "2026-02-12T08:59:18.683021Z"^^xsd:dateTime .

oak:misconception-everyone-country-high-gni-well
  a oakcurric:Misconception ;
  oakcurric:statement """That everyone in a country with a high GNI is well off, with a good quality of life."""@en ;
  oakcurric:correction """A country’s income is not equally divided by everyone who lives there. This is why GNI per head should be used along side other measures in order to understand differences in quality of life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684223Z"^^xsd:dateTime .

oak:misconception-carbon-footprints-ecological-footprints-measure
  a oakcurric:Misconception ;
  oakcurric:statement "Carbon footprints and ecological footprints measure the same thing."@en ;
  oakcurric:correction """Although carbon footprints and ecological footprints both provide comparable measures of human impacts on the environment, carbon footprints measure greenhouse gas emissions while ecological footprints measure the total demand on Earth’s resources."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684232Z"^^xsd:dateTime .

oak:misconception-extraction-use-non-renewable-energy
  a oakcurric:Misconception ;
  oakcurric:statement """Only the extraction and use of non-renewable energy has environmental consequences."""@en ;
  oakcurric:correction """Renewables and recyclables can have environmental consequences too, although they generally cause less harm than fossil fuels. These consequences can include impacts on biodiversity and the ability of ecosystems to absorb carbon dioxide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684239Z"^^xsd:dateTime .

oak:misconception-aid-something-given-event-emergency
  a oakcurric:Misconception ;
  oakcurric:statement "Aid is something given in the event of an emergency."@en ;
  oakcurric:correction """It is not always provided in the event of an emergency. Aid may be given to support the sustainable development of a community, e.g improving health or educational services in an area, to benefit local people in the longer term."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684244Z"^^xsd:dateTime .

oak:misconception-physical-environment-key-cause-global
  a oakcurric:Misconception ;
  oakcurric:statement "That the physical environment is the key cause of global inequalities."@en ;
  oakcurric:correction """Physical geography is a cause of inequality but human factors, past and present, are as influential in affecting the pattern of trade and development."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684251Z"^^xsd:dateTime .

oak:misconception-development-indonesia-positive-effects-like
  a oakcurric:Misconception ;
  oakcurric:statement """Development in Indonesia only has positive effects, like job creation and economic growth."""@en ;
  oakcurric:correction """While development brings economic benefits, it also causes environmental problems like deforestation, water pollution, and loss of biodiversity, which can harm people and ecosystems in the long term."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684267Z"^^xsd:dateTime .

oak:misconception-aid-separate-globalisation-nothing-indonesia
  a oakcurric:Misconception ;
  oakcurric:statement """Aid is separate from globalisation and has nothing to do with how Indonesia connects to the world."""@en ;
  oakcurric:correction """When countries like Australia or organisations like the EU give aid to Indonesia, they are building connections through education and infrastructure. This support helps Indonesia grow economically, attract investment, and take part in global trade."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684344Z"^^xsd:dateTime .

oak:misconception-people-live-65-years-beyond
  a oakcurric:Misconception ;
  oakcurric:statement "That there are few people who live to 65 years and beyond in LICs and NEEs."@en ;
  oakcurric:correction """It is the proportion of the population that is small not the actual number of people. Some LICs and NEEs have large populations so there are millions of people who reach the age of 65 years plus."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684354Z"^^xsd:dateTime .

oak:misconception-building-infrastructure-projects-create-long
  a oakcurric:Misconception ;
  oakcurric:statement "Building infrastructure projects will create long term employment opportunities."@en ;
  oakcurric:correction """In most cases the jobs created by building infrastructure projects are likely to be short term and highly specialist. This means they are unlikely to last the length of the build time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684529Z"^^xsd:dateTime .

oak:misconception-fairtrade-small-scale-mostly-based
  a oakcurric:Misconception ;
  oakcurric:statement "Fairtrade is small-scale and mostly based in the UK."@en ;
  oakcurric:correction """The Fairtrade movement involves the trade in 300 different commodities and global networks of consumers as well as producers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684555Z"^^xsd:dateTime .

oak:misconception-access-electricity-means-24-hours
  a oakcurric:Misconception ;
  oakcurric:statement "Access to electricity means 24 hours a day, seven days a week."@en ;
  oakcurric:correction """Having access to electricity means having an electricity source that can provide lighting and charge a phone or radio for 4 hours a day. In LICs, and some NEEs, electricity outages are part of daily life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684585Z"^^xsd:dateTime .

oak:misconception-indonesia-choosing-china-usa-eventually
  a oakcurric:Misconception ;
  oakcurric:statement """Indonesia is choosing between China and the USA and will eventually have to pick a side."""@en ;
  oakcurric:correction """Indonesia works with both to stay neutral: to gain investment from China and to cooperate on security and trade with the USA. This helps it stay independent and build global influence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684589Z"^^xsd:dateTime .

oak:misconception-net-zero-means-greenhouse-gas
  a oakcurric:Misconception ;
  oakcurric:statement "Net zero means no greenhouse gas emissions at all."@en ;
  oakcurric:correction """In fact, net zero allows for greenhouse gas emissions as long as they are balanced by carbon being removed from the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684769Z"^^xsd:dateTime .

oak:misconception-benefits-international-migration-limited-country
  a oakcurric:Misconception ;
  oakcurric:statement """That the benefits of international migration are limited to the country of origin (such as remittances)."""@en ;
  oakcurric:correction """Destination countries experience a wide range of social and economic benefits as a result of immigration."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684832Z"^^xsd:dateTime .

oak:misconception-fracking-uses-water-means-its
  a oakcurric:Misconception ;
  oakcurric:statement "Fracking only uses water which means its environmental impacts are harmless."@en ;
  oakcurric:correction """In fact fracking fluid includes toxic chemicals and sand as well as water, which can have serious environmental impacts if they get into groundwater or are spilled. The wastewater left over from fracking also needs to be stored carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685106Z"^^xsd:dateTime .

oak:misconception-single-image-help-us-understand
  a oakcurric:Misconception ;
  oakcurric:statement """That a single image can help us to understand how quality of life is different in distant places."""@en ;
  oakcurric:correction """While images can be of use they can not depict all aspects of life, moreover each image can only ever show a single place or group of people. Within any country there is a diversity of lived experience."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685144Z"^^xsd:dateTime .

oak:misconception-commonwealth-represents-nothing-cultural-historical
  a oakcurric:Misconception ;
  oakcurric:statement """The Commonwealth represents nothing more than a cultural and historical connection between countries."""@en ;
  oakcurric:correction """Commonwealth states meet every two years to promote trade relationships, human rights and development aid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685157Z"^^xsd:dateTime .

oak:misconception-sustainable-food-production-benefits-environment
  a oakcurric:Misconception ;
  oakcurric:statement "Sustainable food production only benefits the environment."@en ;
  oakcurric:correction """Sustainable food production also has social and economic benefits, such as improving food security and reducing poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685204Z"^^xsd:dateTime .

oak:misconception-people-around-world-food-insecure
  a oakcurric:Misconception ;
  oakcurric:statement "Most people around the world are food insecure."@en ;
  oakcurric:correction """Thirty per cent are food insecure, meaning 70% experience food security. (Food security for all remains a UN target for 2030 and a key priority for governments around the world.)"""@en ;
  dcterms:modified "2026-02-12T08:59:18.685236Z"^^xsd:dateTime .

oak:misconception-development-new-jobs-industry-occurs
  a oakcurric:Misconception ;
  oakcurric:statement """The development of new jobs in industry occurs at a large scale, involving huge factories and investment by a transnational corporation."""@en ;
  oakcurric:correction """Microfinance loans can also support the development of new jobs in industry, at a smaller scale."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685259Z"^^xsd:dateTime .

oak:misconception-indonesia-hic-people-still-work
  a oakcurric:Misconception ;
  oakcurric:statement "As Indonesia is not an HIC, most people there will still work in agriculture."@en ;
  oakcurric:correction """Agriculture was once Indonesia’s economic backbone, but its share of the workforce has declined since the 1990s. Today, industry and services dominate Indonesia's economy, with manufacturing, finance, tourism and digital sectors growing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685293Z"^^xsd:dateTime .

oak:misconception-countries-consume-oil-same-rate
  a oakcurric:Misconception ;
  oakcurric:statement "All countries consume oil at the same rate."@en ;
  oakcurric:correction """Oil consumption varies based on industrialisation, population size, and economic factors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685312Z"^^xsd:dateTime .

oak:misconception-find-oil-gas-underground-worth
  a oakcurric:Misconception ;
  oakcurric:statement "If you find oil or gas underground, it is always worth extracting it."@en ;
  oakcurric:correction """In fact, just because a reserve exists doesn't mean that it will be technically or economically viable. Reserves that are in remote locations or in challenging conditions may have high development costs, especially if oil prices fall."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685326Z"^^xsd:dateTime .

oak:misconception-research-form-industry-because-involve
  a oakcurric:Misconception ;
  oakcurric:statement "Research is not a form of industry because it does not involve trade."@en ;
  oakcurric:correction """Research is an industry because it creates wealth through innovation and knowledge which has value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685335Z"^^xsd:dateTime .

oak:misconception-chart-axes-immigration-numbers-trend
  a oakcurric:Misconception ;
  oakcurric:statement """Chart axes for 'Immigration numbers trend' show numbers are similar for many countries."""@en ;
  oakcurric:correction """Chart axes appear to be comparable at first, the numbers on the vertical axis differ widely. It is therefore essential to look at the numbers carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685339Z"^^xsd:dateTime .

oak:misconception-green-revolution-came-result-genetically
  a oakcurric:Misconception ;
  oakcurric:statement "The green revolution came about as a result of genetically-modified crops."@en ;
  oakcurric:correction """The original green revolution, in the second half of the twentieth century, came about as a result of hybridisation of existing crop varieties (and the use of pesticides). It did not employ biotechnology such as genetic modification."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685371Z"^^xsd:dateTime .

oak:misconception-country-fossil-fuels-underground-easily
  a oakcurric:Misconception ;
  oakcurric:statement "If a country has fossil fuels underground, it can easily use them."@en ;
  oakcurric:correction """Some countries lack the infrastructure or funding to develop their resources, even if they are accessible, while in other cases a country might have resources that require advanced and expensive technology to access."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685398Z"^^xsd:dateTime .

oak:misconception-tourism-brought-benefits-island-bali
  a oakcurric:Misconception ;
  oakcurric:statement "Tourism has only brought benefits to the island of Bali and its people."@en ;
  oakcurric:correction """Tourism has various positive and negative impacts - while the economy has grown and some public services have improved, others have declined (e.g. the water supply) and so many people visit Bali each year its environment has suffered in the South."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685414Z"^^xsd:dateTime .

oak:misconception-our-wastewater-treated-sent-straight
  a oakcurric:Misconception ;
  oakcurric:statement "Our wastewater is treated and sent straight to our taps, to drink."@en ;
  oakcurric:correction """Few water systems link wastewater treatment plants to the supply system, with treated water going into covered reservoirs before the clean water network. Most release treated wastewater into rivers; from where it is abstracted downstream, later on."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685419Z"^^xsd:dateTime .

oak:misconception-everyone-living-rural-area-higher
  a oakcurric:Misconception ;
  oakcurric:statement "Everyone living in a rural area will have a higher standard of living."@en ;
  oakcurric:correction """While retirees moving into a rural area may be able to live comfortably, local people may experience a stagnation in employment opportunities and not be able to afford to live where they grew up."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685423Z"^^xsd:dateTime .

oak:misconception-everyone-living-particular-region-similar
  a oakcurric:Misconception ;
  oakcurric:statement """Everyone living in a particular region will have a similar lived experience of a place."""@en ;
  oakcurric:correction """Though in general the north and south of the UK show evidence of economic inequality, there are lots of pockets of very high levels of wealth in the north and areas of extreme poverty in the south."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685438Z"^^xsd:dateTime .

oak:misconception-dams-reservoirs-guarantee-reliable-water
  a oakcurric:Misconception ;
  oakcurric:statement """Dams and reservoirs guarantee a reliable water supply for many years into the future."""@en ;
  oakcurric:correction """Although dams and reservoirs do provide a reliable and easily-controllable source of water, this supply is not guaranteed. Over time, sediment will build up and reduce the capacity of the reservoir. Also, reservoirs can dry up during droughts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685454Z"^^xsd:dateTime .

oak:misconception-correct-solution-geographical-issue
  a oakcurric:Misconception ;
  oakcurric:statement "There is always a correct solution to a geographical issue."@en ;
  oakcurric:correction """There is not a 'correct' answer to a geographical issue. Geographers try and balance economic, social and environmental concerns and use evidence to justify their opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685483Z"^^xsd:dateTime .

oak:misconception-indonesia-agriculture-remains-dominant-sector
  a oakcurric:Misconception ;
  oakcurric:statement "In Indonesia, agriculture remains the dominant sector in the economy."@en ;
  oakcurric:correction """Agriculture was once Indonesia’s economic backbone, but its role has declined since the 1990s. Today, industry and services dominate GDP, with manufacturing, finance, tourism, and digital sectors growing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685499Z"^^xsd:dateTime .

oak:misconception-grey-water-includes-reuse-water
  a oakcurric:Misconception ;
  oakcurric:statement """'Grey' water includes the reuse of water already used to flush the toilet - yuck!"""@en ;
  oakcurric:correction """‘Grey’ water does not include water that has been used to flush toilets as that water is too contaminated to be used again without treatment. However, one of the possible uses for ‘grey’ water from baths, showers, sinks etc is to flush toilets."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685515Z"^^xsd:dateTime .

oak:misconception-lics-nees-general-lack-safe
  a oakcurric:Misconception ;
  oakcurric:statement "In LICs and NEEs there is a general lack of safe drinking water."@en ;
  oakcurric:correction """There is unequal access to safe drinking water in LICs and some NEEs, rather than a general lack. Investment in infrastructure often lags behind population growth. Wealthier people buy bottled water or expensive home purification technology."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685524Z"^^xsd:dateTime .

oak:misconception-asean-focused-trade-deal-other
  a oakcurric:Misconception ;
  oakcurric:statement """ASEAN is only focused on trade and does not deal with other important issues like politics or security."""@en ;
  oakcurric:correction """ASEAN focuses not only on trade but also on political stability, security, and regional cooperation to maintain peace in Southeast Asia."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685542Z"^^xsd:dateTime .

oak:misconception-renewables-make-country-less-energy
  a oakcurric:Misconception ;
  oakcurric:statement "Renewables make a country less energy secure because they’re unreliable."@en ;
  oakcurric:correction """Although supplies of energy from solar and wind can be variable, renewables diversify a country's energy supply and reduce reliance on imported fossil fuels. Overeliance on imported fossil fuels is a bigger cause of energy insecurity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685568Z"^^xsd:dateTime .

oak:misconception-water-insecurity-due-lack-rain
  a oakcurric:Misconception ;
  oakcurric:statement "Water insecurity is due to lack of rain."@en ;
  oakcurric:correction """Water insecurity may be the result of physical water scarcity, though a water deficit may be due to high population density or use of large volumes of water for industry."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685592Z"^^xsd:dateTime .

oak:misconception-foreign-companies-take-profits-back
  a oakcurric:Misconception ;
  oakcurric:statement "Foreign companies always take profits back home and give nothing to locals."@en ;
  oakcurric:correction """Many TNCs invest in local jobs, training, and infrastructure, though some profits do return to the home country."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685597Z"^^xsd:dateTime .

oak:misconception-organic-farmers-use-fertiliser-their
  a oakcurric:Misconception ;
  oakcurric:statement "Organic farmers do not use fertiliser on their crops."@en ;
  oakcurric:correction """Organic farming does involve the use of fertiliser but not the use of artificial chemical fertiliser (e.g. derived from fossil fuels). For example, farmyard manure is a good source of nutrients for crops on an organic farm but so too is seaweed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685607Z"^^xsd:dateTime .

oak:misconception-manufacturing-industries-harm-environment
  a oakcurric:Misconception ;
  oakcurric:statement "Only manufacturing industries harm the environment."@en ;
  oakcurric:correction """All sectors of industry have the potential to harm the environment, though manufacturing continues to be highly wasteful."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685621Z"^^xsd:dateTime .

oak:misconception-wealthy-hics-give-aid-other
  a oakcurric:Misconception ;
  oakcurric:statement "Only wealthy HICs give aid to other countries."@en ;
  oakcurric:correction """Newly-emerging economies such as Indonesia, China and India also give aid to other countries, especially within their regions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685628Z"^^xsd:dateTime .

oak:misconception-rising-demand-food-simply-worlds
  a oakcurric:Misconception ;
  oakcurric:statement "Rising demand for food is simply down to the world's growing population."@en ;
  oakcurric:correction """This is one reason for growing demand for food but economic development is another factor that affects demand as people become richer they eat more meat and so more grain or land to graze is needed to feed those animals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685633Z"^^xsd:dateTime .

oak:misconception-tncs-helped-indonesia-develop-its
  a oakcurric:Misconception ;
  oakcurric:statement "TNCs have helped Indonesia to develop its own vehicle manufacturing companies."@en ;
  oakcurric:correction """While TNCs have been important in developing vehicle manufacturing in Indonesia, the vehicles they make are not Indonesian brands and the profits from selling them in Indonesia or in export markets go to the TNCs and not to Indonesian companies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685637Z"^^xsd:dateTime .

oak:misconception-climate-change-impacted-tropical-rainforests
  a oakcurric:Misconception ;
  oakcurric:statement """Climate change has not impacted tropical rainforests as temperature and rainfall patterns have remained the same."""@en ;
  oakcurric:correction """Climate change has affected tropical rainforests by increasing temperatures, changing rainfall patterns and increasing the frequency of droughts. For example, the Amazon rainforest experienced its worst recorded drought in 2023."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688180Z"^^xsd:dateTime .

oak:misconception-main-threats-taiga-come-direct
  a oakcurric:Misconception ;
  oakcurric:statement """The main threats to the taiga come from the direct damage done to forests by the logging industry."""@en ;
  oakcurric:correction """While the logging industry does directly damage taiga forests, indirect threats from warming taiga climates are also a major threat to the taiga and taiga biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688185Z"^^xsd:dateTime .

oak:misconception-rainforests-valuable-timber-agricultural-products
  a oakcurric:Misconception ;
  oakcurric:statement "Rainforests are only valuable for timber and agricultural products."@en ;
  oakcurric:correction """Tropical rainforests are crucial for regulating the global climate, absorbing CO2, producing oxygen, maintaining biodiversity, supporting the water cycle, and preventing soil erosion, all of which are vital for sustaining life on Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688191Z"^^xsd:dateTime .

oak:misconception-wildfires-taiga-harmful-prevented
  a oakcurric:Misconception ;
  oakcurric:statement "All wildfires in the taiga are harmful and should be prevented."@en ;
  oakcurric:correction """Some wildfires are natural and necessary for ecosystem renewal, as they clear old vegetation and help new trees grow. However, climate change has made fires more intense and frequent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688721Z"^^xsd:dateTime .

oak:misconception-taiga-rich-fertile-soil-supports
  a oakcurric:Misconception ;
  oakcurric:statement "The taiga has rich, fertile soil that supports abundant plant life."@en ;
  oakcurric:correction """Taiga soil is nutrient-poor due to slow decomposition in cold temperatures. Most nutrients come from decomposing needles and limited organic matter."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689432Z"^^xsd:dateTime .

oak:misconception-biotic-living-abiotic-non-living
  a oakcurric:Misconception ;
  oakcurric:statement """Biotic (living) and abiotic (non-living) factors of the taiga operate independently."""@en ;
  oakcurric:correction """The taiga’s cold climate affects its plants and animals. Cold temperatures influence vegetation. Poor, acidic soil slows decomposition and limits plant diversity. Snow and short growing seasons impact animal behaviors and population patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690859Z"^^xsd:dateTime .

oak:misconception-issue-protecting-exploiting-taiga-economic
  a oakcurric:Misconception ;
  oakcurric:statement """The only issue in protecting or exploiting the taiga is economic growth versus environmental conservation, without considering the social, cultural, and long-term ecological impacts."""@en ;
  oakcurric:correction """The debate also involves factors such as the rights of indigenous communities, the potential long-term damage to ecosystems, and the need for sustainable management practices that balance both conservation and resource use."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691012Z"^^xsd:dateTime .

oak:misconception-form-data-presentation-applied-data
  a oakcurric:Misconception ;
  oakcurric:statement "Any form of data presentation can be applied to any data set."@en ;
  oakcurric:correction """There are many different types of data. Accurate data presentation means that appropriate graphical data presentation techniques are matched with the particular characteristics of a data set."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691794Z"^^xsd:dateTime .

oak:misconception-immediate-responses-happen-tropical-storm
  a oakcurric:Misconception ;
  oakcurric:statement "Immediate responses only happen during the tropical storm."@en ;
  oakcurric:correction "Immediate responses happen before, during and immediately after the storm."@en ;
  dcterms:modified "2026-02-12T08:59:18.691946Z"^^xsd:dateTime .

oak:misconception-hot-deserts-barren-lifeless-areas
  a oakcurric:Misconception ;
  oakcurric:statement "Hot deserts are barren, lifeless areas with no real economic potential."@en ;
  oakcurric:correction """Deserts can have significant opportunities for economic development, for example mineral extraction, solar energy, tourism and irrigated farming."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692207Z"^^xsd:dateTime .

oak:misconception-changes-affect-ecosystems-created-people
  a oakcurric:Misconception ;
  oakcurric:statement "Changes that affect ecosystems are always created by people."@en ;
  oakcurric:correction """Naturally-occurring events such as storms also affect ecosystems. For example, a storm could fell trees which may have been a habitat for other species."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692476Z"^^xsd:dateTime .

oak:misconception-caves-arches-stacks-stumps-form
  a oakcurric:Misconception ;
  oakcurric:statement "Caves, arches, stacks and stumps form very quickly and at the same time."@en ;
  oakcurric:correction """Coastal landforms form over time through erosion and weathering, progressing from caves to arches, which collapse into stacks, and eventually erode into stumps, show gradual and differential erosion processes that shape the landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692741Z"^^xsd:dateTime .

oak:misconception-ecosystems-made-plants-animals
  a oakcurric:Misconception ;
  oakcurric:statement "That ecosystems are made up of plants and animals only."@en ;
  oakcurric:correction """An ecosystem is a community of living things interacting with one another and with non-living components of their environment, such as soil and climate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692937Z"^^xsd:dateTime .

oak:misconception-animals-plants-taiga-struggle-survive
  a oakcurric:Misconception ;
  oakcurric:statement """Animals and plants in the taiga struggle to survive due to extreme cold and lack specific adaptations."""@en ;
  oakcurric:correction """Taiga species have key adaptations. Conifers have needle-shaped leaves with waxy coatings to reduce water loss. Animals like lynxes grow thick fur, and some hibernate or migrate to survive harsh winters. These adaptations ensure survival."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693333Z"^^xsd:dateTime .

oak:misconception-pupils-mix-population-distribution-population
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils can mix up population distribution and population density."@en ;
  oakcurric:correction """Population density is a spatial pattern of population whereas population density is the ratio of people to a defined space."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694416Z"^^xsd:dateTime .

oak:misconception-rocks-change-once-formed
  a oakcurric:Misconception ;
  oakcurric:statement "Rocks do not change once they are formed."@en ;
  oakcurric:correction """Metamorphic rocks are created by heat and pressure acting on sedimentary and igneous rocks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694642Z"^^xsd:dateTime .

oak:misconception-global-atmospheric-circulation-systems-controls
  a oakcurric:Misconception ;
  oakcurric:statement """The global atmospheric circulation systems controls the temperature of different climate zones."""@en ;
  oakcurric:correction """Global circulation system redistributes heat received at the Equator, but latitude controls temperature of each climate zone. The amount of solar radiation received at each latitude is due to the curvature of the Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695439Z"^^xsd:dateTime .

oak:misconception-weathering-erosion-same-process
  a oakcurric:Misconception ;
  oakcurric:statement "Weathering and erosion are the same process."@en ;
  oakcurric:correction """Weathering breaks down rocks in place without movement, while erosion involves the removal and transport of that material by wind, water, ice, or gravity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695765Z"^^xsd:dateTime .

oak:misconception-countries-prepare-respond-tropical-cyclones
  a oakcurric:Misconception ;
  oakcurric:statement "All countries prepare and respond  to tropical cyclones in the same way."@en ;
  oakcurric:correction """The level of development, amount of governmental planning as well as a country's location and experience of tropical cyclones, will affect how they prepare for and respond to them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695910Z"^^xsd:dateTime .

oak:misconception-creating-managing-wilderness-areas-taiga
  a oakcurric:Misconception ;
  oakcurric:statement """Creating and managing wilderness areas in the taiga biome is easy because the region is sparsely populated."""@en ;
  oakcurric:correction """Managing wilderness areas in the taiga is challenging due to its extreme climate, vast size, remote location, and limited infrastructure, which make access, monitoring, and conservation efforts difficult."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698058Z"^^xsd:dateTime .

oak:misconception-mass-movement-refers-dramatic-events
  a oakcurric:Misconception ;
  oakcurric:statement "Mass movement only refers to dramatic events like landslides and rockfalls."@en ;
  oakcurric:correction """Mass movement includes all downhill movements of soil, rock, or debris due to gravity. It's not just rapid events like landslides but also slower processes which occur gradually and can still significantly alter the landscape over time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698192Z"^^xsd:dateTime .

oak:misconception-natural-hazard-same-thing-natural
  a oakcurric:Misconception ;
  oakcurric:statement "A natural hazard is the same thing as a natural disaster."@en ;
  oakcurric:correction """A natural hazard is a potentially harmful event, a natural disaster is when a natural hazard event significantly affects humans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698798Z"^^xsd:dateTime .

oak:misconception-glacial-erosion-process-creates-new
  a oakcurric:Misconception ;
  oakcurric:statement "Glacial erosion is the only process that creates new landscapes."@en ;
  oakcurric:correction """Glacial erosion does create new landforms, but as glaciers transport and then deposit the eroded material, this also creates new landscapes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699693Z"^^xsd:dateTime .

oak:misconception-sketch-map-needs-artistic-representation
  a oakcurric:Misconception ;
  oakcurric:statement "A sketch map needs to be an artistic representation of a place."@en ;
  oakcurric:correction """A sketch map looks like a map as it has a plan orientation but it is not a work of art. It uses simple, clean lines to communicate the main features of a map."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699801Z"^^xsd:dateTime .

oak:misconception-coastal-communities-equally-vulnerable-coastal
  a oakcurric:Misconception ;
  oakcurric:statement "All coastal communities are equally vulnerable to coastal flooding."@en ;
  oakcurric:correction """Low-lying coastal communities are most at risk of coastal flooding, especially with increasing storms and storm surges."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699815Z"^^xsd:dateTime .

oak:misconception-global-resources-running-because-global
  a oakcurric:Misconception ;
  oakcurric:statement "Global resources are running out because the global population is rising."@en ;
  oakcurric:correction """Population growth is just one of many factors contributing to increased demand for resources."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699843Z"^^xsd:dateTime .

oak:misconception-bigger-hazard-event-higher-hazard
  a oakcurric:Misconception ;
  oakcurric:statement "The bigger the hazard event is, the higher the hazard risk will be."@en ;
  oakcurric:correction """The size of the hazard event is not the only factor that affects hazard risk. For example, a higher income country may have a lower hazard risk for a magnitude 6.5 earthquake than a lower income country, even though the earthquakes have equal power."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699866Z"^^xsd:dateTime .

oak:misconception-boulder-clay-example-sedimentary-rock
  a oakcurric:Misconception ;
  oakcurric:statement "Boulder clay is an example of sedimentary rock."@en ;
  oakcurric:correction """Boulder clay is an example of glacial till. Glacial till is an example of sedimentary deposits."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699885Z"^^xsd:dateTime .

oak:misconception-climate-change-happened-recently
  a oakcurric:Misconception ;
  oakcurric:statement "Climate change has only happened recently."@en ;
  oakcurric:correction """The Earth's climate patterns have changed numerous times in the past, for example there have been around 50 cycles of glacial (cold) phases and interglacial (warmer) phases in the Quaternary period."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699973Z"^^xsd:dateTime .

oak:misconception-valuable-resource-cold-environments-timber
  a oakcurric:Misconception ;
  oakcurric:statement "The only valuable resource in cold environments is timber."@en ;
  oakcurric:correction """Many valuable resources are found in cold environments (albeit difficult to access), such as fossil fuels and minerals. Timber in polar and tundra regions is not found there. These are treeless areas. Timber is found further south in the taiga biome."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700307Z"^^xsd:dateTime .

oak:misconception-students-frequently-confuse-aerial-images
  a oakcurric:Misconception ;
  oakcurric:statement """Students frequently confuse the aerial images seen through software such as Google Maps as a map, partly because they are frequently displayed alongside actual maps."""@en ;
  oakcurric:correction """Maps are representations of the world and use symbols and cartographic language to present certain characteristics of a place (and not others). Aerial photographs are indiscriminate views of the world and do not select certain aspects of geography."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700599Z"^^xsd:dateTime .

oak:misconception-anomaly-data-set-means-error
  a oakcurric:Misconception ;
  oakcurric:statement """An anomaly in a data set means that an error was made in the way the data was collected."""@en ;
  oakcurric:correction """Anomalies could be found in data sets for many reasons, including human error during data collection. It is more likely however that a variable that was not investigated is having an influence on that particular value, causing it to seem 'wrong'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700692Z"^^xsd:dateTime .

oak:misconception-people-come-eryri-national-park
  a oakcurric:Misconception ;
  oakcurric:statement """People only come to Eryri National Park in order to climb Wales' highest mountain."""@en ;
  oakcurric:correction """People do come to climb mountains but also enjoy other enjoy outdoor activities and the historical and cultural attractions in North Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700740Z"^^xsd:dateTime .

oak:misconception-geographer-good-maths-successfully-analyse
  a oakcurric:Misconception ;
  oakcurric:statement "A geographer has to be good at maths to successfully analyse quantitative data."@en ;
  oakcurric:correction """Successful analysis in geography means correctly understanding what numerical values mean, not necessarily being able to process and manipulate data."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700747Z"^^xsd:dateTime .

oak:misconception-earthquake-caused-destruction-2011-tohuku
  a oakcurric:Misconception ;
  oakcurric:statement "The earthquake caused most of the destruction in the 2011 Tohuku disaster."@en ;
  oakcurric:correction """While the magnitude 9.0 earthquake was powerful, Japan’s strict building regulations meant that most modern buildings withstood the shaking. It was the 10-metre-high tsunami that caused the majory of the destruction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700752Z"^^xsd:dateTime .

oak:misconception-using-filters-selecting-incorrect-condition
  a oakcurric:Misconception ;
  oakcurric:statement """When using filters, selecting the incorrect 'condition'; when configuring pop-ups, using the incorrect formula of words to link with attribute titles."""@en ;
  oakcurric:correction """Advise caution when selecting the 'condition' for a filter; take care when typing text and typing or selecting attribute titles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700790Z"^^xsd:dateTime .

oak:misconception-atlases-specialise-large-scale-maps
  a oakcurric:Misconception ;
  oakcurric:statement "Atlases specialise in large scale maps."@en ;
  oakcurric:correction """A large scale map means the map shows a large amount of detail but covers a small area. Therefore, atlases tend to use small scale maps that show a large area of land in limited detail."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700803Z"^^xsd:dateTime .

oak:misconception-gis-long-hand-paper-based
  a oakcurric:Misconception ;
  oakcurric:statement "GIS and long-hand, paper-based mapping have the same value."@en ;
  oakcurric:correction """While it is very possible to create representations of spatial data on paper using layers of tracing paper over a base map, the real value of GIS is its ability to analyse data quickly and be edited once the map has been digitally  created."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700821Z"^^xsd:dateTime .

oak:misconception-flood-management-stop-flooding-area
  a oakcurric:Misconception ;
  oakcurric:statement "Flood management can stop flooding of an area."@en ;
  oakcurric:correction """Flood management cannot stop flooding, but it can reduce the risk, frequency, and impact of floods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700867Z"^^xsd:dateTime .

oak:misconception-factor-affecting-flood-risk-rainfall
  a oakcurric:Misconception ;
  oakcurric:statement "The only factor affecting flood risk is rainfall."@en ;
  oakcurric:correction """Whether a river floods in response to heavy rainfall also relates to many other factors, especially how quickly and in what volume rainfall enters the river."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700875Z"^^xsd:dateTime .

oak:misconception-raining-tropical-rainforest
  a oakcurric:Misconception ;
  oakcurric:statement "It is always raining in the tropical rainforest."@en ;
  oakcurric:correction """Although it will often rain every day in a tropical rainforest, the rain is often short and intense rather than continual. Some rainforests have drier and wetter seasons also."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700880Z"^^xsd:dateTime .

oak:misconception-rivers-change-due-natural-processes
  a oakcurric:Misconception ;
  oakcurric:statement "Rivers only change due to natural processes."@en ;
  oakcurric:correction """While natural processes like erosion and sedimentation affect rivers, human activities such as deforestation and dam construction also significantly alter river landscapes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700915Z"^^xsd:dateTime .

oak:misconception-indonesia-large-island-small-population
  a oakcurric:Misconception ;
  oakcurric:statement "Indonesia is a large island with a small population."@en ;
  oakcurric:correction """Indonesia is not one island: it is an archipelago, a group of over 17 000 islands. Nor does it have a small population: it’s population is over 270 million people."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701131Z"^^xsd:dateTime .

oak:misconception-river-erosion-process-creates-landforms
  a oakcurric:Misconception ;
  oakcurric:statement "River erosion is the only process that creates landforms."@en ;
  oakcurric:correction """River erosion does create distinct landforms such as waterfalls and gorges. However, deposition and erosion create meanders and oxbow lakes in the middle course and deposition creates landforms such as floodplains and levees in the lower course."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701135Z"^^xsd:dateTime .

oak:misconception-top-strategies-benefit-everyone-equally
  a oakcurric:Misconception ;
  oakcurric:statement "Top-down strategies always benefit everyone equally."@en ;
  oakcurric:correction """Top-down strategies often improve infrastructure at a large scale, but they do not always reach all areas fairly. Wealthier areas tend to benefit first, while poorer communities may lack reliable water, waste collection, or transport access."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701777Z"^^xsd:dateTime .

oak:misconception-large-global-organisations-like-united
  a oakcurric:Misconception ;
  oakcurric:statement """Only large global organisations, like the United Nations or Greenpeace, are responsible for protecting rainforests, and that local communities have little impact on sustainability efforts."""@en ;
  oakcurric:correction """Both global and local actions are vital for rainforest sustainability. While global efforts fund and advocate, local communities protect forests through reforestation, sustainable farming, and ecotourism."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701782Z"^^xsd:dateTime .

oak:misconception-japans-tsunami-evacuation-failed-because
  a oakcurric:Misconception ;
  oakcurric:statement """Japan’s tsunami evacuation failed because it had not invested in a tsunami warning system."""@en ;
  oakcurric:correction """Japan had invested in a tsunami warning system, but due to how close the epicentre was, there were only 30 minutes before tsunami waves arrived, meaning that not everyone was evacuated safely. The height of the tsunami was not accurately predicted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702428Z"^^xsd:dateTime .

oak:misconception-tropical-storms-affect-coastal-areas
  a oakcurric:Misconception ;
  oakcurric:statement "Tropical storms only affect coastal areas."@en ;
  oakcurric:correction """Explain that tropical storms can impact inland areas as well due to heavy rainfall and flooding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703253Z"^^xsd:dateTime .

oak:misconception-bottom-strategies-fully-solve-urban
  a oakcurric:Misconception ;
  oakcurric:statement "Bottom-up strategies can fully solve urban problems on their own."@en ;
  oakcurric:correction """Bottom-up strategies are valuable because they reflect community needs, improve trust, and lead to long-term change. However, they usually require support from NGOs or the government, such as funding, land rights, or technical help to be sustainable."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703262Z"^^xsd:dateTime .

oak:misconception-upland-areas-uk-created-glaciers
  a oakcurric:Misconception ;
  oakcurric:statement "Upland areas in the UK were created by glaciers."@en ;
  oakcurric:correction """Glaciers shaped many upland landscapes during the last Ice Age, but the original formation of mountains like those in Scotland and the Lake District was caused by tectonic activity millions of years ago."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703392Z"^^xsd:dateTime .

oak:misconception-tropical-storms-form-land
  a oakcurric:Misconception ;
  oakcurric:statement "Tropical storms can form over land."@en ;
  oakcurric:correction """Tropical storms form over warm ocean waters where they can draw energy from the heat and moisture. Once over land, they lose their energy source and weaken."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703397Z"^^xsd:dateTime .

oak:misconception-tropical-storms-affect-people-immediately
  a oakcurric:Misconception ;
  oakcurric:statement """Tropical storms only affect people during and immediately after they make landfall."""@en ;
  oakcurric:correction """Due to improved monitioring and prediction, people may evacuate high-risk areas before a storm hits, and the effects of the storm can last for months afterwards as people repair and recover their homes, environments and livelihoods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703558Z"^^xsd:dateTime .

oak:misconception-because-know-location-plate-margins
  a oakcurric:Misconception ;
  oakcurric:statement """Because we know the location of plate margins, scientists can predict when earthquakes will happen."""@en ;
  oakcurric:correction """While scientists can identify areas that are at high risk of earthquakes, exact predictions for when and where an earthquake will occur (or what magnitude it will be) are not possible."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703563Z"^^xsd:dateTime .

oak:misconception-deforestation-primarily-caused-small-scale
  a oakcurric:Misconception ;
  oakcurric:statement """Deforestation is primarily caused by small-scale farmers cutting down forests for subsistence farming."""@en ;
  oakcurric:correction """Deforestation is driven by large-scale commercial activities, such as industrial agriculture (like palm oil and soy), logging, and cattle ranching, which are often linked to global demand."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703619Z"^^xsd:dateTime .

oak:misconception-volcanoes-earthquakes-occur-types-plate
  a oakcurric:Misconception ;
  oakcurric:statement "That both volcanoes and earthquakes occur at all types of plate margin."@en ;
  oakcurric:correction """While earthquakes are produced by tectonic movements at all plate margins, volcanoes are not found at conservative plate margins."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704177Z"^^xsd:dateTime .

oak:misconception-volcanoes-occur-directly-oceanic-plate
  a oakcurric:Misconception ;
  oakcurric:statement "That volcanoes occur directly above where the oceanic plate starts to subduct."@en ;
  oakcurric:correction """In fact, the melting of the oceanic plate occurs deep in the mantle, so magma rises to the surface some distance away from the plate margin."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704182Z"^^xsd:dateTime .

oak:misconception-students-find-difficult-grasp-earths
  a oakcurric:Misconception ;
  oakcurric:statement """Students can find it difficult to grasp that Earth's crust and tectonic plates include the ocean floor, which has topography (e.g. mountains including volcanoes, valleys) just like the land areas."""@en ;
  oakcurric:correction """Remind students (often!) that tectonic plates include the ocean floor. Apps such as 3D Scene can help to visualise this underwater topography, which we learn about by bathymetry. The story of Marie Tharp provides excellent disciplinary knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704187Z"^^xsd:dateTime .

oak:misconception-biosphere-affected-atmosphere-little-impact
  a oakcurric:Misconception ;
  oakcurric:statement "The biosphere is affected by the atmosphere but has little impact on it."@en ;
  oakcurric:correction """The biosphere has significant impacts on the composition of the atmosphere, affecting the concentration of gases and moisture content."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704260Z"^^xsd:dateTime .

oak:misconception-deposition-occurs-mouth-river
  a oakcurric:Misconception ;
  oakcurric:statement "Deposition only occurs at the mouth of a river."@en ;
  oakcurric:correction """Deposition happens at the mouth of a river, but it also occurs wherever the river loses energy and can no longer carry its load of sediment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704693Z"^^xsd:dateTime .

oak:misconception-landforms-created-due-erosion-river
  a oakcurric:Misconception ;
  oakcurric:statement "All landforms created are due to erosion by the river."@en ;
  oakcurric:correction """Deposition and changes in geology, as well as human activity, can influence the landforms created."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704933Z"^^xsd:dateTime .

oak:misconception-uk-moderate-climate-doesnt-experience
  a oakcurric:Misconception ;
  oakcurric:statement "The UK has a moderate climate and doesn't experience weather hazards."@en ;
  oakcurric:correction """The UK experiences a range of different weather hazards which can have serious impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704937Z"^^xsd:dateTime .

oak:misconception-easy-miss-important-small-steps
  a oakcurric:Misconception ;
  oakcurric:statement "It is very easy to miss important small steps in GIS."@en ;
  oakcurric:correction "Take students through each step and check for understanding very regularly."@en ;
  dcterms:modified "2026-02-12T08:59:18.704942Z"^^xsd:dateTime .

oak:misconception-impacts-volcanic-eruptions-severe-developing
  a oakcurric:Misconception ;
  oakcurric:statement """Impacts of volcanic eruptions are always more severe in developing and emerging countries than in developed countries."""@en ;
  oakcurric:correction """A lot depends on the eruption type and factors such as population density. Economic impacts are often highest in developed countries because of the higher value of the property impacted by the eruption."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704947Z"^^xsd:dateTime .

oak:misconception-tectonic-plates-float-like-rafts
  a oakcurric:Misconception ;
  oakcurric:statement "Tectonic plates float like rafts on liquid magma."@en ;
  oakcurric:correction "The mantle is semi-solid rather than a sort of liquid sea of magma."@en ;
  dcterms:modified "2026-02-12T08:59:18.705016Z"^^xsd:dateTime .

oak:misconception-attractive-basemap-important
  a oakcurric:Misconception ;
  oakcurric:statement "An attractive basemap is important."@en ;
  oakcurric:correction """A basemap is a backdrop to support the visualisation of data, so it doesn't necessarily need to be attractive. Sometimes a very bland basemap is the most effective because it provides contrast with the layer of spatial data."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705021Z"^^xsd:dateTime .

oak:misconception-glacial-landforms-created-climate-change
  a oakcurric:Misconception ;
  oakcurric:statement "Glacial landforms are not created by climate change."@en ;
  oakcurric:correction """Glacial landforms are often linked to climate change. In many areas we can only see glacial landforms because the ice sheets and glaciers which created them have melted. Climate change also causes glacial processes which modify the landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705411Z"^^xsd:dateTime .

oak:misconception-ice-affects-landscapes-periods-melting
  a oakcurric:Misconception ;
  oakcurric:statement "Ice only affects landscapes during periods of melting."@en ;
  oakcurric:correction """Ice modifies landscapes through continuous processes of erosion, transportation, and deposition, not just during periods of melting."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705418Z"^^xsd:dateTime .

oak:misconception-greenfield-sites-quicker-cheaper-develop
  a oakcurric:Misconception ;
  oakcurric:statement """Greenfield sites are quicker and cheaper to develop as they have not been built on before."""@en ;
  oakcurric:correction """Greenfield sites may take longer to develop and be more costly as everything has to be built from scratch including raod networks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705424Z"^^xsd:dateTime .

oak:misconception-migrants-similar-reasons-migrating
  a oakcurric:Misconception ;
  oakcurric:statement "Migrants all have similar reasons for migrating."@en ;
  oakcurric:correction """Migration is a deeply personal decision. Migrants will have many different, and sometimes contradictory, reasons for migrating."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705429Z"^^xsd:dateTime .

oak:misconception-due-extreme-cold-climate-particularly
  a oakcurric:Misconception ;
  oakcurric:statement """That due to the extreme cold climate, particularly during the winter months, that all animals must hibernate to save energy."""@en ;
  oakcurric:correction """Only two polar or tundra species enter full hibernation - the grizzly bear and arctic ground squirrel. Many other animals migrate to find food and warmth, while others are highly adapted to remain active and survive the extremely cold winters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705459Z"^^xsd:dateTime .

oak:misconception-storm-hydrograph-shows-rainfall
  a oakcurric:Misconception ;
  oakcurric:statement "A storm hydrograph shows rainfall."@en ;
  oakcurric:correction "A storm hydrograph shows river discharge changes over time, not just rainfall."@en ;
  dcterms:modified "2026-02-12T08:59:18.705464Z"^^xsd:dateTime .

oak:misconception-rapid-urban-growth-creates-problems
  a oakcurric:Misconception ;
  oakcurric:statement "Rapid urban growth only creates problems for city residents."@en ;
  oakcurric:correction """While rapid growth does create challenges, it also creates opportunities such as improved access to services (healthcare, education) and resources (water supply, energy)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705633Z"^^xsd:dateTime .

oak:misconception-glaciated-landscapes-found-polar-regions
  a oakcurric:Misconception ;
  oakcurric:statement "Glaciated landscapes are only found in polar regions"@en ;
  oakcurric:correction """Glaciated landscapes can be found in many mountainous regions around the world, including Snowdonia in North Wales, not just in polar areas."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705638Z"^^xsd:dateTime .

oak:misconception-extreme-destruction-haiti-result-earthquake
  a oakcurric:Misconception ;
  oakcurric:statement """The extreme destruction in Haiti was the result of the earthquake magnitude being unusually powerful."""@en ;
  oakcurric:correction """The earthquake had a magnitude of 7.0, which is not unusually powerful. The high death toll and destruction were due to Haiti’s poor infrastructure, weak building regulations and lack of preparedness, not just the earthquake’s strength."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705965Z"^^xsd:dateTime .

oak:misconception-volcanoes-occur-plate-margins
  a oakcurric:Misconception ;
  oakcurric:statement "Volcanoes occur at all plate margins."@en ;
  oakcurric:correction """While volcanoes are a feature of both destructive and constructive plate margins, there are no volcanic eruptions at conservative margins because no magma is produced."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706137Z"^^xsd:dateTime .

oak:misconception-people-developing-countries-less-prepared
  a oakcurric:Misconception ;
  oakcurric:statement """People in developing countries are less prepared because they lack understanding of volcanic hazards."""@en ;
  oakcurric:correction """People in developing countries have expert understanding of volcanic hazards and local communities are fully aware of hazards. Management problems are often due to lack of resources for effective prediction, preparation and relief."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706142Z"^^xsd:dateTime .

oak:misconception-difficulty-remembering-meaning-location-icons
  a oakcurric:Misconception ;
  oakcurric:statement """Difficulty in remembering meaning and location of icons in ArcGIS Online, e.g. Analysis Tools and Scene Tools."""@en ;
  oakcurric:correction """Frequent reminders and checks for understanding about icon locations and their meanings, e.g. Analysis Tools and Scene Tools."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706258Z"^^xsd:dateTime .

oak:misconception-cold-environments-receive-lot-precipitation
  a oakcurric:Misconception ;
  oakcurric:statement "Cold environments receive a lot of precipitation (in this case snowfall)."@en ;
  oakcurric:correction """While some areas of coastal tundra does receive a substantial quantity of precipitation, in reality most cold environment regions are extremely dry, with some areas receiving less than 250 mm of precipitation per year - defining them as deserts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706263Z"^^xsd:dateTime .

oak:misconception-soil-biotic-component-ecosystems-because
  a oakcurric:Misconception ;
  oakcurric:statement "Soil is a biotic component of ecosystems because it contains living organisms."@en ;
  oakcurric:correction "Soil is classed as an abiotic component because soil itself is non-living."@en ;
  dcterms:modified "2026-02-12T08:59:18.706267Z"^^xsd:dateTime .

oak:misconception-economic-development-indonesia-benefits-everyone
  a oakcurric:Misconception ;
  oakcurric:statement "Economic development in Indonesia benefits everyone equally."@en ;
  oakcurric:correction """Economic development in Indonesia is mostly focused in urban areas like Jakarta and Java. Rural areas often miss out on investment, leading to unequal access to jobs, services, and infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706792Z"^^xsd:dateTime .

oak:misconception-tsunamis-landslides-primary-impacts-earthquakes
  a oakcurric:Misconception ;
  oakcurric:statement """Tsunamis and landslides are primary impacts of earthquakes because they can cause massive damage to people and property."""@en ;
  oakcurric:correction """Tsunamis and landslides are secondary impacts of earthquakes because they happen as an indirect result of an earthquake. For e.g, ground shaking destabilises slopes, making a landslide more likely, especially if there is then also heavy rain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706844Z"^^xsd:dateTime .

oak:misconception-understanding-imd-rankings-comparing-them
  a oakcurric:Misconception ;
  oakcurric:statement """Understanding IMD rankings and comparing them with primary data can be challenging."""@en ;
  oakcurric:correction """Make sure students are aware of the challenges of ranking and other attributes where a low number can be a positive thing (similar issue with some measures of development such as IMD)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706849Z"^^xsd:dateTime .

oak:misconception-public-transport-less-convenient-expensive
  a oakcurric:Misconception ;
  oakcurric:statement "Public transport is less convenient and more expensive that private transport."@en ;
  oakcurric:correction """Well-designed public transport systems can be faster, cheaper, and more reliable than driving, especially in urban areas with congestion and parking costs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707041Z"^^xsd:dateTime .

oak:misconception-inner-core-hotter-outer-core
  a oakcurric:Misconception ;
  oakcurric:statement """The inner core is hotter than the outer core so the inner core must be liquid (molten rock) while the outer core is solid rock."""@en ;
  oakcurric:correction """In fact, although the inner core is hotter than the outer core, the inner core is solid while the outer core is molten and liquid. This is because the pressure is so great in the inner core that it prevents the rock from melting."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707047Z"^^xsd:dateTime .

oak:misconception-describing-location-maps-pupils-make
  a oakcurric:Misconception ;
  oakcurric:statement """When describing location from maps pupils can make the mistake of including facts not available on the map itself."""@en ;
  oakcurric:correction """Use only the available information to construct a locational description from a map including the legend, labels, compass rose and scale."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707304Z"^^xsd:dateTime .

oak:misconception-air-pollution-jakarta-comes-industries
  a oakcurric:Misconception ;
  oakcurric:statement "Most air pollution in Jakarta comes from industries."@en ;
  oakcurric:correction """While factories contribute, the main source of air pollution in Jakarta is traffic, particularly from motorbikes and older diesel vehicles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707539Z"^^xsd:dateTime .

oak:misconception-pupils-think-models-represent-reality
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils can think models represent reality."@en ;
  oakcurric:correction """A model is not an exact representation of reality but a simplification designed to help understanding. In this instance to help understand the situation of different areas of cities in relation to one another."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707545Z"^^xsd:dateTime .

oak:misconception-pupils-fail-include-place-specific
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can fail to include place-specific details when responding to questions or giving information about places."""@en ;
  oakcurric:correction """Information about a place should always be supported by specific evidence such as a piece of data or a specific location."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707593Z"^^xsd:dateTime .

oak:misconception-river-valleys-remain-v-shaped
  a oakcurric:Misconception ;
  oakcurric:statement "River valleys remain V-shaped from source to mouth."@en ;
  oakcurric:correction """A river valley changes from a V-shape to a U-shape as they flow towards the mouth due to processes like lateral erosion and deposition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707939Z"^^xsd:dateTime .

oak:misconception-tropical-rainforest-soils-nutrient-rich
  a oakcurric:Misconception ;
  oakcurric:statement """Tropical rainforest soils must be nutrient-rich because the forests are so full of abundant, fast-growing vegetation."""@en ;
  oakcurric:correction """Tropical rainforest soils are nutrient-poor. Nutrients cycle rapidly out of the soil due to them being taken up rapidly by biomass, while the heavy rainfall also washes them out of the soil through leaching and runoff."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708036Z"^^xsd:dateTime .

oak:misconception-challenges-faced-plants-animals-canopy
  a oakcurric:Misconception ;
  oakcurric:statement """The challenges faced by plants and animals in the canopy layer are the same as challenges on the forest floor."""@en ;
  oakcurric:correction """Plants and animals face different challenges in the different habitats of the tropical rainforest. For example, plants on the forest floor have to have adaptations for low light levels."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708040Z"^^xsd:dateTime .

oak:misconception-students-select-basemaps-because-like
  a oakcurric:Misconception ;
  oakcurric:statement "Students will sometimes select basemaps because they like their appearance."@en ;
  oakcurric:correction """Students need to appreciate that some of the basemaps which may be least appealing at first sight provide much more effective visualisation. They are like the canvas for a painting."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708086Z"^^xsd:dateTime .

oak:misconception-green-initiatives-cost-cities-lot
  a oakcurric:Misconception ;
  oakcurric:statement "Green initiatives cost cities a lot of money that could be spent in other ways."@en ;
  oakcurric:correction """Planned well, green initiatives also attract investment and people to cities. They are a sustainable approach to environmental development and also have economic and social benefits."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708193Z"^^xsd:dateTime .

oak:misconception-coastal-deposition-happens-strong-powerful
  a oakcurric:Misconception ;
  oakcurric:statement "Coastal deposition happens with strong powerful waves."@en ;
  oakcurric:correction """Deposition happens in areas with low-energy waves, such as bays or sheltered areas, where waves lose energy and can no longer carry their load of sediment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708394Z"^^xsd:dateTime .

oak:misconception-weather-hazards-dont-badly-affect
  a oakcurric:Misconception ;
  oakcurric:statement "Weather hazards don't badly affect the UK population ."@en ;
  oakcurric:correction """The UK experiences weather hazards that have serious social, economic and environmental impacts, the Beast from the East killed 10 people and cost the UK £1 billion per day."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708399Z"^^xsd:dateTime .

oak:misconception-global-megacity-nee-jakarta-developed
  a oakcurric:Misconception ;
  oakcurric:statement """As a global megacity in an NEE, Jakarta is too developed to have serious problems with providing clean water and sanitation."""@en ;
  oakcurric:correction """Despite being a global megacity, large parts of Jakarta (especially kampungs) lack piped water and sewage systems. Many people rely on groundwater, and open drains are still common in some areas."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708533Z"^^xsd:dateTime .

oak:misconception-urban-planning-nees-lics-designed
  a oakcurric:Misconception ;
  oakcurric:statement "Urban planning in NEEs and LICs is always designed and led by local communities."@en ;
  oakcurric:correction """Much urban planning is led by governments or large corporations, not by local communities. This ‘top-down’ development often aims to improve infrastructure at a city-wide or national level."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708540Z"^^xsd:dateTime .

oak:misconception-students-find-difficult-visualise-orientation
  a oakcurric:Misconception ;
  oakcurric:statement """Students can find it difficult visualise the orientation of landscape visualisations e.g. which way was the camera pointing?"""@en ;
  oakcurric:correction """Remind students to think about the orientation of landscape visualisations. With 3D Scene, there is a compass that can be used to check the orientation and if confused, clicking the compass resets the visualisation to put north at the top."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708685Z"^^xsd:dateTime .

oak:misconception-cold-environments-cannot-support-form
  a oakcurric:Misconception ;
  oakcurric:statement "Cold environments cannot support any form of development."@en ;
  oakcurric:correction """While challenging, development is possible in cold environments with proper planning and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708900Z"^^xsd:dateTime .

oak:misconception-coastal-management-strategies-like-sea
  a oakcurric:Misconception ;
  oakcurric:statement """Coastal management strategies like sea walls and groynes completely solve the threat of coastal erosion."""@en ;
  oakcurric:correction """Coastal management reduces the risk of coastal erosion but does not completely protect an area from erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709025Z"^^xsd:dateTime .

oak:misconception-contour-lines-their-height-marked
  a oakcurric:Misconception ;
  oakcurric:statement "All contour lines have their height marked on them."@en ;
  oakcurric:correction """Most contour lines will show their height, but in very steep areas, where contours are close together, some will be omitted as there is a lack of space. The height of these lines can be calculated by looking at the height of the surrounding lines."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709029Z"^^xsd:dateTime .

oak:misconception-remote-sensing-data-easily-misinterpreted
  a oakcurric:Misconception ;
  oakcurric:statement """Remote sensing data can easily be misinterpreted, especially if filters have been used."""@en ;
  oakcurric:correction """Areas which appear green on an aerial or satellite image may not necessarily represent, e.g. green palm oil plantation or green fields may not be sustainable compared to the natural rainforest vegetation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709034Z"^^xsd:dateTime .

oak:misconception-homes-jakarta-piped-water-connected
  a oakcurric:Misconception ;
  oakcurric:statement """Most homes in Jakarta have piped water and are connected to city sewage infrastructure."""@en ;
  oakcurric:correction """Only 65% of Jakarta has piped water. In kampungs, many homes lack running water and toilets, relying on public wells and pumps and shared toilet facilities, which can spread disease."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709752Z"^^xsd:dateTime .

oak:misconception-volcanoes-occur-land
  a oakcurric:Misconception ;
  oakcurric:statement "Volcanoes only occur on land."@en ;
  oakcurric:correction """In fact, volcanoes occur underwater as well as on land, especially at constructive plate margins and hot spots."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710109Z"^^xsd:dateTime .

oak:misconception-flooding-caused-heavy-rainfall
  a oakcurric:Misconception ;
  oakcurric:statement "Flooding is caused only by heavy rainfall."@en ;
  oakcurric:correction """Heavy rainfall is a key factor, other phyiscal and human factors, such as relief, geology and land use also affect the flood risk."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710296Z"^^xsd:dateTime .

oak:misconception-coastal-landforms-jurassic-coast-such
  a oakcurric:Misconception ;
  oakcurric:statement """Coastal landforms at the Jurassic Coast, such as Lulworth Cove and Old Harry Rocks, were formed quickly in a short period of time."""@en ;
  oakcurric:correction """Coastal landforms at the Jurassic Coast, like Lulworth Cove and Old Harry Rocks, were formed over millions of years. Erosion, weathering, and the movement of tectonic plates have shaped these features gradually."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710585Z"^^xsd:dateTime .
