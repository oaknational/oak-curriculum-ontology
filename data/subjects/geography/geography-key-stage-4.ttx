  a oakcurric:KeyLearningPoint ;
  rdfs:label "Population is unevenly distributed in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.681514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24470-3
  a oakcurric:KeyLearningPoint ;
