  a oakcurric:KeyLearningPoint ;
  rdfs:label """3D GIS visualisations can use attributes including bearing data to create proportional, orientated symbols."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484027Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29609-3
  a oakcurric:KeyLearningPoint ;
