  a oakcurric:KeyLearningPoint ;
  rdfs:label "Food webs help us understand the interrelationships in a small-scale ecosystem."@en ;
  dcterms:modified "2026-02-12T08:59:21.675117Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22969-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nutrient cycles show how nutrients transfer across different stores within an ecosystem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675123Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22984-1
