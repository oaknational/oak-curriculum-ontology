  a oakcurric:KeyLearningPoint ;
  rdfs:label """Theories can help to explain relationships between population and resources, e.g. Malthus and Boserup."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703198Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24412-1
  a oakcurric:KeyLearningPoint ;
