  dcterms:modified "2026-02-12T08:59:21.616969Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24516-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Globalisation has caused economic change in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.616976Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24516-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Government policies have caused economic change in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.616982Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24534-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Direction on a map can be understood by using compass points or bearings."@en ;
  dcterms:modified "2026-02-12T08:59:21.617153Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24534-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Four and six figure grid references are a way of finding a specific place on a map."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24534-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The scale of the map can be used to calculate the distance between two features or places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617170Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24551-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are several important industrial areas located in Jakarta."@en ;
  dcterms:modified "2026-02-12T08:59:21.618695Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24551-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban industrial areas have stimulated economic development in Jakarta."@en ;
  dcterms:modified "2026-02-12T08:59:21.618705Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24551-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban growth has created a range of economic opportunities in Jakarta."@en ;
  dcterms:modified "2026-02-12T08:59:21.618711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24551-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Employment opportunities are changing from manufacturing towards services and from informal to formal sector employment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618717Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29110-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hot desert ecosystems exhibit interdependence of climate, water, soils, plants, animals and people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29110-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Food chains and food webs show how biotic and abiotic components are interdependent in a hot desert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619100Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29110-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nutrient cycles show how biotic and abiotic components are interdependent in hot desert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619106Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24419-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earthquakes have primary and secondary effects (impacts)."@en ;
  dcterms:modified "2026-02-12T08:59:21.619182Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24419-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are short-term (immediate) and long-term responses to earthquakes."@en ;
  dcterms:modified "2026-02-12T08:59:21.619188Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24419-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Volcanic eruptions have primary and secondary effects (impacts)."@en ;
  dcterms:modified "2026-02-12T08:59:21.619195Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24419-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are short-term (immediate) and long-term responses to volcanic eruptions."@en ;
  dcterms:modified "2026-02-12T08:59:21.619201Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24438-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Managing climate change can involve adaptation strategies."@en ;
  dcterms:modified "2026-02-12T08:59:21.619209Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24438-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Adaptation strategies include change in agricultural systems and managing water supply."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24438-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adaptation involves reducing risk from rising sea levels."@en ;
  dcterms:modified "2026-02-12T08:59:21.619222Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24436-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Climate change due to human activity is causing sea level rise, declining Arctic ice and more extreme weather events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622237Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24436-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate change is affecting people and the environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.622242Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24436-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """With a range of projections, for example for global temperatures, there is uncertainty about future climates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24192-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hot deserts are home to a variety of plants and animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.622564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24192-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Plants in hot deserts are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.622570Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24192-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Animals in hot deserts are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.622575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24192-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are issues related to biodiversity in hot deserts."@en ;
  dcterms:modified "2026-02-12T08:59:21.622580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24191-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hot desert ecosystems are located at roughly 30°N and 30°S of the Equator."@en ;
  dcterms:modified "2026-02-12T08:59:21.625887Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24191-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hot desert ecosystems have distinctive physical characteristics."@en ;
  dcterms:modified "2026-02-12T08:59:21.625892Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24191-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The climate influences other physical characteristics of hot deserts."@en ;
  dcterms:modified "2026-02-12T08:59:21.625899Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24548-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban sustainability requires management of resources and transport."@en ;
  dcterms:modified "2026-02-12T08:59:21.626132Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24548-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The features of sustainable living include energy and water conservation, waste recycling and creating green spaces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24548-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban transport strategies can be used to reduce traffic congestion."@en ;
  dcterms:modified "2026-02-12T08:59:21.626145Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27580-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Glaciated upland areas provide opportunities for economic activities."@en ;
  dcterms:modified "2026-02-12T08:59:21.626876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27580-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic activities in glaciated upland areas include tourism, farming, forestry and quarrying."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626881Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27580-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic activities have positive and negative impacts on glaciated upland areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626886Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24529-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate at the coast."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627015Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24529-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data collection techniques at the coast look at beach and wave morphology and coastal management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627020Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24529-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about particular coastlines and comparable data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627025Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24489-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rebranding and regeneration began in Liverpool in the 1980s to reverse the decline of the city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24489-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Significant regeneration has occurred in the centre including areas around the waterfront, RopeWalks and Lime Street."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627036Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24489-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool has been rebranded as a cultural hub due to sports, music, ethnic diversity and maritime and historical sites."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627041Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24489-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Positive impacts include greater job diversity, new leisure facilities and a higher quality urban environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627048Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24489-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Negative impacts include a loss of community, a persistent wealth gap and focus on tourist over local needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24526-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Quantitative data can be presented using a variety of graphs and charts."@en ;
  dcterms:modified "2026-02-12T08:59:21.628004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24526-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Qualitative data can be presented using a variety of text based graphics."@en ;
  dcterms:modified "2026-02-12T08:59:21.628013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24526-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers frequently use maps to show how data varies spatially."@en ;
  dcterms:modified "2026-02-12T08:59:21.628018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24488-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between 1931 and 2021, population in some local authorities in the Liverpool City Region grew, e.g. Halton."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628134Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24488-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1960s saw decentralisation from the declining CBD and inner city in favour of the suburbs and rural-urban fringe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628139Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24488-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Developments in transport enabled decentralisation, e.g. new motorways."@en ;
  dcterms:modified "2026-02-12T08:59:21.628143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24488-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic growth was a result of the development of retail and business parks and out of town shopping from the 1970s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628148Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24488-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban sprawl in the suburbs and rural-urban fringe presents challenges, e.g. congestion and countryside destruction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628153Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24491-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cities are interdependent with accessible rural areas. An example of this is Liverpool and the village of Aughton."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629407Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24491-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Interdependence involves flows of goods, services and labour between urban and accessible rural areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629412Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24491-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Interdependence leads to economic, social and environmental benefits for Aughton and Liverpool."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629417Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24491-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Interdependence leads to economic, social and environmental costs for Aughton and Liverpool."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629422Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24486-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Inequalities exist in Liverpool linked to high relative levels of deprivation."@en ;
  dcterms:modified "2026-02-12T08:59:21.629495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24486-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Index of Multiple Deprivation measures relative deprivation at local authority and smaller scales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629500Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24486-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 6 local authorities in the Liverpool City Region are all in the top 60 most deprived in England. Knowsley ranks 2nd."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629505Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24486-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Deprivation has a cause and effect link to inequalities in services, health, employment and education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24486-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """High deprivation in Liverpool correlates with poor housing, poor health, unemployment and low educational attainment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24541-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Univariate data can be statistically analysed using measures of central tendancy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24541-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data can also be statistically analysed by thinking about proportions and how these change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24541-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The spread of data points across a range of values can be statistically analysed using percentiles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629556Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24531-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate in urban areas such as towns and cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629561Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24531-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data collection techniques in an urban area can investigate quality of life, sustainability and regeneration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629566Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24531-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about urban populations and spaces and how these have changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629571Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24525-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers use different techniques to sample data during fieldwork."@en ;
  dcterms:modified "2026-02-12T08:59:21.629576Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24525-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are a variety of ways that we can measure the morphology (shape) of the land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24525-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways that we can measure the characteristics of the land."@en ;
  dcterms:modified "2026-02-12T08:59:21.629585Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24530-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate along the course of a river."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24530-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data collection methods in a river landscape can examine flood management and a river's agreement to the Bradshaw model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24530-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about particular rivers and comparable data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24492-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Aughton is a rural village easily accesible from Liverpool."@en ;
  dcterms:modified "2026-02-12T08:59:21.629818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24492-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Aughton has experienced economic and social changes as a consequence of counter-urbanisation which began in the 1950s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24492-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Counter-urbanisation led to social changes in Aughton to do with its total population and population structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24492-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The demand for homes in the area has led to a pressure on housing affordability."@en ;
  dcterms:modified "2026-02-12T08:59:21.629834Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24492-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The affluence of the area has led to high-end restaurants and increased visitors have put pressure on the area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629839Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24472-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There has been a decline in the primary and secondary sectors in rural and urban areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24472-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There has been a rise in the tertiary and quaternary sectors in rural and urban areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24472-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """This decline and growth has affected the economy and employment structures of particular areas of the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24490-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool has a number of strategies involving housing such as affordability and energy efficiency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630556Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24490-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool has low rates of recycling. To address this it is using strategies such as education campaigns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24490-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some employment in Liverpool is low paid. Strategies to address this include paying the real national living wage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630565Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24490-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Green spaces have been considered in Liverpool’s city centre though the URBAN GreenUP project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630570Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24490-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is developing integrated transport systems to encourage use of public transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630574Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28944-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are global variations in economic development and quality of life."@en ;
  dcterms:modified "2026-02-12T08:59:21.636775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28944-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are a range of different measures of level of development."@en ;
  dcterms:modified "2026-02-12T08:59:21.636781Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28944-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are limitations of both economic and social measures."@en ;
  dcterms:modified "2026-02-12T08:59:21.636785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24594-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A carbon footprint is the total greenhouse gas emissions caused directly and indirectly by an individual or activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24594-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In some developed countries, there are changing attitudes to unsustainable energy consumption."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636821Z"^^xsd:dateTime .

