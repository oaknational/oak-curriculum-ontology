  dcterms:modified "2026-02-12T08:59:21.484036Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27976-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sediment transportation (longshore drift) and deposition (constructive waves) operate at the coast."""@en ;
