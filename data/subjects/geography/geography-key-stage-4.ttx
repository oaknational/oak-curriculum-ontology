  a oakcurric:KeyLearningPoint ;
  rdfs:label """Marine processes (destructive waves) affect coastal landscapes and the rate of coastal retreat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485131Z"^^xsd:dateTime .

