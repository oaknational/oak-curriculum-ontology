  dcterms:modified "2026-02-12T08:59:21.685827Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24425-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The atmospheric circulation and ocean currents transfer heat around the Earth."@en ;
  dcterms:modified "2026-02-12T08:59:21.685832Z"^^xsd:dateTime .

