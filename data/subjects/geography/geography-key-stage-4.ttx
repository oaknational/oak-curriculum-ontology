# Keywords
# ----------------------------------------------------------------------

oak:keyword-extreme-poverty
  a oakcurric:Keyword ;
  schema:name "extreme poverty"@en ;
  schema:description "living on less than $2.15 a day"@en ;
  dcterms:modified "2026-02-12T08:59:15.789440Z"^^xsd:dateTime .

oak:keyword-modernisation-theory
  a oakcurric:Keyword ;
  schema:name "modernisation theory"@en ;
  schema:description """a view that suggests that countries move through five stages of economic development, proposed by Rostow"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789445Z"^^xsd:dateTime .

oak:keyword-manufacturing
  a oakcurric:Keyword ;
  schema:name "manufacturing"@en ;
  schema:description """the secondary economic sector, involving making goods from raw materials or other manufactured products (for example motor vehicles)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789449Z"^^xsd:dateTime .

oak:keyword-dependency-theory
  a oakcurric:Keyword ;
  schema:name "dependency theory"@en ;
  schema:description """a socialist view that explains how the core (developed countries) exploit the periphery, proposed by Frank"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789454Z"^^xsd:dateTime .

oak:keyword-commonwealth
  a oakcurric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oak:keyword-quality-of-life
  a oakcurric:Keyword ;
  schema:name "quality of life"@en ;
  schema:description """a measure of people’s wellbeing, including access to housing, healthcare, education, income and services"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789667Z"^^xsd:dateTime .

oak:keyword-population-density
  a oakcurric:Keyword ;
  schema:name "population density"@en ;
  schema:description "the number of people living per square kilometre (km²)"@en ;
  dcterms:modified "2026-02-12T08:59:15.789671Z"^^xsd:dateTime .

oak:keyword-kampungs
  a oakcurric:Keyword ;
  schema:name "kampungs"@en ;
  schema:description """informal settlements in Indonesian cities built by residents, often on derelict or unsafe land"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789675Z"^^xsd:dateTime .

oak:keyword-climate
  a oakcurric:Keyword ;
  schema:name "climate"@en ;
  schema:description """the average weather conditions (such as rainfall and temperature) recorded over a 30-year period"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789680Z"^^xsd:dateTime .

oak:keyword-altitude
  a oakcurric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "the height above sea level"@en ;
  dcterms:modified "2026-02-12T08:59:15.789684Z"^^xsd:dateTime .

oak:keyword-drainage
  a oakcurric:Keyword ;
  schema:name "drainage"@en ;
  schema:description "the distribution, storage and movement of water in the environment"@en ;
  dcterms:modified "2026-02-12T08:59:15.789689Z"^^xsd:dateTime .

oak:keyword-biome
  a oakcurric:Keyword ;
  schema:name "biome"@en ;
  schema:description "a large-scale global ecosystem, for example, a tropical rainforest"@en ;
  dcterms:modified "2026-02-12T08:59:15.789699Z"^^xsd:dateTime .

oak:keyword-distribution
  a oakcurric:Keyword ;
  schema:name "distribution"@en ;
  schema:description """the spread (which may have a regular pattern) of, for example, a type of vegetation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789704Z"^^xsd:dateTime .

oak:keyword-latitude
  a oakcurric:Keyword ;
  schema:name "latitude"@en ;
  schema:description """distance from the Equator north or south. Lines of latitude run east-west on a map, e.g., the Tropic of Cancer"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789708Z"^^xsd:dateTime .

oak:keyword-megacity
  a oakcurric:Keyword ;
  schema:name "megacity"@en ;
  schema:description "a city with a population of over 10 million people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789713Z"^^xsd:dateTime .

oak:keyword-migration
  a oakcurric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oak:keyword-natural-increase
  a oakcurric:Keyword ;
  schema:name "natural increase"@en ;
  schema:description """the difference between the birth rate and the death rate of a population; occurs when the birth rate is higher than the death rate"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789724Z"^^xsd:dateTime .

oak:keyword-transnational-corporation
  a oakcurric:Keyword ;
  schema:name "transnational corporation"@en ;
  schema:description """TNCs are firms that own or control productive operations in more than one country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789729Z"^^xsd:dateTime .

oak:keyword-intergovernmental-organisation
  a oakcurric:Keyword ;
  schema:name "intergovernmental organisation"@en ;
  schema:description """IGOs are established by a treaty or agreement between countries pursuing a common goal, e.g. World Bank"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789735Z"^^xsd:dateTime .

oak:keyword-globalisation
  a oakcurric:Keyword ;
  schema:name "globalisation"@en ;
  schema:description """the increased interconnectedness of the world, economically, politically and culturally"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789740Z"^^xsd:dateTime .

oak:keyword-tourism-project
  a oakcurric:Keyword ;
  schema:name "tourism project"@en ;
  schema:description """planned initiative designed to attract tourists such as new attractions, improvements to infrastructure, promotion of sustainable tourism and the development of tourism-related businesses"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789819Z"^^xsd:dateTime .

oak:keyword-rural-diversification
  a oakcurric:Keyword ;
  schema:name "rural diversification"@en ;
  schema:description """increase the spread of commercial activities, for example, by creating new enterprises on a farm such as a shop or a B&B"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789824Z"^^xsd:dateTime .

oak:keyword-enquiry
  a oakcurric:Keyword ;
  schema:name "enquiry"@en ;
  schema:description """a way of learning new information about a place by following a set course of activities or tasks"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789900Z"^^xsd:dateTime .

oak:keyword-hypothesis
  a oakcurric:Keyword ;
  schema:name "hypothesis"@en ;
  schema:description "a prediction taken at the start of the enquiry that can then be tested"@en ;
  dcterms:modified "2026-02-12T08:59:15.789905Z"^^xsd:dateTime .

oak:keyword-research-framework
  a oakcurric:Keyword ;
  schema:name "research framework"@en ;
  schema:description "the type of geographical research on which the enquiry will focus"@en ;
  dcterms:modified "2026-02-12T08:59:15.789911Z"^^xsd:dateTime .

oak:keyword-famine
  a oakcurric:Keyword ;
  schema:name "famine"@en ;
  schema:description """a famine is a situation in which there is not enough food for a great number of people, causing illness and death, or a particular period when this happens"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790016Z"^^xsd:dateTime .

oak:keyword-refugee
  a oakcurric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oak:keyword-character
  a oakcurric:Keyword ;
  schema:name "character"@en ;
  schema:description "a person or an animal in a story"@en ;
  dcterms:modified "2026-02-12T08:59:15.790032Z"^^xsd:dateTime .

oak:keyword-suburbanisation
  a oakcurric:Keyword ;
  schema:name "suburbanisation"@en ;
  schema:description """the movement of people from more central urban areas to the outskirts of an urban area"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790261Z"^^xsd:dateTime .

oak:keyword-urban-sprawl
  a oakcurric:Keyword ;
  schema:name "urban sprawl"@en ;
  schema:description """the unplanned, and often rapid, growth of urban areas into the surrounding countryside"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790265Z"^^xsd:dateTime .

oak:keyword-de-industrialisation
  a oakcurric:Keyword ;
  schema:name "de-industrialisation"@en ;
  schema:description "the loss of manufacturing industries from urban areas"@en ;
  dcterms:modified "2026-02-12T08:59:15.790269Z"^^xsd:dateTime .

oak:keyword-regeneration
  a oakcurric:Keyword ;
  schema:name "regeneration"@en ;
  schema:description """investing money into poorer and derelict urban areas where there was once a sustainable economy in industry"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790305Z"^^xsd:dateTime .

oak:keyword-erosion
  a oakcurric:Keyword ;
  schema:name "erosion"@en ;
  schema:description "the wearing away of rocks along the coastline"@en ;
  dcterms:modified "2026-02-12T08:59:15.790389Z"^^xsd:dateTime .

oak:keyword-climate-change
  a oakcurric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "long-term shifts in temperatures and weather patterns"@en ;
  dcterms:modified "2026-02-12T08:59:15.790394Z"^^xsd:dateTime .

oak:keyword-coastal-management
  a oakcurric:Keyword ;
  schema:name "coastal management"@en ;
  schema:description """the protection of coastlines from erosion and flooding through artificial or natural methods"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790400Z"^^xsd:dateTime .

oak:keyword-objective
  a oakcurric:Keyword ;
  schema:name "objective"@en ;
  schema:description """something that is based on facts and not influenced by personal feelings or opinions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790433Z"^^xsd:dateTime .

oak:keyword-inflow
  a oakcurric:Keyword ;
  schema:name "inflow"@en ;
  schema:description "migration of people to a place"@en ;
  dcterms:modified "2026-02-12T08:59:15.790793Z"^^xsd:dateTime .

oak:keyword-outflow
  a oakcurric:Keyword ;
  schema:name "outflow"@en ;
  schema:description "migration of people away from a place"@en ;
  dcterms:modified "2026-02-12T08:59:15.790797Z"^^xsd:dateTime .

oak:keyword-ethnicity
  a oakcurric:Keyword ;
  schema:name "ethnicity"@en ;
  schema:description """a term that refers to the backgrounds or shared experiences of a group of people, including language, religion and beliefs"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790802Z"^^xsd:dateTime .

oak:keyword-deindustrialisation
  a oakcurric:Keyword ;
  schema:name "deindustrialisation"@en ;
  schema:description """decline in importance of the industrial sector, for example, the closure of factories"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790876Z"^^xsd:dateTime .

oak:keyword-depopulation
  a oakcurric:Keyword ;
  schema:name "depopulation"@en ;
  schema:description """reduction in the population of an area, typically involving out-migration following deindustrialisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790880Z"^^xsd:dateTime .

oak:keyword-studentification
  a oakcurric:Keyword ;
  schema:name "studentification"@en ;
  schema:description """areas with a high concentration of students, typically in sub-divided rental properties"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790885Z"^^xsd:dateTime .

oak:keyword-gentrification
  a oakcurric:Keyword ;
  schema:name "gentrification"@en ;
  schema:description """the upgrading of areas (typically housing) often in the inner city, making them more desirable but often more expensive"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790889Z"^^xsd:dateTime .

oak:keyword-site
  a oakcurric:Keyword ;
  schema:name "site"@en ;
  schema:description "the point on the ground where a settlement is built"@en ;
  dcterms:modified "2026-02-12T08:59:15.790894Z"^^xsd:dateTime .

oak:keyword-situation
  a oakcurric:Keyword ;
  schema:name "situation"@en ;
  schema:description "the description of a place in relation to its human and physical surroundings"@en ;
  dcterms:modified "2026-02-12T08:59:15.790898Z"^^xsd:dateTime .

oak:keyword-connectivity
  a oakcurric:Keyword ;
  schema:name "connectivity"@en ;
  schema:description """a measure of how well connected (by transport and other forms of communication) a place is"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790904Z"^^xsd:dateTime .

oak:keyword-subjective
  a oakcurric:Keyword ;
  schema:name "subjective"@en ;
  schema:description "subjective data is data that is based on opinions"@en ;
  dcterms:modified "2026-02-12T08:59:15.790934Z"^^xsd:dateTime .

oak:keyword-reliable
  a oakcurric:Keyword ;
  schema:name "reliable"@en ;
  schema:description """reliable data is data that would show the same result were it to be collected on a comparably similar occasion"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790938Z"^^xsd:dateTime .

oak:keyword-valid
  a oakcurric:Keyword ;
  schema:name "valid"@en ;
  schema:description """valid data is data that allows the geographer to answer their enquiry question successfully"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790943Z"^^xsd:dateTime .

oak:keyword-anomaly
  a oakcurric:Keyword ;
  schema:name "anomaly"@en ;
  schema:description "a piece of data that sits outside the general trend and cannot be explained"@en ;
  dcterms:modified "2026-02-12T08:59:15.790956Z"^^xsd:dateTime .

oak:keyword-commercial
  a oakcurric:Keyword ;
  schema:name "commercial"@en ;
  schema:description "a land use category used for areas that trade goods and services"@en ;
  dcterms:modified "2026-02-12T08:59:15.790973Z"^^xsd:dateTime .

oak:keyword-cbd
  a oakcurric:Keyword ;
  schema:name "CBD"@en ;
  schema:description "central business district; the commercial centre of an urban area"@en ;
  dcterms:modified "2026-02-12T08:59:15.790978Z"^^xsd:dateTime .

oak:keyword-brownfield-site
  a oakcurric:Keyword ;
  schema:name "brownfield site"@en ;
  schema:description """an area of land that was formerly used for something but which is now abandoned or derelict"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790982Z"^^xsd:dateTime .

oak:keyword-greenbelt
  a oakcurric:Keyword ;
  schema:name "greenbelt"@en ;
  schema:description """a ring of land that surrounds some UK urban areas where new constructions are regulated to prevent urban sprawl"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790986Z"^^xsd:dateTime .

oak:keyword-stakeholder
  a oakcurric:Keyword ;
  schema:name "stakeholder"@en ;
  schema:description "a person with a particular interest in the issue being investigated"@en ;
  dcterms:modified "2026-02-12T08:59:15.790993Z"^^xsd:dateTime .

oak:keyword-lived-experience
  a oakcurric:Keyword ;
  schema:name "lived experience"@en ;
  schema:description "the everyday, personal experience that someone has of living in a place"@en ;
  dcterms:modified "2026-02-12T08:59:15.790997Z"^^xsd:dateTime .

oak:keyword-primary-data
  a oakcurric:Keyword ;
  schema:name "primary data"@en ;
  schema:description "data that is collected in person during fieldwork"@en ;
  dcterms:modified "2026-02-12T08:59:15.791004Z"^^xsd:dateTime .

oak:keyword-secondary-data
  a oakcurric:Keyword ;
  schema:name "secondary data"@en ;
  schema:description """data that has previously been collected by someone, usually unknown to the person doing the fieldwork"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791008Z"^^xsd:dateTime .

oak:keyword-quantitative
  a oakcurric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "data that is made up of numbers"@en ;
  dcterms:modified "2026-02-12T08:59:15.791012Z"^^xsd:dateTime .

oak:keyword-qualitative
  a oakcurric:Keyword ;
  schema:name "qualitative"@en ;
  schema:description "data that is made up of text"@en ;
  dcterms:modified "2026-02-12T08:59:15.791016Z"^^xsd:dateTime .

oak:keyword-asean
  a oakcurric:Keyword ;
  schema:name "ASEAN"@en ;
  schema:description """the Association of Southeast Asian Nations is a group of 10 nations who cooperate on trade and security with the aim of boosting their economic, social and cultural development"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791107Z"^^xsd:dateTime .

oak:keyword-context
  a oakcurric:Keyword ;
  schema:name "context"@en ;
  schema:description """the background conditions and situation that help explain what is happening in a country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791111Z"^^xsd:dateTime .

oak:keyword-economic-sector
  a oakcurric:Keyword ;
  schema:name "economic sector"@en ;
  schema:description """a category of economic activity where jobs are grouped together based on their type of work"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791116Z"^^xsd:dateTime .

oak:keyword-formal-employment
  a oakcurric:Keyword ;
  schema:name "formal employment"@en ;
  schema:description "employment that is officially recognised and regulated"@en ;
  dcterms:modified "2026-02-12T08:59:15.791120Z"^^xsd:dateTime .

oak:keyword-informal-employment
  a oakcurric:Keyword ;
  schema:name "informal employment"@en ;
  schema:description "employment that lacks official recognition and has no regulation"@en ;
  dcterms:modified "2026-02-12T08:59:15.791124Z"^^xsd:dateTime .

oak:keyword-primary-employment
  a oakcurric:Keyword ;
  schema:name "primary employment"@en ;
  schema:description """jobs involving the extraction of raw materials including farming, fishing and mining"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791128Z"^^xsd:dateTime .

oak:keyword-immigration
  a oakcurric:Keyword ;
  schema:name "immigration"@en ;
  schema:description "the act of moving into a new host location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791133Z"^^xsd:dateTime .

oak:keyword-emigration
  a oakcurric:Keyword ;
  schema:name "emigration"@en ;
  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791137Z"^^xsd:dateTime .

oak:keyword-asylum-seeker
  a oakcurric:Keyword ;
  schema:name "asylum seeker"@en ;
  schema:description """someone who seeks permanent or temporary protection in another country from the persecution or danger they experience in their home country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791141Z"^^xsd:dateTime .

oak:keyword-fdi
  a oakcurric:Keyword ;
  schema:name "FDI"@en ;
  schema:description """foreign direct investment. Investment in a business that operates in another country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791145Z"^^xsd:dateTime .

oak:keyword-tnc
  a oakcurric:Keyword ;
  schema:name "TNC"@en ;
  schema:description "transnational corporation. A company that operates in more than one country"@en ;
  dcterms:modified "2026-02-12T08:59:15.791149Z"^^xsd:dateTime .

oak:keyword-free-trade
  a oakcurric:Keyword ;
  schema:name "free trade"@en ;
  schema:description """trade between countries or economic regions where no tariffs (tax) exist on imported or exported goods"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791156Z"^^xsd:dateTime .

oak:keyword-privatisation
  a oakcurric:Keyword ;
  schema:name "privatisation"@en ;
  schema:description "the takeover of state-run industries by private corporations"@en ;
  dcterms:modified "2026-02-12T08:59:15.791160Z"^^xsd:dateTime .

oak:keyword-variation
  a oakcurric:Keyword ;
  schema:name "variation"@en ;
  schema:description """differences or changes in something, for example variations in energy use between countries means differences in the amounts and types of energy that different countries use"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791164Z"^^xsd:dateTime .

oak:keyword-economic-development
  a oakcurric:Keyword ;
  schema:name "economic development"@en ;
  schema:description """the growth of a country’s wealth, leading to better jobs, higher incomes and improved living standards"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791171Z"^^xsd:dateTime .

oak:keyword-economic-sectors
  a oakcurric:Keyword ;
  schema:name "economic sectors"@en ;
  schema:description """the different types of jobs and industries in an economy, divided into primary (e.g. farming), secondary (e.g. manufacturing), tertiary (services) and quaternary (e.g. research)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791175Z"^^xsd:dateTime .

oak:keyword-value
  a oakcurric:Keyword ;
  schema:name "value"@en ;
  schema:description "how important an area is either socially, economically or environmentally"@en ;
  dcterms:modified "2026-02-12T08:59:15.791180Z"^^xsd:dateTime .

oak:keyword-hard-engineering
  a oakcurric:Keyword ;
  schema:name "hard engineering"@en ;
  schema:description "using artificial structures to protect coastlines from erosion and flooding"@en ;
  dcterms:modified "2026-02-12T08:59:15.791184Z"^^xsd:dateTime .

oak:keyword-soft-engineering
  a oakcurric:Keyword ;
  schema:name "soft engineering"@en ;
  schema:description """making use of natural processes to reduce erosion and flooding  in a way that minimies environmental impact"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791188Z"^^xsd:dateTime .

oak:keyword-inequality
  a oakcurric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "inequality is when something is not shared evenly between everyone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791205Z"^^xsd:dateTime .

oak:keyword-development
  a oakcurric:Keyword ;
  schema:name "development"@en ;
  schema:description "development is when something changes, usually an improvement"@en ;
  dcterms:modified "2026-02-12T08:59:15.791209Z"^^xsd:dateTime .

oak:keyword-access
  a oakcurric:Keyword ;
  schema:name "access"@en ;
  schema:description "the ability to use a resource in a way that benefits people"@en ;
  dcterms:modified "2026-02-12T08:59:15.791230Z"^^xsd:dateTime .

oak:keyword-reserve
  a oakcurric:Keyword ;
  schema:name "reserve"@en ;
  schema:description """the amount of a fossil fuel that has been discovered and can be extracted and sold"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791237Z"^^xsd:dateTime .

oak:keyword-supply
  a oakcurric:Keyword ;
  schema:name "supply"@en ;
  schema:description "the amount of something (e.g. oil) that is available to buy"@en ;
  dcterms:modified "2026-02-12T08:59:15.791242Z"^^xsd:dateTime .

oak:keyword-demand
  a oakcurric:Keyword ;
  schema:name "demand"@en ;
  schema:description "how much of something (e.g. oil) that people want to buy"@en ;
  dcterms:modified "2026-02-12T08:59:15.791245Z"^^xsd:dateTime .

oak:keyword-diplomatic-relations
  a oakcurric:Keyword ;
  schema:name "diplomatic relations"@en ;
  schema:description """how well (or badly) countries get along with each other, which can affect trading relationships of supply and demand"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791250Z"^^xsd:dateTime .

oak:keyword-recession
  a oakcurric:Keyword ;
  schema:name "recession"@en ;
  schema:description "a period when economies stop growing temporarily and people spend less"@en ;
  dcterms:modified "2026-02-12T08:59:15.791254Z"^^xsd:dateTime .

oak:keyword-non-renewable-energy
  a oakcurric:Keyword ;
  schema:name "non-renewable energy"@en ;
  schema:description """a natural source of energy that will run out because it cannot be reproduced, such as coal, oil and natural gas"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791281Z"^^xsd:dateTime .

oak:keyword-renewable-energy
  a oakcurric:Keyword ;
  schema:name "renewable energy"@en ;
  schema:description """a natural source of energy that will never run out, such as flows of wind, water and solar energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791287Z"^^xsd:dateTime .

oak:keyword-recyclable-energy
  a oakcurric:Keyword ;
  schema:name "recyclable energy"@en ;
  schema:description """sources of energy that can be reused and so will last into the future, such as biofuels and nuclear energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791292Z"^^xsd:dateTime .

oak:keyword-sustainable
  a oakcurric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description "able to continue over a long time"@en ;
  dcterms:modified "2026-02-12T08:59:15.791311Z"^^xsd:dateTime .

oak:keyword-habitat
  a oakcurric:Keyword ;
  schema:name "habitat"@en ;
  schema:description "the natural home or environment of an animal, plant or other organism"@en ;
  dcterms:modified "2026-02-12T08:59:15.791326Z"^^xsd:dateTime .

oak:keyword-efficiency
  a oakcurric:Keyword ;
  schema:name "efficiency"@en ;
  schema:description """energy efficiency means using technology that needs less energy to perform the same task"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791330Z"^^xsd:dateTime .

oak:keyword-conservation
  a oakcurric:Keyword ;
  schema:name "conservation"@en ;
  schema:description """energy conservation involves changing people's behaviour in ways that mean they use less energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791334Z"^^xsd:dateTime .

oak:keyword-tourism
  a oakcurric:Keyword ;
  schema:name "tourism"@en ;
  schema:description """Tourism means people travelling to a different place from where they live for a holiday"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791349Z"^^xsd:dateTime .

oak:keyword-energy-mix
  a oakcurric:Keyword ;
  schema:name "energy mix"@en ;
  schema:description """the combination of different energy sources used by a country or a region. The energy mix can change over time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791358Z"^^xsd:dateTime .

oak:keyword-energy-security
  a oakcurric:Keyword ;
  schema:name "energy security"@en ;
  schema:description "the uninterrupted availability of energy sources at an affordable price"@en ;
  dcterms:modified "2026-02-12T08:59:15.791362Z"^^xsd:dateTime .

oak:keyword-carbon-footprint
  a oakcurric:Keyword ;
  schema:name "carbon footprint"@en ;
  schema:description """the total amount of carbon dioxide and other greenhouse gases released into the atmosphere by an individual, product, process, country, etc"""@en ;
