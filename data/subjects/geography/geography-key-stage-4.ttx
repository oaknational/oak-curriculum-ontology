oak:keylearningpoint-lesson-22982-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Climate change is affecting tropical rainforests."@en ;
  dcterms:modified "2026-02-12T08:59:21.655921Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22982-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """How is climate change an indirect threat to tropical rainforests (ecosystem stress, drought)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22986-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The taiga is increasingly threatened by commercial development."@en ;
  dcterms:modified "2026-02-12T08:59:21.655930Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22986-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Threats include logging, pulp and paper production, fossil fuel extraction, mining and HEP development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655935Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22986-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An example of threat to the taiga from development is the commercial exploitation of tar sands in Alberta, Canada."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655939Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22980-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are special ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.655944Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22980-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are of value to people at all scales."@en ;
  dcterms:modified "2026-02-12T08:59:21.655948Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22980-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are of value to the environment at all scales."@en ;
  dcterms:modified "2026-02-12T08:59:21.655952Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22987-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The taiga is vulnerable to biodiversity loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.658009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22987-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The taiga is experiencing a loss of biodiversity."@en ;
  dcterms:modified "2026-02-12T08:59:21.658013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22987-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Acid precipitation is contributing to a loss of biodiversity."@en ;
  dcterms:modified "2026-02-12T08:59:21.658018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22987-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Forest fires and pests and diseases are contributing to a loss of biodiversity."@en ;
  dcterms:modified "2026-02-12T08:59:21.658023Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22985-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The taiga has a lower rate of productivity than tropical rainforests and less active nutrient cycling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660680Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22985-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The taiga support much lower levels of biodiversity than tropical rainforests."@en ;
  dcterms:modified "2026-02-12T08:59:21.660685Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22983-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The taiga is an example of a global biome."@en ;
  dcterms:modified "2026-02-12T08:59:21.666551Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22983-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The taiga has distinctive biotic (living) characteristics (plants, animals and humans)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22983-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The taiga has distinctive abiotic (non-living) characteristics (climate, soil and water)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22983-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Biotic and abiotic characteristics are interdependent."@en ;
  dcterms:modified "2026-02-12T08:59:21.666564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22989-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are conflicting views on protecting forest and natural resources in the taiga."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667220Z"^^xsd:dateTime .

