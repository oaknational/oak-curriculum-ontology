  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sub-aerial processes (mass movement, weathering) affect coastal landscapes and the rate of coastal retreat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22971-1
