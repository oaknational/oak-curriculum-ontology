# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oak:keylearningpoint-lesson-24499-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are different theories that can explain how countries develop over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.481150Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24499-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rostow's modernisation theory suggests that the introduction of manufacturing causes countries to develop."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481154Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24499-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Frank's dependency theory suggests that the development of a core and periphery leads to inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481158Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24563-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are significant  inequalities in Jakarta's residential areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.481442Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24563-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are  differences in quality of life in Jakarta's residential areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.481446Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24563-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Managing Jakarta involves political and economic challenges."@en ;
  dcterms:modified "2026-02-12T08:59:21.481450Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22972-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """On a large-scale, climate is the main factor affecting the distribution of biomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22972-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Local factors (altitude, rock and soil type and drainage) can affect local biome distribution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481458Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22972-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Biotic and abiotic components interact within biomes, reflecting these large-scale and small-scale factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22974-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ecosystems at the global scale are called biomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.481484Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22974-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pattern of biomes is broadly latitudinal, with tropical rainforests near the Equator and tundra near the poles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-22974-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each biome has distinct characteristics as a result of its specific climate."@en ;
  dcterms:modified "2026-02-12T08:59:21.481491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24558-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Jakarta is a rapidly growing megacity."@en ;
  dcterms:modified "2026-02-12T08:59:21.481495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24558-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Natural increase has contributed to population growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.481499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24558-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "National and international migration has contributed to population growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.481503Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24558-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Economic investment and growth has contributed to population growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.481507Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24502-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Top-down and bottom-up strategies to reduce global inequalities differ in scale, aims, funding and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481511Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24502-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Strategies such as foreign direct investment contribute to globalisation, but some countries benefit more than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481517Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24502-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Foreign direct investment by TNCs can lead to large-scale, economic change; but profits leak and jobs may be short-term."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24502-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Loans from IGOs for large infrastructure projects can deliver technological solutions, but also risk debt problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481525Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24494-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic challenges from the decline in farming have led to new economic opportunities in rural areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481604Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24494-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tourism projects and rural diversification support the local multiplier effect which strengthens the local economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481611Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24494-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An example of a tourism project in Eden is the Herdwick Stones and of rural diversification, Waterside House."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481616Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24494-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic opportunities have environmental impacts which can be positive and negative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481621Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20261-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An enquiry question helps geographers to learn more about the world when they do fieldwork."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481692Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20261-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A good enquiry question guides the geographer through the enquiry process, is linked to place and uses precise language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20261-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Enquiry questions come from different ways of conducting fieldwork known as research frameworks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481701Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24546-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban areas change over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.482118Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24546-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Urban population numbers, distribution and spatial growth change over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.482122Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24546-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Processes of urban change include urbanisation, suburbanisation, de-industrialisation and regeneration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482126Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24546-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counter-urbanisation is a process leading to urban change."@en ;
  dcterms:modified "2026-02-12T08:59:21.482130Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24449-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Happisburgh is experiencing some of the fastest coastal erosion rates in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.482176Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24449-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physical processes make the Happisburgh coastline vulnerable to erosion."@en ;
  dcterms:modified "2026-02-12T08:59:21.482182Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24449-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Human processes play a significant role in the rate of coastal erosion at Happisburgh."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24485-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool's migrations can be divided over time (historical and recent) and over space (national and international)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24485-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Significant national, historical inflows have been from Ireland and Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.482346Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24485-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "International inflows have been both historic and recent."@en ;
  dcterms:modified "2026-02-12T08:59:21.482350Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24485-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool's population, age structure, economy, ethnicity, housing, income, services and culture have been influenced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482354Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24485-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Toxteth, Calderstones and Halewood have been influenced in different ways"@en ;
  dcterms:modified "2026-02-12T08:59:21.482358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24487-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Deindustrialisation in the 20th century triggered depopulation in Liverpool's CBD and inner city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482378Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24487-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The CBD and inner city experienced decline from the 1930s to 1990s followed by growth due to regeneration efforts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482382Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24487-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Decline in the CBD and inner city led to challenges including dereliction, unemployment and economic recession."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482385Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24487-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """21st century economic and population growth led to significant investment in the CBD."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482392Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24487-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Studentification, gentrification and e-commernce have brought challenges and opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482396Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24483-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is a coastal city sited on flat land in NW England and situated about 300 km NW of London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482400Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24483-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is connected to the rest of the world through rail, road, sea and air links."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482404Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24483-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool's importance nationally and globally is a consequence of its site, situation and connectivity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482408Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24483-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is nationally important for its diversity, city economy, role in the Industrial Revolution and population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482412Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24483-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Liverpool is globally important for trade, sporting and cultural events and its link to the slave trade and migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24528-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are many stages of a geographical enquiry that can be evaluated."@en ;
  dcterms:modified "2026-02-12T08:59:21.482457Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24528-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Conclusions should be evaluated to show how reliable and valid the data is."@en ;
  dcterms:modified "2026-02-12T08:59:21.482461Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24528-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Geographical research is often evaluated to see how ethically and morally considerate it is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24547-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are a variety of urban land uses."@en ;
  dcterms:modified "2026-02-12T08:59:21.482493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24547-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Urban land uses (commercial, industrial and residential) have different characteristics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482498Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24547-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Several factors influence urban land use, including accessibility, availability, cost and planning regulations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482502Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24532-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate in rural areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24532-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Data collection techniques in a rural area can investigate inequality, service provision and lived experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482511Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24532-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about rural populations and spaces and how they have changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24524-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Geographers can collect lots of different types of data during fieldwork."@en ;
  dcterms:modified "2026-02-12T08:59:21.482520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24524-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Questionnaires can be used to measure people's opinions."@en ;
  dcterms:modified "2026-02-12T08:59:21.482523Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24524-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Specific surveys can be used to measure activity in, and the quality of, a settlement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24504-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Indonesia is the largest country in Southeast Asia and is an archipelago consisting of over 17 000 islands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482642Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24504-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Indonesia is important regionally and globally."@en ;
  dcterms:modified "2026-02-12T08:59:21.482646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24504-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Indonesia is placed within a wider political, social, cultural and environmental context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482650Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24545-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are four sectors of employment."@en ;
  dcterms:modified "2026-02-12T08:59:21.482654Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24545-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different urban economies are defined by these sectors."@en ;
  dcterms:modified "2026-02-12T08:59:21.482658Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24545-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Formal and informal employment create different working conditions in urban economies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482662Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24493-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Eden is a very rural district within the rural county of Cumbria."@en ;
  dcterms:modified "2026-02-12T08:59:21.482666Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24493-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eden has the highest percentage of green space and lowest population density of any district in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24493-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eden ranks 186 on the Index of Multiple Deprivation. This masks areas of high deprivation such as barriers to services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482674Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24493-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eden faces four challenges: housing, provision of education and healthcare and decline in primary employment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24493-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The young and elderly are more likely to be affected by challenges due to dependency on parents or the state for income."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24471-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """National migration has altered the population geography of the UK (numbers, distribution, age structure)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482686Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24471-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """International migration has altered the population geography of the UK (numbers, distribution, age structure)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482690Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24471-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """UK and EU immigration policy has contributed to increasing ethnic and cultural diversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24473-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Globalisation has increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.482700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24473-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Free-trade policies have increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.482704Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24473-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Privatisation has increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.482707Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24473-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "TNCs play a significant role in the UK economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.482711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24586-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are variations (inequalities) in the global pattern of energy use."@en ;
  dcterms:modified "2026-02-12T08:59:21.482715Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24586-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Level of economic development is a cause of variations in the global pattern of energy use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482721Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24586-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Demand from different economic sectors cause variations in energy use."@en ;
  dcterms:modified "2026-02-12T08:59:21.482727Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-24586-4
  a oakcurric:KeyLearningPoint ;
