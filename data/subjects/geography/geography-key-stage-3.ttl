  dcterms:modified "2026-02-12T08:59:21.696252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24226-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mumbai accounts for 25% of India's industrial output."@en ;
