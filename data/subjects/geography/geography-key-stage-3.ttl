oakcurric:keylearningpoint-lesson-24300-1
  a curric:KeyLearningPoint ;
  rdfs:label """Life varies around the world in a range of different ways related to physical and human geography."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699565Z"^^xsd:dateTime .

