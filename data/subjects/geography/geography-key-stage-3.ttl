# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-24336-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria is one of the world's largest oil producers."@en ;
  dcterms:modified "2026-02-12T08:59:21.482791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24336-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oil brings wealth, jobs and economic growth but also corruption and inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.482795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24336-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many people in Nigeria don't benefit from oil revenue."@en ;
  dcterms:modified "2026-02-12T08:59:21.482799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24336-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oil extraction has environmental impacts which harm people and ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.482803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24336-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different stakeholders often have different perspectives about the future of Nigeria’s oil industry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24347-1
  a curric:KeyLearningPoint ;
  rdfs:label "Flooding causes widespread problems globally."@en ;
  dcterms:modified "2026-02-12T08:59:21.482848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24347-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Bangladesh, heavy rainfall and snowmelt water regularly cause flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.482854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Drinking water can become contaminated by sewage, which leads to widespread health problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24347-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flooding causes homelessness and displacement."@en ;
  dcterms:modified "2026-02-12T08:59:21.482862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24355-1
  a curric:KeyLearningPoint ;
  rdfs:label "Commercial fishing normally includes less sustainable methods, e.g. trawling."@en ;
  dcterms:modified "2026-02-12T08:59:21.482902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24355-2
  a curric:KeyLearningPoint ;
  rdfs:label "Longlining and trap fishing are more sustainable fishing methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.482906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fish farming, or aquaculture, is the controlled breeding and harvesting of fish in enclosures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24355-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 2018 nearly 90% of the world’s marine (sea) fish stocks were fully exploited, overexploited or depleted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24355-5
  a curric:KeyLearningPoint ;
  rdfs:label """Overfishing, bycatch and marine habitat damage are some of the concerns associated with fishing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Russia's physical geography includes the Ural Mountains, Siberian Plateau, and vast plains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Russia has diverse landforms, including highlands in the south and flat plains in the north."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24388-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Volga River is the longest river in Europe and flows through central Russia."@en ;
  dcterms:modified "2026-02-12T08:59:21.484064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24388-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Kamchatka Peninsula has volcanic landscapes with active volcanoes."@en ;
  dcterms:modified "2026-02-12T08:59:21.484068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24388-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Caspian Sea, located in southern Russia, is the world's largest inland body of water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24328-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria has tropical and semi-arid climate zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.484962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24328-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rainfall is highest in the south and lowest in the north."@en ;
  dcterms:modified "2026-02-12T08:59:21.484966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24328-3
  a curric:KeyLearningPoint ;
  rdfs:label "The country experiences a wet and dry season."@en ;
  dcterms:modified "2026-02-12T08:59:21.484973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24328-4
  a curric:KeyLearningPoint ;
  rdfs:label "Climate varies due to latitude, altitude, and proximity to the sea."@en ;
  dcterms:modified "2026-02-12T08:59:21.484977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24285-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mount Nyiragongo is a volcano located in the Democratic Republic of the Congo, on the East African Rift System."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24285-2
  a curric:KeyLearningPoint ;
  rdfs:label """On the 22nd May 2021, it began to erupt; this followed a deadly eruption in 2002, which reached the city of Goma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24285-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the eruption happened, lava poured down the sides of the volcano."@en ;
  dcterms:modified "2026-02-12T08:59:21.485374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24285-4
  a curric:KeyLearningPoint ;
  rdfs:label "At least 450 000 people were displaced or evacuated due to the lava flows."@en ;
  dcterms:modified "2026-02-12T08:59:21.485378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24190-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are different theories about how population will change in the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.604651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24190-2
  a curric:KeyLearningPoint ;
  rdfs:label """The population of some places around the world is likely to significantly increase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24190-3
  a curric:KeyLearningPoint ;
  rdfs:label "The population of some places around the world is likely to decrease."@en ;
  dcterms:modified "2026-02-12T08:59:21.604667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24190-4
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change will have an impact on the movement of people around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.604675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24214-1
  a curric:KeyLearningPoint ;
  rdfs:label """Communities such as the Saami live in parts of the boreal forest, they are traditionally reindeer herders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24214-2
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional ways of life in the boreal forest are being threatened."@en ;
  dcterms:modified "2026-02-12T08:59:21.607135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24214-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation is rapidly reducing the size of boreal forests to make way for human activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24214-4
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation has led to the fragmentation of the woodland caribou habitat."@en ;
  dcterms:modified "2026-02-12T08:59:21.607150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24170-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of erosion: abrasion, hydraulic action, attrition and solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24170-2
  a curric:KeyLearningPoint ;
  rdfs:label "The geology of a coastline will have an impact on the rate of erosion."@en ;
  dcterms:modified "2026-02-12T08:59:21.607832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24170-3
  a curric:KeyLearningPoint ;
  rdfs:label """Coastal landforms, such as arches, are formed through erosional processes over millions of years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24170-4
  a curric:KeyLearningPoint ;
  rdfs:label "The sequence from a headland to a stump is: headland, cave, arch, stack, stump."@en ;
  dcterms:modified "2026-02-12T08:59:21.607848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24209-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indigenous peoples have been living in tropical rainforests for thousands of years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24209-2
  a curric:KeyLearningPoint ;
  rdfs:label """People use rainforests in a variety of ways including farming, mining, medicine and homes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24209-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation is rapidly reducing the size of rainforests to make way for human activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24209-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation has negative impacts: loss of carbon sinks, loss of habitats, soil erosion and the displacement of people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24346-1
  a curric:KeyLearningPoint ;
  rdfs:label "Floods occur when a river receives more water than the channel has capacity for."@en ;
  dcterms:modified "2026-02-12T08:59:21.613286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24346-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heavy and prolonged rainfall are the main physical causes of flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.613293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other physical causes of flooding are the shape and geology of the drainage basin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24346-4
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation and urbanisation are the main human causes of flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.613307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24401-1
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation reduces habitats and threatens species survival."@en ;
  dcterms:modified "2026-02-12T08:59:21.613753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24401-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pollution from agriculture and industry harms ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.613761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24401-3
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change alters ecosystems and species distributions."@en ;
  dcterms:modified "2026-02-12T08:59:21.613768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24401-4
  a curric:KeyLearningPoint ;
  rdfs:label "Invasive species introduced by humans disrupt native ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.613775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24401-5
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity loss reduces ecosystem resilience and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.613781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24211-1
  a curric:KeyLearningPoint ;
  rdfs:label """Temperate forests are distributed across Europe, Asia and North America, within the temperate climate zone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24211-2
  a curric:KeyLearningPoint ;
  rdfs:label "The temperate forests have an average annual temperature of 10 degrees Celsius."@en ;
  dcterms:modified "2026-02-12T08:59:21.615423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24211-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are four layers in a temperate deciduous forest; the canopy, sub-canopy, herb layer and the ground layer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24211-4
  a curric:KeyLearningPoint ;
  rdfs:label """The nutrient cycle means the soil in the temperate deciduous forest is nutrient rich."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24399-1
  a curric:KeyLearningPoint ;
  rdfs:label "Human activity affects Earth's physical systems."@en ;
  dcterms:modified "2026-02-12T08:59:21.615462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24399-2
  a curric:KeyLearningPoint ;
  rdfs:label """Population increase has significantly increased the human impact on Earth's physical systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24399-3
  a curric:KeyLearningPoint ;
  rdfs:label "Industrialisation significantly increased the human impact on Earth's systems."@en ;
  dcterms:modified "2026-02-12T08:59:21.615475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24399-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Anthropocene is a term used to describe a new geological age shaped by humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24399-5
  a curric:KeyLearningPoint ;
  rdfs:label "The term \"Anthropocene\" is debated by scientists."@en ;
  dcterms:modified "2026-02-12T08:59:21.615488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24205-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change is the long-term shift in temperatures and weather patterns."@en ;
  dcterms:modified "2026-02-12T08:59:21.615495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24205-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Earth's climate varies naturally and continuously over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.615501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24205-3
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change can involve both global warming and global cooling."@en ;
  dcterms:modified "2026-02-12T08:59:21.615507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24205-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence of climate change comes from analysing ice cores, tree rings and the instrumental record."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24223-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sundarbans are a mangrove forest found in north-east India and south-west Bangladesh in the Bay of Bengal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24223-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Sundarbans are known for their wide range of animals included the royal Bengal Tiger and the estuarine crocodile."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24223-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Sundarbans are one of the largest remaining areas of mangroves in the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.615604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24223-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Sundarbans face challenges such as climate change, overuse of resources, and conflict between people and wildlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24223-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are three wildlife sanctuaries in the Sundarbans to help conserve its unique and varied biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24240-1
  a curric:KeyLearningPoint ;
  rdfs:label "More than a quarter of the products manufactured globally are made in China."@en ;
  dcterms:modified "2026-02-12T08:59:21.615656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24240-2
  a curric:KeyLearningPoint ;
  rdfs:label """China manufactures a wide range of products such as electronics, clothing, toys and machinery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24240-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cheaper labour, good infrastructure and a large population are some of the reasons why so many things are made in China."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24240-4
  a curric:KeyLearningPoint ;
  rdfs:label "Manufacturing in China impacts people and the environment in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.615675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24384-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Arctic is an ocean surrounded by land."@en ;
  dcterms:modified "2026-02-12T08:59:21.616089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24384-2
  a curric:KeyLearningPoint ;
  rdfs:label "Around 4 million people live within the Arctic circle."@en ;
  dcterms:modified "2026-02-12T08:59:21.616096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24384-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Arctic region has many natural resources including oil, uranium, minerals and fish."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24384-4
  a curric:KeyLearningPoint ;
  rdfs:label "Countries around the Arctic circle claim they have rights to some resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.616109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24213-1
  a curric:KeyLearningPoint ;
  rdfs:label "The boreal forest is the world's largest land-based biome."@en ;
  dcterms:modified "2026-02-12T08:59:21.616184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24213-2
  a curric:KeyLearningPoint ;
  rdfs:label "The boreal forest is also known as the taiga; they are found at high latitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.616194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24213-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is little rainfall in the boreal biome due to the high latitudes and temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24213-4
  a curric:KeyLearningPoint ;
  rdfs:label """Boreal forests contain many coniferous trees which are normally evergreen and so don’t drop their leaves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most plastic is made from fossil fuels and is not biodegradable."@en ;
  dcterms:modified "2026-02-12T08:59:21.616409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic production has grown rapidly since the 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.616415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic waste pollutes land, rivers, and oceans."@en ;
  dcterms:modified "2026-02-12T08:59:21.616422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Microplastics enter food chains and may harm human health."@en ;
  dcterms:modified "2026-02-12T08:59:21.616428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24403-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wildlife can be injured or killed by plastic waste."@en ;
  dcterms:modified "2026-02-12T08:59:21.616438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24402-1
  a curric:KeyLearningPoint ;
  rdfs:label "High levels of consumption increase demand for natural resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.616580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24402-2
  a curric:KeyLearningPoint ;
  rdfs:label "Global trade increases the environmental footprint of consumption."@en ;
  dcterms:modified "2026-02-12T08:59:21.616587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24402-3
  a curric:KeyLearningPoint ;
  rdfs:label "Richer countries consume more per person than poorer countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.616593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24402-4
  a curric:KeyLearningPoint ;
  rdfs:label "Waste from overconsumption contributes to pollution and emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.616599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24402-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fast fashion and electronics create growing environmental problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.616606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24241-1
  a curric:KeyLearningPoint ;
  rdfs:label """China has the second largest economy in the world; it was worth US$17.8 trillion in 2023."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24241-2
  a curric:KeyLearningPoint ;
  rdfs:label """Global superpower is used to describe a country that has a lot of power or influence over other countries in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24241-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different indicators can be used to measure how China has changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.617668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24241-4
  a curric:KeyLearningPoint ;
  rdfs:label """China’s political system affects some of the rights and freedom that Chinese people have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24375-1
  a curric:KeyLearningPoint ;
  rdfs:label """Earth has experienced periods of global warming and global cooling throughout its history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24375-2
  a curric:KeyLearningPoint ;
  rdfs:label "The last ice age ended around 19 000 years ago."@en ;
  dcterms:modified "2026-02-12T08:59:21.618730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24375-3
  a curric:KeyLearningPoint ;
  rdfs:label """The north of the UK and part of Ireland were covered in the British-Irish ice sheet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24260-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK trades goods and products with countries around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.618961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24260-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UK imports food, products and other goods that it does not produce itself."@en ;
  dcterms:modified "2026-02-12T08:59:21.618967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24260-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK exports goods and manufactured products produced here to other countries that want to buy them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24257-1
  a curric:KeyLearningPoint ;
  rdfs:label "Supermarkets are the main way that people shop for food."@en ;
  dcterms:modified "2026-02-12T08:59:21.619309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24257-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many supermarkets in the UK are global companies and operate in different countries around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Supermarkets sell many different goods and food items which all have their own complex supply chains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24349-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hard engineering is the building of fixed structures to help prevent river flooding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24349-2
  a curric:KeyLearningPoint ;
  rdfs:label "Soft engineering is working with nature to reduce the risk of river flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.620715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24349-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are economical and environmental costs and benefits to different types of flood management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24349-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flood management in one part of the river will have an effect on other parts of the river downstream."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24348-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different groups of people make use of flood risk maps."@en ;
  dcterms:modified "2026-02-12T08:59:21.620736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24348-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Environment Agency collects data to monitor flood risk."@en ;
  dcterms:modified "2026-02-12T08:59:21.620742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24348-3
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to visualise flood risk in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.620751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24348-4
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to analyse the impacts of flood risk in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.620757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24406-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fossil fuels release large amounts of carbon dioxide when burned."@en ;
  dcterms:modified "2026-02-12T08:59:21.620882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24406-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossil fuels are non-renewable and contribute to climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.620888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24406-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries rely heavily on fossil fuels for energy and income."@en ;
  dcterms:modified "2026-02-12T08:59:21.620897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24406-4
  a curric:KeyLearningPoint ;
  rdfs:label "Moving away from fossil fuels requires investment and new technology."@en ;
  dcterms:modified "2026-02-12T08:59:21.620903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24406-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is disagreement about how quickly fossil fuels should be phased out."@en ;
  dcterms:modified "2026-02-12T08:59:21.620909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Roughly one-third of all food produced globally is wasted every year, even as nearly 800 million people go hungry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24357-2
  a curric:KeyLearningPoint ;
  rdfs:label "Generally people in countries with a higher GDP per capita buy more food."@en ;
  dcterms:modified "2026-02-12T08:59:21.621173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food security is the ability of people to access sufficient, safe, and nutritious food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24357-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poverty, conflict, natural disasters and soil quality affect food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.621185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Undernourishment occurs when someone isn’t receiving enough calories or essential nutrients to grow and function well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24156-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are seven continents and five oceans around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.621543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each continent has different characteristics in terms of size, population and physical features."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24156-3
  a curric:KeyLearningPoint ;
  rdfs:label "The UK is in the continent of Europe, which has 44 countries in total."@en ;
  dcterms:modified "2026-02-12T08:59:21.621560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24156-4
  a curric:KeyLearningPoint ;
  rdfs:label "Locations can be described using the acronym CLOCC."@en ;
  dcterms:modified "2026-02-12T08:59:21.621566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24350-1
  a curric:KeyLearningPoint ;
  rdfs:label "People have a variety of opinions on river management."@en ;
  dcterms:modified "2026-02-12T08:59:21.621823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24350-2
  a curric:KeyLearningPoint ;
  rdfs:label "Building flood protection can increase flood risk downstream."@en ;
  dcterms:modified "2026-02-12T08:59:21.621829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Areas of high economic value are more likely to receive funding for flood protection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24350-4
  a curric:KeyLearningPoint ;
  rdfs:label "Slow the flow techniques are increasingly used to prevent flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.621840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24268-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three types of rock; igneous, sedimentary and metamorphic."@en ;
  dcterms:modified "2026-02-12T08:59:21.621977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24268-2
  a curric:KeyLearningPoint ;
  rdfs:label """Igneous rocks are volcanic rocks and examples include basalt, obsidian and granite."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24268-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentary rocks are formed from sediments and examples include sandstone, limestone and chalk."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24268-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metamorphic rocks are formed through heat and pressure and examples include slate, gneiss and marble."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24337-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria exports and imports a wide range of goods."@en ;
  dcterms:modified "2026-02-12T08:59:21.622000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24337-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Nigerian diaspora is large and global."@en ;
  dcterms:modified "2026-02-12T08:59:21.622006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24337-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nigeria is a member of the UN and African Union and plays an important role in African and global affairs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24337-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nigeria is a lower-middle income country and receives foreign aid for health, education and infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24337-5
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria is undergoing economic, environmental, political and societal changes."@en ;
  dcterms:modified "2026-02-12T08:59:21.622061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24341-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of erosion: abrasion, hydraulic action, attrition and solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24341-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of transportation: traction, solution, suspension and saltation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deposition occurs when the river has lost its energy and can no longer carry its load."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24270-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has a rich and varied geology with igneous, metamorphic and sedimentary rocks present."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24270-2
  a curric:KeyLearningPoint ;
  rdfs:label "England's lowland geology is dominated by sedimentary rocks, such as limestone."@en ;
  dcterms:modified "2026-02-12T08:59:21.622220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24270-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scotland's geology is dominated by metamorphic rocks with areas of igenous rock."@en ;
  dcterms:modified "2026-02-12T08:59:21.622226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24270-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the past, Britain was close to a plate boundary, and there was volcanic activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24176-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tuvalu is an island nation in the Pacific Ocean with 9 main islands including some atolls."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24176-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the islands are made from coral, seawater bubbles up through the coral causing flooding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24176-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many Tuvaluans rely on subsistence farming, the saltwater is poisoning the soil."@en ;
  dcterms:modified "2026-02-12T08:59:21.622380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24176-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tuvalu experiences drought and water scarcity due to lack of natural freshwater."@en ;
  dcterms:modified "2026-02-12T08:59:21.622386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24274-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soil is made up of minerals, dead plants and animals, water and living organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24274-2
  a curric:KeyLearningPoint ;
  rdfs:label "Soil takes hundreds of years to form."@en ;
  dcterms:modified "2026-02-12T08:59:21.622429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24274-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are three main particle sizes in soil, clay, sand and silt."@en ;
  dcterms:modified "2026-02-12T08:59:21.622435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24274-4
  a curric:KeyLearningPoint ;
  rdfs:label """Soil is important for farming; infertile soil can make growing crops very difficult."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24274-5
  a curric:KeyLearningPoint ;
  rdfs:label """Soil is an important carbon store and protecting it can help us reduce global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24258-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different drivers for globalisation and these include transport and commnications."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24258-2
  a curric:KeyLearningPoint ;
  rdfs:label """Other drivers for globalisation include economic activity, trade of goods, supply and demand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24258-3
  a curric:KeyLearningPoint ;
  rdfs:label "Political factors and changes in technology also drive globalisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.622516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24361-1
  a curric:KeyLearningPoint ;
  rdfs:label """More greenhouse gases means more insulation of the planet, causing global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24361-2
  a curric:KeyLearningPoint ;
  rdfs:label "Human energy and food consumption can worsen global warming."@en ;
  dcterms:modified "2026-02-12T08:59:21.623292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24361-3
  a curric:KeyLearningPoint ;
  rdfs:label """Individual consumer choices, innovative farming practices and government policies can reduce global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24361-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK committed to reduce greenhouse gas emissions by 81% by 2035, compared to 1990 levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24367-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oil and gas drive many economies in the Middle East region."@en ;
  dcterms:modified "2026-02-12T08:59:21.623548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24367-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries are diversifying beyond oil."@en ;
  dcterms:modified "2026-02-12T08:59:21.623554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24367-3
  a curric:KeyLearningPoint ;
  rdfs:label "Natural resources shape trade and wealth."@en ;
  dcterms:modified "2026-02-12T08:59:21.623559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24367-4
  a curric:KeyLearningPoint ;
  rdfs:label "Unequal resource distribution causes tensions."@en ;
  dcterms:modified "2026-02-12T08:59:21.623564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24392-1
  a curric:KeyLearningPoint ;
  rdfs:label """Russia has the ninth largest population in the world and more people live in the west than the east."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24392-2
  a curric:KeyLearningPoint ;
  rdfs:label "Population densities vary and reasons include climate and infrastructure."@en ;
  dcterms:modified "2026-02-12T08:59:21.623764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24392-3
  a curric:KeyLearningPoint ;
  rdfs:label """Since 1990, birth rates have been declining and Russia's total population has started to fall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Russia’s population is ageing with increasing numbers of people aged 65+ due to improvements in life expectancy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24392-5
  a curric:KeyLearningPoint ;
  rdfs:label """Migration within Russia is significant, with urban populations growing while rural populations are declining."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24389-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climate of a place is influenced by three factors: latitude, altitude and distance from the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Russia has a generally continental climate with cold winters and warm summers."@en ;
  dcterms:modified "2026-02-12T08:59:21.624255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24389-3
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing climate between places, the factors need to be considered together as they interrelate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24389-4
  a curric:KeyLearningPoint ;
  rdfs:label """Russia’s temperature pattern shows the impact of latitude and altitude and distance from the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24389-5
  a curric:KeyLearningPoint ;
  rdfs:label """Russia’s precipitation pattern reflects its distance from the sea: interior regions receive less than coastal areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24383-1
  a curric:KeyLearningPoint ;
  rdfs:label "Antarctica is protected by the Antarctic Treaty."@en ;
  dcterms:modified "2026-02-12T08:59:21.624706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24383-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Antarctic Treaty prevents mining, drilling and nuclear testing."@en ;
  dcterms:modified "2026-02-12T08:59:21.624714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24383-3
  a curric:KeyLearningPoint ;
  rdfs:label "Antarctica is part of the global commons."@en ;
  dcterms:modified "2026-02-12T08:59:21.624720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24163-1
  a curric:KeyLearningPoint ;
  rdfs:label """The representation of Earth on a globe shows landmasses in the correct shape and relative size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24163-2
  a curric:KeyLearningPoint ;
  rdfs:label """World maps project the spherical world (three dimensions) on to a flat surface (two dimensions)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24163-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some projections distort shape, others distort latitude and/or longitude."@en ;
  dcterms:modified "2026-02-12T08:59:21.625173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24356-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using specialist fishing equipment can reduce bycatch."@en ;
  dcterms:modified "2026-02-12T08:59:21.625178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eating fish from well-managed fisheries helps prevent overfishing and protects marine biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exclusive economic zones, quotas and seasonal closures improve fishing sustainability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24356-4
  a curric:KeyLearningPoint ;
  rdfs:label """Historically there have been many tensions surrounding British fishing, ultimately leading to more sustainable law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24382-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food webs display the transfers of energy within one location."@en ;
  dcterms:modified "2026-02-12T08:59:21.625200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24382-2
  a curric:KeyLearningPoint ;
  rdfs:label """Antarctic food webs contain phytoplankton (producers), krill and squid (consumers) and leopard seals (apex predators)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24382-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes to food webs arising from overfishing can affect different species."@en ;
  dcterms:modified "2026-02-12T08:59:21.625211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24382-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Ross Sea Marine Park Area has been established to help protect young fish."@en ;
  dcterms:modified "2026-02-12T08:59:21.625216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24381-1
  a curric:KeyLearningPoint ;
  rdfs:label "Antarctica is a continent at the southern most point of the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.625251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24381-2
  a curric:KeyLearningPoint ;
  rdfs:label "91% of all glaciers are found in Antarctica."@en ;
  dcterms:modified "2026-02-12T08:59:21.625257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24381-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists across the world work in Antarctica, but no-one lives there permanently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24396-1
  a curric:KeyLearningPoint ;
  rdfs:label """Russia is an energy superpower. It is in the world’s top five producers for all three fossil fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24396-2
  a curric:KeyLearningPoint ;
  rdfs:label """Russia produces more fossil fuels than it needs so it exports them to other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24396-3
  a curric:KeyLearningPoint ;
  rdfs:label "The exports of fossil fuels bring opportunities and challenges for Russia."@en ;
  dcterms:modified "2026-02-12T08:59:21.625278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24396-4
  a curric:KeyLearningPoint ;
  rdfs:label "Renewable energy use in Russia is limited in comparison to much of the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.625284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24396-5
  a curric:KeyLearningPoint ;
  rdfs:label """Russia possesses significant renewable energy potential, including wind, geothermal, hydro and solar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24408-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change is a global issue that requires international cooperation."@en ;
  dcterms:modified "2026-02-12T08:59:21.625584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24408-2
  a curric:KeyLearningPoint ;
  rdfs:label "Agreements like the Paris Accord aim to reduce global emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.625589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24408-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries pollute more and have greater responsibility to act."@en ;
  dcterms:modified "2026-02-12T08:59:21.625594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24408-4
  a curric:KeyLearningPoint ;
  rdfs:label "Not all countries agree on climate targets or financial commitments."@en ;
  dcterms:modified "2026-02-12T08:59:21.625599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24408-5
  a curric:KeyLearningPoint ;
  rdfs:label "NGOs and citizens can influence climate action at different levels."@en ;
  dcterms:modified "2026-02-12T08:59:21.625604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24410-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sustainability means meeting today's needs without harming future generations."@en ;
  dcterms:modified "2026-02-12T08:59:21.625861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24410-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reducing waste and reusing materials helps conserve resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.625866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24410-3
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing local and seasonal food reduces environmental footprints."@en ;
  dcterms:modified "2026-02-12T08:59:21.625872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24410-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sustainable transport reduces carbon emissions and pollution."@en ;
  dcterms:modified "2026-02-12T08:59:21.625877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24410-5
  a curric:KeyLearningPoint ;
  rdfs:label "Individuals, communities and governments all play a role in sustainability."@en ;
  dcterms:modified "2026-02-12T08:59:21.625882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24338-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lagos is threatened by flooding and sea level rise."@en ;
  dcterms:modified "2026-02-12T08:59:21.625931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24338-2
  a curric:KeyLearningPoint ;
  rdfs:label "The north of Nigeria faces desertification due to drought."@en ;
  dcterms:modified "2026-02-12T08:59:21.625936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24338-3
  a curric:KeyLearningPoint ;
  rdfs:label "Farmers face changing rainfall and lower crop yields."@en ;
  dcterms:modified "2026-02-12T08:59:21.625944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24338-4
  a curric:KeyLearningPoint ;
  rdfs:label """Climate justice is about understanding that some people and countries are impacted by climate change more than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24338-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate justice advocates for global action to support countries, such as Nigeria, to adapt to climate change impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24218-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable management of the forests is vital for the health of Earth and for future generations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24218-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reforestation and afforestation schemes help absorb carbon dioxide and improve biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24218-3
  a curric:KeyLearningPoint ;
  rdfs:label "Agroforestry can help people farm more sustainably and reduce forest clearance."@en ;
  dcterms:modified "2026-02-12T08:59:21.626475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24218-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stronger laws and the use of technology help to combat deforestation and illegal logging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24219-1
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to visualise the human and physical geography of India."@en ;
  dcterms:modified "2026-02-12T08:59:21.626614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24219-2
  a curric:KeyLearningPoint ;
  rdfs:label "India is located just north of the Equator in southern Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.626619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24219-3
  a curric:KeyLearningPoint ;
  rdfs:label """India is similar in size to Greenland although looks much smaller on some projections of the world map."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24219-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data on a GIS show that the population of India is very high."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24219-5
  a curric:KeyLearningPoint ;
  rdfs:label "Visualising the landscape using GIS shows that India is a very diverse country."@en ;
  dcterms:modified "2026-02-12T08:59:21.626634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24372-1
  a curric:KeyLearningPoint ;
  rdfs:label "The desert has extreme heat and little rainfall."@en ;
  dcterms:modified "2026-02-12T08:59:21.629426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24372-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Bedouin live nomadic lifestyles, using camels for transport and relying on oases for water and farming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24372-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants and animals have adptations that help them survive in the desert."@en ;
  dcterms:modified "2026-02-12T08:59:21.629454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24372-4
  a curric:KeyLearningPoint ;
  rdfs:label """Camels store fat in their humps, fennec foxes have large ears to release heat, and oryx get moisture from plants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24372-5
  a curric:KeyLearningPoint ;
  rdfs:label """Date palms have deep roots, cacti store water in thick stems, and acacia trees have small leaves to reduce water loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Life in the DRC varies greatly between rural villages and urban areas like Kinshasa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24324-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rural life relies on subsistence farming and small-scale trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.629597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24324-3
  a curric:KeyLearningPoint ;
  rdfs:label """Urban life includes a wide range of jobs, from informal market vendors to high-income professionals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24324-4
  a curric:KeyLearningPoint ;
  rdfs:label """High-income careers exist in areas such as banking and the oil and mining industries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24297-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inequality in wealth between countries can lead to migration."@en ;
  dcterms:modified "2026-02-12T08:59:21.629661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24297-2
  a curric:KeyLearningPoint ;
  rdfs:label """On average, people are more likely to move from lower-income countries to higher-income countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24297-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inequality in safety between countries can lead to migration."@en ;
  dcterms:modified "2026-02-12T08:59:21.629670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24297-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refugees often have to flee quickly and they are likely to go to a bordering country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24297-5
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to people's experiences of migration helps us understand the variety of reasons people move."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24373-1
  a curric:KeyLearningPoint ;
  rdfs:label "Desertification is a major challenge in the region."@en ;
  dcterms:modified "2026-02-12T08:59:21.629904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24373-2
  a curric:KeyLearningPoint ;
  rdfs:label "Desalination provides water for farming."@en ;
  dcterms:modified "2026-02-12T08:59:21.629909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24373-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tree planting projects aim to combat desert spread."@en ;
  dcterms:modified "2026-02-12T08:59:21.629914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24373-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vertical farming is used to grow food sustainably."@en ;
  dcterms:modified "2026-02-12T08:59:21.629921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24318-1
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC's physical geography includes mountains, lakes, rivers, and the Congo Basin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24318-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Congo River is the second longest river in Africa and is important for transport and hydroelectric power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24318-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Rift Valley runs through the eastern DRC, forming mountains and volcanoes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24318-4
  a curric:KeyLearningPoint ;
  rdfs:label "Natural landscapes affect where people live and how they use resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.630090Z"^^xsd:dateTime .

