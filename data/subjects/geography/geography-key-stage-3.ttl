  a curric:KeyLearningPoint ;
  rdfs:label "Physical geography is the study of the Earth's natural features and processes."@en ;
  dcterms:modified "2026-02-12T08:59:21.694915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24155-3
  a curric:KeyLearningPoint ;
