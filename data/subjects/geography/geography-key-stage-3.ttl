# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-empire
  a curric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oakcurric:keyword-quality-of-life
  a curric:Keyword ;
  schema:name "quality of life"@en ;
  schema:description """a measure of people’s wellbeing, including access to housing, healthcare, education, income and services"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789667Z"^^xsd:dateTime .

oakcurric:keyword-population-density
  a curric:Keyword ;
  schema:name "population density"@en ;
  schema:description "the number of people living per square kilometre (km²)"@en ;
  dcterms:modified "2026-02-12T08:59:15.789671Z"^^xsd:dateTime .

oakcurric:keyword-climate
  a curric:Keyword ;
  schema:name "climate"@en ;
  schema:description """the average weather conditions (such as rainfall and temperature) recorded over a 30-year period"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789680Z"^^xsd:dateTime .

oakcurric:keyword-altitude
  a curric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "the height above sea level"@en ;
  dcterms:modified "2026-02-12T08:59:15.789684Z"^^xsd:dateTime .

oakcurric:keyword-biome
  a curric:Keyword ;
  schema:name "biome"@en ;
  schema:description "a large-scale global ecosystem, for example, a tropical rainforest"@en ;
  dcterms:modified "2026-02-12T08:59:15.789699Z"^^xsd:dateTime .

oakcurric:keyword-distribution
  a curric:Keyword ;
  schema:name "distribution"@en ;
  schema:description """the spread (which may have a regular pattern) of, for example, a type of vegetation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789704Z"^^xsd:dateTime .

oakcurric:keyword-latitude
  a curric:Keyword ;
  schema:name "latitude"@en ;
  schema:description """distance from the Equator north or south. Lines of latitude run east-west on a map, e.g., the Tropic of Cancer"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789708Z"^^xsd:dateTime .

oakcurric:keyword-megacity
  a curric:Keyword ;
  schema:name "megacity"@en ;
  schema:description "a city with a population of over 10 million people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789713Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-natural-increase
  a curric:Keyword ;
  schema:name "natural increase"@en ;
  schema:description """the difference between the birth rate and the death rate of a population; occurs when the birth rate is higher than the death rate"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789724Z"^^xsd:dateTime .

oakcurric:keyword-globalisation
  a curric:Keyword ;
  schema:name "globalisation"@en ;
  schema:description """the increased interconnectedness of the world, economically, politically and culturally"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789740Z"^^xsd:dateTime .

oakcurric:keyword-erratic
  a curric:Keyword ;
  schema:name "erratic"@en ;
  schema:description "irregular or lacking consistency"@en ;
  dcterms:modified "2026-02-12T08:59:15.789768Z"^^xsd:dateTime .

oakcurric:keyword-enquiry
  a curric:Keyword ;
  schema:name "enquiry"@en ;
  schema:description """a way of learning new information about a place by following a set course of activities or tasks"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789900Z"^^xsd:dateTime .

oakcurric:keyword-hypothesis
  a curric:Keyword ;
  schema:name "hypothesis"@en ;
  schema:description "a prediction taken at the start of the enquiry that can then be tested"@en ;
  dcterms:modified "2026-02-12T08:59:15.789905Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oakcurric:keyword-prediction
  a curric:Keyword ;
  schema:name "prediction"@en ;
  schema:description "making a guess using what we already know"@en ;
  dcterms:modified "2026-02-12T08:59:15.790024Z"^^xsd:dateTime .

oakcurric:keyword-transatlantic-slave-trade
  a curric:Keyword ;
  schema:name "Transatlantic Slave Trade"@en ;
  schema:description """the trade between Europe, West Africa and the Americas, where goods were exchanged for enslaved people who were sold onto plantations in European colonies"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790230Z"^^xsd:dateTime .

oakcurric:keyword-interconnected
  a curric:Keyword ;
  schema:name "interconnected"@en ;
  schema:description "different parts or things being linked or related"@en ;
  dcterms:modified "2026-02-12T08:59:15.790252Z"^^xsd:dateTime .

oakcurric:keyword-regeneration
  a curric:Keyword ;
  schema:name "regeneration"@en ;
  schema:description """investing money into poorer and derelict urban areas where there was once a sustainable economy in industry"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790305Z"^^xsd:dateTime .

oakcurric:keyword-erosion
  a curric:Keyword ;
  schema:name "erosion"@en ;
  schema:description "the wearing away of rocks along the coastline"@en ;
  dcterms:modified "2026-02-12T08:59:15.790389Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "long-term shifts in temperatures and weather patterns"@en ;
  dcterms:modified "2026-02-12T08:59:15.790394Z"^^xsd:dateTime .

oakcurric:keyword-anomaly
  a curric:Keyword ;
  schema:name "anomaly"@en ;
  schema:description "a piece of data that sits outside the general trend and cannot be explained"@en ;
  dcterms:modified "2026-02-12T08:59:15.790956Z"^^xsd:dateTime .

oakcurric:keyword-commercial
  a curric:Keyword ;
  schema:name "commercial"@en ;
  schema:description "a land use category used for areas that trade goods and services"@en ;
  dcterms:modified "2026-02-12T08:59:15.790973Z"^^xsd:dateTime .

oakcurric:keyword-stakeholder
  a curric:Keyword ;
  schema:name "stakeholder"@en ;
  schema:description "a person with a particular interest in the issue being investigated"@en ;
  dcterms:modified "2026-02-12T08:59:15.790993Z"^^xsd:dateTime .

oakcurric:keyword-primary-data
  a curric:Keyword ;
  schema:name "primary data"@en ;
  schema:description "data that is collected in person during fieldwork"@en ;
  dcterms:modified "2026-02-12T08:59:15.791004Z"^^xsd:dateTime .

oakcurric:keyword-secondary-data
  a curric:Keyword ;
  schema:name "secondary data"@en ;
  schema:description """data that has previously been collected by someone, usually unknown to the person doing the fieldwork"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791008Z"^^xsd:dateTime .

oakcurric:keyword-analysis
  a curric:Keyword ;
  schema:name "analysis"@en ;
  schema:description """to unpick and examine a text in detail, considering a writer’s choice of language and intention"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791021Z"^^xsd:dateTime .

oakcurric:keyword-informal-employment
  a curric:Keyword ;
  schema:name "informal employment"@en ;
  schema:description "employment that lacks official recognition and has no regulation"@en ;
  dcterms:modified "2026-02-12T08:59:15.791124Z"^^xsd:dateTime .

oakcurric:keyword-tnc
  a curric:Keyword ;
  schema:name "TNC"@en ;
  schema:description "transnational corporation. A company that operates in more than one country"@en ;
  dcterms:modified "2026-02-12T08:59:15.791149Z"^^xsd:dateTime .

oakcurric:keyword-hard-engineering
  a curric:Keyword ;
  schema:name "hard engineering"@en ;
  schema:description "using artificial structures to protect coastlines from erosion and flooding"@en ;
  dcterms:modified "2026-02-12T08:59:15.791184Z"^^xsd:dateTime .

oakcurric:keyword-soft-engineering
  a curric:Keyword ;
  schema:name "soft engineering"@en ;
  schema:description """making use of natural processes to reduce erosion and flooding  in a way that minimies environmental impact"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791188Z"^^xsd:dateTime .

oakcurric:keyword-economy
  a curric:Keyword ;
  schema:name "economy"@en ;
  schema:description "the economy is the way money in a particular area is made and spent"@en ;
  dcterms:modified "2026-02-12T08:59:15.791201Z"^^xsd:dateTime .

oakcurric:keyword-inequality
  a curric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "inequality is when something is not shared evenly between everyone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791205Z"^^xsd:dateTime .

oakcurric:keyword-development
  a curric:Keyword ;
  schema:name "development"@en ;
  schema:description "development is when something changes, usually an improvement"@en ;
  dcterms:modified "2026-02-12T08:59:15.791209Z"^^xsd:dateTime .

oakcurric:keyword-corruption
  a curric:Keyword ;
  schema:name "corruption"@en ;
  schema:description "dishonest behaviour by people in a position of power for personal gain"@en ;
  dcterms:modified "2026-02-12T08:59:15.791213Z"^^xsd:dateTime .

oakcurric:keyword-legacy
  a curric:Keyword ;
  schema:name "legacy"@en ;
  schema:description """Legacy is the long-lasting impact of particular events and actions that took place in the past, or in a person’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:15.791222Z"^^xsd:dateTime .

oakcurric:keyword-social-effect
  a curric:Keyword ;
  schema:name "social effect"@en ;
  schema:description "an effect on people or communities"@en ;
  dcterms:modified "2026-02-12T08:59:15.791258Z"^^xsd:dateTime .

oakcurric:keyword-environmental-effect
  a curric:Keyword ;
  schema:name "environmental effect"@en ;
  schema:description "an effect on the environment"@en ;
  dcterms:modified "2026-02-12T08:59:15.791262Z"^^xsd:dateTime .

oakcurric:keyword-economic-effect
  a curric:Keyword ;
  schema:name "economic effect"@en ;
  schema:description "an effect on money or business"@en ;
  dcterms:modified "2026-02-12T08:59:15.791266Z"^^xsd:dateTime .

oakcurric:keyword-short-term-effects
  a curric:Keyword ;
  schema:name "short-term effects"@en ;
  schema:description "effects during and immediately after an event"@en ;
  dcterms:modified "2026-02-12T08:59:15.791270Z"^^xsd:dateTime .

oakcurric:keyword-long-term-effects
  a curric:Keyword ;
  schema:name "long-term effects"@en ;
  schema:description "effects that may last for a long time"@en ;
  dcterms:modified "2026-02-12T08:59:15.791274Z"^^xsd:dateTime .

oakcurric:keyword-non-renewable-energy
  a curric:Keyword ;
  schema:name "non-renewable energy"@en ;
  schema:description """a natural source of energy that will run out because it cannot be reproduced, such as coal, oil and natural gas"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791281Z"^^xsd:dateTime .

oakcurric:keyword-renewable-energy
  a curric:Keyword ;
  schema:name "renewable energy"@en ;
  schema:description """a natural source of energy that will never run out, such as flows of wind, water and solar energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791287Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description "able to continue over a long time"@en ;
  dcterms:modified "2026-02-12T08:59:15.791311Z"^^xsd:dateTime .

oakcurric:keyword-exploit
  a curric:Keyword ;
  schema:name "exploit"@en ;
  schema:description "to use something for personal benefit"@en ;
  dcterms:modified "2026-02-12T08:59:15.791315Z"^^xsd:dateTime .

oakcurric:keyword-depleted
  a curric:Keyword ;
  schema:name "depleted"@en ;
  schema:description "used up or nearly all gone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791321Z"^^xsd:dateTime .

oakcurric:keyword-habitat
  a curric:Keyword ;
  schema:name "habitat"@en ;
  schema:description "the natural home or environment of an animal, plant or other organism"@en ;
  dcterms:modified "2026-02-12T08:59:15.791326Z"^^xsd:dateTime .

oakcurric:keyword-conservation
  a curric:Keyword ;
  schema:name "conservation"@en ;
  schema:description """energy conservation involves changing people's behaviour in ways that mean they use less energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791334Z"^^xsd:dateTime .

oakcurric:keyword-antarctic-treaty
  a curric:Keyword ;
  schema:name "Antarctic Treaty"@en ;
  schema:description """The Antarctic Treaty is a set of rules signed by 54 countries to protect Antarctica"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791343Z"^^xsd:dateTime .

oakcurric:keyword-tourism
  a curric:Keyword ;
  schema:name "tourism"@en ;
  schema:description """Tourism means people travelling to a different place from where they live for a holiday"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791349Z"^^xsd:dateTime .

oakcurric:keyword-energy-mix
  a curric:Keyword ;
  schema:name "energy mix"@en ;
  schema:description """the combination of different energy sources used by a country or a region. The energy mix can change over time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791358Z"^^xsd:dateTime .

oakcurric:keyword-carbon-footprint
  a curric:Keyword ;
  schema:name "carbon footprint"@en ;
