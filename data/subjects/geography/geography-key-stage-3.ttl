  dcterms:modified "2026-02-12T08:59:21.688061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24340-4
  a curric:KeyLearningPoint ;
  rdfs:label """Precipitation that falls in the drainage basin moves to the river through a series of stores and flows."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24340-5
  a curric:KeyLearningPoint ;
  rdfs:label "A drainage basin is an example of an open system."@en ;
  dcterms:modified "2026-02-12T08:59:21.688072Z"^^xsd:dateTime .

