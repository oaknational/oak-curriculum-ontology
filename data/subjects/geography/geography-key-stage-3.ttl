  dcterms:modified "2026-02-12T08:59:21.630470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24278-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fossil fuels and minerals support economies through jobs and exports."@en ;
  dcterms:modified "2026-02-12T08:59:21.630474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24301-1
  a curric:KeyLearningPoint ;
  rdfs:label "Strategies to support development can be top-down or bottom-up"@en ;
  dcterms:modified "2026-02-12T08:59:21.630500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24301-2
  a curric:KeyLearningPoint ;
  rdfs:label """Investment, aid, debt relief and fairtrade are all strategies to reduce the development gap"""@en ;
  dcterms:modified "2026-02-12T08:59:21.630505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24301-3
  a curric:KeyLearningPoint ;
  rdfs:label "All strategies to reduce the development gap have strengths and weaknesses."@en ;
  dcterms:modified "2026-02-12T08:59:21.630510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Digital maps and GIS help us visualise inequality globally and within the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.630857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Digital maps help us analyse economic and social inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.630862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24293-3
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to analyse deprivation across a transect in a city."@en ;
  dcterms:modified "2026-02-12T08:59:21.630867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24295-1
  a curric:KeyLearningPoint ;
  rdfs:label "Physical geography can help or hinder development."@en ;
  dcterms:modified "2026-02-12T08:59:21.635954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24295-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relief, natural resources, natural hazards, climate and location may all be barriers to development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24295-3
  a curric:KeyLearningPoint ;
  rdfs:label "Countries can overcome physical barriers to development in a variety of ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.635963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24295-4
  a curric:KeyLearningPoint ;
  rdfs:label """HICs are often more able to overcome physical barriers than LICs due to having more financial resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24292-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different ways of measuring development."@en ;
  dcterms:modified "2026-02-12T08:59:21.637451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Economic indicators of development, such as GDP per capita, are a common way of comparing countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24292-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composite indicators of development, such as the HDI,are often seen as a more rounded way of measuring development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24292-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indicators that measure happiness and ecological footprints are important as they go beyond simply measuring wealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24188-1
  a curric:KeyLearningPoint ;
  rdfs:label "Migration makes our population more diverse."@en ;
  dcterms:modified "2026-02-12T08:59:21.645968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diversity within the UK has led to changes in local communities and culture."@en ;
  dcterms:modified "2026-02-12T08:59:21.645973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24188-3
  a curric:KeyLearningPoint ;
  rdfs:label "Local areas can change over time as a result  of changes in population."@en ;
  dcterms:modified "2026-02-12T08:59:21.645978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24291-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality is the uneven distribution of resources, opportunities, and living conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24291-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality can be categorised as economic, social, political, digital and environmental."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24291-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inequality can vary over geographical space and between different groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.647504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24291-4
  a curric:KeyLearningPoint ;
  rdfs:label """Development refers to the improvement in people's quality of life within a country or region."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24291-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of different perspectives on development."@en ;
  dcterms:modified "2026-02-12T08:59:21.647514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24294-1
  a curric:KeyLearningPoint ;
  rdfs:label "Overall the world has become wealthier over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.648190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24294-2
  a curric:KeyLearningPoint ;
  rdfs:label """GDP per capita has risen in many countries, but in some countries it has remained the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24294-3
  a curric:KeyLearningPoint ;
  rdfs:label """Statistics suggest that health and education has improved in most places around the world over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24294-4
  a curric:KeyLearningPoint ;
  rdfs:label "Despite increasing wealth, inequality has also grown in many countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.648205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24255-1
  a curric:KeyLearningPoint ;
  rdfs:label "Globalisation is the way in which the world has become more interconnected."@en ;
  dcterms:modified "2026-02-12T08:59:21.648527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24255-2
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation is not a new concept. Colonisation and exploration both led to the sharing of ideas and cultures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24255-3
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation can lead to a diverse society where there is a wide variety of people, religions and different cultures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24261-1
  a curric:KeyLearningPoint ;
  rdfs:label "Container ships transport products across the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.648629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24261-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many container ships take products from eastern China to western Europe through a series of 'choke points'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24261-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Suez Canal is an important route for global trade from Asia to Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.648641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24261-4
  a curric:KeyLearningPoint ;
  rdfs:label "In 2021 the Ever Given became stuck in the Suez Canal, delaying global trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.648646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24351-1
  a curric:KeyLearningPoint ;
  rdfs:label """Natural resources are materials or substances that occur naturally in the environment and can be used by humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24351-2
  a curric:KeyLearningPoint ;
  rdfs:label "We rely on natural resources for food, building and income."@en ;
  dcterms:modified "2026-02-12T08:59:21.649042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24351-3
  a curric:KeyLearningPoint ;
  rdfs:label "Natural resources are distributed unevenly around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.649079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24351-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many countries lack certain natural resources and have to import them."@en ;
  dcterms:modified "2026-02-12T08:59:21.649084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24351-5
  a curric:KeyLearningPoint ;
  rdfs:label """The natural resource trap can mean a wealth of resources negatively affects a country's development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29057-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the UK’s geology is important, especially for building, mining and managing our energy and water supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29057-2
  a curric:KeyLearningPoint ;
  rdfs:label """The British Geological Survey is a government-funded organisation that studies the UK’s geology, resources, and hazards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29057-3
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to show the south-east to north-west pattern in the UK’s geology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29057-4
  a curric:KeyLearningPoint ;
  rdfs:label "The UK’s varied geology leads to contrasting landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.649154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Colonialism was a system where powerful countries controlled others for power, land and resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24296-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colonialism shaped modern trade and wealth gaps."@en ;
  dcterms:modified "2026-02-12T08:59:21.649310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24296-3
  a curric:KeyLearningPoint ;
  rdfs:label "Debt and global trade rules reinforce global inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.649317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24296-4
  a curric:KeyLearningPoint ;
  rdfs:label "Technology gaps limit opportunities in poor nations."@en ;
  dcterms:modified "2026-02-12T08:59:21.649322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24296-5
  a curric:KeyLearningPoint ;
  rdfs:label "Historical inequalities still impact development today."@en ;
  dcterms:modified "2026-02-12T08:59:21.649326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29439-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are a range of things we can do to measure our impact on the planet."@en ;
  dcterms:modified "2026-02-12T08:59:21.649808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29439-2
  a curric:KeyLearningPoint ;
  rdfs:label "Living more sustainably can help tackle climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.649813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29439-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can mitigate against climate change by: planting trees, international agreements, and using alternative energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29439-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can adapt to climate change by: adapting agriculture, considering water supply, and protecting the land from erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24368-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most people live near rivers or coasts."@en ;
  dcterms:modified "2026-02-12T08:59:21.650052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24368-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries have high birth rates and growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.650057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24368-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cities are expanding due to urban migration."@en ;
  dcterms:modified "2026-02-12T08:59:21.650062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24368-4
  a curric:KeyLearningPoint ;
  rdfs:label "Population growth puts pressure on resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.650067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24238-1
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing is one of the oldest cities in the world with a history dating back around 3000 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24238-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing’s population has increased; more and more land is becoming built up and infrastructure has developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24238-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing’s rapid growth and status as a global city provides a wide range of opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24238-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many large transnational corporations have bases in Beijing."@en ;
  dcterms:modified "2026-02-12T08:59:21.650107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24206-1
  a curric:KeyLearningPoint ;
  rdfs:label "Extreme weather events are becoming increasingly common due to climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.650136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24206-2
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change effects include higher temperatures in summer, fewer cold spells in winter and an increase in heavy rain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24206-3
  a curric:KeyLearningPoint ;
  rdfs:label "Extreme weather events have social, economic and environmental effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.650145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24232-1
  a curric:KeyLearningPoint ;
  rdfs:label """China’s climate varies considerably because of its large size and diverse landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24232-2
  a curric:KeyLearningPoint ;
  rdfs:label "Much of China has a monsoon climate with dry winters and wetter summers."@en ;
  dcterms:modified "2026-02-12T08:59:21.650157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24232-3
  a curric:KeyLearningPoint ;
  rdfs:label "Temperatures in part of China can reach more than 50oC in the summer."@en ;
  dcterms:modified "2026-02-12T08:59:21.650161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24232-4
  a curric:KeyLearningPoint ;
  rdfs:label """China’s lowest recorded temperature was -53oc in Mohe, the country’s northernmost city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24232-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some places in China receive heavy rainfall; other places have an arid climate."@en ;
  dcterms:modified "2026-02-12T08:59:21.650173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24237-1
  a curric:KeyLearningPoint ;
  rdfs:label """A global city is a well-connected city, this means that there are good transport and financial links across the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24237-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing is the capital of China and has a population of around 22 million people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24237-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing is a major centre for finance and industry, both in in China and globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24237-4
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing is important for its rich history and culture; millions of tourists visit the city each year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24322-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mining and logging have led to deforestation and environmental destruction."@en ;
  dcterms:modified "2026-02-12T08:59:21.650242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24322-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many workers, including children, face unsafe conditions in mines."@en ;
  dcterms:modified "2026-02-12T08:59:21.650247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24322-3
  a curric:KeyLearningPoint ;
  rdfs:label "The wealth from natural resources does not benefit most people in the DRC."@en ;
  dcterms:modified "2026-02-12T08:59:21.650252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24322-4
  a curric:KeyLearningPoint ;
  rdfs:label "Resource exploitation has fueled conflict and corruption."@en ;
  dcterms:modified "2026-02-12T08:59:21.650258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24316-1
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC was a former Belgian colony and has had multiple names over time including the Belgian Congo and Zaire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24316-2
  a curric:KeyLearningPoint ;
  rdfs:label """King Leopold II exploited the country's natural resources and people, causing millions of deaths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24316-3
  a curric:KeyLearningPoint ;
  rdfs:label "After independence in 1960, the DRC faced political instability and conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.650442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24316-4
  a curric:KeyLearningPoint ;
  rdfs:label "Colonial borders and exploitation still affect the DRC today."@en ;
  dcterms:modified "2026-02-12T08:59:21.650449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24366-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Tigris and Euphrates are key rivers for farming."@en ;
  dcterms:modified "2026-02-12T08:59:21.650455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24366-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water scarcity affects many countries in the region."@en ;
  dcterms:modified "2026-02-12T08:59:21.650459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Desalination provides water but is expensive."@en ;
  dcterms:modified "2026-02-12T08:59:21.650464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24366-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dams impact water flow and cause disputes."@en ;
  dcterms:modified "2026-02-12T08:59:21.650487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24321-1
  a curric:KeyLearningPoint ;
  rdfs:label "The DRC has abundant natural resources, including coltan, diamonds, and copper."@en ;
  dcterms:modified "2026-02-12T08:59:21.650573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24321-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the DRC, most mining occurs in the east and southeast of the country."@en ;
  dcterms:modified "2026-02-12T08:59:21.650577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24321-3
  a curric:KeyLearningPoint ;
  rdfs:label """The natural resources of the DRC are essential for global industries, including technology and energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24321-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the DRC's natural resources are owned by companies in other countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.650587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24284-1
  a curric:KeyLearningPoint ;
  rdfs:label """One in twenty people lives close to an active volcano due to their fertile soils, tourist income and geothermal energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24284-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are risks including: pyroclastic flows, ash and lahars."@en ;
  dcterms:modified "2026-02-12T08:59:21.650619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24284-3
  a curric:KeyLearningPoint ;
  rdfs:label """Preparation such as public education as well as the monitoring of volcanoes can reduce risks to people living close by."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24284-4
  a curric:KeyLearningPoint ;
  rdfs:label """Short-term responses include local and international emergency services providing aid to people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24284-5
  a curric:KeyLearningPoint ;
  rdfs:label """Long-term responses include infrastructure repair/rebuild in the months and years after the eruption."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24229-1
  a curric:KeyLearningPoint ;
  rdfs:label "India has the fifth largest economy in the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.650688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24229-2
  a curric:KeyLearningPoint ;
  rdfs:label "India's economy was worth $3.6 trillion in 2023."@en ;
  dcterms:modified "2026-02-12T08:59:21.650692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24229-3
  a curric:KeyLearningPoint ;
  rdfs:label """Global superpower is used to describe a country that has a lot of power or influence over other countries in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24229-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different indicators can be used to measure how India has changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.650701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24239-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are high levels of inequalities in Beijing and many other places in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24239-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing is one of the wealthiest cities in the world but many people struggle to meet their daily living needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24239-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beijing’s high population density puts strains on housing, infrastructure and services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24239-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poor air quality in Beijing is harmful to people and the environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.650876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24220-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most of India has a tropical monsoon climate and has three seasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.650977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24220-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cherrapunjee in India is one of the wettest places on Earth, it receives 12 metres of rain a year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24220-3
  a curric:KeyLearningPoint ;
  rdfs:label "The average annual temperature in India is around 27.4 degrees celsius."@en ;
  dcterms:modified "2026-02-12T08:59:21.650991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24220-4
  a curric:KeyLearningPoint ;
  rdfs:label """The highest recorded temperature was in Delhi in 2024 and it was 53.2 degrees celsius."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24220-5
  a curric:KeyLearningPoint ;
  rdfs:label "India has a varied climate because of its large size and diverse landscape."@en ;
  dcterms:modified "2026-02-12T08:59:21.651001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24235-1
  a curric:KeyLearningPoint ;
  rdfs:label """The population of China is more than 1.4 billion; China is the second most populous country in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24235-2
  a curric:KeyLearningPoint ;
  rdfs:label """China’s population increased rapidly after the Second World War but its population is now declining."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24235-3
  a curric:KeyLearningPoint ;
  rdfs:label """Falling birth rates and an ageing population are contributing to the decrease in China’s population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24235-4
  a curric:KeyLearningPoint ;
  rdfs:label """The population of China is unevenly distributed because of different physical and human factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24215-1
  a curric:KeyLearningPoint ;
  rdfs:label "Global temperatures are increasing because of climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.651024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24215-2
  a curric:KeyLearningPoint ;
  rdfs:label """Forests remove carbon dioxide from Earth's atmosphere and replace it with oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24215-3
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation is a major contributor to climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.651033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24215-4
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change can cause changes to species in a forest; the spread of pests and diseases and more and worse wildfires."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24242-1
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon footprint is a measure of the amount of greenhouse gases something releases into the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24242-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some people and countries contribute more to climate change than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.651070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24242-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tackling climate change needs a huge reduction in the world’s greenhouse gas emissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24242-4
  a curric:KeyLearningPoint ;
  rdfs:label "China is taking action in different ways to reduce greenhouse gas emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.651079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24230-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some people and places are more impacted by climate change than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.651195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24230-2
  a curric:KeyLearningPoint ;
  rdfs:label """Droughts, flooding and heatwaves in India are becoming more frequent and severe because of climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24230-3
  a curric:KeyLearningPoint ;
  rdfs:label """People around the world are taking action against climate change but a lot more action is needed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24230-4
  a curric:KeyLearningPoint ;
  rdfs:label """India is taking action in different ways to reduce its greenhouse gas emissions and adapt to climate change impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24234-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Gobi Desert is a large, cold desert that covers parts of northern China and southern Mongolia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24234-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Gobi Desert is a rain shadow desert and is formed by the blocking of rainfall by the Himalayas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24234-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different factors make the Gobi Desert a challenging environment to survive in."@en ;
  dcterms:modified "2026-02-12T08:59:21.651424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24234-4
  a curric:KeyLearningPoint ;
  rdfs:label "Human activities are causing the Gobi Desert to increase in size."@en ;
  dcterms:modified "2026-02-12T08:59:21.651429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24234-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different actions are being taken to try and reduce desertification in and around the Gobi Desert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24369-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Middle East is a major source and destination for migrants."@en ;
  dcterms:modified "2026-02-12T08:59:21.652496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Migration in the Middle East can be both voluntary or forced."@en ;
  dcterms:modified "2026-02-12T08:59:21.652500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24369-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Gulf States are a major destination for international migrants."@en ;
  dcterms:modified "2026-02-12T08:59:21.652505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24369-4
  a curric:KeyLearningPoint ;
  rdfs:label "War has been a major cause of forced migration."@en ;
  dcterms:modified "2026-02-12T08:59:21.652509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24369-5
  a curric:KeyLearningPoint ;
  rdfs:label """Migration stories reveal the personal impacts of conflict, work, and opportunity across the Middle East."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24287-1
  a curric:KeyLearningPoint ;
  rdfs:label """Primary effects happen directly as a result of an earthquake, for example broken gas pipes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24287-2
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary effects happen as a result of an earthquake's primary effects, for example a fire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Earthquake severity depends on the magnitude, focus depth, epicentre location, aftershocks, preparations and response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the deadliest and costliest earthquake events have occurred in high income countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24333-1
  a curric:KeyLearningPoint ;
  rdfs:label """The population of Lagos is growing rapidly – millions of people have moved to the city from rural areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24333-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lagos is Nigeria's economic hub and a port city."@en ;
  dcterms:modified "2026-02-12T08:59:21.656459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The different industries in Lagos provide job opportunities and higher average incomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24333-4
  a curric:KeyLearningPoint ;
  rdfs:label "Urbanisation in Lagos has brought improvements in infrastructure and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.656468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24333-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lagos is a major cultural hub that is known for its music, arts and entertainment industries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24201-1
  a curric:KeyLearningPoint ;
  rdfs:label "High pressure systems, when air is sinking, are called anticyclones."@en ;
  dcterms:modified "2026-02-12T08:59:21.664276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24201-2
  a curric:KeyLearningPoint ;
  rdfs:label "Anticyclones are characterised by dry, stable weather."@en ;
  dcterms:modified "2026-02-12T08:59:21.664280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anticyclones have very gentle winds shown by widely spaced isobars on a weather map."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24201-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anticyclones can bring summer heatwaves and very cold conditions in winter."@en ;
  dcterms:modified "2026-02-12T08:59:21.664290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24198-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relief rainfall occurs when warm moist air from the ocean rises up over mountains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24198-2
  a curric:KeyLearningPoint ;
  rdfs:label """Convectional rainfall occurs when the sun heats up the land, when it cools and condenses it forms rainclouds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24198-3
  a curric:KeyLearningPoint ;
  rdfs:label "Frontal rainfall occurs when a warm front meets a cold front."@en ;
  dcterms:modified "2026-02-12T08:59:21.666541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24198-4
  a curric:KeyLearningPoint ;
  rdfs:label "The west of the UK is generally wetter than the east."@en ;
  dcterms:modified "2026-02-12T08:59:21.666546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24167-1
  a curric:KeyLearningPoint ;
  rdfs:label "The coastline is where the land meets the sea."@en ;
  dcterms:modified "2026-02-12T08:59:21.667611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24167-2
  a curric:KeyLearningPoint ;
  rdfs:label "The United Kingdom is a range of islands, each with their own coastline."@en ;
  dcterms:modified "2026-02-12T08:59:21.667616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some parts of the coastline have a beach whereas other parts have cliffs."@en ;
  dcterms:modified "2026-02-12T08:59:21.667621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24167-4
  a curric:KeyLearningPoint ;
  rdfs:label "The coastline has many uses, for example for fishing and tourism."@en ;
  dcterms:modified "2026-02-12T08:59:21.667625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24354-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wind speeds are higher in offshore, high-altitude, flat areas as they are less sheltered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wind farms should be located far from densely populated areas and close to the electricity grid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24354-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many people campaign against wind farms due to the noise and visual impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.672353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24354-4
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers often use a cost benefit analysis to help make decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.672357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24354-5
  a curric:KeyLearningPoint ;
  rdfs:label "OS maps are a good source of information for potential sites."@en ;
  dcterms:modified "2026-02-12T08:59:21.672362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24161-1
  a curric:KeyLearningPoint ;
  rdfs:label "Contours show the height of the land on a map."@en ;
  dcterms:modified "2026-02-12T08:59:21.674875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24161-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spot heights give the exact height of a place in metres."@en ;
  dcterms:modified "2026-02-12T08:59:21.674879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24161-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contours that are far apart show an area of flat land."@en ;
  dcterms:modified "2026-02-12T08:59:21.674982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24161-4
  a curric:KeyLearningPoint ;
  rdfs:label "Contours that are close together show steep land."@en ;
  dcterms:modified "2026-02-12T08:59:21.675005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24161-5
  a curric:KeyLearningPoint ;
  rdfs:label "Features such as spurs and valleys can be shown on a map."@en ;
  dcterms:modified "2026-02-12T08:59:21.675014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24342-1
  a curric:KeyLearningPoint ;
  rdfs:label """A river starts in the upper course at the source and this is usually an upland area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24342-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers in the upper course are usually small and slow but have a steep gradient."@en ;
  dcterms:modified "2026-02-12T08:59:21.675025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24342-3
  a curric:KeyLearningPoint ;
  rdfs:label "Erosion in the upper course of a river is usually vertical."@en ;
  dcterms:modified "2026-02-12T08:59:21.675029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24342-4
  a curric:KeyLearningPoint ;
  rdfs:label """Landforms in the upper course of a river include v-shaped valleys, interlocking spurs, waterfalls and gorges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24342-5
  a curric:KeyLearningPoint ;
  rdfs:label "V-shaped valleys are steep-sided valleys caused by vertical erosion."@en ;
  dcterms:modified "2026-02-12T08:59:21.675095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24320-1
  a curric:KeyLearningPoint ;
  rdfs:label "The DRC has several national parks that protect endangered species."@en ;
  dcterms:modified "2026-02-12T08:59:21.677168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virunga National Park is home to rare mountain gorillas but faces threats from poaching and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24320-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conservation efforts must balance protecting nature with supporting local communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24320-4
  a curric:KeyLearningPoint ;
  rdfs:label """International organisations and local people are working to protect the rainforest and wildlife in the DRC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24159-1
  a curric:KeyLearningPoint ;
  rdfs:label "OS maps use symbols to show human and physical features."@en ;
  dcterms:modified "2026-02-12T08:59:21.678984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24159-2
  a curric:KeyLearningPoint ;
  rdfs:label "A key is used to explain what each symbol represents."@en ;
  dcterms:modified "2026-02-12T08:59:21.678989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24159-3
  a curric:KeyLearningPoint ;
  rdfs:label """The details around the outside of the OS map give locational information such as the three norths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24159-4
  a curric:KeyLearningPoint ;
  rdfs:label "Symbols differ between a 1:25 000 and 1:50 000 map."@en ;
  dcterms:modified "2026-02-12T08:59:21.678998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24197-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate zones are areas with a similar climate."@en ;
  dcterms:modified "2026-02-12T08:59:21.681489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24197-2
  a curric:KeyLearningPoint ;
  rdfs:label """Factors such as alititude, latitude and distance from the sea affect the weather and climate of a location."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24197-3
  a curric:KeyLearningPoint ;
  rdfs:label """The height above sea level affects the temperature.The higher above sea level, the cooler the temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24197-4
  a curric:KeyLearningPoint ;
  rdfs:label """Coastal areas tend to have warmer winters than inland areas as water takes longer to warm up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24340-1
  a curric:KeyLearningPoint ;
  rdfs:label "A drainage basin is the area of land drained by a river and its tributaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.688051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24340-2
  a curric:KeyLearningPoint ;
  rdfs:label "The edge of a drainage basin is known as the watershed."@en ;
  dcterms:modified "2026-02-12T08:59:21.688056Z"^^xsd:dateTime .

