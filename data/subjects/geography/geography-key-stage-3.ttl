oakcurric:keylearningpoint-lesson-24216-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is making the conditions needed for wildfires to spread more likely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24216-4
  a curric:KeyLearningPoint ;
  rdfs:label """The carbon dioxide emitted from wildfires was a huge contribution to carbon emissions in 2022."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700097Z"^^xsd:dateTime .

