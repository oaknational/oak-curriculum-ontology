  a curric:KeyLearningPoint ;
  rdfs:label "Tangshan is a major steelmaking city in modern China."@en ;
  dcterms:modified "2026-02-12T08:59:21.694432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24311-4
  a curric:KeyLearningPoint ;
  rdfs:label "Industrial activities shape the landscape, environment, and identity of cities."@en ;
  dcterms:modified "2026-02-12T08:59:21.694436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24155-1
  a curric:KeyLearningPoint ;
  rdfs:label """Geography is the study of places around the world and the relationships between people and their environments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694910Z"^^xsd:dateTime .

