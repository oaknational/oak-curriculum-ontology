  dcterms:modified "2026-02-12T08:59:21.699569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24300-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is inequality in wealth and housing within countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.699573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24300-4
  a curric:KeyLearningPoint ;
  rdfs:label """Average incomes give us perceptions about a country but they give us a limited understanding of what a place is like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24216-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wildfires are uncontrolled fires that spread fast through vegetation, e.g. forests, grasslands or shrublands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700081Z"^^xsd:dateTime .

