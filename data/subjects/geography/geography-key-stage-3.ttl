oakcurric:keylearningpoint-lesson-24308-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cities drive innovation and economic growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.696149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24308-5
  a curric:KeyLearningPoint ;
  rdfs:label "Cities provide more business opportunities."@en ;
  dcterms:modified "2026-02-12T08:59:21.696153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24226-1
  a curric:KeyLearningPoint ;
