oakcurric:keylearningpoint-lesson-24262-1
  a curric:KeyLearningPoint ;
  rdfs:label """A transnational corporation is a company that can be found all over the world such as Nike and McDonalds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24262-2
  a curric:KeyLearningPoint ;
  rdfs:label """Transnational corporations can bring about glocalisation, where products and ideas are adapted to local cultures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24263-1
  a curric:KeyLearningPoint ;
  rdfs:label "Transnational companies can bring benefits and disavantages to countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.700866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24263-2
  a curric:KeyLearningPoint ;
  rdfs:label """Benefits from TNCs include the creation of jobs, new trade markets and better education to produce skilled workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24263-3
  a curric:KeyLearningPoint ;
  rdfs:label """Disadvantages of TNCs can include exploitation of the host country, poor treatment of workers and environmental damage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24179-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our population is growing and has reached 8 billion people."@en ;
  dcterms:modified "2026-02-12T08:59:21.701049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24179-2
  a curric:KeyLearningPoint ;
  rdfs:label """Our population has changed over time, but icnreased most rapidly since the 1800s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24179-3
  a curric:KeyLearningPoint ;
  rdfs:label """Population growth is slowing down, but is still expected to hit 9 billion by 2037."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24227-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mumbai was once a small fishing port however it has grown significantly over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24227-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mumbai’s population has increased; more and more land is becoming built up and infrastructure has developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24227-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mumbai’s rapid growth and status as a global city provides a wide range of opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24227-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many large transnational corporations are based in Mumbai such as Tata and the State Bank of India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24169-1
  a curric:KeyLearningPoint ;
  rdfs:label "Natural processes that happen at the coast help to shape coastlines."@en ;
  dcterms:modified "2026-02-12T08:59:21.701179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24169-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of erosion: abrasion, hydraulic action, attrition and solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24169-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of transportation: traction, solution, suspension and saltation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24169-4
  a curric:KeyLearningPoint ;
  rdfs:label """The process of deposition occurs when waves have lost their energy and can no longer carry their load."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24178-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is putting millions of people across the world at risk from sea level rise and flooding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24178-2
  a curric:KeyLearningPoint ;
  rdfs:label """Island nations and coastal cities and communities are trying to mitigate the risk with built structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24178-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are different actions taking place to find solutions and try to prevent further global issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24362-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rare earth materials are essential to modern technologies but challenging to extract and refine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24362-2
  a curric:KeyLearningPoint ;
  rdfs:label "Open pit mining can lead to deforestation, habitat and biodiversity loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.701540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extracting just one tonne of rare earth materials can produce up to 2,000 tonnes of toxic waste."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Local communities are at risk of respiratory illnesses, reproductive and heart issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24362-5
  a curric:KeyLearningPoint ;
  rdfs:label """Solutions include circular mineral harvesting, new technologies to improve recycling rates and new synthetic materials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24277-1
  a curric:KeyLearningPoint ;
  rdfs:label "Geological resources bring money, jobs, and materials we rely on daily."@en ;
  dcterms:modified "2026-02-12T08:59:21.701558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24277-2
  a curric:KeyLearningPoint ;
  rdfs:label "Extraction harms landscapes, wildlife, and sometimes local communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.701563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24277-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mining and fossil fuels create jobs and support national economies."@en ;
  dcterms:modified "2026-02-12T08:59:21.701567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24277-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fossil fuels pollute and add to global warming despite economic value."@en ;
  dcterms:modified "2026-02-12T08:59:21.701572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24277-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable alternatives are growing but aren't yet fully replacing fossil fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24404-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic pollution harms marine life and spreads through ocean currents."@en ;
  dcterms:modified "2026-02-12T08:59:21.701725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24404-2
  a curric:KeyLearningPoint ;
  rdfs:label "Overfishing reduces fish populations and disrupts marine food chains."@en ;
  dcterms:modified "2026-02-12T08:59:21.701730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24404-3
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change warms oceans and causes coral bleaching."@en ;
  dcterms:modified "2026-02-12T08:59:21.701734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24404-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oil spills and chemical pollution damage marine ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.701739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24404-5
  a curric:KeyLearningPoint ;
  rdfs:label "Rising sea levels and acidification threaten coastal and ocean habitats."@en ;
  dcterms:modified "2026-02-12T08:59:21.701743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Moscow is Russia’s capital city and can be understood through the six features that interact to make a place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moscow is located in western Russia on the River Moskva. It has a well developed infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24394-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moscow is Europe’s largest city and is home to a population of over 12 million."@en ;
  dcterms:modified "2026-02-12T08:59:21.701788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Moscow’s culture has been shaped by centuries of diverse influences including religion and migrant populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24394-5
  a curric:KeyLearningPoint ;
  rdfs:label """Moscow holds over one fifth of Russia's wealth and is home to the national government which is housed in the Kremlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24187-1
  a curric:KeyLearningPoint ;
  rdfs:label "Migration brings opportunities for a country but can also lead to challenges."@en ;
  dcterms:modified "2026-02-12T08:59:21.701803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24187-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migration can increase diversity within a country, leading to changes in fashion, food and culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24187-3
  a curric:KeyLearningPoint ;
  rdfs:label """People may choose to move away from the UK for different work or lifestyle opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24409-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate models predict rising temperatures and more extreme weather."@en ;
  dcterms:modified "2026-02-12T08:59:21.701819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24409-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sea levels are expected to rise due to melting ice and thermal expansion."@en ;
  dcterms:modified "2026-02-12T08:59:21.701823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24409-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some regions may face drought, while others experience more flooding."@en ;
  dcterms:modified "2026-02-12T08:59:21.701828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24409-4
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change may increase migration and conflict over resources."@en ;
  dcterms:modified "2026-02-12T08:59:21.701833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24409-5
  a curric:KeyLearningPoint ;
  rdfs:label "Actions taken now will influence how severe future climate change becomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.701837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Temperate grasslands are called ‘breadbaskets’ for producing much of the world's wheat and cereals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Temperate grassland have characteristics which make them especially good agricultural land: climate, soil and terrain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Russia’s main agricultural areas are found in the west of the country and within the steppe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24391-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Russian steppe is vital to the nation’s domestic food supply. Russia is largely self-sufficient in grain production."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24391-5
  a curric:KeyLearningPoint ;
  rdfs:label """Russia is the world's top wheat exporter, generating US$11 billion from wheat exports in 2023."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Russia is warming at more than twice the global average, especially in the Arctic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24398-2
  a curric:KeyLearningPoint ;
  rdfs:label """The melting permafrost is causing infrastructure damage and releasing greenhouse gases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24398-3
  a curric:KeyLearningPoint ;
  rdfs:label """Agriculture in Russia is impacted by changing rainfall patterns, affecting crop yields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24398-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Russian government has started to acknowledge climate change but actions to mitigate it have been limited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24398-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is also influencing migration patterns with some regions becoming less habitable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24280-1
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of continental drift suggests that Earth’s continents were once joined together and later drifted apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24280-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence for continental drift includes continents' jigsaw like shape, rock type and fossils matching across continents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24280-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are two types of crust; oceanic and continental crust."@en ;
  dcterms:modified "2026-02-12T08:59:21.702333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24280-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oceanic crust is dense but thin and continental crust is thicker and less dense."@en ;
  dcterms:modified "2026-02-12T08:59:21.702338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24280-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plates move by the processes of slab pull and ridge push."@en ;
  dcterms:modified "2026-02-12T08:59:21.702342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24310-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cities change due to economic and social factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.702731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24310-2
  a curric:KeyLearningPoint ;
  rdfs:label """Urban regeneration is often needed when manufacturing industry declines due to dereliction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24310-3
  a curric:KeyLearningPoint ;
  rdfs:label "Regeneration renews the built environment, creating homes, jobs and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.702739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24310-4
  a curric:KeyLearningPoint ;
  rdfs:label "Big changes can leave some groups behind."@en ;
  dcterms:modified "2026-02-12T08:59:21.702746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24310-5
  a curric:KeyLearningPoint ;
  rdfs:label "Community involvement is important in regeneration."@en ;
  dcterms:modified "2026-02-12T08:59:21.702751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24282-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are two main types of volcano: composite and shield volcanoes."@en ;
  dcterms:modified "2026-02-12T08:59:21.702756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24282-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composite volcanoes are usually found at destructive plate boundaries and they are highly explosive volcanoes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24282-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shield volcanoes are usually found at constructive plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.702765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24282-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some eruptions are explosive, whereas others are effusive."@en ;
  dcterms:modified "2026-02-12T08:59:21.702769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24306-1
  a curric:KeyLearningPoint ;
  rdfs:label "Global cities influence business, banking and culture around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.702774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24306-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all megacities (10 million or more) are global cities and vice versa."@en ;
  dcterms:modified "2026-02-12T08:59:21.702778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24306-3
  a curric:KeyLearningPoint ;
  rdfs:label "Global cities are hubs for international travel."@en ;
  dcterms:modified "2026-02-12T08:59:21.702783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24306-4
  a curric:KeyLearningPoint ;
  rdfs:label "Global cities are diverse and multicultural."@en ;
  dcterms:modified "2026-02-12T08:59:21.702787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24306-5
  a curric:KeyLearningPoint ;
  rdfs:label "The influence of different cities changes over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.702792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24359-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroponics uses nutrient rich water to grow plants without soil."@en ;
  dcterms:modified "2026-02-12T08:59:21.702914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Aquaponics uses water from fish farming to nourish plants."@en ;
  dcterms:modified "2026-02-12T08:59:21.702918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24359-3
  a curric:KeyLearningPoint ;
  rdfs:label """They require fewer inputs: no soil, minimal water, less chemicals and produce higher yields than traditional farming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24359-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the Zaatari refugee camp, aquaponics provided over 70% increase in fresh food for farmers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24359-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hydro and aquaponics do have high setup costs, energy demands, and technical complexity, which can limit accessibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24335-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria's economy includes oil, agriculture, and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.703079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24335-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many people in Nigeria work in the informal job sector."@en ;
  dcterms:modified "2026-02-12T08:59:21.703087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24335-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nigeria’s economy has grown but this growth hasn’t benefited everyone in the country equally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24335-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are high levels of economic inequality in Nigeria and many other places in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24312-1
  a curric:KeyLearningPoint ;
  rdfs:label "Urban areas are vulnerable to climate impacts such as increasing temperatures."@en ;
  dcterms:modified "2026-02-12T08:59:21.703101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24312-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the world's cities are vulnerable to sea level rise."@en ;
  dcterms:modified "2026-02-12T08:59:21.703106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24312-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cities contribute to climate change through emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.703110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24312-4
  a curric:KeyLearningPoint ;
  rdfs:label """Planners can adopt strategies that help cities mitigate the impacts of climate change and help populations adapt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24332-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many people in rural communities rely on agriculture and small-scale trading."@en ;
  dcterms:modified "2026-02-12T08:59:21.703119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24332-2
  a curric:KeyLearningPoint ;
  rdfs:label "Urban areas offer more job opportunities in a wider range of sectors."@en ;
  dcterms:modified "2026-02-12T08:59:21.703127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24332-3
  a curric:KeyLearningPoint ;
  rdfs:label "Housing and access to electricity, clean water and sanitation vary widely."@en ;
  dcterms:modified "2026-02-12T08:59:21.703132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24332-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transport, education and healthcare are typically under-resourced in rural areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24332-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are many similarities and differences in people’s lives, both within and between communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24314-1
  a curric:KeyLearningPoint ;
  rdfs:label "Smart cities use technology to improve urban life."@en ;
  dcterms:modified "2026-02-12T08:59:21.703145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24314-2
  a curric:KeyLearningPoint ;
  rdfs:label "Urban planning will focus on climate mitigation and adaptation in future."@en ;
  dcterms:modified "2026-02-12T08:59:21.703150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24314-3
  a curric:KeyLearningPoint ;
  rdfs:label "Future cities will rely on renewable energy and green tech."@en ;
  dcterms:modified "2026-02-12T08:59:21.703154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24314-4
  a curric:KeyLearningPoint ;
  rdfs:label "Advances in transport will shape future city living."@en ;
  dcterms:modified "2026-02-12T08:59:21.703159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24314-5
  a curric:KeyLearningPoint ;
  rdfs:label """The function of cities may change as more of their traditional functions go online."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24323-1
  a curric:KeyLearningPoint ;
  rdfs:label "The DRC has an equatorial climate with high temperatures and heavy rainfall."@en ;
  dcterms:modified "2026-02-12T08:59:21.703170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24323-2
  a curric:KeyLearningPoint ;
  rdfs:label """The country is home to diverse biomes, including rainforest, savanna, and wetlands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24323-3
  a curric:KeyLearningPoint ;
  rdfs:label """The climate creates opportunities and challenges for agriculture, wildlife, and human settlements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24323-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some areas face seasonal flooding, while others experience drought."@en ;
  dcterms:modified "2026-02-12T08:59:21.703184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24313-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sustainable cities prioritise environmental and social well-being."@en ;
  dcterms:modified "2026-02-12T08:59:21.703228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24313-2
  a curric:KeyLearningPoint ;
  rdfs:label "Renewable energy reduces a city's carbon footprint."@en ;
  dcterms:modified "2026-02-12T08:59:21.703233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24313-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sustainable transport reduces emissions and congestion."@en ;
  dcterms:modified "2026-02-12T08:59:21.703237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24313-4
  a curric:KeyLearningPoint ;
  rdfs:label "Green spaces improve urban health, climate resilience, and enrich society."@en ;
  dcterms:modified "2026-02-12T08:59:21.703272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24313-5
  a curric:KeyLearningPoint ;
  rdfs:label """Urban waste management is more sustainable if more people reduce, reuse and recycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24184-1
  a curric:KeyLearningPoint ;
  rdfs:label "A population pyramid shows the age and gender balance for a country."@en ;
  dcterms:modified "2026-02-12T08:59:21.703282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24184-2
  a curric:KeyLearningPoint ;
  rdfs:label "A wider base on a pyramid means that there is a high birth rate."@en ;
  dcterms:modified "2026-02-12T08:59:21.703289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24184-3
  a curric:KeyLearningPoint ;
  rdfs:label "The taller a pyramid is, the greater the life expectancy."@en ;
  dcterms:modified "2026-02-12T08:59:21.703294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24184-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bulges in population pyramids show years where there was a baby boom."@en ;
  dcterms:modified "2026-02-12T08:59:21.703299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is causing rising temperatures, extreme weather, and habitat loss in the DRC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24326-2
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation is reducing the rainforest's ability to absorb carbon dioxide."@en ;
  dcterms:modified "2026-02-12T08:59:21.703322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24326-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flooding and droughts are affecting agriculture and food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.703327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24326-4
  a curric:KeyLearningPoint ;
  rdfs:label "The DRC's role in climate action is crucial for global environmental health."@en ;
  dcterms:modified "2026-02-12T08:59:21.703331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24319-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Congo is the world's second largest tropical rainforest."@en ;
  dcterms:modified "2026-02-12T08:59:21.705145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24319-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Congo rainforest is in the Congo Basin, which spans 6 countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.705154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24319-3
  a curric:KeyLearningPoint ;
  rdfs:label "Over 400 species of mammal live in the Congo, including gorillas and okapi."@en ;
  dcterms:modified "2026-02-12T08:59:21.705159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24319-4
  a curric:KeyLearningPoint ;
  rdfs:label """32 billion tonnes of carbon is stored in trees and plants in the Congo rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24319-5
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation threatens biodiversity and local communities that depend on the forest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24195-1
  a curric:KeyLearningPoint ;
