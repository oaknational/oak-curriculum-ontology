  dcterms:modified "2026-02-12T08:59:21.694924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24308-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cities provide a wider range of jobs, and more opportunities in healthcare and education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696135Z"^^xsd:dateTime .

