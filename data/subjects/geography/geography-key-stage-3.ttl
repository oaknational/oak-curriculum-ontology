  dcterms:modified "2026-02-12T08:59:21.692255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24224-2
  a curric:KeyLearningPoint ;
  rdfs:label "India has a high average population density of 479 people per square kilometre."@en ;
  dcterms:modified "2026-02-12T08:59:21.692260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24224-3
  a curric:KeyLearningPoint ;
  rdfs:label """The population of India is unevenly distributed because of different physical and human factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24221-1
  a curric:KeyLearningPoint ;
  rdfs:label "Monsoons lead to distinct wet and dry seasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.693599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24221-2
  a curric:KeyLearningPoint ;
  rdfs:label """The north-east monsoon occurs in the winter months and the south-west monsoon occurs during the summer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24221-3
  a curric:KeyLearningPoint ;
  rdfs:label """The change in wind direction during the monsoon is caused by a difference in pressure over the land and ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24221-4
  a curric:KeyLearningPoint ;
  rdfs:label "The monsoon is very important to India’s people and its economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.693615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24221-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is causing the monsoon rains to become more erratic and unpredictable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693620Z"^^xsd:dateTime .

