  dcterms:modified "2026-02-12T08:59:21.630352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24278-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mining provides valuable materials like fossil fuels, stone, and metals."@en ;
  dcterms:modified "2026-02-12T08:59:21.630455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24278-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rare earth metals are vital for modern tech like phones and green energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.630460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24278-3
  a curric:KeyLearningPoint ;
  rdfs:label "Oil and gas are found in underground reservoirs, beneath land or sea."@en ;
  dcterms:modified "2026-02-12T08:59:21.630465Z"^^xsd:dateTime .

