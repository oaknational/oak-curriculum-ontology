  dcterms:modified "2026-02-12T08:59:21.705502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24195-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate graphs show us the precipitation and temperature of a place over a calendar year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24195-4
  a curric:KeyLearningPoint ;
  rdfs:label "Analysing climate graphs can help us describe patterns of the climate."@en ;
  dcterms:modified "2026-02-12T08:59:21.705511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24160-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maps have grid lines that help us locate places on a map."@en ;
  dcterms:modified "2026-02-12T08:59:21.707552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24160-2
  a curric:KeyLearningPoint ;
  rdfs:label "Horizontal lines are called northings and vertical lines are called eastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.707560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24160-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each grid square has two sets of numbers, giving a four-figure grid reference."@en ;
  dcterms:modified "2026-02-12T08:59:21.707564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24160-4
  a curric:KeyLearningPoint ;
  rdfs:label """To increase location accuracy, features can be located using six-figure grid references."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24275-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data made up of three parts can be shown on a triangular graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.707574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24275-2
  a curric:KeyLearningPoint ;
  rdfs:label "Proportional shapes or symbols can be used to compare the size of data values."@en ;
  dcterms:modified "2026-02-12T08:59:21.707579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24275-3
  a curric:KeyLearningPoint ;
  rdfs:label """All forms of data presentation need to conform to particular standards and use conventions to make them readable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24317-1
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC has a population distribution of around 45 people per square kilometre due to its sheer size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24317-2
  a curric:KeyLearningPoint ;
  rdfs:label """Just over half of the people live in rural areas, but Kinshasa is one of the fastest-growing cities in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24317-3
  a curric:KeyLearningPoint ;
  rdfs:label "Population pyramids represent the population structure of a given location."@en ;
  dcterms:modified "2026-02-12T08:59:21.707597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24317-4
  a curric:KeyLearningPoint ;
  rdfs:label """The median age in the DRC is 18.8 years, however half of the population are under 15 years old."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24317-5
  a curric:KeyLearningPoint ;
  rdfs:label "High birth rates and low life expectancy impact population growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.707606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24172-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK's coastline is at risk due to sea level rise as a result of climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24172-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rising sea levels are speeding up rates of erosion, leading to the east coast of England eroding quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24172-3
  a curric:KeyLearningPoint ;
  rdfs:label """When cliffs erode quickly they put homes and buildings on top of the cliffs at risk of falling into the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24172-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some parts of the UK's coastline are eroding at a rate of more than 2 metres a year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24290-1
  a curric:KeyLearningPoint ;
  rdfs:label """A tsunami is a series of large, powerful ocean waves caused by a sudden disturbance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24290-2
  a curric:KeyLearningPoint ;
  rdfs:label """Undersea earthquakes, volcanic eruptions and landslides can displace sufficient water to trigger a tsunami."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24290-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2018, a tsunami was caused by the collapse of the Anak Krakatau volcano in the Sunda Strait in Indonesia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24290-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tragically, the tsunami led to the deaths of over 430 people."@en ;
  dcterms:modified "2026-02-12T08:59:21.709313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24290-5
  a curric:KeyLearningPoint ;
  rdfs:label """The impact was devastating due to insufficient warning systems, the Strait  funnelling the waves, and the time of day."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24365-1
  a curric:KeyLearningPoint ;
  rdfs:label "The region has desert, temperate, and Mediterranean biomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.712222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24365-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hot, dry summers and low rainfall shape the land."@en ;
  dcterms:modified "2026-02-12T08:59:21.712227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24365-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is cooler and wetter in the north of the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.712232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24365-4
  a curric:KeyLearningPoint ;
  rdfs:label "Climate affects where people live."@en ;
  dcterms:modified "2026-02-12T08:59:21.712236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24360-1
  a curric:KeyLearningPoint ;
  rdfs:label "Palm oil is sourced from the fruit of the  oil palm tree."@en ;
  dcterms:modified "2026-02-12T08:59:21.712654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24360-2
  a curric:KeyLearningPoint ;
  rdfs:label """An area of rainforest, nearly the size of Greater London, has been wiped out in under a decade for oil palm plantations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24360-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plantations are less dense and less diverse."@en ;
  dcterms:modified "2026-02-12T08:59:21.712666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24360-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oil palm plantations are associated with the loss of forest for indigenous communities, forced labour and child labour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24360-5
  a curric:KeyLearningPoint ;
  rdfs:label """Experts recommend supporting certified sustainable palm oil, as it is the most land-efficient oil crop."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24339-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hydrological cycle identifies the flows and stores of water globally."@en ;
  dcterms:modified "2026-02-12T08:59:21.712680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24339-2
  a curric:KeyLearningPoint ;
  rdfs:label """The major stores of water are the ocean, ice caps, groundwater, surface water and the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24339-3
  a curric:KeyLearningPoint ;
  rdfs:label "The global hydrological cycle is a system."@en ;
  dcterms:modified "2026-02-12T08:59:21.712689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24339-4
  a curric:KeyLearningPoint ;
  rdfs:label "The movement of water between the water stores are called transfers."@en ;
  dcterms:modified "2026-02-12T08:59:21.712694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24339-5
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change has an impact on the size of stores."@en ;
  dcterms:modified "2026-02-12T08:59:21.712711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28485-1
  a curric:KeyLearningPoint ;
  rdfs:label "The scale of a map explains how large an area shown on the map is in real life."@en ;
  dcterms:modified "2026-02-12T08:59:21.715498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Small-scale maps show a large area but have little detail, e.g. a world map."@en ;
  dcterms:modified "2026-02-12T08:59:21.715503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28485-3
  a curric:KeyLearningPoint ;
  rdfs:label "Large-scale maps show a smaller area in more detail, e.g. a town or local area."@en ;
  dcterms:modified "2026-02-12T08:59:21.715507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28485-4
  a curric:KeyLearningPoint ;
  rdfs:label """A scale bar shows how distances between areas in real life compare with the distances shown on a map."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24364-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Middle East lies at the crossroads of continents."@en ;
  dcterms:modified "2026-02-12T08:59:21.715551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24364-2
  a curric:KeyLearningPoint ;
  rdfs:label "It has deserts, mountains, plateaux, and fertile valleys."@en ;
  dcterms:modified "2026-02-12T08:59:21.715556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24364-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Zagros and Taurus Mountains were formed by tectonic movement."@en ;
  dcterms:modified "2026-02-12T08:59:21.715561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24364-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Rub' al Khali is the largest sand desert in the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.715565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciers are large slow-moving rivers of ice."@en ;
  dcterms:modified "2026-02-12T08:59:21.716687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24376-2
  a curric:KeyLearningPoint ;
  rdfs:label "The frozen parts of our planet are collectively known as the cryosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.716691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24376-3
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciers are made up of snow and ice that has been compressed over many years."@en ;
  dcterms:modified "2026-02-12T08:59:21.716696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24376-4
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciers begin to move under the force of gravity."@en ;
  dcterms:modified "2026-02-12T08:59:21.716700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24174-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hard engineering is the building of fixed structures to slow down the waves and the rate of erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24174-2
  a curric:KeyLearningPoint ;
  rdfs:label """Soft engineering is working with nature to reduce the risk of flooding and erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24174-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of hard engineering include groynes, sea walls and gabions."@en ;
  dcterms:modified "2026-02-12T08:59:21.719031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24174-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of soft engineering include beach replenishment and dune stabilisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.719036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24298-1
  a curric:KeyLearningPoint ;
  rdfs:label """Women earn less than men due to unequal access to jobs, pay, and property in many countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24298-2
  a curric:KeyLearningPoint ;
  rdfs:label """Girls are more likely to miss school due to poverty, conflict, or cultural expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24298-3
  a curric:KeyLearningPoint ;
  rdfs:label "Women are underrepresented in political leadership in most countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.719403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gender inequality varies by place and is shaped by geography, culture, laws, and development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24298-5
  a curric:KeyLearningPoint ;
  rdfs:label """Progress is being made in some places through laws, education, and activism, promoting gender equality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24286-1
  a curric:KeyLearningPoint ;
  rdfs:label """Earthquakes are sudden, violent movements of the ground caused by tectonic plate movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24286-2
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes usually happen on or near plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.719421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24286-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a plate boundary two plates are locked together, yet moving in different directions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24286-4
  a curric:KeyLearningPoint ;
  rdfs:label "When rock fractures at a plate boundary this causes an earthquake."@en ;
  dcterms:modified "2026-02-12T08:59:21.719430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24286-5
  a curric:KeyLearningPoint ;
  rdfs:label "Small earthquakes can also occur far from plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.719436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24329-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria has rivers, plateaux, mountains, and savannas."@en ;
  dcterms:modified "2026-02-12T08:59:21.719760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24329-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Jos Plateau is an elevated area in central Nigeria."@en ;
  dcterms:modified "2026-02-12T08:59:21.719765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24329-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Niger Delta is a low-lying, swampy area in the south."@en ;
  dcterms:modified "2026-02-12T08:59:21.719769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24329-4
  a curric:KeyLearningPoint ;
  rdfs:label """The physical geography of Nigeria influences its population and the human activities that take place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24183-1
  a curric:KeyLearningPoint ;
  rdfs:label "A GIS can be used to visualise and analyse the UK population."@en ;
  dcterms:modified "2026-02-12T08:59:21.719778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24183-2
  a curric:KeyLearningPoint ;
  rdfs:label "A GIS can allow us to analyse the population density and age profile of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.719785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24183-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are limitations with all GIS applications."@en ;
  dcterms:modified "2026-02-12T08:59:21.719789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24183-4
  a curric:KeyLearningPoint ;
  rdfs:label "A GIS can be used to investigate changes in the UK population over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.719794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24363-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Middle East is a region of the world that spans parts of western Asia, north Africa and southeastern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24363-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Middle East has diverse physical and human landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.719803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24363-3
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to identify countries within the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.719807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24363-4
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to analyse the relation between physical and human landscapes in the Middle East."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24210-1
  a curric:KeyLearningPoint ;
  rdfs:label """Costa Rica is a small country in central America which once experienced the highest rate of deforestation in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24210-2
  a curric:KeyLearningPoint ;
  rdfs:label "Costa Rica was the first tropical country in the world to reverse deforestation."@en ;
  dcterms:modified "2026-02-12T08:59:21.720478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24210-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wildlife corridors enable species such as the jaguar to move through the rainforest undetected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24210-4
  a curric:KeyLearningPoint ;
  rdfs:label """National parks, selective logging, small-scale agroforestry and ecotourism have protected the rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24386-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is affecting polar regions which are experiencing warming at a faster rate than other places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24386-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Arctic ice cap is shrinking at a rate of 13% per decade"@en ;
  dcterms:modified "2026-02-12T08:59:21.720705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24386-3
  a curric:KeyLearningPoint ;
  rdfs:label """Permafrost is melting and habitats are shrinkingfor species that rely on cold environments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24386-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are signs of change in Antarctica due to climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.720716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24173-1
  a curric:KeyLearningPoint ;
  rdfs:label "Aerial imagery can be used to visualise coastal erosion using GIS."@en ;
  dcterms:modified "2026-02-12T08:59:21.722006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24173-2
  a curric:KeyLearningPoint ;
  rdfs:label "Old and new maps can visualise coastal erosion using GIS."@en ;
  dcterms:modified "2026-02-12T08:59:21.722011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24173-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing maps and aerial imagery using GIS can help us explain patterns of coastal erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24222-1
  a curric:KeyLearningPoint ;
  rdfs:label """A biome is a large community of vegetation and wildlife adapted to a specific climate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24222-2
  a curric:KeyLearningPoint ;
  rdfs:label "India has a range of biomes including desert, savanna and forests."@en ;
  dcterms:modified "2026-02-12T08:59:21.723164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24222-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Thar desert is one of the largest deserts in the world and part of it is found in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24222-4
  a curric:KeyLearningPoint ;
  rdfs:label """The tropical forests of the Western Ghats are one of the most biodiverse places on Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24222-5
  a curric:KeyLearningPoint ;
  rdfs:label """A geographical information system (GIS) can be used to investigate biomes in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24353-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK relies on both renewable and non-renewable energy sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.723184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24353-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wind power is the leading source of renewable electricity in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.723191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24353-3
  a curric:KeyLearningPoint ;
  rdfs:label "Natural gas is often still piped to homes to be burnt to heat rooms and food."@en ;
  dcterms:modified "2026-02-12T08:59:21.723196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24353-4
  a curric:KeyLearningPoint ;
  rdfs:label "The UK has set a target to become carbon neutral by 2050."@en ;
  dcterms:modified "2026-02-12T08:59:21.723200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24353-5
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals in the UK are encouraged to insulate their homes, install solar panels and drive electric cars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24304-1
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to visualise cities around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.723498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24304-2
  a curric:KeyLearningPoint ;
  rdfs:label "India and China now have a large number of megacities."@en ;
  dcterms:modified "2026-02-12T08:59:21.723502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24304-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cities with a lower HDI often have faster growth rates than cities with a higher HDI."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24304-4
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to analyse the growth of different cities around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.723511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24345-1
  a curric:KeyLearningPoint ;
  rdfs:label """A channel profile is a way of graphically representing the shape of a river channel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24345-2
  a curric:KeyLearningPoint ;
  rdfs:label """It may be possible to see correlations between river characteristics by drawing a scattergraph of the data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24345-3
  a curric:KeyLearningPoint ;
  rdfs:label "A line of best fit helps geographers understand the nature of any correlation."@en ;
  dcterms:modified "2026-02-12T08:59:21.723776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29371-1
  a curric:KeyLearningPoint ;
  rdfs:label """Statistical tests are used by geographers to find patterns in data sets that are not obvious in their raw form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29371-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conclusions can be strengthened by combining the results of different data sets together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The scale at which geographers collect data can have a significant influence over the type of conclusions they make."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24358-1
  a curric:KeyLearningPoint ;
  rdfs:label """GM crops are plants whose genes have been altered in a lab to give them improved traits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24358-2
  a curric:KeyLearningPoint ;
  rdfs:label """GM crops offer higher yields, pest resistance, nutrition, climate resilience, longer shelf-life, and lower costs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24358-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bt maize improved food security and income for many rural communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.725491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24358-4
  a curric:KeyLearningPoint ;
  rdfs:label """Concerns include breeding super weeds, long term health issues, resistant pests and big businesses control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24358-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bollworms developed resistance to Bt cotton in India."@en ;
  dcterms:modified "2026-02-12T08:59:21.725500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29367-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analyses of data can sometimes reveal data that does not seem to fit with the general pattern."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29367-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers should try to find explanations for anomalous data."@en ;
  dcterms:modified "2026-02-12T08:59:21.725509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29367-3
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers look for evidence that their data is both valid and reliable."@en ;
  dcterms:modified "2026-02-12T08:59:21.725514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24289-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stress had built up along the Sagaing faultline in central Myanmar and was released during the 2025 earthquake."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24289-2
  a curric:KeyLearningPoint ;
  rdfs:label "Myanmar is a low income country affected by conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.725523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24289-3
  a curric:KeyLearningPoint ;
  rdfs:label "Few plans were in place and earthquake-resistant buildings were rare."@en ;
  dcterms:modified "2026-02-12T08:59:21.725529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24289-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 7.7 magnitude quake occurred close to large centres of population."@en ;
  dcterms:modified "2026-02-12T08:59:21.725534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24289-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many different organisations provided short-term aid for the millions of people who needed support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24196-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has a temperate maritime climate, which means that it is mild with lots of rainfall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24196-2
  a curric:KeyLearningPoint ;
  rdfs:label "The south of the UK is warmer than the North."@en ;
  dcterms:modified "2026-02-12T08:59:21.725547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24196-3
  a curric:KeyLearningPoint ;
  rdfs:label "The west of the UK is wetter than the east."@en ;
  dcterms:modified "2026-02-12T08:59:21.725552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24196-4
  a curric:KeyLearningPoint ;
  rdfs:label "The east of the UK is warmer in summer and colder in winter."@en ;
  dcterms:modified "2026-02-12T08:59:21.725556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24202-1
  a curric:KeyLearningPoint ;
  rdfs:label "Depressions are areas of low pressure where air is rising."@en ;
  dcterms:modified "2026-02-12T08:59:21.726610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24202-2
  a curric:KeyLearningPoint ;
  rdfs:label """Warm air and cold air meet at depressions causing changeable temperatures and rain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24202-3
  a curric:KeyLearningPoint ;
  rdfs:label "Depressions bring windy conditions shown by closely spaced isobars."@en ;
  dcterms:modified "2026-02-12T08:59:21.726619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24202-4
  a curric:KeyLearningPoint ;
  rdfs:label "Typically the passage of a depression over the UK can last between 1 and 5 days."@en ;
  dcterms:modified "2026-02-12T08:59:21.726624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Russia is the largest country in the world and is spread over Europe and Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.728475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24387-2
  a curric:KeyLearningPoint ;
  rdfs:label "Russia has a range of diverse physical and human landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.728480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24387-3
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to locate Russia and compare the size of it relative to other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24387-4
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to analyse the relationship between physical and human landscapes in Russia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24307-1
  a curric:KeyLearningPoint ;
  rdfs:label "Urban populations often have a larger share of people aged 18–40."@en ;
  dcterms:modified "2026-02-12T08:59:21.728766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24307-2
  a curric:KeyLearningPoint ;
  rdfs:label "Migration to cities is driven by employment and educational opportunities."@en ;
  dcterms:modified "2026-02-12T08:59:21.728771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24307-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cities provide a wide range of leisure facilties which are also a draw for younger people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24307-4
  a curric:KeyLearningPoint ;
  rdfs:label "Natural increase is a key factor in the growth of urban populations."@en ;
  dcterms:modified "2026-02-12T08:59:21.728779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24307-5
  a curric:KeyLearningPoint ;
  rdfs:label "High population density puts pressure on infrastructure and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.728784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24352-1
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources can replenish naturally over short periods of time (e.g. solar energy)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24352-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy resources take millions of years to form and cannot be quickly replaced (e.g. coal)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wealthier countries use more energy for transportation, technology, factories, lighting and temperature control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24352-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many people do not have reliable access to modern energy and instead rely on fuelwood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24400-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atmospheric CO₂ levels have risen steeply since the industrial revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.730784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ice core data shows a sharp increase in greenhouse gases linked to human activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24400-3
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity loss is happening faster than natural extinction rates."@en ;
  dcterms:modified "2026-02-12T08:59:21.730793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24400-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plastics and radioactive elements form geological markers of human impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.730797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Land cover change is visible from satellites and historical maps."@en ;
  dcterms:modified "2026-02-12T08:59:21.730801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24171-1
  a curric:KeyLearningPoint ;
  rdfs:label """Longshore drift is the lateral movement of sediment across the beach through swash and backwash."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24171-2
  a curric:KeyLearningPoint ;
  rdfs:label "Longshore drift creates depositional landforms such as spits, bars and tombolos."@en ;
  dcterms:modified "2026-02-12T08:59:21.730809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24171-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spits are long narrow ridges of sand or shingle which project from a coastline into the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24171-4
  a curric:KeyLearningPoint ;
  rdfs:label "Salt marshes may form behind spits, as these are low energy zones."@en ;
  dcterms:modified "2026-02-12T08:59:21.730820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24171-5
  a curric:KeyLearningPoint ;
  rdfs:label """Spits can change direction due to the prevailing wind, which makes them curve into a hook."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24281-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are four main types of plate boundary: conservative, constructive, collision and destructive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24281-2
  a curric:KeyLearningPoint ;
  rdfs:label """At a conservative plate boundary, the tectonic plates move past each other, causing earthquakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24281-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a constructive plate boundary, the tectonic plates move apart, causing volcanic eruptions and earthquakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24281-4
  a curric:KeyLearningPoint ;
  rdfs:label "At collision plate boundaries, plates move together, causing earthquakes."@en ;
  dcterms:modified "2026-02-12T08:59:21.730842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24281-5
  a curric:KeyLearningPoint ;
  rdfs:label """At destructive plate boundaries, plates move together, causing volcanoes and earthquakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24370-1
  a curric:KeyLearningPoint ;
  rdfs:label "Judaism, Christianity and Islam began in the region."@en ;
  dcterms:modified "2026-02-12T08:59:21.730851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24370-2
  a curric:KeyLearningPoint ;
  rdfs:label "Empires shaped borders in the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.730855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24370-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colonial rule created modern political borders."@en ;
  dcterms:modified "2026-02-12T08:59:21.730859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many people in Lagos live in informal settlements because of a lack of affordable housing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24334-2
  a curric:KeyLearningPoint ;
  rdfs:label "Traffic congestion and pollution are major problems in Lagos."@en ;
  dcterms:modified "2026-02-12T08:59:21.731722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24334-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are high levels of inequalities in Lagos."@en ;
  dcterms:modified "2026-02-12T08:59:21.731726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24334-4
  a curric:KeyLearningPoint ;
  rdfs:label "Solutions include the Lagos Bus Rapid Transit system and floating schools."@en ;
  dcterms:modified "2026-02-12T08:59:21.731730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24164-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fieldwork enquiries allow geographers to investigate a place or changes over space."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24164-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geographical enquiry includes asking questions, collecting data, presenting data, analysing, conclusions and evaluation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24164-3
  a curric:KeyLearningPoint ;
  rdfs:label "Key questions or hypotheses can be used to frame a geographical enquiry."@en ;
  dcterms:modified "2026-02-12T08:59:21.731745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24164-4
  a curric:KeyLearningPoint ;
  rdfs:label """Surveys can help geographers to find interesting patterns of data at their field site."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24199-1
  a curric:KeyLearningPoint ;
  rdfs:label "A microclimate is the local climate and will differ from place to place."@en ;
  dcterms:modified "2026-02-12T08:59:21.731852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24199-2
  a curric:KeyLearningPoint ;
  rdfs:label """Land use and aspect can affect the microclimate, increasing or decreasing the temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24199-3
  a curric:KeyLearningPoint ;
  rdfs:label """The microclimate can be measured using weather instruments such as thermometers and anemometers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24199-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our knowledge of microclimates to generate questions that we can study in our fieldwork enquiry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24266-1
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation can have severe environmental consequences and can increase global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24266-2
  a curric:KeyLearningPoint ;
  rdfs:label """Local businesses are often out-competed by foreign businesses leading them to close down."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24266-3
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation has been blamed for creating a more uniform culture around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24327-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nigeria is a country in West Africa and is one of the largest countries on the continent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24327-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nigeria has a coastline to the south along the Atlantic Ocean and shares borders with four countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24327-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data on a GIS help us visualise the human geography of Nigeria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24327-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data on a GIS help us visualise the physical geography of Nigeria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24208-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are located in the tropical climate zone."@en ;
  dcterms:modified "2026-02-12T08:59:21.733444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24208-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical rainforests are home to millions of species of plants, animals, insects, birds and humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24208-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are four layers to the forest; the emergents, the canopy, the understory and the forest floor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24166-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis is the process which makes sense of the data that has been collected."@en ;
  dcterms:modified "2026-02-12T08:59:21.733456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24166-2
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis can involve looking for patterns and relationships in the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.733460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions aim to answer the key questions or disprove hypotheses."@en ;
  dcterms:modified "2026-02-12T08:59:21.733464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24166-4
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers evaluate their fieldwork to learn lessons for future studies."@en ;
  dcterms:modified "2026-02-12T08:59:21.733468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24182-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK has a population of around 67 million people."@en ;
  dcterms:modified "2026-02-12T08:59:21.734707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24182-2
  a curric:KeyLearningPoint ;
  rdfs:label """The population of the UK is unevely distributed with around 10 million people living in and around London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24182-3
  a curric:KeyLearningPoint ;
  rdfs:label """The population distribution of the UK is affected by the topography, with fewer people living in mountainous areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29366-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis can involve looking for relationships between independent and dependent variables."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29366-2
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions discuss the most likely or most common relationships."@en ;
  dcterms:modified "2026-02-12T08:59:21.734725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers are careful not to assume a reason for a relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.734729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers often need to collect more than one sample of each data type to be sure of their conclusions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24344-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Bradshaw model shows theoretically how the physical characteristics of a typical river change from source to mouth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24344-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many physical characteristics of a river can be measured during fieldwork."@en ;
  dcterms:modified "2026-02-12T08:59:21.735051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24344-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers can carry out fieldwork to see if their local river behaves like a theoretical one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24330-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria was an important centre for the Transatlantic Slave Trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.735061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24330-2
  a curric:KeyLearningPoint ;
  rdfs:label "The region of modern-day Nigeria was colonised by Britain in the 1800s."@en ;
  dcterms:modified "2026-02-12T08:59:21.735068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24330-3
  a curric:KeyLearningPoint ;
  rdfs:label "Natural resources such as oil were exploited by colonisers."@en ;
  dcterms:modified "2026-02-12T08:59:21.735074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24330-4
  a curric:KeyLearningPoint ;
  rdfs:label """After independence in 1960, Nigeria has faced political instability and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24330-5
  a curric:KeyLearningPoint ;
  rdfs:label "Colonial legacies still shape Nigeria's economy and society."@en ;
  dcterms:modified "2026-02-12T08:59:21.735082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24309-1
  a curric:KeyLearningPoint ;
  rdfs:label "The high cost of land can lead to overcrowding."@en ;
  dcterms:modified "2026-02-12T08:59:21.735972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24309-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pollution (air, water, noise) is a major urban issue."@en ;
  dcterms:modified "2026-02-12T08:59:21.735976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24309-3
  a curric:KeyLearningPoint ;
  rdfs:label "The growth of cities may be faster than the growth of services."@en ;
  dcterms:modified "2026-02-12T08:59:21.735980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24309-4
  a curric:KeyLearningPoint ;
  rdfs:label "Urban growth and traffic congestion hampers life in cities."@en ;
  dcterms:modified "2026-02-12T08:59:21.735986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24309-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poorest people may be vulnerable to environmental hazards due to the location of informal housing, e.g. landslides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24165-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fieldwork data can be presented using graphs and maps."@en ;
  dcterms:modified "2026-02-12T08:59:21.735994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24165-2
  a curric:KeyLearningPoint ;
  rdfs:label """Where a comparison is needed, the data presentation technique needs to allow any comparison to be seen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spatial data is best shown on a map."@en ;
  dcterms:modified "2026-02-12T08:59:21.736001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24165-4
  a curric:KeyLearningPoint ;
  rdfs:label "All graphs need a title and labelled axis so that they can be read easily."@en ;
  dcterms:modified "2026-02-12T08:59:21.736005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24405-1
  a curric:KeyLearningPoint ;
  rdfs:label """Though most air pollution is not visible to the naked eye, particulate matter can be captured using simple methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24405-2
  a curric:KeyLearningPoint ;
  rdfs:label "Questionnaires are a good way of gauging public opinion about an issue."@en ;
  dcterms:modified "2026-02-12T08:59:21.736755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24405-3
  a curric:KeyLearningPoint ;
  rdfs:label "Secondary data can support the primary data that is collected in the field."@en ;
  dcterms:modified "2026-02-12T08:59:21.736759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24207-1
  a curric:KeyLearningPoint ;
  rdfs:label "Forests have a range of important functions and benefits."@en ;
  dcterms:modified "2026-02-12T08:59:21.736763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24207-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of forest across the world, e.g. tropical rainforests, boreal forests and temperate forests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24207-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of forests are located in specific parts of the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.736771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24157-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lines of latitude are horizontal circles on Earth, measured in degrees north or south of the Equator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24157-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lines of longitude are vertical circles on Earth, measured in degrees east or west of the Greenwich Meridian."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24157-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use coordinates to locate places around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.736782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24157-4
  a curric:KeyLearningPoint ;
  rdfs:label """GPS uses coordinates in communication and transport systems to help society function."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24180-1
  a curric:KeyLearningPoint ;
  rdfs:label "Population is unevenly spread across the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.736793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24180-2
  a curric:KeyLearningPoint ;
  rdfs:label "Human and physical factors can affect population density."@en ;
  dcterms:modified "2026-02-12T08:59:21.736798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24180-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sparse population means that an area has few people relative to its size; rural areas have sparse populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24180-4
  a curric:KeyLearningPoint ;
  rdfs:label """A dense population means that an area has a large amount of people relative to its size; cities are densely populated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24315-1
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC is a country in central Africa and is one of the largest countries in Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24315-2
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC is largely landlocked, it has a very small stretch of coastline to the west."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24315-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data on a GIS help us visualise the human geography of the DRC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24315-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data on a GIS help us visualise the physical geography of the DRC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24331-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria is the most populous country in Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.736979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24331-2
  a curric:KeyLearningPoint ;
  rdfs:label "Population is unevenly distributed across the country."@en ;
  dcterms:modified "2026-02-12T08:59:21.736983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24331-3
  a curric:KeyLearningPoint ;
  rdfs:label "High birth rates and falling death rates contribute to rapid population growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.736987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24331-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different human and physical factors affect population density."@en ;
  dcterms:modified "2026-02-12T08:59:21.736991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24378-1
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciers create wide U-shaped valleys through the process of erosion."@en ;
  dcterms:modified "2026-02-12T08:59:21.737102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24378-2
  a curric:KeyLearningPoint ;
  rdfs:label "Truncated spurs are formed when a glacier cuts off interlocking spurs."@en ;
  dcterms:modified "2026-02-12T08:59:21.737106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24378-3
  a curric:KeyLearningPoint ;
  rdfs:label "Corries are bowl-shaped hollows found on the side of hills and mountains."@en ;
  dcterms:modified "2026-02-12T08:59:21.737109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24378-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aretes are sharp peaks formed by two glaciers wearing down either side of a mountain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24181-1
  a curric:KeyLearningPoint ;
  rdfs:label "A GIS allows us to store and display data on a digital map."@en ;
  dcterms:modified "2026-02-12T08:59:21.737854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24181-2
  a curric:KeyLearningPoint ;
  rdfs:label """A GIS can be used to investigate population data within a country and across the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24181-3
  a curric:KeyLearningPoint ;
  rdfs:label """Maps of the world's ‘human footprint’ show us information on where people live and where has been impacted by humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24181-4
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to help explain the world’s human footprint."@en ;
  dcterms:modified "2026-02-12T08:59:21.737866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24186-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration is the movement of people from one location to another, this can be permanent or temporary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Push factors are the reasons why someone wants to leave a place such as war, famine, lack of jobs and hazards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pull factors are the reasons for someone moving to a place such as improved job prospects, education and safety."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24186-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are different categories of migrants such as economic migrants, refugees and asylum seekers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24265-1
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation can be good for businesses as they can sell products around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24265-2
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation can be good for consumers as they can buy products from around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24265-3
  a curric:KeyLearningPoint ;
  rdfs:label "People are exposed to fashion, food, music and culture from around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.738236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24265-4
  a curric:KeyLearningPoint ;
  rdfs:label """Technology and ideas can spread quickly around the world leading to improvements in people's quality of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24273-1
  a curric:KeyLearningPoint ;
  rdfs:label "Limestone is a sedimentary rock made of calcium carbonate."@en ;
  dcterms:modified "2026-02-12T08:59:21.738244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24273-2
  a curric:KeyLearningPoint ;
  rdfs:label """Grykes are deep cracks on the surface on limestone formed by chemical weathering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24273-3
  a curric:KeyLearningPoint ;
  rdfs:label "Clints are exposed blocks of limestone separated by grykes."@en ;
  dcterms:modified "2026-02-12T08:59:21.738255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24273-4
  a curric:KeyLearningPoint ;
  rdfs:label """Limestone landscapes include limestone pavements, such as Malham Cove, and limestone caves, such as Gough's Cave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24272-1
  a curric:KeyLearningPoint ;
  rdfs:label "Soil texture can potentially affect the rate of water infiltration."@en ;
  dcterms:modified "2026-02-12T08:59:21.739426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24272-2
  a curric:KeyLearningPoint ;
  rdfs:label """A fieldwork enquiry can be used to find the extent to which soil texture effects infiltration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24272-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers can use a combination of data collection techniques to investigate the characteristics of soil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24371-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dubai grew from a small port to a global city."@en ;
  dcterms:modified "2026-02-12T08:59:21.739447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24371-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oil wealth funded rapid development."@en ;
  dcterms:modified "2026-02-12T08:59:21.739452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24371-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tourism, trade, and finance now drive the economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.739455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24371-4
  a curric:KeyLearningPoint ;
  rdfs:label "Urban growth raises environmental challenges."@en ;
  dcterms:modified "2026-02-12T08:59:21.739459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24233-1
  a curric:KeyLearningPoint ;
  rdfs:label """A biome is a large community of vegetation and wildlife adapted to a specific climate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24233-2
  a curric:KeyLearningPoint ;
  rdfs:label "China has a range of biomes including desert, grassland and forests."@en ;
  dcterms:modified "2026-02-12T08:59:21.739944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24233-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Gobi desert is one of the largest deserts in the world and part of it is found in China."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24233-4
  a curric:KeyLearningPoint ;
  rdfs:label "The tropical forest of Xishuangbanna is one of the largest forests in Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.739952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24233-5
  a curric:KeyLearningPoint ;
  rdfs:label """A geographical information system (GIS) can be used to investigate biomes in China."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24305-1
  a curric:KeyLearningPoint ;
  rdfs:label """Urban land use models help explain how cities are structured and how different areas serve different functions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24305-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Burgess and Hoyt models are examples of urban land use models."@en ;
  dcterms:modified "2026-02-12T08:59:21.739964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24305-3
  a curric:KeyLearningPoint ;
  rdfs:label """Land use models often don’t match the land use of cities due to physical geography and local context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24305-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing urban land use models to cities such as Sheffield can help us understand the layout and function of the city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24168-1
  a curric:KeyLearningPoint ;
  rdfs:label """Waves are powered by the wind and tides are controlled by the gravitational pull between the moon and Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24168-2
  a curric:KeyLearningPoint ;
  rdfs:label "The stretch of open water over which the wind blows is called the fetch."@en ;
  dcterms:modified "2026-02-12T08:59:21.739980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24168-3
  a curric:KeyLearningPoint ;
  rdfs:label "Constructive waves have a powerful swash and a weaker backwash."@en ;
  dcterms:modified "2026-02-12T08:59:21.739984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24168-4
  a curric:KeyLearningPoint ;
  rdfs:label "Destructive waves have a powerful backwash and a weaker swash."@en ;
  dcterms:modified "2026-02-12T08:59:21.739988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24279-1
  a curric:KeyLearningPoint ;
  rdfs:label """Earth is made up of four main layers: the inner core, outer core, mantle and crust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24279-2
  a curric:KeyLearningPoint ;
  rdfs:label """Together the upper mantle and the crust form Earth’s rigid outer layer: the lithosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24279-3
  a curric:KeyLearningPoint ;
  rdfs:label "The lithosphere is broken into large sections or tectonic plates."@en ;
  dcterms:modified "2026-02-12T08:59:21.739999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24279-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most earthquakes and volcanoes occur at plate boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.740003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24185-1
  a curric:KeyLearningPoint ;
  rdfs:label """Life expectancies around the world are increasing due to better healthcare and disease prevention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24185-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many higher income countries such as the UK, Germany and Japan have ageing populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24185-3
  a curric:KeyLearningPoint ;
  rdfs:label """An ageing population leads to the government having to invest more in pensions and healthcare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24325-1
  a curric:KeyLearningPoint ;
  rdfs:label """The DRC has potential for sustainable development through renewable energy and responsible resource management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24325-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydropower from the Congo River could provide electricity to millions."@en ;
  dcterms:modified "2026-02-12T08:59:21.740355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24325-3
  a curric:KeyLearningPoint ;
  rdfs:label "Community-led conservation and fair trade practices can improve livelihoods."@en ;
  dcterms:modified "2026-02-12T08:59:21.740361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24325-4
  a curric:KeyLearningPoint ;
  rdfs:label "International support and government policies will shape the country's future."@en ;
  dcterms:modified "2026-02-12T08:59:21.740367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24177-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tuvalu is a low elevation coastal zone."@en ;
  dcterms:modified "2026-02-12T08:59:21.740594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24177-2
  a curric:KeyLearningPoint ;
  rdfs:label """Building coastal defences for small island nations can be challenging due to their low elevation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24177-3
  a curric:KeyLearningPoint ;
  rdfs:label """The residents of Tuvalu could become displaced as a consequence of climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24177-4
  a curric:KeyLearningPoint ;
  rdfs:label """A displaced person is someone who is forced to move due to something outside their control such as flooding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24379-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Lake District is a region of mountains and lakes in the north west of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24379-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mountains and valleys in the Lake District have been shaped by ice sheets and the actions of glaciers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24379-3
  a curric:KeyLearningPoint ;
  rdfs:label """The landforms of the Lake District include U-shaped valleys, mountains and sharp ridges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24385-1
  a curric:KeyLearningPoint ;
  rdfs:label "The tundra is a treeless landscape found at high latitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.740962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24385-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the winter the tundra is frozen and dark and experiences 24 hours of darkness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24385-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the ground in the tundra is permafrost, this is ground which is permanently frozen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24385-4
  a curric:KeyLearningPoint ;
  rdfs:label "Animals such as the Arctic fox and the polar bear can be found in the tundra."@en ;
  dcterms:modified "2026-02-12T08:59:21.740982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24256-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials to make jeans come from a number of countries and they may be made and exported from another country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24256-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fashion is a global industry and jeans are sold all over the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.741396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24256-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are issues with sustainability in the manufacture of jeans."@en ;
  dcterms:modified "2026-02-12T08:59:21.741400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24374-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rising temperatures make the region hotter and drier."@en ;
  dcterms:modified "2026-02-12T08:59:21.741638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24374-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water scarcity is worsening due to climate change, and this impacts food supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24374-3
  a curric:KeyLearningPoint ;
  rdfs:label "Countries can use their natural resources to respond to climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.741647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24299-1
  a curric:KeyLearningPoint ;
  rdfs:label """Historically, high income countries have produced more greenhouse gases than low income countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24299-2
  a curric:KeyLearningPoint ;
  rdfs:label """Low income countries are often more vulnerable to climate change as they have fewer resources to adapt to its impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24299-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many people call for climate justice, so that poorer and more vulnerable people are not unfairly affected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24189-1
  a curric:KeyLearningPoint ;
  rdfs:label """Overpopulation is where there are not enough resources to meet the needs of the population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24189-2
  a curric:KeyLearningPoint ;
  rdfs:label """China's population grew rapdily in the twentieth century, resulting in the One Child Policy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24189-3
  a curric:KeyLearningPoint ;
  rdfs:label """Underpopulation is where there are not enough people for the resources available."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24189-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Australian government felt the country was underpopulated after WWII and encouraged people to live there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24407-1
  a curric:KeyLearningPoint ;
  rdfs:label "Alternative energy sources include renewable energy sources and nuclear power."@en ;
  dcterms:modified "2026-02-12T08:59:21.743576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24407-2
  a curric:KeyLearningPoint ;
  rdfs:label "Renewable energy sources produce little or no greenhouse gas emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.743580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24407-3
  a curric:KeyLearningPoint ;
  rdfs:label "The cost of renewable technology is falling, making it more accessible."@en ;
  dcterms:modified "2026-02-12T08:59:21.743583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24407-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nuclear energy is reliable and does not produce greenhouse gas emissions."@en ;
  dcterms:modified "2026-02-12T08:59:21.743589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24407-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are disadvantages in using nuclear energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.743593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24397-1
  a curric:KeyLearningPoint ;
  rdfs:label """A country that can project its power and influence all over the world is called a global superpower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Economy, military, population, land area, energy reserves and cultural influence are factors that give countries power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24397-3
  a curric:KeyLearningPoint ;
  rdfs:label """Russia is often considered a global superpower due to its strong military, large land area and large energy reserves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some people think Russia’s power is limited by the size of its economy and the size of its population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24377-1
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciers erode the landscape by plucking and abrasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.744492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eroded material called moraine is moved by the glacier in a process called transportation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24377-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the ice melts, moraine is dropped in the process of deposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.744500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24158-1
  a curric:KeyLearningPoint ;
  rdfs:label "A GIS allows us to store and display data on a digital map."@en ;
  dcterms:modified "2026-02-12T08:59:21.745602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24158-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different layers of data can be added on a GIS which allows us to investigate spatial patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24158-3
  a curric:KeyLearningPoint ;
  rdfs:label """A GIS can be used to locate places around the world and investigate their size and distance from other places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Decisions are taken when using a GIS to analyse data which can lead to differences in results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24288-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can calculate the probability of an earthquake happening within an area in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24288-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is not currently possible to predict exactly when or where earthquakes will occur."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24288-3
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquake detection can only provide seconds of warning."@en ;
  dcterms:modified "2026-02-12T08:59:21.745628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24288-4
  a curric:KeyLearningPoint ;
  rdfs:label "Drop-cover-hold is practised during earthquake drills."@en ;
  dcterms:modified "2026-02-12T08:59:21.745632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24288-5
  a curric:KeyLearningPoint ;
  rdfs:label """Base isolators, flexible building materials, strong shapes and mass dampers help create earthquake-resistant buildings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Volcanic eruptions can lead to a range of hazards, such as pyroclastic flows, ash and lahars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24283-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pyroclastic flows are flows of hot volcanic gases, ash and rock."@en ;
  dcterms:modified "2026-02-12T08:59:21.745644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24283-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ash is made up of tiny pieces of volcanic rock and glass, this can damage lungs, machines, crops and buildings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24283-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lahars are mudflows caused by volcanic material mixed with water."@en ;
  dcterms:modified "2026-02-12T08:59:21.745653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24283-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mount Semeru (Java, Indonesia) erupted in 2021, triggering damaging pyroclastic flows, ashfall and lahars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24200-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data can be presented to make it easier to analyse."@en ;
  dcterms:modified "2026-02-12T08:59:21.745825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24200-2
  a curric:KeyLearningPoint ;
  rdfs:label "To compare data it might be possible to represent it on the same set of axes."@en ;
  dcterms:modified "2026-02-12T08:59:21.745829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24200-3
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting data on a map can help geographers see spatial patterns."@en ;
  dcterms:modified "2026-02-12T08:59:21.745833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24200-4
  a curric:KeyLearningPoint ;
  rdfs:label """All data presentations need to conform to particular standards (such as having keys and labels) to make them readable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24395-1
  a curric:KeyLearningPoint ;
  rdfs:label """Over 70% of Russia is considered to be rural. It is home to 25% of the population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24395-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality in Russia is most marked between rural and urban areas. Average rural incomes are 57% lower than urban."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24395-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality leads to a number of differences such as higher rates of poverty and poorer infrastructure and services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24395-4
  a curric:KeyLearningPoint ;
  rdfs:label """Russia officially recognises 40 Indigenous peoples. They make up 0.2% of the population yet inhabit 65% of Russia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24395-5
  a curric:KeyLearningPoint ;
  rdfs:label """Challenges for Indigenous Peoples include: loss of land, access to services, population decline and cultural erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24276-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mass movement is the downhill movement of sediment under the influence of gravity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24276-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main types of mass movement are rockfall, sliding, and slumping."@en ;
  dcterms:modified "2026-02-12T08:59:21.746147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24276-3
  a curric:KeyLearningPoint ;
  rdfs:label "Slumping is common on coastlines."@en ;
  dcterms:modified "2026-02-12T08:59:21.746151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24276-4
  a curric:KeyLearningPoint ;
  rdfs:label """Weathering and erosion lead to mass movement when combined with wet weather conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24343-1
  a curric:KeyLearningPoint ;
  rdfs:label """As the river flows downstream, the gradient becomes flatter and the river becomes wider and deeper."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24343-2
  a curric:KeyLearningPoint ;
  rdfs:label "Landforms such as meanders form in the middle course of a river."@en ;
  dcterms:modified "2026-02-12T08:59:21.746941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24343-3
  a curric:KeyLearningPoint ;
  rdfs:label """Landforms such as levees, flodplains, estuaries and deltas can be found in the lower course."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24343-4
  a curric:KeyLearningPoint ;
  rdfs:label """Over time oxbow lakes can form when meander loops become cut off following a flood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24343-5
  a curric:KeyLearningPoint ;
  rdfs:label """Deposition occurs in the lower course and this forms landforms such as deltas and estuaries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Qualitative data can be presented in interesting ways, such as word clouds and proportional speech bubbles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29370-2
  a curric:KeyLearningPoint ;
  rdfs:label "Choropleth shading on a map can be used to show the level of air pollution."@en ;
  dcterms:modified "2026-02-12T08:59:21.747090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29370-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emoji icons can be used to show the strength of agreement or favourability."@en ;
  dcterms:modified "2026-02-12T08:59:21.747093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24303-1
  a curric:KeyLearningPoint ;
  rdfs:label """The urban hierarchy explains how settlements range from small villages to global cities based on size and function."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24303-2
  a curric:KeyLearningPoint ;
  rdfs:label """Urbanisation is the growth of urban areas and is a phenomenon experienced globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24303-3
  a curric:KeyLearningPoint ;
  rdfs:label """The location of the biggest cities in the world has changed over time from high to low and middle income countries.."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24303-4
  a curric:KeyLearningPoint ;
  rdfs:label """The two main causes of urbanisation are rural to urban migration and natural increase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24303-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 2008, for the first time in world history, over 50% of the world's population lived in towns and cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24264-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some places of the world are more interconnected than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.747135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24264-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital maps and graphs can help us visualise and analyse patterns and trends in globalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24264-3
  a curric:KeyLearningPoint ;
  rdfs:label """The wealth and size of the country can influence economic and social globalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24212-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals such as squirrels, hedgehogs, and birds, such as nightingales, can be found in temperate deciduous forests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24212-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants such as oak trees, beech trees and bluebells can be found in temperate deciduous forests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24212-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals and plants adapt to living in seasonal conditions in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.748548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24380-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Mer de Glace is the largest glacier in France."@en ;
  dcterms:modified "2026-02-12T08:59:21.748551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24380-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Mer de Glace is a tourist attraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.748555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24380-3
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change has had an impact on the Mer de Glace."@en ;
  dcterms:modified "2026-02-12T08:59:21.748561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24175-1
  a curric:KeyLearningPoint ;
  rdfs:label "Management plans are in place in order to protect the coast."@en ;
  dcterms:modified "2026-02-12T08:59:21.749272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24175-2
  a curric:KeyLearningPoint ;
  rdfs:label """In England and Wales, local councils work with the government to implement Shoreline Management Plans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24175-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hard and soft engineering can be used to help protect coastal areas from erosion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24175-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are different groups of stakeholders in coastal areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.749284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24175-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different stakeholders support different coastal management plans."@en ;
  dcterms:modified "2026-02-12T08:59:21.749287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24217-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mangroves are shrubs and trees which grow in coastal waters."@en ;
  dcterms:modified "2026-02-12T08:59:21.749291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24217-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mangroves help protect the land from flooding, caused by tropical storms and tidal surges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24217-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Sundarbans in India and Bangladesh are an example of a mangrove forest."@en ;
  dcterms:modified "2026-02-12T08:59:21.749301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24217-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mangroves face a variety of threats including coastal developments, farming and sea level rise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24217-5
  a curric:KeyLearningPoint ;
  rdfs:label """The impacts of mangrove loss include: coastal flooding, loss of biodiversity, resources and income."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24302-1
  a curric:KeyLearningPoint ;
  rdfs:label """Grassroots development is when local people work together to solve problems and make their communities better."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24302-2
  a curric:KeyLearningPoint ;
  rdfs:label """Grassroots development focuses on community participation, local knowledge, empowerment and sustainability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24302-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practical Action is a charity which supports grassroots development."@en ;
  dcterms:modified "2026-02-12T08:59:21.749321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24302-4
  a curric:KeyLearningPoint ;
  rdfs:label "Grassroots development is often seen as sustainable."@en ;
  dcterms:modified "2026-02-12T08:59:21.749325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29368-1
  a curric:KeyLearningPoint ;
  rdfs:label """Correlations between variables can be positive or negative and can be of differing strengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29368-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interpolation and extrapolation help geographers estimate unknown values in a set of data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29368-3
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers often consider the ethical aspects of their fieldwork."@en ;
  dcterms:modified "2026-02-12T08:59:21.749338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24390-1
  a curric:KeyLearningPoint ;
  rdfs:label "Russia's main biomes include tundra, taiga, temperate forest and steppe."@en ;
  dcterms:modified "2026-02-12T08:59:21.749881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24390-2
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions of distribution involve three steps: identify map features - general pattern - specific details."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24390-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pattern of biome distribution is broadly latitudinal with tundra occupying the northernmost latitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24390-4
  a curric:KeyLearningPoint ;
  rdfs:label """Climate and soil type varies between the biomes and determines the type of dominant vegetation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24390-5
  a curric:KeyLearningPoint ;
  rdfs:label "Vegetation is adapted to the climate and soil conditions of the biome."@en ;
  dcterms:modified "2026-02-12T08:59:21.749899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24393-1
  a curric:KeyLearningPoint ;
  rdfs:label "Russia's borders have changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.749903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Russia lost territory during World War I, and instability led to the formation of the Soviet Union."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24393-3
  a curric:KeyLearningPoint ;
  rdfs:label "After World War II, the Soviet Union expanded in Eastern Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.749911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24393-4
  a curric:KeyLearningPoint ;
  rdfs:label """The USSR collapsed in 1991, creating independent republics such as Ukraine, Belarus, Estonia, Latvia and Lithuania."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24393-5
  a curric:KeyLearningPoint ;
  rdfs:label "Russia’s invasion of Ukraine is an attempt to redraw their western border."@en ;
  dcterms:modified "2026-02-12T08:59:21.749921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24203-1
  a curric:KeyLearningPoint ;
  rdfs:label "Weather forecasts can be displayed on synoptic charts."@en ;
  dcterms:modified "2026-02-12T08:59:21.749926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24203-2
  a curric:KeyLearningPoint ;
  rdfs:label """Air pressure is shown on weather maps by isobars indicating areas of equal air pressure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24203-3
  a curric:KeyLearningPoint ;
  rdfs:label "Symbols are used to indicate the type of weather that can be expected."@en ;
  dcterms:modified "2026-02-12T08:59:21.749933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24203-4
  a curric:KeyLearningPoint ;
  rdfs:label "Weather fronts are shown on weather forecasts, these are cold and warm fronts."@en ;
  dcterms:modified "2026-02-12T08:59:21.749937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24271-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are three types of weathering; biological, chemical and physical weathering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24271-2
  a curric:KeyLearningPoint ;
  rdfs:label """Biological weathering is when rocks are broken up by the roots of plants or from animals burrowing into them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24271-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical weathering is when rocks are broken up by acids in rainwater or when air reacts with minerals in the rocks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24271-4
  a curric:KeyLearningPoint ;
  rdfs:label """Physical weathering is when rocks are broken up by changes in temperature, such as when ice forces apart cracks in rock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24204-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are both human and physical causes of climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.750668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24204-2
  a curric:KeyLearningPoint ;
  rdfs:label """Volcanoes, sunspots and Earth's changing orbit around the sun can change the climate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24204-3
  a curric:KeyLearningPoint ;
  rdfs:label """Human activity since the industrial revolution has been blamed for climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24204-4
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases absorb energy from long-wave radiation and re-emit it back into our atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750680Z"^^xsd:dateTime .

