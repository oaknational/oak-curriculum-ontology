@prefix curric: <https://w3id.org/oak/curriculum/ontology/> .
@prefix natcurric: <https://w3id.org/oak/curriculum/nationalcurriculum/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ======================================================================
# National Curriculum for England - Geography Knowledge Taxonomy 
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/oak/curriculum/nationalcurriculum/geography-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Geography Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Geography Knowledge Taxonomy"@en ;
  rdfs:comment """Geography knowledge taxonomy defining the hierarchical organization of geographical
  content from strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/oak/curriculum/nationalcurriculum/geography-knowledge-taxonomy/0.1.0> ;
  
  dcterms:description """This file defines the Geography knowledge taxonomy for the National 
  Curriculum in England, organizing content through strands, sub-strands, content descriptors, 
  and sub-content descriptors."""@en ;
  dcterms:created "2025-11-24T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  
  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/oak/curriculum/core/> ;
  owl:imports <https://w3id.org/oak/curriculum/nationalcurriculum/geography-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-geography ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .
  
# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-geography
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "Geography"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower natcurric:strand-world-knowledge ,
                natcurric:strand-thinking-geographically ,
                natcurric:strand-working-geographically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-world-knowledge
  a skos:Concept, curric:Strand ;
  skos:prefLabel "World Knowledge"@en ;
  skos:definition "Description of strand..." ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-geography ;
  skos:narrower natcurric:substrand-locational-knowledge ,
                natcurric:substrand-place-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-thinking-geographically
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Thinking Geographically"@en ;
  skos:definition "Description of strand..." ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-geography ;
  skos:narrower natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-working-geographically
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Working Geographically"@en ;
  skos:definition "Description of strand..." ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-geography ;
  skos:narrower natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Sub-Strands
# ----------------------------------------------------------------------

natcurric:substrand-locational-knowledge
  a skos:Concept, curric:SubStrand ;
  skos:prefLabel "Locational Knowledge"@en ;
  skos:definition "Description of sub-strand..." ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:strand-world-knowledge ;
  skos:narrower 
    natcurric:contentdescriptor-locate-continents-oceans ,
    natcurric:contentdescriptor-countries-capitals-united-kingdom ,
    natcurric:contentdescriptor-locate-worlds-countries ,
    natcurric:contentdescriptor-locate-counties-cities-of-uk ,
    natcurric:contentdescriptor-latitude-longitude-time-zones ,
    natcurric:contentdescriptor-deepen-spatial-awareness-worlds-countries ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:substrand-place-knowledge
  a skos:Concept, curric:SubStrand ;
  skos:prefLabel "Place Knowledge"@en ;
  skos:definition "Description of sub-strand..." ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:strand-world-knowledge ;
  skos:narrower 
    natcurric:contentdescriptor-uk-and-contrasting-non-european-areas ,
    natcurric:contentdescriptor-uk-european-america-regions ,
    natcurric:contentdescriptor-africa-asia-regions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:substrand-human-and-physical-geography
  a skos:Concept, curric:SubStrand ;
  skos:prefLabel "Human and Physical Geography"@en ;
  skos:definition "Description of sub-strand..." ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:strand-thinking-geographically ;
  skos:narrower 
    natcurric:contentdescriptor-weather-patterns-hot-cold-areas ,
    natcurric:contentdescriptor-key-features-physical-geography ,
    natcurric:contentdescriptor-key-features-human-geography ,
    natcurric:contentdescriptor-key-aspects-physical-geography ,
    natcurric:contentdescriptor-key-aspects-human-geography ,
    natcurric:contentdescriptor-key-processes-physical-geography ,
    natcurric:contentdescriptor-key-processes-human-geography ,
    natcurric:contentdescriptor-landscapes-environment-climate ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:substrand-geographical-skills-and-fieldwork
  a skos:Concept, curric:SubStrand ;
  skos:prefLabel "Geographical Skills and Fieldwork"@en ;
  skos:definition "Description of sub-strand..." ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:strand-working-geographically ;
  skos:narrower
    natcurric:contentdescriptor-world-maps-atlases-globes ,
    natcurric:contentdescriptor-simple-compass-directions ,
    natcurric:contentdescriptor-aerial-photographs-and-plan-perspectives ,
    natcurric:contentdescriptor-simple-fieldwork-and-observational-skills ,
    natcurric:contentdescriptor-maps-digital-computer-mapping ,
    natcurric:contentdescriptor-compass-grid-references-symbols-key ,
    natcurric:contentdescriptor-measure-record-human-physical-features ,
    natcurric:contentdescriptor-develop-knowledge-maps-atlases-globes ,
    natcurric:contentdescriptor-interpret-ordnance-survey-maps ,
    natcurric:contentdescriptor-geographical-information-systems ,
    natcurric:contentdescriptor-analyse-geographical-data ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Content Descriptors
# ----------------------------------------------------------------------

natcurric:contentdescriptor-locate-continents-oceans
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Name and locate the world’s 7 continents and 5 oceans."@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-countries-capitals-united-kingdom
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Name, locate and identify characteristics of the 4 countries and capital cities 
  of the United Kingdom and its surrounding seas."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-locate-worlds-countries
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Locate the world’s countries, using maps to focus on Europe (including the 
  location of Russia) and North and South America, concentrating on their environmental regions, 
  key physical and human characteristics, countries, and major cities."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-locate-counties-cities-of-uk
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Name and locate counties and cities of the United Kingdom, geographical regions 
  and their identifying human and physical characteristics, key topographical features (including 
  hills, mountains, coasts and rivers), and land-use patterns; and understand how some of these 
  aspects have changed over time."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-latitude-longitude-time-zones
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Identify the position and significance of latitude, longitude, Equator, 
  Northern Hemisphere, Southern Hemisphere, the Tropics of Cancer and Capricorn, Arctic and 
  Antarctic Circle, the Prime/Greenwich Meridian and time zones (including day and night)."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-deepen-spatial-awareness-worlds-countries
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Extend their locational knowledge and deepen their spatial awareness of the 
  world’s countries, using maps of the world to focus on Africa, Russia, Asia (including China and 
  India), and the Middle East, focusing on their environmental regions, including polar and hot 
  deserts, key physical and human characteristics, countries and major cities."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-locational-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-uk-and-contrasting-non-european-areas
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand geographical similarities and differences through studying the human 
  and physical geography of a small area of the United Kingdom, and of a small area in a 
  contrasting non-European country."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-uk-european-america-regions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand geographical similarities and differences through the study of human 
  and physical geography of a region of the United Kingdom, a region in a European country, and a 
  region in North or South America."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-africa-asia-regions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand geographical similarities, differences and links between places 
  through the study of the human and physical geography of a region in Africa and a region in 
  Asia."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-knowledge ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-weather-patterns-hot-cold-areas
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Identify seasonal and daily weather patterns in the United Kingdom and the 
  location of hot and cold areas of the world in relation to the Equator and the North and South 
  Poles."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-features-physical-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use basic geographical vocabulary to refer to key physical features, including: 
  beach, cliff, coast, forest, hill, mountain, sea, ocean, river, soil, valley, vegetation, season 
  and weather."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-features-human-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use basic geographical vocabulary to refer to key human features, including: 
  city, town, village, factory, farm, house, office, port, harbour and shop."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-aspects-physical-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Describe and understand key aspects of physical geography, including: climate 
  zones, biomes and vegetation belts, rivers, mountains, volcanoes and earthquakes, and the water 
  cycle."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-aspects-human-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Describe and understand key aspects of human geography, including: types of 
  settlement and land use, economic activity including trade links, and the distribution of natural 
  resources including energy, food, minerals and water."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-processes-physical-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand, through the use of detailed place-based exemplars at a variety of 
  scales, the key processes in physical geography relating to: geological timescales and plate 
  tectonics; rocks, weathering and soils; weather and climate, including the change in climate from 
  the Ice Age to the present; and glaciation, hydrology and coasts."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-processes-human-geography
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand, through the use of detailed place-based exemplars at a variety of 
  scales, the key processes in human geography relating to: population and urbanisation; 
  international development; economic activity in the primary, secondary, tertiary and quaternary 
  sectors; and the use of natural resources."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-landscapes-environment-climate
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand how human and physical processes interact to influence and change 
  landscapes, environments and the climate; and how human activity relies on the effective 
  functioning of natural systems."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-human-and-physical-geography ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-world-maps-atlases-globes
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use world maps, atlases and globes to identify the United Kingdom and its 
  countries, as well as the countries, continents and oceans studied at this key stage."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-simple-compass-directions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use simple compass directions (north, south, east and west) and locational and 
  directional language [for example, near and far, left and right], to describe the location of 
  features and routes on a map."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-aerial-photographs-and-plan-perspectives
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use aerial photographs and plan perspectives to recognise landmarks and basic 
  human and physical features; devise a simple map; and use and construct basic symbols in a 
  key."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-simple-fieldwork-and-observational-skills
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use simple fieldwork and observational skills to study the geography of their 
  school and its grounds and the key human and physical features of its surrounding 
  environment."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-maps-digital-computer-mapping
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use maps, atlases, globes and digital/computer mapping to locate countries and 
  describe features studied."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-compass-grid-references-symbols-key
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use the 8 points of a compass, 4- and 6-figure grid references, symbols and key 
  (including the use of Ordnance Survey maps) to build their knowledge of the United Kingdom and 
  the wider world."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-measure-record-human-physical-features
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use fieldwork to observe, measure record and present the human and physical 
  features in the local area using a range of methods, including sketch maps, plans and graphs, and 
  digital technologies."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-develop-knowledge-maps-atlases-globes
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Build on their knowledge of globes, maps and atlases, and apply and develop 
  this knowledge routinely in the classroom and in the field."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-ordnance-survey-maps
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Interpret Ordnance Survey maps in the classroom and the field, including using 
  grid references and scale, topographical and other thematic mapping, and aerial and satellite 
  photographs."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "9"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-geographical-information-systems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use Geographical Information Systems (GIS) to view, analyse and interpret 
  places and data."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "10"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geographical-skills-and-fieldwork ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:contentdescriptor-analyse-geographical-data
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use fieldwork in contrasting locations to collect, analyse and draw conclusions 
