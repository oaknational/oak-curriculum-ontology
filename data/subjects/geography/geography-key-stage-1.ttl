  dcterms:modified "2026-06-07T15:30:02.417560Z"^^xsd:dateTime .

oakcurric:keyword-international-airport
  a curric:Keyword ;
  schema:name "international airport"@en ;
  schema:description """An international airport is an airport that has flights to and from other
  countries"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417565Z"^^xsd:dateTime .

oakcurric:keyword-aquabus
  a curric:Keyword ;
