  dcterms:modified "2026-06-07T15:30:02.417210Z"^^xsd:dateTime .

oakcurric:keyword-holiday
  a curric:Keyword ;
  schema:name "holiday"@en ;
  schema:description "A holiday is a planned break from work or school."@en ;
  dcterms:modified "2026-06-07T15:30:02.417497Z"^^xsd:dateTime .

oakcurric:keyword-destination
  a curric:Keyword ;
  schema:name "destination"@en ;
  schema:description """A destination is a place that someone or something travels or is
