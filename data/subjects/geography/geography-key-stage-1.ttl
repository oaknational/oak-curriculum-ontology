# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-2590-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'local area' can mean different things to different people."@en ;
  dcterms:modified "2026-06-07T15:30:29.278923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2590-2
  a curric:KeyLearningPoint ;
  rdfs:label """Maps can be used to plot and show your typical range and places visited in a week,
  and how you feel about them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2590-3
  a curric:KeyLearningPoint ;
  rdfs:label """A typical local range will probably include your school, your house, the local shops
  and play areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2573-1
  a curric:KeyLearningPoint ;
  rdfs:label """Green spaces and trees help soak up noise and pollution from traffic and provide
  peaceful spots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2573-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nearly one fifth of London is covered by around 3000 parks and green spaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.284045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2573-3
  a curric:KeyLearningPoint ;
  rdfs:label "London was declared the world’s first National Park City in 2019."@en ;
  dcterms:modified "2026-06-07T15:30:29.284048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2575-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different ways to travel to London such as long distance trains, or
  national and international flights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Travel guides can help you decide where you want to go when you are visiting a new
  place, like London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Once in London, maps and travel tools can help you identify the best routes to get
  to where you need to go."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2575-4
  a curric:KeyLearningPoint ;
  rdfs:label """Locating the landmarks and places you want to visit will help you map the best route
  to see as many of them as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2566-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scotland is mountainous in the north and west, and flatter in the south and
  east."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2566-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most people in Scotland live in the bigger towns and cities in the flatter
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2566-3
  a curric:KeyLearningPoint ;
  rdfs:label """The countryside in Scotland has smaller towns and villages, farmland, forests and
  lakes known as lochs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2566-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scotland has a varied coastline and many islands."@en ;
  dcterms:modified "2026-06-07T15:30:29.299712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2565-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is made up of four countries: England, Scotland, Wales and Northern
  Ireland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2565-2
  a curric:KeyLearningPoint ;
  rdfs:label """A capital city is the place in a country where the government ‘sits’ and has its
  centre of power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Belfast, Cardiff, Edinburgh and London are capitals of NI, Wales, Scotland and
  England; London is also capital of UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2586-1
  a curric:KeyLearningPoint ;
  rdfs:label """The largest hot desert in the world is the Sahara, in North Africa, and it is still
  growing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2586-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hot deserts have extremely high temperatures during the day and very little rain;
  not much life can survive there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2586-3
  a curric:KeyLearningPoint ;
  rdfs:label """Not many people live in hot desert regions because of the lack of water for everyday
  activities and growing crops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2592-1
  a curric:KeyLearningPoint ;
  rdfs:label "A landmark is a notable human or physical feature with meaning attached to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.322193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2592-2
  a curric:KeyLearningPoint ;
  rdfs:label """Landmarks can be personal to you, known locally, or of national or global
  importance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2592-3
  a curric:KeyLearningPoint ;
  rdfs:label """Landmarks can be human features such as a statue or building e.g. Buckingham palace,
  the Taj Mahal, Hadrian's Wall."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2592-4
  a curric:KeyLearningPoint ;
  rdfs:label """Landmarks can be physical features e.g. Giant's Causeway (Northern Ireland),
  Sycamore Gap (England), Yr Wyddfa (Wales)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6817-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are similarities and differences between places and the lives of people in
  different parts of the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6817-2
  a curric:KeyLearningPoint ;
  rdfs:label "Photographs can be used to investigate and compare Arusha and my local area."@en ;
  dcterms:modified "2026-06-07T15:30:29.354955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6817-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are similarities and differences between the physical and human features in
  Arusha and my own local area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3170-1
  a curric:KeyLearningPoint ;
  rdfs:label """An imaginary scenario can help us to plan what we would show an alien visiting our
  school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3170-2
  a curric:KeyLearningPoint ;
  rdfs:label """Routes can be plotted on large-scale maps and aerial photographs of familiar places,
  e.g. the school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3170-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographical vocabulary is used to name and describe familiar places, e.g. features
  of the school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3167-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is summer in the UK in June, July and August."@en ;
  dcterms:modified "2026-06-07T15:30:29.369091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3167-2
  a curric:KeyLearningPoint ;
  rdfs:label "Summer is the hottest time of the year and has the most hours of daylight."@en ;
  dcterms:modified "2026-06-07T15:30:29.369094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3167-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can see signs of summer by observing weather, plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.369098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3167-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make and compare seasonal maps of the school grounds to help us talk about
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3168-1
  a curric:KeyLearningPoint ;
  rdfs:label "In the UK, spring falls in the months of March, April and May."@en ;
  dcterms:modified "2026-06-07T15:30:29.373712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3168-2
  a curric:KeyLearningPoint ;
  rdfs:label "In spring, the days start to get warmer and there are more hours of daylight."@en ;
  dcterms:modified "2026-06-07T15:30:29.373716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3168-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can see signs of spring by observing the weather, plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.373736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3168-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make and compare seasonal maps of the school grounds to help us talk about
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3149-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photographs can give clues about the location where they were taken."@en ;
  dcterms:modified "2026-06-07T15:30:29.373744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3149-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use locational language to describe where things are e.g. the location of a toy
  in the school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3149-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers can record places on an aerial photograph e.g. the location of a toy in
  the school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3149-4
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers can follow or record a route on a map; large scale maps are best for
  small areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3173-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Journey sticks’ help us remember what we saw during a fieldtrip."@en ;
  dcterms:modified "2026-06-07T15:30:29.378431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3173-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing photographs helps recall of a journey and places visited."@en ;
  dcterms:modified "2026-06-07T15:30:29.378435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3173-3
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers make maps to show what places are like and to show routes."@en ;
  dcterms:modified "2026-06-07T15:30:29.378439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3173-4
  a curric:KeyLearningPoint ;
  rdfs:label """Models or maps made from memory are not usually very accurate, but show what is
  important to the maker."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6816-1
  a curric:KeyLearningPoint ;
  rdfs:label "Google Earth can be used to locate places in Tanzania."@en ;
  dcterms:modified "2026-06-07T15:30:29.381911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6816-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different human and physical features in Tanzania."@en ;
  dcterms:modified "2026-06-07T15:30:29.381915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6816-3
  a curric:KeyLearningPoint ;
  rdfs:label "Google Earth can be used to investigate Tanzania’s human and physical features."@en ;
  dcterms:modified "2026-06-07T15:30:29.381919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2596-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human features are things that are made by people and physical features occur
  naturally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2596-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial photographs and satellite images are useful for finding out about
  Jamaica."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2596-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial photographs and satellite images can be labelled to show physical and human
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3155-1
  a curric:KeyLearningPoint ;
  rdfs:label """In investigations, geographers collect and organise information to sort and
  rank it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3155-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many different means of transport are used to travel to school, e.g. bus, walk, car,
  train, bike."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3155-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphs showing information (or data) from fieldwork or surveys can help us discuss
  and analyse what has been found out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3155-4
  a curric:KeyLearningPoint ;
  rdfs:label """People have different reasons for choosing how they travel, e.g. distance, time
  available, safety, the weather, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3151-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial images and large-scale maps can be used to find and identify our homes and
  other familiar features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3151-2
  a curric:KeyLearningPoint ;
  rdfs:label """Locational vocabulary is used to describe the location of our homes and other local
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3151-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of homes: terraced/semi-detached/detached houses, flats,
  bungalows, cottages, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2572-1
  a curric:KeyLearningPoint ;
  rdfs:label """The River Thames was one of the earliest transport routes: people travelled up and
  down the river in boats for trade."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2572-2
  a curric:KeyLearningPoint ;
  rdfs:label """London is famous for its red double decker buses, black taxi cabs and its London
  Underground tube trains."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2572-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are special rules to help keep the most polluting cars out of central
  London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2572-4
  a curric:KeyLearningPoint ;
  rdfs:label """To reduce pollution, a network of bicycles and electric scooters are available to
  hire in London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9357-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is autumn in the UK in September, October and November."@en ;
  dcterms:modified "2026-06-07T15:30:29.394033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9357-2
  a curric:KeyLearningPoint ;
  rdfs:label "In autumn, the days start to get colder and there are fewer hours of daylight."@en ;
  dcterms:modified "2026-06-07T15:30:29.394037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9357-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can see signs of autumn by observing the weather, plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.394041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9357-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make and compare seasonal maps of the school grounds to help us talk about
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3152-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most local areas include geographical features such as houses, shops, places of
  worship and green spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3152-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital maps can switch from aerial to map view to help identify the familiar
  features of the local area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3152-3
  a curric:KeyLearningPoint ;
  rdfs:label """Locational language, maps, aerial images and fieldwork are used to identify and
  locate features in the local area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2567-1
  a curric:KeyLearningPoint ;
  rdfs:label "England is mountainous in the north and west, and flatter in the south and east."@en ;
  dcterms:modified "2026-06-07T15:30:29.401990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2567-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most people in the UK live in England; there are lots of cities, towns and
  villages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2567-3
  a curric:KeyLearningPoint ;
  rdfs:label """The countryside in England has smaller towns and villages, farmland, forests, lakes
  and moorland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2567-4
  a curric:KeyLearningPoint ;
  rdfs:label "England's coastline has many sandy beaches."@en ;
  dcterms:modified "2026-06-07T15:30:29.402002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3166-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is winter in the UK in December, January and February."@en ;
  dcterms:modified "2026-06-07T15:30:29.402608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3166-2
  a curric:KeyLearningPoint ;
  rdfs:label "Winter is the coldest time of the year and has the fewest hours of daylight."@en ;
  dcterms:modified "2026-06-07T15:30:29.402612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3166-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can see signs of winter by observing the weather, plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.402616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3166-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make and compare seasonal maps of the school grounds to help us talk about
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2598-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different crops are suited to different climates."@en ;
  dcterms:modified "2026-06-07T15:30:29.409608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Questions are a useful way to learn more about farming in Jamaica."@en ;
  dcterms:modified "2026-06-07T15:30:29.409612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2598-3
  a curric:KeyLearningPoint ;
  rdfs:label "We are connected to different countries by the food we eat."@en ;
  dcterms:modified "2026-06-07T15:30:29.409616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2598-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bananas, sugar, yams, peppers, tomatoes and peas all grow in Jamaica."@en ;
  dcterms:modified "2026-06-07T15:30:29.409620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2569-1
  a curric:KeyLearningPoint ;
  rdfs:label """The highest mountain in Northern Ireland is Slieve Donard in the Mourne mountains to
  the south east."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2569-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most people in Northern Ireland live in Belfast, Northern Ireland's Capital and
  biggest city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2569-3
  a curric:KeyLearningPoint ;
  rdfs:label """The countryside in Northern Ireland has small towns and villages, farms, forests and
  the UK's largest lake, Lough Neagh."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2569-4
  a curric:KeyLearningPoint ;
  rdfs:label "Northern Ireland has some incredible coastal features, e.g. Giant's Causeway."@en ;
  dcterms:modified "2026-06-07T15:30:29.410070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3158-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is hard to make a 2D map of a 3D world and so maps of the world can look quite
  different from each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3158-2
  a curric:KeyLearningPoint ;
  rdfs:label "We call large blocks of land continents and there are seven of these on Earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.411028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3158-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are seven continents: Europe, Africa, North America, South America, Asia,
  Oceania and Antarctica."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some continents, such as North and South America, are connected and some, such as
  Oceania, include lots of islands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3165-1
  a curric:KeyLearningPoint ;
  rdfs:label """We have seasons because Earth is tilted on its axis as it orbits the Sun
  each year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3165-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each season has its own weather patterns and we can use weather data to talk about
  this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3165-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the North Pole is tilted away from the Sun, UK days have fewer hours of
  daylight, are colder, and it’s winter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3165-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the North Pole is tilted towards the Sun, UK days have more hours of daylight,
  are warmer, and it’s summer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3171-1
  a curric:KeyLearningPoint ;
  rdfs:label """Maps of different scales, or a zoom function on a digital map, may be needed to
  locate pupils’ favourite play places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3171-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial photographs and large-scale maps show local features, including play
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3171-3
  a curric:KeyLearningPoint ;
  rdfs:label "Aerial photographs and large-scale maps can be used to plan routes."@en ;
  dcterms:modified "2026-06-07T15:30:29.413192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3171-4
  a curric:KeyLearningPoint ;
  rdfs:label """Play areas need to be accessed safely so thinking about routes and access is
  important."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3164-1
  a curric:KeyLearningPoint ;
  rdfs:label """A thermometer measures how hot or cold the air is and the reading can be affected by
  the time of day or season."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3164-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can measure rainfall using a gauge or count the number of rainy days within a
  given time, such as a week."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3164-3
  a curric:KeyLearningPoint ;
  rdfs:label "A weather vane uses compass directions to show where the wind is coming from."@en ;
  dcterms:modified "2026-06-07T15:30:29.414114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3164-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can build up a better picture of the weather pattern by taking weather readings
  at the same time and place each day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3145-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each school has a name that tells it apart from others."@en ;
  dcterms:modified "2026-06-07T15:30:29.415441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3145-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are names for the different school buildings and parts of the grounds such as
  playground, field, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3145-3
  a curric:KeyLearningPoint ;
  rdfs:label """The address of the school includes its name, the road, the suburb or village and
  possibly a town or city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3145-4
  a curric:KeyLearningPoint ;
  rdfs:label "Maps and addresses tell us where a place is located."@en ;
  dcterms:modified "2026-06-07T15:30:29.415455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3157-1
  a curric:KeyLearningPoint ;
  rdfs:label """The round Earth is covered with water and land, and above that is the
  atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3157-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use models, called globes, and photographs taken from space to think about what
  the world is like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3157-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most of the surface of the world (over 70%) is covered with water, which is why
  Earth is known as the Blue Planet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3157-4
  a curric:KeyLearningPoint ;
  rdfs:label """The colours on a globe or satellite image give us information, such as whether it’s
  land or ocean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2594-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maps can be used to locate the Caribbean Sea and the countries there."@en ;
  dcterms:modified "2026-06-07T15:30:29.423880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Compass directions (north, east, south and west) can be used to describe the
  location of Caribbean countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2594-3
  a curric:KeyLearningPoint ;
  rdfs:label "The UK and Caribbean are connected in many different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.423888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Places close to the Equator have a hot and wet climate which are perfect conditions
  for tropical rainforests."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2585-2
  a curric:KeyLearningPoint ;
  rdfs:label """Temperatures in the Tropics temperatures reach over 24° Celsius every day of the
  year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2585-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests support a great diversity of plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.425479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2585-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fruit such as pineapples, bananas and mangoes grow well in tropical regions."@en ;
  dcterms:modified "2026-06-07T15:30:29.425485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3175-1
  a curric:KeyLearningPoint ;
  rdfs:label "People have different points of view about what makes a place special."@en ;
  dcterms:modified "2026-06-07T15:30:29.426643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3175-2
  a curric:KeyLearningPoint ;
  rdfs:label """Places have features that can be named and described, and places also trigger
  different kinds of feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3175-3
  a curric:KeyLearningPoint ;
  rdfs:label "Maps can be annotated using a range of symbols including emoji symbols."@en ;
  dcterms:modified "2026-06-07T15:30:29.426655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3175-4
  a curric:KeyLearningPoint ;
  rdfs:label """If geographers draw maps of their special places, they will show similarities and
  differences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2580-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals like polar bears live within the Arctic Circle and have special features to
  live in this environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2580-2
  a curric:KeyLearningPoint ;
  rdfs:label """Polar bears hibernate during the harsh Arctic winter and emerge during the summer
  months to hunt seals from the ice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2580-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing ice cover due to climate change means that some polar bear habitats are
  under threat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2580-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Arctic ice is usually greatest in March after winter and least in September
  after the summer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2589-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maps and fieldwork can help us identify key features and where they are."@en ;
  dcterms:modified "2026-06-07T15:30:29.437561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Marshes are low-lying, wet places near rivers and coasts, that often flood, and they
  attract a range of wildlife."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2589-3
  a curric:KeyLearningPoint ;
  rdfs:label """People do lots of different jobs: some need to be done wherever you live and some
  are unique to a locality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2568-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wales is very mountainous, its highest mountain is Yr Wyddfa (Snowdon) in North
  Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2568-2
  a curric:KeyLearningPoint ;
  rdfs:label "The biggest cities in Wales are in the south."@en ;
  dcterms:modified "2026-06-07T15:30:29.587968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2568-3
  a curric:KeyLearningPoint ;
  rdfs:label """The countryside in Wales has smaller towns and villages, farmland, forests, lakes
  and moorland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2568-4
  a curric:KeyLearningPoint ;
  rdfs:label "Wales has a varied coastline with some major ports."@en ;
  dcterms:modified "2026-06-07T15:30:29.587976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2593-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a fieldwork safety code to stay safe when completing fieldwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.589954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2593-2
  a curric:KeyLearningPoint ;
  rdfs:label """As well as gathering facts about places, a sense of place can be developed using the
  senses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2593-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interesting and favourite human and physical features can be shared with trails,
  maps and guides for visitors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2593-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fieldwork helps us collect information about a place using first-hand
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6808-1
  a curric:KeyLearningPoint ;
  rdfs:label """Green spaces and trees help soak up noise and pollution too from traffic and provide
  peaceful spots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6808-2
  a curric:KeyLearningPoint ;
  rdfs:label "Maps help us to identify and name green spaces as well as other features."@en ;
  dcterms:modified "2026-06-07T15:30:29.591515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bute Park is a large park located behind Cardiff Castle and close to the shops, and
  the River Taff flows through it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3172-1
  a curric:KeyLearningPoint ;
  rdfs:label """Routes, e.g. to a local play area, can be plotted and followed on different kinds of
  maps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3172-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use maps in fieldwork to find and locate specific features, e.g. in a
  local play area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3172-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use different ways of assessing features and places, such as when
  comparing views about a play area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3172-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journey sticks can help us record and remember what a place is like."@en ;
  dcterms:modified "2026-06-07T15:30:29.591538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3153-1
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers sometimes draw maps from memory, e.g. a map showing things in a street
  outside school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers investigate places by going outside to gather information in different
  ways and we call this fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Risk assessment means thinking about possible dangers and how you can keep yourself
  safe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2570-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial imagery and maps at different scales help us describe where places are using
  geographical vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2570-2
  a curric:KeyLearningPoint ;
  rdfs:label """London is a city near the mouth of the River Thames in the south-east of England and
  the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2570-3
  a curric:KeyLearningPoint ;
  rdfs:label "London is the capital and largest city of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.592278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2579-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Antarctic Circle is an imagined circle around the South Pole that surrounds the
  area known as the Antarctic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2579-2
  a curric:KeyLearningPoint ;
  rdfs:label """Antarctica is a large region, surrounded by the Southern Ocean, and is the coldest
  and windiest continent on Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2579-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some of Antarctica’s Ice Cap is more than four kilometres thick."@en ;
  dcterms:modified "2026-06-07T15:30:29.593433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2579-4
  a curric:KeyLearningPoint ;
  rdfs:label """Antarctica can double in size by the end of the Antarctic winter as the sea ice
  around the continent increases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2591-1
  a curric:KeyLearningPoint ;
  rdfs:label """A long-term pattern of weather is called climate and this can vary within
  the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2591-2
  a curric:KeyLearningPoint ;
  rdfs:label """The climate of the UK shows the south-east and some parts of the south-west, get
  most sunshine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2591-3
  a curric:KeyLearningPoint ;
  rdfs:label """The climate of the UK shows the north-west and mountainous areas get the least
  sunshine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2591-4
  a curric:KeyLearningPoint ;
  rdfs:label """A meteorologist is someone who investigates and measures weather and climate, and
  makes predictions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2599-1
  a curric:KeyLearningPoint ;
  rdfs:label "People go on holiday for different reasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.594652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2599-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tourists visit Jamaica for its climate and geographical features."@en ;
  dcterms:modified "2026-06-07T15:30:29.594656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tourism affects places in different ways; some of these effects can be good and some
  can be bad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3169-1
  a curric:KeyLearningPoint ;
  rdfs:label "We all have opinions on our favourite places to play around school."@en ;
  dcterms:modified "2026-06-07T15:30:29.594863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3169-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial images and large-scale maps show the main features of a place, e.g. the
  school grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3169-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use images, words and maps to help them explain why they like a place
  and how they use it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6797-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff Central railway station is the largest railway station in Wales, used by
  millions of passengers each year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6797-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cardiff is home to the only international airport in Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.594940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6797-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff can be reached by car from England on the M4 motorway, though this is a very
  busy route."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6797-4
  a curric:KeyLearningPoint ;
  rdfs:label """An Aquabus water taxi runs from the city centre to Cardiff Bay and from there to
  Penarth, a nearby town."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6797-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Taff Trail is a mainly traffic-free route from Cardiff to Brecon Beacons
  National Park that can be walked or cycled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6814-1
  a curric:KeyLearningPoint ;
  rdfs:label """Africa is a very large continent with different climates, countries and
  landscapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6814-2
  a curric:KeyLearningPoint ;
  rdfs:label """The compass directions north, south, west and east can be used to describe the
  location of places in Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6814-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can take different routes and types of transport to get to Tanzania from
  the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3174-1
  a curric:KeyLearningPoint ;
  rdfs:label """School grounds can be adapted and changed to provide spaces and features that pupils
  want."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3174-2
  a curric:KeyLearningPoint ;
  rdfs:label "A birds eye perspective is what a seagull might see if it flew overhead."@en ;
  dcterms:modified "2026-06-07T15:30:29.598150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3174-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers make models and maps to share ideas, information and opinions about
  places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2597-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital maps and aerial photographs are useful for finding out about the human
  features in Kingston."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2597-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of settlement in Jamaica."@en ;
  dcterms:modified "2026-06-07T15:30:29.599137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2597-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are similarities and differences between Kingston and the place where
  I live."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2595-1
  a curric:KeyLearningPoint ;
  rdfs:label """A range of resources can be used to investigate the location, climate and features
  of Jamaica."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2595-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical weather and climate have an impact on the environment and daily life."@en ;
  dcterms:modified "2026-06-07T15:30:29.600742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2595-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hurricanes are a type of storm with very strong winds and heavy rain; they can cause
  a lot of damage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3180-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human as well as natural features can be special, e.g. the Riverside Museum in
  Glasgow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3180-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers use images and maps to investigate places, e.g. landmarks."@en ;
  dcterms:modified "2026-06-07T15:30:29.600754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3180-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers sometimes add labels or captions to images and maps to share their
  opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3180-4
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers make models and maps to share their ideas about places, including
  imagined buildings or places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6819-1
  a curric:KeyLearningPoint ;
  rdfs:label """Daily life in Arusha can be investigated using pictures and written sources of
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6819-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways in which our lives are the same as, but also different from,
  other people’s lives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6819-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are similarities and differences between a child’s life in Arusha and my own
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6795-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial imagery and maps at different scales help us describe where places are using
  geographical vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6795-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff is located in the south east of Wales, near the coast and close to the M4
  motorway."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6795-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cardiff is the largest city and capital city of Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.602362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2576-1
  a curric:KeyLearningPoint ;
  rdfs:label """Locally, air temperatures are affected by factors such wind direction and speed,
  shelter and shade."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2576-2
  a curric:KeyLearningPoint ;
  rdfs:label """Globally, as Earth orbits the sun, temperatures are affected by where a place is and
  time of year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2576-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the Northern Hemisphere winter, the North Pole is tilted away from the sun and is
  darker and colder as a result."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2576-4
  a curric:KeyLearningPoint ;
  rdfs:label """While places in the Northern Hemisphere experience winter, the opposite happens in
  the Southern Hemisphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3148-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are lots of different jobs in a primary school and some are easily noticed but
  others are not obvious."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3148-2
  a curric:KeyLearningPoint ;
  rdfs:label "Interviews are a good way of finding out information from people."@en ;
  dcterms:modified "2026-06-07T15:30:29.604639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3148-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interviews need to be planned in advance, to ensure the right questions are
  asked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3148-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interviews can be recorded to help us remember what the person being interviewed
  said."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2577-1
  a curric:KeyLearningPoint ;
  rdfs:label """The geographical North and South Poles mark where Earth’s axis meets Earth’s
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2577-2
  a curric:KeyLearningPoint ;
  rdfs:label """The North Pole is located in the Arctic Ocean and the South Pole in the frozen
  continent of Antarctica."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2577-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Antarctic is colder because of its land mass, with high mountains and the Arctic
  warmer because much is ocean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2577-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ice sheets cover land and ice shelves extend over the ocean."@en ;
  dcterms:modified "2026-06-07T15:30:29.605189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2578-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Arctic Circle is an imagined circle around the North Pole that surrounds the
  area known as the Arctic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2578-2
  a curric:KeyLearningPoint ;
  rdfs:label """Much of the Artic Ocean around the North Pole is frozen sea ice, two to three metres
  thick, but this reduces in summer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2578-3
  a curric:KeyLearningPoint ;
  rdfs:label """The northern edges of three continents: North America, Europe and Asia, can be found
  within the Arctic Circle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2578-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Arctic Summer has almost continuous daylight and the winter almost continuous
  darkness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Places can be located using their address and postcode."@en ;
  dcterms:modified "2026-06-07T15:30:29.607614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2588-2
  a curric:KeyLearningPoint ;
  rdfs:label "Maps and keys help us locate places, give directions and plan journeys."@en ;
  dcterms:modified "2026-06-07T15:30:29.607653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the scale on a map by zooming in or out shows us different views of a
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2588-4
  a curric:KeyLearningPoint ;
  rdfs:label "Public transport such as buses, trains and planes, are shared means of travel."@en ;
  dcterms:modified "2026-06-07T15:30:29.607663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3179-1
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use images and maps to investigate places, e.g. the ‘Seven wonders of
  the natural world’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3179-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers sometimes add labels or captions to images to share their opinions."@en ;
  dcterms:modified "2026-06-07T15:30:29.608436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3179-3
  a curric:KeyLearningPoint ;
  rdfs:label """Surveys help geographers find out what people do or think, e.g. what is their
  favourite natural wonder?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.608440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2584-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sun’s energy is more concentrated when it is directly overhead: in the tropics
  this happens throughout the year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2584-2
  a curric:KeyLearningPoint ;
  rdfs:label """The tropics are areas either side of the equator where the sun remains high in the
  sky throughout the year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2584-3
  a curric:KeyLearningPoint ;
  rdfs:label "Places that are hot and wet all year round are found at the Equator."@en ;
  dcterms:modified "2026-06-07T15:30:29.608794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2584-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hot and dry areas called hot deserts can be found on the northern and southern edges
  of the tropical region."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3160-1
  a curric:KeyLearningPoint ;
  rdfs:label """The ocean is a vast joined-up area of salt water covering nearly three-quarters of
  Earth's surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3160-2
  a curric:KeyLearningPoint ;
  rdfs:label "We have five named ocean areas: Pacific, Atlantic, Indian, Arctic and Southern."@en ;
  dcterms:modified "2026-06-07T15:30:29.609214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3160-3
  a curric:KeyLearningPoint ;
  rdfs:label "Oceans are very important for all life on Earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.609218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2571-1
  a curric:KeyLearningPoint ;
  rdfs:label """A capital city is where a country's government has its headquarters and where it
  makes important decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2571-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many people commute to London for work and millions of tourists visit or travel
  through the city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2571-3
  a curric:KeyLearningPoint ;
  rdfs:label """London has many important buildings and landmarks, such as Buckingham Palace, the
  Elizabeth Tower and Big Ben."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3176-1
  a curric:KeyLearningPoint ;
  rdfs:label "A favourite visited place may be nearby, or far away, even in another country."@en ;
  dcterms:modified "2026-06-07T15:30:29.610368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3176-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geographical vocabulary helps us talk about why places are special to us."@en ;
  dcterms:modified "2026-06-07T15:30:29.610372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers make connections between what a place is like and the activities that
  are possible there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3176-4
  a curric:KeyLearningPoint ;
  rdfs:label "All places can be located using maps and globes or atlases."@en ;
  dcterms:modified "2026-06-07T15:30:29.610399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many streets include a range of buildings, including homes, shops, places of
  worship, offices, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3154-2
  a curric:KeyLearningPoint ;
  rdfs:label """When doing fieldwork geographers use large-scale maps to locate their position and
  features they see."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3154-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use maps, labels and photographs to share information about places they
  have investigated through fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6672-1
  a curric:KeyLearningPoint ;
  rdfs:label "Continents are divided into smaller areas known as countries."@en ;
  dcterms:modified "2026-06-07T15:30:29.610416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6672-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UK is a country located in Europe with the Atlantic Ocean to its west."@en ;
  dcterms:modified "2026-06-07T15:30:29.610420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6672-3
  a curric:KeyLearningPoint ;
  rdfs:label "We may have friends and family who live in other countries in the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.610424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6672-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can locate the UK on a globe and our location in the UK on a map."@en ;
  dcterms:modified "2026-06-07T15:30:29.610428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6809-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different ways to travel to Cardiff such as long distance trains, or
  national and international flights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6809-2
  a curric:KeyLearningPoint ;
  rdfs:label """Travel guides can help you decide where you want to go when you are visiting a new
  place, like Cardiff."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6809-3
  a curric:KeyLearningPoint ;
  rdfs:label """Locating the landmarks and places you want to visit will help you map the best route
  for seeing as many as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6809-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once in Cardiff, maps and travel tools can help you identify the best routes to get
  to where you need to go."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2583-1
  a curric:KeyLearningPoint ;
  rdfs:label """Due to its inaccessibility, the continent of Antarctica has only been visited and
  explored over the past 250 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2583-2
  a curric:KeyLearningPoint ;
  rdfs:label """People first went to the Southern Ocean and Antarctica hunting for whales, then
  explorers raced to the South Pole."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2583-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Antarctic Treaty is there to protect the continent and states no one country can
  claim it as its own."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2583-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is no permanent population in Antarctica but scientists and tourists visit the
  continent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6798-1
  a curric:KeyLearningPoint ;
  rdfs:label """The River Taff flows from the north to the south of the city and drains into Cardiff
  Bay, a freshwater lake."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6798-2
  a curric:KeyLearningPoint ;
  rdfs:label """Over 200 years ago, a famous engineer called Isambard Kingdom Brunel changed the
  course of the River Taff."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6798-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff Station was then built in an area that used to flood before the river was
  diverted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6798-4
  a curric:KeyLearningPoint ;
  rdfs:label """The River Taff used to be heavily polluted but is now home to trout, salmon and
  other wildlife."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3161-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers carry water from high places such as mountains to a sea, ocean or lake."@en ;
  dcterms:modified "2026-06-07T15:30:29.612749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3161-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are rivers on every continent, and some of the biggest rivers are the Nile and
  the Amazon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.612753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6818-1
  a curric:KeyLearningPoint ;
  rdfs:label "People around the world do many different jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.613413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6818-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arusha’s climate and geographical features affect some of the jobs that people do
  there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6818-3
  a curric:KeyLearningPoint ;
  rdfs:label "Talking to people is one way of finding out about what a place is like."@en ;
  dcterms:modified "2026-06-07T15:30:29.613422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2574-1
  a curric:KeyLearningPoint ;
  rdfs:label """People settled by the River Thames for navigation, trade and a water supply. Today,
  many bridges connect both banks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2574-2
  a curric:KeyLearningPoint ;
  rdfs:label """Today, Londoners use the most water in the country; much of this comes from the
  River Thames."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2574-3
  a curric:KeyLearningPoint ;
  rdfs:label """Waste water is also pumped into the River Thames, which is why a new super sewer is
  being built."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2574-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Thames’ Barrier is a special piece of engineering that is designed to protect
  London from flooding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6815-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photographs can be used to investigate the geography of Tanzania."@en ;
  dcterms:modified "2026-06-07T15:30:29.613834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6815-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tanzania has a warm climate that varies across the country."@en ;
  dcterms:modified "2026-06-07T15:30:29.613838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6815-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are a range of landscapes in Tanzania."@en ;
  dcterms:modified "2026-06-07T15:30:29.613844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3150-1
  a curric:KeyLearningPoint ;
  rdfs:label """Recording daily weather conditions (e.g. temperature, wind direction and speed)
  develops weather-specific vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3150-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four seasons, and signs of each of them can be seen in the school
  grounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fieldwork outside, e.g. finding signs of autumn, develops geographical vocabulary,
  observation and recording skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3150-4
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers take photographs, draw pictures, make models, or add information to maps
  to record what they notice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2564-1
  a curric:KeyLearningPoint ;
  rdfs:label """The United Kingdom, called the UK for short, is a country that is part of the
  continent of Europe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2564-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK consists of a large island, part of another island and many smaller
  islands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2564-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is separated from Europe by the North Sea and English Channel, and from
  Ireland by the Irish Sea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6671-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mountains are areas of land that are much higher than the land around them."@en ;
  dcterms:modified "2026-06-07T15:30:29.615015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6671-2
  a curric:KeyLearningPoint ;
  rdfs:label """A group of mountains in one area is called a mountain range, and there are mountain
  ranges on every continent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6671-3
  a curric:KeyLearningPoint ;
  rdfs:label "Every continent has some special places and landmarks."@en ;
  dcterms:modified "2026-06-07T15:30:29.615025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6671-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the natural features in the world, such as the Grand Canyon in North
  America, are called landmarks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6671-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are some built features that are amazing too, such as the Pyramids in Egypt
  and the Taj Mahal in India."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3147-1
  a curric:KeyLearningPoint ;
  rdfs:label """People may have similar and different ideas about the most important feature of a
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3147-2
  a curric:KeyLearningPoint ;
  rdfs:label """Real and relevant questions from people help geographers find out what others want
  to know about a place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3147-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers add captions or labels to photographs to share information and opinions
  about places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3147-4
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers might talk about the evidence they have collected to find out what
  others think."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2582-1
  a curric:KeyLearningPoint ;
  rdfs:label """Greenland is the largest non-continent island in the world, and nearly 80,000 people
  live there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2582-2
  a curric:KeyLearningPoint ;
  rdfs:label """Greenland is part of the Kingdom of Denmark, in Europe, but is geographically part
  of the North America continent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2582-3
  a curric:KeyLearningPoint ;
  rdfs:label """Because Greenlanders need to live by the coast, fishing is important. Fish and seal
  are the main catches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2582-4
  a curric:KeyLearningPoint ;
  rdfs:label """Houses are often made from stone, concrete and corrugated metal as few trees grow
  there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3163-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather describes the conditions of the outside world at any one time."@en ;
  dcterms:modified "2026-06-07T15:30:29.616477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3163-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wind direction is the direction that the wind is coming from: a north wind blows
  from the north."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3163-3
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature is a measure of how hot or cold it is."@en ;
  dcterms:modified "2026-06-07T15:30:29.616488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3163-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fresh water that falls to the ground from clouds can take different forms, such as
  rain, snow, hail or sleet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many people leave the UK when they go on holiday to seek sunshine and warmth,
  especially during the winter months."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2587-2
  a curric:KeyLearningPoint ;
  rdfs:label "The right clothes and equipment can help protect us from extreme heat and cold."@en ;
  dcterms:modified "2026-06-07T15:30:29.616925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many homes and offices in hot climates have air conditioning installed, although
  this uses a lot of energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2587-4
  a curric:KeyLearningPoint ;
  rdfs:label """The hot and wet areas of the world also attract insects like mosquitoes that might
  sting or bite."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6796-1
  a curric:KeyLearningPoint ;
  rdfs:label """A capital city is where the Government has their headquarters and makes important
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6796-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Welsh name for Cardiff is Caerdydd; the Welsh language is widely spoken in
  Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6796-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff Castle is on a site that is nearly 2000 years old and is an important
  landmark and tourist attraction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6796-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiff grew into a large settlement very quickly because it was an important centre
  for the coal industry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3146-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerial photographs help us identify the main features of a school and its
  surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3146-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers go outside to gather information in different ways and we call this
  fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3146-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographers use photographs and sketches with labels to share opinions, information
  and ideas about places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3146-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use locational vocabulary to describe where things are. E.g., the location of
  familiar features in the school ground."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3156-1
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers make maps to show journeys, e.g. their route to school."@en ;
  dcterms:modified "2026-06-07T15:30:29.627103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Map-makers use symbols and colours to show information and sometimes maps need a
  key."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3156-3
  a curric:KeyLearningPoint ;
  rdfs:label "The routes most walked or travelled may show the same buildings and landmarks."@en ;
  dcterms:modified "2026-06-07T15:30:29.627185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2581-1
  a curric:KeyLearningPoint ;
  rdfs:label "All the creatures that come to the Antarctic feed in the sea."@en ;
  dcterms:modified "2026-06-07T15:30:29.635077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2581-2
  a curric:KeyLearningPoint ;
  rdfs:label "Penguins are only found in the Southern Hemisphere."@en ;
  dcterms:modified "2026-06-07T15:30:29.635082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2581-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many species of penguin visit the Antarctic during the summer because of the
  abundant food and hours of daylight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2581-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Emperor Penguin is the only species of penguin that remains in the Antarctic
  throughout the winter months."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635090Z"^^xsd:dateTime .

