  schema:name "farmland"@en ;
  schema:description """Farmland is land used for the growing and harvesting of crops or rearing
  animals for food or raw materials."""@en ;
  dcterms:modified "2026-06-07T15:30:02.415106Z"^^xsd:dateTime .

oakcurric:keyword-photograph
  a curric:Keyword ;
  schema:name "photograph"@en ;
  schema:description "a picture made using a camera"@en ;
  dcterms:modified "2026-06-07T15:30:02.415162Z"^^xsd:dateTime .

oakcurric:keyword-celebrate
  a curric:Keyword ;
  schema:name "celebrate"@en ;
  schema:description "When we celebrate we acknowledge an important date, event or place."@en ;
  dcterms:modified "2026-06-07T15:30:02.415855Z"^^xsd:dateTime .

oakcurric:keyword-sense-of-place
  a curric:Keyword ;
  schema:name "sense of place"@en ;
  schema:description """A sense of place is the character of a place, or the meaning that people
  apply to it, including how we feel about a place."""@en ;
  dcterms:modified "2026-06-07T15:30:02.415860Z"^^xsd:dateTime .

oakcurric:keyword-trail
  a curric:Keyword ;
  schema:name "trail"@en ;
  schema:description """A trail can be a rough marked path or a marked path with guidance about a
