# ----------------------------------------------------------------------
# Prior Knowledge Requirements
# ----------------------------------------------------------------------

oakcurric:priorknowledge-206-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Knowledge of the locality including school, home and the local area, including
  through fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:29:25.156221Z"^^xsd:dateTime .

oakcurric:priorknowledge-206-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some experience of using simple mapping techniques to locate and annotate
  places."""@en ;
  dcterms:modified "2026-06-07T15:29:25.156234Z"^^xsd:dateTime .

oakcurric:priorknowledge-203-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should know that the UK is made up of England, Scotland, Wales and Northern
  Ireland."""@en ;
  dcterms:modified "2026-06-07T15:29:25.318958Z"^^xsd:dateTime .

oakcurric:priorknowledge-203-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to locate England, Scotland, Wales and Northern Ireland using an
  atlas or map."""@en ;
