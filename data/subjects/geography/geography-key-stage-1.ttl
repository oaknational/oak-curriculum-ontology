# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "range"@en ;
  schema:description "the range of pitches that an instrument is capable of playing"@en ;
  dcterms:modified "2026-06-07T15:30:02.347362Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-trade
  a curric:Keyword ;
  schema:name "trade"@en ;
  schema:description "Trade is the exchange of goods, commodities and services."@en ;
  dcterms:modified "2026-06-07T15:30:02.348359Z"^^xsd:dateTime .

oakcurric:keyword-atmosphere
  a curric:Keyword ;
  schema:name "atmosphere"@en ;
  schema:description "the mood created in a section or whole of a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348363Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-natural
  a curric:Keyword ;
  schema:name "natural"@en ;
  schema:description """the natural symbol is used to show a note in the bar has returned to the
  normal pitch"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348642Z"^^xsd:dateTime .

oakcurric:keyword-government
  a curric:Keyword ;
  schema:name "government"@en ;
  schema:description """a government is a group of leaders who make laws and decisions for a
  country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350145Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "a long-term change in Earth’s climate patterns"@en ;
  dcterms:modified "2026-06-07T15:30:02.350396Z"^^xsd:dateTime .

oakcurric:keyword-symbol
  a curric:Keyword ;
  schema:name "symbol"@en ;
  schema:description """a word, object, or image that represents a bigger idea or meaning beyond
  itself"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350718Z"^^xsd:dateTime .

oakcurric:keyword-urban
  a curric:Keyword ;
  schema:name "urban"@en ;
  schema:description """relating to a city or town; often busy, built-up areas with lots of human
  activity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350839Z"^^xsd:dateTime .

oakcurric:keyword-temperature
  a curric:Keyword ;
  schema:name "temperature"@en ;
  schema:description """a measure of how hot a substance is; it is related to the kinetic energy of
  the individual particles"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351318Z"^^xsd:dateTime .

oakcurric:keyword-cycle
  a curric:Keyword ;
  schema:name "cycle"@en ;
  schema:description """a cycle is a sequence of events that occur repeatedly and follow the same
  pattern each time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351550Z"^^xsd:dateTime .

oakcurric:keyword-label
  a curric:Keyword ;
  schema:name "label"@en ;
  schema:description """each piece of data is annotated with one or more labels which provide
  information about that data"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351564Z"^^xsd:dateTime .

oakcurric:keyword-community
  a curric:Keyword ;
  schema:name "community"@en ;
  schema:description "a group of people who share something in common"@en ;
  dcterms:modified "2026-06-07T15:30:02.352054Z"^^xsd:dateTime .

oakcurric:keyword-axis
  a curric:Keyword ;
  schema:name "axis"@en ;
