  dcterms:modified "2026-06-07T15:30:02.416568Z"^^xsd:dateTime .

oakcurric:keyword-street
  a curric:Keyword ;
  schema:name "street"@en ;
  schema:description "A street is a road, usually with houses or buildings on both sides."@en ;
  dcterms:modified "2026-06-07T15:30:02.416574Z"^^xsd:dateTime .

oakcurric:keyword-river-mouth
  a curric:Keyword ;
  schema:name "river mouth"@en ;
  schema:description "The mouth of a river is where it enters the sea or a lake."@en ;
  dcterms:modified "2026-06-07T15:30:02.416855Z"^^xsd:dateTime .

oakcurric:keyword-antarctic-circle
  a curric:Keyword ;
  schema:name "Antarctic Circle"@en ;
  schema:description """An imaginary line around the earth which surrounds the southern polar region
