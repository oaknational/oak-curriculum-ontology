oakcurric:keyword-english-channel
  a curric:Keyword ;
  schema:name "English Channel"@en ;
  schema:description """The English Channel is a narrow part of the Atlantic Ocean that separates
  the south coast of England from France."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423073Z"^^xsd:dateTime .

oakcurric:keyword-built
  a curric:Keyword ;
  schema:name "built"@en ;
  schema:description "Something that is built has been made by humans."@en ;
  dcterms:modified "2026-06-07T15:30:02.423081Z"^^xsd:dateTime .

oakcurric:keyword-ground-level-photograph
  a curric:Keyword ;
  schema:name "ground level photograph"@en ;
  schema:description """A ground level photograph is a picture of an object or place taken from the
  ground."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423333Z"^^xsd:dateTime .

oakcurric:keyword-inuit
  a curric:Keyword ;
  schema:name "Inuit"@en ;
  schema:description "the Inuit are nomadic people who live within the Arctic Circle"@en ;
  dcterms:modified "2026-06-07T15:30:02.423392Z"^^xsd:dateTime .

oakcurric:keyword-sealskin
  a curric:Keyword ;
  schema:name "sealskin"@en ;
  schema:description """sealskin is the furry skin of seals, which is used to make a variety of good
  such as clothes, shoes and rugs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423400Z"^^xsd:dateTime .

oakcurric:keyword-weather-vane
  a curric:Keyword ;
  schema:name "weather vane"@en ;
  schema:description """A weather vane is a tool for showing from which direction the wind is
  blowing."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423483Z"^^xsd:dateTime .

oakcurric:keyword-sunscreen
  a curric:Keyword ;
  schema:name "sunscreen"@en ;
  schema:description """Sunscreen is a cream that you rub on your skin to protect it and stop it
  from burning in the sun."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423705Z"^^xsd:dateTime .

oakcurric:keyword-insect-repellent
  a curric:Keyword ;
  schema:name "insect repellent"@en ;
  schema:description """Insect repellent is a spray which stops insects such as mosquitoes from
  biting you."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423713Z"^^xsd:dateTime .

oakcurric:keyword-holiday-resort
  a curric:Keyword ;
  schema:name "holiday resort"@en ;
  schema:description "A holiday resort is a place where a lot of people go on holiday."@en ;
