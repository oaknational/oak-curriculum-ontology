oakcurric:keyword-school-grounds
  a curric:Keyword ;
  schema:name "school grounds"@en ;
  schema:description "The school grounds are all the outside spaces at a school."@en ;
  dcterms:modified "2026-06-07T15:30:02.417554Z"^^xsd:dateTime .

oakcurric:keyword-railway-station
  a curric:Keyword ;
  schema:name "railway station"@en ;
  schema:description """A railway station is a place where trains stop so that people can get on or
