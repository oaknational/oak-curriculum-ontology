  dcterms:modified "2026-06-07T15:30:02.415868Z"^^xsd:dateTime .

oakcurric:keyword-journey-stick
  a curric:Keyword ;
  schema:name "journey stick"@en ;
  schema:description """A journey stick is a way to remember a route by collecting items on the
  route and fixing them to a stick."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416557Z"^^xsd:dateTime .

oakcurric:keyword-play-equipment
  a curric:Keyword ;
  schema:name "play equipment"@en ;
  schema:description """Play equipment are structures that children use for play such as swings,
