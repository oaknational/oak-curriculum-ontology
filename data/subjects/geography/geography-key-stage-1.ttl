  dcterms:modified "2026-06-07T15:30:02.352271Z"^^xsd:dateTime .

oakcurric:keyword-survive
  a curric:Keyword ;
  schema:name "survive"@en ;
  schema:description "Survive means to continue to stay alive."@en ;
