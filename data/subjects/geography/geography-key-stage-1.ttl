# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-pupils-think-local-area-either
  a curric:Misconception ;
  curric:statement """Pupils think the local area is either one particular place or has a particular
  size."""@en ;
  curric:correction """Share examples of where we go, and think about this in the context of
  everyday lives in urban and rural areas, using different examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094931Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-parks-playgrounds-play
  a curric:Misconception ;
  curric:statement """Pupils may think that all parks have playgrounds and play equipment like
  swings and climbing frames."""@en ;
  curric:correction """Some parks do have places to play, but not all of them. Parks are natural
  open spaces often with grass or woodlands that we can enjoy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096657Z"^^xsd:dateTime .

oakcurric:misconception-pupils-still-developing-understanding-concept
  a curric:Misconception ;
  curric:statement """Pupils are still developing understanding of the concept of quantifying time
  and as such they can significantly overestimate how much they can do and see in just one
  day."""@en ;
  curric:correction """Remind pupils to think about all the things that we have to do around
  visiting attractions, how long will it take to get to an attraction, what type of
  transport is best to take, what about time for meal breaks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102296Z"^^xsd:dateTime .

oakcurric:misconception-mountainous-areas-scotland
  a curric:Misconception ;
  curric:statement "There are only mountainous areas in Scotland."@en ;
  curric:correction """There are different types of landscapes in Scotland include lakes, rivers and
  mountains. There are also lots of cities, towns and villages."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102909Z"^^xsd:dateTime .

oakcurric:misconception-rural-areas-shops-people-live
  a curric:Misconception ;
  curric:statement "Rural areas have no shops or people that live there."@en ;
  curric:correction """Rural areas are sparsely populated which means there are less people living
  there in comparison to urban areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106928Z"^^xsd:dateTime .

oakcurric:misconception-one-able-live-sahara-desert
  a curric:Misconception ;
  curric:statement "No one is able to live in the Sahara desert."@en ;
  curric:correction "2.5 million people live in the Sahara desert."@en ;
  dcterms:modified "2026-06-07T15:30:15.108580Z"^^xsd:dateTime .

oakcurric:misconception-stereotypical-views-landmark-typifies-our
  a curric:Misconception ;
  curric:statement """Stereotypical views about what a landmark is, and how it typifies our own and
  other countries."""@en ;
  curric:correction """Use and share diverse examples of landmarks and their meanings, include those
  relevant and personal to pupils."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110279Z"^^xsd:dateTime .

oakcurric:misconception-learners-fully-appreciate-diversity-places
  a curric:Misconception ;
  curric:statement """Learners may not fully appreciate the diversity of places within
  countries."""@en ;
  curric:correction "Spend time exploring a range of settlements in different parts of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:15.121102Z"^^xsd:dateTime .

oakcurric:misconception-places-route-visited-random-order
  a curric:Misconception ;
  curric:statement "Places on the route can be visited in a random order."@en ;
  curric:correction """A route has a start point and end point and the stops in between help us find
  the last place of our route. If we visit places in a different order we may get lost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126608Z"^^xsd:dateTime .

oakcurric:misconception-summer-its-hot
  a curric:Misconception ;
  curric:statement "In summer it's always hot."@en ;
  curric:correction """Even though the days are hottest in summer, there are still days that may be
  wet and cold."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126613Z"^^xsd:dateTime .

oakcurric:misconception-flowers-bloom-its-sunny-children
  a curric:Misconception ;
  curric:statement """When flowers bloom and it's sunny, some children might mistake this for
  summer."""@en ;
  curric:correction """Spring falls in the months of March, April and May. In spring, the days start
  to get warmer and there are more hours of daylight, but temperatures are not the hottest
  and the hours of daylight are not the longest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129513Z"^^xsd:dateTime .

oakcurric:misconception-maps-show-get-one-place
  a curric:Misconception ;
  curric:statement "Maps show how to get from one place to another."@en ;
  curric:correction """A map can show a small area in detail. We use maps as representations of
  places. We can study an area in detail using a map."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129518Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-sequence-images-photographs
  a curric:Misconception ;
  curric:statement "You don't need to sequence images or photographs you took on your route."@en ;
  curric:correction """Sequencing photographs (keeping them in the correct order) helps us to
  remember a route correctly and helps us find the correct end point (destination)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131847Z"^^xsd:dateTime .

oakcurric:misconception-learners-difficulties-identifying-different-features
  a curric:Misconception ;
  curric:statement """Learners may have difficulties in identifying different features in satellite
  images and aerial photographs."""@en ;
  curric:correction """Use Google Earth to first locate and zoom in on features near your school
  that are already familiar to learners."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133145Z"^^xsd:dateTime .

oakcurric:misconception-learners-familiar-human-physical-features
  a curric:Misconception ;
  curric:statement """Learners may not be familiar with some of the human and physical features in
  the images from Jamaica."""@en ;
  curric:correction """Spend time exploring aerial photographs and satellite images of your local
  area before investigating ones from Jamaica."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133151Z"^^xsd:dateTime .

oakcurric:misconception-children-use-one-method-transport
  a curric:Misconception ;
  curric:statement "Children only use one method of transport to get to school everyday."@en ;
  curric:correction """Depending on the circumstances on that day, e.g. weather, parent's work
  schedule, public transport delays etc. you might travel to school in different ways on
  different days of the week. We are looking at the most frequent way you travel on average."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133888Z"^^xsd:dateTime .

oakcurric:misconception-houses-look-same
  a curric:Misconception ;
  curric:statement "All houses look the same from above."@en ;
  curric:correction """You can identify that some houses have flat roofs while others have pitched
  roofs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134521Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-buses-red-taxi
  a curric:Misconception ;
  curric:statement """Pupils may think that all buses are red, and all taxi cabs are black or all
  trains are tube trains."""@en ;
  curric:correction """These types of transport are symbolic of London, but they are not the only
  ones in the city; there are many buses and taxis in a variety of colours and there are
  overground trains as well as underground tube trains."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135272Z"^^xsd:dateTime .

oakcurric:misconception-trees-leaves-change-colour
  a curric:Misconception ;
  curric:statement "All trees have leaves that change colour."@en ;
  curric:correction """Evergreen trees are green all year round and do not shed their leaves. Only
  deciduous trees have leaves that change colour in autumn and eventually lose them in
  winter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138222Z"^^xsd:dateTime .

oakcurric:misconception-cities-towns-words-used-describe
  a curric:Misconception ;
  curric:statement """Cities and towns are words used to describe a settlement of the same size
  interchangeably."""@en ;
  curric:correction """Towns are used to describe settlements with a population of thousands whereas
  cities are usually used to describe settlements of over 100 000 or millions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138669Z"^^xsd:dateTime .

oakcurric:misconception-many-people-live-rural-areas
  a curric:Misconception ;
  curric:statement "There are not many people who live in rural areas in England."@en ;
  curric:correction """In 2020, 12.0 million people lived in rural areas – this is 21.3% of the
  England population (gov. website)"""@en ;
  dcterms:modified "2026-06-07T15:30:15.140940Z"^^xsd:dateTime .

oakcurric:misconception-snowing-winter
  a curric:Misconception ;
  curric:statement "It is always snowing in winter."@en ;
  curric:correction """If conditions are right and it is cold enough then it will snow during the
  winter months. There are some days in winter that are mild and not cold."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141131Z"^^xsd:dateTime .

oakcurric:misconception-grow-food-eat-uk
  a curric:Misconception ;
  curric:statement "We grow all the food we eat in the UK."@en ;
  curric:correction """We import lots of the food we eat. Bananas, for example, can be imported from
  Jamaica."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143589Z"^^xsd:dateTime .

oakcurric:misconception-republic-ireland-part-united-kingdom
  a curric:Misconception ;
  curric:statement "Republic of Ireland is a part of the United Kingdom."@en ;
  curric:correction """Republic of Ireland is in the continent of Europe and only Northern Ireland
  is part of the United Kingdom."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143753Z"^^xsd:dateTime .

oakcurric:misconception-africa-country
  a curric:Misconception ;
  curric:statement "Africa is country."@en ;
  curric:correction "The continent of Africa contains 54 countries."@en ;
  dcterms:modified "2026-06-07T15:30:15.143912Z"^^xsd:dateTime .

oakcurric:misconception-earth-orbits-sun-rotate-its
  a curric:Misconception ;
  curric:statement "Earth orbits the Sun and does not rotate on its axis at the same time."@en ;
  curric:correction """Earth rotates on its axis, one full rotation is 24 hours. While it rotates on
  its axis it orbits the Sun. This takes 365 1/4 days, or one year."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143918Z"^^xsd:dateTime .

oakcurric:misconception-direct-route-play-area-safest
  a curric:Misconception ;
  curric:statement "The most direct route to a play area might not be the safest."@en ;
  curric:correction """Just because a route might be the shortest, it does not mean it's the best
  route to take if there are no safe areas or pavements to walk along or safe crossing
  points. The best route must consider the time taken, most direct way and be safest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144634Z"^^xsd:dateTime .

oakcurric:misconception-using-thermometer-take-reading-accurate
  a curric:Misconception ;
  curric:statement """Using a thermometer to take a reading is an accurate representation of the
  temperature."""@en ;
  curric:correction """Temperature can change depending on the time of day. When taking the
  temperature and comparing it over time, it needs to be taken at the same time everyday to
  make it a fair test."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146577Z"^^xsd:dateTime .

oakcurric:misconception-schools-look-same
  a curric:Misconception ;
  curric:statement "All schools look the same."@en ;
  curric:correction """Many schools have the same key features and complete similar activities but
  don't all look the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147074Z"^^xsd:dateTime .

oakcurric:misconception-earth-flat-shaped-like-circle
  a curric:Misconception ;
  curric:statement "Earth is flat and shaped like a circle."@en ;
  curric:correction """Earth is round and shaped like a sphere. It is 3D and not flat. Relate this
  to globes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149483Z"^^xsd:dateTime .

oakcurric:misconception-caribbean-south-america
  a curric:Misconception ;
  curric:statement "The Caribbean is in South America."@en ;
  curric:correction "The Caribbean is in North America."@en ;
  dcterms:modified "2026-06-07T15:30:15.149923Z"^^xsd:dateTime .

oakcurric:misconception-weather-climate-same
  a curric:Misconception ;
  curric:statement "Weather and climate are the same."@en ;
  curric:correction """Weather is the day to day changes in the atmosphere. Climate is the long term
  weather for an area."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150366Z"^^xsd:dateTime .

oakcurric:misconception-special-places-famous-sites-visit
  a curric:Misconception ;
  curric:statement "Special places have to be famous sites or those you visit on holiday."@en ;
  curric:correction """Special places can be places that make you feel different emotions, they can
  include a range of places like your home, school, family home, place of worship etc.
  They're places that make you feel happy and positive and evoke memories."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150736Z"^^xsd:dateTime .

oakcurric:misconception-polar-bears-hunt-penguins-eat
  a curric:Misconception ;
  curric:statement "Polar bears hunt penguins to eat."@en ;
  curric:correction """Penguins live in Antarctica, where there are no polar bears, not in the
  Arctic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151277Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jobs-gendered-e
  a curric:Misconception ;
  curric:statement """Pupils often think that some jobs are gendered - e.g. tractor drivers or
  lifeboat crew are men."""@en ;
  curric:correction """Model jobs being done by a variety of people showing diversity where
  appropriate, in terms of gender, age, ethnicity and ability."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154219Z"^^xsd:dateTime .

oakcurric:misconception-mount-snowdon-tallest-mountain-uk
  a curric:Misconception ;
  curric:statement "Mount Snowdon is the tallest mountain in the UK."@en ;
  curric:correction "Ben Nevis is the tallest mountain in the UK which is in Scotland."@en ;
  dcterms:modified "2026-06-07T15:30:15.155545Z"^^xsd:dateTime .

oakcurric:misconception-everyday-places-live-particular-value
  a curric:Misconception ;
  curric:statement "Everyday places where we live, are of no particular value for fieldwork."@en ;
  curric:correction """Local and ordinary places deserve attention and this can be modelled through
  careful, local investigations that celebrate the everyday."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156185Z"^^xsd:dateTime .

oakcurric:misconception-fieldwork-means-field
  a curric:Misconception ;
  curric:statement "Fieldwork means being in a field."@en ;
  curric:correction """Fieldwork can take place anywhere! It means going outside to observe and
  gather information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156684Z"^^xsd:dateTime .

oakcurric:misconception-streets-outside-schools-across-country
  a curric:Misconception ;
  curric:statement """All streets outside schools across the country have all of these features and
  look the same."""@en ;
  curric:correction """The street outside your school is unique to your school. There might be all,
  some or none of these features. There could be features outside your school that are not
  mentioned here."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156690Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-rivers-simply-stop
  a curric:Misconception ;
  curric:statement """Pupils may think that rivers simply stop or disappear, rather than flow into
  the sea at the mouth."""@en ;
  curric:correction """All rivers flow from their source to their mouth, where they flow into the
  sea. For example, the River Thames flows into the North Sea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156973Z"^^xsd:dateTime .

oakcurric:misconception-antarctica-country
  a curric:Misconception ;
  curric:statement "Antarctica is a country."@en ;
  curric:correction "Antarctica is a continent."@en ;
  dcterms:modified "2026-06-07T15:30:15.157298Z"^^xsd:dateTime .

oakcurric:misconception-pupils-first-encounter-idea-climate
  a curric:Misconception ;
  curric:statement """As pupils first encounter the idea of climate they confuse it with
  weather."""@en ;
  curric:correction """Keep offering different examples and talk about weather being a snapshot of a
  moment in time but climate is a long-term trend of weather."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157630Z"^^xsd:dateTime .

oakcurric:misconception-tourist-go-another-country
  a curric:Misconception ;
  curric:statement "To be a tourist you have to go to another country."@en ;
  curric:correction """Explain that you can be a tourist abroad or in your home country. You could
  sensitively discuss learners' own experiences of going on holiday."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157663Z"^^xsd:dateTime .

oakcurric:misconception-everyone-same-favourite-area-play
  a curric:Misconception ;
  curric:statement "Everyone has the same favourite area to play."@en ;
  curric:correction """Everyone has different opinions and can have different favourite areas to
  play compared to other pupils."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157733Z"^^xsd:dateTime .

oakcurric:misconception-taking-journeys-getting-one-place
  a curric:Misconception ;
  curric:statement """That taking journeys is only about getting from one place to another in an
  efficient way."""@en ;
  curric:correction """Travelling between locations may be about getting there quickly for
  commuters, but journeys can also be taken in free time for pleasure. For example, taking
  long walks in natural places, or bike rides in the countryside are very enjoyable
  journeys."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157744Z"^^xsd:dateTime .

oakcurric:misconception-africa-country-geographically-diverse-continent
  a curric:Misconception ;
  curric:statement "That Africa is a country not a geographically diverse continent."@en ;
  curric:correction """Recap the names of the seven continents and five oceans. Spend more time
  using a map to identify different countries in Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158642Z"^^xsd:dateTime .

oakcurric:misconception-one-way-improve-something
  a curric:Misconception ;
  curric:statement "There is only one way to improve something."@en ;
  curric:correction """Improvements can be in any shape or form. If we think about our school
  grounds it could be to paint some areas, add extra climbing frames/ slides or plant more
  flowers etc. Everyone's ideas about improvements are different and unique."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158648Z"^^xsd:dateTime .

oakcurric:misconception-learners-difficulties-identifying-human-features
  a curric:Misconception ;
  curric:statement """Learners may have difficulties in identifying human features on digital maps
  and aerial photographs."""@en ;
  curric:correction """Use digital maps and aerial photographs to first locate features near your
  school that are already familiar to learners."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158744Z"^^xsd:dateTime .

oakcurric:misconception-hotter-equator-because-close-sun
  a curric:Misconception ;
  curric:statement "It is hotter at the Equator because it is close to the Sun."@en ;
  curric:correction "The Equator is hotter because the Sun's rays are more concentrated."@en ;
  dcterms:modified "2026-06-07T15:30:15.159186Z"^^xsd:dateTime .

oakcurric:misconception-landmarks-new-futuristic-buildings
  a curric:Misconception ;
  curric:statement "Landmarks are only new, futuristic buildings."@en ;
  curric:correction """Historical architecture and buildings linked to past cultures and places are
  also landmarks. These buildings represent places and evoke memories and feelings just as
  much as modern and futuristic buildings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159195Z"^^xsd:dateTime .

oakcurric:misconception-learners-think-life-child-tanzania
  a curric:Misconception ;
  curric:statement """Learners may think that the life of every child in Tanzania (and Africa) is
  like the life of Zahra."""@en ;
  curric:correction """Spend more time discussing the similarities and differences between people in
  the UK to help learners appreciate that there will be many similarities and differences in
  people's lives both within and between countries and places."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159396Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-london-capital-city
  a curric:Misconception ;
  curric:statement "Pupils may think that London is the only capital city in the UK."@en ;
  curric:correction """The UK consists of four countries; England, Scotland, Northern Ireland and
  Wales. Each of these has their own capital city, so London is not the only capital city in
  the UK. Cardiff is the capital city of Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159652Z"^^xsd:dateTime .

oakcurric:misconception-winter-same-time-year-around
  a curric:Misconception ;
  curric:statement "It is winter at the same time of year all around the world."@en ;
  curric:correction "It is winter at the North Pole when it is summer at the South Pole."@en ;
  dcterms:modified "2026-06-07T15:30:15.160236Z"^^xsd:dateTime .

oakcurric:misconception-everyone-works-school-gets-paid
  a curric:Misconception ;
  curric:statement "Everyone who works in a school gets paid."@en ;
  curric:correction """There are many volunteers who work in schools to help them run smoothly.
  These people don't get paid, they give up their time for free."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160436Z"^^xsd:dateTime .

oakcurric:misconception-arctic-antarctica-continents
  a curric:Misconception ;
  curric:statement "The Arctic and Antarctica are both continents."@en ;
  curric:correction "Antarctica is a continent but the Arctic is frozen sea ice."@en ;
  dcterms:modified "2026-06-07T15:30:15.160583Z"^^xsd:dateTime .

oakcurric:misconception-arctic-north-pole
  a curric:Misconception ;
  curric:statement "The Arctic is just at the North Pole."@en ;
  curric:correction """The Arctic is all the area within the Arctic circle, which includes parts of
  Europe, North America and Asia."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161051Z"^^xsd:dateTime .

oakcurric:misconception-large-scale-maps-show-large
  a curric:Misconception ;
  curric:statement "Large scale maps show a large area and small scale maps show a small area."@en ;
  curric:correction "Large scale maps show a small area. Small scale maps show a large area."@en ;
  dcterms:modified "2026-06-07T15:30:15.161460Z"^^xsd:dateTime .

oakcurric:misconception-special-places-landscapes-look-same
  a curric:Misconception ;
  curric:statement "Special places or landscapes all look the same."@en ;
  curric:correction """Special landscapes can look and feel very different to each other. They are
  special because they make you feel different things like awe and wonder."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161784Z"^^xsd:dateTime .

oakcurric:misconception-hot-deserts-mostly-found-equator
  a curric:Misconception ;
  curric:statement "Hot deserts are mostly found at the Equator."@en ;
  curric:correction """Tropical rainforests are found at the Equator. Deserts are mostly found at
  the Tropic of Cancer and Tropic of Capricorn."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161861Z"^^xsd:dateTime .

oakcurric:misconception-pacific-ocean-sides-world
  a curric:Misconception ;
  curric:statement "The Pacific ocean is on both sides of the world."@en ;
  curric:correction """The world is round and spherical in shape like a ball. If we cut it and lay
  it out flat it will look like there are two Pacific oceans but they are one connected
  ocean when looking at the Earth in a 3D perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162064Z"^^xsd:dateTime .

oakcurric:misconception-commuters-drive-cars-work
  a curric:Misconception ;
  curric:statement "that commuters all drive cars to work"@en ;
  curric:correction """Many people do drive their car to work, but commuters are all the people that
  travel to a place for work using any mode of transport."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162322Z"^^xsd:dateTime .

oakcurric:misconception-best-place-ive-ever-another
  a curric:Misconception ;
  curric:statement "The best place I've ever been to has to be in another country."@en ;
  curric:correction """The best place you have been to can be abroad but it doesn't have to be, it
  can be somewhere you have visited with family or to see family like another town or can be
  a place you went to on a day trip like a theme park, museum or zoo."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162408Z"^^xsd:dateTime .

oakcurric:misconception-features-discussed-slides-way-look
  a curric:Misconception ;
  curric:statement """The features discussed in the slides are the only way they look in real life
  e.g. all houses/ shops/ leisure facilities all look the same (like the pictures in the
  slides)."""@en ;
  curric:correction """Houses, shops, green spaces, places of worship etc. are all unique. The
  features in your area might look the same as the examples or they might look different to
  the examples used. They are still a type of that feature."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162414Z"^^xsd:dateTime .

oakcurric:misconception-ireland-part-uk
  a curric:Misconception ;
  curric:statement "Ireland is part of the UK"@en ;
  curric:correction "Northern Ireland is part of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:15.162420Z"^^xsd:dateTime .

oakcurric:misconception-young-children-still-developing-understanding
  a curric:Misconception ;
  curric:statement """Young children are still developing understanding of the concept of
  quantifying time and as such they can significantly overestimate how much they can do and
  see in just one day."""@en ;
  curric:correction """Remind pupils to think about travel time between points of interest when they
  are planning their route, as well as how long they will spend in each place. Use the
  length of a school day and how it is punctuated with lessons and breaks for comparison."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162504Z"^^xsd:dateTime .

oakcurric:misconception-antarctica-its-own-government
  a curric:Misconception ;
  curric:statement "Antarctica has its own government."@en ;
  curric:correction "Antarctica is protected by the Antarctic Treaty."@en ;
  dcterms:modified "2026-06-07T15:30:15.162641Z"^^xsd:dateTime .

oakcurric:misconception-arent-rivers-antarctica
  a curric:Misconception ;
  curric:statement "There aren't any rivers in Antarctica."@en ;
  curric:correction """There are rivers in every continent. Rivers in Antarctica are frozen or
  beneath a sheet of ice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162920Z"^^xsd:dateTime .

oakcurric:misconception-learners-limited-knowledge-jobs-people
  a curric:Misconception ;
  curric:statement "Learners may have limited knowledge about the jobs that people do."@en ;
  curric:correction """Spend more time at the start of the lesson discussing the different jobs that
  people do in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163144Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-banks-river-actually
  a curric:Misconception ;
  curric:statement """Pupils may think the banks of a river actually \"burst\" in an explosive way
  when there is a flood."""@en ;
  curric:correction """During a flood, the water level of a river is higher than the banks, so the
  water 'bursts' out of the river, over the banks onto the surrounding land."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163152Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stereotypical-views-tanzania-like
  a curric:Misconception ;
  curric:statement """Pupils may have stereotypical views about what Tanzania is like and may not be
  aware of its geographical diversity."""@en ;
  curric:correction """Additional photographs of Tanzania could be found online to further emphasise
  the geographical diversity of this country."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163248Z"^^xsd:dateTime .

oakcurric:misconception-fieldwork-takes-place-field
  a curric:Misconception ;
  curric:statement "Fieldwork only takes place in a field."@en ;
  curric:correction """You can complete fieldwork anywhere as long as you can get outside and look
  for changes and make observations!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.163589Z"^^xsd:dateTime .

oakcurric:misconception-mountain-ranges-antarctica
  a curric:Misconception ;
  curric:statement "There are no mountain ranges in Antarctica."@en ;
  curric:correction "There are mountain ranges on every continent."@en ;
  dcterms:modified "2026-06-07T15:30:15.163738Z"^^xsd:dateTime .

oakcurric:misconception-ground-photos-taken-close-ground
  a curric:Misconception ;
  curric:statement "Ground photos can only be taken close to the ground."@en ;
  curric:correction """They can also be taken at eye level (if you are lying on the floor, sitting
  down or standing up). They all count as ground level photos."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164011Z"^^xsd:dateTime .

oakcurric:misconception-greenland-part-canada
  a curric:Misconception ;
  curric:statement "Greenland is part of Canada."@en ;
  curric:correction "Greenland belongs to the Kingdom of Denmark."@en ;
  dcterms:modified "2026-06-07T15:30:15.164102Z"^^xsd:dateTime .

oakcurric:misconception-weather-day-constant
  a curric:Misconception ;
  curric:statement "The weather for that day is constant."@en ;
  curric:correction """Weather is constantly changing. It can change between hours or even
  minutes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164189Z"^^xsd:dateTime .

oakcurric:misconception-people-uk-go-holiday-france
  a curric:Misconception ;
  curric:statement "Most people from the UK go on holiday to France, if they go abroad."@en ;
  curric:correction "The most common destination is in fact Spain."@en ;
  dcterms:modified "2026-06-07T15:30:15.164323Z"^^xsd:dateTime .

oakcurric:misconception-dont-field-fieldwork
  a curric:Misconception ;
  curric:statement "You don't have to be in a field to be doing fieldwork."@en ;
  curric:correction """Fieldwork means going outside to gather information. Going outside and
  exploring our school grounds is fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164412Z"^^xsd:dateTime .

oakcurric:misconception-symbols-map-key-universal
  a curric:Misconception ;
  curric:statement "All symbols on the map key are universal."@en ;
  curric:correction """Some map keys use different symbols for different places. It's important to
  check the key to make sure you know each symbol means on that particular map as it might
  mean something different to what you are used to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166815Z"^^xsd:dateTime .

oakcurric:misconception-polar-bears-live-antarctica
  a curric:Misconception ;
  curric:statement "Polar bears live in Antarctica."@en ;
  curric:correction "No polar bears live in Antarctica, they live in the Arctic."@en ;
  dcterms:modified "2026-06-07T15:30:15.170145Z"^^xsd:dateTime .
