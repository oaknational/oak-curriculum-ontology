# ----------------------------------------------------------------------
# Units
# ----------------------------------------------------------------------

oakcurric:unit-206
  a curric:Unit ;
  rdfs:label "Local area: why is (our place) special?"@en ;
  curric:slug "local-area-why-is-our-place-special" ;
  rdfs:comment """This unit explores what makes the local area special by identifying key features,
  landmarks and places of interest. Pupils use maps, address and direction language, local
  climate knowledge and fieldwork to describe and represent their locality."""@en ;
  curric:whyThisWhyNow """This unit consolidates pupils’ geographical understanding by revisiting
  their local area through enriched knowledge of features, mapping and place significance.
  Positioned at the end of Year 2, it prepares pupils to make meaningful comparisons with other
  places in future study.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-206-1 ,
    oakcurric:priorknowledge-206-2 ;
  curric:id "206"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.156263Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-local-area .

oakcurric:unit-203
  a curric:Unit ;
  rdfs:label "Life in a capital city: London/Cardiff"@en ;
  curric:slug "life-in-a-capital-city-london-cardiff" ;
  rdfs:comment """This unit explores the capital cities of London and Cardiff through their
  landmarks, transport, rivers and green spaces. Pupils describe key physical and human
  features and plan a day out using maps, images and simple route planning."""@en ;
  curric:whyThisWhyNow """This unit builds on pupils’ understanding of the UK’s nations and capital
  cities by focusing in depth on two contrasting urban locations. Its placement supports the
  development of locational knowledge, place comparison and urban geography through applied
  geographical skills.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-203-1 ,
    oakcurric:priorknowledge-203-2 ,
    oakcurric:priorknowledge-203-3 ;
  curric:id "203"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.319006Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-water-and-rivers ,
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-economic-activity ,
    oakcurric:thread-the-uk-and-regions .

oakcurric:unit-202
  a curric:Unit ;
  rdfs:label "The UK: what kind of place is it?"@en ;
  curric:slug "the-uk-what-kind-of-place-is-it" ;
  rdfs:comment """This unit introduces the United Kingdom as a country made up of four nations.
  Pupils learn to name and locate the nations, capital cities and surrounding seas, and
  explore distinctive geographical features across the UK using maps and images."""@en ;
  curric:whyThisWhyNow """This unit introduces national-scale geography through a focused study of
  the UK, including its countries, capitals and surrounding seas, as outlined in the National
  Curriculum. Its placement builds on pupils’ locational knowledge and prepares them for
  regional comparisons in later units.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-202-1 ,
    oakcurric:priorknowledge-202-2 ;
  curric:id "202"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.703725Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-water-and-rivers ,
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-natural-resources ,
    oakcurric:thread-the-uk-and-regions ,
    oakcurric:thread-diversity .

oakcurric:unit-205
  a curric:Unit ;
  rdfs:label "Hot places: where are they and what are they like?"@en ;
  curric:slug "hot-places-where-are-they-and-what-are-they-like" ;
  rdfs:comment """This unit explores the world’s hottest places, focusing on tropical rainforests
  and hot deserts. Pupils use maps and images to locate these environments, describe their
  climates and features, and compare contrasting hot places around the world."""@en ;
  curric:whyThisWhyNow """This unit builds on pupils’ understanding of weather, seasonal change and
  polar regions by introducing contrasting hot environments. Its placement supports comparison
  across climate zones and prepares pupils for future learning about biomes, vegetation and
  human-environment interaction.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-205-1 ,
    oakcurric:priorknowledge-205-2 ,
    oakcurric:priorknowledge-205-3 ;
  curric:id "205"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.991675Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-climate-and-weather ,
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-natural-resources ,
    oakcurric:thread-earth-geometry ,
    oakcurric:thread-physical-processes .

oakcurric:unit-207
  a curric:Unit ;
  rdfs:label "What is it like to live in Tanzania?"@en ;
  curric:slug "contrasting-locality-what-is-it-like-to-live-in-jamaica-tanzania" ;
  rdfs:comment """This unit explores what it is like to live in a contrasting locality by studying
  Jamaica and Tanzania. Pupils investigate location, climate, and key physical and human
  features, and compare each place with their own through maps, images and geographical
  vocabulary."""@en ;
  curric:whyThisWhyNow """This unit introduces a contrasting non-European locality, as required by
  the National Curriculum, and builds on pupils’ understanding of their own place. Its
  placement supports meaningful comparison, encouraging empathy, curiosity and awareness of
  diverse ways of living.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-207-1 ,
    oakcurric:priorknowledge-207-2 ,
    oakcurric:priorknowledge-207-3 ;
  curric:id "207"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.288144Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-americas-and-regions ,
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-economic-activity ,
    oakcurric:thread-natural-resources ,
    oakcurric:thread-diversity .

oakcurric:unit-274
  a curric:Unit ;
  rdfs:label "Local area: how do we read maps and plan routes?"@en ;
  curric:slug "local-area-how-do-we-read-maps-and-plan-routes" ;
  rdfs:comment """This unit develops pupils’ understanding of maps and route planning by exploring
  their school grounds. Pupils create maps, use symbols and keys, plan and follow routes,
  and apply their knowledge through simple fieldwork and observation."""@en ;
  curric:whyThisWhyNow """This unit builds on prior learning about the school and local area by
  developing pupils’ ability to represent and navigate space. Its placement enables the
  introduction of early mapping conventions and supports future units that involve route
  descriptions and spatial comparisons.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-274-1 ,
    oakcurric:priorknowledge-274-2 ,
    oakcurric:priorknowledge-274-3 ;
  curric:id "274"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.391638Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-natural-resources ,
    oakcurric:thread-local-area .

oakcurric:unit-273
  a curric:Unit ;
  rdfs:label "Seasons: how does the weather change through the year?"@en ;
  curric:slug "seasons-how-does-the-weather-change-through-the-year" ;
  rdfs:comment """This unit introduces weather and seasonal change by exploring different types of
  weather and how they vary across the year. Pupils observe and measure the weather,
  identify patterns, and begin to relate seasonal change to the calendar year."""@en ;
  curric:whyThisWhyNow """This unit builds on pupils’ existing awareness of the seasons, using this
  lived experience to introduce weather and seasonal change as geographical patterns. Its
  placement supports progression from local place knowledge and prepares pupils for later
  studies of climate and biomes.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-273-1 ,
    oakcurric:priorknowledge-273-2 ;
  curric:id "273"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.393547Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-climate-and-weather ,
    oakcurric:thread-earth-geometry ,
    oakcurric:thread-physical-processes .

oakcurric:unit-270
  a curric:Unit ;
  rdfs:label "Local area: where do we go to school?"@en ;
  curric:slug "local-area-where-do-we-go-to-school" ;
  rdfs:comment """Explore the school environment to identify features, describe locations using
  simple vocabulary, interpret aerial photos and observe seasonal change through early
  fieldwork."""@en ;
  curric:whyThisWhyNow """This unit introduces pupils to the concept of place by using their
  immediate surroundings to begin developing spatial awareness. Positioned at the very start of
  the geography curriculum, it establishes key vocabulary and observational skills that will
  support later learning about other familiar and contrasting locations. Focusing on the school
  grounds enables pupils to practise describing features and locations at a scale that is
  meaningful and accessible.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-270-1 ,
    oakcurric:priorknowledge-270-2 ,
    oakcurric:priorknowledge-270-3 ;
  curric:id "270"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.533692Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-local-area .

oakcurric:unit-271
  a curric:Unit ;
  rdfs:label "Local area: where do we live?"@en ;
  curric:slug "local-area-where-do-we-live" ;
  rdfs:comment """This unit investigates the area around school and home by identifying local
  features, exploring buildings, using simple maps, collecting data on how we travel to
  school, and describing familiar routes using basic geographical vocabulary."""@en ;
  curric:whyThisWhyNow """This unit builds on pupils’ earlier study of their school by extending
  their understanding of place to the wider local area. Its placement enables pupils to begin
  working with simple maps, using familiar locations to develop early mapping skills such as
  identifying features and interpreting symbols. By exploring geography at a slightly broader
  scale, this unit supports progression toward comparing distant places later in the curriculum
  and lays a foundation for more complex spatial thinking.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-271-1 ,
    oakcurric:priorknowledge-271-2 ,
    oakcurric:priorknowledge-271-3 ;
  curric:id "271"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.627218Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-economic-activity ,
    oakcurric:thread-natural-resources ,
    oakcurric:thread-local-area ,
    oakcurric:thread-human-processes ,
    oakcurric:thread-physical-processes ,
    oakcurric:thread-diversity .

oakcurric:unit-272
  a curric:Unit ;
  rdfs:label "Continents and oceans: what can we find out about the world?"@en ;
  curric:slug "continents-and-oceans-what-can-we-find-out-about-the-world" ;
  rdfs:comment """This unit uses globes, maps and satellite images to explore the world’s
  continents, oceans, rivers and mountains. Pupils locate key features and landmarks and
  begin to understand the UK’s position in the wider world."""@en ;
  curric:whyThisWhyNow """This unit introduces pupils to geography at the global scale, building on
  their earlier studies of the school and local area. Its placement supports progression in
  scale, helping pupils understand how their locality and the UK fit within the wider world.
  Pupils develop spatial awareness through engagement with photographs, satellite images and
  maps, supporting early understanding of spatial relationships and nested hierarchies. This
  foundation prepares pupils for future comparative and thematic studies.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-272-1 ;
  curric:id "272"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.683905Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-earth-geometry ,
    oakcurric:thread-diversity ,
    oakcurric:thread-interconnection .

oakcurric:unit-275
  a curric:Unit ;
  rdfs:label "Local to global: how can we identify special places?"@en ;
  curric:slug "local-to-global-how-can-we-identify-special-places" ;
  rdfs:comment """This unit explores what makes places special by combining personal geography with
  global examples. Pupils describe, annotate and locate familiar places before learning
  about the natural and human wonders of the world using images, maps and geographical
  vocabulary."""@en ;
  curric:whyThisWhyNow """This unit draws together the year’s learning by linking pupils’ personal
  experiences of place with global examples of significance. Its position at the end of Year 1
  helps pupils reflect on their growing spatial awareness and prepares them to compare places
  in Year 2.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-275-1 ,
    oakcurric:priorknowledge-275-2 ,
    oakcurric:priorknowledge-275-3 ;
  curric:id "275"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.725415Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-economic-activity ,
    oakcurric:thread-local-area ,
    oakcurric:thread-diversity ,
    oakcurric:thread-interconnection .

oakcurric:unit-204
  a curric:Unit ;
  rdfs:label "Cold places: what is it like at the North and South Poles?"@en ;
  curric:slug "cold-places-what-is-it-like-at-the-north-and-south-poles" ;
  rdfs:comment """This unit explores the North and South Poles through their locations, climates,
  landscapes, wildlife and ways of life. Pupils learn to compare the Arctic and Antarctic
  using maps, images and geographical vocabulary to describe features of cold environments."""@en ;
  curric:whyThisWhyNow """This unit develops pupils’ understanding of extreme environments by
  applying their knowledge of weather, seasonal change and global geography. Its placement
  allows for direct comparison of polar regions and builds the foundation for future learning
  about climate, habitats and adaptation.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-204-1 ,
    oakcurric:priorknowledge-204-2 ,
    oakcurric:priorknowledge-204-3 ;
  curric:id "204"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.736569Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-geography-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-climate-and-weather ,
    oakcurric:thread-land-use-and-settlement ,
    oakcurric:thread-earth-geometry ,
    oakcurric:thread-physical-processes .

