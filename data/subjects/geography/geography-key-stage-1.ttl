  dcterms:modified "2026-06-07T15:30:02.416563Z"^^xsd:dateTime .

oakcurric:keyword-familiar-street-features
  a curric:Keyword ;
  schema:name "familiar street features"@en ;
  schema:description """Familiar street features are those items that you usually find near to roads
