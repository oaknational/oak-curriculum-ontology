  dcterms:modified "2026-06-07T15:30:02.391824Z"^^xsd:dateTime .

oakcurric:keyword-intermediate-technology
  a curric:Keyword ;
  schema:name "intermediate technology"@en ;
  schema:description """technology suited to the needs, skills, knowledge and wealth of local people
  in the environment in which they live"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391833Z"^^xsd:dateTime .

oakcurric:keyword-organic-produce
