  dcterms:modified "2026-06-07T15:30:29.259163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24436-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change due to human activity is causing sea level rise, declining Arctic ice
  and more extreme weather events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24436-2
  a curric:KeyLearningPoint ;
