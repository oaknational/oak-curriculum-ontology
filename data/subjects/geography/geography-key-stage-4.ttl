oakcurric:unit-3696
  a curric:Unit ;
  rdfs:label "Climate change and weather hazards"@en ;
  curric:slug "climate-change-and-weather-hazards" ;
  rdfs:comment """This unit teaches pupils about climate change (causes, impacts and responses)
  together with extreme weather events, specifically tropical cyclones."""@en ;
  curric:whyThisWhyNow """This unit naturally builds on pupils prior knowledge gained from studying
  weather and climate at KS3. Climate change underpins many of the issues considered in
  subsequent units, such as global economic development, energy resources and urban planning.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3696-1 ,
    oakcurric:priorknowledge-3696-2 ,
    oakcurric:priorknowledge-3696-3 ,
