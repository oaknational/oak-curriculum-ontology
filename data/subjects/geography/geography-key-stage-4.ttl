  a curric:KeyLearningPoint ;
  rdfs:label "There are social opportunities associated with urban growth in Jakarta."@en ;
  dcterms:modified "2026-06-07T15:30:29.257654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24550-2
  a curric:KeyLearningPoint ;
