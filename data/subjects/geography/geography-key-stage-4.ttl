oakcurric:priorknowledge-3264-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have global locational knowledge and can use atlas maps"@en ;
  dcterms:modified "2026-06-07T15:29:23.291091Z"^^xsd:dateTime .

oakcurric:priorknowledge-3264-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand that plants and animals adapt to their environment"@en ;
  dcterms:modified "2026-06-07T15:29:23.291107Z"^^xsd:dateTime .

oakcurric:priorknowledge-3264-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the terms 'biotic' and 'abiotic' in the context of ecosystems"@en ;
  dcterms:modified "2026-06-07T15:29:23.291113Z"^^xsd:dateTime .

oakcurric:priorknowledge-3264-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can describe and infer using photos"@en ;
  dcterms:modified "2026-06-07T15:29:23.291118Z"^^xsd:dateTime .

oakcurric:priorknowledge-3264-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the concept of interdependence and the importance of
  biodiversity"""@en ;
  dcterms:modified "2026-06-07T15:29:23.291123Z"^^xsd:dateTime .

oakcurric:priorknowledge-3264-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that people living in extreme environments face challenges and
  opportunities"""@en ;
  dcterms:modified "2026-06-07T15:29:23.291127Z"^^xsd:dateTime .

oakcurric:priorknowledge-3301-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have a sound locational knowledge of the world and of Asia in particular"@en ;
  dcterms:modified "2026-06-07T15:29:23.384265Z"^^xsd:dateTime .

oakcurric:priorknowledge-3301-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have an understanding of the geography of Indonesia"@en ;
  dcterms:modified "2026-06-07T15:29:23.384281Z"^^xsd:dateTime .

oakcurric:priorknowledge-3301-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the terms 'social', 'economic' and 'environmental' in the context
  of cities"""@en ;
  dcterms:modified "2026-06-07T15:29:23.384288Z"^^xsd:dateTime .

