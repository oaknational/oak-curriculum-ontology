  dcterms:modified "2026-06-07T15:30:02.359633Z"^^xsd:dateTime .

oakcurric:keyword-national-park
  a curric:Keyword ;
  schema:name "national park"@en ;
  schema:description """a protected area of natural beauty, wildlife, and cultural importance,
  managed to preserve its environment while allowing public access for recreation and
  education"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359906Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-tourism
  a curric:Keyword ;
  schema:name "sustainable tourism"@en ;
  schema:description """tourism that considers its current and future economic, social, and
