  dcterms:modified "2026-06-07T15:30:29.259155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24472-2
  a curric:KeyLearningPoint ;
  rdfs:label """There has been a rise in the tertiary and quaternary sectors in rural and urban
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24472-3
  a curric:KeyLearningPoint ;
  rdfs:label """This decline and growth has affected the economy and employment structures of
