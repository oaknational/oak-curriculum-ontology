  dcterms:modified "2026-06-07T15:30:29.414068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24576-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are physical factors that affect water availability, such as climate and
