  a curric:KeyLearningPoint ;
  rdfs:label "Rivers exhibit a distinctive long profile from source to mouth."@en ;
  dcterms:modified "2026-06-07T15:30:29.632153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24453-2
  a curric:KeyLearningPoint ;
