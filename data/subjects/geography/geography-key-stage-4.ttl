oakcurric:unit-3297
  a curric:Unit ;
  rdfs:label "Economic futures in the UK"@en ;
  curric:slug "economic-futures-in-the-uk" ;
  rdfs:comment """This unit teaches economic change in the UK. Pupils will learn about the causes of
  economic change and the move to a post-industrial economy. Pupils will learn about
  economic developments in rural areas, developments in transport, the north-south divide
  and the role of the UK in the wider world."""@en ;
  curric:whyThisWhyNow """Pupils can build on their prior knowledge of economic geography and use
  their understanding of key terms such as globalisation learned in previous units to focus and
  better understand economic change in the UK. Some pupils can go on to use their knowledge
  gained in this unit for their fieldwork later in the course.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3297-1 ,
    oakcurric:priorknowledge-3297-2 ,
    oakcurric:priorknowledge-3297-3 ,
    oakcurric:priorknowledge-3297-4 ,
    oakcurric:priorknowledge-3297-5 ,
    oakcurric:priorknowledge-3297-6 ;
  curric:id "3297"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.860616Z"^^xsd:dateTime ;
