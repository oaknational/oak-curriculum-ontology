  dcterms:modified "2026-06-07T15:30:29.259567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24436-3
  a curric:KeyLearningPoint ;
  rdfs:label """With a range of projections, for example for global temperatures, there is
