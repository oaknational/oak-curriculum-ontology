  dcterms:modified "2026-06-07T15:30:29.261628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22987-4
  a curric:KeyLearningPoint ;
  rdfs:label "Forest fires and pests and diseases are contributing to a loss of biodiversity."@en ;
