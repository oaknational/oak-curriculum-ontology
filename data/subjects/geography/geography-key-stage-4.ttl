    oakcurric:priorknowledge-3303-5 ,
    oakcurric:priorknowledge-3303-6 ,
    oakcurric:priorknowledge-3303-7 ;
  curric:id "3303"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.142184Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-geography-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-risk-and-resilience ,
    oakcurric:thread-sustainability-and-climate-change ,
    oakcurric:thread-inequality ,
    oakcurric:thread-globalisation-and-interconnection ,
    oakcurric:thread-human-systems-and-processes .

oakcurric:unit-3296
  a curric:Unit ;
  rdfs:label "Indonesia: case study of a Newly Emerging Economy"@en ;
  curric:slug "indonesia-case-study-of-a-newly-emerging-economy" ;
  rdfs:comment """This unit teaches pupils about Indonesia, a case study of an emerging country/NEE.
  Pupils learn about the location and importance of Indonesia at different scales and the
  economic and social characteristics of the country. Pupils will also learn about
  industrial developments, population and aid."""@en ;
  curric:whyThisWhyNow """Pupils can build on and develop their understanding of global economic
  inequalities studied previously by focusing on Indonesia, an emerging country/NEE. They can
  also apply knowledge learned in the earlier study of Jakarta. Pupils can use knowledge gained
  in this unit when studying global resources later in the year.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3296-1 ,
    oakcurric:priorknowledge-3296-2 ,
    oakcurric:priorknowledge-3296-3 ,
