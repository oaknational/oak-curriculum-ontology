  dcterms:modified "2026-06-07T15:30:29.257662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22989-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are conflicting views on protecting forest and natural resources in
