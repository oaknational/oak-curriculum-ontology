oakcurric:keylearningpoint-lesson-24454-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rivers transport sediment through the processes of traction, saltation, suspension
  and solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24454-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers deposit sediment in areas of low energy."@en ;
  dcterms:modified "2026-06-07T15:30:29.618244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24456-1
  a curric:KeyLearningPoint ;
  rdfs:label "The River Eden valley is located in the northwest of England."@en ;
  dcterms:modified "2026-06-07T15:30:29.619111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24456-2
  a curric:KeyLearningPoint ;
  rdfs:label "The River Eden valley features landforms of erosion and deposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.619115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24456-3
  a curric:KeyLearningPoint ;
  rdfs:label """It has erosional landforms in its upper course including a V-shaped valley, Hell
  Gill, and a waterfall, Hell Gill Force."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24456-4
  a curric:KeyLearningPoint ;
  rdfs:label """It has depositional landforms in its middle and lower course including meanders
  across floodplains near to Carlisle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28465-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ready-made tropical storm layers can be configured to visualise spatial patterns
  more effectively, e.g. using filters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28465-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical storms can be analysed using pop-up data."@en ;
  dcterms:modified "2026-06-07T15:30:29.619132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28465-3
  a curric:KeyLearningPoint ;
  rdfs:label """Georeferenced data about a particular tropical storm can be mapped using GIS and
  configured to show selected attributes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28465-4
  a curric:KeyLearningPoint ;
  rdfs:label "A storm track can be visualised using temporal data, in a time-enabled GIS map."@en ;
  dcterms:modified "2026-06-07T15:30:29.619140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29566-1
  a curric:KeyLearningPoint ;
  rdfs:label "Primary impacts are immediate and caused directly by the tectonic hazard."@en ;
  dcterms:modified "2026-06-07T15:30:29.619146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29566-2
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary impacts are indirect impacts and occur in the hours, days and weeks after
  the hazard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29566-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a range of reasons why primary and secondary impacts may differ between two
  volcanic eruptions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29566-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different indicators can be considered to assess the significance of primary impacts
  and secondary impacts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28463-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change impacts can be visualised and analysed using geospatial data."@en ;
