  dcterms:modified "2026-06-07T15:30:41.118876Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28469
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use GIS to visualise glaciated landforms in upland areas."@en ;
  dcterms:modified "2026-06-07T15:30:41.119355Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-27577
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain opportunities and challenges of developing cold environments in
  Northern Canada."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119444Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24535
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use contour lines to identify and describe physical features on a map."@en ;
  dcterms:modified "2026-06-07T15:30:41.119500Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28462
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use GIS to visualise deforestation and analyse the causes of
  deforestation."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119504Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24480
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how urban change has led to pressure on areas of Liverpool’s
  rural-urban fringe."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119789Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24416
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain the processes at constructive/divergent plate margins and the causes
  of earthquakes and volcanoes."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120170Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24459
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how physical and human factors interacted to cause the River Eden
  flooding in Cumbria in 2015."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120277Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24481
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the location of the Albert Dock and explain the reasons for its
  decline and features of its regeneration."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120385Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24447
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe and explain landforms of coastal erosion and deposition on the
  Jurassic Coast."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120474Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-sustainability
  a curric:Keyword ;
  schema:name "sustainability"@en ;
  schema:description "using resources wisely so future generations can also meet their needs"@en ;
  dcterms:modified "2026-06-07T15:30:02.348175Z"^^xsd:dateTime .

oakcurric:keyword-development
  a curric:Keyword ;
  schema:name "development"@en ;
  schema:description "improving and building on design ideas to make them better"@en ;
  dcterms:modified "2026-06-07T15:30:02.348273Z"^^xsd:dateTime .

oakcurric:keyword-trade
  a curric:Keyword ;
  schema:name "trade"@en ;
  schema:description "Trade is the exchange of goods, commodities and services."@en ;
  dcterms:modified "2026-06-07T15:30:02.348359Z"^^xsd:dateTime .

oakcurric:keyword-atmosphere
  a curric:Keyword ;
  schema:name "atmosphere"@en ;
  schema:description "the mood created in a section or whole of a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348363Z"^^xsd:dateTime .

oakcurric:keyword-biotic
  a curric:Keyword ;
  schema:name "biotic"@en ;
  schema:description "the living elements of an ecosystem (e.g. plants, animals)"@en ;
  dcterms:modified "2026-06-07T15:30:02.348377Z"^^xsd:dateTime .

oakcurric:keyword-abiotic
  a curric:Keyword ;
  schema:name "abiotic"@en ;
  schema:description "the non-living elements of an ecosystem (e.g. water, nutrients)"@en ;
  dcterms:modified "2026-06-07T15:30:02.348382Z"^^xsd:dateTime .

oakcurric:keyword-interdependence
  a curric:Keyword ;
  schema:name "interdependence"@en ;
  schema:description """the connections between different components of the environment, where each
  component depends on or influences the others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348389Z"^^xsd:dateTime .

oakcurric:keyword-evapotranspiration
  a curric:Keyword ;
  schema:name "evapotranspiration"@en ;
  schema:description """the transfer of water to the atmosphere through evaporation from surfaces
  and transpiration from plants"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348394Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-character
  a curric:Keyword ;
  schema:name "character"@en ;
  schema:description "a person or animal in a story"@en ;
  dcterms:modified "2026-06-07T15:30:02.348600Z"^^xsd:dateTime .

oakcurric:keyword-kampung
  a curric:Keyword ;
  schema:name "kampung"@en ;
  schema:description """an informal settlement in Indonesian cities that is self-built without
  planning permission. Homes are overcrowded, poorly constructed and lack basic services"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349264Z"^^xsd:dateTime .

oakcurric:keyword-infrastructure
  a curric:Keyword ;
  schema:name "infrastructure"@en ;
  schema:description """the basic services and facilities needed for a city to function, such as
  water supply, electricity, sewage systems, transport and waste collection"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349268Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description """describes something that's based on a person's opinions, individual
  experiences, and biased influences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349519Z"^^xsd:dateTime .

oakcurric:keyword-quaternary-period
  a curric:Keyword ;
  schema:name "Quaternary period"@en ;
  schema:description "the period of geological time from 2.6 million years ago to the present"@en ;
  dcterms:modified "2026-06-07T15:30:02.350392Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "a long-term change in Earth’s climate patterns"@en ;
  dcterms:modified "2026-06-07T15:30:02.350396Z"^^xsd:dateTime .

oakcurric:keyword-ice-core
  a curric:Keyword ;
  schema:name "ice core"@en ;
  schema:description """a cylinder of ice extracted from an ice sheet or glacier which is used to
  analyse past climate conditions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350403Z"^^xsd:dateTime .

oakcurric:keyword-transnational-corporation
  a curric:Keyword ;
  schema:name "transnational corporation"@en ;
  schema:description """TNCs are firms that own or control productive operations in more than one
  country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350410Z"^^xsd:dateTime .

oakcurric:keyword-intergovernmental-organisation
  a curric:Keyword ;
  schema:name "intergovernmental organisation"@en ;
  schema:description """IGOs are established by a treaty or agreement between countries pursuing a
  common goal, e.g. World Bank"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350414Z"^^xsd:dateTime .

oakcurric:keyword-globalisation
  a curric:Keyword ;
  schema:name "globalisation"@en ;
  schema:description """the increased interconnectedness of the world, economically, politically and
  culturally"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350419Z"^^xsd:dateTime .

oakcurric:keyword-fdi
  a curric:Keyword ;
  schema:name "FDI"@en ;
  schema:description """foreign direct investment. Investment in a business that operates in another
  country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350424Z"^^xsd:dateTime .

oakcurric:keyword-tnc
  a curric:Keyword ;
  schema:name "TNC"@en ;
  schema:description """transnational corporation. A company that operates in more than one
  country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350428Z"^^xsd:dateTime .

oakcurric:keyword-free-trade
  a curric:Keyword ;
  schema:name "free trade"@en ;
  schema:description """trade between countries or economic regions where no tariffs (tax) exist on
  imported or exported goods"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350433Z"^^xsd:dateTime .

oakcurric:keyword-privatisation
  a curric:Keyword ;
  schema:name "privatisation"@en ;
  schema:description "the takeover of state-run industries by private corporations"@en ;
  dcterms:modified "2026-06-07T15:30:02.350439Z"^^xsd:dateTime .

oakcurric:keyword-conflict
  a curric:Keyword ;
  schema:name "conflict"@en ;
  schema:description """an active disagreement between people with opposing opinions or
  principles"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350705Z"^^xsd:dateTime .

oakcurric:keyword-erosion
  a curric:Keyword ;
  schema:name "erosion"@en ;
  schema:description "the wearing away of rocks along the coastline"@en ;
  dcterms:modified "2026-06-07T15:30:02.350793Z"^^xsd:dateTime .

oakcurric:keyword-coastal-management
  a curric:Keyword ;
  schema:name "coastal management"@en ;
  schema:description """the protection of coastlines from erosion and flooding through artificial or
  natural methods"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350797Z"^^xsd:dateTime .

oakcurric:keyword-annotation
  a curric:Keyword ;
  schema:name "annotation"@en ;
  schema:description """notes added to sketches to explain ideas, describe textures, or record
  thoughts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350859Z"^^xsd:dateTime .

oakcurric:keyword-deindustrialisation
  a curric:Keyword ;
  schema:name "deindustrialisation"@en ;
  schema:description """decline in importance of the industrial sector, for example, the closure of
  factories"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351186Z"^^xsd:dateTime .

oakcurric:keyword-depopulation
  a curric:Keyword ;
  schema:name "depopulation"@en ;
  schema:description """reduction in the population of an area, typically involving out-migration
  following deindustrialisation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351190Z"^^xsd:dateTime .

oakcurric:keyword-studentification
  a curric:Keyword ;
  schema:name "studentification"@en ;
  schema:description """areas with a high concentration of students, typically in sub-divided rental
  properties"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351195Z"^^xsd:dateTime .

oakcurric:keyword-gentrification
  a curric:Keyword ;
  schema:name "gentrification"@en ;
  schema:description """the upgrading of areas (typically housing) often in the inner city, making
  them more desirable but often more expensive"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351200Z"^^xsd:dateTime .

oakcurric:keyword-poverty
  a curric:Keyword ;
  schema:name "poverty"@en ;
  schema:description "poverty is the state of being extremely poor"@en ;
  dcterms:modified "2026-06-07T15:30:02.351257Z"^^xsd:dateTime .

oakcurric:keyword-label
  a curric:Keyword ;
  schema:name "label"@en ;
  schema:description """each piece of data is annotated with one or more labels which provide
  information about that data"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351564Z"^^xsd:dateTime .

oakcurric:keyword-carbon-emissions
  a curric:Keyword ;
  schema:name "carbon emissions"@en ;
  schema:description "volume of carbon produced contributing to global warming"@en ;
  dcterms:modified "2026-06-07T15:30:02.351639Z"^^xsd:dateTime .

oakcurric:keyword-immigration
  a curric:Keyword ;
  schema:name "immigration"@en ;
  schema:description "the act of moving into a new host location"@en ;
  dcterms:modified "2026-06-07T15:30:02.351691Z"^^xsd:dateTime .

oakcurric:keyword-emigration
  a curric:Keyword ;
  schema:name "emigration"@en ;
  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-06-07T15:30:02.351695Z"^^xsd:dateTime .

oakcurric:keyword-asylum-seeker
  a curric:Keyword ;
  schema:name "asylum seeker"@en ;
  schema:description """someone who seeks permanent or temporary protection in another country from
  the persecution or danger they experience in their home country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351702Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """someone who has successfully sought asylum in another country and is
  henceforth protected by international law"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351707Z"^^xsd:dateTime .

oakcurric:keyword-adaptation
  a curric:Keyword ;
  schema:name "adaptation"@en ;
  schema:description """An adaptation is a feature that organisms have to help them live in a
  particular place."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351940Z"^^xsd:dateTime .

oakcurric:keyword-ecosystem
  a curric:Keyword ;
  schema:name "ecosystem"@en ;
  schema:description """An ecosystem is made up of all the living organisms in a place, interacting
  with each other and their non-living surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351953Z"^^xsd:dateTime .

oakcurric:keyword-habitat
  a curric:Keyword ;
  schema:name "habitat"@en ;
  schema:description """A habitat is the place where an organism lives. It must provide food,
  shelter and a place to reproduce."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351958Z"^^xsd:dateTime .

oakcurric:keyword-channel
  a curric:Keyword ;
  schema:name "channel"@en ;
  schema:description "an imaginary line that divides the court vertically into 3 sections"@en ;
  dcterms:modified "2026-06-07T15:30:02.352035Z"^^xsd:dateTime .

oakcurric:keyword-sanitation
  a curric:Keyword ;
  schema:name "sanitation"@en ;
  schema:description """systems for removing human waste and managing rubbish and dirty water to
  prevent the spread of disease"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352263Z"^^xsd:dateTime .

oakcurric:keyword-pollution
  a curric:Keyword ;
  schema:name "pollution"@en ;
  schema:description """presence of harmful substances in the environment, such as in the air, water
  or soil, which can damage ecosystems and human health"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352271Z"^^xsd:dateTime .

oakcurric:keyword-groundwater
  a curric:Keyword ;
  schema:name "groundwater"@en ;
  schema:description """water found underground in soil, sand, and rock. It is stored in aquifers
  and can be used as a source of water for drinking or industry"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352276Z"^^xsd:dateTime .

oakcurric:keyword-subsidence
  a curric:Keyword ;
  schema:name "subsidence"@en ;
  schema:description """the sinking or settling of land, often caused by human activities such as
  excessive groundwater extraction, which can increase the risk of flooding"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352299Z"^^xsd:dateTime .

oakcurric:keyword-world-city
  a curric:Keyword ;
  schema:name "world city"@en ;
  schema:description """a city with global influence, important in the world economy through
  finance, trade, culture and communication"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352305Z"^^xsd:dateTime .

oakcurric:keyword-natural-increase
  a curric:Keyword ;
  schema:name "natural increase"@en ;
  schema:description """the difference between the birth rate and the death rate of a population;
  occurs when the birth rate is higher than the death rate"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352310Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
  environment or reducing resources for future generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352314Z"^^xsd:dateTime .

oakcurric:keyword-bottom-up-development
  a curric:Keyword ;
  schema:name "bottom-up development"@en ;
  schema:description """small-scale projects led by local people to meet community needs, often
  supported by NGOs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352321Z"^^xsd:dateTime .

oakcurric:keyword-cooperative
  a curric:Keyword ;
  schema:name "cooperative"@en ;
  schema:description """a group of people working together to achieve shared goals. A housing
  cooperative is where residents help plan and manage their homes, often in partnership with
  local government or NGOs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352326Z"^^xsd:dateTime .

oakcurric:keyword-biodiversity
  a curric:Keyword ;
  schema:name "biodiversity"@en ;
  schema:description "the variety of species found in a habitat"@en ;
  dcterms:modified "2026-06-07T15:30:02.352330Z"^^xsd:dateTime .

oakcurric:keyword-adaptations
  a curric:Keyword ;
  schema:name "adaptations"@en ;
  schema:description """a feature or behaviour that helps an animal or plant survive in its
  environment"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352335Z"^^xsd:dateTime .

oakcurric:keyword-nutrients
  a curric:Keyword ;
  schema:name "nutrients"@en ;
  schema:description """chemical substances found in all biotic features which are important for
  survival"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352469Z"^^xsd:dateTime .

oakcurric:keyword-interdependent
  a curric:Keyword ;
  schema:name "interdependent"@en ;
  schema:description """when two or more biotic features, like plants or animals, depend or rely on
  each other to survive"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352474Z"^^xsd:dateTime .

oakcurric:keyword-strategy
  a curric:Keyword ;
  schema:name "strategy"@en ;
  schema:description "a plan for achieving success"@en ;
  dcterms:modified "2026-06-07T15:30:02.352572Z"^^xsd:dateTime .

oakcurric:keyword-preparation
  a curric:Keyword ;
  schema:name "preparation"@en ;
  schema:description """the initial set of movements and position required before executing the
  throw"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352652Z"^^xsd:dateTime .

oakcurric:keyword-access
  a curric:Keyword ;
  schema:name "access"@en ;
  schema:description """how easy it is for people to take part in an activity, especially if there
  are barriers"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352750Z"^^xsd:dateTime .

oakcurric:keyword-efficiency
  a curric:Keyword ;
  schema:name "efficiency"@en ;
  schema:description "working in an organised way that doesn't waste time and resources"@en ;
  dcterms:modified "2026-06-07T15:30:02.352951Z"^^xsd:dateTime .

oakcurric:keyword-mitigation
  a curric:Keyword ;
  schema:name "mitigation"@en ;
  schema:description "actions to reduce or prevent the emission of greenhouse gases"@en ;
  dcterms:modified "2026-06-07T15:30:02.353040Z"^^xsd:dateTime .

oakcurric:keyword-renewable-energy
  a curric:Keyword ;
  schema:name "renewable energy"@en ;
  schema:description """energy from natural sources that are constantly replenished, like wind and
  solar"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353046Z"^^xsd:dateTime .

oakcurric:keyword-paris-agreement
  a curric:Keyword ;
  schema:name "Paris Agreement"@en ;
  schema:description "an international treaty on climate change aiming to limit global warming"@en ;
  dcterms:modified "2026-06-07T15:30:02.353050Z"^^xsd:dateTime .

oakcurric:keyword-weathering
  a curric:Keyword ;
  schema:name "weathering"@en ;
  schema:description "the breakdown or disintegration of rocks at or close to the surface"@en ;
  dcterms:modified "2026-06-07T15:30:02.353105Z"^^xsd:dateTime .

oakcurric:keyword-mechanical-weathering
  a curric:Keyword ;
  schema:name "mechanical weathering"@en ;
  schema:description "physical disintegration of rocks, for example through freeze-thaw"@en ;
  dcterms:modified "2026-06-07T15:30:02.353111Z"^^xsd:dateTime .

oakcurric:keyword-chemical-weathering
  a curric:Keyword ;
  schema:name "chemical weathering"@en ;
  schema:description "chemical breakdown of rocks usually involving slightly acidic rainwater"@en ;
  dcterms:modified "2026-06-07T15:30:02.353118Z"^^xsd:dateTime .

oakcurric:keyword-mass-movement
  a curric:Keyword ;
  schema:name "mass movement"@en ;
  schema:description "the downhill movement of material under the influence of gravity"@en ;
  dcterms:modified "2026-06-07T15:30:02.353123Z"^^xsd:dateTime .

oakcurric:keyword-forecast
  a curric:Keyword ;
  schema:name "forecast"@en ;
  schema:description """use of technology to predict the likelihood of a tropical storm, including
  its path, intensity and speed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353319Z"^^xsd:dateTime .

oakcurric:keyword-meteorologist
  a curric:Keyword ;
  schema:name "meteorologist"@en ;
  schema:description """person who studies the causes of weather conditions using information from
  land, sea and the atmosphere, and creates forecasts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353323Z"^^xsd:dateTime .

oakcurric:keyword-monitoring
  a curric:Keyword ;
  schema:name "monitoring"@en ;
  schema:description """the continuous observation and recording of atmospheric conditions to detect
  changes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353328Z"^^xsd:dateTime .

oakcurric:keyword-mitigate
  a curric:Keyword ;
  schema:name "mitigate"@en ;
  schema:description "taking actions to reduce the effects of a tropical storm"@en ;
  dcterms:modified "2026-06-07T15:30:02.353332Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description """The gradient on a displacement-time graph gives the instantaneous
  velocity."""@en ;
  dcterms:modified "2026-06-07T15:30:02.353605Z"^^xsd:dateTime .

oakcurric:keyword-latitude
  a curric:Keyword ;
  schema:name "latitude"@en ;
  schema:description """an imaginary line running east to west around the Earth's surface that is
  used to show how far north or south a place is"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353687Z"^^xsd:dateTime .

oakcurric:keyword-longitude
  a curric:Keyword ;
  schema:name "longitude"@en ;
  schema:description """an imaginary line running north to south across the Earth's surface that is
