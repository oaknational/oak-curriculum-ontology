  dcterms:modified "2026-06-07T15:30:29.623245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29565-1
  a curric:KeyLearningPoint ;
  rdfs:label "Primary impacts are immediate and caused directly by the tectonic hazard."@en ;
  dcterms:modified "2026-06-07T15:30:29.625596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary impacts are indirect impacts and occur in the hours, days and weeks after
  the hazard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29565-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a range of reasons why primary and secondary impacts may differ between two
