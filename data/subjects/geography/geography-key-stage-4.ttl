  schema:description """a GIS (geographic information system) is a computer system that captures,
  analyses and displays geographic data to help understand spatial patterns"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369002Z"^^xsd:dateTime .

oakcurric:keyword-webmap
  a curric:Keyword ;
  schema:name "webmap"@en ;
  schema:description """a digital map which is available online. It will usually be interactive or
  can be created or saved by the user online (‘in the cloud’)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369006Z"^^xsd:dateTime .

oakcurric:keyword-spatial-distribution
  a curric:Keyword ;
  schema:name "spatial distribution"@en ;
  schema:description """the spread of information (data) across an area, creating spatial patterns
  which geographers attempt to describe, explain and analyse"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369013Z"^^xsd:dateTime .

oakcurric:keyword-undernutrition
  a curric:Keyword ;
  schema:name "undernutrition"@en ;
  schema:description "having an intake of energy and/or nutrients below what is needed"@en ;
  dcterms:modified "2026-06-07T15:30:02.369058Z"^^xsd:dateTime .

oakcurric:keyword-threat
  a curric:Keyword ;
  schema:name "threat"@en ;
  schema:description """A threat is the possibility that something unwanted or dangerous will
  happen."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369807Z"^^xsd:dateTime .

oakcurric:keyword-pull-factor
  a curric:Keyword ;
  schema:name "pull factor"@en ;
  schema:description """Pull factors refer to the attractive aspects or opportunities that draw
  individuals to a new destination."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370140Z"^^xsd:dateTime .

oakcurric:keyword-orientation
  a curric:Keyword ;
  schema:name "orientation"@en ;
  schema:description "the way a rectangular page is positioned for normal viewing"@en ;
  dcterms:modified "2026-06-07T15:30:02.370379Z"^^xsd:dateTime .

oakcurric:keyword-commonwealth
  a curric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """a voluntary association of 56 independent and equal countries, many of which
  were formerly colonised as part of the British Empire"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370789Z"^^xsd:dateTime .

oakcurric:keyword-arid
  a curric:Keyword ;
  schema:name "arid"@en ;
  schema:description "a climate with little to no rainfall"@en ;
  dcterms:modified "2026-06-07T15:30:02.370930Z"^^xsd:dateTime .

oakcurric:keyword-mineral-extraction
  a curric:Keyword ;
  schema:name "mineral extraction"@en ;
  schema:description "the process of removing valuable minerals from the earth"@en ;
  dcterms:modified "2026-06-07T15:30:02.370935Z"^^xsd:dateTime .

oakcurric:keyword-tourism
  a curric:Keyword ;
  schema:name "tourism"@en ;
  schema:description "the business of attracting and taking care of visitors to a place"@en ;
  dcterms:modified "2026-06-07T15:30:02.370939Z"^^xsd:dateTime .

oakcurric:keyword-linear
  a curric:Keyword ;
  schema:name "linear"@en ;
  schema:description "in a straight, direct line"@en ;
  dcterms:modified "2026-06-07T15:30:02.372985Z"^^xsd:dateTime .

oakcurric:keyword-floodplain
  a curric:Keyword ;
  schema:name "floodplain"@en ;
  schema:description """an area of low-lying ground adjacent to a river, formed mainly of river
  sediments and subject to flooding"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373108Z"^^xsd:dateTime .

oakcurric:keyword-sediment-load
  a curric:Keyword ;
  schema:name "sediment load"@en ;
  schema:description "the total amount of sediment transported by a river"@en ;
  dcterms:modified "2026-06-07T15:30:02.373113Z"^^xsd:dateTime .

oakcurric:keyword-irrigation
  a curric:Keyword ;
  schema:name "irrigation"@en ;
  schema:description "a method of supplying water to crops to help them grow"@en ;
  dcterms:modified "2026-06-07T15:30:02.373327Z"^^xsd:dateTime .

oakcurric:keyword-desalination
  a curric:Keyword ;
  schema:name "desalination"@en ;
  schema:description """the process of removing salt from seawater to make it suitable for drinking
  and irrigation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373333Z"^^xsd:dateTime .

oakcurric:keyword-coastal-defences
  a curric:Keyword ;
  schema:name "coastal defences"@en ;
  schema:description "structures built to protect land from the sea, e.g. sea walls"@en ;
  dcterms:modified "2026-06-07T15:30:02.373338Z"^^xsd:dateTime .

oakcurric:keyword-primary-effect
  a curric:Keyword ;
  schema:name "primary effect"@en ;
  schema:description """impacts that occur instantly and as a direct result of the earthquake or
  volcanic eruption"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373381Z"^^xsd:dateTime .

oakcurric:keyword-secondary-effect
  a curric:Keyword ;
  schema:name "secondary effect"@en ;
  schema:description """impacts that follow as a consequence of the earthquake or volcanic eruption
  in the hours, days and weeks that follow"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373385Z"^^xsd:dateTime .

oakcurric:keyword-immediate-response
  a curric:Keyword ;
  schema:name "immediate response"@en ;
  schema:description """action taken during and immediately after a hazard event that focuses on
  surviving the hazard and providing short-term relief"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373390Z"^^xsd:dateTime .

oakcurric:keyword-long-term-response
  a curric:Keyword ;
  schema:name "long-term response"@en ;
  schema:description """action that focuses on rebuilding after the tectonic hazard and reducing
  risks from future hazards"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373394Z"^^xsd:dateTime .

oakcurric:keyword-site
  a curric:Keyword ;
  schema:name "site"@en ;
  schema:description "the point on the ground where a settlement is built"@en ;
  dcterms:modified "2026-06-07T15:30:02.373401Z"^^xsd:dateTime .

oakcurric:keyword-situation
  a curric:Keyword ;
  schema:name "situation"@en ;
  schema:description """the description of a place in relation to its human and physical
  surroundings"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373406Z"^^xsd:dateTime .

oakcurric:keyword-connectivity
  a curric:Keyword ;
  schema:name "connectivity"@en ;
  schema:description """a measure of how well connected (by transport and other forms of
  communication) a place is"""@en ;
  dcterms:modified "2026-06-07T15:30:02.373413Z"^^xsd:dateTime .

oakcurric:keyword-built-environment
  a curric:Keyword ;
  schema:name "built environment"@en ;
  schema:description "the human-made spaces around us that create our local environment"@en ;
  dcterms:modified "2026-06-07T15:30:02.374166Z"^^xsd:dateTime .

oakcurric:keyword-habitats
  a curric:Keyword ;
  schema:name "habitats"@en ;
  schema:description "the natural place where a plant or animal lives and grows"@en ;
  dcterms:modified "2026-06-07T15:30:02.374547Z"^^xsd:dateTime .

oakcurric:keyword-employment
  a curric:Keyword ;
  schema:name "employment"@en ;
  schema:description """the availability of jobs and work for people, often used to measure economic
  opportunity and development"""@en ;
  dcterms:modified "2026-06-07T15:30:02.374815Z"^^xsd:dateTime .

oakcurric:keyword-formal-sector
  a curric:Keyword ;
  schema:name "formal sector"@en ;
  schema:description """jobs which pay tax to the government and which come with legal contracts and
  benefits like a regular salary, sick pay and pensions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.374820Z"^^xsd:dateTime .

oakcurric:keyword-informal-sector
  a curric:Keyword ;
  schema:name "informal sector"@en ;
  schema:description """jobs which are not registered with the government and illegally avoid paying
  tax, and which do not have any protections for workers such as contracts, insurance
  against accidents, sick pay, holidays"""@en ;
  dcterms:modified "2026-06-07T15:30:02.374827Z"^^xsd:dateTime .

oakcurric:keyword-inflow
  a curric:Keyword ;
  schema:name "inflow"@en ;
  schema:description "migration of people to a place"@en ;
  dcterms:modified "2026-06-07T15:30:02.374916Z"^^xsd:dateTime .

oakcurric:keyword-outflow
  a curric:Keyword ;
  schema:name "outflow"@en ;
  schema:description "migration of people away from a place"@en ;
  dcterms:modified "2026-06-07T15:30:02.374921Z"^^xsd:dateTime .

oakcurric:keyword-economic-impact
  a curric:Keyword ;
  schema:name "economic impact"@en ;
  schema:description """the effect of an event on the financial conditions of an area, e.g.
  employment, income, investment"""@en ;
  dcterms:modified "2026-06-07T15:30:02.374937Z"^^xsd:dateTime .

oakcurric:keyword-enquiry
  a curric:Keyword ;
  schema:name "enquiry"@en ;
  schema:description "An enquiry is an investigation to find out more about something."@en ;
  dcterms:modified "2026-06-07T15:30:02.375804Z"^^xsd:dateTime .

oakcurric:keyword-sinuosity
  a curric:Keyword ;
  schema:name "sinuosity"@en ;
  schema:description "how straight or curvy (sinuous) a river is"@en ;
  dcterms:modified "2026-06-07T15:30:02.376188Z"^^xsd:dateTime .

oakcurric:keyword-nucleated
  a curric:Keyword ;
  schema:name "nucleated"@en ;
  schema:description """a description for a feature (such as a settlement) that is wrapped around a
  central point"""@en ;
  dcterms:modified "2026-06-07T15:30:02.376195Z"^^xsd:dateTime .

oakcurric:keyword-variation
  a curric:Keyword ;
  schema:name "variation"@en ;
  schema:description "changing the type of training to keep it interesting and effective"@en ;
  dcterms:modified "2026-06-07T15:30:02.376200Z"^^xsd:dateTime .

oakcurric:keyword-decomposer
  a curric:Keyword ;
  schema:name "decomposer"@en ;
  schema:description """A decomposer is an organism that feeds on the remains of other living
  organisms (organic matter)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.376581Z"^^xsd:dateTime .

oakcurric:keyword-cross-section
  a curric:Keyword ;
  schema:name "cross-section"@en ;
  schema:description "the inside view of a 3D object when cut straight through"@en ;
  dcterms:modified "2026-06-07T15:30:02.377906Z"^^xsd:dateTime .

oakcurric:keyword-ice-sheet
  a curric:Keyword ;
  schema:name "ice sheet"@en ;
  schema:description "a vast, continuous expanse of ice covering a very large area of land"@en ;
  dcterms:modified "2026-06-07T15:30:02.377964Z"^^xsd:dateTime .

oakcurric:keyword-glacier
  a curric:Keyword ;
  schema:name "glacier"@en ;
  schema:description "a large mass of ice that forms on land and moves slowly due to gravity"@en ;
  dcterms:modified "2026-06-07T15:30:02.377969Z"^^xsd:dateTime .

oakcurric:keyword-freeze-thaw-weathering
  a curric:Keyword ;
  schema:name "freeze-thaw weathering"@en ;
  schema:description "the break up of rocks caused by water regularly freezing and thawing"@en ;
  dcterms:modified "2026-06-07T15:30:02.377973Z"^^xsd:dateTime .

oakcurric:keyword-glacial-till
  a curric:Keyword ;
  schema:name "glacial till"@en ;
  schema:description "a mixture of unsorted debris"@en ;
  dcterms:modified "2026-06-07T15:30:02.377978Z"^^xsd:dateTime .

oakcurric:keyword-food-miles
  a curric:Keyword ;
  schema:name "food miles"@en ;
  schema:description """Food miles are the distance between the place where food is grown or made
  and the place where it is eaten."""@en ;
  dcterms:modified "2026-06-07T15:30:02.378220Z"^^xsd:dateTime .

oakcurric:keyword-milankovitch-cycles
  a curric:Keyword ;
  schema:name "Milankovitch cycles"@en ;
  schema:description """natural changes in Earth's orbit and tilt over thousands of years that
  influence solar energy and Earth’s climate"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378717Z"^^xsd:dateTime .

oakcurric:keyword-enhanced-greenhouse-effect
  a curric:Keyword ;
  schema:name "enhanced greenhouse effect"@en ;
  schema:description """the increased concentration of greenhouse gases in the atmosphere due to
  human activities, leading to global warming"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378722Z"^^xsd:dateTime .

oakcurric:keyword-bivariate-data
  a curric:Keyword ;
  schema:name "bivariate data"@en ;
  schema:description """data for two variables where one of those variables is believed to influence
  the other"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378727Z"^^xsd:dateTime .

oakcurric:keyword-anomaly
  a curric:Keyword ;
  schema:name "anomaly"@en ;
  schema:description """a value within the data set that does not appear to follow the general
  pattern or trend"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378731Z"^^xsd:dateTime .

oakcurric:keyword-interpolation
  a curric:Keyword ;
  schema:name "interpolation"@en ;
  schema:description """estimating unknown values within a data set based on other values within the
  set"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378736Z"^^xsd:dateTime .

oakcurric:keyword-extrapolation
  a curric:Keyword ;
  schema:name "extrapolation"@en ;
  schema:description """estimating unknown values beyond the data set based on the pattern or trend
  of the known values"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378740Z"^^xsd:dateTime .

oakcurric:keyword-integrated-transport-system
  a curric:Keyword ;
  schema:name "integrated transport system"@en ;
  schema:description """an interconnected urban transport network, with interchange hubs linking
  different forms of transport, such as bicycles, buses and cars"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378816Z"^^xsd:dateTime .

oakcurric:keyword-urban-greening
  a curric:Keyword ;
  schema:name "urban greening"@en ;
  schema:description """the greening of urban areas, involving planting trees and the creation of
  green areas and parks"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378820Z"^^xsd:dateTime .

oakcurric:keyword-discharge
  a curric:Keyword ;
  schema:name "discharge"@en ;
  schema:description """the volume of water flowing through a river channel at any given time,
  measured in cumecs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.379380Z"^^xsd:dateTime .

oakcurric:keyword-infiltration
  a curric:Keyword ;
  schema:name "infiltration"@en ;
  schema:description "the process by which water on the ground surface enters the soil"@en ;
  dcterms:modified "2026-06-07T15:30:02.379384Z"^^xsd:dateTime .

oakcurric:keyword-lag-time
  a curric:Keyword ;
  schema:name "lag time"@en ;
  schema:description "the time between the peak rainfall and the peak discharge"@en ;
  dcterms:modified "2026-06-07T15:30:02.379389Z"^^xsd:dateTime .

oakcurric:keyword-drainage-density
  a curric:Keyword ;
  schema:name "drainage density"@en ;
  schema:description """a measure of how many rivers and streams there are within a given area. A
  high drainage density indicates many streams and rivers in the given area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.379396Z"^^xsd:dateTime .

oakcurric:keyword-hibernation
  a curric:Keyword ;
  schema:name "hibernation"@en ;
  schema:description """a state that certain animals enter to save energy during periods of
  unfavourable weather conditions or food shortages"""@en ;
  dcterms:modified "2026-06-07T15:30:02.379428Z"^^xsd:dateTime .

oakcurric:keyword-push-factor
  a curric:Keyword ;
  schema:name "push factor"@en ;
  schema:description "negative things that make people want to leave an area, for example, war"@en ;
  dcterms:modified "2026-06-07T15:30:02.379754Z"^^xsd:dateTime .

oakcurric:keyword-cold-environments
  a curric:Keyword ;
  schema:name "cold environments"@en ;
  schema:description """environments found at higher latitudes and higher altitudes; they include
  polar, tundra and alpine biomes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.379832Z"^^xsd:dateTime .

oakcurric:keyword-tundra
  a curric:Keyword ;
  schema:name "tundra"@en ;
  schema:description """a vast, flat, treeless Arctic region where vegetation growth is hindered by
  extreme low temperatures and short growing seasons"""@en ;
  dcterms:modified "2026-06-07T15:30:02.379837Z"^^xsd:dateTime .

oakcurric:keyword-historical-imagery
  a curric:Keyword ;
  schema:name "historical imagery"@en ;
  schema:description """photographs from any time in the past which can be compared with more recent
  photographs including aerial, satellite or conventional"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380219Z"^^xsd:dateTime .

oakcurric:keyword-temporal-data
  a curric:Keyword ;
  schema:name "temporal data"@en ;
  schema:description """information which is tied to a particular point in time, so that data can be
  time-enabled (also known as spatiotemporal data)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380225Z"^^xsd:dateTime .

oakcurric:keyword-historical-maps
  a curric:Keyword ;
  schema:name "historical maps"@en ;
  schema:description """maps from any time in the past which can be compared with more
  recent maps"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380231Z"^^xsd:dateTime .

oakcurric:keyword-georeferenced
  a curric:Keyword ;
  schema:name "georeferenced"@en ;
  schema:description """information which has been tied to a particular location (geolocated), using
  an agreed system such as latitude and longitude"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380235Z"^^xsd:dateTime .

oakcurric:keyword-national
  a curric:Keyword ;
  schema:name "national"@en ;
  schema:description "relating to a country"@en ;
  dcterms:modified "2026-06-07T15:30:02.380596Z"^^xsd:dateTime .

oakcurric:keyword-indirect
  a curric:Keyword ;
  schema:name "indirect"@en ;
  schema:description """effects or consequences that are not immediately caused by an event or
  action but happen as a result of it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380601Z"^^xsd:dateTime .

oakcurric:keyword-cardinal-points
  a curric:Keyword ;
  schema:name "cardinal points"@en ;
  schema:description "the four main compass points (north, south, east and west)"@en ;
  dcterms:modified "2026-06-07T15:30:02.380617Z"^^xsd:dateTime .

oakcurric:keyword-easting
  a curric:Keyword ;
  schema:name "easting"@en ;
  schema:description """vertical lines running north to south on a map that divide it into east and
  west parts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380622Z"^^xsd:dateTime .

oakcurric:keyword-northing
  a curric:Keyword ;
  schema:name "northing"@en ;
  schema:description """horizontal lines running west to east on a map that divide it into north and
  south parts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380628Z"^^xsd:dateTime .

oakcurric:keyword-goods
  a curric:Keyword ;
  schema:name "goods"@en ;
  schema:description """physical resources or products that can be directly harvested or used by
  people and animals"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380732Z"^^xsd:dateTime .

oakcurric:keyword-service
  a curric:Keyword ;
  schema:name "service"@en ;
  schema:description """natural processes or benefits that rainforests provide to support life on
  Earth, often indirectly"""@en ;
  dcterms:modified "2026-06-07T15:30:02.380738Z"^^xsd:dateTime .

oakcurric:keyword-hotspot
  a curric:Keyword ;
  schema:name "hotspot"@en ;
  schema:description "a hotspot is a place of significant activity, danger or violence"@en ;
  dcterms:modified "2026-06-07T15:30:02.381088Z"^^xsd:dateTime .

oakcurric:keyword-ethnicity
  a curric:Keyword ;
  schema:name "ethnicity"@en ;
  schema:description """a term that refers to the backgrounds or shared experiences of a group of
  people, including language, religion and beliefs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.381219Z"^^xsd:dateTime .

oakcurric:keyword-desertification
  a curric:Keyword ;
  schema:name "desertification"@en ;
  schema:description """the process by which land becomes desert due to climate change,
  deforestation, or inappropriate agriculture"""@en ;
  dcterms:modified "2026-06-07T15:30:02.381390Z"^^xsd:dateTime .

oakcurric:keyword-drought
  a curric:Keyword ;
  schema:name "drought"@en ;
  schema:description """a long period of time with little or no rainfall, leading to a shortage of
  water"""@en ;
  dcterms:modified "2026-06-07T15:30:02.381398Z"^^xsd:dateTime .

oakcurric:keyword-chalk
  a curric:Keyword ;
  schema:name "chalk"@en ;
  schema:description "a soft white sedimentary rock found in southern England"@en ;
  dcterms:modified "2026-06-07T15:30:02.381872Z"^^xsd:dateTime .

oakcurric:keyword-granite
  a curric:Keyword ;
  schema:name "granite"@en ;
  schema:description "a hard igneous rock found in upland UK areas"@en ;
  dcterms:modified "2026-06-07T15:30:02.381876Z"^^xsd:dateTime .

oakcurric:keyword-spatial-data
  a curric:Keyword ;
  schema:name "spatial data"@en ;
  schema:description "data that is assigned to a specific location"@en ;
  dcterms:modified "2026-06-07T15:30:02.381885Z"^^xsd:dateTime .

oakcurric:keyword-gis
  a curric:Keyword ;
  schema:name "GIS"@en ;
  schema:description """Geographical Information System: software that create maps of spatial data,
  as well as digital tools to analyse it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.381890Z"^^xsd:dateTime .

oakcurric:keyword-choropleth-shading
  a curric:Keyword ;
  schema:name "choropleth shading"@en ;
  schema:description "using density of colour on a map to show the density of data spatially"@en ;
  dcterms:modified "2026-06-07T15:30:02.381894Z"^^xsd:dateTime .

oakcurric:keyword-isoline
  a curric:Keyword ;
  schema:name "isoline"@en ;
  schema:description "a line on a map that joins points that have the same value"@en ;
  dcterms:modified "2026-06-07T15:30:02.381899Z"^^xsd:dateTime .

oakcurric:keyword-flood-risk
  a curric:Keyword ;
  schema:name "flood risk"@en ;
  schema:description "the probability of a flood event occurring and its potential impact"@en ;
  dcterms:modified "2026-06-07T15:30:02.382206Z"^^xsd:dateTime .

oakcurric:keyword-non-renewable-energy
  a curric:Keyword ;
  schema:name "non-renewable energy"@en ;
  schema:description """energy sources, such as fossil fuels, that cannot be replaced and will
  eventually run out"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382271Z"^^xsd:dateTime .

oakcurric:keyword-central-business-district-cbd
  a curric:Keyword ;
  schema:name "Central Business District: CBD"@en ;
  schema:description """commonly, the centrally-located commercial and business district in a city
  with a dominance of offices and shops"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382711Z"^^xsd:dateTime .

oakcurric:keyword-inner-city
  a curric:Keyword ;
  schema:name "inner city"@en ;
  schema:description """located between the city centre and the suburbs and often an area of high
  density terraced housing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382716Z"^^xsd:dateTime .

oakcurric:keyword-rural-urban-fringe
  a curric:Keyword ;
  schema:name "rural-urban fringe"@en ;
  schema:description "the outer edge of a city where it merges with the countryside"@en ;
  dcterms:modified "2026-06-07T15:30:02.382720Z"^^xsd:dateTime .

oakcurric:keyword-discrete-data
  a curric:Keyword ;
  schema:name "discrete data"@en ;
  schema:description "data that can be arranged into exclusive categories"@en ;
  dcterms:modified "2026-06-07T15:30:02.382757Z"^^xsd:dateTime .

oakcurric:keyword-continuous-data
  a curric:Keyword ;
  schema:name "continuous data"@en ;
  schema:description "data that sits on a continuum from low to high values"@en ;
  dcterms:modified "2026-06-07T15:30:02.382761Z"^^xsd:dateTime .

oakcurric:keyword-frequency-data
  a curric:Keyword ;
  schema:name "frequency data"@en ;
  schema:description "data such as counts or the actual amounts of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.382768Z"^^xsd:dateTime .

oakcurric:keyword-proportional-data
  a curric:Keyword ;
  schema:name "proportional data"@en ;
  schema:description """data that is the relative amount of something when considered as part of a
  whole"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382775Z"^^xsd:dateTime .

oakcurric:keyword-distribution
  a curric:Keyword ;
  schema:name "distribution"@en ;
  schema:description "how something is spread out over a geographical area"@en ;
  dcterms:modified "2026-06-07T15:30:02.383036Z"^^xsd:dateTime .

oakcurric:keyword-altitude
  a curric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "height above sea level or ground level"@en ;
  dcterms:modified "2026-06-07T15:30:02.383549Z"^^xsd:dateTime .

oakcurric:keyword-resistant
  a curric:Keyword ;
  schema:name "resistant"@en ;
  schema:description "refers to rocks that are less likely to be eroded or weathered"@en ;
  dcterms:modified "2026-06-07T15:30:02.383690Z"^^xsd:dateTime .

oakcurric:keyword-retreat
  a curric:Keyword ;
  schema:name "retreat"@en ;
  schema:description """the process where cliffs move backward over time as erosion wears away the
  base of a cliff"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383694Z"^^xsd:dateTime .

oakcurric:keyword-geological-structure
  a curric:Keyword ;
  schema:name "geological structure"@en ;
  schema:description "the arrangement of rock structure"@en ;
  dcterms:modified "2026-06-07T15:30:02.383699Z"^^xsd:dateTime .

oakcurric:keyword-water-column
  a curric:Keyword ;
  schema:name "water column"@en ;
  schema:description "refers to the vertical section of water from the surface to the sea bed"@en ;
  dcterms:modified "2026-06-07T15:30:02.383923Z"^^xsd:dateTime .

oakcurric:keyword-prevailing-wind
  a curric:Keyword ;
  schema:name "prevailing wind"@en ;
  schema:description "the most frequent wind direction a location receives"@en ;
  dcterms:modified "2026-06-07T15:30:02.383927Z"^^xsd:dateTime .

oakcurric:keyword-urban-change
  a curric:Keyword ;
  schema:name "urban change"@en ;
  schema:description "changes that occur in a city due to its growth or decline"@en ;
  dcterms:modified "2026-06-07T15:30:02.383971Z"^^xsd:dateTime .

oakcurric:keyword-place-specific-details
  a curric:Keyword ;
  schema:name "place-specific details"@en ;
  schema:description "facts and figures which are particular to a place"@en ;
  dcterms:modified "2026-06-07T15:30:02.383975Z"^^xsd:dateTime .

oakcurric:keyword-cultural-mix
  a curric:Keyword ;
  schema:name "cultural mix"@en ;
  schema:description """in population, a community of people from different backgrounds with their
  own beliefs and traditions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383980Z"^^xsd:dateTime .

oakcurric:keyword-severity
  a curric:Keyword ;
  schema:name "severity"@en ;
  schema:description "the quality of being very serious"@en ;
  dcterms:modified "2026-06-07T15:30:02.384378Z"^^xsd:dateTime .

oakcurric:keyword-fertility-rate
  a curric:Keyword ;
  schema:name "fertility rate"@en ;
  schema:description "average number of children per woman in a population"@en ;
  dcterms:modified "2026-06-07T15:30:02.384771Z"^^xsd:dateTime .

oakcurric:keyword-death-rate
  a curric:Keyword ;
  schema:name "death rate"@en ;
  schema:description "number of deaths per 1000 people per year"@en ;
  dcterms:modified "2026-06-07T15:30:02.384775Z"^^xsd:dateTime .

oakcurric:keyword-gdp-per-capita
  a curric:Keyword ;
  schema:name "GDP per capita"@en ;
  schema:description """total value of goods and services produced within a country, divided by its
  population"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384862Z"^^xsd:dateTime .

oakcurric:keyword-gni-per-capita
  a curric:Keyword ;
  schema:name "GNI per capita"@en ;
  schema:description """GDP plus income from foreign investments and remittances, divided by the
  population"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384867Z"^^xsd:dateTime .

oakcurric:keyword-foreign-direct-investment
  a curric:Keyword ;
  schema:name "foreign direct investment"@en ;
  schema:description """(FDI) foreign countries invest in businesses or industries in another
  country, often by setting up or buying local companies"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384871Z"^^xsd:dateTime .

oakcurric:keyword-quality-of-life
  a curric:Keyword ;
  schema:name "quality of life"@en ;
  schema:description """wellbeing of individuals or groups of people measured by criteria other than
  wealth such as housing, employment and environmental factors"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384965Z"^^xsd:dateTime .

oakcurric:keyword-primary-employment
  a curric:Keyword ;
  schema:name "primary employment"@en ;
  schema:description """jobs involving the extraction of raw materials including farming, fishing
  and mining"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384969Z"^^xsd:dateTime .

oakcurric:keyword-famine
  a curric:Keyword ;
  schema:name "famine"@en ;
  schema:description """a famine is a situation in which there is not enough food for a great number
  of people, causing illness and death, or a particular period when this happens"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384985Z"^^xsd:dateTime .

oakcurric:keyword-quarrying
  a curric:Keyword ;
  schema:name "quarrying"@en ;
  schema:description "the process of extracting stone or other materials from a quarry"@en ;
  dcterms:modified "2026-06-07T15:30:02.385206Z"^^xsd:dateTime .

oakcurric:keyword-forestry
  a curric:Keyword ;
  schema:name "forestry"@en ;
  schema:description "the science and practice of planting, managing and caring for forests"@en ;
  dcterms:modified "2026-06-07T15:30:02.385210Z"^^xsd:dateTime .

oakcurric:keyword-coastal-morphology
  a curric:Keyword ;
  schema:name "coastal morphology"@en ;
  schema:description """the physical shape and size of a beach, a cliff, waves and beach
  sediment"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385247Z"^^xsd:dateTime .

oakcurric:keyword-transect
  a curric:Keyword ;
  schema:name "transect"@en ;
  schema:description "an imaginary line along which samples of data are collected"@en ;
  dcterms:modified "2026-06-07T15:30:02.385251Z"^^xsd:dateTime .

oakcurric:keyword-ranging-pole
  a curric:Keyword ;
  schema:name "ranging pole"@en ;
  schema:description """a metal pole (traditionally red and white striped) that is used to mark a
