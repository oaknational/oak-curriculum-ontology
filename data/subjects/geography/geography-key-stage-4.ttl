  schema:description """increase the spread of commercial activities, for example, by creating new
  enterprises on a farm such as a shop or a B&B"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359245Z"^^xsd:dateTime .

oakcurric:keyword-fracking
  a curric:Keyword ;
