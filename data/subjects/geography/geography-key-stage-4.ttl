  dcterms:modified "2026-06-07T15:30:29.259571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24592-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK's energy mix has diversified in response to policies of reducing carbon
  emissions and improving energy security."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24592-2
  a curric:KeyLearningPoint ;
  rdfs:label """2020 was the UK's first year in which more electricity came from alternatives to
  fossil fuels than from non-renewables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24592-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatives to fossil fuels can reduce carbon emissions, improve energy security
  and diversify the energy mix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24592-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatives to fossil fuels include biofuels, wind, solar, HEP and future
  technologies such as hydrogen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24592-5
  a curric:KeyLearningPoint ;
  rdfs:label "Alternatives to fossil fuels have both benefits and costs."@en ;
  dcterms:modified "2026-06-07T15:30:29.259757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22979-1
  a curric:KeyLearningPoint ;
