oakcurric:keyword-stakeholder
  a curric:Keyword ;
  schema:name "stakeholder"@en ;
  schema:description "anyone who has an interest in or is affected by a decision or issue"@en ;
  dcterms:modified "2026-06-07T15:30:02.356034Z"^^xsd:dateTime .

oakcurric:keyword-ngo
  a curric:Keyword ;
