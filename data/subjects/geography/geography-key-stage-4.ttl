  a curric:KeyLearningPoint ;
  rdfs:label """Rapid economic change has caused urbanisation and created regional disparities in
  Indonesia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24512-4
  a curric:KeyLearningPoint ;
  rdfs:label """Economic development and globalisation have had positive and negative impacts on
  different age and gender groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24510-1
  a curric:KeyLearningPoint ;
  rdfs:label "Indonesia has experienced rapid  economic change."@en ;
  dcterms:modified "2026-06-07T15:30:29.324847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24510-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Indonesia, there has been rapid economic change in GDP and per capita GNI since
  1990."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24510-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Indonesia, there have been changes in the importance of economic sectors since
  1990."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24510-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Indonesia, there have been economic changes in the type of foreign direct
  investment since 1990."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24493-1
  a curric:KeyLearningPoint ;
  rdfs:label "Eden is a very rural district within the rural county of Cumbria."@en ;
  dcterms:modified "2026-06-07T15:30:29.325252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24493-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eden has the highest percentage of green space and lowest population density of any
  district in England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24493-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eden ranks 186 on the Index of Multiple Deprivation. This masks areas of high
  deprivation such as barriers to services."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24493-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eden faces four challenges: housing, provision of education and healthcare and
  decline in primary employment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24493-5
  a curric:KeyLearningPoint ;
  rdfs:label """The young and elderly are more likely to be affected by challenges due to dependency
  on parents or the state for income."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24490-1
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool has a number of strategies involving housing such as affordability and
  energy efficiency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24490-2
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool has low rates of recycling. To address this it is using strategies such as
  education campaigns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24490-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some employment in Liverpool is low paid. Strategies to address this include paying
  the real national living wage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24490-4
  a curric:KeyLearningPoint ;
  rdfs:label """Green spaces have been considered in Liverpool’s city centre though the URBAN
  GreenUP project."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24490-5
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool is developing integrated transport systems to encourage use of public
  transport."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Glaciated upland areas provide opportunities for economic activities."@en ;
  dcterms:modified "2026-06-07T15:30:29.326132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27580-2
  a curric:KeyLearningPoint ;
  rdfs:label """Economic activities in glaciated upland areas include tourism, farming, forestry and
  quarrying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27580-3
  a curric:KeyLearningPoint ;
  rdfs:label """Economic activities have positive and negative impacts on glaciated upland
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24529-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate at
  the coast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24529-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data collection techniques at the coast look at beach and wave morphology and
  coastal management."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24529-3
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about particular coastlines and
  comparable data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24489-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rebranding and regeneration began in Liverpool in the 1980s to reverse the decline
  of the city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Significant regeneration has occurred in the centre including areas around the
  waterfront, RopeWalks and Lime Street."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24489-3
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool has been rebranded as a cultural hub due to sports, music, ethnic
  diversity and maritime and historical sites."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24489-4
  a curric:KeyLearningPoint ;
  rdfs:label """Positive impacts include greater job diversity, new leisure facilities and a higher
  quality urban environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24489-5
  a curric:KeyLearningPoint ;
  rdfs:label """Negative impacts include a loss of community, a persistent wealth gap and focus on
  tourist over local needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Between 1931 and 2021, population in some local authorities in the Liverpool City
  Region grew, e.g. Halton."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24488-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1960s saw decentralisation from the declining CBD and inner city in favour of
  the suburbs and rural-urban fringe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24488-3
  a curric:KeyLearningPoint ;
  rdfs:label "Developments in transport enabled decentralisation, e.g. new motorways."@en ;
  dcterms:modified "2026-06-07T15:30:29.327844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24488-4
  a curric:KeyLearningPoint ;
  rdfs:label """Economic growth was a result of the development of retail and business parks and out
  of town shopping from the 1970s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24488-5
  a curric:KeyLearningPoint ;
  rdfs:label """Urban sprawl in the suburbs and rural-urban fringe presents challenges, e.g.
  congestion and countryside destruction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24491-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cities are interdependent with accessible rural areas. An example of this is
  Liverpool and the village of Aughton."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24491-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interdependence involves flows of goods, services and labour between urban and
  accessible rural areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24491-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interdependence leads to economic, social and environmental benefits for Aughton and
  Liverpool."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24491-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interdependence leads to economic, social and environmental costs for Aughton and
  Liverpool."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24541-1
  a curric:KeyLearningPoint ;
  rdfs:label """Univariate data can be statistically analysed using measures of central
  tendancy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24541-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data can also be statistically analysed by thinking about proportions and how these
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24541-3
  a curric:KeyLearningPoint ;
  rdfs:label """The spread of data points across a range of values can be statistically analysed
  using percentiles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24492-1
  a curric:KeyLearningPoint ;
  rdfs:label "Aughton is a rural village easily accesible from Liverpool."@en ;
  dcterms:modified "2026-06-07T15:30:29.329692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24492-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aughton has experienced economic and social changes as a consequence of
  counter-urbanisation which began in the 1950s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24492-3
  a curric:KeyLearningPoint ;
  rdfs:label """Counter-urbanisation led to social changes in Aughton to do with its total
  population and population structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24492-4
  a curric:KeyLearningPoint ;
  rdfs:label "The demand for homes in the area has led to a pressure on housing affordability."@en ;
  dcterms:modified "2026-06-07T15:30:29.330200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24492-5
  a curric:KeyLearningPoint ;
  rdfs:label """The affluence of the area has led to high-end restaurants and increased visitors
  have put pressure on the area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22974-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ecosystems at the global scale are called biomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.332057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22974-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pattern of biomes is broadly latitudinal, with tropical rainforests near the
  Equator and tundra near the poles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22974-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each biome has distinct characteristics as a result of its specific climate."@en ;
  dcterms:modified "2026-06-07T15:30:29.332065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24579-1
  a curric:KeyLearningPoint ;
  rdfs:label "Demand for energy resources is rising globally."@en ;
  dcterms:modified "2026-06-07T15:30:29.334673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24579-2
  a curric:KeyLearningPoint ;
  rdfs:label "Globally, there are areas of surplus (security) and deficit (insecurity)."@en ;
  dcterms:modified "2026-06-07T15:30:29.334677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Impacts of energy insecurity include exploration in sensitive areas, economic and
  environmental costs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24528-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many stages of a geographical enquiry that can be evaluated."@en ;
  dcterms:modified "2026-06-07T15:30:29.335627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24528-2
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions should be evaluated to show how reliable and valid the data is."@en ;
  dcterms:modified "2026-06-07T15:30:29.335631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24528-3
  a curric:KeyLearningPoint ;
  rdfs:label """Geographical research is often evaluated to see how ethically and morally
  considerate it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24543-1
  a curric:KeyLearningPoint ;
  rdfs:label "The world is becoming increasingly urbanised."@en ;
  dcterms:modified "2026-06-07T15:30:29.335638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24543-2
  a curric:KeyLearningPoint ;
  rdfs:label "Trends in urbanisation (past, present and future) vary between global regions."@en ;
  dcterms:modified "2026-06-07T15:30:29.335642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24543-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some urban areas have grown into megacities."@en ;
  dcterms:modified "2026-06-07T15:30:29.335646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24543-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some urban areas have disproportionate economic and/or political influence."@en ;
  dcterms:modified "2026-06-07T15:30:29.335650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24525-1
  a curric:KeyLearningPoint ;
  rdfs:label "Geographers use different techniques to sample data during fieldwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.336982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24525-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are a variety of ways that we can measure the morphology (shape) of
  the land."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24525-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways that we can measure the characteristics of the land."@en ;
  dcterms:modified "2026-06-07T15:30:29.336990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24418-1
  a curric:KeyLearningPoint ;
  rdfs:label "Conservative plate margins involve two plates sliding alongside each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.336994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24418-2
  a curric:KeyLearningPoint ;
  rdfs:label "Distinctive processes occur at conservative plate margins."@en ;
  dcterms:modified "2026-06-07T15:30:29.337001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes occur at conservative plate margins but volcanoes do not."@en ;
  dcterms:modified "2026-06-07T15:30:29.337005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24594-1
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon footprint is the total greenhouse gas emissions caused directly and
  indirectly by an individual or activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24594-2
  a curric:KeyLearningPoint ;
  rdfs:label """In some developed countries, there are changing attitudes to unsustainable energy
  consumption."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24594-3
  a curric:KeyLearningPoint ;
  rdfs:label """Environmental concerns, economic interests and education are responsible for
  changing attitudes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24532-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate in rural
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24532-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data collection techniques in a rural area can investigate inequality, service
  provision and lived experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24532-3
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary data can provide contextual information about rural populations and spaces
  and how they have changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24556-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jakarta is a global megacity located on the island of Java and is the capital of
  Indonesia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Jakarta has distinctive characteristics of site, situation and connectivity."@en ;
  dcterms:modified "2026-06-07T15:30:29.338610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24556-3
  a curric:KeyLearningPoint ;
  rdfs:label "Jakarta is important nationally, regionally and internationally."@en ;
  dcterms:modified "2026-06-07T15:30:29.338614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24511-1
  a curric:KeyLearningPoint ;
  rdfs:label "Globalisation has had an important role in the development of Indonesia."@en ;
  dcterms:modified "2026-06-07T15:30:29.339066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24511-2
  a curric:KeyLearningPoint ;
  rdfs:label "Government policy has had an important role in the development of Indonesia."@en ;
  dcterms:modified "2026-06-07T15:30:29.339069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24511-3
  a curric:KeyLearningPoint ;
  rdfs:label "International aid has helped Indonesia develop and take part in globalisation."@en ;
  dcterms:modified "2026-06-07T15:30:29.339073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24413-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earth has a layered structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.339163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24413-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layers of Earth have different physical properties (temperature, density,
  composition, physical state)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24582-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many countries are taking action to use energy more sustainably."@en ;
  dcterms:modified "2026-06-07T15:30:29.339869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24582-2
  a curric:KeyLearningPoint ;
  rdfs:label "More sustainable energy use includes energy conservation and energy efficiency."@en ;
  dcterms:modified "2026-06-07T15:30:29.339873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24582-3
  a curric:KeyLearningPoint ;
  rdfs:label "Togo provides examples of local renewable energy schemes using solar power."@en ;
  dcterms:modified "2026-06-07T15:30:29.339877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Globally, there are areas of surplus (security) and deficit (insecurity), and
  inequalities in access to water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water insecurity has impacts on people when they use polluted water or contract
  waterborne diseases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Water insecurity has impacts on the economy including food production and industrial
  output."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24575-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is potential for conflict where demand exceeds supply."@en ;
  dcterms:modified "2026-06-07T15:30:29.339895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24581-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different strategies can be used to increase energy supply."@en ;
  dcterms:modified "2026-06-07T15:30:29.340585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24581-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies to increase energy supply include developing renewable and non-renewable
  sources of energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24581-3
  a curric:KeyLearningPoint ;
  rdfs:label """The USA is developing new sources of oil and gas in Alaska, which has advantages and
  disadvantages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24498-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are consequences of global inequality."@en ;
  dcterms:modified "2026-06-07T15:30:29.341007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24498-2
  a curric:KeyLearningPoint ;
  rdfs:label "Uneven development can result in disparities in wealth, health and education."@en ;
  dcterms:modified "2026-06-07T15:30:29.341011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24498-3
  a curric:KeyLearningPoint ;
  rdfs:label "Uneven development can result in different types of international migration."@en ;
  dcterms:modified "2026-06-07T15:30:29.341015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24530-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many geographical enquiry questions that you can investigate along the
  course of a river."""@en ;
