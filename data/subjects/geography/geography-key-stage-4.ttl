oakcurric:keylearningpoint-lesson-24578-3
  a curric:KeyLearningPoint ;
  rdfs:label """Groundwater management and improved water access has helped the community to adapt
  to the impacts of climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24576-1
  a curric:KeyLearningPoint ;
