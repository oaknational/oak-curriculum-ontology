  dcterms:modified "2026-06-07T15:30:29.261236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24421-1
  a curric:KeyLearningPoint ;
  rdfs:label """In January 2010, a 7.0 magnitude earthquake struck Haiti in the Caribbean, one of
  the world's poorest countries."""@en ;
