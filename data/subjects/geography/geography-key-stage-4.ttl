  dcterms:modified "2026-06-07T15:30:29.414060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24576-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water consumption is increasing due to economic development."@en ;
