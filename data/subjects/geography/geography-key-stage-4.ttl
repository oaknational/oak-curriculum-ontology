  dcterms:modified "2026-06-07T15:30:02.356741Z"^^xsd:dateTime .

oakcurric:keyword-response
  a curric:Keyword ;
  schema:name "response"@en ;
  schema:description "action taken to address the impacts of a disaster"@en ;
  dcterms:modified "2026-06-07T15:30:02.356748Z"^^xsd:dateTime .

oakcurric:keyword-mechanisation
  a curric:Keyword ;
  schema:name "mechanisation"@en ;
  schema:description """the development of machinery and technology in industries such that it
  reduces the need for human labour"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356752Z"^^xsd:dateTime .

oakcurric:keyword-global-shift
  a curric:Keyword ;
  schema:name "global shift"@en ;
  schema:description """the movement of manufacturing industries from developed countries to
