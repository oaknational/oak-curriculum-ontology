oakcurric:unit-3298
  a curric:Unit ;
  rdfs:label "Fieldwork"@en ;
  curric:slug "fieldwork" ;
  rdfs:comment """This unit teaches pupils about fieldwork, an important assessment component at
  GCSE. Pupils will learn about the six stages of enquiry (formulating a question;
  collecting, presenting and analysing data; and writing conclusions and an evaluation).
  Pupils will also consider four field study options."""@en ;
  curric:whyThisWhyNow """Fieldwork is an essential part of geography and features as an assessment
  component at GCSE. This unit builds on the appropriate subject knowledge gained in earlier
  units and, at the start of Year 11, is an ideal time to embark on fieldwork (weather
  condusive to outdoor work, high level of pupil maturity, break in routine of study).""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3298-1 ,
    oakcurric:priorknowledge-3298-2 ,
    oakcurric:priorknowledge-3298-3 ,
    oakcurric:priorknowledge-3298-4 ,
    oakcurric:priorknowledge-3298-5 ,
    oakcurric:priorknowledge-3298-6 ,
    oakcurric:priorknowledge-3298-7 ;
  curric:id "3298"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.082130Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-geography-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-physical-systems-and-processes ,
    oakcurric:thread-human-systems-and-processes .

