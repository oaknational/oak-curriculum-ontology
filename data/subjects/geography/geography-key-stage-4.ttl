  dcterms:modified "2026-06-07T15:30:02.356197Z"^^xsd:dateTime .

oakcurric:keyword-boserup
  a curric:Keyword ;
  schema:name "Boserup"@en ;
  schema:description """Ester Boserup (born 1910) took an optimistic view of the link between
  population growth and agriculture"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356204Z"^^xsd:dateTime .

oakcurric:keyword-deforestation
  a curric:Keyword ;
