  dcterms:modified "2026-06-07T15:30:02.394613Z"^^xsd:dateTime .

oakcurric:keyword-research-framework
  a curric:Keyword ;
  schema:name "research framework"@en ;
  schema:description "the type of geographical research on which the enquiry will focus"@en ;
  dcterms:modified "2026-06-07T15:30:02.395139Z"^^xsd:dateTime .

oakcurric:keyword-land-use
