    oakcurric:thread-human-systems-and-processes .

oakcurric:unit-3705
  a curric:Unit ;
  rdfs:label "Making geographical decisions"@en ;
  curric:slug "making-geographical-decisions" ;
  rdfs:comment """This unit teaches pupils how to address a key exam component, 'Making a Decision'.
  Pupils learn how to address these important geographical skills to support them in the
  run-up to the exam."""@en ;
  curric:whyThisWhyNow """This final unit is based on selected geographical content studied during
  Years 10 and 11. Pupils need the knowledge and skills learned throughout the course to enable
  them to achieve success Making a Decision.""" ;
