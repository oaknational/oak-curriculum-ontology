# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-29408-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cold environment ecosystems exhibit interdependence of climate, water, soils,
  plants, animals and people."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29408-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food chains and food webs show how biotic and abiotic components are interdependent
  in a cold environment."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nutrient cycles show how biotic and abiotic components are interdependent in a cold
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24552-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are challenges associated with managing urban growth in Jakarta."@en ;
  dcterms:modified "2026-06-07T15:30:29.001324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24552-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rapid population growth has created housing shortages in Jakarta."@en ;
  dcterms:modified "2026-06-07T15:30:29.001328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24552-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are challenges associated with squatter settlements in Jakarta."@en ;
  dcterms:modified "2026-06-07T15:30:29.001332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24434-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate has changed in the past through natural causes."@en ;
  dcterms:modified "2026-06-07T15:30:29.002865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24434-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence for natural climate change include ice cores, tree rings and historical
  sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24434-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence can be used to reconstruct climate change from the Quaternary to the
  present day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24502-1
  a curric:KeyLearningPoint ;
  rdfs:label """Top-down and bottom-up strategies to reduce global inequalities differ in scale,
  aims, funding and technology."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24502-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies such as foreign direct investment contribute to globalisation, but some
  countries benefit more than others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24502-3
  a curric:KeyLearningPoint ;
  rdfs:label """Foreign direct investment by TNCs can lead to large-scale, economic change; but
  profits leak and jobs may be short-term."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24502-4
  a curric:KeyLearningPoint ;
  rdfs:label """Loans from IGOs for large infrastructure projects can deliver technological
  solutions, but also risk debt problems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24473-1
  a curric:KeyLearningPoint ;
  rdfs:label "Globalisation has increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.002916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24473-2
  a curric:KeyLearningPoint ;
  rdfs:label "Free-trade policies have increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.002920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24473-3
  a curric:KeyLearningPoint ;
  rdfs:label "Privatisation has increased foreign direct investment in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.002926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24473-4
  a curric:KeyLearningPoint ;
  rdfs:label "TNCs play a significant role in the UK economy."@en ;
  dcterms:modified "2026-06-07T15:30:29.002931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24449-1
  a curric:KeyLearningPoint ;
  rdfs:label "Happisburgh is experiencing some of the fastest coastal erosion rates in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.003665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24449-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical processes make the Happisburgh coastline vulnerable to erosion."@en ;
  dcterms:modified "2026-06-07T15:30:29.003669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24449-3
  a curric:KeyLearningPoint ;
  rdfs:label """Human processes play a significant role in the rate of coastal erosion at
  Happisburgh."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deindustrialisation in the 20th century triggered depopulation in Liverpool's CBD
  and inner city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24487-2
  a curric:KeyLearningPoint ;
  rdfs:label """The CBD and inner city experienced decline from the 1930s to 1990s followed by
  growth due to regeneration efforts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decline in the CBD and inner city led to challenges including dereliction,
  unemployment and economic recession."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24487-4
  a curric:KeyLearningPoint ;
  rdfs:label """21st century economic and population growth led to significant investment in the
  CBD."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Studentification, gentrification and e-commernce have brought challenges and
  opportunities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24471-1
  a curric:KeyLearningPoint ;
  rdfs:label """National migration has altered the population geography of the UK (numbers,
  distribution, age structure)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24471-2
  a curric:KeyLearningPoint ;
  rdfs:label """International migration has altered the population geography of the UK (numbers,
  distribution, age structure)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24471-3
  a curric:KeyLearningPoint ;
  rdfs:label """UK and EU immigration policy has contributed to increasing ethnic and cultural
  diversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24553-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are challenges associated with providing clean water, sanitation systems and
  energy in Jakarta."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24553-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are challenges associated with providing access to health and education
  services in Jakarta."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24553-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are challenges associated with reducing unemployment and crime in Jakarta."@en ;
  dcterms:modified "2026-06-07T15:30:29.252648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24549-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jakarta is located on the island of Java and is the capital of Indonesia."@en ;
  dcterms:modified "2026-06-07T15:30:29.252677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24549-2
  a curric:KeyLearningPoint ;
  rdfs:label "Jakarta is important nationally, regionally and internationally."@en ;
  dcterms:modified "2026-06-07T15:30:29.252681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24549-3
  a curric:KeyLearningPoint ;
  rdfs:label "Jakarta has experienced rapid growth due to natural increase and migration."@en ;
  dcterms:modified "2026-06-07T15:30:29.252686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24555-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Kampung Akuarium project has improved quality of life for the urban poor in
  Jakarta by improving housing conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Posyandu clinics have improved quality of life for the urban poor in Jakarta by
  improving access to healthcare."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24555-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages of 'bottom-up' strategies for improving
  health and education services."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22976-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are home to a wide variety of plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.252706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22976-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants are adapted to the physical conditions in tropical rainforests, for example,
  drip tips and buttress roots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22976-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals are well adapted to the physical conditions in tropical rainforests."@en ;
  dcterms:modified "2026-06-07T15:30:29.252717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24448-1
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of human activities take place at the coast (development, agriculture,
  industry and coastal management)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24448-2
  a curric:KeyLearningPoint ;
  rdfs:label "Human activities can have direct effects on coastal landscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.252949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24448-3
  a curric:KeyLearningPoint ;
  rdfs:label "Human activities can have indirect effects on coastal landscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.252953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22977-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests support high levels of biodiversity."@en ;
  dcterms:modified "2026-06-07T15:30:29.252958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22977-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests have high rates of nutrient cycling."@en ;
  dcterms:modified "2026-06-07T15:30:29.252963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22977-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests support complex food webs."@en ;
  dcterms:modified "2026-06-07T15:30:29.252968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24437-1
  a curric:KeyLearningPoint ;
  rdfs:label "Managing climate change can involve mitigation strategies."@en ;
  dcterms:modified "2026-06-07T15:30:29.253902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24437-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mitigation strategies include alternative energy production, carbon capture and
  planting trees."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24437-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mitigation can involve international agreements."@en ;
  dcterms:modified "2026-06-07T15:30:29.253911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24443-1
  a curric:KeyLearningPoint ;
  rdfs:label "The coast is shaped by weathering processes (mechanical and chemical)."@en ;
  dcterms:modified "2026-06-07T15:30:29.253972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24443-2
  a curric:KeyLearningPoint ;
  rdfs:label """The coast is shaped by processes of mass movement (sliding, slumping and rock
  falls)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24429-1
  a curric:KeyLearningPoint ;
  rdfs:label """Monitoring, for example using satellite technology, can reduce the effects of
  tropical storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24429-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prediction, for example using weather forecasting, can reduce the effects of
  tropical storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24429-3
  a curric:KeyLearningPoint ;
  rdfs:label """Protection and planning, for example evacuation strategies, can reduce the effects
  of tropical storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24533-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atlases present the world at the smallest scale, showing the least detail but larger
  patterns and relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24533-2
  a curric:KeyLearningPoint ;
  rdfs:label "Atlases use latitude and longitude lines to locate particular places."@en ;
  dcterms:modified "2026-06-07T15:30:29.254804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24533-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are many types of atlas map that are used to show specific information."@en ;
  dcterms:modified "2026-06-07T15:30:29.254808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22981-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable management means using resources in a way that allows future generations
  to use them in the same way too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22981-2
  a curric:KeyLearningPoint ;
  rdfs:label """Local actions, such as alternative livelihoods, enable tropical rainforests to be
  sustainably managed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22981-3
  a curric:KeyLearningPoint ;
  rdfs:label "Global actions can contribute to sustainable management of tropical rainforests."@en ;
  dcterms:modified "2026-06-07T15:30:29.255128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24439-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK has upland and lowland landscapes and river systems."@en ;
  dcterms:modified "2026-06-07T15:30:29.255919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24439-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geology affects the shape and type of UK landscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.255923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24439-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tectonic activity has helped form upland and lowland areas."@en ;
  dcterms:modified "2026-06-07T15:30:29.255927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24439-4
  a curric:KeyLearningPoint ;
  rdfs:label "Glacial erosion and deposition shaped upland and lowland landscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.255934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24439-5
  a curric:KeyLearningPoint ;
  rdfs:label "Geology is the study of the Earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.255939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24426-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical storms have distinctive structural characteristics and are widely
  distributed within the tropics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24426-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical storms are related to the atmospheric circulation and are formed by
  particular meteorological conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24426-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical storms form in source areas, intensify as they track over oceans and then
  dissipate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24426-4
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change may affect the distribution, frequency and intensity of tropical
  storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22975-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are distinctive global biomes (large-scale ecosystems)."@en ;
  dcterms:modified "2026-06-07T15:30:29.256988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical rainforests have distinctive abiotic characteristics that result from the
  equatorial climate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical rainforests have distinctive biotic characteristics, including the
  structure of vegetation into layers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24427-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical storms have significant effects on people and the environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.257000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24427-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical storms have primary effects on people and the environment, such as strong
  winds, heavy rain and storm surges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24427-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tropical storms have secondary effects on people and the environment, such as
  coastal flooding and landslides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24427-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some countries are more vulnerable to the impacts (physically, socially and
  economically) of tropical storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22983-1
  a curric:KeyLearningPoint ;
  rdfs:label "The taiga is an example of a global biome."@en ;
  dcterms:modified "2026-06-07T15:30:29.257019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22983-2
  a curric:KeyLearningPoint ;
  rdfs:label """The taiga has distinctive biotic (living) characteristics (plants, animals and
  humans)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22983-3
  a curric:KeyLearningPoint ;
  rdfs:label """The taiga has distinctive abiotic (non-living) characteristics (climate, soil and
  water)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22983-4
  a curric:KeyLearningPoint ;
  rdfs:label "Biotic and abiotic characteristics are interdependent."@en ;
  dcterms:modified "2026-06-07T15:30:29.257034Z"^^xsd:dateTime .

