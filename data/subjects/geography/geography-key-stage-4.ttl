  dcterms:modified "2026-06-07T15:30:29.632161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29583-1
  a curric:KeyLearningPoint ;
  rdfs:label "GIS can be used to add and visualise georeferenced data in a webmap."@en ;
  dcterms:modified "2026-06-07T15:30:29.632493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29583-2
  a curric:KeyLearningPoint ;
  rdfs:label """GIS uses a variety of basemaps which need to be selected carefully to visualise data
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29583-3
  a curric:KeyLearningPoint ;
  rdfs:label """GIS uses filters to select data in a layer to visualise spatial patterns more
  clearly and avoid cluttering a webmap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29583-4
  a curric:KeyLearningPoint ;
  rdfs:label """GIS uses tools such as buffers to create visualisations which support analysis of
  data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28469-1
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to visualise glacial landforms of the physical geography of upland
  areas such as North Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28469-2
