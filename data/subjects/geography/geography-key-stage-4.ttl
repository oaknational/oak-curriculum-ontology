  dcterms:modified "2026-06-07T15:30:29.371957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22972-1
  a curric:KeyLearningPoint ;
  rdfs:label """On a large-scale, climate is the main factor affecting the distribution of
