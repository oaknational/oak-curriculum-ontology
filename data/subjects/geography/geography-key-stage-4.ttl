oakcurric:keyword-non-governmental-organisation
  a curric:Keyword ;
  schema:name "non-governmental organisation"@en ;
  schema:description """a non-profit, voluntary group of citizens who work on a local, national or
  international level to achieve an aim; they are not controlled by the Government, but will
  often work closely with them"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362144Z"^^xsd:dateTime .

oakcurric:keyword-demography
  a curric:Keyword ;
  schema:name "demography"@en ;
  schema:description "the study of population: its size, composition and change over time"@en ;
  dcterms:modified "2026-06-07T15:30:02.362987Z"^^xsd:dateTime .

oakcurric:keyword-birth-rate
  a curric:Keyword ;
  schema:name "birth rate"@en ;
  schema:description "the number of births for every 1000 people in a population per year"@en ;
  dcterms:modified "2026-06-07T15:30:02.362992Z"^^xsd:dateTime .

oakcurric:keyword-population-pyramid
  a curric:Keyword ;
  schema:name "population pyramid"@en ;
  schema:description """an age-sex graph used to present the structure of a population (that may
  resemble a pyramid)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362999Z"^^xsd:dateTime .

oakcurric:keyword-demographic-transition-model
  a curric:Keyword ;
  schema:name "demographic transition model"@en ;
  schema:description """a theoretical model that suggests how birth rate, death rate and total
  population change over time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363004Z"^^xsd:dateTime .

oakcurric:keyword-tectonic-plate
  a curric:Keyword ;
  schema:name "tectonic plate"@en ;
  schema:description """a large, rigid slab of Earth's lithosphere (outer layer) that sits on the
  semi-solid asthenosphere beneath it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363030Z"^^xsd:dateTime .

oakcurric:keyword-asthenosphere
  a curric:Keyword ;
  schema:name "asthenosphere"@en ;
  schema:description "a semi-solid layer of Earth's upper mantle"@en ;
  dcterms:modified "2026-06-07T15:30:02.363034Z"^^xsd:dateTime .

oakcurric:keyword-convection
  a curric:Keyword ;
  schema:name "convection"@en ;
  schema:description """the transfer of heat through the movement of fluids: warmer, less dense
  material rises and cooler, denser material sinks, creating a circular flow"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363039Z"^^xsd:dateTime .

oakcurric:keyword-constructive-wave
  a curric:Keyword ;
  schema:name "constructive wave"@en ;
  schema:description """low-energy waves that result in the buildup of sediment along the
  coastline"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363109Z"^^xsd:dateTime .

oakcurric:keyword-destructive-wave
  a curric:Keyword ;
  schema:name "destructive wave"@en ;
  schema:description """high-energy waves that result in the removal of sediment along the
  coastline"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363114Z"^^xsd:dateTime .

oakcurric:keyword-value
  a curric:Keyword ;
  schema:name "value"@en ;
  schema:description """how important an area is either socially, economically or
  environmentally"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363205Z"^^xsd:dateTime .

oakcurric:keyword-hard-engineering
  a curric:Keyword ;
  schema:name "hard engineering"@en ;
  schema:description """using artificial structures to protect coastlines from erosion and
  flooding"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363210Z"^^xsd:dateTime .

oakcurric:keyword-soft-engineering
  a curric:Keyword ;
  schema:name "soft engineering"@en ;
  schema:description """making use of natural processes to reduce erosion and flooding in a way that
  minimies environmental impact"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363214Z"^^xsd:dateTime .

oakcurric:keyword-sampling
  a curric:Keyword ;
  schema:name "sampling"@en ;
  schema:description "the process of creating and using a sample"@en ;
  dcterms:modified "2026-06-07T15:30:02.363377Z"^^xsd:dateTime .

oakcurric:keyword-managed-retreat
  a curric:Keyword ;
  schema:name "managed retreat"@en ;
  schema:description """when areas of the coast are deliberately allowed to flood or erode
  naturally"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363486Z"^^xsd:dateTime .

oakcurric:keyword-stakeholders
  a curric:Keyword ;
  schema:name "stakeholders"@en ;
  schema:description """any groups or individuals involved in or interested in changes being made at
  the coast"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363491Z"^^xsd:dateTime .

oakcurric:keyword-topography
  a curric:Keyword ;
  schema:name "topography"@en ;
  schema:description "the shape and height of the land"@en ;
  dcterms:modified "2026-06-07T15:30:02.363665Z"^^xsd:dateTime .

oakcurric:keyword-landlocked
  a curric:Keyword ;
  schema:name "landlocked"@en ;
  schema:description "being surrounded by land of other countries, having no coast"@en ;
  dcterms:modified "2026-06-07T15:30:02.363672Z"^^xsd:dateTime .

oakcurric:keyword-colonialism
  a curric:Keyword ;
  schema:name "colonialism"@en ;
  schema:description """the occupation, management and control of one country by another, often
  involving exploitation of its people and resources"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363678Z"^^xsd:dateTime .

oakcurric:keyword-international-relations
  a curric:Keyword ;
  schema:name "international relations"@en ;
  schema:description """the way in which nations interact with and regard each other, in relation to
  politics, economics and culture"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363684Z"^^xsd:dateTime .

oakcurric:keyword-neo-colonialism
  a curric:Keyword ;
  schema:name "neo-colonialism"@en ;
  schema:description """the indirect control of one country by another via economic power or
  cultural influence"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363688Z"^^xsd:dateTime .

oakcurric:keyword-objective
  a curric:Keyword ;
  schema:name "objective"@en ;
  schema:description "not influenced by personal feelings or opinions when representing facts"@en ;
  dcterms:modified "2026-06-07T15:30:02.363740Z"^^xsd:dateTime .

oakcurric:keyword-evacuation
  a curric:Keyword ;
  schema:name "evacuation"@en ;
  schema:description "the process of moving people from a dangerous place to safety"@en ;
  dcterms:modified "2026-06-07T15:30:02.363968Z"^^xsd:dateTime .

oakcurric:keyword-emergency-aid
  a curric:Keyword ;
  schema:name "emergency aid"@en ;
  schema:description """immediate assistance and supplies provided to people affected by a
  disaster"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363974Z"^^xsd:dateTime .

oakcurric:keyword-extreme-poverty
  a curric:Keyword ;
  schema:name "extreme poverty"@en ;
  schema:description "living on less than $2.15 a day"@en ;
  dcterms:modified "2026-06-07T15:30:02.364100Z"^^xsd:dateTime .

oakcurric:keyword-modernisation-theory
  a curric:Keyword ;
  schema:name "modernisation theory"@en ;
  schema:description """a view that suggests that countries move through five stages of economic
  development, proposed by Rostow"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364105Z"^^xsd:dateTime .

oakcurric:keyword-manufacturing
  a curric:Keyword ;
  schema:name "manufacturing"@en ;
  schema:description """the secondary economic sector, involving making goods from raw materials or
  other manufactured products (for example motor vehicles)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364112Z"^^xsd:dateTime .

oakcurric:keyword-dependency-theory
  a curric:Keyword ;
  schema:name "dependency theory"@en ;
  schema:description """a socialist view that explains how the core (developed countries) exploit
  the periphery, proposed by Frank"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364117Z"^^xsd:dateTime .

oakcurric:keyword-culture
  a curric:Keyword ;
  schema:name "culture"@en ;
  schema:description "the shared ideas, customs, and art of a group of people"@en ;
  dcterms:modified "2026-06-07T15:30:02.364173Z"^^xsd:dateTime .

oakcurric:keyword-quantitative
  a curric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "Refers to a measurement of quantity. A numerical value."@en ;
  dcterms:modified "2026-06-07T15:30:02.364588Z"^^xsd:dateTime .

oakcurric:keyword-weather
  a curric:Keyword ;
  schema:name "weather"@en ;
  schema:description """the day-to-day conditions of the atmosphere at a particular place, e.g.
  temperature, rainfall"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364759Z"^^xsd:dateTime .

oakcurric:keyword-location
  a curric:Keyword ;
  schema:name "location"@en ;
  schema:description "where a shape or action is placed, e.g. a starting position"@en ;
  dcterms:modified "2026-06-07T15:30:02.365115Z"^^xsd:dateTime .

oakcurric:keyword-life-expectancy
  a curric:Keyword ;
  schema:name "life expectancy"@en ;
  schema:description "the average number of years a person is expected to live"@en ;
  dcterms:modified "2026-06-07T15:30:02.365437Z"^^xsd:dateTime .

oakcurric:keyword-economic
  a curric:Keyword ;
  schema:name "economic"@en ;
  schema:description "anything to do with money, jobs, and resources"@en ;
  dcterms:modified "2026-06-07T15:30:02.365453Z"^^xsd:dateTime .

oakcurric:keyword-waves
  a curric:Keyword ;
  schema:name "waves"@en ;
  schema:description "ripples in the sea caused by wind blowing over the surface of the water"@en ;
  dcterms:modified "2026-06-07T15:30:02.365471Z"^^xsd:dateTime .

oakcurric:keyword-destructive-waves
  a curric:Keyword ;
  schema:name "destructive waves"@en ;
  schema:description """high, steep waves, typically formed by local storms, that remove sediment
  from beaches"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365476Z"^^xsd:dateTime .

oakcurric:keyword-constructive-waves
  a curric:Keyword ;
  schema:name "constructive waves"@en ;
  schema:description """low waves, typically formed by distant storms, that deposit sediment onto
  beaches"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365483Z"^^xsd:dateTime .

oakcurric:keyword-recycle
  a curric:Keyword ;
  schema:name "recycle"@en ;
  schema:description """Recycling is when we collect and sort our rubbish instead of throwing it
  away. These items then get changed into something new for us to use."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365622Z"^^xsd:dateTime .

oakcurric:keyword-attribute
  a curric:Keyword ;
  schema:name "attribute"@en ;
  schema:description "properties or characteristics of an entity"@en ;
  dcterms:modified "2026-06-07T15:30:02.366273Z"^^xsd:dateTime .

oakcurric:keyword-qualitative
  a curric:Keyword ;
  schema:name "qualitative"@en ;
  schema:description "A test in which the result is based on an observation."@en ;
  dcterms:modified "2026-06-07T15:30:02.366585Z"^^xsd:dateTime .

oakcurric:keyword-relief
  a curric:Keyword ;
  schema:name "relief"@en ;
  schema:description """a sculptural technique where the designs are raised above a flat
  background"""@en ;
  dcterms:modified "2026-06-07T15:30:02.366713Z"^^xsd:dateTime .

oakcurric:keyword-green-space
  a curric:Keyword ;
  schema:name "green space"@en ;
  schema:description """areas of grass, trees, or plants within urban environments, like parks or
  gardens"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367009Z"^^xsd:dateTime .

oakcurric:keyword-quadrat
  a curric:Keyword ;
  schema:name "quadrat"@en ;
  schema:description """A quadrat is a square frame used to sample populations of plants or
  slow-moving animals."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367315Z"^^xsd:dateTime .

oakcurric:keyword-unconventional
  a curric:Keyword ;
  schema:name "unconventional"@en ;
  schema:description """If you are unconventional, you do not follow accepted norms or
  standards."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367746Z"^^xsd:dateTime .

oakcurric:keyword-food-web
  a curric:Keyword ;
  schema:name "food web"@en ;
  schema:description "a complex interconnection of food chains within an ecosystem"@en ;
  dcterms:modified "2026-06-07T15:30:02.368359Z"^^xsd:dateTime .

oakcurric:keyword-ecosystem-services
  a curric:Keyword ;
  schema:name "ecosystem services"@en ;
  schema:description """benefits gained from the day-to-day functioning of the world's ecosystems
  that support human life"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368398Z"^^xsd:dateTime .

oakcurric:keyword-regulate
  a curric:Keyword ;
  schema:name "regulate"@en ;
  schema:description """to control, for example, the flow of water in a pipe or the temperature in a
  room"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368403Z"^^xsd:dateTime .

oakcurric:keyword-soil-health
  a curric:Keyword ;
  schema:name "soil health"@en ;
  schema:description """the structure, composition and nutrient content of a soil; a measure of soil
  fertility"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368410Z"^^xsd:dateTime .

oakcurric:keyword-hydrological-cycle
  a curric:Keyword ;
  schema:name "hydrological cycle"@en ;
  schema:description """the continuous recycling of water in its different states, for example via
  rainfall and evaporation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368415Z"^^xsd:dateTime .

oakcurric:keyword-geographic-information-system
  a curric:Keyword ;
