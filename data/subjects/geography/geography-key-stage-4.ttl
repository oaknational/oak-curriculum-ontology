oakcurric:keylearningpoint-lesson-24421-2
  a curric:KeyLearningPoint ;
  rdfs:label """The earthquake was caused by slippage at the conservative margin between the
  Caribbean plate and North American plate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24421-3
  a curric:KeyLearningPoint ;
  rdfs:label """Primary and secondary effects of the disaster caused the deaths of more than 220 000
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24421-4
  a curric:KeyLearningPoint ;
  rdfs:label """Haiti's position as an LIC influenced its immediate and long-term responses and
  their effectiveness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22987-1
  a curric:KeyLearningPoint ;
  rdfs:label "The taiga is vulnerable to biodiversity loss."@en ;
