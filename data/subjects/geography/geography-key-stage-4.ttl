  dcterms:modified "2026-06-07T15:30:02.359917Z"^^xsd:dateTime .

oakcurric:keyword-pop-up
  a curric:Keyword ;
  schema:name "pop-up"@en ;
  schema:description """in GIS, a read-only display of attribute information (e.g. text, images,
  charts) often linked to a location"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359922Z"^^xsd:dateTime .

oakcurric:keyword-choropleth
