  schema:description """visible damage to a landscape caused by human activities such as mining or
  construction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396242Z"^^xsd:dateTime .

oakcurric:keyword-overtourism
  a curric:Keyword ;
  schema:name "overtourism"@en ;
  schema:description """when too many people visit a place, so that it is spoiled and life becomes
  difficult for people who live there"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398153Z"^^xsd:dateTime .

oakcurric:keyword-natural-hazard
  a curric:Keyword ;
  schema:name "natural hazard"@en ;
  schema:description """a natural event that has the potential to cause damage, loss of life or
  economic disruption"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398197Z"^^xsd:dateTime .

oakcurric:keyword-hazard-risk
  a curric:Keyword ;
  schema:name "hazard risk"@en ;
  schema:description """the likelihood that people or property will be harmed by a natural
  hazard"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398203Z"^^xsd:dateTime .

oakcurric:keyword-drainage
  a curric:Keyword ;
  schema:name "drainage"@en ;
  schema:description "the distribution, storage and movement of water in the environment"@en ;
  dcterms:modified "2026-06-07T15:30:02.398682Z"^^xsd:dateTime .

oakcurric:keyword-gross-national-income-gni
  a curric:Keyword ;
  schema:name "gross national income (GNI)"@en ;
  schema:description """a measure of goods and services produced by a country, including income
  earned abroad; may be divided by the total population to give ‘GNI per head’"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398710Z"^^xsd:dateTime .

oakcurric:keyword-human-development-index-hdi
  a curric:Keyword ;
  schema:name "Human Development Index (HDI)"@en ;
  schema:description """a UN measure of development calculated using education, life expectancy and
  income data"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398716Z"^^xsd:dateTime .

oakcurric:keyword-kampungs
  a curric:Keyword ;
  schema:name "kampungs"@en ;
  schema:description """informal settlements in Indonesian cities built by residents, often on
  derelict or unsafe land"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398758Z"^^xsd:dateTime .

oakcurric:keyword-bearing
  a curric:Keyword ;
  schema:name "Bearing"@en ;
  schema:description """A bearing is an angle measured in degrees from North in the clockwise
  direction and written with three figures."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399225Z"^^xsd:dateTime .

oakcurric:keyword-cholera
  a curric:Keyword ;
  schema:name "cholera"@en ;
  schema:description """a waterborne disease caused by bacteria in contaminated water or food. It
  spreads quickly in areas with poor sanitation and can cause severe diarrhoea and
  dehydration"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399319Z"^^xsd:dateTime .

oakcurric:keyword-dereliction
  a curric:Keyword ;
  schema:name "dereliction"@en ;
  schema:description """when buildings or land degrades into a state of poor condition, having been
  abandoned"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400486Z"^^xsd:dateTime .

oakcurric:keyword-contamination
  a curric:Keyword ;
  schema:name "contamination"@en ;
  schema:description "the process by which bacteria are transferred from one area to another"@en ;
  dcterms:modified "2026-06-07T15:30:02.401769Z"^^xsd:dateTime .

oakcurric:keyword-hydraulic-power
  a curric:Keyword ;
  schema:name "hydraulic power"@en ;
  schema:description """waves compress air into cracks in the rock, putting pressure on it and
  causing it to break over time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403622Z"^^xsd:dateTime .

oakcurric:keyword-biosphere
  a curric:Keyword ;
  schema:name "biosphere"@en ;
  schema:description """life on Earth, encompassing all living organisms (plants, animals, bacteria,
  etc.) and the ecosystems they form"""@en ;
  dcterms:modified "2026-06-07T15:30:02.405453Z"^^xsd:dateTime .

oakcurric:keyword-hdi
  a curric:Keyword ;
  schema:name "HDI"@en ;
  schema:description """the Human Development Index (HDI) is a composite measure of development
  using income, life expectancy and education, ranging between 0 and 1"""@en ;
  dcterms:modified "2026-06-07T15:30:02.405881Z"^^xsd:dateTime .

oakcurric:keyword-slope-processes
  a curric:Keyword ;
  schema:name "slope processes"@en ;
  schema:description "processes that move material downslope due to gravity"@en ;
  dcterms:modified "2026-06-07T15:30:02.405921Z"^^xsd:dateTime .

oakcurric:keyword-human-activity
  a curric:Keyword ;
  schema:name "human activity"@en ;
  schema:description "actions like farming, forestry and building that alter landscapes"@en ;
  dcterms:modified "2026-06-07T15:30:02.405931Z"^^xsd:dateTime .

oakcurric:keyword-water-conservation
  a curric:Keyword ;
  schema:name "water conservation"@en ;
  schema:description """reducing waste, such as through leakages, and unnecessary use e.g. using
  drinking water to flush toilets"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407755Z"^^xsd:dateTime .

oakcurric:keyword-groundwater-management
  a curric:Keyword ;
  schema:name "groundwater management"@en ;
  schema:description """regulation and control of water levels, pollution, ownership and use of
  groundwater"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407760Z"^^xsd:dateTime .

oakcurric:keyword-grey-water
  a curric:Keyword ;
  schema:name "'grey' water"@en ;
  schema:description """water from sinks, showers and washing machines that, whilst not suitable for
  drinking, can be used for other purposes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407769Z"^^xsd:dateTime .

oakcurric:keyword-disposable-income
  a curric:Keyword ;
  schema:name "disposable income"@en ;
  schema:description """money that people earn that is left over after they have paid their bills is
  called disposable income"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407774Z"^^xsd:dateTime .

oakcurric:keyword-abstraction
  a curric:Keyword ;
  schema:name "abstraction"@en ;
  schema:description "the extraction of water from a water source, such as a river or aquifer"@en ;
  dcterms:modified "2026-06-07T15:30:02.408185Z"^^xsd:dateTime .

oakcurric:keyword-over-abstraction
  a curric:Keyword ;
  schema:name "over-abstraction"@en ;
  schema:description "occurs when the extraction exceeds recharge by precipitation"@en ;
  dcterms:modified "2026-06-07T15:30:02.408190Z"^^xsd:dateTime .

oakcurric:keyword-wilderness-areas
  a curric:Keyword ;
  schema:name "wilderness areas"@en ;
  schema:description """large, undisturbed natural areas protected to preserve biodiversity and
  natural processes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408396Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-food-supply
  a curric:Keyword ;
  schema:name "sustainable food supply"@en ;
  schema:description """when food is produced in ways that avoid damaging natural resources, provide
  social benefits and contribute to local economies"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408456Z"^^xsd:dateTime .

oakcurric:keyword-organic-farming
  a curric:Keyword ;
  schema:name "organic farming"@en ;
  schema:description """when food is grown without the use of artificial chemicals, such as
  fertiliser and pesticide"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408461Z"^^xsd:dateTime .

oakcurric:keyword-permaculture
  a curric:Keyword ;
  schema:name "permaculture"@en ;
  schema:description """a system of farming based upon or directly using patterns and features
  observed in natural ecosystems, such as increased biodiversity and intercropping"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408467Z"^^xsd:dateTime .

oakcurric:keyword-urban-farming
  a curric:Keyword ;
  schema:name "urban farming"@en ;
  schema:description """the growing of crops and the raising of animals in towns and cities;
  includes processing and distributing food, as well as collecting and reusing food waste"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408476Z"^^xsd:dateTime .

oakcurric:keyword-indigenous-people
  a curric:Keyword ;
  schema:name "indigenous people"@en ;
  schema:description """people who have inhabited an area from the earliest times before the arrival
  of colonists"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408544Z"^^xsd:dateTime .

oakcurric:keyword-resources
  a curric:Keyword ;
  schema:name "resources"@en ;
  schema:description """materials available in the environment (such as water, food and wood) that
  support our wants and needs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408550Z"^^xsd:dateTime .

oakcurric:keyword-commercial-exploitation
  a curric:Keyword ;
  schema:name "commercial exploitation"@en ;
  schema:description "the extraction and trading of materials, such as wood, for profit"@en ;
  dcterms:modified "2026-06-07T15:30:02.408555Z"^^xsd:dateTime .

oakcurric:keyword-mineral-resources
  a curric:Keyword ;
  schema:name "mineral resources"@en ;
  schema:description """economically-valuable material concentrated in the Earth's crust, such as
  copper and oil"""@en ;
  dcterms:modified "2026-06-07T15:30:02.408560Z"^^xsd:dateTime .

oakcurric:keyword-food-insecurity
  a curric:Keyword ;
  schema:name "food insecurity"@en ;
  schema:description "being without reliable access to sufficient, affordable, nutritious food"@en ;
  dcterms:modified "2026-06-07T15:30:02.408879Z"^^xsd:dateTime .

oakcurric:keyword-development-gap
  a curric:Keyword ;
  schema:name "development gap"@en ;
  schema:description """the widening difference in standards of living and wellbeing between the
  world’s richest and poorest countries"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409169Z"^^xsd:dateTime .

oakcurric:keyword-manufacturing-industries
  a curric:Keyword ;
  schema:name "manufacturing industries"@en ;
  schema:description """the secondary economic sector, involving making goods from raw materials or
  other manufactured products (for example motor vehicles)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409174Z"^^xsd:dateTime .

oakcurric:keyword-service-industries
  a curric:Keyword ;
  schema:name "service industries"@en ;
  schema:description """the tertiary economic sector, which includes tourism, banking, education and
  health"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409180Z"^^xsd:dateTime .

oakcurric:keyword-microfinance-loans
  a curric:Keyword ;
  schema:name "microfinance loans"@en ;
  schema:description """the provision of small-scale loans given to people in LICs to help them
  start a small business"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409185Z"^^xsd:dateTime .

oakcurric:keyword-diplomatic-relations
  a curric:Keyword ;
  schema:name "diplomatic relations"@en ;
  schema:description """how well (or badly) countries get along with each other, which can affect
  trading relationships of supply and demand"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409375Z"^^xsd:dateTime .

oakcurric:keyword-recession
  a curric:Keyword ;
  schema:name "recession"@en ;
  schema:description "a period when economies stop growing temporarily and people spend less"@en ;
  dcterms:modified "2026-06-07T15:30:02.409380Z"^^xsd:dateTime .

oakcurric:keyword-post-industrial
  a curric:Keyword ;
  schema:name "post-industrial"@en ;
  schema:description """term used to describe a city after it has changed from being centre of
  manufacturing to a place where most people work in services"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410199Z"^^xsd:dateTime .

oakcurric:keyword-oblique-aerial-photograph
  a curric:Keyword ;
  schema:name "oblique aerial photograph"@en ;
  schema:description "an aerial photograph where the camera is at an angle to Earth’s surface"@en ;
  dcterms:modified "2026-06-07T15:30:02.411098Z"^^xsd:dateTime .

oakcurric:keyword-vertical-aerial-photograph
  a curric:Keyword ;
  schema:name "vertical aerial photograph"@en ;
  schema:description """a photograph taken straight down from the air, showing a view of Earth’s
  surface"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411103Z"^^xsd:dateTime .

oakcurric:keyword-critical-analysis
  a curric:Keyword ;
  schema:name "critical analysis"@en ;
  schema:description "thinking more widely about an image to gain a deeper understanding of it"@en ;
  dcterms:modified "2026-06-07T15:30:02.411111Z"^^xsd:dateTime .

oakcurric:keyword-empirical-evidence
  a curric:Keyword ;
  schema:name "empirical evidence"@en ;
  schema:description """evidence collected through direct observation and experience rather than
  through logical thinking"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411342Z"^^xsd:dateTime .

oakcurric:keyword-confirmation-bias
  a curric:Keyword ;
  schema:name "confirmation bias"@en ;
  schema:description """concluding what one believes to be true by basing one's ideas on some, but
  not all, of the evidence collected"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411350Z"^^xsd:dateTime .

oakcurric:keyword-basemap
  a curric:Keyword ;
  schema:name "basemap"@en ;
  schema:description "a background map in a GIS"@en ;
  dcterms:modified "2026-06-07T15:30:02.412622Z"^^xsd:dateTime .

oakcurric:keyword-management
  a curric:Keyword ;
  schema:name "management"@en ;
  schema:description """techniques used to reduce hazard risk, including short-term relief and
  long-term planning, preparation and prediction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413751Z"^^xsd:dateTime .

oakcurric:keyword-rock-type
  a curric:Keyword ;
  schema:name "rock type"@en ;
  schema:description "the physical and chemical characteristics of rocks"@en ;
  dcterms:modified "2026-06-07T15:30:02.414893Z"^^xsd:dateTime .

oakcurric:keyword-discordant-coastline
  a curric:Keyword ;
  schema:name "discordant coastline"@en ;
  schema:description "where rock layers (hard and soft) run perpendicular to the coastline"@en ;
  dcterms:modified "2026-06-07T15:30:02.414899Z"^^xsd:dateTime .

oakcurric:keyword-concordant-coastline
  a curric:Keyword ;
  schema:name "concordant coastline"@en ;
  schema:description "where rock layers (hard and soft) run parallel to the coastline"@en ;
  dcterms:modified "2026-06-07T15:30:02.414904Z"^^xsd:dateTime .

oakcurric:keyword-primary-sector
  a curric:Keyword ;
  schema:name "primary sector"@en ;
  schema:description """the part of an economy that involves using natural resources directly from
  the land or sea, for example, agriculture, fishing, forestry and mining"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415909Z"^^xsd:dateTime .

oakcurric:keyword-secondary-sector
  a curric:Keyword ;
  schema:name "secondary sector"@en ;
  schema:description """the part of an economy that involves manufacturing goods from raw materials
  or other manufactured goods, for example factory work, construction and food processing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415914Z"^^xsd:dateTime .

oakcurric:keyword-tertiary-sector
  a curric:Keyword ;
  schema:name "tertiary sector"@en ;
  schema:description """the part of an economy that provides services to people and businesses
  rather than goods, for example teachers, doctors, shop workers and delivery drivers"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415920Z"^^xsd:dateTime .

oakcurric:keyword-oil-reserves
  a curric:Keyword ;
  schema:name "oil reserves"@en ;
  schema:description "locations where oil is found in significant amounts"@en ;
  dcterms:modified "2026-06-07T15:30:02.415925Z"^^xsd:dateTime .

oakcurric:keyword-emerging-countries
  a curric:Keyword ;
  schema:name "emerging countries"@en ;
  schema:description """nations with social or business activities in the process of rapid growth
  and industrialisation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415931Z"^^xsd:dateTime .

oakcurric:keyword-primary-data
  a curric:Keyword ;
  schema:name "primary data"@en ;
  schema:description "data that is collected in person during fieldwork"@en ;
  dcterms:modified "2026-06-07T15:30:02.416587Z"^^xsd:dateTime .

oakcurric:keyword-secondary-data
  a curric:Keyword ;
  schema:name "secondary data"@en ;
  schema:description """data that has previously been collected by someone, usually unknown to the
  person doing the fieldwork"""@en ;
  dcterms:modified "2026-06-07T15:30:02.416592Z"^^xsd:dateTime .

oakcurric:keyword-top-down-development
  a curric:Keyword ;
  schema:name "top-down development"@en ;
  schema:description """development led by governments or large organisations, often with
  large-scale funding and limited community input"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417508Z"^^xsd:dateTime .

oakcurric:keyword-last-glacial-maximum-lgm
  a curric:Keyword ;
  schema:name "Last Glacial Maximum (LGM)"@en ;
  schema:description """period when ice sheets were at their largest extent, during the last Ice Age
  about 26 000 years ago"""@en ;
  dcterms:modified "2026-06-07T15:30:02.418552Z"^^xsd:dateTime .

oakcurric:keyword-corrie-or-cwm
  a curric:Keyword ;
  schema:name "corrie (or cwm)"@en ;
  schema:description """a bowl-shaped hollow eroded by a glacier, typically forming at the head of a
  valley"""@en ;
  dcterms:modified "2026-06-07T15:30:02.418558Z"^^xsd:dateTime .

oakcurric:keyword-contour-lines
  a curric:Keyword ;
  schema:name "contour lines"@en ;
  schema:description "lines drawn on maps that connect points of equal height above sea level"@en ;
  dcterms:modified "2026-06-07T15:30:02.418563Z"^^xsd:dateTime .

oakcurric:keyword-periphery
  a curric:Keyword ;
  schema:name "periphery"@en ;
  schema:description "the outer edges or boundary of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.418713Z"^^xsd:dateTime .

oakcurric:keyword-recyclable-energy
  a curric:Keyword ;
  schema:name "recyclable energy"@en ;
  schema:description """sources of energy that can be reused and so will last into the future, such
  as biofuels and nuclear energy"""@en ;
  dcterms:modified "2026-06-07T15:30:02.418980Z"^^xsd:dateTime .

oakcurric:keyword-energy-efficient
  a curric:Keyword ;
  schema:name "energy efficient"@en ;
  schema:description """being able to produce the same level of output but through the use of less
  energy"""@en ;
  dcterms:modified "2026-06-07T15:30:02.419621Z"^^xsd:dateTime .

oakcurric:keyword-commuter
  a curric:Keyword ;
  schema:name "commuter"@en ;
  schema:description """someone who lives a distance from where they work and has to regularly
  travel between the two locations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.419753Z"^^xsd:dateTime .

oakcurric:keyword-asean
  a curric:Keyword ;
  schema:name "ASEAN"@en ;
  schema:description """the Association of Southeast Asian Nations is a group of 10 nations who
  cooperate on trade and security with the aim of boosting their economic, social and
  cultural development"""@en ;
  dcterms:modified "2026-06-07T15:30:02.420070Z"^^xsd:dateTime .

oakcurric:keyword-regional-inequality
  a curric:Keyword ;
  schema:name "regional inequality"@en ;
  schema:description """differences in the standard of living and wealth between two areas of the
  same country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.420999Z"^^xsd:dateTime .

oakcurric:keyword-elevation-profile
  a curric:Keyword ;
  schema:name "Elevation Profile"@en ;
  schema:description """a GIS tool which visualises changes in height above or below sea level along
  a transect line"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421347Z"^^xsd:dateTime .

oakcurric:keyword-bipolar-scoring
  a curric:Keyword ;
  schema:name "bipolar scoring"@en ;
  schema:description "a score scale that uses both positive and negative values"@en ;
  dcterms:modified "2026-06-07T15:30:02.421431Z"^^xsd:dateTime .

oakcurric:keyword-proxy-indicator
  a curric:Keyword ;
  schema:name "proxy indicator"@en ;
  schema:description "a variable which indirectly suggests that another variable may be true"@en ;
  dcterms:modified "2026-06-07T15:30:02.421441Z"^^xsd:dateTime .

oakcurric:keyword-margin
  a curric:Keyword ;
  schema:name "margin"@en ;
  schema:description "the boundary where tectonic plates meet"@en ;
  dcterms:modified "2026-06-07T15:30:02.423016Z"^^xsd:dateTime .

oakcurric:keyword-bathymetry
  a curric:Keyword ;
  schema:name "bathymetry"@en ;
  schema:description """the measurement of elevation for bodies of water, e.g. depth of oceans,
  seas, or lakes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423022Z"^^xsd:dateTime .

oakcurric:keyword-traditional-industries
  a curric:Keyword ;
  schema:name "traditional industries"@en ;
  schema:description """labour-intensive industries such as coal mining, steel and textile
  production and ship building"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423325Z"^^xsd:dateTime .

oakcurric:keyword-suburbanisation
  a curric:Keyword ;
  schema:name "suburbanisation"@en ;
  schema:description """the movement of people from more central urban areas to the outskirts of an
  urban area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423419Z"^^xsd:dateTime .

oakcurric:keyword-international-migration
  a curric:Keyword ;
  schema:name "international migration"@en ;
  schema:description "the movement of people from one country to another"@en ;
  dcterms:modified "2026-06-07T15:30:02.423865Z"^^xsd:dateTime .

oakcurric:keyword-river-discharge
  a curric:Keyword ;
  schema:name "river discharge"@en ;
  schema:description """the volume of water that flows through a river at a given point over a
  specific period of time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424125Z"^^xsd:dateTime .

oakcurric:keyword-river-velocity
  a curric:Keyword ;
  schema:name "river velocity"@en ;
  schema:description "the speed at which water flows in a river"@en ;
  dcterms:modified "2026-06-07T15:30:02.424130Z"^^xsd:dateTime .

oakcurric:keyword-georeferenced-data
  a curric:Keyword ;
  schema:name "georeferenced data"@en ;
  schema:description """information which has been tied to a particular location (geolocated), using
  an agreed system such as latitude and longitude"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424293Z"^^xsd:dateTime .

oakcurric:keyword-primary-impact
  a curric:Keyword ;
  schema:name "primary impact"@en ;
  schema:description """the immediate impacts of a tectonic hazard which are directly caused
  by it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424298Z"^^xsd:dateTime .

oakcurric:keyword-secondary-impact
  a curric:Keyword ;
  schema:name "secondary impact"@en ;
  schema:description """indirect effects that occur as a consequence of a tectonic hazard’s primary
  impacts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424304Z"^^xsd:dateTime .

oakcurric:keyword-geospatial-data
  a curric:Keyword ;
  schema:name "geospatial  data"@en ;
  schema:description """georeferenced information including quantitative data (e.g. numbers) or
  qualitative data (e.g. photos), which has been tied to a particular location (geolocated)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424594Z"^^xsd:dateTime .

oakcurric:keyword-media-layers
  a curric:Keyword ;
  schema:name "media layers"@en ;
  schema:description """overlays of scanned maps, aerial or satellite images which can be
  georeferenced to visually line up with other layers"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424599Z"^^xsd:dateTime .

oakcurric:keyword-greenfield-site
  a curric:Keyword ;
  schema:name "greenfield site"@en ;
  schema:description """land, often rural or on the edges of urban areas, which has not been built
  on before"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424605Z"^^xsd:dateTime .

oakcurric:keyword-analysis-tools
  a curric:Keyword ;
  schema:name "analysis tools"@en ;
  schema:description """a range of GIS applications used to support the processing, analysing, and
  visualising of spatial data"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425109Z"^^xsd:dateTime .

oakcurric:keyword-trace-downstream
  a curric:Keyword ;
  schema:name "Trace Downstream"@en ;
  schema:description """a GIS tool which maps the course of a river from a location such as its
  source to the end of the river"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425114Z"^^xsd:dateTime .

oakcurric:keyword-create-watersheds
  a curric:Keyword ;
  schema:name "Create Watersheds"@en ;
  schema:description """a GIS tool which maps the drainage basin or catchment of a river and all of
  its tributaries"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425119Z"^^xsd:dateTime .

oakcurric:keyword-buffer
  a curric:Keyword ;
  schema:name "buffer"@en ;
  schema:description """in GIS, an area generated by analysis tools for a specified distance around
  a point, line or polygon feature"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427258Z"^^xsd:dateTime .

oakcurric:keyword-glacial-landforms
  a curric:Keyword ;
  schema:name "glacial landforms"@en ;
  schema:description """physical landscape features created by the action of glaciers during a
  glaciation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427622Z"^^xsd:dateTime .

oakcurric:keyword-oblique-view
  a curric:Keyword ;
  schema:name "oblique view"@en ;
  schema:description """a view over a landscape from one side at an angle (also known as
  ‘perspective view’)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427627Z"^^xsd:dateTime .

oakcurric:keyword-spot-height
  a curric:Keyword ;
  schema:name "spot height"@en ;
  schema:description "a point marked on a map showing a particular height"@en ;
  dcterms:modified "2026-06-07T15:30:02.427756Z"^^xsd:dateTime .

oakcurric:keyword-remote-sensing
  a curric:Keyword ;
  schema:name "remote sensing"@en ;
  schema:description """the collection of data at a distance reflected or emitted by objects, living
  things or areas on different wavelengths of the electromagnetic spectrum, observed by
  satellite or aircraft"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427762Z"^^xsd:dateTime .

oakcurric:keyword-satellite-imagery
  a curric:Keyword ;
  schema:name "satellite imagery"@en ;
  schema:description """a type of remote sensing which uses observations by satellites of selected
  parts of the electromagnetic spectrum to monitor terrestrial, oceanic or atmospheric
  features and processes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427767Z"^^xsd:dateTime .

oakcurric:keyword-aerial-imagery
  a curric:Keyword ;
  schema:name "aerial imagery"@en ;
  schema:description """a type of remote sensing which uses observations by aircraft of selected
  parts of the electromagnetic spectrum to monitor terrestrial, oceanic or atmospheric
  features and processes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427773Z"^^xsd:dateTime .

oakcurric:keyword-rift-valley
  a curric:Keyword ;
  schema:name "rift valley"@en ;
  schema:description """a long, narrow depression formed when a tectonic plate stretches and
  fractures at a constructive margin, causing the land to sink between parallel fault lines"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428241Z"^^xsd:dateTime .

oakcurric:keyword-shield-volcano
  a curric:Keyword ;
  schema:name "shield volcano"@en ;
  schema:description """a broad, gently sloping volcano formed by basaltic lava that is runny and
  flows easily. Eruptions tend to be effusive rather than explosive - lava flows out"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428246Z"^^xsd:dateTime .

oakcurric:keyword-flood-defences
  a curric:Keyword ;
  schema:name "flood defences"@en ;
  schema:description "structures built to protect areas from flooding"@en ;
  dcterms:modified "2026-06-07T15:30:02.428403Z"^^xsd:dateTime .

oakcurric:keyword-urban-regeneration
  a curric:Keyword ;
  schema:name "urban regeneration"@en ;
  schema:description "planned improvements to an area of deprivation within a town or city"@en ;
  dcterms:modified "2026-06-07T15:30:02.428506Z"^^xsd:dateTime .

oakcurric:keyword-coastal-erosion-landforms
  a curric:Keyword ;
  schema:name "coastal erosion landforms"@en ;
  schema:description "landforms resulting from a dominance of coastal erosion"@en ;
  dcterms:modified "2026-06-07T15:30:02.428547Z"^^xsd:dateTime .

oakcurric:keyword-coastal-deposition-landforms
  a curric:Keyword ;
  schema:name "coastal deposition landforms"@en ;
  schema:description "landforms resulting from a dominance of coastal deposition"@en ;
  dcterms:modified "2026-06-07T15:30:02.428552Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-soil-biotic-component-ecosystems-because
  a curric:Misconception ;
  curric:statement """Soil is a biotic component of ecosystems because it contains living
  organisms."""@en ;
  curric:correction """Soil is classed as an abiotic component because soil itself is
  non-living."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084139Z"^^xsd:dateTime .

oakcurric:misconception-homes-jakarta-piped-water-connected
  a curric:Misconception ;
  curric:statement """Most homes in Jakarta have piped water and are connected to city sewage
  infrastructure."""@en ;
  curric:correction """Only 65% of Jakarta has piped water. In kampungs, many homes lack running
  water and toilets, relying on public wells and pumps and shared toilet facilities, which
  can spread disease."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084449Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-happened-recently
  a curric:Misconception ;
  curric:statement "Climate change has only happened recently."@en ;
  curric:correction """The Earth's climate patterns have changed numerous times in the past, for
  example there have been around 50 cycles of glacial (cold) phases and interglacial
  (warmer) phases in the Quaternary period."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084878Z"^^xsd:dateTime .

oakcurric:misconception-global-shift-manufacturing-industries-developed
  a curric:Misconception ;
  curric:statement """The 'global shift' of manufacturing industries from developed to emerging
  and/or developing countries was a one-off movement of jobs."""@en ;
  curric:correction """TNCs continue to seek locations with the lowest wages, meaning the loss of
  manufacturing jobs from emerging countries is possible; so some of the benefits of FDI may
  only be short-term."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084883Z"^^xsd:dateTime .

oakcurric:misconception-uk-cautious-fdi-tncs
  a curric:Misconception ;
  curric:statement "The UK should be cautious of FDI and TNCs."@en ;
  curric:correction """FDI and TNCs are crucial aspects of international business. Without FDI many
  businesses would not be able to operate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084889Z"^^xsd:dateTime .

oakcurric:misconception-coastal-management-positively-impacts-coastlines
  a curric:Misconception ;
  curric:statement "Coastal management always positively impacts coastlines."@en ;
  curric:correction """Coastal management can sometimes harm coastlines by causing erosion in nearby
  areas. For example, building groynes may protect one section but increase erosion further
  down the coast."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085035Z"^^xsd:dateTime .

oakcurric:misconception-regeneration-brings-positive-impacts
  a curric:Misconception ;
  curric:statement "Regeneration only brings positive impacts."@en ;
  curric:correction """Whilst regeneration in Liverpool has been very positive for the CBD and inner
  city overall, it has brought a number of challenges such as negative impacts of
  studentification, gentrification and e-commerce developments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085273Z"^^xsd:dateTime .

oakcurric:misconception-immigrants-asylum-seekers-refugees-same
  a curric:Misconception ;
  curric:statement "Immigrants, asylum seekers and refugees are all the same thing."@en ;
  curric:correction """The three terms are often confused and misused. All asylum seekers are
  immigrants but not all immigrants are asylum seekers. Some people seeking asylum may be
  granted refugee status while others may not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085700Z"^^xsd:dateTime .

oakcurric:misconception-global-megacity-nee-jakarta-developed
  a curric:Misconception ;
  curric:statement """As a global megacity in an NEE, Jakarta is too developed to have serious
  problems with providing clean water and sanitation."""@en ;
  curric:correction """Despite being a global megacity, large parts of Jakarta (especially kampungs)
  lack piped water and sewage systems. Many people rely on groundwater, and open drains are
  still common in some areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085937Z"^^xsd:dateTime .

oakcurric:misconception-jakarta-important-nationally-because-capital
  a curric:Misconception ;
  curric:statement "Jakarta is only important nationally because it is the capital city."@en ;
  curric:correction """Jakarta is not just important because it’s the capital. It also plays a major
  role nationally as Indonesia’s economic centre and globally through its trade, transport
  links and role as the ASEAN headquarters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085951Z"^^xsd:dateTime .

oakcurric:misconception-urban-planning-nees-lics-designed
  a curric:Misconception ;
  curric:statement """Urban planning in NEEs and LICs is always designed and led by local
  communities."""@en ;
  curric:correction """Much urban planning is led by governments or large corporations, not by local
  communities. This ‘top-down’ development often aims to improve infrastructure at a
  city-wide or national level."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085957Z"^^xsd:dateTime .

oakcurric:misconception-challenges-faced-plants-animals-canopy
  a curric:Misconception ;
  curric:statement """The challenges faced by plants and animals in the canopy layer are the same as
  challenges on the forest floor."""@en ;
  curric:correction """Plants and animals face different challenges in the different habitats of the
  tropical rainforest. For example, plants on the forest floor have to have adaptations for
  low light levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085963Z"^^xsd:dateTime .

oakcurric:misconception-indirect-effects-human-activities-less
  a curric:Misconception ;
  curric:statement """Indirect effects of human activities are less important than direct
  effects."""@en ;
  curric:correction """Indirect effects of human activities at the coast have very significant
  effects: for example, rising sea levels as a result of global warming are an indirect
  effect with globally important impacts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086032Z"^^xsd:dateTime .

oakcurric:misconception-tropical-rainforest-soils-nutrient-rich
  a curric:Misconception ;
  curric:statement """Tropical rainforest soils must be nutrient-rich because the forests are so
  full of abundant, fast-growing vegetation."""@en ;
  curric:correction """Tropical rainforest soils are nutrient-poor. Nutrients cycle rapidly out of
  the soil due to them being taken up rapidly by biomass, while the heavy rainfall also
  washes them out of the soil through leaching and runoff."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086040Z"^^xsd:dateTime .

oakcurric:misconception-individuals-cannot-make-significant-contributions
  a curric:Misconception ;
  curric:statement "Individuals cannot make significant contributions to mitigation."@en ;
  curric:correction """Although national and international mitigation strategies are essential to
  achieve meaingful mitigation of climate change, individual actions, such as reducing
  energy use, collectively contribute to mitigation efforts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086302Z"^^xsd:dateTime .

oakcurric:misconception-mass-movement-refers-dramatic-events
  a curric:Misconception ;
  curric:statement """Mass movement only refers to dramatic events like landslides and
  rockfalls."""@en ;
  curric:correction """Mass movement includes all downhill movements of soil, rock, or debris due to
  gravity. It's not just rapid events like landslides but also slower processes which occur
  gradually and can still significantly alter the landscape over time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086325Z"^^xsd:dateTime .

oakcurric:misconception-tropical-storms-cannot-accurately-predicted
  a curric:Misconception ;
  curric:statement "Tropical storms cannot be accurately predicted."@en ;
  curric:correction """While it is challenging, advances in technology and meteorology have improved
  the accuracy of tropical storm predictions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086408Z"^^xsd:dateTime .

oakcurric:misconception-atlases-specialise-large-scale-maps
  a curric:Misconception ;
  curric:statement "Atlases specialise in large scale maps."@en ;
  curric:correction """A large scale map means the map shows a large amount of detail but covers a
  small area. Therefore, atlases tend to use small scale maps that show a large area of land
  in limited detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086575Z"^^xsd:dateTime .

oakcurric:misconception-large-global-organisations-like-united
  a curric:Misconception ;
  curric:statement """Only large global organisations, like the United Nations or Greenpeace, are
  responsible for protecting rainforests, and that local communities have little impact on
  sustainability efforts."""@en ;
  curric:correction """Both global and local actions are vital for rainforest sustainability. While
  global efforts fund and advocate, local communities protect forests through reforestation,
  sustainable farming, and ecotourism."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086667Z"^^xsd:dateTime .

oakcurric:misconception-upland-areas-uk-created-glaciers
  a curric:Misconception ;
  curric:statement "Upland areas in the UK were created by glaciers."@en ;
  curric:correction """Glaciers shaped many upland landscapes during the last Ice Age, but the
  original formation of mountains like those in Scotland and the Lake District was caused by
  tectonic activity millions of years ago."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086924Z"^^xsd:dateTime .

oakcurric:misconception-tropical-storms-form-land
  a curric:Misconception ;
  curric:statement "Tropical storms can form over land."@en ;
  curric:correction """Tropical storms form over warm ocean waters where they can draw energy from
  the heat and moisture. Once over land, they lose their energy source and weaken."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086938Z"^^xsd:dateTime .

oakcurric:misconception-raining-tropical-rainforest
  a curric:Misconception ;
  curric:statement "It is always raining in the tropical rainforest."@en ;
  curric:correction """Although it will often rain every day in a tropical rainforest, the rain is
  often short and intense rather than continual. Some rainforests have drier and wetter
  seasons also."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087337Z"^^xsd:dateTime .

oakcurric:misconception-tropical-storms-affect-coastal-areas
  a curric:Misconception ;
  curric:statement "Tropical storms only affect coastal areas."@en ;
  curric:correction """Explain that tropical storms can impact inland areas as well due to heavy
  rainfall and flooding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087344Z"^^xsd:dateTime .

oakcurric:misconception-biotic-living-abiotic-non-living
  a curric:Misconception ;
  curric:statement """Biotic (living) and abiotic (non-living) factors of the taiga operate
  independently."""@en ;
  curric:correction """The taiga’s cold climate affects its plants and animals. Cold temperatures
  influence vegetation. Poor, acidic soil slows decomposition and limits plant diversity.
  Snow and short growing seasons impact animal behaviors and population patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087350Z"^^xsd:dateTime .

oakcurric:misconception-rapid-urban-growth-creates-problems
  a curric:Misconception ;
  curric:statement "Rapid urban growth only creates problems for city residents."@en ;
  curric:correction """While rapid growth does create challenges, it also creates opportunities such
  as improved access to services (healthcare, education) and resources (water supply,
  energy)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087539Z"^^xsd:dateTime .

oakcurric:misconception-protecting-taiga-means-stopping-development
  a curric:Misconception ;
  curric:statement "Protecting the taiga means stopping all development."@en ;
  curric:correction """In fact, many stakeholders argue for sustainable use, for example selective
  logging, ecotourism or selective hunting, which provides money for local communities
  without causing long-term and widepread environmental damage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087625Z"^^xsd:dateTime .

oakcurric:misconception-global-resources-running-because-global
  a curric:Misconception ;
  curric:statement """Global resources are only running out because the global population is
  rising."""@en ;
  curric:correction """Population growth is just one of many factors contributing to increased
  demand for resources."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087724Z"^^xsd:dateTime .

oakcurric:misconception-deforestation-primarily-caused-small-scale
  a curric:Misconception ;
  curric:statement """Deforestation is primarily caused by small-scale farmers cutting down forests
  for subsistence farming."""@en ;
  curric:correction """Deforestation is driven by large-scale commercial activities, such as
  industrial agriculture (like palm oil and soy), logging, and cattle ranching, which are
  often linked to global demand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087867Z"^^xsd:dateTime .

oakcurric:misconception-tropical-storms-affect-people-immediately
  a curric:Misconception ;
  curric:statement """Tropical storms only affect people during and immediately after they make
  landfall."""@en ;
  curric:correction """Due to improved monitioring and prediction, people may evacuate high-risk
  areas before a storm hits, and the effects of the storm can last for months afterwards as
  people repair and recover their homes, environments and livelihoods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088174Z"^^xsd:dateTime .

oakcurric:misconception-forms-primary-secondary-industry-declined
  a curric:Misconception ;
  curric:statement "All forms of primary and secondary industry have declined in all areas."@en ;
  curric:correction """While the general trend has been one of decline, some aspects of primary and
  secondary industries have become more successful such as organic farming."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088180Z"^^xsd:dateTime .

oakcurric:misconception-regions-equally-affected-climate-change
  a curric:Misconception ;
  curric:statement "All regions will be equally affected by climate change."@en ;
  curric:correction """Different regions experience the effects of climate change differently due to
  environmental, economic and social factors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088317Z"^^xsd:dateTime .

oakcurric:misconception-got-your-electricity-100-renewable
  a curric:Misconception ;
  curric:statement """If you got your electricity from 100% renewable energy sources, then your
  carbon footprint would be zero."""@en ;
  curric:correction """Even if all your electricity comes from renewables, other parts of your
  lifestyle (like the manufacture of the clothes you wear, the food you eat, the technology
  you use) still produce carbon emissions elsewhere — often in other countries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088379Z"^^xsd:dateTime .

oakcurric:misconception-indonesia-large-island-small-population
  a curric:Misconception ;
  curric:statement "Indonesia is a large island with a small population."@en ;
  curric:correction """Indonesia is not one island: it is an archipelago, a group of over 17 000
  islands. Nor does it have a small population: it’s population is over 270 million people."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088824Z"^^xsd:dateTime .

oakcurric:misconception-because-taiga-covered-trees-rich
  a curric:Misconception ;
  curric:statement """Because the taiga is covered with trees it must have rich soils from all the
  leaf litter that accumulates."""@en ;
  curric:correction """Taiga soil is nutrient-poor due to slow decomposition in cold temperatures.
  This means nutrients stay locked inside the trees and litter, rather than entering the
  soil. As a result, the soil is often thin, acidic and nutrient-poor."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088830Z"^^xsd:dateTime .

oakcurric:misconception-rains-hot-deserts
  a curric:Misconception ;
  curric:statement "It never rains in hot deserts."@en ;
  curric:correction """While some deserts are exceptionally dry, a region can experience up to 250
  mm of rain each year and still be categorised as a desert."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088995Z"^^xsd:dateTime .

oakcurric:misconception-extreme-destruction-haiti-result-earthquake
  a curric:Misconception ;
  curric:statement """The extreme destruction in Haiti was the result of the earthquake magnitude
  being unusually powerful."""@en ;
  curric:correction """The earthquake had a magnitude of 7.0, which is not unusually powerful. The
  high death toll and destruction were due to Haiti’s poor infrastructure, weak building
  regulations and lack of preparedness, not just the earthquake’s strength."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089123Z"^^xsd:dateTime .

oakcurric:misconception-wildfires-taiga-harmful-prevented
  a curric:Misconception ;
  curric:statement "All wildfires in the taiga are harmful and should be prevented."@en ;
  curric:correction """Some wildfires are natural and necessary for ecosystem renewal, as they clear
  old vegetation and help new trees grow. However, climate change has made fires more
  intense and frequent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089134Z"^^xsd:dateTime .

oakcurric:misconception-glacial-erosion-process-creates-new
  a curric:Misconception ;
  curric:statement "Glacial erosion is the only process that creates new landscapes."@en ;
  curric:correction """Glacial erosion does create new landforms, but as glaciers transport and then
  deposit the eroded material, this also creates new landscapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089717Z"^^xsd:dateTime .

oakcurric:misconception-reducing-speed-limits-increase-traffic
  a curric:Misconception ;
  curric:statement "Reducing speed limits can increase traffic congestion."@en ;
  curric:correction """Reducing speed limits is more likely to keep traffic flowing through a space
  rather than have prolonged congestion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089723Z"^^xsd:dateTime .

oakcurric:misconception-environmental-impacts-economic-development-negative
  a curric:Misconception ;
  curric:statement "Environmental impacts from economic development are always negative."@en ;
  curric:correction """Environmental impacts from development can be negative, but they can also be
  positive, such as increased environmental awareness and reduced use of agricultural
  chemicals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089771Z"^^xsd:dateTime .

oakcurric:misconception-people-come-eryri-national-park
  a curric:Misconception ;
  curric:statement """People only come to Eryri National Park in order to climb Wales' highest
  mountain."""@en ;
  curric:correction """People do come to climb mountains but also enjoy other enjoy outdoor
  activities and the historical and cultural attractions in North Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090133Z"^^xsd:dateTime .

oakcurric:misconception-earthquake-caused-destruction-2011-tohuku
  a curric:Misconception ;
  curric:statement "The earthquake caused most of the destruction in the 2011 Tohuku disaster."@en ;
  curric:correction """While the magnitude 9.0 earthquake was powerful, Japan’s strict building
  regulations meant that most modern buildings withstood the shaking. It was the
  10-metre-high tsunami that caused the majory of the destruction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090139Z"^^xsd:dateTime .

oakcurric:misconception-using-filters-selecting-incorrect-condition
  a curric:Misconception ;
  curric:statement """When using filters, selecting the incorrect 'condition'; when configuring
  pop-ups, using the incorrect formula of words to link with attribute titles."""@en ;
  curric:correction """Advise caution when selecting the 'condition' for a filter; take care when
  typing text and typing or selecting attribute titles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090147Z"^^xsd:dateTime .

oakcurric:misconception-river-erosion-process-creates-landforms
  a curric:Misconception ;
  curric:statement "River erosion is the only process that creates landforms."@en ;
  curric:correction """River erosion does create distinct landforms such as waterfalls and gorges.
  However, deposition and erosion create meanders and oxbow lakes in the middle course and
  deposition creates landforms such as floodplains and levees in the lower course."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090496Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-sweeping-statements-people
  a curric:Misconception ;
  curric:statement "Pupils can make sweeping statements about people that live in places."@en ;
  curric:correction """It is important that data is used as an average and not the characteristics
  of every individual. The word stereotype is useful to use in this instance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090849Z"^^xsd:dateTime .

oakcurric:misconception-litter-nutrient-cycle-considered-biotic
  a curric:Misconception ;
  curric:statement "Litter in the nutrient cycle is considered biotic."@en ;
  curric:correction """Litter in the nutrient cycle is considered abiotic because it consists of
  non-living organic material, such as dead leaves and decomposing matter. Although it
  originated from living organisms, once it becomes litter, it is classified as non-living."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091065Z"^^xsd:dateTime .

oakcurric:misconception-global-atmospheric-circulation-systems-controls
  a curric:Misconception ;
  curric:statement """The global atmospheric circulation systems controls the temperature of
  different climate zones."""@en ;
  curric:correction """Global circulation system redistributes heat received at the Equator, but
  latitude controls temperature of each climate zone. The amount of solar radiation received
  at each latitude is due to the curvature of the Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091259Z"^^xsd:dateTime .

oakcurric:misconception-people-live-65-years-beyond
  a curric:Misconception ;
  curric:statement """That there are few people who live to 65 years and beyond in LICs and
  NEEs."""@en ;
  curric:correction """It is the proportion of the population that is small not the actual number of
  people. Some LICs and NEEs have large populations so there are millions of people who
  reach the age of 65 years plus."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092107Z"^^xsd:dateTime .

oakcurric:misconception-tectonic-plates-float-like-rafts
  a curric:Misconception ;
  curric:statement "Tectonic plates float like rafts on liquid magma."@en ;
  curric:correction "The mantle is semi-solid rather than a sort of liquid sea of magma."@en ;
  dcterms:modified "2026-06-07T15:30:15.092129Z"^^xsd:dateTime .

oakcurric:misconception-countries-prepare-respond-tropical-cyclones
  a curric:Misconception ;
  curric:statement "All countries prepare and respond  to tropical cyclones in the same way."@en ;
  curric:correction """The level of development, amount of governmental planning as well as a
  country's location and experience of tropical cyclones, will affect how they prepare for
  and respond to them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092135Z"^^xsd:dateTime .

oakcurric:misconception-swash-wave-moves-beach-sea
  a curric:Misconception ;
  curric:statement """Swash is when a wave moves down the beach to the sea and backwash is when a
  wave moves up the beach from the sea."""@en ;
  curric:correction """The swash is the movement of the wave from the sea to the beach which brings
  sediment with it. Whereas the backwash is the movement of the wave from the beach to sea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092188Z"^^xsd:dateTime .

oakcurric:misconception-managed-retreat-land-allowed-erode
  a curric:Misconception ;
  curric:statement """Managed retreat is when the land is allowed to erode without any
  direction."""@en ;
  curric:correction """Managed retreat allows for certain areas to erode or flood in a controlled
  manner. This approach is often chosen for low value land, where it can create natural
  habitats and reduce long term maintenance costs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092255Z"^^xsd:dateTime .

oakcurric:misconception-coastal-communities-equally-vulnerable-coastal
  a curric:Misconception ;
  curric:statement "All coastal communities are equally vulnerable to coastal flooding."@en ;
  curric:correction """Low-lying coastal communities are most at risk of coastal flooding,
  especially with increasing storms and storm surges."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092261Z"^^xsd:dateTime .

oakcurric:misconception-coastal-management-strategies-like-sea
  a curric:Misconception ;
  curric:statement """Coastal management strategies like sea walls and groynes completely solve the
  threat of coastal erosion."""@en ;
  curric:correction """Coastal management reduces the risk of coastal erosion but does not
  completely protect an area from erosion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092427Z"^^xsd:dateTime .

oakcurric:misconception-physical-environment-key-cause-global
  a curric:Misconception ;
  curric:statement "That the physical environment is the key cause of global inequalities."@en ;
  curric:correction """Physical geography is a cause of inequality but human factors, past and
  present, are as influential in affecting the pattern of trade and development."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092598Z"^^xsd:dateTime .

oakcurric:misconception-immediate-responses-happen-tropical-storm
  a curric:Misconception ;
  curric:statement "Immediate responses only happen during the tropical storm."@en ;
  curric:correction """Immediate responses happen before, during and immediately after the
  storm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092832Z"^^xsd:dateTime .

oakcurric:misconception-people-living-poverty-today-once
  a curric:Misconception ;
  curric:statement "There are more people living in poverty today than there once were."@en ;
  curric:correction """The share of the global population living in extreme poverty has dramatically
  fallen in the past decades."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092894Z"^^xsd:dateTime .

oakcurric:misconception-uk-moderate-climate-doesnt-experience
  a curric:Misconception ;
  curric:statement "The UK has a moderate climate and doesn't experience weather hazards."@en ;
  curric:correction """The UK experiences a range of different weather hazards which can have
  serious impacts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093336Z"^^xsd:dateTime .

oakcurric:misconception-camels-hump-stores-water
  a curric:Misconception ;
  curric:statement "A camel's hump stores water."@en ;
  curric:correction """A camel's hump does not hold water at all – it actually stores fat. The camel
  uses it as nourishment when food is scarce. If a camel uses the fat inside the hump, the
  hump will become limp and droop, but with food and rest the hump will normalise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093376Z"^^xsd:dateTime .

oakcurric:misconception-changes-affect-ecosystems-created-people
  a curric:Misconception ;
  curric:statement "Changes that affect ecosystems are always created by people."@en ;
  curric:correction """Naturally-occurring events such as storms also affect ecosystems. For
  example, a storm could fell trees which may have been a habitat for other species."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095563Z"^^xsd:dateTime .

oakcurric:misconception-biosphere-affected-atmosphere-little-impact
  a curric:Misconception ;
  curric:statement "The biosphere is affected by the atmosphere but has little impact on it."@en ;
  curric:correction """The biosphere has significant impacts on the composition of the atmosphere,
  affecting the concentration of gases and moisture content."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095614Z"^^xsd:dateTime .

oakcurric:misconception-attractive-basemap-important
  a curric:Misconception ;
  curric:statement "An attractive basemap is important."@en ;
  curric:correction """A basemap is a backdrop to support the visualisation of data, so it doesn't
  necessarily need to be attractive. Sometimes a very bland basemap is the most effective
  because it provides contrast with the layer of spatial data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096061Z"^^xsd:dateTime .

oakcurric:misconception-hot-deserts-barren-lifeless-areas
  a curric:Misconception ;
  curric:statement "Hot deserts are barren, lifeless areas with no real economic potential."@en ;
  curric:correction """Deserts can have significant opportunities for economic development, for
  example mineral extraction, solar energy, tourism and irrigated farming."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097519Z"^^xsd:dateTime .

oakcurric:misconception-rivers-change-due-natural-processes
  a curric:Misconception ;
  curric:statement "Rivers only change due to natural processes."@en ;
  curric:correction """While natural processes like erosion and sedimentation affect rivers, human
  activities such as deforestation and dam construction also significantly alter river
  landscapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098830Z"^^xsd:dateTime .

oakcurric:misconception-adaptation-strategies-expensive-complex
  a curric:Misconception ;
  curric:statement "All adaptation strategies are expensive and complex."@en ;
  curric:correction """Some adaptation strategies are cost-effective and simple, such as rainwater
  harvesting and crop rotation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098984Z"^^xsd:dateTime .

oakcurric:misconception-primary-effects-cause-damage
  a curric:Misconception ;
  curric:statement "Primary effects always cause the most damage."@en ;
  curric:correction """Sometimes it is the secondary effects of a hazard that cause the most
  destruction, for example mudslides following a volcanic eruption."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099003Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-site-situation
  a curric:Misconception ;
  curric:statement "Pupils can confuse site and situation."@en ;
  curric:correction """The site of a settlement is its exact point on the surface of Earth and the
  situation describes it in relation to other human and physical features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099009Z"^^xsd:dateTime .

oakcurric:misconception-taiga-winter-cold-animals-survive
  a curric:Misconception ;
  curric:statement """The taiga winter is too cold for animals to survive, so they all migrate to
  warmer regions."""@en ;
  curric:correction """Although some animal and bird species do migrate in winter, other animals are
  adapted to survive the cold, dark taiga winter. For example, some animals have thick fur,
  some hibernate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101206Z"^^xsd:dateTime .

oakcurric:misconception-city-newly-emerging-economy-economic
  a curric:Misconception ;
  curric:statement """As it is a city in a Newly Emerging Economy, most economic opportunities in
  Jakarta are in the informal sector."""@en ;
  curric:correction """A large majority of jobs in Jakarta are actually in the formal sector rather
  than in the informal sector, and the share of informal sector jobs is decreasing over
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101402Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-focus-lesson-migration
  a curric:Misconception ;
  curric:statement """Pupils can think that as the focus of the lesson is about migration, that
  inflows and outflows are responsible for all population change."""@en ;
  curric:correction """Migration is important to understand when addressing population change but
  changes to birth and death rates must also be considered alongside for complete
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101503Z"^^xsd:dateTime .

oakcurric:misconception-weather-hazards-dont-badly-affect
  a curric:Misconception ;
  curric:statement "Weather hazards don't badly affect the UK population ."@en ;
  curric:correction """The UK experiences weather hazards that have serious social, economic and
  environmental impacts, the Beast from the East killed 10 people and cost the UK £1 billion
  per day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101514Z"^^xsd:dateTime .

oakcurric:misconception-hard-engineering-better-soft-engineering
  a curric:Misconception ;
  curric:statement "Hard engineering is always better than soft engineering."@en ;
  curric:correction """While hard engineering can be effective, it is not always the best choice due
  to cost and environmental impact. Soft engineering can be more sustainable and less
  intrusive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102193Z"^^xsd:dateTime .

oakcurric:misconception-white-space-map-means-nothing
  a curric:Misconception ;
  curric:statement "White space on a map means there is nothing there."@en ;
  curric:correction "White space means that the land cover there is grassland or farmland."@en ;
  dcterms:modified "2026-06-07T15:30:15.102510Z"^^xsd:dateTime .

oakcurric:misconception-ice-affects-landscapes-periods-melting
  a curric:Misconception ;
  curric:statement "Ice only affects landscapes during periods of melting."@en ;
  curric:correction """Ice modifies landscapes through continuous processes of erosion,
  transportation, and deposition, not just during periods of melting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103994Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-caused-human-activity
  a curric:Misconception ;
  curric:statement "Climate change is only caused by human activity."@en ;
  curric:correction """Human activity has been significant in recent climate change, but natural
  factors have caused changes to the climate over millions of years."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105049Z"^^xsd:dateTime .

oakcurric:misconception-anomaly-data-set-means-error
  a curric:Misconception ;
  curric:statement """An anomaly in a data set means that an error was made in the way the data was
  collected."""@en ;
  curric:correction """Anomalies could be found in data sets for many reasons, including human error
  during data collection. It is more likely however that a variable that was not
  investigated is having an influence on that particular value, causing it to seem 'wrong'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105057Z"^^xsd:dateTime .

oakcurric:misconception-green-initiatives-cost-cities-lot
  a curric:Misconception ;
  curric:statement """Green initiatives cost cities a lot of money that could be spent in other
  ways."""@en ;
  curric:correction """Planned well, green initiatives also attract investment and people to cities.
  They are a sustainable approach to environmental development and also have economic and
  social benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105103Z"^^xsd:dateTime .

oakcurric:misconception-storm-hydrograph-shows-rainfall
  a curric:Misconception ;
  curric:statement "A storm hydrograph shows rainfall."@en ;
  curric:correction """A storm hydrograph shows river discharge changes over time, not just
  rainfall."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105593Z"^^xsd:dateTime .

oakcurric:misconception-due-extreme-cold-climate-particularly
  a curric:Misconception ;
  curric:statement """That due to the extreme cold climate, particularly during the winter months,
  that all animals must hibernate to save energy."""@en ;
  curric:correction """Only two polar or tundra species enter full hibernation - the grizzly bear
  and arctic ground squirrel. Many other animals migrate to find food and warmth, while
  others are highly adapted to remain active and survive the extremely cold winters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105638Z"^^xsd:dateTime .

oakcurric:misconception-ecosystems-made-plants-animals
  a curric:Misconception ;
  curric:statement "That ecosystems are made up of plants and animals only."@en ;
  curric:correction """An ecosystem is a community of living things interacting with one another and
  with non-living components of their environment, such as soil and climate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105767Z"^^xsd:dateTime .

oakcurric:misconception-cold-environments-receive-lot-precipitation
  a curric:Misconception ;
  curric:statement "Cold environments receive a lot of precipitation (in this case snowfall)."@en ;
  curric:correction """While some areas of coastal tundra does receive a substantial quantity of
  precipitation, in reality most cold environment regions are extremely dry, with some areas
  receiving less than 250 mm of precipitation per year - defining them as deserts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106164Z"^^xsd:dateTime .

oakcurric:misconception-confusion-similar-sounding-gis-tools
  a curric:Misconception ;
  curric:statement """Confusion between similar sounding GIS tools in Esri Wayback; Use of 'Measure
  tools' in NLS Maps."""@en ;
  curric:correction """CfU to clarify learning and procedures e.g. similar sounding GIS tools in
  Esri Wayback: ‘Toggle Animate Mode’ ‘Toggle Swipe Mode’; careful use of 'Measure distance'
  tool in NLS Maps along with 'Swipe', ensuring line is perpendicular."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106653Z"^^xsd:dateTime .

oakcurric:misconception-describing-location-maps-pupils-make
  a curric:Misconception ;
  curric:statement """When describing location from maps pupils can make the mistake of including
  facts not available on the map itself."""@en ;
  curric:correction """Use only the available information to construct a locational description from
  a map including the legend, labels, compass rose and scale."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107017Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-impacted-tropical-rainforests
  a curric:Misconception ;
  curric:statement """Climate change has not impacted tropical rainforests as temperature and
  rainfall patterns have remained the same."""@en ;
  curric:correction """Climate change has affected tropical rainforests by increasing temperatures,
  changing rainfall patterns and increasing the frequency of droughts. For example, the
  Amazon rainforest experienced its worst recorded drought in 2023."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107028Z"^^xsd:dateTime .

oakcurric:misconception-six-figure-grid-reference-refers
  a curric:Misconception ;
  curric:statement "A six figure grid reference refers to only one point in the UK."@en ;
  curric:correction """A six figure grid reference will be specific to a larger grid square in the
  OS National Grid. Each of these 100km2 squares are denoted by a two letter code, often
  seen in faint blue on the map. This means it refers to more than one point in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107042Z"^^xsd:dateTime .

oakcurric:misconception-main-threats-taiga-come-direct
  a curric:Misconception ;
  curric:statement """The main threats to the taiga come from the direct damage done to forests by
  the logging industry."""@en ;
  curric:correction """While the logging industry does directly damage taiga forests, indirect
  threats from warming taiga climates are also a major threat to the taiga and taiga
  biodiversity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107146Z"^^xsd:dateTime .

oakcurric:misconception-rainforests-valuable-timber-agricultural-products
  a curric:Misconception ;
  curric:statement "Rainforests are only valuable for timber and agricultural products."@en ;
  curric:correction """Tropical rainforests are crucial for regulating the global climate, absorbing
  CO2, producing oxygen, maintaining biodiversity, supporting the water cycle, and
  preventing soil erosion, all of which are vital for sustaining life on Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107152Z"^^xsd:dateTime .

oakcurric:misconception-asean-focused-trade-deal-other
  a curric:Misconception ;
  curric:statement """ASEAN is only focused on trade and does not deal with other important issues
  like politics or security."""@en ;
  curric:correction """ASEAN focuses not only on trade but also on political stability, security,
  and regional cooperation to maintain peace in Southeast Asia."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107538Z"^^xsd:dateTime .

oakcurric:misconception-desertification-occurs-existing-deserts
  a curric:Misconception ;
  curric:statement "Desertification only occurs in existing deserts."@en ;
  curric:correction """Desertification can occur in any fertile land that becomes increasingly arid,
  not just in deserts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107549Z"^^xsd:dateTime .

oakcurric:misconception-rocks-change-once-formed
  a curric:Misconception ;
  curric:statement "Rocks do not change once they are formed."@en ;
  curric:correction """Metamorphic rocks are created by heat and pressure acting on sedimentary and
  igneous rocks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108003Z"^^xsd:dateTime .

oakcurric:misconception-gis-long-hand-paper-based
  a curric:Misconception ;
  curric:statement "GIS and long-hand, paper-based mapping have the same value."@en ;
  curric:correction """While it is very possible to create representations of spatial data on paper
  using layers of tracing paper over a base map, the real value of GIS is its ability to
  analyse data quickly and be edited once the map has been digitally created."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108030Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-models-represent-reality
  a curric:Misconception ;
  curric:statement "Pupils can think models represent reality."@en ;
  curric:correction """A model is not an exact representation of reality but a simplification
  designed to help understanding. In this instance to help understand the situation of
  different areas of cities in relation to one another."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108931Z"^^xsd:dateTime .

oakcurric:misconception-form-data-presentation-applied-data
  a curric:Misconception ;
  curric:statement "Any form of data presentation can be applied to any data set."@en ;
  curric:correction """There are many different types of data. Accurate data presentation means that
  appropriate graphical data presentation techniques are matched with the particular
  characteristics of a data set."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108953Z"^^xsd:dateTime .

oakcurric:misconception-boulder-clay-example-sedimentary-rock
  a curric:Misconception ;
  curric:statement "Boulder clay is an example of sedimentary rock."@en ;
  curric:correction """Boulder clay is an example of glacial till. Glacial till is an example of
  sedimentary deposits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109796Z"^^xsd:dateTime .

oakcurric:misconception-spit-formation-occurs-solely-sediment
  a curric:Misconception ;
  curric:statement "Spit formation occurs solely from sediment deposition."@en ;
  curric:correction """Longshore drift, wave and wind direction play an important role in the
  formation of spits, and a change in direction of the coastline is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110025Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-include-place-specific
  a curric:Misconception ;
  curric:statement """Pupils can fail to include place-specific details when responding to questions
  or giving information about places."""@en ;
  curric:correction """Information about a place should always be supported by specific evidence
  such as a piece of data or a specific location."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110113Z"^^xsd:dateTime .

oakcurric:misconception-land-use-conflicts-glacial-areas
  a curric:Misconception ;
  curric:statement """Land use conflicts in glacial areas only concern conservationists and
  developers."""@en ;
  curric:correction """Land use conflicts are much more complex. While conservation groups and
  developers often have opposing views, there are other stakeholders involved, such as local
  communities, local governments, farmers, and tourism operators."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110781Z"^^xsd:dateTime .

oakcurric:misconception-economic-development-indonesia-benefits-everyone
  a curric:Misconception ;
  curric:statement "Economic development in Indonesia benefits everyone equally."@en ;
  curric:correction """Economic development in Indonesia is mostly focused in urban areas like
  Jakarta and Java. Rural areas often miss out on investment, leading to unequal access to
  jobs, services, and infrastructure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111018Z"^^xsd:dateTime .

oakcurric:misconception-indonesia-agriculture-remains-dominant-sector
  a curric:Misconception ;
  curric:statement "In Indonesia, agriculture remains the dominant sector in the economy."@en ;
  curric:correction """Agriculture was once Indonesia’s economic backbone, but its role has declined
  since the 1990s. Today, industry and services dominate GDP, with manufacturing, finance,
  tourism, and digital sectors growing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111127Z"^^xsd:dateTime .

oakcurric:misconception-rank-index-multiple-deprivation-tells
  a curric:Misconception ;
  curric:statement """The rank on the Index of Multiple Deprivation tells you everything about the
  deprivation of an area."""@en ;
  curric:correction """The Index of Multiple Deprivation is calculated by combining seven
  indicators. The overall rank is therefore an average and can mask significant variation in
  different aspects of deprivation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111247Z"^^xsd:dateTime .

oakcurric:misconception-sustainable-development-environment
  a curric:Misconception ;
  curric:statement "Sustainable development is all about the environment."@en ;
  curric:correction """One pillar of sustainable development is the environment but sustainable
  development is only achieved when social and economic aspects are also considered."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111348Z"^^xsd:dateTime .

oakcurric:misconception-glaciated-upland-areas-harsh-economic
  a curric:Misconception ;
  curric:statement "Glaciated upland areas are too harsh for any economic activity."@en ;
  curric:correction """Even though conditions are harsh, economic activities such as tourism and
  sheep farming are prevalent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111486Z"^^xsd:dateTime .

oakcurric:misconception-enquiries-focus-coastal-management-discuss
  a curric:Misconception ;
  curric:statement "Enquiries that focus on coastal management have to discuss effectiveness."@en ;
  curric:correction """While many coastal enquiries focus on how effective management strategies
  are, the concept of effectiveness is far broader. Enquiries could study how coastal
  defences look, if they prevent access to the beach, or how sustainable it is to build
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111514Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fall-habit-writing-superficial
  a curric:Misconception ;
  curric:statement """Pupils can fall into the habit of writing superficial explanations or fail to
  extend them fully."""@en ;
  curric:correction """An extended explanation would be: Regeneration and rebranding in Liverpool
  led to economic growth as a result of more businesses and tourism. This led to more
  diverse jobs and has contributed to a stronger and more resilient local economy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111520Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-greenfield-greenbelt
  a curric:Misconception ;
  curric:statement "Pupils can confuse greenfield and greenbelt."@en ;
  curric:correction """Greenfield refers to land which has never been built on. Greenbelt is
  protected land around major cities in England and is a policy designed to prevent urban
  sprawl."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111961Z"^^xsd:dateTime .

oakcurric:misconception-urban-areas-facilities-services-rural
  a curric:Misconception ;
  curric:statement """Urban areas have more facilities and services than rural areas. As a result,
  rural areas can offer cities little in return."""@en ;
  curric:correction """Rural areas can offer the residents of urban areas a source of labour and
  produce. They can provide jobs in industries such as agriculture and opportunities for
  recreation and leisure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112860Z"^^xsd:dateTime .

oakcurric:misconception-better-use-mean-value-rather
  a curric:Misconception ;
  curric:statement """It is better to use the mean value rather than the mode or the median
  values."""@en ;
  curric:correction """The mean, median and mode have different purposes but none of the methods
  produce a result that is thought of as more reliable than the others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112906Z"^^xsd:dateTime .

oakcurric:misconception-counter-urbanisation-responsible-population-change
  a curric:Misconception ;
  curric:statement """Counter-urbanisation is responsible for all population change in a
  rural area."""@en ;
  curric:correction """Population change is a balance of inflows and outflows. Migration is one of
  these and counter-urbanisation is a process of migration but will not be responsible for
  all population change in an area."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112945Z"^^xsd:dateTime .

oakcurric:misconception-areas-within-same-biome-physically
  a curric:Misconception ;
  curric:statement "Areas within the same biome are physically connected."@en ;
  curric:correction """A biome may occur on different continents at the same or similar latitude,
  such as the tropical rainforest biome."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113568Z"^^xsd:dateTime .

oakcurric:misconception-renewables-make-country-less-energy
  a curric:Misconception ;
  curric:statement "Renewables make a country less energy secure because they’re unreliable."@en ;
  curric:correction """Although supplies of energy from solar and wind can be variable, renewables
  diversify a country's energy supply and reduce reliance on imported fossil fuels.
  Overeliance on imported fossil fuels is a bigger cause of energy insecurity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114525Z"^^xsd:dateTime .

oakcurric:misconception-highlighting-flaws-geographical-enquiry-shows
  a curric:Misconception ;
  curric:statement """Highlighting the flaws in a geographical enquiry shows that I am a poor
  geographer."""@en ;
  curric:correction """Good geographers take time to be deeply reflective of their work and will
  present their findings honestly and transparently, even if they show errors that affect
  the final outcome. Good geographers also show how a study can be improved and extended."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114862Z"^^xsd:dateTime .

oakcurric:misconception-first-cities-become-megacities-now
  a curric:Misconception ;
  curric:statement "The first cities to become megacities are now the largest global cities."@en ;
  curric:correction """Most of the world's largest cities are relatively young megacities that have
  only grown to a significant size since 2000."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114868Z"^^xsd:dateTime .

oakcurric:misconception-systematic-stratified-sampling-better-random
  a curric:Misconception ;
  curric:statement """Systematic and stratified sampling are 'better' than a random sampling
  strategy."""@en ;
  curric:correction """There is no hierarchy of effectiveness in sampling strategies. The best
  strategy to use depends on the dynamics of the location, the size of the overall
  population of data, and what geographical conclusions one hopes to be able to make from
  the data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115360Z"^^xsd:dateTime .

oakcurric:misconception-volcanoes-occur-plate-margins
  a curric:Misconception ;
  curric:statement "Volcanoes occur at all plate margins."@en ;
  curric:correction """While volcanoes are a feature of both destructive and constructive plate
  margins, there are no volcanic eruptions at conservative margins because no magma is
  produced."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115368Z"^^xsd:dateTime .

oakcurric:misconception-carbon-footprints-ecological-footprints-measure
  a curric:Misconception ;
  curric:statement "Carbon footprints and ecological footprints measure the same thing."@en ;
  curric:correction """Although carbon footprints and ecological footprints both provide comparable
  measures of human impacts on the environment, carbon footprints measure greenhouse gas
  emissions while ecological footprints measure the total demand on Earth’s resources."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115644Z"^^xsd:dateTime .

oakcurric:misconception-enough-issues-rural-areas-make
  a curric:Misconception ;
  curric:statement """There are not enough issues in rural areas to make it worth studying fieldwork
  enquiries there."""@en ;
  curric:correction """Rural areas have a lot of issues around inequality and access to services as
  well as interesting cultural geography to study."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115736Z"^^xsd:dateTime .

oakcurric:misconception-aid-separate-globalisation-nothing-indonesia
  a curric:Misconception ;
  curric:statement """Aid is separate from globalisation and has nothing to do with how Indonesia
  connects to the world."""@en ;
  curric:correction """When countries like Australia or organisations like the EU give aid to
  Indonesia, they are building connections through education and infrastructure. This
  support helps Indonesia grow economically, attract investment, and take part in global
  trade."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115872Z"^^xsd:dateTime .

oakcurric:misconception-inner-core-hotter-outer-core
  a curric:Misconception ;
  curric:statement """The inner core is hotter than the outer core so the inner core must be liquid
  (molten rock) while the outer core is solid rock."""@en ;
  curric:correction """In fact, although the inner core is hotter than the outer core, the inner
  core is solid while the outer core is molten and liquid. This is because the pressure is
  so great in the inner core that it prevents the rock from melting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115903Z"^^xsd:dateTime .

oakcurric:misconception-energy-efficiency-energy-conservation-mean
  a curric:Misconception ;
  curric:statement "Energy efficiency and energy conservation mean the same thing."@en ;
  curric:correction """In fact, energy efficiency is about using technology to do the same task but
  with less use of energy, while energy conservation is about changing people's behaviour so
  they use less energy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116202Z"^^xsd:dateTime .

oakcurric:misconception-water-insecurity-due-lack-rain
  a curric:Misconception ;
  curric:statement "Water insecurity is due to lack of rain."@en ;
  curric:correction """Water insecurity may be the result of physical water scarcity, though a water
  deficit may be due to high population density or use of large volumes of water for
  industry."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116208Z"^^xsd:dateTime .

oakcurric:misconception-biomass-renewable-source-energy-because
  a curric:Misconception ;
  curric:statement """Biomass is not a renewable source of energy because carbon dioxide is released
  when it is burned."""@en ;
  curric:correction """Renewable energy comes from sources that don’t run out or are quickly
  renewed. Because plants are quickly replaced, biomass is a renewable energy source. Also,
  biomass is carbon neutral as CO2 released is the same CO2 absorbed during plant growth."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116461Z"^^xsd:dateTime .

oakcurric:misconception-benefits-international-migration-limited-country
  a curric:Misconception ;
  curric:statement """That the benefits of international migration are limited to the country of
  origin (such as remittances)."""@en ;
  curric:correction """Destination countries experience a wide range of social and economic benefits
  as a result of immigration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116599Z"^^xsd:dateTime .

oakcurric:misconception-river-processes-independent-variables-shape
  a curric:Misconception ;
  curric:statement "River processes are independent variables that shape river features."@en ;
  curric:correction """Rivers are complex systems where processes and features both affect each
  other at different times. This means that students need to disengage with the idea that
  one variable is going to be independent of another as they present and analyse data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116850Z"^^xsd:dateTime .

oakcurric:misconception-wealthy-hics-give-aid-other
  a curric:Misconception ;
  curric:statement "Only wealthy HICs give aid to other countries."@en ;
  curric:correction """Newly-emerging economies such as Indonesia, China and India also give aid to
  other countries, especially within their regions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116858Z"^^xsd:dateTime .

oakcurric:misconception-fracking-uses-water-means-its
  a curric:Misconception ;
  curric:statement """Fracking only uses water which means its environmental impacts are
  harmless."""@en ;
  curric:correction """In fact fracking fluid includes toxic chemicals and sand as well as water,
  which can have serious environmental impacts if they get into groundwater or are spilled.
  The wastewater left over from fracking also needs to be stored carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117098Z"^^xsd:dateTime .

oakcurric:misconception-single-image-help-us-understand
  a curric:Misconception ;
  curric:statement """That a single image can help us to understand how quality of life is different
  in distant places."""@en ;
  curric:correction """While images can be of use they can not depict all aspects of life, moreover
  each image can only ever show a single place or group of people. Within any country there
  is a diversity of lived experience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117113Z"^^xsd:dateTime .

oakcurric:misconception-find-oil-gas-underground-worth
  a curric:Misconception ;
  curric:statement "If you find oil or gas underground, it is always worth extracting it."@en ;
  curric:correction """In fact, just because a reserve exists doesn't mean that it will be
  technically or economically viable. Reserves that are in remote locations or in
  challenging conditions may have high development costs, especially if oil prices fall."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117762Z"^^xsd:dateTime .

oakcurric:misconception-green-revolution-came-result-genetically
  a curric:Misconception ;
  curric:statement "The green revolution came about as a result of genetically-modified crops."@en ;
  curric:correction """The original green revolution, in the second half of the twentieth century,
  came about as a result of hybridisation of existing crop varieties (and the use of
  pesticides). It did not employ biotechnology such as genetic modification."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117891Z"^^xsd:dateTime .

oakcurric:misconception-our-wastewater-treated-sent-straight
  a curric:Misconception ;
  curric:statement "Our wastewater is treated and sent straight to our taps, to drink."@en ;
  curric:correction """Few water systems link wastewater treatment plants to the supply system, with
  treated water going into covered reservoirs before the clean water network. Most release
  treated wastewater into rivers; from where it is abstracted downstream, later on."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117922Z"^^xsd:dateTime .

oakcurric:misconception-dams-reservoirs-guarantee-reliable-water
  a curric:Misconception ;
  curric:statement """Dams and reservoirs guarantee a reliable water supply for many years into the
  future."""@en ;
  curric:correction """Although dams and reservoirs do provide a reliable and easily-controllable
  source of water, this supply is not guaranteed. Over time, sediment will build up and
  reduce the capacity of the reservoir. Also, reservoirs can dry up during droughts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117970Z"^^xsd:dateTime .

oakcurric:misconception-correct-solution-geographical-issue
  a curric:Misconception ;
  curric:statement "There is always a correct solution to a geographical issue."@en ;
  curric:correction """There is not a 'correct' answer to a geographical issue. Geographers try and
  balance economic, social and environmental concerns and use evidence to justify their
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118084Z"^^xsd:dateTime .

oakcurric:misconception-extraction-use-non-renewable-energy
  a curric:Misconception ;
  curric:statement """Only the extraction and use of non-renewable energy has environmental
  consequences."""@en ;
  curric:correction """Renewables and recyclables can have environmental consequences too, although
  they generally cause less harm than fossil fuels. These consequences can include impacts
  on biodiversity and the ability of ecosystems to absorb carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118312Z"^^xsd:dateTime .

oakcurric:misconception-aid-something-given-event-emergency
  a curric:Misconception ;
  curric:statement "Aid is something given in the event of an emergency."@en ;
  curric:correction """It is not always provided in the event of an emergency. Aid may be given to
  support the sustainable development of a community, e.g improving health or educational
  services in an area, to benefit local people in the longer term."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118323Z"^^xsd:dateTime .

oakcurric:misconception-organic-farmers-use-fertiliser-their
  a curric:Misconception ;
  curric:statement "Organic farmers do not use fertiliser on their crops."@en ;
  curric:correction """Organic farming does involve the use of fertiliser but not the use of
  artificial chemical fertiliser (e.g. derived from fossil fuels). For example, farmyard
  manure is a good source of nutrients for crops on an organic farm but so too is seaweed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118463Z"^^xsd:dateTime .

oakcurric:misconception-rising-demand-food-simply-worlds
  a curric:Misconception ;
  curric:statement "Rising demand for food is simply down to the world's growing population."@en ;
  curric:correction """This is one reason for growing demand for food but economic development is
  another factor that affects demand as people become richer they eat more meat and so more
  grain or land to graze is needed to feed those animals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118548Z"^^xsd:dateTime .

oakcurric:misconception-tncs-helped-indonesia-develop-its
  a curric:Misconception ;
  curric:statement """TNCs have helped Indonesia to develop its own vehicle manufacturing
  companies."""@en ;
  curric:correction """While TNCs have been important in developing vehicle manufacturing in
  Indonesia, the vehicles they make are not Indonesian brands and the profits from selling
  them in Indonesia or in export markets go to the TNCs and not to Indonesian companies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118554Z"^^xsd:dateTime .

oakcurric:misconception-hot-countries-use-less-energy
  a curric:Misconception ;
  curric:statement """Hot countries use less energy because it is warm all year so they do not need
  to heat their houses."""@en ;
  curric:correction """While people in hot countries may need to use less energy on heating, energy
  use depends most on how developed a country is - developed countries use more energy per
  person because they have more industries, transport and technology."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118799Z"^^xsd:dateTime .

oakcurric:misconception-development-indonesia-positive-effects-like
  a curric:Misconception ;
  curric:statement """Development in Indonesia only has positive effects, like job creation and
  economic growth."""@en ;
  curric:correction """While development brings economic benefits, it also causes environmental
  problems like deforestation, water pollution, and loss of biodiversity, which can harm
  people and ecosystems in the long term."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118813Z"^^xsd:dateTime .

oakcurric:misconception-migrants-similar-reasons-migrating
  a curric:Misconception ;
  curric:statement "Migrants all have similar reasons for migrating."@en ;
  curric:correction """Migration is a deeply personal decision. Migrants will have many different,
  and sometimes contradictory, reasons for migrating."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118825Z"^^xsd:dateTime .

oakcurric:misconception-geographers-present-data-make-look
  a curric:Misconception ;
  curric:statement "Geographers present data to make it look more attractive."@en ;
  curric:correction """Geographers present data so that it becomes more meaningful. It allows
  geographers to see patterns and relationships in the data that will help them answer their
  enquiry question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119056Z"^^xsd:dateTime .

oakcurric:misconception-volcanoes-occur-directly-oceanic-plate
  a curric:Misconception ;
  curric:statement """That volcanoes occur directly above where the oceanic plate starts to
  subduct."""@en ;
  curric:correction """In fact, the melting of the oceanic plate occurs deep in the mantle, so magma
  rises to the surface some distance away from the plate margin."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119457Z"^^xsd:dateTime .

oakcurric:misconception-fairtrade-small-scale-mostly-based
  a curric:Misconception ;
  curric:statement "Fairtrade is small-scale and mostly based in the UK."@en ;
  curric:correction """The Fairtrade movement involves the trade in 300 different commodities and
  global networks of consumers as well as producers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120290Z"^^xsd:dateTime .

oakcurric:misconception-people-jakarta-easily-access-good
  a curric:Misconception ;
  curric:statement """Most people in Jakarta can easily access good healthcare and education, no
  matter what income level they have."""@en ;
  curric:correction """In poorer parts of Jakarta, schools often lack teachers, books, and
  resources. Although Jakarta has about 1 doctor for every 350 people, hospitals are still
  overcrowded, and poor families struggle to get care."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120307Z"^^xsd:dateTime .

oakcurric:misconception-indonesia-isnt-influential-because-emerging
  a curric:Misconception ;
  curric:statement "Indonesia isn’t very influential because it is an emerging country."@en ;
  curric:correction """Indonesia is the world’s fourth-most populous country and Southeast Asia’s
  largest economy. It is a major player in ASEAN, the G20 and global supply chains."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122612Z"^^xsd:dateTime .

oakcurric:misconception-coastal-deposition-happens-strong-powerful
  a curric:Misconception ;
  curric:statement "Coastal deposition happens with strong powerful waves."@en ;
  curric:correction """Deposition happens in areas with low-energy waves, such as bays or sheltered
  areas, where waves lose energy and can no longer carry their load of sediment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123031Z"^^xsd:dateTime .

oakcurric:misconception-bottom-strategies-fully-solve-urban
  a curric:Misconception ;
  curric:statement "Bottom-up strategies can fully solve urban problems on their own."@en ;
  curric:correction """Bottom-up strategies are valuable because they reflect community needs,
  improve trust, and lead to long-term change. However, they usually require support from
  NGOs or the government, such as funding, land rights, or technical help to be sustainable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123036Z"^^xsd:dateTime .

oakcurric:misconception-net-zero-means-greenhouse-gas
  a curric:Misconception ;
  curric:statement "Net zero means no greenhouse gas emissions at all."@en ;
  curric:correction """In fact, net zero allows for greenhouse gas emissions as long as they are
  balanced by carbon being removed from the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123125Z"^^xsd:dateTime .

oakcurric:misconception-house-prices-decrease-further-one
  a curric:Misconception ;
  curric:statement "House prices will decrease the further one gets from the CBD."@en ;
  curric:correction """The price per square metre may decrease as one moves further from the CBD,
  but as homes get larger with that distance, one cannot say that they get cheaper overall."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123609Z"^^xsd:dateTime .

oakcurric:misconception-good-enquiry-question-answered-data
  a curric:Misconception ;
  curric:statement "A good enquiry question is answered in the data collection stage."@en ;
  curric:correction """A good enquiry question guides you through all stages of the enquiry to help
  you find an answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124103Z"^^xsd:dateTime .

oakcurric:misconception-jakartas-suburbs-poor-unplanned-informal
  a curric:Misconception ;
  curric:statement "Jakarta’s suburbs are poor and unplanned with informal settlements."@en ;
  curric:correction """Jakarta’s suburbs include both wealthy and mid-income areas, many of which
  are well-planned and developed (e.g. Pondok Indah, Kelapa Gading)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124124Z"^^xsd:dateTime .

oakcurric:misconception-informal-employment-unskilled
  a curric:Misconception ;
  curric:statement "Those in informal employment are unskilled."@en ;
  curric:correction """Just because work is unregulated it does not mean that the workers are
  unskilled. While some workers may not have official certification of skills, they still
  possess expertise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124439Z"^^xsd:dateTime .

oakcurric:misconception-tourism-brought-benefits-island-bali
  a curric:Misconception ;
  curric:statement "Tourism has only brought benefits to the island of Bali and its people."@en ;
  curric:correction """Tourism has various positive and negative impacts - while the economy has
  grown and some public services have improved, others have declined (e.g. the water supply)
  and so many people visit Bali each year its environment has suffered in the South."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127795Z"^^xsd:dateTime .

oakcurric:misconception-natural-hazard-same-thing-natural
  a curric:Misconception ;
  curric:statement "A natural hazard is the same thing as a natural disaster."@en ;
  curric:correction """A natural hazard is a potentially harmful event, a natural disaster is when a
  natural hazard event significantly affects humans."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128026Z"^^xsd:dateTime .

oakcurric:misconception-within-given-biome-plants-animals
  a curric:Misconception ;
  curric:statement "Within a given biome, the plants and animals are the same everywhere."@en ;
  curric:correction "Small-scale variation occurs within global biomes due to local factors."@en ;
  dcterms:modified "2026-06-07T15:30:15.129336Z"^^xsd:dateTime .

oakcurric:misconception-everyone-country-high-gni-well
  a curric:Misconception ;
  curric:statement """That everyone in a country with a high GNI is well off, with a good quality of
  life."""@en ;
  curric:correction """A country’s income is not equally divided by everyone who lives there. This
  is why GNI per head should be used along side other measures in order to understand
  differences in quality of life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129429Z"^^xsd:dateTime .

oakcurric:misconception-poorer-people-live-far-city
  a curric:Misconception ;
  curric:statement """Poorer people always live far away from the city centre, and richer people
  live near the centre."""@en ;
  curric:correction """Jakarta is more complex. In Jakarta, many wealthy areas stretch from north to
  south along the central axis, but some low-income areas are found right next to rich
  districts, even in the inner city. Kampungs can develop wherever there’s space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129527Z"^^xsd:dateTime .

oakcurric:misconception-people-jakarta-equal-access-safe
  a curric:Misconception ;
  curric:statement """All people in Jakarta have equal access to safe housing with running
  water."""@en ;
  curric:correction """Not all people in Jakarta have equal access to safe housing with running
  water. Poorer communities, especially in informal settlements, often lack basic services,
  while wealthier areas have more reliable infrastructure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130786Z"^^xsd:dateTime .

oakcurric:misconception-bigger-hazard-event-higher-hazard
  a curric:Misconception ;
  curric:statement "The bigger the hazard event is, the higher the hazard risk will be."@en ;
  curric:correction """The size of the hazard event is not the only factor that affects hazard risk.
  For example, a higher income country may have a lower hazard risk for a magnitude 6.5
  earthquake than a lower income country, even though the earthquakes have equal power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137546Z"^^xsd:dateTime .

oakcurric:misconception-caves-arches-stacks-stumps-form
  a curric:Misconception ;
  curric:statement "Caves, arches, stacks and stumps form very quickly and at the same time."@en ;
  curric:correction """Coastal landforms form over time through erosion and weathering, progressing
  from caves to arches, which collapse into stacks, and eventually erode into stumps, show
  gradual and differential erosion processes that shape the landscape."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138678Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-population-distribution-population
  a curric:Misconception ;
  curric:statement "Pupils can mix up population distribution and population density."@en ;
  curric:correction """Population density is a spatial pattern of population whereas population
  density is the ratio of people to a defined space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141498Z"^^xsd:dateTime .

oakcurric:misconception-education-healthcare-jakarta-improve-wellbeing
  a curric:Misconception ;
  curric:statement """Education and healthcare in Jakarta only improve wellbeing, not economic
  opportunities."""@en ;
  curric:correction """Both sectors also create job opportunities. Schools, hospitals, and research
  centres employ many people, and better education leads to higher-skilled, better-paid
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142645Z"^^xsd:dateTime .

oakcurric:misconception-chart-axes-immigration-numbers-trend
  a curric:Misconception ;
  curric:statement """Chart axes for 'Immigration numbers trend' show numbers are similar for many
  countries."""@en ;
  curric:correction """Chart axes appear to be comparable at first, the numbers on the vertical axis
  differ widely. It is therefore essential to look at the numbers carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142998Z"^^xsd:dateTime .

oakcurric:misconception-weathering-erosion-same-process
  a curric:Misconception ;
  curric:statement "Weathering and erosion are the same process."@en ;
  curric:correction """Weathering breaks down rocks in place without movement, while erosion
  involves the removal and transport of that material by wind, water, ice, or gravity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143026Z"^^xsd:dateTime .

oakcurric:misconception-grey-water-includes-reuse-water
  a curric:Misconception ;
  curric:statement """'Grey' water includes the reuse of water already used to flush the toilet -
  yuck!"""@en ;
  curric:correction """‘Grey’ water does not include water that has been used to flush toilets as
  that water is too contaminated to be used again without treatment. However, one of the
  possible uses for ‘grey’ water from baths, showers, sinks etc is to flush toilets."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143869Z"^^xsd:dateTime .

oakcurric:misconception-lics-nees-general-lack-safe
  a curric:Misconception ;
  curric:statement "In LICs and NEEs there is a general lack of safe drinking water."@en ;
  curric:correction """There is unequal access to safe drinking water in LICs and some NEEs, rather
  than a general lack. Investment in infrastructure often lags behind population growth.
  Wealthier people buy bottled water or expensive home purification technology."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146564Z"^^xsd:dateTime .

oakcurric:misconception-creating-managing-wilderness-areas-taiga
  a curric:Misconception ;
  curric:statement """Creating and managing wilderness areas in the taiga biome is easy because the
  region is sparsely populated."""@en ;
  curric:correction """Managing wilderness areas in the taiga is challenging due to its extreme
  climate, vast size, remote location, and limited infrastructure, which make access,
  monitoring, and conservation efforts difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146966Z"^^xsd:dateTime .

oakcurric:misconception-sustainable-food-production-benefits-environment
  a curric:Misconception ;
  curric:statement "Sustainable food production only benefits the environment."@en ;
  curric:correction """Sustainable food production also has social and economic benefits, such as
  improving food security and reducing poverty."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147030Z"^^xsd:dateTime .

oakcurric:misconception-indigenous-people-cut-commercial-world
  a curric:Misconception ;
  curric:statement "Indigenous people are cut off from the commercial world."@en ;
  curric:correction """Indigenous people are increasingly linked to the wider world through
  technology and are affected by large-scale commercial resource exploitation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147187Z"^^xsd:dateTime .

oakcurric:misconception-rising-demand-energy-simply-worlds
  a curric:Misconception ;
  curric:statement "Rising demand for energy is simply down to the world's growing population."@en ;
  curric:correction """This is one reason for the growing demand for energy, but economic
  development is another factor that affects demand. As people become richer, their
  consumption of energy increases, e.g. instead of using bicycles for transport, people use
  mopeds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147529Z"^^xsd:dateTime .

oakcurric:misconception-people-around-world-food-insecure
  a curric:Misconception ;
  curric:statement "Most people around the world are food insecure."@en ;
  curric:correction """Thirty per cent are food insecure, meaning 70% experience food security.
  (Food security for all remains a UN target for 2030 and a key priority for governments
  around the world.)"""@en ;
  dcterms:modified "2026-06-07T15:30:15.147777Z"^^xsd:dateTime .

oakcurric:misconception-development-new-jobs-industry-occurs
  a curric:Misconception ;
  curric:statement """The development of new jobs in industry occurs at a large scale, involving
  huge factories and investment by a transnational corporation."""@en ;
  curric:correction """Microfinance loans can also support the development of new jobs in industry,
  at a smaller scale."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148153Z"^^xsd:dateTime .

oakcurric:misconception-areas-jakarta-experiencing-same-kind
  a curric:Misconception ;
  curric:statement """All areas of Jakarta are experiencing the same kind of land use change and
  impacts."""@en ;
  curric:correction """Different parts of Jakarta are changing in different ways. West Jakarta is
  losing green space to malls and housing, East Jakarta is growing with factories and roads,
  South Jakarta has gated communities, and Central Jakarta is focused on business."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148330Z"^^xsd:dateTime .

oakcurric:misconception-demand-oil-decreases-oil-prices
  a curric:Misconception ;
  curric:statement "If demand for oil decreases then oil prices will always decrease too."@en ;
  curric:correction """Although oil prices may decrease if demand decreases, oil-producing countries
  can increase the price of oil by reducing the amount of oil they supply. This requires
  oil-producing countries to work together to reduce supply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148471Z"^^xsd:dateTime .

oakcurric:misconception-sketch-map-needs-artistic-representation
  a curric:Misconception ;
  curric:statement "A sketch map needs to be an artistic representation of a place."@en ;
  curric:correction """A sketch map looks like a map as it has a plan orientation but it is not a
  work of art. It uses simple, clean lines to communicate the main features of a map."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149094Z"^^xsd:dateTime .

oakcurric:misconception-valuable-resource-cold-environments-timber
  a curric:Misconception ;
  curric:statement "The only valuable resource in cold environments is timber."@en ;
  curric:correction """Many valuable resources are found in cold environments (albeit difficult to
  access), such as fossil fuels and minerals. Timber in polar and tundra regions is not
  found there. These are treeless areas. Timber is found further south in the taiga biome."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150372Z"^^xsd:dateTime .

oakcurric:misconception-students-frequently-confuse-aerial-images
  a curric:Misconception ;
  curric:statement """Students frequently confuse the aerial images seen through software such as
  Google Maps as a map, partly because they are frequently displayed alongside actual maps."""@en ;
  curric:correction """Maps are representations of the world and use symbols and cartographic
  language to present certain characteristics of a place (and not others). Aerial
  photographs are indiscriminate views of the world and do not select certain aspects of
  geography."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150774Z"^^xsd:dateTime .

oakcurric:misconception-geographer-good-maths-successfully-analyse
  a curric:Misconception ;
  curric:statement """A geographer has to be good at maths to successfully analyse quantitative
  data."""@en ;
  curric:correction """Successful analysis in geography means correctly understanding what numerical
  values mean, not necessarily being able to process and manipulate data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151119Z"^^xsd:dateTime .

oakcurric:misconception-flood-management-stop-flooding-area
  a curric:Misconception ;
  curric:statement "Flood management can stop flooding of an area."@en ;
  curric:correction """Flood management cannot stop flooding, but it can reduce the risk, frequency,
  and impact of floods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151377Z"^^xsd:dateTime .

oakcurric:misconception-factor-affecting-flood-risk-rainfall
  a curric:Misconception ;
  curric:statement "The only factor affecting flood risk is rainfall."@en ;
  curric:correction """Whether a river floods in response to heavy rainfall also relates to many
  other factors, especially how quickly and in what volume rainfall enters the river."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151384Z"^^xsd:dateTime .

oakcurric:misconception-japans-tsunami-evacuation-failed-because
  a curric:Misconception ;
  curric:statement """Japan’s tsunami evacuation failed because it had not invested in a tsunami
  warning system."""@en ;
  curric:correction """Japan had invested in a tsunami warning system, but due to how close the
  epicentre was, there were only 30 minutes before tsunami waves arrived, meaning that not
  everyone was evacuated safely. The height of the tsunami was not accurately predicted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154214Z"^^xsd:dateTime .

oakcurric:misconception-indonesia-hic-people-still-work
  a curric:Misconception ;
  curric:statement """As Indonesia is not an HIC, most people there will still work in
  agriculture."""@en ;
  curric:correction """Agriculture was once Indonesia’s economic backbone, but its share of the
  workforce has declined since the 1990s. Today, industry and services dominate Indonesia's
  economy, with manufacturing, finance, tourism and digital sectors growing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156218Z"^^xsd:dateTime .

oakcurric:misconception-countries-consume-oil-same-rate
  a curric:Misconception ;
  curric:statement "All countries consume oil at the same rate."@en ;
  curric:correction """Oil consumption varies based on industrialisation, population size, and
  economic factors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156233Z"^^xsd:dateTime .

oakcurric:misconception-secondary-data-collected-geographical-experts
  a curric:Misconception ;
  curric:statement "Secondary data has to be collected by geographical experts."@en ;
  curric:correction """Secondary data is often collected by experts or professional geographers but
  it can also be the data collected by other students in a different time frame."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156710Z"^^xsd:dateTime .

oakcurric:misconception-top-strategies-benefit-everyone-equally
  a curric:Misconception ;
  curric:statement "Top-down strategies always benefit everyone equally."@en ;
  curric:correction """Top-down strategies often improve infrastructure at a large scale, but they
  do not always reach all areas fairly. Wealthier areas tend to benefit first, while poorer
  communities may lack reliable water, waste collection, or transport access."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157668Z"^^xsd:dateTime .

oakcurric:misconception-glaciated-landscapes-found-polar-regions
  a curric:Misconception ;
  curric:statement "Glaciated landscapes are only found in polar regions"@en ;
  curric:correction """Glaciated landscapes can be found in many mountainous regions around the
  world, including Snowdonia in North Wales, not just in polar areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158659Z"^^xsd:dateTime .

oakcurric:misconception-research-form-industry-because-involve
  a curric:Misconception ;
  curric:statement "Research is not a form of industry because it does not involve trade."@en ;
  curric:correction """Research is an industry because it creates wealth through innovation and
  knowledge which has value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158664Z"^^xsd:dateTime .

oakcurric:misconception-because-know-location-plate-margins
  a curric:Misconception ;
  curric:statement """Because we know the location of plate margins, scientists can predict when
  earthquakes will happen."""@en ;
  curric:correction """While scientists can identify areas that are at high risk of earthquakes,
  exact predictions for when and where an earthquake will occur (or what magnitude it will
  be) are not possible."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158756Z"^^xsd:dateTime .

oakcurric:misconception-recyclable-energy-same-renewable-energy
  a curric:Misconception ;
  curric:statement "Recyclable energy is the same as renewable energy."@en ;
  curric:correction """Renewable energy comes from natural processes that are constantly renewed, so
  they never run out. Recyclable energy comes from resources that are often finite (they can
  run out) but which can be reprocessed or reused to extend their use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159041Z"^^xsd:dateTime .

oakcurric:misconception-country-fossil-fuels-underground-easily
  a curric:Misconception ;
  curric:statement "If a country has fossil fuels underground, it can easily use them."@en ;
  curric:correction """Some countries lack the infrastructure or funding to develop their resources,
  even if they are accessible, while in other cases a country might have resources that
  require advanced and expensive technology to access."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159220Z"^^xsd:dateTime .

oakcurric:misconception-manufacturing-industries-harm-environment
  a curric:Misconception ;
  curric:statement "Only manufacturing industries harm the environment."@en ;
  curric:correction """All sectors of industry have the potential to harm the environment, though
  manufacturing continues to be highly wasteful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159644Z"^^xsd:dateTime .

oakcurric:misconception-everyone-living-rural-area-higher
  a curric:Misconception ;
  curric:statement "Everyone living in a rural area will have a higher standard of living."@en ;
  curric:correction """While retirees moving into a rural area may be able to live comfortably,
  local people may experience a stagnation in employment opportunities and not be able to
  afford to live where they grew up."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159818Z"^^xsd:dateTime .

oakcurric:misconception-indonesia-made-small-islands-small
  a curric:Misconception ;
  curric:statement "Indonesia is made up of small islands and has a small population."@en ;
  curric:correction """In fact, Indonesia is the world's fourth most populous country and while its
  17 000 islands do include many small islands, it has many large islands too: for example,
  Java is around the same size as England and Borneo's size is similar to France."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160242Z"^^xsd:dateTime .

oakcurric:misconception-building-infrastructure-projects-create-long
  a curric:Misconception ;
  curric:statement """Building infrastructure projects will create long term employment
  opportunities."""@en ;
  curric:correction """In most cases the jobs created by building infrastructure projects are likely
  to be short term and highly specialist. This means they are unlikely to last the length of
  the build time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160642Z"^^xsd:dateTime .

oakcurric:misconception-access-electricity-means-24-hours
  a curric:Misconception ;
  curric:statement "Access to electricity means 24 hours a day, seven days a week."@en ;
  curric:correction """Having access to electricity means having an electricity source that can
  provide lighting and charge a phone or radio for 4 hours a day. In LICs, and some NEEs,
  electricity outages are part of daily life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160654Z"^^xsd:dateTime .

oakcurric:misconception-everyone-living-particular-region-similar
  a curric:Misconception ;
  curric:statement """Everyone living in a particular region will have a similar lived experience of
  a place."""@en ;
  curric:correction """Though in general the north and south of the UK show evidence of economic
  inequality, there are lots of pockets of very high levels of wealth in the north and areas
  of extreme poverty in the south."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161225Z"^^xsd:dateTime .

oakcurric:misconception-missing-small-step-procedural-knowledge
  a curric:Misconception ;
  curric:statement "Missing a small step in procedural knowledge for GIS."@en ;
  curric:correction """Emphasise the most likely pitfalls e.g. toggling 'Time'; configuring symbols
  and pop-ups"""@en ;
  dcterms:modified "2026-06-07T15:30:15.161798Z"^^xsd:dateTime .

oakcurric:misconception-secondary-crime-data-tells-us
  a curric:Misconception ;
  curric:statement "Secondary crime data tells us about the economic prosperity of a place."@en ;
  curric:correction """Crime data can be misinterpreted. The data does not give any details about
  the economic status of the victim or the perpetrator. It is also assumes that the
  perpetrator lives in the area where they committed the crime, for which there is no
  evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161880Z"^^xsd:dateTime .

oakcurric:misconception-rapid-urban-growth-jakarta-improved
  a curric:Misconception ;
  curric:statement """Rapid urban growth in Jakarta has improved living conditions for everyone,
  reducing inequality between rich and poor."""@en ;
  curric:correction """Rapid urban growth in Jakarta has not improved life for everyone. While some
  benefit from new jobs and development, many poor migrants face rising living costs,
  limited job security and end up in squatter settlements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162137Z"^^xsd:dateTime .

oakcurric:misconception-volcanoes-earthquakes-occur-types-plate
  a curric:Misconception ;
  curric:statement "That both volcanoes and earthquakes occur at all types of plate margin."@en ;
  curric:correction """While earthquakes are produced by tectonic movements at all plate margins,
  volcanoes are not found at conservative plate margins."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163679Z"^^xsd:dateTime .

oakcurric:misconception-students-find-difficult-grasp-earths
  a curric:Misconception ;
  curric:statement """Students can find it difficult to grasp that Earth's crust and tectonic plates
  include the ocean floor, which has topography (e.g. mountains including volcanoes,
  valleys) just like the land areas."""@en ;
  curric:correction """Remind students (often!) that tectonic plates include the ocean floor. Apps
  such as 3D Scene can help to visualise this underwater topography, which we learn about by
  bathymetry. The story of Marie Tharp provides excellent disciplinary knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163690Z"^^xsd:dateTime .

oakcurric:misconception-foreign-companies-take-profits-back
  a curric:Misconception ;
  curric:statement """Foreign companies always take profits back home and give nothing to
  locals."""@en ;
  curric:correction """Many TNCs invest in local jobs, training, and infrastructure, though some
  profits do return to the home country."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163795Z"^^xsd:dateTime .

oakcurric:misconception-changes-uk-economy-affected-regions
  a curric:Misconception ;
  curric:statement """The changes in the UK economy affected all regions equally and at the same
  time."""@en ;
  curric:correction """Some areas, such as the north east, continued to rely on traditional
  industries until the 1980s and 1990s. Other areas, like London, moved into tertiary
  industries long before others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164005Z"^^xsd:dateTime .

oakcurric:misconception-urban-areas-experience-one-process
  a curric:Misconception ;
  curric:statement "Urban areas can only experience one process of urban change at a time."@en ;
  curric:correction """While in theory urban changes appear to follow a logical order, in reality
  processes often overlap and it is best to avoid thinking of changes occurring along a set
  timeline."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164120Z"^^xsd:dateTime .

oakcurric:misconception-commonwealth-represents-nothing-cultural-historical
  a curric:Misconception ;
  curric:statement """The Commonwealth represents nothing more than a cultural and historical
  connection between countries."""@en ;
  curric:correction """Commonwealth states meet every two years to promote trade relationships,
  human rights and development aid."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164531Z"^^xsd:dateTime .

oakcurric:misconception-deposition-occurs-mouth-river
  a curric:Misconception ;
  curric:statement "Deposition only occurs at the mouth of a river."@en ;
  curric:correction """Deposition happens at the mouth of a river, but it also occurs wherever the
  river loses energy and can no longer carry its load of sediment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164726Z"^^xsd:dateTime .

oakcurric:misconception-landforms-created-due-erosion-river
  a curric:Misconception ;
  curric:statement "All landforms created are due to erosion by the river."@en ;
  curric:correction """Deposition and changes in geology, as well as human activity, can influence
  the landforms created."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165076Z"^^xsd:dateTime .

oakcurric:misconception-easy-miss-important-small-steps
  a curric:Misconception ;
  curric:statement "It is very easy to miss important small steps in GIS."@en ;
  curric:correction """Take students through each step and check for understanding very
  regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165085Z"^^xsd:dateTime .

oakcurric:misconception-impacts-volcanic-eruptions-severe-developing
  a curric:Misconception ;
  curric:statement """Impacts of volcanic eruptions are always more severe in developing and
  emerging countries than in developed countries."""@en ;
  curric:correction """A lot depends on the eruption type and factors such as population density.
  Economic impacts are often highest in developed countries because of the higher value of
  the property impacted by the eruption."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165091Z"^^xsd:dateTime .

oakcurric:misconception-glacial-landforms-created-climate-change
  a curric:Misconception ;
  curric:statement "Glacial landforms are not created by climate change."@en ;
  curric:correction """Glacial landforms are often linked to climate change. In many areas we can
  only see glacial landforms because the ice sheets and glaciers which created them have
  melted. Climate change also causes glacial processes which modify the landscape."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165638Z"^^xsd:dateTime .

oakcurric:misconception-greenfield-sites-quicker-cheaper-develop
  a curric:Misconception ;
  curric:statement """Greenfield sites are quicker and cheaper to develop as they have not been
  built on before."""@en ;
  curric:correction """Greenfield sites may take longer to develop and be more costly as everything
  has to be built from scratch including raod networks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165644Z"^^xsd:dateTime .

oakcurric:misconception-people-developing-countries-less-prepared
  a curric:Misconception ;
  curric:statement """People in developing countries are less prepared because they lack
  understanding of volcanic hazards."""@en ;
  curric:correction """People in developing countries have expert understanding of volcanic hazards
  and local communities are fully aware of hazards. Management problems are often due to
  lack of resources for effective prediction, preparation and relief."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166292Z"^^xsd:dateTime .

oakcurric:misconception-difficulty-remembering-meaning-location-icons
  a curric:Misconception ;
  curric:statement """Difficulty in remembering meaning and location of icons in ArcGIS Online, e.g.
  Analysis Tools and Scene Tools."""@en ;
  curric:correction """Frequent reminders and checks for understanding about icon locations and
  their meanings, e.g. Analysis Tools and Scene Tools."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166368Z"^^xsd:dateTime .

oakcurric:misconception-tsunamis-landslides-primary-impacts-earthquakes
  a curric:Misconception ;
  curric:statement """Tsunamis and landslides are primary impacts of earthquakes because they can
  cause massive damage to people and property."""@en ;
  curric:correction """Tsunamis and landslides are secondary impacts of earthquakes because they
  happen as an indirect result of an earthquake. For e.g, ground shaking destabilises
  slopes, making a landslide more likely, especially if there is then also heavy rain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166712Z"^^xsd:dateTime .

oakcurric:misconception-understanding-imd-rankings-comparing-them
  a curric:Misconception ;
  curric:statement """Understanding IMD rankings and comparing them with primary data can be
  challenging."""@en ;
  curric:correction """Make sure students are aware of the challenges of ranking and other
  attributes where a low number can be a positive thing (similar issue with some measures of
  development such as IMD)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166721Z"^^xsd:dateTime .

oakcurric:misconception-public-transport-less-convenient-expensive
  a curric:Misconception ;
  curric:statement """Public transport is less convenient and more expensive that private
  transport."""@en ;
  curric:correction """Well-designed public transport systems can be faster, cheaper, and more
  reliable than driving, especially in urban areas with congestion and parking costs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168187Z"^^xsd:dateTime .

oakcurric:misconception-air-pollution-jakarta-comes-industries
  a curric:Misconception ;
  curric:statement "Most air pollution in Jakarta comes from industries."@en ;
  curric:correction """While factories contribute, the main source of air pollution in Jakarta is
  traffic, particularly from motorbikes and older diesel vehicles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168570Z"^^xsd:dateTime .

oakcurric:misconception-river-valleys-remain-v-shaped
  a curric:Misconception ;
  curric:statement "River valleys remain V-shaped from source to mouth."@en ;
  curric:correction """A river valley changes from a V-shape to a U-shape as they flow towards the
  mouth due to processes like lateral erosion and deposition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168961Z"^^xsd:dateTime .

oakcurric:misconception-students-select-basemaps-because-like
  a curric:Misconception ;
  curric:statement """Students will sometimes select basemaps because they like their
  appearance."""@en ;
  curric:correction """Students need to appreciate that some of the basemaps which may be least
  appealing at first sight provide much more effective visualisation. They are like the
  canvas for a painting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169052Z"^^xsd:dateTime .

oakcurric:misconception-students-find-difficult-visualise-orientation
  a curric:Misconception ;
  curric:statement """Students can find it difficult visualise the orientation of landscape
  visualisations e.g. which way was the camera pointing?"""@en ;
  curric:correction """Remind students to think about the orientation of landscape visualisations.
  With 3D Scene, there is a compass that can be used to check the orientation and if
  confused, clicking the compass resets the visualisation to put north at the top."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169770Z"^^xsd:dateTime .

oakcurric:misconception-cold-environments-cannot-support-form
  a curric:Misconception ;
  curric:statement "Cold environments cannot support any form of development."@en ;
  curric:correction """While challenging, development is possible in cold environments with proper
  planning and technology."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170056Z"^^xsd:dateTime .

oakcurric:misconception-contour-lines-their-height-marked
  a curric:Misconception ;
  curric:statement "All contour lines have their height marked on them."@en ;
  curric:correction """Most contour lines will show their height, but in very steep areas, where
  contours are close together, some will be omitted as there is a lack of space. The height
  of these lines can be calculated by looking at the height of the surrounding lines."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170129Z"^^xsd:dateTime .

oakcurric:misconception-remote-sensing-data-easily-misinterpreted
  a curric:Misconception ;
  curric:statement """Remote sensing data can easily be misinterpreted, especially if filters have
  been used."""@en ;
  curric:correction """Areas which appear green on an aerial or satellite image may not necessarily
  represent, e.g. green palm oil plantation or green fields may not be sustainable compared
  to the natural rainforest vegetation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170137Z"^^xsd:dateTime .

oakcurric:misconception-volcanoes-occur-land
  a curric:Misconception ;
  curric:statement "Volcanoes only occur on land."@en ;
  curric:correction """In fact, volcanoes occur underwater as well as on land, especially at
  constructive plate margins and hot spots."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170927Z"^^xsd:dateTime .

oakcurric:misconception-flooding-caused-heavy-rainfall
  a curric:Misconception ;
  curric:statement "Flooding is caused only by heavy rainfall."@en ;
  curric:correction """Heavy rainfall is a key factor, other phyiscal and human factors, such as
  relief, geology and land use also affect the flood risk."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171069Z"^^xsd:dateTime .

oakcurric:misconception-coastal-landforms-jurassic-coast-such
  a curric:Misconception ;
  curric:statement """Coastal landforms at the Jurassic Coast, such as Lulworth Cove and Old Harry
  Rocks, were formed quickly in a short period of time."""@en ;
  curric:correction """Coastal landforms at the Jurassic Coast, like Lulworth Cove and Old Harry
  Rocks, were formed over millions of years. Erosion, weathering, and the movement of
  tectonic plates have shaped these features gradually."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171299Z"^^xsd:dateTime .
