  dcterms:modified "2026-06-07T15:30:02.385256Z"^^xsd:dateTime .

oakcurric:keyword-clinometer
  a curric:Keyword ;
  schema:name "clinometer"@en ;
  schema:description "a hand-held device used to measure the gradient of a slope"@en ;
  dcterms:modified "2026-06-07T15:30:02.385263Z"^^xsd:dateTime .

oakcurric:keyword-regeneration
  a curric:Keyword ;
  schema:name "regeneration"@en ;
  schema:description """a planning strategy aimed at addressing problems associated with decline,
  often involving improvements to infrastructure and encouraging new industries to an area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385267Z"^^xsd:dateTime .

oakcurric:keyword-rebranding
  a curric:Keyword ;
  schema:name "rebranding"@en ;
  schema:description """a planning and marketing strategy aimed at creating a new image of a city to
  encourage growth"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385272Z"^^xsd:dateTime .

oakcurric:keyword-decentralisation
  a curric:Keyword ;
  schema:name "decentralisation"@en ;
  schema:description """the outward movement of businesses and administrative organisations from the
  city centre to the outskirts or beyond"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385583Z"^^xsd:dateTime .

oakcurric:keyword-urban-sprawl
  a curric:Keyword ;
  schema:name "urban sprawl"@en ;
  schema:description """the physical outward expansion of a city into the surrounding
  countryside"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385590Z"^^xsd:dateTime .

oakcurric:keyword-greenbelt
  a curric:Keyword ;
  schema:name "greenbelt"@en ;
  schema:description """land that is protected from development and surrounds major English
  cities"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385594Z"^^xsd:dateTime .

oakcurric:keyword-commuter-settlement
  a curric:Keyword ;
  schema:name "commuter settlement"@en ;
  schema:description """a place, often a town or village, where people live and then travel to other
