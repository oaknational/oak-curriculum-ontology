    oakcurric:scheme-geography-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-physical-systems-and-processes ,
    oakcurric:thread-human-systems-and-processes .

oakcurric:unit-3700
  a curric:Unit ;
  rdfs:label "UK physical landscapes"@en ;
  curric:slug "uk-physical-landscapes" ;
  rdfs:comment """This unit teaches pupils about the UK's physical landscape, forming a solid
  foundation for further studies of physical systems and processes. Pupils learn how geology
  and past processes have influenced the physical and human landscape of the UK."""@en ;
  curric:whyThisWhyNow """Pupils can build on their existing knowledge of of the UK to gain -
  through the study of geology - a more in-depth understanding of the UK's distinctive
  landscapes. This unit provides an important context for future units focusing on physical
  processes and landforms.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3700-1 ,
    oakcurric:priorknowledge-3700-2 ,
