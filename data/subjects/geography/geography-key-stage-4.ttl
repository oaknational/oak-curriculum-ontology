  rdfs:label """Landscapes can be described through the shape and situation of their
  settlements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24463-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ice covered large parts of the UK in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.302865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24463-2
  a curric:KeyLearningPoint ;
  rdfs:label "Glacial processes have been responsible for shaping the landscape of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.302869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24463-3
  a curric:KeyLearningPoint ;
  rdfs:label """Glacial processes include freeze-thaw weathering, erosion, movement, transportation
  and deposition (till and outwash)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24435-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are natural and human causes of climate change."@en ;
  dcterms:modified "2026-06-07T15:30:29.305434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24435-2
  a curric:KeyLearningPoint ;
  rdfs:label """Natural causes of climate change include orbital changes, asteroid collisions,
  volcanic activity and solar output."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24435-3
  a curric:KeyLearningPoint ;
  rdfs:label """Human causes of climate change include the use of fossil fuels, agriculture and
  deforestation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24435-4
  a curric:KeyLearningPoint ;
  rdfs:label """Human causes of climate change produce greenhouse gases, enhancing the greenhouse
  effect and leading to global warming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24540-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphs of data allow geographers to understand trends and correlations."@en ;
  dcterms:modified "2026-06-07T15:30:29.305450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Bivariate graphical data allows geographers to predict other values within or beyond
  the data set."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24540-3
  a curric:KeyLearningPoint ;
  rdfs:label """More complex data presentation techniques can be used to show the relationships
  between two or more aspects of data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24477-1
  a curric:KeyLearningPoint ;
  rdfs:label """Urban change has created environmental opportunities to develop integrated transport
  systems and urban greening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24477-2
  a curric:KeyLearningPoint ;
  rdfs:label """Integrated transport systems encourage people to use public transport through making
  journeys smoother."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24477-3
  a curric:KeyLearningPoint ;
  rdfs:label """Future development of the integrated transport system includes becoming more
  integrated, sustainable and accessible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24477-4
  a curric:KeyLearningPoint ;
  rdfs:label "Urban greening can help Liverpool achieve its 2040 net-carbon zero ambitions."@en ;
  dcterms:modified "2026-06-07T15:30:29.305586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24477-5
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of urban greening include the investment from URBAN GreenUP, St John's
  Shopping Centre and Mersey Forest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24458-1
  a curric:KeyLearningPoint ;
  rdfs:label "The storm hydrograph shows the relationship between precipitation and discharge."@en ;
  dcterms:modified "2026-06-07T15:30:29.307168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24458-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical and human factors affect the shape of the storm hydrograph."@en ;
  dcterms:modified "2026-06-07T15:30:29.307172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27576-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cold environments are home to a variety of plants and animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.307286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27576-2
  a curric:KeyLearningPoint ;
  rdfs:label "Animals in cold environments are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-06-07T15:30:29.307290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27576-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants in cold environments are well adapted to the physical conditions."@en ;
  dcterms:modified "2026-06-07T15:30:29.307294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27576-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are issues related to biodiversity in cold environments."@en ;
  dcterms:modified "2026-06-07T15:30:29.307298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22969-1
  a curric:KeyLearningPoint ;
  rdfs:label """An ecosystem is a natural system in which plants, animals and their non-living
  environment interact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22969-2
  a curric:KeyLearningPoint ;
  rdfs:label "Living and non-living things interract within a small-scale ecosystem."@en ;
  dcterms:modified "2026-06-07T15:30:29.307630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22969-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food webs help us understand the interrelationships in a small-scale ecosystem."@en ;
  dcterms:modified "2026-06-07T15:30:29.307634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nutrient cycles show how nutrients transfer across different stores within an
  ecosystem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cold environments (polar and tundra) and located at high latitudes close to the
  poles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27575-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cold environments have distinctive physical characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.308741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27575-3
  a curric:KeyLearningPoint ;
  rdfs:label "The climate influences other physical characteristics of cold environments."@en ;
  dcterms:modified "2026-06-07T15:30:29.308747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28467-1
  a curric:KeyLearningPoint ;
  rdfs:label """GIS uses historical imagery to visualise and analyse how the coastline changes over
  time. This is called temporal data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28467-2
  a curric:KeyLearningPoint ;
  rdfs:label """GIS uses historical maps to analyse how the coastline changes using georeferenced
  older maps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28467-3
  a curric:KeyLearningPoint ;
  rdfs:label """GIS apps which enable visualisation of temporal data include Esri Wayback and NLS
  Maps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28467-4
  a curric:KeyLearningPoint ;
  rdfs:label """GIS apps use historical imagery and historical maps to visualise and measure change
  such as the rate of coastal erosion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24474-1
  a curric:KeyLearningPoint ;
  rdfs:label "Liverpool is a coastal city in the north-west of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.311585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24474-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence of Liverpool’s importance can be categorised into historical,
  socio-economic, demographic and economic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24474-3
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool is nationally important for its diversity, city economy, role in the
  Industrial Revolution and population."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24474-4
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool is globally important for trade, sporting and cultural events and its link
  to the slave trade and migration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22982-1
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change is affecting tropical rainforests."@en ;
  dcterms:modified "2026-06-07T15:30:29.311623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22982-2
  a curric:KeyLearningPoint ;
  rdfs:label """How is climate change an indirect threat to tropical rainforests (ecosystem stress,
  drought)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24534-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direction on a map can be understood by using compass points or bearings."@en ;
  dcterms:modified "2026-06-07T15:30:29.311650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24534-2
  a curric:KeyLearningPoint ;
  rdfs:label """Four and six figure grid references are a way of finding a specific place on
  a map."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24534-3
  a curric:KeyLearningPoint ;
  rdfs:label """The scale of the map can be used to calculate the distance between two features or
  places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22986-1
  a curric:KeyLearningPoint ;
  rdfs:label "The taiga is increasingly threatened by commercial development."@en ;
  dcterms:modified "2026-06-07T15:30:29.311957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22986-2
  a curric:KeyLearningPoint ;
  rdfs:label """Threats include logging, pulp and paper production, fossil fuel extraction, mining
  and HEP development."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22986-3
  a curric:KeyLearningPoint ;
  rdfs:label """An example of threat to the taiga from development is the commercial exploitation of
  tar sands in Alberta, Canada."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22980-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are special ecosystems."@en ;
  dcterms:modified "2026-06-07T15:30:29.311969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22980-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are of value to people at all scales."@en ;
  dcterms:modified "2026-06-07T15:30:29.311973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22980-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tropical rainforests are of value to the environment at all scales."@en ;
  dcterms:modified "2026-06-07T15:30:29.311977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool's migrations can be divided over time (historical and recent) and over
  space (national and international)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Significant national, historical inflows have been from Ireland and Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.313208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24485-3
  a curric:KeyLearningPoint ;
  rdfs:label "International inflows have been both historic and recent."@en ;
  dcterms:modified "2026-06-07T15:30:29.313212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool's population, age structure, economy, ethnicity, housing, income, services
  and culture have been influenced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24485-5
  a curric:KeyLearningPoint ;
  rdfs:label "Toxteth, Calderstones and Halewood have been influenced in different ways"@en ;
  dcterms:modified "2026-06-07T15:30:29.313222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24509-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indonesia is the largest country in SE Asia and is an archipelago consisting of over
  17 000 islands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24509-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indonesia is significant nationally (environmental and cultural), regionally and
  globally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24509-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indonesia is placed within a wider political, social, cultural and environmental
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24194-1
  a curric:KeyLearningPoint ;
  rdfs:label "Desertification is a serious threat in hot desert environments."@en ;
  dcterms:modified "2026-06-07T15:30:29.313319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24194-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are several causes of desertification including climate change, population
  growth and removal of fuelwood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24194-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are several strategies used to reduce the risk of desertification including
  soil management and tree planting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24440-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rock types have distinctive physical and chemical characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.314538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Igneous, metamorphic and sedimentary rocks are found in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.314542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24440-3
  a curric:KeyLearningPoint ;
  rdfs:label "Igneous rocks form from cooling molten magma."@en ;
  dcterms:modified "2026-06-07T15:30:29.314546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24440-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sedimentary rocks form from accumulated sediments."@en ;
  dcterms:modified "2026-06-07T15:30:29.314550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24440-5
  a curric:KeyLearningPoint ;
  rdfs:label "Metamorphic rocks change due to heat and/or pressure."@en ;
  dcterms:modified "2026-06-07T15:30:29.314554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24542-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spatial data can be shown on a map using points, lines and polygons."@en ;
  dcterms:modified "2026-06-07T15:30:29.314601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24542-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geographical Information Systems (GIS) create maps that can show many forms of
  spatial data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24542-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are some styles of maps that show spatial data in specific ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.314612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24484-1
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool exhibits characteristic urban forms (CBD, inner city, suburbs and
  rural-urban fringe)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24484-2
  a curric:KeyLearningPoint ;
  rdfs:label "Liverpool's structure (urban form)  is determined by  building age and density."@en ;
  dcterms:modified "2026-06-07T15:30:29.318226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24484-3
  a curric:KeyLearningPoint ;
  rdfs:label """Liverpool's structure (urban form) is determined by land use and environmental
  quality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24539-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many forms of graphical data presentation but not all are appropriate for
  all types of data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24539-2
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency data can be presented using bar charts, pictograms and histograms."@en ;
  dcterms:modified "2026-06-07T15:30:29.318313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24539-3
  a curric:KeyLearningPoint ;
  rdfs:label "Proportional data can be presented using pie charts and percentage bars."@en ;
  dcterms:modified "2026-06-07T15:30:29.318317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27974-1
  a curric:KeyLearningPoint ;
  rdfs:label """How resistant rock is to erosional processes is influenced by its rock type
  (hard/soft)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27974-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geological structure can result in concordant and discordant coastlines."@en ;
  dcterms:modified "2026-06-07T15:30:29.320848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27974-3
  a curric:KeyLearningPoint ;
  rdfs:label "Coastal erosion creates distinctive landforms."@en ;
  dcterms:modified "2026-06-07T15:30:29.320853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27976-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sediment transportation (longshore drift) and deposition (constructive waves)
  operate at the coast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27976-2
  a curric:KeyLearningPoint ;
  rdfs:label """Processes of transportation and deposition influences coastal landforms (spits,
  beaches, bars)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24476-1
  a curric:KeyLearningPoint ;
  rdfs:label """Urban change has created social and economic opportunities for people in
  Liverpool."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24476-2
  a curric:KeyLearningPoint ;
  rdfs:label "Social opportunities include entertainment and recreation opportunities."@en ;
  dcterms:modified "2026-06-07T15:30:29.321721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24476-3
  a curric:KeyLearningPoint ;
  rdfs:label "Social opportunities include the benefits of a cultural mix."@en ;
  dcterms:modified "2026-06-07T15:30:29.321725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24476-4
  a curric:KeyLearningPoint ;
  rdfs:label "Economic opportunities are in the form of a varied employment sector."@en ;
  dcterms:modified "2026-06-07T15:30:29.321729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24476-5
  a curric:KeyLearningPoint ;
  rdfs:label """Tech companies are attracted to Liverpool due to the workforce, supportive
  environment and links to similar companies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27581-1
  a curric:KeyLearningPoint ;
  rdfs:label "Conflicts can exist between different land uses in glaciated upland areas."@en ;
  dcterms:modified "2026-06-07T15:30:29.323819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27581-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conflicts can exist between development and conservation in glaciated upland
  areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323823Z"^^xsd:dateTime .

