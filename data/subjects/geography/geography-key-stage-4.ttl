  dcterms:modified "2026-06-07T15:30:29.625607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29585-1
  a curric:KeyLearningPoint ;
  rdfs:label """GIS can be used to visualise and configure primary georeferenced data attributes
  from human geography fieldwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29585-2
  a curric:KeyLearningPoint ;
  rdfs:label """GIS visualisations can use attributes including bearing data to create proportional,
  orientated symbols."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29585-3
  a curric:KeyLearningPoint ;
  rdfs:label """GIS visualisations can be time-enabled using temporal data attributes to enhance the
