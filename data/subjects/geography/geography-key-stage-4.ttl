  dcterms:modified "2026-06-07T15:30:02.356761Z"^^xsd:dateTime .

oakcurric:keyword-science-park
  a curric:Keyword ;
  schema:name "science park"@en ;
  schema:description """an area of land dedicated to businesses specialising in science and
  technology"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356766Z"^^xsd:dateTime .

oakcurric:keyword-financial-services
  a curric:Keyword ;
  schema:name "financial services"@en ;
  schema:description """a tertiary sector industry that deals with banking, investments, pensions
  and insurance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356770Z"^^xsd:dateTime .

oakcurric:keyword-extreme-weather
  a curric:Keyword ;
