  dcterms:modified "2026-06-07T15:30:29.267425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24486-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 6 local authorities in the Liverpool City Region are all in the top 60 most
  deprived in England. Knowsley ranks 2nd."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24486-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deprivation has a cause and effect link to inequalities in services, health,
