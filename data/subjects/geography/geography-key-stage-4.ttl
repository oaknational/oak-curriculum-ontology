oakcurric:keylearningpoint-lesson-28463-2
  a curric:KeyLearningPoint ;
  rdfs:label """The impacts can be visualised with georeferenced data using the GIS tool called
  media layers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28463-3
  a curric:KeyLearningPoint ;
  rdfs:label """Configuration of media layers happens in a 2D webmap, which can be saved for even
  more powerful use in 3D maps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28463-4
  a curric:KeyLearningPoint ;
  rdfs:label """GIS tools can support analysis of media layers including measurement tools and the
  Elevation Profile tool."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620796Z"^^xsd:dateTime .

