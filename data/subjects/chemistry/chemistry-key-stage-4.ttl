  dcterms:modified "2026-02-12T08:59:15.811117Z"^^xsd:dateTime .

oakcurric:keyword-anion
  a curric:Keyword ;
  schema:name "anion"@en ;
  schema:description "A particle with a negative charge."@en ;
  dcterms:modified "2026-02-12T08:59:15.811121Z"^^xsd:dateTime .

oakcurric:keyword-composition
  a curric:Keyword ;
  schema:name "Composition"@en ;
  schema:description """The composition of a whole number is the way in which the whole number is made up. For example, ten is composed of seven and three."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811205Z"^^xsd:dateTime .

oakcurric:keyword-line-graph
  a curric:Keyword ;
  schema:name "Line graph"@en ;
  schema:description """A line graph is a graph where the points are connected by line segments. It shows how something changes in value, usually over time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811248Z"^^xsd:dateTime .

oakcurric:keyword-combustion
  a curric:Keyword ;
  schema:name "combustion"@en ;
  schema:description """In a combustion reaction, fuel is burned and reacts with oxygen to provide energy. Carbon dioxide is released in combustion reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811509Z"^^xsd:dateTime .

oakcurric:keyword-exothermic
  a curric:Keyword ;
  schema:name "exothermic"@en ;
  schema:description """An exothermic chemical reaction is a type of reaction in which energy is transferred from the reactants to the surroundings, e.g. combustion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811513Z"^^xsd:dateTime .

oakcurric:keyword-activation-energy
  a curric:Keyword ;
  schema:name "activation energy"@en ;
  schema:description """The minimum energy that the particles must have in order to react is known as the activation energy."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811521Z"^^xsd:dateTime .

oakcurric:keyword-ammonia
  a curric:Keyword ;
  schema:name "ammonia"@en ;
  schema:description """a simple molecular substance, with the formula NH₃, is a soluble, toxic, pungent gas at room temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811602Z"^^xsd:dateTime .

oakcurric:keyword-alkaline
  a curric:Keyword ;
  schema:name "alkaline"@en ;
  schema:description "a base that dissolves in water; these solutions have a pH greater than 7"@en ;
  dcterms:modified "2026-02-12T08:59:15.811609Z"^^xsd:dateTime .

oakcurric:keyword-pungent
  a curric:Keyword ;
  schema:name "pungent"@en ;
  schema:description "a description of a substance that has a sharply strong smell"@en ;
  dcterms:modified "2026-02-12T08:59:15.811613Z"^^xsd:dateTime .

oakcurric:keyword-toxic
  a curric:Keyword ;
  schema:name "toxic"@en ;
  schema:description "a substance that is poisonous, and can cause harm or death to living organisms"@en ;
  dcterms:modified "2026-02-12T08:59:15.811618Z"^^xsd:dateTime .

oakcurric:keyword-corrosive
  a curric:Keyword ;
  schema:name "corrosive"@en ;
  schema:description """a substance that causes damage by chemical action, often resulting in severe injury or destruction"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811622Z"^^xsd:dateTime .

oakcurric:keyword-monomer
  a curric:Keyword ;
  schema:name "monomer"@en ;
  schema:description "Monomers are small molecules that can join together to form a polymer."@en ;
  dcterms:modified "2026-02-12T08:59:15.811626Z"^^xsd:dateTime .

oakcurric:keyword-intermolecular-forces
  a curric:Keyword ;
  schema:name "intermolecular forces"@en ;
  schema:description """Intermolecular forces are weak forces of attraction between molecules, and molecular substances."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811630Z"^^xsd:dateTime .

oakcurric:keyword-le-chateliers-principle
  a curric:Keyword ;
  schema:name "Le Chatelier’s principle"@en ;
  schema:description """states that if a dynamic equilibrium is disturbed by changing the conditions, the equilibrium position ‘shifts’ to counteract the change."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811635Z"^^xsd:dateTime .

oakcurric:keyword-equilibrium-position
  a curric:Keyword ;
  schema:name "equilibrium position"@en ;
  schema:description """refers to the relative concentrations of reactants and products in a reversible reaction at equilibrium."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811639Z"^^xsd:dateTime .

oakcurric:keyword-repeatable
  a curric:Keyword ;
  schema:name "repeatable"@en ;
  schema:description """Measurements are repeatable if they are very similar when the same procedure is carried out by the same person or team."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811759Z"^^xsd:dateTime .

oakcurric:keyword-binary-ionic-substance
  a curric:Keyword ;
  schema:name "binary ionic substance"@en ;
  schema:description """is made up of two different elements, one of which is a metal and the other a non-metal element."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811883Z"^^xsd:dateTime .

oakcurric:keyword-empirical-formula
  a curric:Keyword ;
  schema:name "empirical formula"@en ;
  schema:description "show the simplest whole number ratio of atoms of each element in a compound."@en ;
  dcterms:modified "2026-02-12T08:59:15.811887Z"^^xsd:dateTime .

oakcurric:keyword-ratio
  a curric:Keyword ;
  schema:name "ratio"@en ;
  schema:description "can be used to determine the size of one quantity in relation to another."@en ;
  dcterms:modified "2026-02-12T08:59:15.811894Z"^^xsd:dateTime .

oakcurric:keyword-dot-and-cross-diagram
  a curric:Keyword ;
  schema:name "dot-and-cross diagram"@en ;
  schema:description """is used to show how chemical bonds are formed between atoms. The electrons from one atom are shown as dots and the electrons from the other atom are shown as crosses."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811898Z"^^xsd:dateTime .

oakcurric:keyword-compound
  a curric:Keyword ;
  schema:name "Compound"@en ;
  schema:description "A shape made up of two or more other shapes is known as compound."@en ;
  dcterms:modified "2026-02-12T08:59:15.811956Z"^^xsd:dateTime .

oakcurric:keyword-bar-chart
  a curric:Keyword ;
  schema:name "Bar chart"@en ;
  schema:description """A bar chart (bar graph) is a graph consisting of bars visually representing the frequency of objects or groups."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811984Z"^^xsd:dateTime .

oakcurric:keyword-end-point
  a curric:Keyword ;
  schema:name "end point"@en ;
  schema:description "The point at which the chemical reaction has finished."@en ;
  dcterms:modified "2026-02-12T08:59:15.812284Z"^^xsd:dateTime .

oakcurric:keyword-octet-rule
  a curric:Keyword ;
  schema:name "octet rule"@en ;
  schema:description """The tendency for atoms to fill their outer shell to 8 electrons to become stable. This occurs through chemical bonding, and results in the electron configuration of a noble gas."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812289Z"^^xsd:dateTime .

oakcurric:keyword-covalent-bond
  a curric:Keyword ;
  schema:name "covalent bond"@en ;
