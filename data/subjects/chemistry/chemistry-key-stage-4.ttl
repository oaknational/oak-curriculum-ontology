  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for chlorine involves passing the gas over damp blue litmus paper."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-1
  a curric:KeyLearningPoint ;
  rdfs:label "The uses of polymers are related to their properties."@en ;
  dcterms:modified "2026-02-12T08:59:21.701418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many problems associated with polymers (e.g. availability of raw materials, landfill, combustion)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many advantages and disadvantages to recycling polymers (e.g. economical and environmental)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fertilisers contain nitrogen, phosphorus and potassium compounds to promote plant growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is a feedstock for manufacture of fertilisers, explosives, plastics, dyes and cleaning products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701440Z"^^xsd:dateTime .

