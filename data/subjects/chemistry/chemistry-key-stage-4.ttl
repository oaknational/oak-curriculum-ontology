  dcterms:modified "2026-02-12T08:59:15.804909Z"^^xsd:dateTime .

oakcurric:keyword-precise
  a curric:Keyword ;
  schema:name "precise"@en ;
  schema:description "sharply defined or stated"@en ;
  dcterms:modified "2026-02-12T08:59:15.805164Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "being exact and precise"@en ;
  dcterms:modified "2026-02-12T08:59:15.805937Z"^^xsd:dateTime .

oakcurric:keyword-sterilisation
  a curric:Keyword ;
  schema:name "sterilisation"@en ;
  schema:description "the process of having a medical operation to make it impossible to have children"@en ;
  dcterms:modified "2026-02-12T08:59:15.807380Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description "the action of moving something from its place or position"@en ;
  dcterms:modified "2026-02-12T08:59:15.807610Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description """a measurement result is considered accurate if it is judged to be close to the true value"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808059Z"^^xsd:dateTime .

oakcurric:keyword-carbon-sink
  a curric:Keyword ;
  schema:name "carbon sink"@en ;
  schema:description "a natural or artificial system that absorbs more carbon dioxide than it releases"@en ;
  dcterms:modified "2026-02-12T08:59:15.808500Z"^^xsd:dateTime .

oakcurric:keyword-fertiliser
  a curric:Keyword ;
  schema:name "fertiliser"@en ;
  schema:description "Fertiliser are minerals that are added to the soil to help plants to grow."@en ;
  dcterms:modified "2026-02-12T08:59:15.809028Z"^^xsd:dateTime .

oakcurric:keyword-eutrophication
  a curric:Keyword ;
  schema:name "eutrophication"@en ;
  schema:description """Eutrophication is the process in which a body of water is overly enriched with plant nutrients. This leads to excessive growth of simple plants such as algae."""@en ;
  dcterms:modified "2026-02-12T08:59:15.809034Z"^^xsd:dateTime .

oakcurric:keyword-magnitude
  a curric:Keyword ;
  schema:name "magnitude"@en ;
  schema:description """how much energy is released during an earthquake, often measured in Mw (moment magnitude)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.810583Z"^^xsd:dateTime .

oakcurric:keyword-dynamic-equilibrium
  a curric:Keyword ;
  schema:name "dynamic equilibrium"@en ;
  schema:description """occurs in a closed system when the forward and backward reactions of a reversible chemical reaction occur at the same rate; and the concentrations of reactants and products remain constant."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810813Z"^^xsd:dateTime .

oakcurric:keyword-reaction-rate
  a curric:Keyword ;
  schema:name "reaction rate"@en ;
  schema:description """is the speed with which a chemical reaction takes place, measured by the amount of a reactant used or amount of product formed in a given time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810817Z"^^xsd:dateTime .

oakcurric:keyword-closed-system
  a curric:Keyword ;
  schema:name "closed system"@en ;
  schema:description """is one in which matter cannot enter or leave the observed environment, allowing only energy transfer between the system and its surrounding environment."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810822Z"^^xsd:dateTime .

oakcurric:keyword-concentration
  a curric:Keyword ;
  schema:name "concentration"@en ;
  schema:description """A measure of the quantity of a dissolved substance in a given volume of solution."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810826Z"^^xsd:dateTime .

oakcurric:keyword-control-variable
  a curric:Keyword ;
  schema:name "control variable"@en ;
  schema:description "a factor that is kept the same during an experiment"@en ;
  dcterms:modified "2026-02-12T08:59:15.810854Z"^^xsd:dateTime .

oakcurric:keyword-polymers
  a curric:Keyword ;
  schema:name "polymers"@en ;
  schema:description "Polymers are long-chained molecules formed by joining together monomers."@en ;
  dcterms:modified "2026-02-12T08:59:15.810867Z"^^xsd:dateTime .

oakcurric:keyword-monomers
  a curric:Keyword ;
  schema:name "monomers"@en ;
  schema:description "Monomers are small molecules that can join together to form a polymer."@en ;
  dcterms:modified "2026-02-12T08:59:15.810871Z"^^xsd:dateTime .

oakcurric:keyword-relative-molecular-mass
  a curric:Keyword ;
  schema:name "relative molecular mass"@en ;
  schema:description """The relative molecular mass of a substance is the sum of the relative atomic masses of all the atoms in a molecule."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810876Z"^^xsd:dateTime .

oakcurric:keyword-addition-polymerisation
  a curric:Keyword ;
  schema:name "addition polymerisation"@en ;
  schema:description """Addition polymerisation is a type of polymerisation where monomers join together to form only one product; a polymer."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810880Z"^^xsd:dateTime .

oakcurric:keyword-repeating-unit
  a curric:Keyword ;
  schema:name "repeating unit"@en ;
  schema:description "The section of a polymer that repeats is known as the repeating unit."@en ;
  dcterms:modified "2026-02-12T08:59:15.810884Z"^^xsd:dateTime .

oakcurric:keyword-simple-molecular
  a curric:Keyword ;
  schema:name "simple molecular"@en ;
  schema:description """Simple molecular substances are made up of two or more atoms covalently bonded together to form a distinct unit."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810889Z"^^xsd:dateTime .

oakcurric:keyword-intermolecular-force
  a curric:Keyword ;
  schema:name "intermolecular force"@en ;
  schema:description """Intermolecular forces are weak forces of attraction between molecules and molecular substances."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810893Z"^^xsd:dateTime .

oakcurric:keyword-giant-covalent
  a curric:Keyword ;
  schema:name "giant covalent"@en ;
