  dcterms:modified "2026-02-12T08:59:21.701699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-02-12T08:59:21.701752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving full electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic nucleus with less force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.701772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas tests can be used to identify carbon dioxide, oxygen, hydrogen and ammonia."@en ;
  dcterms:modified "2026-02-12T08:59:21.701953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the practical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps, crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-1
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst affects the reaction rate without being used up."@en ;
  dcterms:modified "2026-02-12T08:59:21.701969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-2
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst reduces the activation energy needed for a reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.701974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-3
  a curric:KeyLearningPoint ;
  rdfs:label """With a catalyst present, more collisions between reactants result in the formation of product(s)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are biological catalysts."@en ;
  dcterms:modified "2026-02-12T08:59:21.701983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-5
  a curric:KeyLearningPoint ;
  rdfs:label "Catalysts vary in efficiency; qualitative data helps evaluate effectiveness."@en ;
  dcterms:modified "2026-02-12T08:59:21.701987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere comprises ~80% nitrogen and ~20% oxygen."@en ;
  dcterms:modified "2026-02-12T08:59:21.701992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains small proportions of various other gases, including CO₂, water vapour and noble gases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid) state in clouds and precipitation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-5
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-02-12T08:59:21.702010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation & relevant mathematical relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added excess, not all of it will react and some will be found in the final product mixture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from the available particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the amount of gas produced as the reaction progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-3
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid with equal amounts of magnesium, the same volume is produced for all concentrations of acid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a correlation between increasing amounts of atmospheric carbon dioxide and a rising average global temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increases in atmospheric carbon dioxide have been caused by human activity."@en ;
  dcterms:modified "2026-02-12T08:59:21.702354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Overwhelming evidence shows human activity is responsible for the rapid global warming of the last 200 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Global warming measurements and conclusions are reliable despite some unavoidable uncertainty in measured values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon footprints measure the annual greenhouse gas emissions of individuals, industry and nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gently heating the acid speeds up the reaction, ensuring all acid reacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.702512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The salt should be dried using an appropriate method (using filter paper, or in the oven)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-3
  a curric:KeyLearningPoint ;
  rdfs:label """A pure sample should be prepared with equipment washed with distilled water to avoid contamination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reacting a metal hydroxide with an acid also produces a salt and water."@en ;
  dcterms:modified "2026-02-12T08:59:21.702529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal carbonate with an acid can produce a desired salt with water, as well as carbon dioxide gas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Small masses of a substance, including magnesium, can be easily heated in a crucible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible needs to be opened periodically to allow air (i.e. oxygen) to enter the apparatus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lifting a crucible lid too often or for too long may lead to loss of product (i.e. lower final mass recorded)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using practical data and conservation of mass, chemists can calculate unknown reactant masses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reactant masses can determine the empirical formula of a substance, including the ionic molar ratio of a metal & oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of a carbon-12 atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of compound) × 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solution is a type of mixture made of a solvent and a solute."@en ;
  dcterms:modified "2026-02-12T08:59:21.702669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solutions form due to a solute dissolving in the solvent."@en ;
  dcterms:modified "2026-02-12T08:59:21.702673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Solubility is a measure of how well a chemical dissolves (soluble/insoluble)."@en ;
  dcterms:modified "2026-02-12T08:59:21.702680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many substances can act as a solvent; however, water is the most common."@en ;
  dcterms:modified "2026-02-12T08:59:21.702685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-5
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols are used to identify the three states of matter and aqueous solutions in chemical equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.702709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-02-12T08:59:21.702713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-12T08:59:21.702721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed throughout the heating process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Small masses of a substance, including magnesium, can be easily heated in a crucible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible needs to be opened periodically to allow air (i.e. oxygen) to enter the apparatus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lifting a crucible lid too often or for too long may lead to loss of product (i.e. lower final mass recorded)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using practical data and conservation of mass, chemists can calculate unknown reactant masses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reactant masses can determine the empirical formula of a substance, including the ionic ratio of a metal and oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is made from monomers called nucleotides."@en ;
  dcterms:modified "2026-02-12T08:59:21.702973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-2
  a curric:KeyLearningPoint ;
  rdfs:label "Natural polymers are important for life."@en ;
  dcterms:modified "2026-02-12T08:59:21.702978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-3
  a curric:KeyLearningPoint ;
  rdfs:label "The carbohydrates starch and cellulose are made from the monomer glucose."@en ;
  dcterms:modified "2026-02-12T08:59:21.702982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Amino acids contain two functional groups and can form polypeptides and proteins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-02-12T08:59:21.702994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining the element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their own, or in compound form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical compositions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue Bunsen flame."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and identifying elements and compounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-02-12T08:59:21.703038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-02-12T08:59:21.703043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the concentration of each."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of an aqueous solution is the mass of solute dissolved in 1 dm³ of distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of solute is equal to the relative mass of the solute measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concentration can be expressed in g/dm³ or mol/dm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.703064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-4
  a curric:KeyLearningPoint ;
  rdfs:label """Equal volumes of solutions of the same concentration (in mol/dm³) have equal numbers of dissolved solute particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.703073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-1
  a curric:KeyLearningPoint ;
  rdfs:label "Corrosion is a general process of degradation of metals through various causes."@en ;
  dcterms:modified "2026-02-12T08:59:21.703336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting is a specific type of corrosion, affecting iron in the presence of air and moisture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide layer can protect the underlying metal if the oxide forms a physical barrier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some coatings are reactive and contain a more reactive metal to provide sacrificial protection, e.g. zinc to galvanise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electroplating can be used to improve the appearance and/or the resistance to corrosion of metal objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-1
  a curric:KeyLearningPoint ;
  rdfs:label """A chemical equation is used to represent the chemical reaction that occurs during the formation of a compound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic equations can be used to show only the chemical species that are changing within a reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-3
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols (s), (l), (g) and (aq), are used in ionic equations to show which substances change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ionic equation for water formation (neutralisation) is H⁺(aq) + OH⁻(aq) → H2O(l)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is an average value that takes account of the abundance of the isotopes of the element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data collected during a titration allows chemists to determine a solution’s unknown concentration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-2
  a curric:KeyLearningPoint ;
  rdfs:label """Concordant titres should be used when calculating a mean volume used to neutralise a solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-3
  a curric:KeyLearningPoint ;
  rdfs:label """The coefficients in a balanced equation indicates the stoichiometry (i.e. molar ratio) between substances in a reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of an unknown solution is found using the relationship: concentration = moles ÷ volume (in dm³)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to avoid false positives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to a solution containing them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution containing sulfate ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Titration is a method used to completely neutralise an acid with a soluble base (alkali)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-2
  a curric:KeyLearningPoint ;
  rdfs:label """Titrations are performed using strong acids and strong alkalis to accurately determine reacting volumes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strong acids and alkalis are completely ionised in an aqueous solution."@en ;
  dcterms:modified "2026-02-12T08:59:21.704377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each piece of apparatus in a titration has a specific and essential function."@en ;
  dcterms:modified "2026-02-12T08:59:21.704382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-5
  a curric:KeyLearningPoint ;
  rdfs:label """A suitable indicator (not universal indicator) is used to identify the end point of the titration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-02-12T08:59:21.704404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated similar properties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into groups of similar properties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were later found."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by atomic weight was not always correct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere comprises 78% nitrogen, 21% oxygen, 1% argon and trace gases including 0.04% carbon dioxide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid) state in clouds and precipitation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-4
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-02-12T08:59:21.704865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the lab."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density and particles is fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-02-12T08:59:21.704909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce uncertainty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytomining, metal is extracted from a crop of plants that absorb metal ions through their roots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-02-12T08:59:21.705293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.705298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-02-12T08:59:21.705307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.705318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright light produced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-12T08:59:21.705328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating the number of moles in a substance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same substance."@en ;
  dcterms:modified "2026-02-12T08:59:21.705941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-02-12T08:59:21.705945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-02-12T08:59:21.705950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentation, filtration and chlorination are used to obtain potable water from groundwater and fresh water sources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of seawater creates potable water by distillation or reverse osmosis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating the number of moles in a substance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of an aqueous solution is the mass of solute dissolved in 1 dm³ of distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of solute is equal to the relative mass of the solute measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concentration can be expressed in g/dm³ or mol/dm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.706113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-4
  a curric:KeyLearningPoint ;
  rdfs:label """Equal volumes of solutions of the same concentration (in mol/dm³) have equal numbers of dissolved solute particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.706124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.707372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all suggested atomic models."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom & the nuclear model are two important models in the history of the atom's discovery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-02-12T08:59:21.707385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fertilisers contain nitrogen, phosphorus and potassium compounds to promote plant growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is a feedstock for manufacture of fertilisers, explosives, plastics, dyes and cleaning products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ammonia can be used to manufacture ammonium salts and nitric acid."@en ;
  dcterms:modified "2026-02-12T08:59:21.707402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-4
  a curric:KeyLearningPoint ;
  rdfs:label "Phosphate rock is used in the production of fertilisers."@en ;
  dcterms:modified "2026-02-12T08:59:21.707406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-5
  a curric:KeyLearningPoint ;
  rdfs:label """The laboratory preparation of ammonium salts is not the same as the industrial preparation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data collected during a titration allows chemists to determine a solution’s unknown concentration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-2
  a curric:KeyLearningPoint ;
  rdfs:label """Concordant titres should be used when calculating a mean volume used to neutralise a solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-3
  a curric:KeyLearningPoint ;
  rdfs:label """The coefficients in a balanced equation indicate the stoichiometry (i.e. molar ratio) between substances in a reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of an unknown solution if found using the relationship: concentration = moles ÷ volume (in dm³)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting points than Group 1 metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-02-12T08:59:21.708607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.708612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often exhibit vibrant colours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-02-12T08:59:21.708621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.708632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright light produced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-12T08:59:21.708642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-1
  a curric:KeyLearningPoint ;
  rdfs:label """A more reactive element will replace a less reactive element in a compound (displacement)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more easily a metal atom forms a positive ion, the more reactive it is."@en ;
  dcterms:modified "2026-02-12T08:59:21.708651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with acid to produce a metal salt and hydrogen gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.708656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with water to produce a metal hydroxide and hydrogen gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.708660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is a non-metal element often included in the reactivity series between aluminium and zinc."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Corrosion is a general process of degradation of metals through various causes."@en ;
  dcterms:modified "2026-02-12T08:59:21.709466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting is a specific type of corrosion, affecting iron in the presence of air and moisture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide layer can protect the underlying metal if the oxide forms a physical barrier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some coatings are reactive and contain a more reactive metal to provide sacrificial protection, e.g. zinc to galvanise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electroplating can be used to improve the appearance and/or the resistance to corrosion of metal objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytoextraction, metal is extracted from a crop of plants that absorb metal ions through their roots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-02-12T08:59:21.709567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.709574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a compound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions, calculate the empirical formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula, calculate the molecular formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Know that we are using moles, and molar ratios to calculate formulae"@en ;
  dcterms:modified "2026-02-12T08:59:21.709689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of mass of gas produced against time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess marble chips with acid, the same mass of gas is produced for all surface areas of chips."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mean rate of reaction = total mass of gas produced ÷ total time of reaction"@en ;
  dcterms:modified "2026-02-12T08:59:21.709933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-4
  a curric:KeyLearningPoint ;
  rdfs:label "The instantaneous rate of reaction is equal to the gradient of the graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.709938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a covalent bond, two non-metal atoms share a pair of electrons (from their outer shells)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-2
  a curric:KeyLearningPoint ;
  rdfs:label """For every one electron needed to complete the outer shell of an atom, one covalent bond will form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-3
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms can share multiple pairs of electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.709958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Displayed formulae of covalent substances are a model, showing lines to represent shared pairs of electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon dioxide and methane are common greenhouse gases."@en ;
  dcterms:modified "2026-02-12T08:59:21.711483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases reduce the amount of lower-energy IR that can escape from Earth’s atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-3
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases do not reduce the amount of higher-energy IR radiation entering the atmosphere from the Sun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the rate energy is transferred into the atmosphere exceeds the rate it is transferred out, average temperatures rise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-5
  a curric:KeyLearningPoint ;
  rdfs:label """An increasing average temperature of Earth’s atmosphere is called global warming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1 atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting mass calculations can use a combination of mass to volume calculations and vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-3
  a curric:KeyLearningPoint ;
  rdfs:label "Amount of substance (moles) can be calculated using multiple equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.713481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-4
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation for calculating moles depends on the context of the problem or calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-1
  a curric:KeyLearningPoint ;
  rdfs:label """In an ideal chemical reaction, all atoms in the reactants would end up in useful products, with no waste."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theoretical yield of a chemical reaction can be calculated from the reaction equation alone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-3
  a curric:KeyLearningPoint ;
  rdfs:label "The percentage yield shows how actual yield compares with theoretical yield."@en ;
  dcterms:modified "2026-02-12T08:59:21.713523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atom economy is a measure of the efficiency with which a reaction uses its reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many factors will be considered when choosing a reaction pathway."@en ;
  dcterms:modified "2026-02-12T08:59:21.713534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equal amounts in moles of gases occupy the same volume under the same conditions of temperature and pressure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1 atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volumes of gaseous reactants and products can be calculated from the balanced equation for the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-4
  a curric:KeyLearningPoint ;
  rdfs:label """If moles of gas are known, its density can be calculated using molar gas volume and the relationship mass = RFM x moles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.716351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-02-12T08:59:21.716355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-12T08:59:21.716362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed throughout the heating process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Contact Process involves the production of sulfur trioxide (SO₃) from sulfur dioxide (SO₂) using a catalyst."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-2
  a curric:KeyLearningPoint ;
  rdfs:label """The process has three main stages: burning sulfur to produce SO₂, converting SO₂ to SO₃, then converting SO₃ to H₂SO₄."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conversion of SO₂ to SO₃ is a reversible reaction performed at 1-2 atmospheres and 450°C, using a V₂O₅ catalyst."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfuric acid production is energy-intensive and releases large amounts of CO₂, contributing to global emissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfuric acid is vital for various industries, such as: fertilisers, chemical manufacturing, and petroleum refining."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the RFM of the reactants equals the sum of the RFM of the products, taking account of balancing coefficients."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms can identify unknown substances by qualitative visual comparison or quantitatively by Rf value comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be employed when using chromatograms to identify unknown substances in a mixture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-3
  a curric:KeyLearningPoint ;
  rdfs:label "An appropriate number of significant figures should be used in calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.716682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting points than Group 1 metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-02-12T08:59:21.716753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.716757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often exhibit vibrant colours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-02-12T08:59:21.717616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell, and become positive ions (cations)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.717632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the number (e.g. 2+, not +2)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-1
  a curric:KeyLearningPoint ;
  rdfs:label """Industrial equilibria involve a trade-off between production rate and equilibrium position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-2
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature, pressure, surface area, concentration, and catalysts impact rates and equilibrium, often in opposing ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-3
  a curric:KeyLearningPoint ;
  rdfs:label """High pressures and temperatures boost reaction rates but must balance safety and cost."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-4
  a curric:KeyLearningPoint ;
  rdfs:label "High pressures are costly and increase equipment failure risk."@en ;
  dcterms:modified "2026-02-12T08:59:21.718632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-5
  a curric:KeyLearningPoint ;
  rdfs:label """Low temperatures slow reactions but can favour desired product in exothermic reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of a carbon-12 atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of compound) × 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.719270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oxidation is the loss of electrons and reduction is the gain of electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.719274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Half equations can be written to show which species are oxidised and which are reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic equations can be written for displacement reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.719286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Whenever a measurement is made, there is always some uncertainty about the result obtained."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-2
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of an individual measurement is equal to half the resolution of the device used to take the measurement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-3
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the resolution, the lower the uncertainty of an individual measurement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-4
  a curric:KeyLearningPoint ;
  rdfs:label "Half the range of repeated measurements equals the uncertainty of a mean value."@en ;
  dcterms:modified "2026-02-12T08:59:21.719309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-5
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of a measurement provides a range within which the actual value can be found."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas tests can be used to identify carbon dioxide, oxygen, hydrogen and ammonia."@en ;
  dcterms:modified "2026-02-12T08:59:21.720764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the practical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps, crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting points than Group 1 metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-02-12T08:59:21.720927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.720932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often exhibit vibrant colours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement reactions involve a more reactive element replacing another in a compound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-02-12T08:59:21.720969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to calculate energy change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hypotheses guide predictions about the effect of variables in experiments."@en ;
  dcterms:modified "2026-02-12T08:59:21.720980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts can visually represent collected results to help analyse data."@en ;
  dcterms:modified "2026-02-12T08:59:21.720985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every atom of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons in atoms of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-1
  a curric:KeyLearningPoint ;
  rdfs:label """A half–equation describes what happens to one reactant in a reaction, such as the process at an individual electrode."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-2
  a curric:KeyLearningPoint ;
  rdfs:label "Half–equations show balanced charges as well as balanced atoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.721513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-3
  a curric:KeyLearningPoint ;
  rdfs:label "A balanced ionic equation shows all reacting ions involved in a reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.721518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions not involved in a reaction do not appear in a balanced ionic equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.721522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-1
  a curric:KeyLearningPoint ;
  rdfs:label """All the atoms in the reactants of a chemical reaction are reorganised to form all the products of the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-2
  a curric:KeyLearningPoint ;
  rdfs:label """There must be an equal number of each type of atom on both the reactant and product side of the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical formulae cannot be altered to balance a reaction equation; only coefficients can change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms cannot be created or destroyed. During a chemical reaction, atoms are simply rearranged into products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps, crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the practical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a chemical reaction is the molar ratio of each substance in a balanced symbol equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoichiometric values can be calculated using masses found by experiment."@en ;
  dcterms:modified "2026-02-12T08:59:21.723311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subscript values in chemical formula indicate the ratio of atoms/ions in a molecule/formula unit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The combustion of fossil fuels adds more carbon dioxide to the atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.723927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide added to the atmosphere in one place will, over time, spread throughout Earth’s atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plants act as carbon sinks because, as they grow, they remove carbon dioxide from the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-4
  a curric:KeyLearningPoint ;
  rdfs:label """The decomposition or combustion of plants returns the carbon they are storing into the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-5
  a curric:KeyLearningPoint ;
  rdfs:label """Human activity is adding carbon dioxide to the atmosphere more quickly than it is being removed by natural processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ionic equation represents the reaction between positive and negative ions."@en ;
  dcterms:modified "2026-02-12T08:59:21.723948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-2
  a curric:KeyLearningPoint ;
  rdfs:label "The electric charge on each side of an ionic equation adds up to zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.723953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-3
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g) and (aq) in ionic equations identify the state of each substance as solid, liquid, gas or in solution"""@en ;
  dcterms:modified "2026-02-12T08:59:21.723959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a compound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions, calculate the empirical formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula, calculate the molecular formula."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.725829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all suggested atomic models."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom and the nuclear model are two important models in the history of the atom's discovery"""@en ;
  dcterms:modified "2026-02-12T08:59:21.725838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-02-12T08:59:21.725842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature generally increases rate by boosting the energy and frequency of collisions between particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cooling a reactant decreases its reaction rate by reducing collision energy and frequency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use models to represent parts of the natural world that are too difficult to observe or explain directly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple ways (models) of drawing/showing bonding."@en ;
  dcterms:modified "2026-02-12T08:59:21.730301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are multiple advantages and limitations of particular representations and models."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a chemical reaction is the molar ratio of each substance in a balanced symbol equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoichiometric values can be calculated using masses found by experiment."@en ;
  dcterms:modified "2026-02-12T08:59:21.732591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subscript values in chemical formula indicate the ratio of atoms/ions in a molecule/formula unit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stoichiometry means ‘measuring elements’, from the Greek 'stoikhein' – meaning element and 'metron' – to measure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations should be interpreted in terms of moles (i.e. 1 mole of this reacts with 2 moles of that)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of each reactant that does react can be worked out from the relative formula masses in the chemical equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-02-12T08:59:21.733732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining the element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their own, or in compound form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical compositions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-02-12T08:59:21.734860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell, and become positive ions (cations)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.734874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the number (e.g. 2+, not +2)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reduction is the gain of electrons, and oxidation is the loss of electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.735334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement reactions are often examples of redox reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.735338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Half equations show which elements are oxidised, and which are reduced."@en ;
  dcterms:modified "2026-02-12T08:59:21.735342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electrons have a relative charge of -1 and roughly a relative mass of 0.0005."@en ;
  dcterms:modified "2026-02-12T08:59:21.735348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge and contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-1
  a curric:KeyLearningPoint ;
  rdfs:label "Isotopes are atoms of the same element with different numbers of neutrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.736188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relative abundances of isotopes can be used to calculate the relative atomic mass (RAM) of an element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mass spectrometry ionises samples to create positive ions for analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.736196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-4
  a curric:KeyLearningPoint ;
  rdfs:label "The M⁺ peak represents the molecular ion, indicating the molecular mass."@en ;
  dcterms:modified "2026-02-12T08:59:21.736200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fragmentation in mass spectrometry helps identify molecular structure by breaking molecules into smaller ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive with other elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-3
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they do not decompose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every atom of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons in atoms of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data can be analysed to assess the purity of water samples containing dissolved solids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation set-ups can be used to collect dissolved solids from a water sample."@en ;
  dcterms:modified "2026-02-12T08:59:21.743144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the RFM of the reactants equals the sum of the RFM of the products, taking account of balancing coefficients."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative mass of 0.0005 (very small)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745148Z"^^xsd:dateTime .

