  dcterms:modified "2026-02-12T08:59:15.795108Z"^^xsd:dateTime .

oakcurric:keyword-uncertainty
  a curric:Keyword ;
  schema:name "uncertainty"@en ;
  schema:description "a situation in which something is not known or certain"@en ;
  dcterms:modified "2026-02-12T08:59:15.795164Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description """Story structure refers to the order of events within a narrative that gives it a coherent and engaging flow."""@en ;
  dcterms:modified "2026-02-12T08:59:15.795619Z"^^xsd:dateTime .

oakcurric:keyword-evaporation
  a curric:Keyword ;
