# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9639-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds, not chemically combined together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged."@en ;
  dcterms:modified "2026-02-12T08:59:21.615984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures."@en ;
  dcterms:modified "2026-02-12T08:59:21.615991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and mixtures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-5
  a curric:KeyLearningPoint ;
  rdfs:label """A formulation is a designed mixture, with each component serving a specific purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH of rain water is naturally below 7."@en ;
  dcterms:modified "2026-02-12T08:59:21.619272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions between certain pollutants and water in the atmosphere may cause a decrease in the pH of rainwater."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-3
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain is not as acidic as vinegar or citric acid that is found in lemons and oranges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain chemically reacts with carbonates that form many rocks to produce a salt, water and carbon dioxide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Acid rain can have long term effects on habitats and ecosystems."@en ;
  dcterms:modified "2026-02-12T08:59:21.619302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-1
  a curric:KeyLearningPoint ;
  rdfs:label "At equilibrium, both reactants and products are formed at the same rate."@en ;
  dcterms:modified "2026-02-12T08:59:21.653588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amounts of reactants and products remain constant at equilibrium."@en ;
  dcterms:modified "2026-02-12T08:59:21.653593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-3
  a curric:KeyLearningPoint ;
  rdfs:label "Equilibrium can only occur in a closed system."@en ;
  dcterms:modified "2026-02-12T08:59:21.653597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-1
  a curric:KeyLearningPoint ;
  rdfs:label """A polymer is a substance of high average relative molecular mass made up of small repeating units."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-2
  a curric:KeyLearningPoint ;
  rdfs:label """In addition polymerisation only one molecule is formed, e.g. addition polymerisation of ethene forms poly(ethene)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers have a specific displayed formula to show repeat units."@en ;
  dcterms:modified "2026-02-12T08:59:21.653699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-4
  a curric:KeyLearningPoint ;
  rdfs:label "A polymer's monomer can be deduced from its structure and vice versa."@en ;
  dcterms:modified "2026-02-12T08:59:21.653706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-5
  a curric:KeyLearningPoint ;
  rdfs:label """Addition polymers can be made by combining together a variety of monomer molecules containing C=C."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-1
  a curric:KeyLearningPoint ;
  rdfs:label "Molecular modelling represents the bonding and structure of substances."@en ;
  dcterms:modified "2026-02-12T08:59:21.653718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way giant covalent structures melt/boil is very different to simple molecules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct electricity, every atom is bonded to another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-4
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite each atom is bonded to three others to form layers of hexagonal rings. Each atom contributes a free electron"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-5
  a curric:KeyLearningPoint ;
  rdfs:label """Simple molecules are held together by intermolecular forces, no chemical bonds hold them together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-1
  a curric:KeyLearningPoint ;
  rdfs:label """An investigation can measure the temperature change through continuous heating of a substance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curve observations are best presented in a table and graphically."@en ;
  dcterms:modified "2026-02-12T08:59:21.654206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reliable data can be collected by taking repeat measurements, identifying anomalies and calculating a mean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curves can be used to determine the melting point of a substance."@en ;
  dcterms:modified "2026-02-12T08:59:21.654216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules), giant covalent, ionic and metallic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it can only hold 2 electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-02-12T08:59:21.654234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or anions, respectfully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-1
  a curric:KeyLearningPoint ;
  rdfs:label """In all chemical reactions, bonds in the reactants need to be broken before the reaction can happen"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-2
  a curric:KeyLearningPoint ;
  rdfs:label "Energy must be supplied to break bonds in the reactants"@en ;
  dcterms:modified "2026-02-12T08:59:21.655463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-3
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is released when bonds in the products are formed"@en ;
  dcterms:modified "2026-02-12T08:59:21.655467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-4
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the energy needed to break bonds and the energy released is the overall energy change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia can be synthesised in the lab by heating a mixture of NH₄Cl and NaOH, producing NH₃ gas and other by-products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is an alkaline gas that reacts readily with water to form a corrosive, basic solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ammonia gas turns moist red litmus paper blue, indicating its alkaline nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.655836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia gas is soluble, toxic, and has a pungent smell, requiring careful handling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia reacts with hydrogen chloride (from concentrated hydrochloric acid) to form white fumes of ammonium chloride."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-1
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers are very large covalent molecules (not giant structures)"@en ;
  dcterms:modified "2026-02-12T08:59:21.655849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-2
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers can be represented by showing repeated units"@en ;
  dcterms:modified "2026-02-12T08:59:21.655854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers consist of repeating and identical sections called monomers"@en ;
  dcterms:modified "2026-02-12T08:59:21.655858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Polymers are solid at room temperature because the intermolecular forces between polymer molecules are relatively strong"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-1
  a curric:KeyLearningPoint ;
  rdfs:label """Catalysts, pressure, temperature & concentration of solutions can affect equilibrium position of a reversible reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the conditions of a reversible reaction are changed, the equilibrium will move to counteract that change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-3
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst increases the rate at which equilibrium is achieved."@en ;
  dcterms:modified "2026-02-12T08:59:21.655876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature increases the rate of both reactions; equilibrium shifts in favour of the endothermic reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the concentration or pressure of a substance increases the rate of reaction; equilibrium shifts in response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dot and cross diagrams as a model for binary ionic substances"@en ;
  dcterms:modified "2026-02-12T08:59:21.656665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dot and cross diagrams show the empirical formula/ratio of atoms to show how electrons are transferred"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ions are shown with full outer shells, square brackets, and a charge in the top right corner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds are neutral overall, so positive and negative charge must balance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-5
  a curric:KeyLearningPoint ;
  rdfs:label """When positive ions do not have the same magnitude of charge as negative ions, multiple of some ions will be required."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon atoms will form up to four covalent bonds (as they will fill their outer shell with four more electrons)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon atoms can combine with other non-metal atoms to make a wide range of molecules, some with chains and rings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-3
  a curric:KeyLearningPoint ;
  rdfs:label "An organic compound contains two or more elements (including carbon)."@en ;
  dcterms:modified "2026-02-12T08:59:21.657886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-4
  a curric:KeyLearningPoint ;
  rdfs:label "A lot of organic compounds also include hydrogen, oxygen and nitrogen."@en ;
  dcterms:modified "2026-02-12T08:59:21.657893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-5
  a curric:KeyLearningPoint ;
  rdfs:label "Organic compounds can be found both in nature, but also produced synthetically."@en ;
  dcterms:modified "2026-02-12T08:59:21.657897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-1
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is ordered by increasing atomic number (proton number)."@en ;
  dcterms:modified "2026-02-12T08:59:21.658586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-2
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is split into periods and groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.658592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-3
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an element in the periodic table is linked to its atomic number and the arrangement of its electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elements can be classed as metals or non-metals according to their position on the periodic table."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-5
  a curric:KeyLearningPoint ;
  rdfs:label "A useful model for atoms arranges electrons in shells around the nucleus."@en ;
  dcterms:modified "2026-02-12T08:59:21.658607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-1
  a curric:KeyLearningPoint ;
  rdfs:label """The ozone layer protects life from harmful ultraviolet (UV) radiation from the Sun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chlorofluorocarbons (CFCs) were once used, and when they entered our atmosphere reacted with ozone (O₃)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ozone levels decreased, but scientific communication led to action being taken to prevent further loss of ozone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-4
  a curric:KeyLearningPoint ;
  rdfs:label "The work of analytical scientists suggests the ozone layer is now reforming."@en ;
  dcterms:modified "2026-02-12T08:59:21.658909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-1
  a curric:KeyLearningPoint ;
  rdfs:label "Calorimetry can be used to measure a reaction's energy change indirectly."@en ;
  dcterms:modified "2026-02-12T08:59:21.660645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calorimetry data can be used to calculate the mass of alcohol needed to cause a 1°C rise in temperature of the water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-3
  a curric:KeyLearningPoint ;
  rdfs:label """An alcohol that causes a 1°C temperature rise when the least amount is combusted is releasing the most energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy change of combustion for a variety of alcohols can be compared to the molecular formula of each alcohol."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal oxide with an appropriate acid can form a desired salt and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding metal oxide to excess ensures that the acid fully reacts to form salt and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Excess metal oxide can be removed by filtration so that the filtrate contains only salt and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be removed from the salt by evaporation."@en ;
  dcterms:modified "2026-02-12T08:59:21.665582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reactions of an alkene happen at its functional group, C=C."@en ;
  dcterms:modified "2026-02-12T08:59:21.665587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reactions of an alkene change it from an unsaturated to a saturated molecule."@en ;
  dcterms:modified "2026-02-12T08:59:21.665591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-3
  a curric:KeyLearningPoint ;
  rdfs:label "Larger alkenes have higher boiling points and are less flammable."@en ;
  dcterms:modified "2026-02-12T08:59:21.665598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-4
  a curric:KeyLearningPoint ;
  rdfs:label "Alkenes tend to burn with smoky flames due to incomplete combustion."@en ;
  dcterms:modified "2026-02-12T08:59:21.665605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-5
  a curric:KeyLearningPoint ;
  rdfs:label """Isomers are structures with the same molecular formula, but different arrangement of atoms in space."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-1
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is ordered by increasing atomic number (proton number)."@en ;
  dcterms:modified "2026-02-12T08:59:21.667581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-2
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is split into periods and groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.667587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-3
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an element in the periodic table is linked to its atomic number and the arrangement of its electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elements can be classed as metals or non-metals according to their position on the periodic table."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-5
  a curric:KeyLearningPoint ;
  rdfs:label "A useful model for atoms arranges electrons in shells around the nucleus."@en ;
  dcterms:modified "2026-02-12T08:59:21.667607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration is a technique used to separate insoluble substances from a mixture with a liquid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Separation in filtration occurs due to the difference in size of particles."@en ;
  dcterms:modified "2026-02-12T08:59:21.672137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-3
  a curric:KeyLearningPoint ;
  rdfs:label """The terms 'filtrate' and 'residue' describe the components separated by the process of filtration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-02-12T08:59:21.672237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of that element measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules), giant covalent, ionic and metallic"""@en ;
  dcterms:modified "2026-02-12T08:59:21.672670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it can only hold 2 electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-02-12T08:59:21.672687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or anions, respectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used to separate substances in a mixture of inks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inks are a mixture of substances that can be separated using distillation."@en ;
  dcterms:modified "2026-02-12T08:59:21.673497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-3
  a curric:KeyLearningPoint ;
  rdfs:label "Care should be taken when heating substances to their boiling points."@en ;
  dcterms:modified "2026-02-12T08:59:21.673502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simple distillation completed in the school lab has limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.673509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every atom of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons in atoms of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Salts form ionic structures because they contain metal and non-metal ions."@en ;
  dcterms:modified "2026-02-12T08:59:21.674543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-2
  a curric:KeyLearningPoint ;
  rdfs:label """In an ionic structure each positive ion attracts the negative ions and vice-versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metal ions attract all non-metal ions and vice-versa, they bond to the opposite charged ions that are closest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-4
  a curric:KeyLearningPoint ;
  rdfs:label """An ionic bond is the electrostatic force of attraction between oppositely-charged ions acting in all directions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic substances are 3D lattices with regular arrangements of ions ( in a repeating pattern of +ve and -ve charge)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring volume of gas produced throughout a reaction allows the changing rate of reaction to be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring volumes of gas over time include timing, reading volumes in real time and gas displaced by the bung."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring an end-point in a reaction allows direct and simple comparison of reaction rates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-4
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring end-points include subjectivity of observations, measuring times and volumes, and contamination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-1
  a curric:KeyLearningPoint ;
  rdfs:label """Production processes for industrial materials are under continuous development, with new materials discovered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-2
  a curric:KeyLearningPoint ;
  rdfs:label """Several factors direct a choice of materials: performance, production processes, cost, aesthetics, and others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composites are mixtures of materials made up of a matrix and a reinforcement."@en ;
  dcterms:modified "2026-02-12T08:59:21.674714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-4
  a curric:KeyLearningPoint ;
  rdfs:label """Qualitative data describes properties, while quantitative data measures properties numerically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different types of bonding (covalent, ionic, metallic)."@en ;
  dcterms:modified "2026-02-12T08:59:21.674787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are only two types of structure (simple and giant)."@en ;
  dcterms:modified "2026-02-12T08:59:21.674792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-3
  a curric:KeyLearningPoint ;
  rdfs:label "The type of bonding and structure are what lead to properties of substances."@en ;
  dcterms:modified "2026-02-12T08:59:21.674797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting/boiling points are linked to intermolecular forces (simple) and bond strength (giant)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conductivity is linked to whether there are free moving charge carriers."@en ;
  dcterms:modified "2026-02-12T08:59:21.674808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base is a substance that neutralises an acid to make salt and water only (this is a neutralisation reaction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroxides are generally soluble bases (they contain OH⁻ ions)."@en ;
  dcterms:modified "2026-02-12T08:59:21.675926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases that are generally insoluble."@en ;
  dcterms:modified "2026-02-12T08:59:21.675930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides are soluble and form acidic solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.675935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Purification of copper involves using copper electrodes in an electrolyte."@en ;
  dcterms:modified "2026-02-12T08:59:21.675958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The electrolyte must contain the same ions, in solution,  as the metal being purified by electrolysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring the mass change in the copper electrodes demonstrates the transfer of copper."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-4
  a curric:KeyLearningPoint ;
  rdfs:label """Impurities in the anode do not transfer to the cathode, leading to pure copper deposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other uses for this technique include electroplating, where you would use multiple metals e.g. gold."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many sources of wastewater and each introduces different types of contaminants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are sequential steps involved in making wastewater safe before disposal into the environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple types of waste need to be removed from different kinds of wastewater."@en ;
  dcterms:modified "2026-02-12T08:59:21.675993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Releasing untreated wastewater into the environment could impact an ecosystem's health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sludge can be anaerobically treated, producing materials that can be used as a fertiliser or fuel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple particle model explains melting, boiling, freezing, and condensing processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Boiling is when a liquid becomes a gas throughout, forming bubbles. Condensation is when gas turns into liquid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Melting is when a solid turns into a liquid with added energy. Freezing is the reverse: liquid to solid, losing energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particles remain the same size and shape as they do not have bulk properties like melting and boiling points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil have different properties and uses, affecting the demand for these molecules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-2
  a curric:KeyLearningPoint ;
  rdfs:label """Larger hydrocarbons can be broken down (cracked) to produce smaller, more useful molecules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cracking can be done by various methods including catalytic cracking and steam cracking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-4
  a curric:KeyLearningPoint ;
  rdfs:label """The products of cracking include alkanes and alkenes, which have a double bond between two carbon atoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bromine water changes from orange/brown to colourless in the presence of an alkene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of volume of gas produced against time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid, the same volume of gas is produced for equal amounts of magnesium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-3
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling the concentration doubles the rate of reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.676282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electric cells contain a store of chemicals that react to produce a voltage across two electrical contacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric cell made of two different metals in contact with an electrolyte, produces a voltage across the metals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of voltage across an electric cell depends on the materials it is made from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-4
  a curric:KeyLearningPoint ;
  rdfs:label """A battery is made of one or more electric cells, which can be connected in series to produce a larger voltage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-5
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical reaction in a rechargeable battery is reversed when an external voltage is connected across it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms are the building blocks that can be combined in different ways to form different substances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible for any atom to be changed into a different type of atom by a chemical reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-3
  a curric:KeyLearningPoint ;
  rdfs:label """All of the atoms in the reactants of a chemical reaction are reorganised to form all of the products of the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to make a particular product without all the atoms that it needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-5
  a curric:KeyLearningPoint ;
  rdfs:label """The law of conservation of mass can be applied to a closed system, or a non-enclosed system that takes in/gives out gas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-1
  a curric:KeyLearningPoint ;
  rdfs:label """The reaction between sodium thiosulfate solution and hydrochloric acid produces a cloudy precipitate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, each reaction has produced the same amount of product."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, the chemical reaction may not be complete."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue Bunsen flame."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-02-12T08:59:21.677380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and identifying elements and compounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-02-12T08:59:21.677389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the concentration of each."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most chemical reactions start more quickly and slow down as they progress."@en ;
  dcterms:modified "2026-02-12T08:59:21.677398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a chemical reaction is equal to the amount of product formed per unit time (or reactant used per unit time)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mean rate of a chemical reaction is different to the instantaneous rate that changes throughout the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphs of mass, volume, or concentration vs. time can all represent the changing rate of a chemical reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the correct equipment is crucial for obtaining accurate and reliable results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-2
  a curric:KeyLearningPoint ;
  rdfs:label """An upturned measuring cylinder is suitable for reactions producing large volumes of gas at moderate rates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gas syringes are ideal for measuring small volumes of gas with high precision."@en ;
  dcterms:modified "2026-02-12T08:59:21.677464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of the measuring equipment should be close to the expected volume of gas produced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Light sensors can be used to measure the percentage of light transmitted through a reaction producing a precipitate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation is the change from solid to gas; deposition is the change from gas to solid, both bypass the liquid state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation and deposition occur at specific conditions of temperature and pressure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy changes in sublimation/deposition are similar to melting/freezing but happen directly between solid and gas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaporation is when a liquid changes to gas at the surface as particles gain enough energy to overcome forces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatography has two phases, stationary and mobile, and separation depends on the distribution between these phases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-2
  a curric:KeyLearningPoint ;
  rdfs:label "Both aqueous and non-aqueous solvents can be used in chromatography."@en ;
  dcterms:modified "2026-02-12T08:59:21.677501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-02-12T08:59:21.677506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction the desired product needs to be continuously removed from the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Natural gas is a feedstock for industrial production of ammonia."@en ;
  dcterms:modified "2026-02-12T08:59:21.677515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen, one of the raw materials in ammonia production, is produced from natural gas and steam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-4
  a curric:KeyLearningPoint ;
  rdfs:label """In industry, the Haber process is typically performed at 150-300 atmospheres, 400-450°C, with an iron catalyst."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia production is energy-intensive and releases large amounts of carbon dioxide, contributing to global emissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-1
  a curric:KeyLearningPoint ;
  rdfs:label "Metals are good electrical conductors and good thermal conductors."@en ;
  dcterms:modified "2026-02-12T08:59:21.678771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metals can be stretched into wires, or bent/hammered into different shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.678776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Individual atoms do not have the physical properties of the substances that contain them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metallic structures consist of positive ions and free–moving outer shell electrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electrostatic forces of attraction between ions and free electrons bind them all together in a giant metallic structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-1
  a curric:KeyLearningPoint ;
  rdfs:label "Iron is alloyed with other metals to produce steel alloys."@en ;
  dcterms:modified "2026-02-12T08:59:21.678794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-2
  a curric:KeyLearningPoint ;
  rdfs:label "Copper is alloyed with other metals to make multiple useful alloys."@en ;
  dcterms:modified "2026-02-12T08:59:21.678799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gold, aluminium, and magnesium all form useful alloys with other metals."@en ;
  dcterms:modified "2026-02-12T08:59:21.678803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation separates a soluble substance from its solvent based on differences in boiling points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-2
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation requires multiple pieces of apparatus which work in conjunction with each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-3
  a curric:KeyLearningPoint ;
  rdfs:label """The processes of boiling and condensing are involved in the process of distillation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-4
  a curric:KeyLearningPoint ;
  rdfs:label """Simple distillation is used primarily to separate mixtures of only two components."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carboxylic acids have a -COOH functional group."@en ;
  dcterms:modified "2026-02-12T08:59:21.678826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carboxylic acids are weak acids."@en ;
  dcterms:modified "2026-02-12T08:59:21.678831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-3
  a curric:KeyLearningPoint ;
  rdfs:label "When ethanol is oxidised, ethanoic acid is formed."@en ;
  dcterms:modified "2026-02-12T08:59:21.678838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carboxylic acids react with carbonates to produce a metal salt, carbon dioxide and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carboxylic acid can react with alcohol to produce esters (such as ethyl ethanoate)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of a solution is the mass of solute dissolved in 1 dm³ of distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more solute that is dissolved, the more concentrated the solution."@en ;
  dcterms:modified "2026-02-12T08:59:21.678860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solutions can be diluted (i.e. made less concentrated) by increasing the volume of distilled water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-4
  a curric:KeyLearningPoint ;
  rdfs:label """Diluting solutions with distilled water ensures no other substances are present in the solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.678876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three states of matter: solid state, liquid state, and gas state."@en ;
  dcterms:modified "2026-02-12T08:59:21.678881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-2
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas state can be compressed because there is empty space between the particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-3
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the liquid or solid state cannot be compressed because the particles are already touching."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-4
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas or liquid state has no fixed shape as the particles can move past each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-5
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the solid state will not flow because the particles vibrate in a fixed position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation is an extension of simple distillation, and is mostly used to separate mixtures of liquids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-2
  a curric:KeyLearningPoint ;
  rdfs:label """A main distinction between fractional and simple distillation is that the former uses a fractionating column."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation has multiple real-world examples, including the fractional distillation of air."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation produces fractions; these can be pure or mixtures of chemicals with very similar boiling points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid ionic compound cannot conduct electricity."@en ;
  dcterms:modified "2026-02-12T08:59:21.679585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are ionic compounds which can be electrolysed when they are in the molten state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gases may be formed at the electrodes."@en ;
  dcterms:modified "2026-02-12T08:59:21.679594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-4
  a curric:KeyLearningPoint ;
  rdfs:label "Freely moving ions can reach the electrodes and undergo oxidation or reduction."@en ;
  dcterms:modified "2026-02-12T08:59:21.679599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-5
  a curric:KeyLearningPoint ;
  rdfs:label """A non-metal always forms at the positive electrode, and a metal forms at the negative electrode."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same material."@en ;
  dcterms:modified "2026-02-12T08:59:21.680145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-02-12T08:59:21.680149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-02-12T08:59:21.680154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration and sterilisation are used to obtain potable water from groundwater and fresh water sources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of sea water creates potable water by distillation or reverse osmosis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds not chemically combined together"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged"@en ;
  dcterms:modified "2026-02-12T08:59:21.680307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures"@en ;
  dcterms:modified "2026-02-12T08:59:21.680312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and mixtures"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pH of water samples can be determined using appropriate methods and/or instruments e.g pH meter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH data can be analysed to assess if water contains impurities."@en ;
  dcterms:modified "2026-02-12T08:59:21.680326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different substances dissolve in different types of water."@en ;
  dcterms:modified "2026-02-12T08:59:21.680330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-4
  a curric:KeyLearningPoint ;
  rdfs:label """The substances that dissolve in different waters can affect the water's acidity or alkalinity (i.e. its pH)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water is necessary for laboratory tests; it must be neutral (i.e. pH 7)."@en ;
  dcterms:modified "2026-02-12T08:59:21.680339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation is a technique that is used to separate a soluble solute from a solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation involves the formation of a saturated solution and temperature differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Crystallisation results in the loss of the solvent to the surroundings."@en ;
  dcterms:modified "2026-02-12T08:59:21.680353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-1
  a curric:KeyLearningPoint ;
  rdfs:label """An experiment can be planned to measure the temperature change through continuous heating of a substance"""@en ;
  dcterms:modified "2026-02-12T08:59:21.683685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is needed to overcome forces of attraction between particles so temperature does not change when changing state"""@en ;
  dcterms:modified "2026-02-12T08:59:21.683689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-3
  a curric:KeyLearningPoint ;
  rdfs:label """The change in state of pure substances can be seen on a heating/cooling curve as a horizontal line"""@en ;
  dcterms:modified "2026-02-12T08:59:21.683694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is a change of energy, arrangement, and organisation of particles of a pure substance at each stage"""@en ;
  dcterms:modified "2026-02-12T08:59:21.683698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-1
  a curric:KeyLearningPoint ;
  rdfs:label """A reaction profile compares the amount of energy the products of a reaction have compared to the reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exothermic chemical reactions transfer energy from reactants to the surroundings causing an increase in temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Endothermic chemical reactions transfer energy from the surroundings to the products causing a decrease in temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Activation energy is the minimum amount of energy transferred to reactants that allows a chemical reaction to start."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-02-12T08:59:21.684237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of that element measured in grams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-02-12T08:59:21.684259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated similar properties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into groups of similar properties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were later found."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by atomic weight was not always correct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equal amounts in moles of gases occupy the same volume under the same conditions of temperature and pressure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1 atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volumes of gaseous reactants and products can be calculated from the balanced equation for the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-4
  a curric:KeyLearningPoint ;
  rdfs:label """If moles of gas are known, its density can be calculated using molar gas volume and the relationship mass = RFM x moles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-1
  a curric:KeyLearningPoint ;
  rdfs:label "Crude oil is a non-renewable mixture of different hydrocarbons and impurities."@en ;
  dcterms:modified "2026-02-12T08:59:21.684305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crude oil can be separated into groups of hydrocarbon molecules of similar size, called fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the hydrocarbon molecules in crude oil are alkanes."@en ;
  dcterms:modified "2026-02-12T08:59:21.684317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller hydrocarbon molecules have lower boiling points, are more flammable, and are less viscous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil include petroleum gases, petrol, kerosene, diesel oil, heavy fuel oil, and bitumen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-1
  a curric:KeyLearningPoint ;
  rdfs:label """In an ideal chemical reaction, all atoms in the reactants would end up in useful products, with no waste."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theoretical yield of a chemical reaction can be calculated from the reaction equation alone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-3
  a curric:KeyLearningPoint ;
  rdfs:label "The percentage yield shows how actual yield compares with theoretical yield."@en ;
  dcterms:modified "2026-02-12T08:59:21.684413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atom economy is a measure of the efficiency with which a reaction uses its reactants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many factors will be considered when choosing a reaction pathway."@en ;
  dcterms:modified "2026-02-12T08:59:21.684422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of positive ions are in competition at the negative electrode (cathode)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of negative ions are in competition at the positive electrode (anode)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode."@en ;
  dcterms:modified "2026-02-12T08:59:21.684715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested."@en ;
  dcterms:modified "2026-02-12T08:59:21.684719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrogen may be formed at the cathode"@en ;
  dcterms:modified "2026-02-12T08:59:21.684726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hazard symbols provide vital safety information about chemical substances."@en ;
  dcterms:modified "2026-02-12T08:59:21.685753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Correct identification of hazard symbols is crucial for laboratory safety."@en ;
  dcterms:modified "2026-02-12T08:59:21.685757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correctly choosing and using appropriate lab equipment is essential for conducting experiments safely and accurately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-4
  a curric:KeyLearningPoint ;
  rdfs:label """Risk assessments identify potential hazards & outline how to minimise risk; these can be general & specific precautions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-5
  a curric:KeyLearningPoint ;
  rdfs:label """Safety protocols, like wearing eye protection and ensuring good ventilation, are essential when working with hazards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-1
  a curric:KeyLearningPoint ;
  rdfs:label "Balanced symbol equations can be written for the combustion of alcohols."@en ;
  dcterms:modified "2026-02-12T08:59:21.685800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is difficult to measure directly the energy change of a reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.685805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Calorimetry can be used to measure a reaction's energy change indirectly."@en ;
  dcterms:modified "2026-02-12T08:59:21.685809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-1
  a curric:KeyLearningPoint ;
  rdfs:label "A salt is formed when an acid neutralises a base."@en ;
  dcterms:modified "2026-02-12T08:59:21.685997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are giant, 3D ionic structures that form crystals with regular arrangements of ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-3
  a curric:KeyLearningPoint ;
  rdfs:label """The empirical chemical formula of a salt provides the ratio of metal to non-metal ions it contains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acids contain aqueous hydrogen ions, H⁺(aq) and alkalis contain aqueous hydroxide ions, OH⁻(aq)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-5
  a curric:KeyLearningPoint ;
  rdfs:label "During a neutralisation reaction: H⁺(aq) + OH⁻(aq) → H₂O(l)."@en ;
  dcterms:modified "2026-02-12T08:59:21.686018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a titration, a trial investigation helps estimate the amount of acid needed to neutralise the alkali."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-2
  a curric:KeyLearningPoint ;
  rdfs:label """Near the end point, add the acid drop by drop whilst swirling the solution in the conical flask to mix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Placing a white tile under the conical flask enhances the visibility of the colour change and accuracy of readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-4
  a curric:KeyLearningPoint ;
  rdfs:label "Volume readings should be taken at eye level from the bottom of the meniscus."@en ;
  dcterms:modified "2026-02-12T08:59:21.686070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-5
  a curric:KeyLearningPoint ;
  rdfs:label "Concordant titres are typically within ±0.10 cm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.686074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-1
  a curric:KeyLearningPoint ;
  rdfs:label "Typical atomic radii, and bond length, are in the order of 10⁻¹⁰m."@en ;
  dcterms:modified "2026-02-12T08:59:21.686201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal elements and non-metal compounds form covalent structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.686209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple covalent substances have no free moving charge carriers so cannot conduct electricity (some giant covalent can)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Small molecules are usually gases or liquids with relatively low melting and boiling points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-5
  a curric:KeyLearningPoint ;
  rdfs:label """Giant covalent structures have high melting/boiling points because strong covalent bonds need to be broken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis involves the decomposition / break-down of a substance by passing an electric current."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of positive ions are in competition at the negative electrode"@en ;
  dcterms:modified "2026-02-12T08:59:21.686445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of negative ions are in competition at the positive electrode"@en ;
  dcterms:modified "2026-02-12T08:59:21.686450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode"@en ;
  dcterms:modified "2026-02-12T08:59:21.686454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested"@en ;
  dcterms:modified "2026-02-12T08:59:21.686459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations are most correctly interpreted in terms of molar ratios (i.e. 1 mole of A reacts with 2 moles of B)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The molar ratios of the substances in a chemical reaction is known as stoichiometry, which means ‘measuring elements’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a reaction is shown by coefficients in a balanced equation. These molar relationships don't change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-5
  a curric:KeyLearningPoint ;
  rdfs:label """The moles of substance in a reaction can be determined using: mass(g) = Mr  × moles (& the stoichiometry of reaction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrocarbons are simple covalent compounds made of hydrogen and carbon atoms only."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrocarbons are found in crude oil, and are used as fuels and feedstock."@en ;
  dcterms:modified "2026-02-12T08:59:21.686591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes consist of chains, or rings, of carbon atoms that are each also bonded to hydrogen atoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes are a homologous series of hydrocarbons, with the same general formula with a trend in properties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-5
  a curric:KeyLearningPoint ;
  rdfs:label "The general formula for an alkane is CnH2n+2."@en ;
  dcterms:modified "2026-02-12T08:59:21.686604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of reactants in a chemical reaction can react together if they collide with sufficient energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing surface area of a solid lets more reacting particles in a solution collide with its particles each second."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature of reactants increases the speed of particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing pressure of reacting gases pushes reactant particles closer together, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-1
  a curric:KeyLearningPoint ;
  rdfs:label "Condensation polymerisation requires monomers with two functional groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.688324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-2
  a curric:KeyLearningPoint ;
  rdfs:label "Condensation polymers can be made of two different monomers."@en ;
  dcterms:modified "2026-02-12T08:59:21.688328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-3
  a curric:KeyLearningPoint ;
  rdfs:label """A polyester is formed by reaction of a monomer with two carboxylic acid groups with a monomer with two alcohol groups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-4
  a curric:KeyLearningPoint ;
  rdfs:label """In condensation polymerisation as well as the polymer a small molecule is formed, usually water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-5
  a curric:KeyLearningPoint ;
  rdfs:label """Amino acids contain two functional groups and can form polypeptides and proteins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change; physical and chemical, and the physical state of a substance can be predicted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-3
  a curric:KeyLearningPoint ;
  rdfs:label """The attraction between particles has a role in determining the amount of energy needed for state changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particle model has limitations, for example by showing particles as same sized, inelastic spheres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-5
  a curric:KeyLearningPoint ;
  rdfs:label """The model does not show the attraction between the particles which affects the amount of energy needed to change state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aluminium is above carbon in the reactivity series and can therefore not be extracted with carbon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Impurities are removed from the bauxite ore at the start."@en ;
  dcterms:modified "2026-02-12T08:59:21.688400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cryolite acts as a solvent and allows the electrolysis to take place at a lower temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon electrodes need to be continuously replaced as they react with oxygen as it is produced, forming carbon dioxide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is an expensive process as it requires large amounts of energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.688414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphene is a single layer of graphite, is very strong and conducts electricity."@en ;
  dcterms:modified "2026-02-12T08:59:21.688418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fullerenes are molecules of carbon with hollow shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.688423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of fullerenes is based on hexagonal rings of carbon atoms, or on carbon rings of five or seven atoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-4
  a curric:KeyLearningPoint ;
  rdfs:label "A Buckminsterfullerene is a spherical fullerene of sixty carbon atoms (C₆₀)."@en ;
  dcterms:modified "2026-02-12T08:59:21.688432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-5
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon nanotube is a tube of graphene that is very long compared to its diameter and has a high tensile strength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to avoid false positives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to a solution containing them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution containing sulfate ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early volcanic activity is thought to have made an atmosphere of carbon dioxide and nitrogen billions of years ago."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can dissolve in oceans and form carbonates that, over millions of years, can form sedimentary rock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-3
  a curric:KeyLearningPoint ;
  rdfs:label """The amount of carbon dioxide was reduced by the formation of sedimentary rocks and photosynthesis by algae and plants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-4
  a curric:KeyLearningPoint ;
  rdfs:label """Algae and plants produced the oxygen that is now in the atmosphere by photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-5
  a curric:KeyLearningPoint ;
  rdfs:label """Phytoplankton in the oceans are responsible for roughly half of all oxygen production that takes place today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-1
  a curric:KeyLearningPoint ;
  rdfs:label """In pure metals, ions are arranged in a regular structure with delocalised electrons between them"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a metal is stretched or forced out of shape, its ions are able to move position without the metallic bonds breaking"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-3
  a curric:KeyLearningPoint ;
  rdfs:label """An alloy is a mixture of different metal elements or of metals with non metal elements (i.e. carbon)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ions of different metal elements may be different sizes and have different electrical charges"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-5
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of an alloy is not as regular as a pure metal and this affects its properties"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-1
  a curric:KeyLearningPoint ;
  rdfs:label """When powdered hydroxide/oxide (base) is added to an acidic solution there is an increase in pH."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH changes quickly around the neutralisation point."@en ;
  dcterms:modified "2026-02-12T08:59:21.689284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indicators, such as Universal Indicator paper, can be used to collect quantitative data on pH."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-4
  a curric:KeyLearningPoint ;
  rdfs:label """pH can be plotted on a graph to find the quantity of base required to neutralise an acid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-1
  a curric:KeyLearningPoint ;
  rdfs:label """pH is a logarithmic scale (as hydrogen ion concentration increases by a factor of 10, the pH decreases by 1)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-2
  a curric:KeyLearningPoint ;
  rdfs:label "For a given concentration, a stronger acid contains more H⁺ ions."@en ;
  dcterms:modified "2026-02-12T08:59:21.691469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-3
  a curric:KeyLearningPoint ;
  rdfs:label """Titration curves can be used to show the change in pH to allow chemists to pinpoint a more accurate end point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong acid is completely ionised in aqueous solution, a weak acid only partially ionises."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Titration curves show how the pH changes throughout a neutralisation reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.691485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can identify unknown substances through comparison or Rf values."@en ;
  dcterms:modified "2026-02-12T08:59:21.691489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used during comparisons, and calculations should consider significant figures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair comparison of chromatograms depends on stationary and mobile phase choices, sample concentration and temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-4
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-02-12T08:59:21.691503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue Bunsen flame."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and identifying elements and compounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-02-12T08:59:21.691844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-02-12T08:59:21.691848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the concentration of each."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive with other elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 0 elements density and boiling points increase."@en ;
  dcterms:modified "2026-02-12T08:59:21.693052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they do not decompose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points increase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just full electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance of each shell from the nucleus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-02-12T08:59:21.693079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the lab."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density & particles is fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-02-12T08:59:21.693171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce uncertainty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes milli-, micro-, nano-, and pico-, in this order, subdivide a metre into smaller and smaller divisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nanoparticles are 1-100 nm in size, and are larger than atoms and molecules."@en ;
  dcterms:modified "2026-02-12T08:59:21.693265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-3
  a curric:KeyLearningPoint ;
  rdfs:label "The smaller a particle, the bigger its surface area to volume ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.693272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nanotubes are very small and extremely strong fibres that are thermal and electrical conductors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nanoparticles have many applications; new applications for nanoparticulate materials are an important area of research."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-1
  a curric:KeyLearningPoint ;
  rdfs:label """Neutralisation reactions involve an acid reacting with a base to form salt and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-02-12T08:59:21.693291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methods must be detailed and replicable for reliable data collection."@en ;
  dcterms:modified "2026-02-12T08:59:21.693296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-4
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to calculate energy change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-5
  a curric:KeyLearningPoint ;
  rdfs:label """Line graphs can illustrate relationships between continuous variables in experiments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points increase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just full electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance of each shell from the nucleus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-02-12T08:59:21.693547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to avoid false positives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to a solution containing them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution containing sulfate ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-1
  a curric:KeyLearningPoint ;
  rdfs:label """An empirical formula is the simplest whole number ratio of atoms of each element in a compound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formula of an ionic compound is an empirical formula, as there is no definite quantity of each ion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic compounds ending with \"–ide\" only contain a metal and a non–metal ion."@en ;
  dcterms:modified "2026-02-12T08:59:21.695155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polyatomic ions are ions that are made up of more than one type of atom."@en ;
  dcterms:modified "2026-02-12T08:59:21.695160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds ending with "–ate" always contain at least three elements, one of which is oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis: the process in which an electrolyte is broken down by electricity; it's not a physical separation method."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cathode is the negative electrode, where positive particles gain electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.695249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-3
  a curric:KeyLearningPoint ;
  rdfs:label "The anode is the positive electrode, where negative particles lose electrons."@en ;
  dcterms:modified "2026-02-12T08:59:21.695256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electrolyte contains freely moving ions, and these are attracted to the charged electrodes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis allowed Davy and Faraday to make their scientific discoveries."@en ;
  dcterms:modified "2026-02-12T08:59:21.695265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-1
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1 atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting mass calculations can use a combination of mass to volume calculations and vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-3
  a curric:KeyLearningPoint ;
  rdfs:label "Amount of substance (moles) can be calculated using multiple equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.695279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-4
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation for calculating moles depends on the context of the problem or calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a list of general rules which describe the solubility of common types of substances in water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reactions that form insoluble products are called precipitation reactions; the solids formed are called the precipitate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-3
  a curric:KeyLearningPoint ;
  rdfs:label """When two soluble salts are mixed together, sometimes they will rearrange to create an insoluble salt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-4
  a curric:KeyLearningPoint ;
  rdfs:label """Solubility rules can be used to identify which two solutions are needed to mix in order to create an insoluble salt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists discovered and isolated fullerenes accidentally, which led to exciting new possibilities in chemistry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-2
  a curric:KeyLearningPoint ;
  rdfs:label """Research into the allotropes of carbon is an important part of chemistry's history, earning multiple Nobel Prizes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphene is so thin that it's nearly transparent, allowing most light to pass through."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fullerenes, nanotubes, and graphene have a wide range of real-world uses in fields like electronics and medicine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific discoveries have the power to change the world, even if their significance takes time to be fully understood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-1
  a curric:KeyLearningPoint ;
  rdfs:label "To make a product, raw materials need to be obtained and processed."@en ;
  dcterms:modified "2026-02-12T08:59:21.698407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-2
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the people who benefit from each stage of a product’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-3
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the costs to individuals or the environment at each stage of a product’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of its useful life a product can be repaired, recycled, incinerated or thrown away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-5
  a curric:KeyLearningPoint ;
  rdfs:label """LCAs are often subjective, so it is important to consider the vested interests of those reporting on their findings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative atomic mass of 1/1835 (negligible)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation & relevant mathematical relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added in excess, not all of it will react and some will be found in the final product mixture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from the available particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-1
  a curric:KeyLearningPoint ;
  rdfs:label """metal + acid ⭢ salt + hydrogen; metal carbonate + acid → salt + water + carbon dioxide"""@en ;
  dcterms:modified "2026-02-12T08:59:21.699199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-2
  a curric:KeyLearningPoint ;
  rdfs:label """The test for hydrogen gas is to introduce a lighted splint, which will make a squeaky pop in hydrogen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-3
  a curric:KeyLearningPoint ;
  rdfs:label "The name of a salt formed is dependent on the acid used."@en ;
  dcterms:modified "2026-02-12T08:59:21.699208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-4
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g), (aq) in chemical equations identify the state of substances as solid, liquid, gas or in aqueous solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be bubbled through limewater, which turns cloudy (test for CO₂)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-1
  a curric:KeyLearningPoint ;
  rdfs:label """A 'pure substance' in chemistry is a single element or compound not mixed with any other substance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-2
  a curric:KeyLearningPoint ;
  rdfs:label "The definition of 'pure' means something different in its everyday usage."@en ;
  dcterms:modified "2026-02-12T08:59:21.699263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pure elements and compounds have specific melting and boiling points."@en ;
  dcterms:modified "2026-02-12T08:59:21.699268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to recognise substances with specific melting points as pure substances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing average global temperatures leads to an increase in sea levels."@en ;
  dcterms:modified "2026-02-12T08:59:21.699305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures cause more powerful convection currents, increasing the number and severity of storms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures can affect atmospheric air streams and change weather patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes of human behaviour can lead to smaller increases in global temperature."@en ;
  dcterms:modified "2026-02-12T08:59:21.699318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate engineering may enable humans to reduce global temperatures through the application of technologies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-1
  a curric:KeyLearningPoint ;
  rdfs:label """In diamond each carbon atom is bonded to four others with strong covalent bonds to form a giant covalent structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct electricity (makes it good for cutting tools)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-3
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite, each carbon atom is covalently bonded to three others to form layers of hexagonal rings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are only weak forces between the layers in graphite which can easily be rubbed apart (makes it a good lubricant)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-5
  a curric:KeyLearningPoint ;
  rdfs:label """Graphite conducts electricity because it has delocalised electrons which can move and carry charge/current."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paper, thin layer (TLC), and gas chromatography (GC) can all distinguish between pure and impure substances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatographic processes use a mobile and stationary phase. TLC and GC both use silica/alumina as a stationary phase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thin layer chromatography (TLC) uses locating agents to develop chromatograms and aid analysis of them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms from gas chromatography (GC) also provide details about the amount of each component in a sample."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-5
  a curric:KeyLearningPoint ;
  rdfs:label """Retention factors (Rf) and retention times both provide quantitative information about a sample's components."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-1
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in heat energy accompany salts dissolving in water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in heat energy accompany neutralisation, displacement and precipitation reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic and endothermic reactions have everyday uses."@en ;
  dcterms:modified "2026-02-12T08:59:21.700313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reactions take place in solution, temperature changes can be measured to reflect the energy changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-1
  a curric:KeyLearningPoint ;
  rdfs:label """The energy needed to break bonds and the energy released when bonds are formed can be calculated from bond energies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the energy needed to break bonds and the energy released is the overall energy change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans use Earth’s natural resources for most of our material needs."@en ;
  dcterms:modified "2026-02-12T08:59:21.700331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Finite resources exist in limited quantities and will run out because we use them quicker than they can be regenerated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Synthetic products such as plastic and glass are made by humans using natural resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable development meets our needs without compromising the ability of future generations to meet their own needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of renewable resources, and the reuse and recycling of products, are sustainable development strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a giant ionic structure there are strong electrostatic forces in all directions between oppositely charged particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds have high melting points and high boiling points because strong ionic bonds need to be broken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most ionic substances can dissolve in water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds dissolved in water are free to move around and the solution can conduct electricity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds that are in the liquid state are free to move around and the liquid can conduct electricity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combustion is the chemical combination of a substance with oxygen, involving the production of heat and light."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Complete combustion of fuels (like hydrocarbons) involve the production of carbon dioxide and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-3
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for oxygen is a combustion reaction, involving relighting a glowing splint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Incomplete combustion produces carbon particulates (soot) and carbon monoxide due to reduced oxygen levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon monoxide gas is toxic."@en ;
  dcterms:modified "2026-02-12T08:59:21.700702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon particulates contribute to health issues and global dimming."@en ;
  dcterms:modified "2026-02-12T08:59:21.700709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfur dioxide and nitrogen oxides are formed through burning fuels, and form acids in water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-4
  a curric:KeyLearningPoint ;
  rdfs:label """Catalytic converters help complete combustion reactions and the removal of nitrogen monoxide from exhaust gases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen can be used as a fuel in cars and this has advantages and disadvantages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Distillation can be used to purify water samples."@en ;
  dcterms:modified "2026-02-12T08:59:21.700730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Boiling point data can be analysed to assess the purity of water samples."@en ;
  dcterms:modified "2026-02-12T08:59:21.700734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-3
  a curric:KeyLearningPoint ;
  rdfs:label """The more impurities present in a sample, the larger the temperature range over which the water will boil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water boils at 100°C."@en ;
  dcterms:modified "2026-02-12T08:59:21.700743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohols can react, at their functional group -OH, with sodium, oxygen, water, or an oxidising agent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-2
  a curric:KeyLearningPoint ;
  rdfs:label "Alcohols need less oxygen than equivalent alkanes in order to burn completely."@en ;
  dcterms:modified "2026-02-12T08:59:21.700753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-3
  a curric:KeyLearningPoint ;
  rdfs:label "Alcohols are good solvents which also mix with water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-4
  a curric:KeyLearningPoint ;
  rdfs:label "The boiling point of ethanol is much higher than the boiling point of ethane."@en ;
  dcterms:modified "2026-02-12T08:59:21.700762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ethanol can be formed via fermentation of glucose (renewable) or via hydration of ethene (non-renewable)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-1
  a curric:KeyLearningPoint ;
  rdfs:label """One type of fuel cell contains hydrogen that reacts with oxygen from the air to produce a voltage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen used in fuel cells can be extracted from fossil fuels or produced by electrolysis powered by the National Grid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-3
  a curric:KeyLearningPoint ;
  rdfs:label "Other fuel cells exist, but have other products than just water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are many strengths and weaknesses of fuel cells, and these should be compared against other energy sources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of arrows (→, ⇌) are used in chemical equations to indicate the nature of the reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reversible reactions are symbolised using the double-headed arrow (⇌) in chemical equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction, both the forward and reverse reactions can occur under the right conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-4
  a curric:KeyLearningPoint ;
  rdfs:label "hydrated copper sulfate (blue) ⇌ anhydrous copper sulfate (white) + water"@en ;
  dcterms:modified "2026-02-12T08:59:21.700919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-5
  a curric:KeyLearningPoint ;
  rdfs:label "ammonium chloride ⇌ ammonia + hydrogen chloride"@en ;
  dcterms:modified "2026-02-12T08:59:21.700923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-02-12T08:59:21.700933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving full electron shells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic nucleus with less force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.700948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change, physical and chemical, and these can be explained in terms of the particle model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-3
  a curric:KeyLearningPoint ;
  rdfs:label "The physical state of a substance can be predicted at specified temperatures."@en ;
  dcterms:modified "2026-02-12T08:59:21.700962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-4
  a curric:KeyLearningPoint ;
  rdfs:label """Forces of attraction between particles have a role in determining the amount of energy needed for state changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the mass of gas produced as the reaction progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller marble chips have a larger surface area than larger chips of the same mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-3
  a curric:KeyLearningPoint ;
  rdfs:label "The larger the surface area, the faster the rate of reaction."@en ;
  dcterms:modified "2026-02-12T08:59:21.701005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four ions present in a solution of brine: H⁺, OH⁻, Na⁺ and Cl⁻."@en ;
  dcterms:modified "2026-02-12T08:59:21.701378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the negative electrode is hydrogen gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.701382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-3
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the positive electrode is chlorine gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.701386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sodium hydroxide solution forms in the electrolyte solution, making it alkaline."@en ;
  dcterms:modified "2026-02-12T08:59:21.701391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-5
  a curric:KeyLearningPoint ;
