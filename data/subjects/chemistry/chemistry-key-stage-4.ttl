# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-climate
  a curric:Keyword ;
  schema:name "climate"@en ;
  schema:description """the average weather conditions (such as rainfall and temperature) recorded over a 30-year period"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789680Z"^^xsd:dateTime .

oakcurric:keyword-altitude
  a curric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "the height above sea level"@en ;
  dcterms:modified "2026-02-12T08:59:15.789684Z"^^xsd:dateTime .

oakcurric:keyword-fraction
  a curric:Keyword ;
  schema:name "fraction"@en ;
  schema:description "A fraction shows us how many equal parts in a whole."@en ;
  dcterms:modified "2026-02-12T08:59:15.789811Z"^^xsd:dateTime .

oakcurric:keyword-hypothesis
  a curric:Keyword ;
  schema:name "hypothesis"@en ;
  schema:description "a prediction taken at the start of the enquiry that can then be tested"@en ;
  dcterms:modified "2026-02-12T08:59:15.789905Z"^^xsd:dateTime .

oakcurric:keyword-method
  a curric:Keyword ;
  schema:name "method"@en ;
  schema:description """the tools a writer uses to create their work; structure, form and language are perhaps the most significant examples."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790045Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description "to consider something carefully and make a judgement about it."@en ;
  dcterms:modified "2026-02-12T08:59:15.790049Z"^^xsd:dateTime .

oakcurric:keyword-objective
  a curric:Keyword ;
  schema:name "objective"@en ;
  schema:description """something that is based on facts and not influenced by personal feelings or opinions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790433Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description "subjective data is data that is based on opinions"@en ;
  dcterms:modified "2026-02-12T08:59:15.790934Z"^^xsd:dateTime .

oakcurric:keyword-quantitative
  a curric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "data that is made up of numbers"@en ;
  dcterms:modified "2026-02-12T08:59:15.791012Z"^^xsd:dateTime .

oakcurric:keyword-analysis
  a curric:Keyword ;
  schema:name "analysis"@en ;
  schema:description """to unpick and examine a text in detail, considering a writer’s choice of language and intention"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791021Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description "able to continue over a long time"@en ;
  dcterms:modified "2026-02-12T08:59:15.791311Z"^^xsd:dateTime .

oakcurric:keyword-pollutant
  a curric:Keyword ;
  schema:name "pollutant"@en ;
  schema:description "a substance that pollutes water or the air"@en ;
  dcterms:modified "2026-02-12T08:59:15.791813Z"^^xsd:dateTime .

oakcurric:keyword-natural-resources
  a curric:Keyword ;
  schema:name "natural resources"@en ;
  schema:description """Natural resources are those that come from Earth without human influence and can be used for human needs."""@en ;
  dcterms:modified "2026-02-12T08:59:15.791916Z"^^xsd:dateTime .

oakcurric:keyword-solution
  a curric:Keyword ;
  schema:name "solution"@en ;
  schema:description "A solution is a way of solving a problem."@en ;
  dcterms:modified "2026-02-12T08:59:15.791940Z"^^xsd:dateTime .

oakcurric:keyword-deposition
  a curric:Keyword ;
  schema:name "deposition"@en ;
  schema:description """the sea dropping sediment (or material) being carried by the water at the coastline"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792445Z"^^xsd:dateTime .

oakcurric:keyword-global-warming
  a curric:Keyword ;
  schema:name "global warming"@en ;
  schema:description """the gradual increase in Earth's average temperature; caused by human activities that release gases, such as carbon dioxide, that trap heat in the atmosphere"""@en ;
  dcterms:modified "2026-02-12T08:59:15.793328Z"^^xsd:dateTime .

oakcurric:keyword-surface-area-to-volume-ratio
  a curric:Keyword ;
  schema:name "surface area to volume ratio"@en ;
  schema:description "The relationship between the surface area and the volume of a shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.793671Z"^^xsd:dateTime .

oakcurric:keyword-catalyst
  a curric:Keyword ;
  schema:name "catalyst"@en ;
  schema:description "A substance that speeds up the rate of a reaction without being used up."@en ;
  dcterms:modified "2026-02-12T08:59:15.793733Z"^^xsd:dateTime .

oakcurric:keyword-model
  a curric:Keyword ;
  schema:name "model"@en ;
  schema:description "Scientists use models as simpler representations of complex things and ideas."@en ;
  dcterms:modified "2026-02-12T08:59:15.793747Z"^^xsd:dateTime .

oakcurric:keyword-polymer
  a curric:Keyword ;
  schema:name "polymer"@en ;
  schema:description "A polymer is a molecule made of many repeated units."@en ;
  dcterms:modified "2026-02-12T08:59:15.793907Z"^^xsd:dateTime .

oakcurric:keyword-dna
  a curric:Keyword ;
  schema:name "DNA"@en ;
  schema:description """A large chemical molecule made of smaller chemical groups, it carries the genetic code of all living organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793932Z"^^xsd:dateTime .

oakcurric:keyword-photosynthesis
  a curric:Keyword ;
  schema:name "photosynthesis"@en ;
  schema:description """the process used by producers to make their own food via a series of chemical reactions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.793997Z"^^xsd:dateTime .

oakcurric:keyword-nucleus
  a curric:Keyword ;
  schema:name "nucleus"@en ;
  schema:description """A sub-cellular structure that contains the genetic material (DNA); controls the cell activities."""@en ;
  dcterms:modified "2026-02-12T08:59:15.794080Z"^^xsd:dateTime .

oakcurric:keyword-separate
  a curric:Keyword ;
  schema:name "separate"@en ;
  schema:description "when things are apart, they are described as separate"@en ;
  dcterms:modified "2026-02-12T08:59:15.794331Z"^^xsd:dateTime .

oakcurric:keyword-standard-form
  a curric:Keyword ;
  schema:name "standard form"@en ;
  schema:description "A way of writing down very large or very small numbers easily; e.g. 1000 = 10³."@en ;
  dcterms:modified "2026-02-12T08:59:15.794536Z"^^xsd:dateTime .

oakcurric:keyword-ph
  a curric:Keyword ;
  schema:name "pH"@en ;
  schema:description "A measure of how acidic or alkaline a solution is."@en ;
  dcterms:modified "2026-02-12T08:59:15.794787Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-reaction
  a curric:Keyword ;
  schema:name "rate of reaction"@en ;
  schema:description "How fast a chemical reaction occurs."@en ;
  dcterms:modified "2026-02-12T08:59:15.794791Z"^^xsd:dateTime .

oakcurric:keyword-endothermic
  a curric:Keyword ;
  schema:name "endothermic"@en ;
  schema:description "a chemical process that requires energy transferred from its surroundings"@en ;
  dcterms:modified "2026-02-12T08:59:15.794868Z"^^xsd:dateTime .

oakcurric:keyword-ore
  a curric:Keyword ;
  schema:name "ore"@en ;
