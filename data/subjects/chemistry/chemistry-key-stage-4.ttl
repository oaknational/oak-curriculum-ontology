  dcterms:modified "2026-02-12T08:59:15.812293Z"^^xsd:dateTime .

oakcurric:keyword-organic-compound
  a curric:Keyword ;
  schema:name "organic compound"@en ;
  schema:description """A chemical compound in which one or more atoms of carbon are covalently linked to atoms of other elements, most commonly hydrogen, oxygen, or nitrogen."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812298Z"^^xsd:dateTime .

oakcurric:keyword-systematic-error
  a curric:Keyword ;
  schema:name "systematic error"@en ;
  schema:description """Causes measurements to differ from the true value by the same amount each time they are taken."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812403Z"^^xsd:dateTime .

oakcurric:keyword-electron-shell
  a curric:Keyword ;
  schema:name "electron shell"@en ;
  schema:description "is an energy level outside the nucleus which contains electrons."@en ;
  dcterms:modified "2026-02-12T08:59:15.812411Z"^^xsd:dateTime .

oakcurric:keyword-electronic-configuration
  a curric:Keyword ;
  schema:name "electronic configuration"@en ;
  schema:description "of an atom of an element describes how the electrons are arranged in shells."@en ;
  dcterms:modified "2026-02-12T08:59:15.812418Z"^^xsd:dateTime .

oakcurric:keyword-period
  a curric:Keyword ;
  schema:name "period"@en ;
  schema:description """is a horizontal row on the periodic table, it corresponds to the number of shells of an atom in an element that have electrons in them."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812422Z"^^xsd:dateTime .

oakcurric:keyword-anaerobic
  a curric:Keyword ;
  schema:name "anaerobic"@en ;
  schema:description "A process that does not require oxygen."@en ;
  dcterms:modified "2026-02-12T08:59:15.812446Z"^^xsd:dateTime .

oakcurric:keyword-fermentation
  a curric:Keyword ;
  schema:name "fermentation"@en ;
