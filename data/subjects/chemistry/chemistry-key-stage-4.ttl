  dcterms:modified "2026-02-12T08:59:15.800501Z"^^xsd:dateTime .

oakcurric:keyword-chemical-weathering
  a curric:Keyword ;
  schema:name "chemical weathering"@en ;
  schema:description """Chemical weathering is when rocks are broken down by a chemical change, for example reactions with acid rain."""@en ;
  dcterms:modified "2026-02-12T08:59:15.800507Z"^^xsd:dateTime .

oakcurric:keyword-fossil-fuel
  a curric:Keyword ;
  schema:name "fossil fuel"@en ;
  schema:description """natural substances that were formed over millions of years ago from the buried remains of ancient organisms. They include coal, oil and gas"""@en ;
  dcterms:modified "2026-02-12T08:59:15.800711Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the point where the problems in a story are resolved"@en ;
  dcterms:modified "2026-02-12T08:59:15.800780Z"^^xsd:dateTime .

oakcurric:keyword-risk-assessment
  a curric:Keyword ;
  schema:name "risk assessment"@en ;
  schema:description """A risk assessment looks at what hazards we might come across and how to keep us safe."""@en ;
  dcterms:modified "2026-02-12T08:59:15.800846Z"^^xsd:dateTime .

oakcurric:keyword-recycling
  a curric:Keyword ;
  schema:name "recycling"@en ;
  schema:description "the process of collecting and turning used materials into new products"@en ;
  dcterms:modified "2026-02-12T08:59:15.800921Z"^^xsd:dateTime .

oakcurric:keyword-glacier
  a curric:Keyword ;
  schema:name "glacier"@en ;
  schema:description "a huge accumulation of ice and snow that moves slowly over land"@en ;
  dcterms:modified "2026-02-12T08:59:15.801796Z"^^xsd:dateTime .

oakcurric:keyword-excess
  a curric:Keyword ;
  schema:name "excess"@en ;
  schema:description "If you have an excess of something, you have more than is necessary."@en ;
  dcterms:modified "2026-02-12T08:59:15.801978Z"^^xsd:dateTime .

oakcurric:keyword-raw-material
  a curric:Keyword ;
  schema:name "raw material"@en ;
  schema:description """Raw materials are things that can be grown or dug out of the ground and processed or used in the manufacture of goods."""@en ;
  dcterms:modified "2026-02-12T08:59:15.802626Z"^^xsd:dateTime .

oakcurric:keyword-sample
  a curric:Keyword ;
  schema:name "sample"@en ;
