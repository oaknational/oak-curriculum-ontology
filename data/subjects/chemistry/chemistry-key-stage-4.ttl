  dcterms:modified "2026-02-12T08:59:15.803850Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description """the final part of a text that summarises the main points, providing closure to the subject"""@en ;
  dcterms:modified "2026-02-12T08:59:15.804054Z"^^xsd:dateTime .

oakcurric:keyword-nucleotides
  a curric:Keyword ;
  schema:name "nucleotides"@en ;
