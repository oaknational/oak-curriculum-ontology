  dcterms:modified "2026-02-12T08:59:15.799621Z"^^xsd:dateTime .

oakcurric:keyword-desalination
  a curric:Keyword ;
  schema:name "desalination"@en ;
  schema:description """the process of removing salt from seawater to make it suitable for drinking and irrigation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.800475Z"^^xsd:dateTime .

oakcurric:keyword-ph-scale
  a curric:Keyword ;
  schema:name "pH scale"@en ;
  schema:description """The pH scale measures acidity and alkalinity and is often shown with values ranging from 1 to 14. A pH below 7 indicates an acid, a pH above 7 indicates an alkali, and a pH of 7 is neutral."""@en ;
  dcterms:modified "2026-02-12T08:59:15.800497Z"^^xsd:dateTime .

oakcurric:keyword-acid-rain
  a curric:Keyword ;
  schema:name "acid rain"@en ;
