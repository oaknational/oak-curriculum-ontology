oakcurric:keylearningpoint-lesson-609-4
  a curric:KeyLearningPoint ;
  rdfs:label "Missing side lengths can be found if the perimeter is known."@en ;
  dcterms:modified "2026-02-12T08:59:21.659298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-681-1
  a curric:KeyLearningPoint ;
