  dcterms:modified "2026-02-12T08:59:21.666978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-631-4
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of the sphere is the difference between the volume of the cylinder and water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-631-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is a formula you can use to calculate the volume of a sphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.666987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7627-1
  a curric:KeyLearningPoint ;
