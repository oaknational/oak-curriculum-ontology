  dcterms:modified "2026-02-12T08:59:21.742693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-644-4
  a curric:KeyLearningPoint ;
  rdfs:label """The number of sides in a regular polygon can be determined from the size of the interior angle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-644-5
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the interior angles is the same, regardless of whether the polygon is regular."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-796-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sequence notation becomes more formal in further studies."@en ;
  dcterms:modified "2026-02-12T08:59:21.742705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-796-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is notation for a term, the next term and for general terms."@en ;
  dcterms:modified "2026-02-12T08:59:21.742733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-796-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use this notation to write the term-to-term rule."@en ;
  dcterms:modified "2026-02-12T08:59:21.742737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-692-1
  a curric:KeyLearningPoint ;
  rdfs:label "The product of a number and its reciprocal is 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.743655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-692-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product of a term and its reciprocal is 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.743659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-692-3
  a curric:KeyLearningPoint ;
  rdfs:label """Equivalence can be maintained by multiplying the connected statements by the same reciprocal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-692-4
  a curric:KeyLearningPoint ;
  rdfs:label "This step can help you simplify an equation so you can solve it."@en ;
  dcterms:modified "2026-02-12T08:59:21.743667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-468-1
  a curric:KeyLearningPoint ;
  rdfs:label "When the coefficient of the x term is zero, you may still be able to factorise."@en ;
  dcterms:modified "2026-02-12T08:59:21.743673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-468-2
  a curric:KeyLearningPoint ;
  rdfs:label """There is a structure to the quadratic expressions that can be factorised if there is no x term."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-468-3
  a curric:KeyLearningPoint ;
  rdfs:label "The same area model can be used to explore this structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.743681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-750-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two densities can be combined to give an overall density."@en ;
  dcterms:modified "2026-02-12T08:59:21.743687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-495-1
  a curric:KeyLearningPoint ;
  rdfs:label "Calculators are very useful here as they can be programmed efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.743693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-495-2
  a curric:KeyLearningPoint ;
  rdfs:label "This saves time and can reduce error."@en ;
