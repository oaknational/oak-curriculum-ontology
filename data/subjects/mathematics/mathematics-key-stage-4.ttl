  dcterms:modified "2026-02-12T08:59:21.744929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-802-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can rearrange an equation in order to carry out iteration"@en ;
  dcterms:modified "2026-02-12T08:59:21.744933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-802-2
  a curric:KeyLearningPoint ;
