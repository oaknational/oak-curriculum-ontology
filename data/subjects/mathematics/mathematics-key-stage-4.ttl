  dcterms:modified "2026-02-12T08:59:21.670148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-828-1
  a curric:KeyLearningPoint ;
  rdfs:label "A scaled version of a shape is very useful."@en ;
  dcterms:modified "2026-02-12T08:59:21.670153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-828-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being able to scale the perimeter can reduce the number of calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.670157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-828-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enlargement (transformations) and similar shapes are connected."@en ;
  dcterms:modified "2026-02-12T08:59:21.670162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-809-1
  a curric:KeyLearningPoint ;
  rdfs:label "A linear inequality is solved using the rules of algebraic manipulation"@en ;
  dcterms:modified "2026-02-12T08:59:21.670379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-809-2
  a curric:KeyLearningPoint ;
