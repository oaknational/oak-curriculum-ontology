  dcterms:modified "2026-02-12T08:59:21.688271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-615-2
  a curric:KeyLearningPoint ;
  rdfs:label "This gives the length of the curved section of a sector."@en ;
  dcterms:modified "2026-02-12T08:59:21.688276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-615-3
  a curric:KeyLearningPoint ;
