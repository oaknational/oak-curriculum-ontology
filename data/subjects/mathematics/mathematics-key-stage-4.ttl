  dcterms:modified "2026-02-12T08:59:21.750109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-787-2
  a curric:KeyLearningPoint ;
  rdfs:label "Special number sequences are not geometric."@en ;
  dcterms:modified "2026-02-12T08:59:21.750113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-787-3
  a curric:KeyLearningPoint ;
  rdfs:label "Special number sequences are generated using different rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.750117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-572-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rounding and estimation are practical maths skills."@en ;
  dcterms:modified "2026-02-12T08:59:21.750122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-572-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes you will need to apply common sense to rounding in context."@en ;
  dcterms:modified "2026-02-12T08:59:21.750125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-572-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using your knowledge of arithmetic procedures, you can determine which bounds to calculate with."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-463-1
  a curric:KeyLearningPoint ;
  rdfs:label """With linear equation involving brackets, there are two methods for addressing the brackets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-463-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can expand the bracket (multiply out)."@en ;
  dcterms:modified "2026-02-12T08:59:21.750735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-463-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can divide each term."@en ;
  dcterms:modified "2026-02-12T08:59:21.750739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-463-4
  a curric:KeyLearningPoint ;
  rdfs:label "If there is a common factor across all terms, then division may be best."@en ;
  dcterms:modified "2026-02-12T08:59:21.750745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-775-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using function notation, you can write a composite function."@en ;
  dcterms:modified "2026-02-12T08:59:21.750749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-775-2
  a curric:KeyLearningPoint ;
