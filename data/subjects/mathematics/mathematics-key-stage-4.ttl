  dcterms:modified "2026-02-12T08:59:21.669006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-639-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vertically opposite angles are equal."@en ;
  dcterms:modified "2026-02-12T08:59:21.669010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-543-1
  a curric:KeyLearningPoint ;
  rdfs:label "The stem is made of all but the last digit of each value."@en ;
  dcterms:modified "2026-02-12T08:59:21.669841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-543-2
  a curric:KeyLearningPoint ;
  rdfs:label "The leaves are made from the last digit of each value."@en ;
  dcterms:modified "2026-02-12T08:59:21.669845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-543-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important that place value is preserved in the diagram through use of a key."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-543-4
  a curric:KeyLearningPoint ;
  rdfs:label "A stem and leaf diagram can display data in strata."@en ;
  dcterms:modified "2026-02-12T08:59:21.669857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-586-1
  a curric:KeyLearningPoint ;
  rdfs:label "Linear equations can be rearranged into the form y = mx + c"@en ;
  dcterms:modified "2026-02-12T08:59:21.669862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-586-2
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient (m) and the y-intercept (c) can be determined from the graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.669866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-586-3
  a curric:KeyLearningPoint ;
  rdfs:label """The amount y changes when x increases by one is the rate of change and called the gradient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-586-4
  a curric:KeyLearningPoint ;
  rdfs:label "Where the graph crosses the y-axis is the value of the y-intercept."@en ;
  dcterms:modified "2026-02-12T08:59:21.669876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-586-5
  a curric:KeyLearningPoint ;
  rdfs:label "The equation of the line can be written in the form y = mx + c"@en ;
  dcterms:modified "2026-02-12T08:59:21.669880Z"^^xsd:dateTime .

