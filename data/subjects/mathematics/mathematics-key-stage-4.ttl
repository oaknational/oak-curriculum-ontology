  dcterms:modified "2026-02-12T08:59:21.672207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-656-1
  a curric:KeyLearningPoint ;
  rdfs:label "A shape can be transformed more than once."@en ;
  dcterms:modified "2026-02-12T08:59:21.672616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-656-2
  a curric:KeyLearningPoint ;
  rdfs:label "The first transformation is performed on the object."@en ;
  dcterms:modified "2026-02-12T08:59:21.672621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-656-3
  a curric:KeyLearningPoint ;
  rdfs:label "The second transformation is performed on the image."@en ;
  dcterms:modified "2026-02-12T08:59:21.672625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-656-4
  a curric:KeyLearningPoint ;
  rdfs:label "The third transformation is performed on the new image etc."@en ;
  dcterms:modified "2026-02-12T08:59:21.672630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7690-1
  a curric:KeyLearningPoint ;
