  a curric:KeyLearningPoint ;
  rdfs:label """By considering the properties of the shape, there may be a more efficient method."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-609-3
  a curric:KeyLearningPoint ;
