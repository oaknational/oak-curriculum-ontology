oakcurric:keylearningpoint-lesson-802-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficient use of the calculator makes this process much faster"@en ;
  dcterms:modified "2026-02-12T08:59:21.744945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-462-1
  a curric:KeyLearningPoint ;
