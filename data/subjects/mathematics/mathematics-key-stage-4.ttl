  dcterms:modified "2026-02-12T08:59:21.689544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7820-1
  a curric:KeyLearningPoint ;
  rdfs:label "Your knowledge of loci can be applied to your knowledge of bearings"@en ;
  dcterms:modified "2026-02-12T08:59:21.689548Z"^^xsd:dateTime .

