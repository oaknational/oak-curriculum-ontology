  dcterms:modified "2026-02-12T08:59:21.669907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-521-1
  a curric:KeyLearningPoint ;
  rdfs:label """Primary data is collected first-hand, secondary data was collected by someone else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-521-2
  a curric:KeyLearningPoint ;
