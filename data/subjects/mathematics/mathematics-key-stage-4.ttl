oakcurric:keylearningpoint-lesson-770-2
  a curric:KeyLearningPoint ;
  rdfs:label "The context of the question can be used to determine the type of proportion."@en ;
  dcterms:modified "2026-02-12T08:59:21.668953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-770-3
  a curric:KeyLearningPoint ;
  rdfs:label """If more than one pair of values is given, this can determine the type of proportion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-739-1
  a curric:KeyLearningPoint ;
  rdfs:label """By systematically listing the outcomes for two or more events, a pattern begins to emerge"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-739-2
  a curric:KeyLearningPoint ;
  rdfs:label """This pattern can be generalised so that counting possible outcome combinations is quicker"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-739-3
  a curric:KeyLearningPoint ;
  rdfs:label """Whether the order of the outcomes matters affects the number of possible outcomes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-739-4
  a curric:KeyLearningPoint ;
  rdfs:label """If order does not matter then repetition can be accounted for when considering the total number of outcomes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-727-1
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an outcome can be found by considering a table"@en ;
  dcterms:modified "2026-02-12T08:59:21.668983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-727-2
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an event can be found by considering a table showing all possible outcomes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-727-3
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an outcome can be found by considering a two-way table showing all possible outcomes for two events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-727-4
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an event can be found by considering a two-way table showing all possible outcomes for two events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-639-1
  a curric:KeyLearningPoint ;
  rdfs:label "Angles that meet around a point sum to 360°"@en ;
  dcterms:modified "2026-02-12T08:59:21.669001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-639-2
  a curric:KeyLearningPoint ;
