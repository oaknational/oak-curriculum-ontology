oakcurric:keylearningpoint-lesson-681-2
  a curric:KeyLearningPoint ;
  rdfs:label "Angle facts can be used to deduce the bearing of point."@en ;
  dcterms:modified "2026-02-12T08:59:21.659330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-681-3
  a curric:KeyLearningPoint ;
  rdfs:label "Additional lines may be added to a diagram to facilitate problem solving."@en ;
  dcterms:modified "2026-02-12T08:59:21.659335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-829-1
  a curric:KeyLearningPoint ;
  rdfs:label "A scaled version of a shape/object is very useful."@en ;
  dcterms:modified "2026-02-12T08:59:21.659340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-829-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being able to scale the perimeter/area/volume can reduce the number of calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-829-3
  a curric:KeyLearningPoint ;
  rdfs:label "This knowledge of similarity can be extended to include surface area."@en ;
  dcterms:modified "2026-02-12T08:59:21.659349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-746-1
  a curric:KeyLearningPoint ;
