  dcterms:modified "2026-02-12T08:59:21.660263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-746-2
  a curric:KeyLearningPoint ;
  rdfs:label "The units for speed can be converted to alternative units."@en ;
  dcterms:modified "2026-02-12T08:59:21.660268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-746-3
  a curric:KeyLearningPoint ;
  rdfs:label "When converting, it can be helpful to think about a context."@en ;
  dcterms:modified "2026-02-12T08:59:21.660275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-851-1
  a curric:KeyLearningPoint ;
  rdfs:label "The first side can be drawn accurately with a ruler"@en ;
  dcterms:modified "2026-02-12T08:59:21.660279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-851-2
  a curric:KeyLearningPoint ;
  rdfs:label "All triangles with these measurements in the same place are congruent"@en ;
  dcterms:modified "2026-02-12T08:59:21.660284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-851-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angle should be accurately measured with a protractor"@en ;
  dcterms:modified "2026-02-12T08:59:21.660288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-851-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two different triangles can be drawn with these measurements"@en ;
  dcterms:modified "2026-02-12T08:59:21.660293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7687-1
  a curric:KeyLearningPoint ;
  rdfs:label "Real life graphs present a visual model of a situation."@en ;
  dcterms:modified "2026-02-12T08:59:21.660300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7687-2
  a curric:KeyLearningPoint ;
  rdfs:label "Linear graphs are not always the best representation."@en ;
  dcterms:modified "2026-02-12T08:59:21.660305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7687-3
  a curric:KeyLearningPoint ;
  rdfs:label """The different parts of the graph describe different parts of the whole situation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-706-1
  a curric:KeyLearningPoint ;
  rdfs:label "The tangent ratio involves the opposite, adjacent and the angle"@en ;
  dcterms:modified "2026-02-12T08:59:21.660314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-706-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the opposite and the size of the angle, you can use the tangent ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-706-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the adjacent and the size of the angle, you can use the tangent ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-706-4
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the opposite and adjacent, you can use the tangent ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-667-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theorem is a statement that can be demonstrated to be true by accepted mathematical operations and arguments"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Theorems can be thought of as puzzles to solve, you are showing how to find a result"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-667-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to use this theorem, you may need to draw a diagram or add more information to an existing one"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-765-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct proportion equations are of the form y = kx"@en ;
  dcterms:modified "2026-02-12T08:59:21.660345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-765-2
  a curric:KeyLearningPoint ;
  rdfs:label "k is the constant of proportionality and it is also the gradient of the graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.660350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-765-3
  a curric:KeyLearningPoint ;
  rdfs:label "To find the gradient, k, you can use a set of coordinates (pair of values)."@en ;
  dcterms:modified "2026-02-12T08:59:21.660354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-591-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parallel lines have the same gradient."@en ;
  dcterms:modified "2026-02-12T08:59:21.660361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-591-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product of the gradients of two perpendicular lines is -1"@en ;
  dcterms:modified "2026-02-12T08:59:21.660366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-591-3
  a curric:KeyLearningPoint ;
  rdfs:label "Your knowledge of the geometrical properties of shapes can be applied here."@en ;
  dcterms:modified "2026-02-12T08:59:21.660371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-550-1
  a curric:KeyLearningPoint ;
  rdfs:label "Certain data is suitable for a pie chart."@en ;
  dcterms:modified "2026-02-12T08:59:21.661031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-550-2
  a curric:KeyLearningPoint ;
  rdfs:label "The shape of the chart can be estimated from the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.661035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-550-3
  a curric:KeyLearningPoint ;
  rdfs:label "For larger data sets, technology can make constructing charts quicker."@en ;
  dcterms:modified "2026-02-12T08:59:21.661040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-658-1
  a curric:KeyLearningPoint ;
  rdfs:label """By understanding what changes and what is invariant, you can determine whether a transformation has occurred."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-658-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes you might need to persevere in order to find the right transformation(s)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-658-3
  a curric:KeyLearningPoint ;
  rdfs:label "You may be able to check your deductions by carrying out the transformation."@en ;
  dcterms:modified "2026-02-12T08:59:21.661078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-705-1
  a curric:KeyLearningPoint ;
  rdfs:label "The cosine ratio involves the hypotenuse, adjacent and the angle"@en ;
  dcterms:modified "2026-02-12T08:59:21.661083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-705-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the hypotenuse and the size of the angle, you can use the cosine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-705-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the adjacent and the size of the angle, you can use the cosine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-705-4
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the hypotenuse and adjacent, you can use the cosine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-558-1
  a curric:KeyLearningPoint ;
  rdfs:label "A box plot allows us to make conclusions about the data set"@en ;
  dcterms:modified "2026-02-12T08:59:21.661106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-558-2
  a curric:KeyLearningPoint ;
  rdfs:label "Box plots can be compared to highlight similarities/differences in data sets"@en ;
  dcterms:modified "2026-02-12T08:59:21.661111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-558-3
  a curric:KeyLearningPoint ;
  rdfs:label "The box part tells us about the middle 50% of the data"@en ;
  dcterms:modified "2026-02-12T08:59:21.661115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-561-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes data is presented using unequal class widths"@en ;
  dcterms:modified "2026-02-12T08:59:21.661120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-561-2
  a curric:KeyLearningPoint ;
  rdfs:label "In order to compare, frequency density is used"@en ;
  dcterms:modified "2026-02-12T08:59:21.661124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-561-3
  a curric:KeyLearningPoint ;
  rdfs:label """Frequency density is proportional to the frequency per unit for the data in each class"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-561-4
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency is proportional to the area of the bar"@en ;
  dcterms:modified "2026-02-12T08:59:21.661134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7685-1
  a curric:KeyLearningPoint ;
  rdfs:label "For non-linear graphs, this can be estimated by considering a trapezium."@en ;
  dcterms:modified "2026-02-12T08:59:21.661161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7685-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more trapezia used, the better the estimate."@en ;
  dcterms:modified "2026-02-12T08:59:21.661166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-734-1
  a curric:KeyLearningPoint ;
  rdfs:label "A tree diagram can be used to calculate conditional probabilities"@en ;
  dcterms:modified "2026-02-12T08:59:21.661707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-734-2
  a curric:KeyLearningPoint ;
  rdfs:label """A tree diagram can be used to calculate conditional probabilities involving sets of events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-734-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tree diagrams allow us to identify which events are mutually exclusive"@en ;
  dcterms:modified "2026-02-12T08:59:21.661718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-734-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tree diagrams can be used to identify which events are independent"@en ;
  dcterms:modified "2026-02-12T08:59:21.661725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-810-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inequalities can be combined to be more efficient"@en ;
  dcterms:modified "2026-02-12T08:59:21.661730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-810-2
  a curric:KeyLearningPoint ;
  rdfs:label """By treating the combined inequality as two separate inequalities, you can easily solve"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-810-3
  a curric:KeyLearningPoint ;
  rdfs:label """There may be a set of possible values, inequality notation can be used to communicate them efficiently"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-830-1
  a curric:KeyLearningPoint ;
  rdfs:label "It can be helpful to choose a vertex and translate that."@en ;
  dcterms:modified "2026-02-12T08:59:21.661744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-830-2
  a curric:KeyLearningPoint ;
  rdfs:label "Once all the vertices have been translated, the image can be drawn."@en ;
  dcterms:modified "2026-02-12T08:59:21.661751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-830-3
  a curric:KeyLearningPoint ;
  rdfs:label "The image and the object should be congruent."@en ;
  dcterms:modified "2026-02-12T08:59:21.661756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-830-4
  a curric:KeyLearningPoint ;
  rdfs:label "To translate, you need to know the distance left/right and up/down to move."@en ;
  dcterms:modified "2026-02-12T08:59:21.661763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-590-1
  a curric:KeyLearningPoint ;
  rdfs:label """If two equations are written in the form y = mx + c then you can identify if they are perpendicular."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-590-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the equations are not in that form, you can rearrange them to be."@en ;
  dcterms:modified "2026-02-12T08:59:21.661772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-590-3
  a curric:KeyLearningPoint ;
  rdfs:label "From their graphs, you can identify whether two lines are perpendicular."@en ;
  dcterms:modified "2026-02-12T08:59:21.661777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-530-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data is given as pairs of values."@en ;
  dcterms:modified "2026-02-12T08:59:21.662289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-530-2
  a curric:KeyLearningPoint ;
  rdfs:label "The independent variable is placed on the horizontal axis."@en ;
  dcterms:modified "2026-02-12T08:59:21.662293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-530-3
  a curric:KeyLearningPoint ;
  rdfs:label """Placing the independent variable on the other axis reflects the data points in y=x but not the correlation type."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-755-1
  a curric:KeyLearningPoint ;
  rdfs:label "Speed may not always be constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.662302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-755-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration may not always be constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.662307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-755-3
  a curric:KeyLearningPoint ;
  rdfs:label "Depending on the variables, multiple graphs can represent the same journey."@en ;
  dcterms:modified "2026-02-12T08:59:21.662312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Desmos is an effective tool for showing the effects of this transformation"@en ;
  dcterms:modified "2026-02-12T08:59:21.662316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7822-2
  a curric:KeyLearningPoint ;
  rdfs:label "The actual function itself does not need to be known"@en ;
  dcterms:modified "2026-02-12T08:59:21.662321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7822-3
  a curric:KeyLearningPoint ;
  rdfs:label "The graph is stretched by a scale factor of 1/a in the x-direction"@en ;
  dcterms:modified "2026-02-12T08:59:21.662326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-552-1
  a curric:KeyLearningPoint ;
  rdfs:label "When presented with a large volume of data, valid interpretation can be hard."@en ;
  dcterms:modified "2026-02-12T08:59:21.662908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-552-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important that any conclusions are supported by the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.662913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-552-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the real world, multiple representations are often used so critiquing them is a vital skill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-701-1
  a curric:KeyLearningPoint ;
  rdfs:label "For a triangle to be right-angled, Pythagoras' theorem must hold"@en ;
  dcterms:modified "2026-02-12T08:59:21.662922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-701-2
  a curric:KeyLearningPoint ;
  rdfs:label "By substituting in the three lengths, you can show whether the theorem holds"@en ;
  dcterms:modified "2026-02-12T08:59:21.662927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-701-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the numbers produce a true statement, the triangle is right-angled"@en ;
  dcterms:modified "2026-02-12T08:59:21.662931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-701-4
  a curric:KeyLearningPoint ;
  rdfs:label "If they do not produce a true statement, the triangle is not right-angled"@en ;
  dcterms:modified "2026-02-12T08:59:21.662936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-525-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sample can only produce conclusions for that sample."@en ;
  dcterms:modified "2026-02-12T08:59:21.662940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-525-2
  a curric:KeyLearningPoint ;
  rdfs:label "A different sample may produce different conclusions."@en ;
  dcterms:modified "2026-02-12T08:59:21.662947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-525-3
  a curric:KeyLearningPoint ;
  rdfs:label "The usefulness of any conclusions may be limited by the sample size."@en ;
  dcterms:modified "2026-02-12T08:59:21.662952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes on coordinate grids do not often have their measurements clearly written."@en ;
  dcterms:modified "2026-02-12T08:59:21.662957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-620-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instead, you are expect to calculate the desired lengths."@en ;
  dcterms:modified "2026-02-12T08:59:21.662961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-620-3
  a curric:KeyLearningPoint ;
  rdfs:label """This may involve Pythagoras' theorem, shape properties or equations of lines for example."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-485-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use your knowledge of graphical representations to draw the graphs on the same axes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-485-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there exists two solutions, then the points of intersection are those solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-485-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there exists one solution, then the point where the linear graph touches the quadratic graph is that solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-485-4
  a curric:KeyLearningPoint ;
  rdfs:label "If there are no solutions then the graphs do not touch at all."@en ;
  dcterms:modified "2026-02-12T08:59:21.662985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-485-5
  a curric:KeyLearningPoint ;
  rdfs:label """When substituting or eliminating, you are left with a combined quadratic which has roots where the graphs intersect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-629-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different types of pyramid."@en ;
  dcterms:modified "2026-02-12T08:59:21.663482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-629-2
  a curric:KeyLearningPoint ;
  rdfs:label "The apex of the pyramid is not necessarily above the centre of the base."@en ;
  dcterms:modified "2026-02-12T08:59:21.663486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-629-3
  a curric:KeyLearningPoint ;
  rdfs:label "The formula for the volume of a pyramid can be derived."@en ;
  dcterms:modified "2026-02-12T08:59:21.663491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-549-1
  a curric:KeyLearningPoint ;
  rdfs:label "Technology can be used to calculate numerical summary statistics."@en ;
  dcterms:modified "2026-02-12T08:59:21.663495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-549-2
  a curric:KeyLearningPoint ;
  rdfs:label "Technology can be used to create visual representations of data."@en ;
  dcterms:modified "2026-02-12T08:59:21.663500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-549-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to select appropriate representations and summaries based on context and the type of data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-824-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing the three side lengths of the triangle and its image, you can prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-824-2
  a curric:KeyLearningPoint ;
  rdfs:label """If congruent, the same multiplicative relationship will exist for each pair of side lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-824-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angle pairs will be the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.663518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-812-1
  a curric:KeyLearningPoint ;
  rdfs:label "When combining solution sets, you may wish to use a number line"@en ;
  dcterms:modified "2026-02-12T08:59:21.663525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-812-2
  a curric:KeyLearningPoint ;
  rdfs:label "Once you are certain, you can write the solution set using algebraic notation"@en ;
  dcterms:modified "2026-02-12T08:59:21.663533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-812-3
  a curric:KeyLearningPoint ;
  rdfs:label "Both inequalities must be solved before the solution set can be determined"@en ;
  dcterms:modified "2026-02-12T08:59:21.663537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-608-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading values from scales in a useful skill in a variety of contexts."@en ;
  dcterms:modified "2026-02-12T08:59:21.664014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-608-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different countries may use different measurements."@en ;
  dcterms:modified "2026-02-12T08:59:21.664019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-608-3
  a curric:KeyLearningPoint ;
  rdfs:label "Incorrect conversion produces a different ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.664023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct proportion can be used in a number of contexts, for example in currency conversion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-742-2
  a curric:KeyLearningPoint ;
  rdfs:label "Proportional relationships can be expressed as ratios, often in unitary form."@en ;
  dcterms:modified "2026-02-12T08:59:21.664035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-742-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ratio is in unitary form if one of the parts is equal to one."@en ;
  dcterms:modified "2026-02-12T08:59:21.664040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-742-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to be able to recognise which contexts involve direct proportion."@en ;
  dcterms:modified "2026-02-12T08:59:21.664047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-728-1
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an outcome can be found by considering a tree diagram"@en ;
  dcterms:modified "2026-02-12T08:59:21.664052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-728-2
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an event can be found by considering a tree diagram"@en ;
  dcterms:modified "2026-02-12T08:59:21.664056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-728-3
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an outcome can be found by considering a Venn diagram"@en ;
  dcterms:modified "2026-02-12T08:59:21.664064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-728-4
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an event can be found by considering a Venn diagram"@en ;
  dcterms:modified "2026-02-12T08:59:21.664069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-674-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plans and elevations may be drawn to scale."@en ;
  dcterms:modified "2026-02-12T08:59:21.664073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-674-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can combine an isometric drawing with its plan and elevations to find missing information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-674-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scaling could be indicated by a scale factor or a ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.664082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-836-1
  a curric:KeyLearningPoint ;
  rdfs:label "More than one operation may be seen."@en ;
  dcterms:modified "2026-02-12T08:59:21.664087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-836-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priority of operations still apply."@en ;
  dcterms:modified "2026-02-12T08:59:21.664091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-836-3
  a curric:KeyLearningPoint ;
  rdfs:label "Constructing all the vectors can help when checking the resultant is correct."@en ;
  dcterms:modified "2026-02-12T08:59:21.664096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-473-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are other methods to find the solutions of a quadratic equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.664103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-473-2
  a curric:KeyLearningPoint ;
  rdfs:label "One of these methods is called completing the square."@en ;
  dcterms:modified "2026-02-12T08:59:21.664108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-473-3
  a curric:KeyLearningPoint ;
  rdfs:label "By representing this with a model, you can see why it has this name."@en ;
  dcterms:modified "2026-02-12T08:59:21.664112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-473-4
  a curric:KeyLearningPoint ;
  rdfs:label "Completing the square is useful when the quadratic cannot be easily factorised."@en ;
  dcterms:modified "2026-02-12T08:59:21.664117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-473-5
  a curric:KeyLearningPoint ;
  rdfs:label "The square root of a number can be positive or negative."@en ;
  dcterms:modified "2026-02-12T08:59:21.664122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-785-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to prove something, you may need to use any of your maths skills and knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-785-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to define any algebraic expressions at the start of a proof."@en ;
  dcterms:modified "2026-02-12T08:59:21.664131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-785-3
  a curric:KeyLearningPoint ;
  rdfs:label "This is so it is clear what cases you are proving."@en ;
  dcterms:modified "2026-02-12T08:59:21.664137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7691-1
  a curric:KeyLearningPoint ;
  rdfs:label "When handling a project, there are often constraints."@en ;
  dcterms:modified "2026-02-12T08:59:21.664142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7691-2
  a curric:KeyLearningPoint ;
  rdfs:label "Constraints exist for a variety of reasons, such as cost or supply limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.664147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7691-3
  a curric:KeyLearningPoint ;
  rdfs:label "Finding a set of possible solutions allows you to work within the constraints."@en ;
  dcterms:modified "2026-02-12T08:59:21.664151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-837-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter can be used to represent a vector."@en ;
  dcterms:modified "2026-02-12T08:59:21.664156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each unique vector is assigned a unique letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.664160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-544-1
  a curric:KeyLearningPoint ;
  rdfs:label "The range can be calculated from a stem and leaf diagram."@en ;
  dcterms:modified "2026-02-12T08:59:21.664826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-544-2
  a curric:KeyLearningPoint ;
  rdfs:label "The mode can be calculated from a stem and leaf diagram."@en ;
  dcterms:modified "2026-02-12T08:59:21.664831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-544-3
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be calculated from a stem and leaf diagram."@en ;
  dcterms:modified "2026-02-12T08:59:21.664835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-544-4
  a curric:KeyLearningPoint ;
  rdfs:label "Although possible, the mean is very time consuming to calculate."@en ;
  dcterms:modified "2026-02-12T08:59:21.664840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-594-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inverse proportion can be recognised graphically."@en ;
  dcterms:modified "2026-02-12T08:59:21.664847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-594-2
  a curric:KeyLearningPoint ;
  rdfs:label "The equation of an inverse proportion graph is of the form y = k/x"@en ;
  dcterms:modified "2026-02-12T08:59:21.664852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-594-3
  a curric:KeyLearningPoint ;
  rdfs:label "An alternative way of writing the equation is y α 1/x"@en ;
  dcterms:modified "2026-02-12T08:59:21.664857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-708-1
  a curric:KeyLearningPoint ;
  rdfs:label "The trigonometric ratios for 45° can be calculated using a square"@en ;
  dcterms:modified "2026-02-12T08:59:21.664861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-708-2
  a curric:KeyLearningPoint ;
  rdfs:label "The square should have lengths of 1 unit"@en ;
  dcterms:modified "2026-02-12T08:59:21.664866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-708-3
  a curric:KeyLearningPoint ;
  rdfs:label """By splitting the square into two right-angled triangles, you can calculate the ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-708-4
  a curric:KeyLearningPoint ;
  rdfs:label "The ratios for 0° and 90° can be reasoned"@en ;
  dcterms:modified "2026-02-12T08:59:21.664875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-638-1
  a curric:KeyLearningPoint ;
  rdfs:label "A protractor is used to draw angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.665092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-638-2
  a curric:KeyLearningPoint ;
  rdfs:label "A protractor is used to measure the size of angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.665098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-638-3
  a curric:KeyLearningPoint ;
  rdfs:label "A protractor measures angles in degrees."@en ;
  dcterms:modified "2026-02-12T08:59:21.665103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-551-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data can be hard to compare when presented in differing formats."@en ;
  dcterms:modified "2026-02-12T08:59:21.665108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-551-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being able to convert/interpret differing representations is useful."@en ;
  dcterms:modified "2026-02-12T08:59:21.665112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-551-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to identify the most efficient form for the data to be in to compare it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-536-1
  a curric:KeyLearningPoint ;
  rdfs:label "The graph can be used to estimate a frequency at a given time"@en ;
  dcterms:modified "2026-02-12T08:59:21.665122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-536-2
  a curric:KeyLearningPoint ;
  rdfs:label "Time series graphs can help us spot underlying trends or systematic patterns"@en ;
  dcterms:modified "2026-02-12T08:59:21.665126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-536-3
  a curric:KeyLearningPoint ;
  rdfs:label """These trends can be interpreted in context and the context may explain the pattern seen"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-826-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing two angles and the length between them in the triangle and image, you can prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-826-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angle pairs must be identical."@en ;
  dcterms:modified "2026-02-12T08:59:21.665142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-826-3
  a curric:KeyLearningPoint ;
  rdfs:label "This rule is derived from the SAS criteria for congruence."@en ;
  dcterms:modified "2026-02-12T08:59:21.665147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-669-1
  a curric:KeyLearningPoint ;
  rdfs:label "Circle theorems can be used in situations involving circles"@en ;
  dcterms:modified "2026-02-12T08:59:21.665151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-669-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is not always obvious that a circle theorem can be used"@en ;
  dcterms:modified "2026-02-12T08:59:21.665158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes you may wish to add more to a diagram in order to deduce more information"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-556-1
  a curric:KeyLearningPoint ;
  rdfs:label "A cumulative frequency has values read in the same way as a line graph"@en ;
  dcterms:modified "2026-02-12T08:59:21.665167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-556-2
  a curric:KeyLearningPoint ;
  rdfs:label "The median is the 50th percentile"@en ;
  dcterms:modified "2026-02-12T08:59:21.665172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-556-3
  a curric:KeyLearningPoint ;
  rdfs:label "The lower quartile is the 25th percentile"@en ;
  dcterms:modified "2026-02-12T08:59:21.665176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-556-4
  a curric:KeyLearningPoint ;
  rdfs:label "The upper quartile is the 75th percentile"@en ;
  dcterms:modified "2026-02-12T08:59:21.665181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-556-5
  a curric:KeyLearningPoint ;
  rdfs:label "Other percentiles can also be found"@en ;
  dcterms:modified "2026-02-12T08:59:21.665186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-604-1
  a curric:KeyLearningPoint ;
  rdfs:label """A table of values can be useful to identify coordinate pairs which satisfy the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-604-2
  a curric:KeyLearningPoint ;
  rdfs:label "By substituting the values for x, you can calculate corresponding values for y."@en ;
  dcterms:modified "2026-02-12T08:59:21.665195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-604-3
  a curric:KeyLearningPoint ;
  rdfs:label """If used correctly, your calculator can be a powerful tool to speed up calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-532-1
  a curric:KeyLearningPoint ;
  rdfs:label "When a linear trend can be identified, you can draw a line of best fit."@en ;
  dcterms:modified "2026-02-12T08:59:21.665429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-532-2
  a curric:KeyLearningPoint ;
  rdfs:label "The line of best fit should represent the trend of the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.665433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-532-3
  a curric:KeyLearningPoint ;
  rdfs:label "The line of best fit can be used to estimate the values of a data point."@en ;
  dcterms:modified "2026-02-12T08:59:21.665438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-532-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lines of best fit should only be used to estimate the dependent variable."@en ;
  dcterms:modified "2026-02-12T08:59:21.665442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-537-1
  a curric:KeyLearningPoint ;
  rdfs:label "Errors in drawing the graph will produce incorrect conclusions"@en ;
  dcterms:modified "2026-02-12T08:59:21.665447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-537-2
  a curric:KeyLearningPoint ;
  rdfs:label "Outliers may just be unusual results"@en ;
  dcterms:modified "2026-02-12T08:59:21.665451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-537-3
  a curric:KeyLearningPoint ;
  rdfs:label "These types of graphs are widely used in the media and can be misinterpreted"@en ;
  dcterms:modified "2026-02-12T08:59:21.665456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-702-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any line segment can be turned into a right-angled triangle by adding two lines which meet at 90°"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Calculating the horizontal distance gives the length of one side"@en ;
  dcterms:modified "2026-02-12T08:59:21.665465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-702-3
  a curric:KeyLearningPoint ;
  rdfs:label "Calculating the vertical distance gives the length of the other side"@en ;
  dcterms:modified "2026-02-12T08:59:21.665472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-702-4
  a curric:KeyLearningPoint ;
  rdfs:label """These two shorter sides lengths can be used to calculate the length of the line segment"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-702-5
  a curric:KeyLearningPoint ;
  rdfs:label "This can be done using Pythagoras' theorem"@en ;
  dcterms:modified "2026-02-12T08:59:21.665482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-654-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each length in the shape is multiplied by the scale factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.665486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-654-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each vertex in the object is a given distance from the centre of enlargement."@en ;
  dcterms:modified "2026-02-12T08:59:21.665491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-654-3
  a curric:KeyLearningPoint ;
  rdfs:label """This distance is also multiplied by the scale factor to give the distance of the image's vertex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-654-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative scale factor produces an image that is the other side of centre of enlargement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-654-5
  a curric:KeyLearningPoint ;
  rdfs:label "To enlarge, you need the centre of enlargement and a scale factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.665506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-718-1
  a curric:KeyLearningPoint ;
  rdfs:label """The formula for the area of a right-angled triangle is 0.5 x base x perpendicular height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-718-2
  a curric:KeyLearningPoint ;
  rdfs:label """With an equilateral or isosceles triangle, you can use Pythagoras' theorem to find the height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-718-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you know one of the base angles, you can use the sine ratio to find the perpendicular height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-718-4
  a curric:KeyLearningPoint ;
  rdfs:label "Doing this leads to the formula 0.5absinC"@en ;
  dcterms:modified "2026-02-12T08:59:21.665525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-840-1
  a curric:KeyLearningPoint ;
  rdfs:label "Priority of operations still apply."@en ;
  dcterms:modified "2026-02-12T08:59:21.665530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-840-2
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms can be collected."@en ;
  dcterms:modified "2026-02-12T08:59:21.665534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-840-3
  a curric:KeyLearningPoint ;
  rdfs:label "The vectors can be sketched and the resultant shown."@en ;
  dcterms:modified "2026-02-12T08:59:21.665538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-827-1
  a curric:KeyLearningPoint ;
  rdfs:label """For a right-angled triangle, you need the hypotenuse and one other side length to prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-827-2
  a curric:KeyLearningPoint ;
  rdfs:label "Right-angled triangles, by definition, have a right-angle."@en ;
  dcterms:modified "2026-02-12T08:59:21.665918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-827-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a special relationship between the sides in a right-angled triangle."@en ;
  dcterms:modified "2026-02-12T08:59:21.665923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-818-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct proportion can be used in a number of contexts."@en ;
  dcterms:modified "2026-02-12T08:59:21.665927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-818-2
  a curric:KeyLearningPoint ;
  rdfs:label "One context is converting compound measure."@en ;
  dcterms:modified "2026-02-12T08:59:21.665932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-818-3
  a curric:KeyLearningPoint ;
  rdfs:label "Another is currency conversion."@en ;
  dcterms:modified "2026-02-12T08:59:21.665941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-818-4
  a curric:KeyLearningPoint ;
  rdfs:label "Regardless of the context, if one quantity is zero, the other must be as well."@en ;
  dcterms:modified "2026-02-12T08:59:21.665946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-818-5
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to be able to recognise which contexts involve direct proportion."@en ;
  dcterms:modified "2026-02-12T08:59:21.665950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-664-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theorem is a statement that can be demonstrated to be true by accepted mathematical operations and arguments"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-664-2
  a curric:KeyLearningPoint ;
  rdfs:label """Theorems can be thought of as puzzles to solve, you are showing how to find a result"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-664-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to use this theorem, you may need to draw a diagram or add more information to an existing one"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7243-1
  a curric:KeyLearningPoint ;
  rdfs:label """By understanding what changes and what is invariant, you can determine whether a transformation has occurred."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7243-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes you might need to persevere in order to find the right transformation(s)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7243-3
  a curric:KeyLearningPoint ;
  rdfs:label "You may be able to check your deductions by carrying out the transformation."@en ;
  dcterms:modified "2026-02-12T08:59:21.665977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-631-1
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of a sphere can be found by displacement."@en ;
  dcterms:modified "2026-02-12T08:59:21.666964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Putting a sphere into a cylinder filled with water displaces the water."@en ;
  dcterms:modified "2026-02-12T08:59:21.666971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-631-3
  a curric:KeyLearningPoint ;
