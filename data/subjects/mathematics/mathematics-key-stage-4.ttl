  dcterms:modified "2026-02-12T08:59:21.670123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-612-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple ways to find the area of compound shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.670127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-612-2
  a curric:KeyLearningPoint ;
