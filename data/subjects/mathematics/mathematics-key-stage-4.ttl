  dcterms:modified "2026-02-12T08:59:21.688951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7818-2
  a curric:KeyLearningPoint ;
  rdfs:label "The problem asks for these constructions within the context of the question"@en ;
  dcterms:modified "2026-02-12T08:59:21.688958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7818-3
  a curric:KeyLearningPoint ;
  rdfs:label "All construction lines should be left on the diagram to show your working"@en ;
  dcterms:modified "2026-02-12T08:59:21.688963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-780-1
  a curric:KeyLearningPoint ;
  rdfs:label "Substituting values can reveal whether the conjecture is wrong."@en ;
  dcterms:modified "2026-02-12T08:59:21.688968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-780-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is referred to as disproving."@en ;
  dcterms:modified "2026-02-12T08:59:21.688972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-780-3
  a curric:KeyLearningPoint ;
  rdfs:label "A proof requires all possible cases to be considered and accounted for."@en ;
  dcterms:modified "2026-02-12T08:59:21.688976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-483-1
  a curric:KeyLearningPoint ;
  rdfs:label """When one equation is quadratic it will only be possible to eliminate the linear variable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-483-2
  a curric:KeyLearningPoint ;
  rdfs:label "Doing so produces a third equation which is quadratic."@en ;
  dcterms:modified "2026-02-12T08:59:21.688986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-483-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can use any of your methods for solving a quadratic to find possible solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-483-4
  a curric:KeyLearningPoint ;
  rdfs:label """These values need to be substituted into one of the original equations to find its pair."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-483-5
  a curric:KeyLearningPoint ;
  rdfs:label """If your quadratic has two valid solutions then you will have two pairs of solutions to your simultaneous equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Average speed can be calculated by dividing the distance travelled by the time taken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-743-2
  a curric:KeyLearningPoint ;
