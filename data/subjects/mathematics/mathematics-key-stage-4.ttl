<https://w3id.org/uk/oak/curriculum/oakcurriculum/mathematics-key-stage-4>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Mathematics KS4 Instance Data"@en ;
  dc:title "Oak Curriculum Data - Mathematics KS4 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for Mathematics KS4."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/mathematics-key-stage-4/0.1.0> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Mathematics KS4, including exam board-specific unit variants and lesson sequences."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2026-02-11T00:00:00Z"^^xsd:dateTime ;
  dcterms:modified "2026-02-12T08:59:50.018088Z"^^xsd:dateTime ;
