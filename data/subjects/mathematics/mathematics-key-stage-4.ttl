oakcurric:keylearningpoint-lesson-657-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the shapes look identical but are in different places, one may be a translation of the other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-618-1
  a curric:KeyLearningPoint ;
