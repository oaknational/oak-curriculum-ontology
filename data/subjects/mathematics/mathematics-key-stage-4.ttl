  dcterms:modified "2026-02-12T08:59:21.672634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7690-2
  a curric:KeyLearningPoint ;
  rdfs:label "Constraints exist for a variety of reasons, such as cost or supply limitations"@en ;
  dcterms:modified "2026-02-12T08:59:21.672639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7690-3
  a curric:KeyLearningPoint ;
  rdfs:label "Finding a set of possible solutions allows you to work within the constraints"@en ;
  dcterms:modified "2026-02-12T08:59:21.672643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-846-1
  a curric:KeyLearningPoint ;
  rdfs:label "When constructing the perpendicular, you are constructing a 90° angle"@en ;
  dcterms:modified "2026-02-12T08:59:21.672648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-846-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bisecting a 90° angle results in two angles, each measuring 45°"@en ;
  dcterms:modified "2026-02-12T08:59:21.672652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-670-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pair of compasses can be used to draw a circle with a particular radius."@en ;
  dcterms:modified "2026-02-12T08:59:21.672657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-670-2
  a curric:KeyLearningPoint ;
  rdfs:label """A ruler and protractor can be used to accurately draw a triangle given enough information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-670-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ruler and a pair of compasses can also be used to accurately draw a triangle where the side lengths are known."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-526-1
  a curric:KeyLearningPoint ;
  rdfs:label "A data collection sheet should be suitable for the type and volume of data."@en ;
  dcterms:modified "2026-02-12T08:59:21.672712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-526-2
  a curric:KeyLearningPoint ;
