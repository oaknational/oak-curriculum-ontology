oakcurric:keylearningpoint-lesson-711-1
  a curric:KeyLearningPoint ;
  rdfs:label """If angles are involved, then you may wish to apply trigonometric ratios to the 3D problem"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689964Z"^^xsd:dateTime .

