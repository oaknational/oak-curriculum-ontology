  dcterms:modified "2026-02-12T08:59:21.670093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-576-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ratio table can also be used to help show the multiplicative relationship."@en ;
