  dcterms:modified "2026-02-12T08:59:21.750753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-775-3
  a curric:KeyLearningPoint ;
  rdfs:label "An input can be substituted in and the numerical output found."@en ;
  dcterms:modified "2026-02-12T08:59:21.750757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25097-1
  a curric:KeyLearningPoint ;
  rdfs:label "A quadratic sequence does not have a common difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.750761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25097-2
  a curric:KeyLearningPoint ;
  rdfs:label "The second differences between terms are equal."@en ;
  dcterms:modified "2026-02-12T08:59:21.750764Z"^^xsd:dateTime .

