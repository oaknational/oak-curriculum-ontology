# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-457-1
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms and their coefficients can be identified."@en ;
  dcterms:modified "2026-02-12T08:59:21.482439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-457-2
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms can be represented using a bar model."@en ;
  dcterms:modified "2026-02-12T08:59:21.482443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-457-3
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms can be collected together, paying careful attention to coefficients."@en ;
  dcterms:modified "2026-02-12T08:59:21.482449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-457-4
  a curric:KeyLearningPoint ;
  rdfs:label "Expressions are easier to read once you have collected all the like terms."@en ;
  dcterms:modified "2026-02-12T08:59:21.482453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-508-1
  a curric:KeyLearningPoint ;
  rdfs:label "When dividing two terms, you can sometimes write this more simply."@en ;
  dcterms:modified "2026-02-12T08:59:21.612891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-508-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the powers have the same base, then the powers can be combined into a single power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-508-3
  a curric:KeyLearningPoint ;
  rdfs:label "The exponent or index of the new power reflects this combination."@en ;
  dcterms:modified "2026-02-12T08:59:21.612906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-508-4
  a curric:KeyLearningPoint ;
  rdfs:label "By studying the structure of division, you can see how the index will change."@en ;
  dcterms:modified "2026-02-12T08:59:21.612912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-508-5
  a curric:KeyLearningPoint ;
  rdfs:label "a^b ÷ a^c = a^(b−c)"@en ;
  dcterms:modified "2026-02-12T08:59:21.612919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-511-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is difficult to read very large numbers, due to the number of digits involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-511-2
  a curric:KeyLearningPoint ;
  rdfs:label "It can be more efficient to write these very large numbers in standard form.."@en ;
  dcterms:modified "2026-02-12T08:59:21.624372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-511-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a convention for standard form."@en ;
  dcterms:modified "2026-02-12T08:59:21.624377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-516-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equivalent fractions can be used to calculate the quotient when dividing with two numbers represented in standard form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-516-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using your knowledge of the index laws, you can combine powers with the same base."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-516-3
  a curric:KeyLearningPoint ;
  rdfs:label "Standard form calculations can be done using a calculator."@en ;
  dcterms:modified "2026-02-12T08:59:21.626322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-458-1
  a curric:KeyLearningPoint ;
  rdfs:label "Expressions and formulae in context can be evaluated for particular values."@en ;
  dcterms:modified "2026-02-12T08:59:21.629142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-458-2
  a curric:KeyLearningPoint ;
  rdfs:label "Changing the value of the variable changes the overall value of the expression."@en ;
  dcterms:modified "2026-02-12T08:59:21.629147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-458-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring what value gives a particular solution can help you to understand the expression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-458-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expressions may have multiple variables and you can substitute some or all of them for numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-491-1
  a curric:KeyLearningPoint ;
  rdfs:label """In all of these representations a single multiplier can be used to find a percentage decrease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-491-2
  a curric:KeyLearningPoint ;
  rdfs:label "Representation can help when you are not using a calculator."@en ;
  dcterms:modified "2026-02-12T08:59:21.634513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-491-3
  a curric:KeyLearningPoint ;
  rdfs:label "A multiplier is significantly faster when using a calculator."@en ;
  dcterms:modified "2026-02-12T08:59:21.634518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-491-4
  a curric:KeyLearningPoint ;
  rdfs:label "To decrease you are going below the original amount."@en ;
  dcterms:modified "2026-02-12T08:59:21.634525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-642-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many shapes have similar properties."@en ;
  dcterms:modified "2026-02-12T08:59:21.653981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-642-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is not always clear which shape is being described so more details may be needed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Knowing the properties of shapes can help you solve more complex problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.653993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-650-1
  a curric:KeyLearningPoint ;
  rdfs:label "It can be helpful to choose a vertex and translate that."@en ;
  dcterms:modified "2026-02-12T08:59:21.653998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-650-2
  a curric:KeyLearningPoint ;
  rdfs:label "Once all the vertices have been translated, the image can be drawn."@en ;
  dcterms:modified "2026-02-12T08:59:21.654002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-650-3
  a curric:KeyLearningPoint ;
  rdfs:label "The image and the object should be congruent."@en ;
  dcterms:modified "2026-02-12T08:59:21.654006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-650-4
  a curric:KeyLearningPoint ;
  rdfs:label "To translate, you need to know the distance left/right and up/down to move."@en ;
  dcterms:modified "2026-02-12T08:59:21.654011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-610-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before calculating perimeter, consider the shape and check you know the required lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-610-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is not necessary to know every side length."@en ;
  dcterms:modified "2026-02-12T08:59:21.654729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-610-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes you can deduce the sum of a subset of side lengths."@en ;
  dcterms:modified "2026-02-12T08:59:21.654733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-610-4
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying where you can be more efficient can make calculations simpler."@en ;
  dcterms:modified "2026-02-12T08:59:21.654740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-524-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are situations in which you may not know the size of a population."@en ;
  dcterms:modified "2026-02-12T08:59:21.654745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-524-2
  a curric:KeyLearningPoint ;
  rdfs:label "The capture/recapture sampling method allows you to estimate population size."@en ;
  dcterms:modified "2026-02-12T08:59:21.654750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-524-3
  a curric:KeyLearningPoint ;
  rdfs:label "The size of the initial sample affects how accurate your estimation will be."@en ;
  dcterms:modified "2026-02-12T08:59:21.654755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-838-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parallel vectors have the same gradient."@en ;
  dcterms:modified "2026-02-12T08:59:21.654928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-838-2
  a curric:KeyLearningPoint ;
  rdfs:label "In algebraic form, this may be seen when one vector is a multiple of another."@en ;
  dcterms:modified "2026-02-12T08:59:21.654933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-838-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vectors with opposite signs are parallel but act in opposite directions."@en ;
  dcterms:modified "2026-02-12T08:59:21.654938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-820-1
  a curric:KeyLearningPoint ;
  rdfs:label "An enlargement means the object and image are similar."@en ;
  dcterms:modified "2026-02-12T08:59:21.654943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-820-2
  a curric:KeyLearningPoint ;
  rdfs:label "All lengths in the object have been multiplied by the scale factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.654947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-820-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using index laws, this means the area has been multiplied by the scale factor squared."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two lines are parallel if they are equidistant and never touch."@en ;
  dcterms:modified "2026-02-12T08:59:21.654956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-588-2
  a curric:KeyLearningPoint ;
  rdfs:label "For linear graphs, the rate of change is constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.654961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-588-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the gradients are the same then the linear graphs may be parallel."@en ;
  dcterms:modified "2026-02-12T08:59:21.654965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-588-4
  a curric:KeyLearningPoint ;
  rdfs:label "The y-intercepts must be different, otherwise the lines are the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.654970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-559-1
  a curric:KeyLearningPoint ;
  rdfs:label "The interquartile range tells us how spread out the middle 50% of the data is"@en ;
  dcterms:modified "2026-02-12T08:59:21.654974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-559-2
  a curric:KeyLearningPoint ;
  rdfs:label "This can be seen visually with a box plot"@en ;
  dcterms:modified "2026-02-12T08:59:21.654979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-559-3
  a curric:KeyLearningPoint ;
  rdfs:label "Box plots and cumulative frequency graphs can be compared"@en ;
  dcterms:modified "2026-02-12T08:59:21.654986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-559-4
  a curric:KeyLearningPoint ;
  rdfs:label "This comparison involves the median and interquartile range"@en ;
  dcterms:modified "2026-02-12T08:59:21.654995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-649-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tracing paper can be a helpful tool to perform a rotation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-649-2
  a curric:KeyLearningPoint ;
  rdfs:label "The image and the object should be congruent."@en ;
  dcterms:modified "2026-02-12T08:59:21.655005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Unless a full rotation occurs, the object and its image will not have the same orientation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-649-4
  a curric:KeyLearningPoint ;
  rdfs:label "Clockwise is the direction the hands of a clock travel in."@en ;
  dcterms:modified "2026-02-12T08:59:21.655014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-649-5
  a curric:KeyLearningPoint ;
  rdfs:label "To rotate, you need the centre, direction and angle of rotation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20049-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are other methods to find the solutions of a quadratic equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20049-2
  a curric:KeyLearningPoint ;
  rdfs:label "One of these methods is called completing the square."@en ;
  dcterms:modified "2026-02-12T08:59:21.655027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Completing the square is useful when the quadratic cannot be easily factorised."@en ;
  dcterms:modified "2026-02-12T08:59:21.655035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20049-4
  a curric:KeyLearningPoint ;
  rdfs:label """Quadratic equations of the form $$ax^2 + bx + c = 0$$ (where $$a$$ ≠ 1) can be solved by completing the square."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-630-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is a formula for the surface area of a sphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.655044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-630-2
  a curric:KeyLearningPoint ;
  rdfs:label "Demonstration allows you to see that this formula works."@en ;
  dcterms:modified "2026-02-12T08:59:21.655049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-630-3
  a curric:KeyLearningPoint ;
  rdfs:label """The formula can be used to calculate a missing measurement when the surface area is known."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-614-1
  a curric:KeyLearningPoint ;
  rdfs:label "A chord splits the circle into two uneven pieces."@en ;
  dcterms:modified "2026-02-12T08:59:21.656239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-614-2
  a curric:KeyLearningPoint ;
  rdfs:label "The smaller piece is the minor segment and the larger is the major segment."@en ;
  dcterms:modified "2026-02-12T08:59:21.656244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-614-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sectors look familiar as you broke a circle into sectors to draw a pie chart."@en ;
  dcterms:modified "2026-02-12T08:59:21.656248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-614-4
  a curric:KeyLearningPoint ;
  rdfs:label "The circumference of a circle is found using C = πd or C = 2πr"@en ;
  dcterms:modified "2026-02-12T08:59:21.656255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-614-5
  a curric:KeyLearningPoint ;
  rdfs:label "The area of a circle is found using A = πr²"@en ;
  dcterms:modified "2026-02-12T08:59:21.656260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-723-1
  a curric:KeyLearningPoint ;
  rdfs:label "Outcomes can be listed systematically using an appropriate representation"@en ;
  dcterms:modified "2026-02-12T08:59:21.656265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-723-2
  a curric:KeyLearningPoint ;
  rdfs:label "Outcomes can be placed on the probability scale"@en ;
  dcterms:modified "2026-02-12T08:59:21.656274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-723-3
  a curric:KeyLearningPoint ;
  rdfs:label """A probability of 0 means the outcome is impossible and a probability of 1 means the outcome is certain"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-482-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use your knowledge of linear graphs to draw the graphs of both equations on the same axes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-482-2
  a curric:KeyLearningPoint ;
  rdfs:label "If there exists a solution, the point of intersection is that solution."@en ;
  dcterms:modified "2026-02-12T08:59:21.656288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-482-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the lines are parallel then there are no solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.656293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-482-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the lines lie on top of each other, there are infinitely many solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.656297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-816-1
  a curric:KeyLearningPoint ;
  rdfs:label """By comparing the graphs to the algebraic approach, you can compare the representations of the solution set"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-816-2
  a curric:KeyLearningPoint ;
  rdfs:label "The point of intersection is an important point"@en ;
  dcterms:modified "2026-02-12T08:59:21.656306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-821-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can calculate the scale factor from the two areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.656314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-821-2
  a curric:KeyLearningPoint ;
  rdfs:label "Having calculated the scale factor, you can find missing lengths."@en ;
  dcterms:modified "2026-02-12T08:59:21.656318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-855-1
  a curric:KeyLearningPoint ;
  rdfs:label "Desmos is an effective tool for showing the effects of this transformation"@en ;
  dcterms:modified "2026-02-12T08:59:21.656572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-855-2
  a curric:KeyLearningPoint ;
  rdfs:label "The actual function itself does not need to be known"@en ;
  dcterms:modified "2026-02-12T08:59:21.656576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-855-3
  a curric:KeyLearningPoint ;
  rdfs:label "The graph is transformed by a horizontal translation in the opposite direction"@en ;
  dcterms:modified "2026-02-12T08:59:21.656581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-713-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes an answer may be best left in an exact form"@en ;
  dcterms:modified "2026-02-12T08:59:21.656588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-713-2
  a curric:KeyLearningPoint ;
  rdfs:label """When dealing with right-angled trigonometry, it is important to look at the information you have and can deduce"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-713-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consider whether Pythagoras' theorem or trigonometric ratios are more efficient to use"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-713-4
  a curric:KeyLearningPoint ;
  rdfs:label "All models are wrong, but some models are useful"@en ;
  dcterms:modified "2026-02-12T08:59:21.656602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7688-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different speed/time graphs can be interpreted and compared."@en ;
  dcterms:modified "2026-02-12T08:59:21.656606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7688-2
  a curric:KeyLearningPoint ;
  rdfs:label "The area under the graph can also be interpreted in context."@en ;
  dcterms:modified "2026-02-12T08:59:21.656611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Circle theorems can be demonstrated using coordinate geometry."@en ;
  dcterms:modified "2026-02-12T08:59:21.656646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-716-1
  a curric:KeyLearningPoint ;
  rdfs:label "The unit circle can help you predict what the tangent graph will look like"@en ;
  dcterms:modified "2026-02-12T08:59:21.656651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-716-2
  a curric:KeyLearningPoint ;
  rdfs:label "The tangent graph has asymptotes"@en ;
  dcterms:modified "2026-02-12T08:59:21.656656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-716-3
  a curric:KeyLearningPoint ;
  rdfs:label "The trigonometric functions have different periods."@en ;
  dcterms:modified "2026-02-12T08:59:21.656661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-740-1
  a curric:KeyLearningPoint ;
  rdfs:label "Probabilities may appear in unfamiliar contexts"@en ;
  dcterms:modified "2026-02-12T08:59:21.657039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-740-2
  a curric:KeyLearningPoint ;
  rdfs:label """Probabilities may require a strong knowledge of converting between fractions, decimals and percentages"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-740-3
  a curric:KeyLearningPoint ;
  rdfs:label """Selecting an appropriate and efficient method for solving the problem comes from evaluating methods"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-740-4
  a curric:KeyLearningPoint ;
  rdfs:label "A clear, logical, structured argument is much easier to follow and understand"@en ;
  dcterms:modified "2026-02-12T08:59:21.657052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-534-1
  a curric:KeyLearningPoint ;
  rdfs:label "Outliers can be visually seen on a scatter graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.657222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-534-2
  a curric:KeyLearningPoint ;
  rdfs:label "Outliers do not necessarily occur at the start/end of the data set."@en ;
  dcterms:modified "2026-02-12T08:59:21.657226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-534-3
  a curric:KeyLearningPoint ;
  rdfs:label """Outliers must be carefully considered and only removed if they were recorded in error."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-763-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct proportion can be recognised graphically."@en ;
  dcterms:modified "2026-02-12T08:59:21.657238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-763-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direct proportion graph is always a straight line through the origin."@en ;
  dcterms:modified "2026-02-12T08:59:21.657243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-763-3
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient is the constant of proportionality."@en ;
  dcterms:modified "2026-02-12T08:59:21.657248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-763-4
  a curric:KeyLearningPoint ;
  rdfs:label """The equation of the line can be found and this is the algebraic model of the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-535-1
  a curric:KeyLearningPoint ;
  rdfs:label "Time series graphs are a visual representation"@en ;
  dcterms:modified "2026-02-12T08:59:21.657283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-535-2
  a curric:KeyLearningPoint ;
  rdfs:label "Time series graphs plot frequency over time"@en ;
  dcterms:modified "2026-02-12T08:59:21.657287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-535-3
  a curric:KeyLearningPoint ;
  rdfs:label "Consecutive points are joined by straight line segments"@en ;
  dcterms:modified "2026-02-12T08:59:21.657292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5464-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different representations of the same data set give a fuller picture"@en ;
  dcterms:modified "2026-02-12T08:59:21.657296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5464-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to identify what features are used to analyse a data set"@en ;
  dcterms:modified "2026-02-12T08:59:21.657301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5464-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to identify what features are used to compare two data sets"@en ;
  dcterms:modified "2026-02-12T08:59:21.657308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equations can be constructed when there is a known relationship between the probabilities of exhaustive events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-725-2
  a curric:KeyLearningPoint ;
  rdfs:label "Equations can be manipulated and solved to find missing probabilities"@en ;
  dcterms:modified "2026-02-12T08:59:21.657317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-725-3
  a curric:KeyLearningPoint ;
  rdfs:label """Algebraic statements can be created regardless of the way the probabilities are displayed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-640-1
  a curric:KeyLearningPoint ;
  rdfs:label """Corresponding angles are equal if they are on parallel lines and the same side of the transversal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alternate angles are equal if they are on parallel lines and the opposite sides of the transversal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Supplementary co-interior angles sum to 180°"@en ;
  dcterms:modified "2026-02-12T08:59:21.657335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-696-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to apply the inverse operations in the right order."@en ;
  dcterms:modified "2026-02-12T08:59:21.658349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-696-2
  a curric:KeyLearningPoint ;
  rdfs:label """The subject can be thought of as the unknown you are trying to find the value of."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instead of finding a value though, you will find an expression that the unknown is equal to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-753-1
  a curric:KeyLearningPoint ;
  rdfs:label """On a distance-time graph, a horizontal line means no distance was travelled for that time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-753-2
  a curric:KeyLearningPoint ;
  rdfs:label "A slanted line means that the distance from the start is changing over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.658373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-753-3
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled divided by the time taken gives the speed."@en ;
  dcterms:modified "2026-02-12T08:59:21.658377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-753-4
  a curric:KeyLearningPoint ;
  rdfs:label """You find this by considering the change in distance with respect to the change in time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-753-5
  a curric:KeyLearningPoint ;
  rdfs:label "This is how you find the gradient of the line, which is also the speed."@en ;
  dcterms:modified "2026-02-12T08:59:21.658386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-704-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sine ratio involves the hypotenuse, opposite and the angle"@en ;
  dcterms:modified "2026-02-12T08:59:21.658391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-704-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the hypotenuse and the size of the angle, you can use the sine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-704-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the opposite and the size of the angle, you can use the sine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-704-4
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the hypotenuse and opposite, you can use the sine ratio"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-766-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct proportion equations are of the form y = kx"@en ;
  dcterms:modified "2026-02-12T08:59:21.658409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-766-2
  a curric:KeyLearningPoint ;
  rdfs:label "k is the constant of proportionality and it is also the gradient of the graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.658413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-766-3
  a curric:KeyLearningPoint ;
  rdfs:label "To find the gradient, k, you can use two sets of coordinates (pairs of values)."@en ;
  dcterms:modified "2026-02-12T08:59:21.658418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-592-1
  a curric:KeyLearningPoint ;
