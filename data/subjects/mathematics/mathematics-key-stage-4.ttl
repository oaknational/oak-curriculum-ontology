  dcterms:modified "2026-02-12T08:59:21.667899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A table of values can be useful to identify coordinate pairs which satisfy the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667904Z"^^xsd:dateTime .

