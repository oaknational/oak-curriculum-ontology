  dcterms:modified "2026-02-12T08:59:21.666996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writing an algebraic statement about surface area/volume can be done from a diagram."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-563-1
  a curric:KeyLearningPoint ;
  rdfs:label "The mean can be found using a histogram"@en ;
  dcterms:modified "2026-02-12T08:59:21.667005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-563-2
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be found using a histogram"@en ;
  dcterms:modified "2026-02-12T08:59:21.667010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-563-3
  a curric:KeyLearningPoint ;
  rdfs:label "An estimate for the frequency within a given data range can be found"@en ;
  dcterms:modified "2026-02-12T08:59:21.667017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-548-1
  a curric:KeyLearningPoint ;
  rdfs:label "Certain data is suitable for a composite bar chart or bar-line chart."@en ;
  dcterms:modified "2026-02-12T08:59:21.667526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-548-2
  a curric:KeyLearningPoint ;
  rdfs:label "The shape of the graph can be estimated from the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.667530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-548-3
  a curric:KeyLearningPoint ;
  rdfs:label "For larger data sets, technology can make constructing graphs quicker."@en ;
  dcterms:modified "2026-02-12T08:59:21.667535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-657-1
  a curric:KeyLearningPoint ;
