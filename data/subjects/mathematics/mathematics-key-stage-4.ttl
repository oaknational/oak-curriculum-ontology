# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-systematically
  a curric:Keyword ;
  schema:name "systematically"@en ;
  schema:description """when something is done systematically it is done in a way that is done according to an agreed set of methods or organised plan"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790007Z"^^xsd:dateTime .

oakcurric:keyword-like-terms
  a curric:Keyword ;
  schema:name "Like terms"@en ;
  schema:description """Like terms are terms that have the same set of variables and corresponding exponents."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790926Z"^^xsd:dateTime .

oakcurric:keyword-simplify
  a curric:Keyword ;
  schema:name "Simplify"@en ;
  schema:description """Simplifying is to write an expression in a more efficient and compact form without affecting the value of the original expression. Fully simplifying means the expression cannot be simplified further."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790930Z"^^xsd:dateTime .

oakcurric:keyword-quantitative
  a curric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "data that is made up of numbers"@en ;
  dcterms:modified "2026-02-12T08:59:15.791012Z"^^xsd:dateTime .

oakcurric:keyword-qualitative
  a curric:Keyword ;
  schema:name "qualitative"@en ;
  schema:description "data that is made up of text"@en ;
  dcterms:modified "2026-02-12T08:59:15.791016Z"^^xsd:dateTime .

oakcurric:keyword-inequality
  a curric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "inequality is when something is not shared evenly between everyone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791205Z"^^xsd:dateTime .

oakcurric:keyword-solution
  a curric:Keyword ;
  schema:name "solution"@en ;
  schema:description "A solution is a way of solving a problem."@en ;
  dcterms:modified "2026-02-12T08:59:15.791940Z"^^xsd:dateTime .

oakcurric:keyword-bearing
  a curric:Keyword ;
  schema:name "bearing"@en ;
  schema:description """an angle measured clockwise from north 0° to 359°, used to orientate attribute symbols to show direction"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792184Z"^^xsd:dateTime .

oakcurric:keyword-radical
  a curric:Keyword ;
  schema:name "radical"@en ;
  schema:description "radical is believing or expressing extreme change"@en ;
  dcterms:modified "2026-02-12T08:59:15.792687Z"^^xsd:dateTime .

oakcurric:keyword-equation
  a curric:Keyword ;
  schema:name "Equation"@en ;
  schema:description "An equation is used to show that one number or calculation is equal to another."@en ;
  dcterms:modified "2026-02-12T08:59:15.792747Z"^^xsd:dateTime .

oakcurric:keyword-identity
  a curric:Keyword ;
  schema:name "identity"@en ;
  schema:description """who a person is, or the qualities of a person or group that make them different from others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792801Z"^^xsd:dateTime .

oakcurric:keyword-expression
  a curric:Keyword ;
  schema:name "expression"@en ;
  schema:description """the ability to show emotions and feelings through facial movements, speech, gestures or body language"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792833Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-02-12T08:59:15.792948Z"^^xsd:dateTime .

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "Sequence"@en ;
  schema:description """A sequence is a succession of objects, diagrams or values usually formed according to a rule."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793414Z"^^xsd:dateTime .

oakcurric:keyword-term
  a curric:Keyword ;
  schema:name "Term"@en ;
  schema:description """Each number in a sequence is called a term. Each term has a position - a location in the sequence."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793420Z"^^xsd:dateTime .

oakcurric:keyword-multiple
  a curric:Keyword ;
  schema:name "Multiple"@en ;
  schema:description "The result of multiplying a number by an integer."@en ;
  dcterms:modified "2026-02-12T08:59:15.793645Z"^^xsd:dateTime .

oakcurric:keyword-pace
  a curric:Keyword ;
  schema:name "pace"@en ;
  schema:description """the speed at which a story or scene progresses. In theatre: Pace controls the rhythm of a play, balancing fast action and slower moments to maintain interest and emotional impact"""@en ;
  dcterms:modified "2026-02-12T08:59:15.793662Z"^^xsd:dateTime .

oakcurric:keyword-surface-area
  a curric:Keyword ;
  schema:name "surface area"@en ;
  schema:description "The total area of the surface of an object."@en ;
  dcterms:modified "2026-02-12T08:59:15.793667Z"^^xsd:dateTime .

oakcurric:keyword-correlation
  a curric:Keyword ;
  schema:name "correlation"@en ;
  schema:description "a relationship or pattern between two or more variables"@en ;
  dcterms:modified "2026-02-12T08:59:15.793820Z"^^xsd:dateTime .

oakcurric:keyword-vector
  a curric:Keyword ;
  schema:name "vector"@en ;
  schema:description "an organism that carries the pathogen from the host to another organism"@en ;
  dcterms:modified "2026-02-12T08:59:15.794196Z"^^xsd:dateTime .

oakcurric:keyword-population
  a curric:Keyword ;
  schema:name "population"@en ;
  schema:description "all the inhabitants of a particular place or region"@en ;
  dcterms:modified "2026-02-12T08:59:15.794489Z"^^xsd:dateTime .

oakcurric:keyword-standard-form
  a curric:Keyword ;
  schema:name "standard form"@en ;
  schema:description "A way of writing down very large or very small numbers easily; e.g. 1000 = 10³."@en ;
  dcterms:modified "2026-02-12T08:59:15.794536Z"^^xsd:dateTime .

oakcurric:keyword-plan
  a curric:Keyword ;
  schema:name "plan"@en ;
  schema:description "a framework that writers create before they write a section or whole text"@en ;
  dcterms:modified "2026-02-12T08:59:15.794890Z"^^xsd:dateTime .

oakcurric:keyword-pyramid
  a curric:Keyword ;
  schema:name "pyramid"@en ;
  schema:description """the pyramids were large stone buildings that the Ancient Egyptians buried their pharaohs in during the Old Kingdom"""@en ;
  dcterms:modified "2026-02-12T08:59:15.795341Z"^^xsd:dateTime .

oakcurric:keyword-turning-point
  a curric:Keyword ;
  schema:name "turning point"@en ;
  schema:description """a turning point in history is an idea, event, or action that leads to permanent change"""@en ;
  dcterms:modified "2026-02-12T08:59:15.796165Z"^^xsd:dateTime .

oakcurric:keyword-linear
  a curric:Keyword ;
  schema:name "linear"@en ;
  schema:description "a description for a feature (such as a settlement) that resembles a line"@en ;
  dcterms:modified "2026-02-12T08:59:15.796916Z"^^xsd:dateTime .

oakcurric:keyword-rate
  a curric:Keyword ;
  schema:name "rate"@en ;
  schema:description """a measure of the quantity, frequency or speed at which something happens or occurs"""@en ;
  dcterms:modified "2026-02-12T08:59:15.797161Z"^^xsd:dateTime .

oakcurric:keyword-imperial
  a curric:Keyword ;
  schema:name "imperial"@en ;
  schema:description "imperial refers to things or people which were part of the British Empire"@en ;
  dcterms:modified "2026-02-12T08:59:15.797487Z"^^xsd:dateTime .

oakcurric:keyword-irregular
  a curric:Keyword ;
  schema:name "irregular"@en ;
  schema:description "not conforming to a regular or predictable pattern"@en ;
  dcterms:modified "2026-02-12T08:59:15.797824Z"^^xsd:dateTime .

oakcurric:keyword-partial-product
  a curric:Keyword ;
  schema:name "partial product"@en ;
  schema:description """Any of the multiplication results that lead up to an overall multiplication result."""@en ;
  dcterms:modified "2026-02-12T08:59:15.797851Z"^^xsd:dateTime .

oakcurric:keyword-factor
  a curric:Keyword ;
  schema:name "Factor"@en ;
  schema:description "Numbers we can multiply together to get another number are known as factors."@en ;
  dcterms:modified "2026-02-12T08:59:15.798062Z"^^xsd:dateTime .

oakcurric:keyword-reflection
  a curric:Keyword ;
  schema:name "Reflection"@en ;
  schema:description "The reflection of a shape is the mirror image of a shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.798654Z"^^xsd:dateTime .

oakcurric:keyword-simplest-form
  a curric:Keyword ;
  schema:name "Simplest form"@en ;
  schema:description """When a fraction is in its simplest form, the numerator and denominator only share a common factor of one."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798741Z"^^xsd:dateTime .

oakcurric:keyword-polygon
  a curric:Keyword ;
  schema:name "Polygon"@en ;
  schema:description "A 2D shape made up of three or more straight lines."@en ;
  dcterms:modified "2026-02-12T08:59:15.798754Z"^^xsd:dateTime .

oakcurric:keyword-index
  a curric:Keyword ;
  schema:name "Index"@en ;
  schema:description """An exponent is a number positioned above and to the right of a base value. It indicates repeated multiplication. An alternative word for this is index (plural indices)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798763Z"^^xsd:dateTime .

oakcurric:keyword-coefficient
  a curric:Keyword ;
  schema:name "Coefficient"@en ;
  schema:description "A numerical coefficient is a constant multiplier of the variables in a term."@en ;
  dcterms:modified "2026-02-12T08:59:15.798767Z"^^xsd:dateTime .

oakcurric:keyword-generalisation
  a curric:Keyword ;
  schema:name "Generalisation"@en ;
  schema:description """A generalisation is a statement or rule that applies correctly to all relevant cases."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798854Z"^^xsd:dateTime .

oakcurric:keyword-mass
  a curric:Keyword ;
  schema:name "Mass"@en ;
  schema:description """Mass is a measure of how much matter something contains. It is commonly measured by how much something weighs. Mass can be measured in kilograms and grams."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798981Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "Volume"@en ;
  schema:description """Volume is the amount of space that an object takes up. In this case, the specific amount of liquid in a container. Volume can be measured in millilitres and litres."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798990Z"^^xsd:dateTime .

oakcurric:keyword-interval
  a curric:Keyword ;
  schema:name "Interval"@en ;
  schema:description """An interval is what is between two values. On a scale, intervals are shown using a small mark or line to show the space between."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799068Z"^^xsd:dateTime .

oakcurric:keyword-associative
  a curric:Keyword ;
  schema:name "associative"@en ;
  schema:description """The associative law states that it doesn't matter how you group or pair values (i.e. which we calculate first), the result is still the same. It applies for addition and multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799422Z"^^xsd:dateTime .

oakcurric:keyword-commutative
  a curric:Keyword ;
  schema:name "commutative"@en ;
  schema:description """The commutative law states that you can write the values of a calculation in a different order without changing the calculation; the result is the same. It applies for addition and multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799426Z"^^xsd:dateTime .

oakcurric:keyword-proportion
  a curric:Keyword ;
  schema:name "Proportion"@en ;
  schema:description "The proportion of a number, shape or group of objects is a part of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:15.799717Z"^^xsd:dateTime .

oakcurric:keyword-coordinates
  a curric:Keyword ;
  schema:name "Coordinates"@en ;
  schema:description "A set of values that show an exact position."@en ;
  dcterms:modified "2026-02-12T08:59:15.800335Z"^^xsd:dateTime .

oakcurric:keyword-region
  a curric:Keyword ;
  schema:name "region"@en ;
  schema:description "A region is a part of a country or the world."@en ;
  dcterms:modified "2026-02-12T08:59:15.800389Z"^^xsd:dateTime .

oakcurric:keyword-trial
  a curric:Keyword ;
  schema:name "trial"@en ;
  schema:description "an examination of evidence to decide if someone is guilty or innocent of a crime"@en ;
  dcterms:modified "2026-02-12T08:59:15.800929Z"^^xsd:dateTime .

oakcurric:keyword-pressure
  a curric:Keyword ;
  schema:name "pressure"@en ;
  schema:description "pressure is a force pushing or pressing on a given area"@en ;
  dcterms:modified "2026-02-12T08:59:15.800986Z"^^xsd:dateTime .

oakcurric:keyword-distributive-law
  a curric:Keyword ;
  schema:name "Distributive law"@en ;
  schema:description """The distributive law says that multiplying a number by a group of numbers added together is the same as doing each multiplication separately."""@en ;
  dcterms:modified "2026-02-12T08:59:15.801033Z"^^xsd:dateTime .

oakcurric:keyword-area
  a curric:Keyword ;
  schema:name "Area"@en ;
  schema:description "The measurement of a flat surface. It measures a 2D space."@en ;
  dcterms:modified "2026-02-12T08:59:15.801161Z"^^xsd:dateTime .

oakcurric:keyword-metric
  a curric:Keyword ;
  schema:name "Metric"@en ;
  schema:description "Metric is a system of measuring based mainly around the decimal system."@en ;
  dcterms:modified "2026-02-12T08:59:15.801455Z"^^xsd:dateTime .

oakcurric:keyword-associative-law
  a curric:Keyword ;
  schema:name "Associative law"@en ;
  schema:description """The associative law states that a repeated application of the operation produces the same result regardless of how pairs of values are grouped. We can group using brackets."""@en ;
  dcterms:modified "2026-02-12T08:59:15.801583Z"^^xsd:dateTime .

oakcurric:keyword-translation
  a curric:Keyword ;
  schema:name "translation"@en ;
  schema:description """converting text from one language to another while preserving the meaning and style"""@en ;
  dcterms:modified "2026-02-12T08:59:15.801731Z"^^xsd:dateTime .

oakcurric:keyword-exponential-form
  a curric:Keyword ;
  schema:name "Exponential form"@en ;
  schema:description """When a number is multiplied by itself multiple times, it can be written more simply in exponential form."""@en ;
  dcterms:modified "2026-02-12T08:59:15.802034Z"^^xsd:dateTime .

oakcurric:keyword-continuous-data
  a curric:Keyword ;
  schema:name "continuous data"@en ;
  schema:description "data that is connected to values before and after it in sequence"@en ;
  dcterms:modified "2026-02-12T08:59:15.802841Z"^^xsd:dateTime .

oakcurric:keyword-substitution
  a curric:Keyword ;
  schema:name "Substitution"@en ;
  schema:description """Substitute means to put in place of another. In Algebra, substitution can be used to replace variables with values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.803247Z"^^xsd:dateTime .

oakcurric:keyword-percentile
  a curric:Keyword ;
  schema:name "percentile"@en ;
  schema:description """the number of values within a data set that fall below a certain percentage of the total number of values"""@en ;
  dcterms:modified "2026-02-12T08:59:15.803830Z"^^xsd:dateTime .

oakcurric:keyword-sample
  a curric:Keyword ;
  schema:name "sample"@en ;
  schema:description "a selection of data from a much bigger data population"@en ;
  dcterms:modified "2026-02-12T08:59:15.803850Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description "an unfair favouritism for or against something"@en ;
  dcterms:modified "2026-02-12T08:59:15.803858Z"^^xsd:dateTime .

oakcurric:keyword-hypotenuse
  a curric:Keyword ;
  schema:name "hypotenuse"@en ;
  schema:description """A hypotenuse is the side of the right-angled triangle which is opposite the right-angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804249Z"^^xsd:dateTime .

oakcurric:keyword-pythagoras-theorem
  a curric:Keyword ;
  schema:name "Pythagoras’ theorem"@en ;
  schema:description """Pythagoras’ theorem shows that the sum of the squares of the two shorter sides of a right-angled triangle is equal to the square of its longest side (the hypotenuse)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804253Z"^^xsd:dateTime .

oakcurric:keyword-congruent
  a curric:Keyword ;
  schema:name "Congruent"@en ;
  schema:description """If one shape can fit exactly on top of another using rotation, reflection or translation, then the shapes are congruent."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804437Z"^^xsd:dateTime .

oakcurric:keyword-object
  a curric:Keyword ;
  schema:name "Object"@en ;
  schema:description "The object is the starting figure before a transformation has been applied."@en ;
  dcterms:modified "2026-02-12T08:59:15.805503Z"^^xsd:dateTime .

oakcurric:keyword-image
  a curric:Keyword ;
  schema:name "Image"@en ;
  schema:description "The image is the resulting figure after a transformation has been applied."@en ;
  dcterms:modified "2026-02-12T08:59:15.805507Z"^^xsd:dateTime .

oakcurric:keyword-similar
  a curric:Keyword ;
  schema:name "Similar"@en ;
  schema:description """Two shapes are similar if the only difference between them is their size. Their side lengths are in the same proportions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805512Z"^^xsd:dateTime .

oakcurric:keyword-scale-factor
  a curric:Keyword ;
  schema:name "Scale factor"@en ;
  schema:description """Scale factor is the multiplier between similar shapes that describes how large one shape is compared to the other."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805520Z"^^xsd:dateTime .

oakcurric:keyword-invariant
  a curric:Keyword ;
  schema:name "Invariant"@en ;
  schema:description """A property of a shape is invariant if that property has not changed after the shape is transformed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805524Z"^^xsd:dateTime .

oakcurric:keyword-parallel
  a curric:Keyword ;
  schema:name "parallel"@en ;
  schema:description "describing something that is similar to something else."@en ;
  dcterms:modified "2026-02-12T08:59:15.805641Z"^^xsd:dateTime .

oakcurric:keyword-speed
  a curric:Keyword ;
  schema:name "speed"@en ;
  schema:description "in handwriting, refers to the rate at which one can write"@en ;
  dcterms:modified "2026-02-12T08:59:15.805928Z"^^xsd:dateTime .

oakcurric:keyword-co-interior-angles
  a curric:Keyword ;
  schema:name "Co-interior angles"@en ;
  schema:description """Co-interior angles are on the same side of the transversal line and in between the two other lines."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805974Z"^^xsd:dateTime .

oakcurric:keyword-transformation
  a curric:Keyword ;
  schema:name "transformation"@en ;
  schema:description "a complete change in the appearance or character of something or someone"@en ;
  dcterms:modified "2026-02-12T08:59:15.806587Z"^^xsd:dateTime .

oakcurric:keyword-sphere
  a curric:Keyword ;
  schema:name "Sphere"@en ;
  schema:description """refers to a specific group or area of influence- for example, the political sphere refers to the area of political activity"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806861Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description "the action of moving something from its place or position"@en ;
  dcterms:modified "2026-02-12T08:59:15.807610Z"^^xsd:dateTime .

oakcurric:keyword-perimeter
  a curric:Keyword ;
  schema:name "Perimeter"@en ;
  schema:description "Perimeter is the distance around a two-dimensional shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.808175Z"^^xsd:dateTime .

oakcurric:keyword-inversely-proportional
  a curric:Keyword ;
  schema:name "inversely proportional"@en ;
  schema:description """variables are inversely proportional when one increases and the other decreases at the same (proportional) rate, e.g. as one variable doubles, the other variable halves"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808532Z"^^xsd:dateTime .

oakcurric:keyword-estimate
  a curric:Keyword ;
  schema:name "Estimate"@en ;
  schema:description """Estimation means to find a value that is close enough to the right answer, usually with some thought or calculation involved."""@en ;
  dcterms:modified "2026-02-12T08:59:15.809426Z"^^xsd:dateTime .

oakcurric:keyword-prism
  a curric:Keyword ;
  schema:name "Prism"@en ;
  schema:description """a polyhedron with a base that is a polygon and a parallel opposite face that is identical joined by parallelograms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810612Z"^^xsd:dateTime .

oakcurric:keyword-radius
  a curric:Keyword ;
  schema:name "Radius"@en ;
  schema:description "any line segment that joins the centre of a circle to its circumference."@en ;
  dcterms:modified "2026-02-12T08:59:15.810616Z"^^xsd:dateTime .

oakcurric:keyword-cylinder
  a curric:Keyword ;
  schema:name "Cylinder"@en ;
  schema:description """3D shape with a base that is a circle and a parallel opposite face that is identical and uniform cross-section."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810620Z"^^xsd:dateTime .

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "Range"@en ;
  schema:description """The range is a measure of spread. It is found by finding the difference between the highest and lowest values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810625Z"^^xsd:dateTime .

oakcurric:keyword-midpoint
  a curric:Keyword ;
  schema:name "Midpoint"@en ;
  schema:description "The middle of something. The point halfway along."@en ;
  dcterms:modified "2026-02-12T08:59:15.810761Z"^^xsd:dateTime .

oakcurric:keyword-perpendicular
  a curric:Keyword ;
  schema:name "Perpendicular"@en ;
  schema:description "Two lines are perpendicular if they meet at a right angle."@en ;
  dcterms:modified "2026-02-12T08:59:15.810921Z"^^xsd:dateTime .

oakcurric:keyword-parallelogram
  a curric:Keyword ;
  schema:name "Parallelogram"@en ;
  schema:description "A parallelogram is a quadrilateral with two pairs of parallel and equal sides."@en ;
  dcterms:modified "2026-02-12T08:59:15.810938Z"^^xsd:dateTime .

oakcurric:keyword-rhombus
  a curric:Keyword ;
  schema:name "Rhombus"@en ;
  schema:description "A rhombus is parallelogram where all the sides are the same length."@en ;
  dcterms:modified "2026-02-12T08:59:15.810942Z"^^xsd:dateTime .

oakcurric:keyword-trapezium
  a curric:Keyword ;
  schema:name "Trapezium"@en ;
  schema:description "A trapezium is a quadrilateral with exactly one pair of parallel sides."@en ;
  dcterms:modified "2026-02-12T08:59:15.810946Z"^^xsd:dateTime .

oakcurric:keyword-equilateral-triangle
  a curric:Keyword ;
  schema:name "Equilateral triangle"@en ;
  schema:description """Equilateral triangles have three equal-sized angles and three edges of equal length. They are regular triangles."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810951Z"^^xsd:dateTime .

oakcurric:keyword-isosceles-triangle
  a curric:Keyword ;
  schema:name "Isosceles triangle"@en ;
  schema:description """Isosceles triangles have two angles that are equal. That is also true for its side lengths: two sides are of equal length."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810955Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description "The gradient on a displacement-time graph gives the instantaneous velocity."@en ;
  dcterms:modified "2026-02-12T08:59:15.811020Z"^^xsd:dateTime .

oakcurric:keyword-tangent
  a curric:Keyword ;
  schema:name "tangent"@en ;
  schema:description """A tangent drawn to the gradient on a curving displacement-time graph will give the instantaneous velocity."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811024Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description "The factor that we change in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811096Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description "The factor that we measure in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811100Z"^^xsd:dateTime .

oakcurric:keyword-additive-inverse
  a curric:Keyword ;
  schema:name "Additive inverse"@en ;
  schema:description """The additive inverse of a number is a number that, when added to the original number, gives the sum of 0."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811229Z"^^xsd:dateTime .

oakcurric:keyword-formula
  a curric:Keyword ;
  schema:name "Formula"@en ;
  schema:description "A formula is a rule linking sets of physical variables in context."@en ;
  dcterms:modified "2026-02-12T08:59:15.811242Z"^^xsd:dateTime .

oakcurric:keyword-compound-shapes
  a curric:Keyword ;
  schema:name "Compound shapes"@en ;
  schema:description "A compound shape is a shape created using two or more basic shapes."@en ;
  dcterms:modified "2026-02-12T08:59:15.811257Z"^^xsd:dateTime .

oakcurric:keyword-composite-shapes
  a curric:Keyword ;
  schema:name "Composite shapes"@en ;
  schema:description "A composite shape is an alternative for a compound shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.811262Z"^^xsd:dateTime .

oakcurric:keyword-capturerecapture
  a curric:Keyword ;
  schema:name "Capture/recapture"@en ;
  schema:description """Capture-recapture is a sampling method which allows us to estimate the size of a population without counting it fully. It is very useful when the entire population may be too difficult to count."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811267Z"^^xsd:dateTime .

oakcurric:keyword-acceleration
  a curric:Keyword ;
  schema:name "acceleration"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how much the velocity changes per second."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811355Z"^^xsd:dateTime .

oakcurric:keyword-deceleration
  a curric:Keyword ;
  schema:name "deceleration"@en ;
  schema:description """Deceleration is used to describe a change in velocity where the object slows down."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811359Z"^^xsd:dateTime .

oakcurric:keyword-enlargement
  a curric:Keyword ;
  schema:name "Enlargement"@en ;
  schema:description "Enlargement is a transformation that causes a change of size."@en ;
  dcterms:modified "2026-02-12T08:59:15.811363Z"^^xsd:dateTime .

oakcurric:keyword-intercept
  a curric:Keyword ;
  schema:name "Intercept"@en ;
  schema:description "An intercept is the coordinate where a line or curve meets a given axis."@en ;
  dcterms:modified "2026-02-12T08:59:15.811370Z"^^xsd:dateTime .

oakcurric:keyword-interquartile-range
  a curric:Keyword ;
  schema:name "Interquartile range"@en ;
  schema:description """Interquartile range is calculated by finding Q3 − Q1. This is because it is the range from the first to the third quartile."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811374Z"^^xsd:dateTime .

oakcurric:keyword-rotation
  a curric:Keyword ;
  schema:name "Rotation"@en ;
  schema:description """The rotation of an object is the turning of an object by a fixed amount and around a fixed point (called the centre of rotation), without the image being flipped or its size changing."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811379Z"^^xsd:dateTime .

oakcurric:keyword-centre-of-rotation
  a curric:Keyword ;
  schema:name "Centre of rotation"@en ;
  schema:description "The centre of rotation is the fixed point about which an object is rotated."@en ;
  dcterms:modified "2026-02-12T08:59:15.811383Z"^^xsd:dateTime .

oakcurric:keyword-completing-the-square
  a curric:Keyword ;
  schema:name "Completing the square"@en ;
  schema:description """Completing the square is the process of rearranging an expression of the form ax^2 + bx + c into an equivalent expression of the form a(x + p)^2 + q"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811387Z"^^xsd:dateTime .

oakcurric:keyword-exchange-rate
  a curric:Keyword ;
  schema:name "Exchange rate"@en ;
  schema:description "An exchange rate is the rate at which one currency is exchanged for another."@en ;
  dcterms:modified "2026-02-12T08:59:15.811392Z"^^xsd:dateTime .

oakcurric:keyword-prime-factorisation
  a curric:Keyword ;
  schema:name "Prime factorisation"@en ;
  schema:description "a method to find the prime factors of a given integer"@en ;
  dcterms:modified "2026-02-12T08:59:15.811396Z"^^xsd:dateTime .

oakcurric:keyword-hcf
  a curric:Keyword ;
  schema:name "HCF"@en ;
  schema:description "an abbreviation for highest common factor"@en ;
  dcterms:modified "2026-02-12T08:59:15.811404Z"^^xsd:dateTime .

oakcurric:keyword-sector
  a curric:Keyword ;
  schema:name "Sector"@en ;
  schema:description "A sector is the region formed between two radii and their connecting arc."@en ;
  dcterms:modified "2026-02-12T08:59:15.811408Z"^^xsd:dateTime .

oakcurric:keyword-generalise
  a curric:Keyword ;
  schema:name "Generalise"@en ;
  schema:description """To generalise is to formulate a statement or rule that applies correctly to all relevant cases."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811427Z"^^xsd:dateTime .

oakcurric:keyword-equivalent-fractions
  a curric:Keyword ;
  schema:name "Equivalent fractions"@en ;
  schema:description "Two fractions are equivalent if they have the same value"@en ;
  dcterms:modified "2026-02-12T08:59:15.811431Z"^^xsd:dateTime .

oakcurric:keyword-angle
  a curric:Keyword ;
  schema:name "Angle"@en ;
  schema:description "An angle is a measure of turn."@en ;
  dcterms:modified "2026-02-12T08:59:15.811474Z"^^xsd:dateTime .

oakcurric:keyword-vertex
  a curric:Keyword ;
  schema:name "Vertex"@en ;
  schema:description "A vertex is a point where two or more lines meet."@en ;
  dcterms:modified "2026-02-12T08:59:15.811479Z"^^xsd:dateTime .

oakcurric:keyword-arithmetic-sequence
  a curric:Keyword ;
  schema:name "Arithmetic sequence"@en ;
  schema:description """An arithmetic (or linear) sequence is a sequence where the difference between terms is a constant."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811703Z"^^xsd:dateTime .

oakcurric:keyword-geometric-sequence
  a curric:Keyword ;
  schema:name "Geometric sequence"@en ;
  schema:description """A geometric sequence is a sequence with a constant multiplicative relationship between successive terms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811707Z"^^xsd:dateTime .

oakcurric:keyword-integer
  a curric:Keyword ;
  schema:name "Integer"@en ;
  schema:description """An integer is any positive or negative whole number or zero. E.g. -2, 0, 153 are all examples of integers."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811711Z"^^xsd:dateTime .

oakcurric:keyword-event
  a curric:Keyword ;
  schema:name "Event"@en ;
  schema:description """An event is a subset of a sample space. It could be a particular outcome or be a set of outcomes that may occur from a trial."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811716Z"^^xsd:dateTime .

oakcurric:keyword-theoretical-probability
  a curric:Keyword ;
  schema:name "Theoretical probability"@en ;
  schema:description """A theoretical probability is a probability based on counting the number of desired outcomes from a sample space where all individual outcomes are equally likely."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811720Z"^^xsd:dateTime .

oakcurric:keyword-chord
  a curric:Keyword ;
  schema:name "Chord"@en ;
  schema:description "A chord is any line segment joining two points on the circumference of a circle."@en ;
  dcterms:modified "2026-02-12T08:59:15.811725Z"^^xsd:dateTime .

oakcurric:keyword-segment
  a curric:Keyword ;
  schema:name "Segment"@en ;
  schema:description "Two segments are created when dividing a circle into two parts using a chord."@en ;
  dcterms:modified "2026-02-12T08:59:15.811729Z"^^xsd:dateTime .

oakcurric:keyword-arc
  a curric:Keyword ;
  schema:name "Arc"@en ;
  schema:description """An arc is part of a curve. An arc of a circle is part of the circle’s circumference."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811733Z"^^xsd:dateTime .

oakcurric:keyword-outcome
  a curric:Keyword ;
  schema:name "Outcome"@en ;
  schema:description "An outcome is a result of a trial."@en ;
  dcterms:modified "2026-02-12T08:59:15.811737Z"^^xsd:dateTime .

oakcurric:keyword-function
  a curric:Keyword ;
  schema:name "Function"@en ;
  schema:description """A function is a mathematical relationship that uniquely maps values of one set to the values of another set."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811855Z"^^xsd:dateTime .

oakcurric:keyword-trigonometric-functions
  a curric:Keyword ;
  schema:name "Trigonometric functions"@en ;
  schema:description """Trigonometric functions are commonly defined as ratios of two sides of a right-angled triangle for a given angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811861Z"^^xsd:dateTime .

oakcurric:keyword-sine-function
  a curric:Keyword ;
  schema:name "Sine function"@en ;
  schema:description """The sine of an angle (sin(θ°)) is the y-coordinate of point P on the triangle formed inside the unit circle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811866Z"^^xsd:dateTime .

oakcurric:keyword-cosine-function
  a curric:Keyword ;
  schema:name "Cosine function"@en ;
  schema:description """The cosine of an angle (cos(θ°)) is the x-coordinate of point P on the triangle formed inside the unit circle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811870Z"^^xsd:dateTime .

oakcurric:keyword-tangent-function
  a curric:Keyword ;
  schema:name "Tangent function"@en ;
  schema:description """The tangent of an angle (tan(θ°)) is the y-coordinate of point Q on the triangle which extends from the unit circle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811874Z"^^xsd:dateTime .

oakcurric:keyword-period-of-a-function
  a curric:Keyword ;
  schema:name "Period (of a function)"@en ;
  schema:description """For a repeating function, the period is the distance of one repetition of the entire function."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811879Z"^^xsd:dateTime .

oakcurric:keyword-ratio
  a curric:Keyword ;
  schema:name "ratio"@en ;
  schema:description "can be used to determine the size of one quantity in relation to another."@en ;
  dcterms:modified "2026-02-12T08:59:15.811894Z"^^xsd:dateTime .

oakcurric:keyword-cube-number
  a curric:Keyword ;
  schema:name "Cube number"@en ;
  schema:description "A cube number is the product of three repeated whole numbers."@en ;
  dcterms:modified "2026-02-12T08:59:15.811973Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "Frequency"@en ;
  schema:description """The frequency is the number of times an event occurs; or the number of individuals (people, animals etc.) with some specific property."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811977Z"^^xsd:dateTime .

oakcurric:keyword-bar-chart
  a curric:Keyword ;
  schema:name "Bar chart"@en ;
  schema:description """A bar chart (bar graph) is a graph consisting of bars visually representing the frequency of objects or groups."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811984Z"^^xsd:dateTime .

oakcurric:keyword-mode
  a curric:Keyword ;
  schema:name "Mode"@en ;
  schema:description """The mode is the most frequent value. It is a measure of central tendency representing the average of the values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811988Z"^^xsd:dateTime .

oakcurric:keyword-probability
  a curric:Keyword ;
  schema:name "Probability"@en ;
  schema:description """The probability that an event will occur is the proportion of times the event is expected to happen in a suitably large experiment."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811992Z"^^xsd:dateTime .

oakcurric:keyword-exhaustive-events
  a curric:Keyword ;
  schema:name "Exhaustive events"@en ;
  schema:description """A set of events are exhaustive if at least one of them has to occur whenever the experiment is carried out."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811999Z"^^xsd:dateTime .

oakcurric:keyword-mutually-exclusive
  a curric:Keyword ;
  schema:name "Mutually exclusive"@en ;
  schema:description "Mutually exclusive events have no outcomes in common."@en ;
  dcterms:modified "2026-02-12T08:59:15.812004Z"^^xsd:dateTime .

oakcurric:keyword-venn-diagram
  a curric:Keyword ;
  schema:name "Venn diagram"@en ;
  schema:description """Venn diagrams are a representation used to model statistical/probability questions. Commonly circles are used to represent events."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812008Z"^^xsd:dateTime .

oakcurric:keyword-outlier
  a curric:Keyword ;
  schema:name "Outlier"@en ;
  schema:description """An outlier is a data point that is extremely large or small compared to the rest of the dataset. Visually, outliers lie far away from where the majority of the results are clustered."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812088Z"^^xsd:dateTime .

oakcurric:keyword-direct-proportion
  a curric:Keyword ;
  schema:name "Direct proportion"@en ;
  schema:description """Two variables are in direct proportion if they have a constant multiplicative relationship"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812092Z"^^xsd:dateTime .

oakcurric:keyword-time-series-graph
  a curric:Keyword ;
  schema:name "Time series graph"@en ;
  schema:description """Time series graphs show data over a time period. The time period is always shown on the x-axis. Data points are joined chronologically by line segments."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812100Z"^^xsd:dateTime .

oakcurric:keyword-box-plot
  a curric:Keyword ;
  schema:name "Box plot"@en ;
  schema:description """A box plot is a diagram that clearly shows the minimum and maximum value of a data set long with the three quartiles."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812106Z"^^xsd:dateTime .

oakcurric:keyword-lower-quartile
  a curric:Keyword ;
  schema:name "Lower quartile"@en ;
  schema:description """The lower quartile is the value under which 25% of data points are found when they are arranged in increasing order.  Also known as the first quartile (Q1)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812111Z"^^xsd:dateTime .

oakcurric:keyword-upper-quartile
  a curric:Keyword ;
  schema:name "Upper quartile"@en ;
  schema:description """The upper quartile is the value under which 75% of data points are found when they are arranged in increasing order.  Also known as the third quartile (Q3)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812115Z"^^xsd:dateTime .

oakcurric:keyword-histogram
  a curric:Keyword ;
  schema:name "Histogram"@en ;
  schema:description """A histogram is a diagram consisting of rectangles whose area is proportional to the frequency in each class and whose width is equal to the class interval."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812119Z"^^xsd:dateTime .

oakcurric:keyword-transversal
  a curric:Keyword ;
  schema:name "Transversal"@en ;
  schema:description """A transversal is a line, line segment, or ray that intersects through two or more lines at distinct (different) points."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812123Z"^^xsd:dateTime .

oakcurric:keyword-corresponding-angles
  a curric:Keyword ;
  schema:name "Corresponding angles"@en ;
  schema:description """Corresponding angles are a pair of angles at different vertices on the same side of a transversal in equivalent positions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812130Z"^^xsd:dateTime .

oakcurric:keyword-alternate-angles
  a curric:Keyword ;
  schema:name "Alternate angles"@en ;
  schema:description """Alternate angles are a pair of angles both between or both outside two line segments that are on opposite sides of the transversal that cuts them."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812134Z"^^xsd:dateTime .

oakcurric:keyword-pie-chart
  a curric:Keyword ;
  schema:name "Pie chart"@en ;
  schema:description """A pie chart (pie graph) is a circular graph where sectors represent different groups proportionally."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812140Z"^^xsd:dateTime .

oakcurric:keyword-scatter-graph
  a curric:Keyword ;
  schema:name "Scatter graph"@en ;
  schema:description """A scatter graph is a visual representation for bivariate data. It can be useful when determining the nature of the relationship between the two variables."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812145Z"^^xsd:dateTime .

oakcurric:keyword-exterior-angle
  a curric:Keyword ;
  schema:name "Exterior angle"@en ;
  schema:description """An exterior angle is an angle on the outside of a polygon between an extension of an edge and its adjacent edge."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812149Z"^^xsd:dateTime .

oakcurric:keyword-supplementary-angles
  a curric:Keyword ;
  schema:name "Supplementary angles"@en ;
  schema:description "Supplementary angles are a pair of angles that sum to 180°."@en ;
  dcterms:modified "2026-02-12T08:59:15.812154Z"^^xsd:dateTime .

oakcurric:keyword-conjugate-angles
  a curric:Keyword ;
  schema:name "Conjugate angles"@en ;
  schema:description "Conjugate angles are a pair of angles that sum to 360°."@en ;
  dcterms:modified "2026-02-12T08:59:15.812158Z"^^xsd:dateTime .

oakcurric:keyword-reciprocal
  a curric:Keyword ;
  schema:name "Reciprocal"@en ;
  schema:description """A reciprocal is the multiplicative inverse of any non-zero number. Any non-zero number multiplied by its reciprocal is equal to 1"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812167Z"^^xsd:dateTime .

oakcurric:keyword-pictogram
  a curric:Keyword ;
  schema:name "Pictogram"@en ;
  schema:description "A pictogram is a graph that uses pictures to represent information."@en ;
  dcterms:modified "2026-02-12T08:59:15.812192Z"^^xsd:dateTime .

oakcurric:keyword-net
  a curric:Keyword ;
  schema:name "Net"@en ;
  schema:description """A net is a 2D representation of the faces of a 3D shape, that can be folded up into the 3D object."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812332Z"^^xsd:dateTime .

oakcurric:keyword-interior-angle
  a curric:Keyword ;
  schema:name "Interior angle"@en ;
  schema:description "an angle formed inside a polygon by two of its edges."@en ;
  dcterms:modified "2026-02-12T08:59:15.812336Z"^^xsd:dateTime .

oakcurric:keyword-adjacent
  a curric:Keyword ;
  schema:name "Adjacent"@en ;
  schema:description """The adjacent side of a right-angled triangle is the side which is next to both the right angle and the marked angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812360Z"^^xsd:dateTime .

oakcurric:keyword-opposite
  a curric:Keyword ;
  schema:name "Opposite"@en ;
  schema:description """The opposite side of a right-angled triangle is the side which is opposite the marked angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812364Z"^^xsd:dateTime .

oakcurric:keyword-trigonometric-ratios
  a curric:Keyword ;
  schema:name "Trigonometric ratios"@en ;
  schema:description """The trigonometric ratios are ratios between each pair of lengths in a right-angled triangle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812369Z"^^xsd:dateTime .

oakcurric:keyword-subject-of-an-equationformula
  a curric:Keyword ;
  schema:name "Subject of an equation/formula"@en ;
  schema:description """The subject of an equation/a formula is a variable that is expressed in terms of other variables. It should have an exponent of 1 and a coefficient of 1"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812373Z"^^xsd:dateTime .

oakcurric:keyword-roots
  a curric:Keyword ;
  schema:name "Roots"@en ;
  schema:description """When drawing the graph of an equation, the roots of the equation are where its graph intercepts the x-axis (where y = 0)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812493Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change
  a curric:Keyword ;
  schema:name "Rate of change"@en ;
  schema:description "The rate of change is how quickly one variable changes in relation to another."@en ;
  dcterms:modified "2026-02-12T08:59:15.812598Z"^^xsd:dateTime .

oakcurric:keyword-common-ratio
  a curric:Keyword ;
  schema:name "Common ratio"@en ;
  schema:description """A common ratio is a key feature of a geometric sequence. The constant multiplier between successive terms is called the common ratio."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812607Z"^^xsd:dateTime .

oakcurric:keyword-corresponding
  a curric:Keyword ;
  schema:name "Corresponding"@en ;
  schema:description """Corresponding angles are a pair of angles at different vertices on the same side of a transversal in equivalent positions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812619Z"^^xsd:dateTime .

oakcurric:keyword-alternate
  a curric:Keyword ;
  schema:name "Alternate"@en ;
  schema:description """Alternate angles are a pair of angles, both between or both outside two line segments, that are on opposite sides of the transversal that cuts them."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812624Z"^^xsd:dateTime .

oakcurric:keyword-co-interior
  a curric:Keyword ;
  schema:name "Co-interior"@en ;
  schema:description """Co-interior angles are on the same side of the transversal line and in between the two other lines."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812630Z"^^xsd:dateTime .

oakcurric:keyword-tree-diagram
  a curric:Keyword ;
  schema:name "Tree diagram"@en ;
  schema:description """Tree diagrams are a representation used to model statistical/probability questions. Branches represent different possible events or outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812822Z"^^xsd:dateTime .

oakcurric:keyword-pair-of-compasses
  a curric:Keyword ;
  schema:name "Pair of compasses"@en ;
  schema:description """A pair of compasses is a tool which can be used to draw circles and arcs. A pair of compasses is sometimes referred to just as a compass."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812831Z"^^xsd:dateTime .

oakcurric:keyword-equidistant
  a curric:Keyword ;
  schema:name "Equidistant"@en ;
  schema:description """Points A and B are equidistant from a third point C if the distance AC is equal to the distance BC."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812835Z"^^xsd:dateTime .

oakcurric:keyword-bisect
  a curric:Keyword ;
  schema:name "Bisect"@en ;
  schema:description "To bisect means to cut or divide an object into two equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:15.812949Z"^^xsd:dateTime .

oakcurric:keyword-sense
  a curric:Keyword ;
  schema:name "Sense"@en ;
  schema:description """The sense of an object is the direction of the orientation of the object. When the sense of an object changes, the direction of its orientation changes from clockwise to anti-clockwise, or vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812961Z"^^xsd:dateTime .

oakcurric:keyword-median
  a curric:Keyword ;
  schema:name "Median"@en ;
  schema:description """The median is the central (middle) piece of data when the data are in numerical order.  It is a measure of central tendency representing the average of the values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812966Z"^^xsd:dateTime .

oakcurric:keyword-frequency-density
  a curric:Keyword ;
  schema:name "Frequency density"@en ;
  schema:description """Frequency density is proportional to the frequency per unit for the data in each class. Often, the multiplier is 1 meaning that frequency density = frequency ÷ class width."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812970Z"^^xsd:dateTime .

oakcurric:keyword-mean
  a curric:Keyword ;
  schema:name "Mean"@en ;
  schema:description """The (arithmetic) mean for a set of numerical data is the sum of the values divided by the number of values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813064Z"^^xsd:dateTime .

oakcurric:keyword-probability-tree
  a curric:Keyword ;
  schema:name "Probability tree"@en ;
  schema:description """Each branch of a probability tree shows a possible outcome from an event or from a stage of a trial, along with the probability of that outcome happening."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813068Z"^^xsd:dateTime .

oakcurric:keyword-sample-space
  a curric:Keyword ;
  schema:name "Sample space"@en ;
  schema:description """A sample space is all the possible outcomes of a trial. A sample space diagram is a systematic way of producing a sample space."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813073Z"^^xsd:dateTime .

oakcurric:keyword-independent-events
  a curric:Keyword ;
  schema:name "Independent events"@en ;
  schema:description """Event A is independent of event B if the probability of event A occurring is not affected by whether or not event B occurs."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813077Z"^^xsd:dateTime .

oakcurric:keyword-irrational-number
  a curric:Keyword ;
  schema:name "Irrational number"@en ;
  schema:description """An irrational number is one that cannot be written in the form a/b where a and b are integers and b is not equal to 0"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813081Z"^^xsd:dateTime .

oakcurric:keyword-surd
  a curric:Keyword ;
  schema:name "Surd"@en ;
  schema:description "A surd is an irrational number expressed as the root of a rational number."@en ;
  dcterms:modified "2026-02-12T08:59:15.813087Z"^^xsd:dateTime .

oakcurric:keyword-front-elevation
  a curric:Keyword ;
  schema:name "Front elevation"@en ;
  schema:description "The front elevation of a solid is the view of it from the front."@en ;
  dcterms:modified "2026-02-12T08:59:15.813182Z"^^xsd:dateTime .

oakcurric:keyword-side-elevation
  a curric:Keyword ;
  schema:name "Side elevation"@en ;
  schema:description "The side elevation of a solid is the view of it from the side."@en ;
  dcterms:modified "2026-02-12T08:59:15.813186Z"^^xsd:dateTime .

oakcurric:keyword-bivariate-data
  a curric:Keyword ;
  schema:name "Bivariate data"@en ;
  schema:description """Bivariate data has two variables, where each data point for one variable has a corresponding data point for the other variable."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813190Z"^^xsd:dateTime .

oakcurric:keyword-density
  a curric:Keyword ;
  schema:name "density"@en ;
  schema:description "the mass per cubic metre (m³) or cubic centimetre (cm³) of a material"@en ;
  dcterms:modified "2026-02-12T08:59:15.813208Z"^^xsd:dateTime .

oakcurric:keyword-round
  a curric:Keyword ;
  schema:name "Round"@en ;
  schema:description """To change a number into another number that is approximately the same value but is easier to work with. E.g. round 561 to the nearest 10 is 560."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813304Z"^^xsd:dateTime .

oakcurric:keyword-nth-term
  a curric:Keyword ;
  schema:name "n^th term"@en ;
  schema:description """The nth term of a sequence is the position of a term in a sequence where n stands for the term number."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813338Z"^^xsd:dateTime .

oakcurric:keyword-equation-of-a-straight-line
  a curric:Keyword ;
  schema:name "Equation of a straight line"@en ;
  schema:description """An equation of a line is any equation whose graph forms a straight line. These equations can be written in the form y = mx + c."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813343Z"^^xsd:dateTime .

oakcurric:keyword-quadratic
  a curric:Keyword ;
  schema:name "Quadratic"@en ;
  schema:description """A quadratic is an equation, graph, or sequence whereby the highest exponent of the variable is 2; the graph of which forms a parabola."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813347Z"^^xsd:dateTime .

oakcurric:keyword-square-number
  a curric:Keyword ;
  schema:name "Square number"@en ;
  schema:description """A square number is the result of multiplying a whole number (not a fraction) by itself."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813417Z"^^xsd:dateTime .

oakcurric:keyword-prime-number
  a curric:Keyword ;
  schema:name "prime number"@en ;
  schema:description "A prime number is a whole number greater than one which has exactly two factors."@en ;
  dcterms:modified "2026-02-12T08:59:15.813432Z"^^xsd:dateTime .

oakcurric:keyword-parabola
  a curric:Keyword ;
  schema:name "Parabola"@en ;
  schema:description """A parabola is a curve where any point on the curve is an equal distance from a fixed point (the focus) and a fixed straight line (the directrix)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813436Z"^^xsd:dateTime .

oakcurric:keyword-statistical-summary
  a curric:Keyword ;
  schema:name "statistical summary"@en ;
  schema:description "A statistical summary sums up the features of a data set."@en ;
  dcterms:modified "2026-02-12T08:59:15.813440Z"^^xsd:dateTime .

oakcurric:keyword-apex
  a curric:Keyword ;
  schema:name "Apex"@en ;
  schema:description """The apex is the point (vertex) which is the greatest perpendicular distance from the base."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813459Z"^^xsd:dateTime .

oakcurric:keyword-right-pyramid
  a curric:Keyword ;
  schema:name "Right pyramid"@en ;
  schema:description """When the apex lies directly above the centre of the base, then it is called a right pyramid."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813464Z"^^xsd:dateTime .

oakcurric:keyword-oblique-pyramid
  a curric:Keyword ;
  schema:name "Oblique pyramid"@en ;
  schema:description """An oblique pyramid is when the apex is not directly above the centre of the base."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813475Z"^^xsd:dateTime .

oakcurric:keyword-metric-units
  a curric:Keyword ;
  schema:name "Metric units"@en ;
  schema:description "Metric units are based around the standard units of metre, gram and litre."@en ;
  dcterms:modified "2026-02-12T08:59:15.813542Z"^^xsd:dateTime .

oakcurric:keyword-isometric-paper
  a curric:Keyword ;
  schema:name "Isometric paper"@en ;
  schema:description """Isometric means distances between points stay the same. In this lesson you may use isometric paper which has equally spaced dots or points."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813547Z"^^xsd:dateTime .

oakcurric:keyword-resultant-vector
  a curric:Keyword ;
  schema:name "Resultant vector"@en ;
  schema:description """A resultant vector is the single vector that produces the same effect as a combination of other vectors."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813551Z"^^xsd:dateTime .

oakcurric:keyword-circle
  a curric:Keyword ;
  schema:name "Circle"@en ;
  schema:description "A 2D shape with one curved line around the outside."@en ;
  dcterms:modified "2026-02-12T08:59:15.813633Z"^^xsd:dateTime .

oakcurric:keyword-diameter
  a curric:Keyword ;
  schema:name "Diameter"@en ;
  schema:description """The diameter of a circle is any line segment that starts and ends on the edge of the circle and passes through the centre."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813711Z"^^xsd:dateTime .

oakcurric:keyword-stem-and-leaf-diagram
  a curric:Keyword ;
  schema:name "Stem and leaf diagram"@en ;
  schema:description """A stem and leaf diagram is a systematic way to organise and represent numerical data, by splitting each value into a stem and a leaf."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813716Z"^^xsd:dateTime .

oakcurric:keyword-inverse-proportion
  a curric:Keyword ;
  schema:name "Inverse proportion"@en ;
  schema:description """Two variables are inversely proportional if there is a constant multiplicative relationship between one variable and the reciprocal of the other."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813720Z"^^xsd:dateTime .

oakcurric:keyword-continuous
  a curric:Keyword ;
  schema:name "Continuous"@en ;
  schema:description "Continuous means that every position on the line or scale has a value."@en ;
  dcterms:modified "2026-02-12T08:59:15.813734Z"^^xsd:dateTime .

oakcurric:keyword-lowest-common-multiple
  a curric:Keyword ;
  schema:name "Lowest common multiple"@en ;
  schema:description """The lowest common multiple is the lowest number that is a multiple of two or more numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813743Z"^^xsd:dateTime .

oakcurric:keyword-reflex-angle
  a curric:Keyword ;
  schema:name "Reflex angle"@en ;
  schema:description """An angle that is greater than a straight line (i.e. greater than 180°) is a reflex angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813748Z"^^xsd:dateTime .

oakcurric:keyword-time-series-graphs
  a curric:Keyword ;
  schema:name "Time series graphs"@en ;
  schema:description """Time series graphs show data over a time period. The time period is always shown on the x-axis. Data points are joined chronologically by line segments."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813752Z"^^xsd:dateTime .

oakcurric:keyword-line-of-best-fit
  a curric:Keyword ;
  schema:name "Line of best fit"@en ;
  schema:description """A line of best fit is a line where the distance between each data point and the line is minimised."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813763Z"^^xsd:dateTime .

oakcurric:keyword-a-scatter-graph
  a curric:Keyword ;
  schema:name "A scatter graph"@en ;
  schema:description """A scatter graph is a visual representation for bivariate data. It can be useful when determining the nature of the relationship between the variables."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813767Z"^^xsd:dateTime .

oakcurric:keyword-centre-of-enlargement
  a curric:Keyword ;
  schema:name "Centre of enlargement"@en ;
  schema:description "The centre of enlargement is the point from which a shape is enlarged."@en ;
  dcterms:modified "2026-02-12T08:59:15.813771Z"^^xsd:dateTime .

oakcurric:keyword-significant-figures
  a curric:Keyword ;
  schema:name "Significant figures"@en ;
  schema:description """Significant figures are the digits in a number that contribute to the accuracy of the number."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813884Z"^^xsd:dateTime .

oakcurric:keyword-theorem
  a curric:Keyword ;
  schema:name "Theorem"@en ;
  schema:description """A theorem is a statement that can be proved using known mathematical facts and reasoning."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813889Z"^^xsd:dateTime .

oakcurric:keyword-subtended
  a curric:Keyword ;
  schema:name "Subtended"@en ;
  schema:description """An angle can be subtended by a line segment or curve. The legs of the subtended angle meet the endpoints of the line segment or curve."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813893Z"^^xsd:dateTime .

oakcurric:keyword-invariant-point
  a curric:Keyword ;
  schema:name "Invariant point"@en ;
  schema:description """A point on a shape is invariant if that point has not changed location after the shape is transformed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813897Z"^^xsd:dateTime .

oakcurric:keyword-extrapolation
  a curric:Keyword ;
  schema:name "Extrapolation"@en ;
  schema:description """Extrapolation is the process of estimating unknown values that are outside the range of existing data."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813970Z"^^xsd:dateTime .

oakcurric:keyword-compound-shape
  a curric:Keyword ;
  schema:name "Compound shape"@en ;
  schema:description """A compound shape is a shape created using two or more basic shapes. A composite shape is an alternative for compound shape."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813974Z"^^xsd:dateTime .

oakcurric:keyword-arithmetic-mean
  a curric:Keyword ;
  schema:name "Arithmetic mean"@en ;
  schema:description """The (arithmetic) mean for a set of numerical data is the sum of the values divided by the number of values. It is a measure of central tendency representing the average of the values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813978Z"^^xsd:dateTime .

oakcurric:keyword-line-of-reflection
  a curric:Keyword ;
  schema:name "Line of reflection"@en ;
  schema:description """The line of reflection is the line about which an object is reflected. The object and image are equidistant from the line of reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814060Z"^^xsd:dateTime .

oakcurric:keyword-circumference
  a curric:Keyword ;
  schema:name "Circumference"@en ;
  schema:description "The circumference of a circle is the perimeter of the circle."@en ;
  dcterms:modified "2026-02-12T08:59:15.814099Z"^^xsd:dateTime .

oakcurric:keyword-solid
  a curric:Keyword ;
  schema:name "Solid"@en ;
  schema:description "A solid is a shape that has three dimensions (e.g. width, height and depth)."@en ;
  dcterms:modified "2026-02-12T08:59:15.814103Z"^^xsd:dateTime .

oakcurric:keyword-cubic
  a curric:Keyword ;
  schema:name "Cubic"@en ;
  schema:description """A cubic is an equation, graph, or sequence whereby the highest exponent of the variable is 3"""@en ;
  dcterms:modified "2026-02-12T08:59:15.814108Z"^^xsd:dateTime .

oakcurric:keyword-region-inequalities
  a curric:Keyword ;
  schema:name "Region (inequalities)"@en ;
  schema:description """A region is an area that graphically represents the solutions to one or more inequalities. Every coordinate pair within the region satisfies the inequalities that define the region."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814121Z"^^xsd:dateTime .

oakcurric:keyword-proportionality
  a curric:Keyword ;
  schema:name "Proportionality"@en ;
  schema:description """If two things are proportional then the ratio of part to whole is maintained and the multiplicative relationship between parts is also maintained."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814209Z"^^xsd:dateTime .

oakcurric:keyword-conditional-probability
  a curric:Keyword ;
  schema:name "Conditional probability"@en ;
  schema:description """Conditional probability is the probability of an outcome occurring given that another event has occurred."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814213Z"^^xsd:dateTime .

oakcurric:keyword-iteration
  a curric:Keyword ;
  schema:name "Iteration"@en ;
  schema:description """Iteration is the repeated application of a function or process in which the output of each iteration is used as the input for the next iteration."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814217Z"^^xsd:dateTime .

oakcurric:keyword-experimental-probability
  a curric:Keyword ;
  schema:name "Experimental probability"@en ;
  schema:description """The frequency of an outcome from an experiment can be used to produce an experimental probability. This is sometimes referred to as relative frequency."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814243Z"^^xsd:dateTime .

oakcurric:keyword-fair
  a curric:Keyword ;
  schema:name "Fair"@en ;
  schema:description """A trial or experiment is fair if each outcome has an equal chance of happening. Each outcome is said to be equally likely."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814247Z"^^xsd:dateTime .

oakcurric:keyword-unitary-ratio
  a curric:Keyword ;
  schema:name "Unitary ratio"@en ;
  schema:description "A unitary ratio is any ratio where one part of the ratio is 1"@en ;
  dcterms:modified "2026-02-12T08:59:15.814251Z"^^xsd:dateTime .

oakcurric:keyword-inverse-function
  a curric:Keyword ;
  schema:name "Inverse function"@en ;
  schema:description "An inverse function reverses the mapping of the original function."@en ;
  dcterms:modified "2026-02-12T08:59:15.814256Z"^^xsd:dateTime .

oakcurric:keyword-absolute-value
  a curric:Keyword ;
  schema:name "Absolute value"@en ;
  schema:description "The absolute value of a number is its distance from zero."@en ;
  dcterms:modified "2026-02-12T08:59:15.814260Z"^^xsd:dateTime .

oakcurric:keyword-exponential
  a curric:Keyword ;
  schema:name "Exponential"@en ;
  schema:description """The general form for an exponential equation is $$y = ab^x$$ where $$a$$ is the coefficient, $$b$$ is the base and $$x$$ is the exponent."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814264Z"^^xsd:dateTime .

oakcurric:keyword-primarysecondary-data
  a curric:Keyword ;
  schema:name "Primary/Secondary data"@en ;
  schema:description """Primary data refers to data that are directly collected for specific use in an investigation. Secondary data refers to data that were previously collected for a different or unknown purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814364Z"^^xsd:dateTime .

oakcurric:keyword-discrete
  a curric:Keyword ;
  schema:name "Discrete"@en ;
  schema:description "Discrete data can only take specific numerical values."@en ;
  dcterms:modified "2026-02-12T08:59:15.814368Z"^^xsd:dateTime .

oakcurric:keyword-asymptote
  a curric:Keyword ;
  schema:name "Asymptote"@en ;
  schema:description "An asymptote is a line that a curve approaches but never touches."@en ;
  dcterms:modified "2026-02-12T08:59:15.814372Z"^^xsd:dateTime .

oakcurric:keyword-composite-shape
  a curric:Keyword ;
  schema:name "Composite shape"@en ;
  schema:description "A composite shape is an alternative for a compound shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.814392Z"^^xsd:dateTime .

oakcurric:keyword-centi
  a curric:Keyword ;
  schema:name "Centi"@en ;
  schema:description "Centi placed before a unit means (1/100)"@en ;
  dcterms:modified "2026-02-12T08:59:15.814396Z"^^xsd:dateTime .

oakcurric:keyword-milli
  a curric:Keyword ;
  schema:name "Milli"@en ;
  schema:description "Milli placed before a unit means (1/1000)"@en ;
  dcterms:modified "2026-02-12T08:59:15.814434Z"^^xsd:dateTime .

oakcurric:keyword-kilo
  a curric:Keyword ;
  schema:name "Kilo"@en ;
  schema:description "Kilo placed before a unit means 1000 times."@en ;
  dcterms:modified "2026-02-12T08:59:15.814460Z"^^xsd:dateTime .

oakcurric:keyword-compound-interest
  a curric:Keyword ;
  schema:name "Compound interest"@en ;
  schema:description """Compound interest is the interest calculated on the original amount and the interest accumulated over the previous period."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814642Z"^^xsd:dateTime .

oakcurric:keyword-tree-diagrams
  a curric:Keyword ;
  schema:name "Tree diagrams"@en ;
  schema:description """Tree diagrams are a representation used to model statistical/probability questions. Branches represent different possible events or outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814646Z"^^xsd:dateTime .

oakcurric:keyword-venn-diagrams
  a curric:Keyword ;
  schema:name "Venn diagrams"@en ;
  schema:description """Venn diagrams are a representation used to model statistical/probability questions. Commonly circles are used to represent events."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814652Z"^^xsd:dateTime .

oakcurric:keyword-iff
  a curric:Keyword ;
  schema:name "IFF"@en ;
  schema:description "IFF (If and only if) is an implication that goes both ways."@en ;
  dcterms:modified "2026-02-12T08:59:15.814715Z"^^xsd:dateTime .

oakcurric:keyword-binomial
  a curric:Keyword ;
  schema:name "Binomial"@en ;
  schema:description """A binomial is an algebraic expression representing the sum of exactly two unlike terms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814767Z"^^xsd:dateTime .

oakcurric:keyword-percentage-loss
  a curric:Keyword ;
  schema:name "Percentage loss"@en ;
  schema:description """Percentage loss is the decrease when referencing something that loses cost/mass/length, etc. given as a percentage of the original amount."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814772Z"^^xsd:dateTime .

oakcurric:keyword-complementary-angles
  a curric:Keyword ;
  schema:name "Complementary angles"@en ;
  schema:description "Complementary angles are a pair of angles that sum to 90°."@en ;
  dcterms:modified "2026-02-12T08:59:15.814776Z"^^xsd:dateTime .

oakcurric:keyword-statistical-enquiry-cycle
  a curric:Keyword ;
  schema:name "Statistical Enquiry Cycle"@en ;
  schema:description """The Statistical Enquiry Cycle is a cycle used to carry out a statistical investigation. There are five stages. This is an ongoing process as evaluation may lead to new/refined questioning."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814780Z"^^xsd:dateTime .

oakcurric:keyword-conjecture
  a curric:Keyword ;
  schema:name "Conjecture"@en ;
  schema:description """A conjecture is a (mathematical) statement that is thought to be true but has not been proved yet."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814785Z"^^xsd:dateTime .

oakcurric:keyword-cone
  a curric:Keyword ;
  schema:name "Cone"@en ;
  schema:description """A circular cone is a 3D shape that has a circular base and one curved surface that narrows from the base to a fixed point called the apex/vertex."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814811Z"^^xsd:dateTime .

oakcurric:keyword-right-cone
  a curric:Keyword ;
  schema:name "Right cone"@en ;
  schema:description """A line drawn through the apex and centre of the base of a right circular cone will be perpendicular to the base."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814815Z"^^xsd:dateTime .

oakcurric:keyword-frustum
  a curric:Keyword ;
  schema:name "Frustum"@en ;
  schema:description """A frustum is the 3D shape made from a cone by making a cut parallel to its circular base and removing the resultant smaller cone."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814852Z"^^xsd:dateTime .

oakcurric:keyword-regular
  a curric:Keyword ;
  schema:name "Regular"@en ;
  schema:description "A regular polygon has all sides equal and all angles equal."@en ;
  dcterms:modified "2026-02-12T08:59:15.814881Z"^^xsd:dateTime .

oakcurric:keyword-factorise
  a curric:Keyword ;
  schema:name "Factorise"@en ;
  schema:description """A ratio shows the relative sizes of 2 or more values and allows you to compare a part with another part in a whole."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814933Z"^^xsd:dateTime .

oakcurric:keyword-triangular-number
  a curric:Keyword ;
  schema:name "Triangular number"@en ;
  schema:description """A triangular number is a number that can be represented by a pattern of dots arranged into an equilateral triangle. The term number is the number of dots in a side of the triangle"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815145Z"^^xsd:dateTime .

oakcurric:keyword-simultaneous-equations
  a curric:Keyword ;
  schema:name "Simultaneous equations"@en ;
  schema:description """Equations which represent different relationships between the same variables are called simultaneous equations."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815228Z"^^xsd:dateTime .

oakcurric:keyword-prime-factors
  a curric:Keyword ;
  schema:name "Prime factors"@en ;
  schema:description "Prime factors are the factors of a number that are, themselves, prime."@en ;
  dcterms:modified "2026-02-12T08:59:15.815389Z"^^xsd:dateTime .

oakcurric:keyword-significant-figure
  a curric:Keyword ;
  schema:name "Significant figure"@en ;
  schema:description """Significant figures are the digits in a number that contribute to the accuracy of the number. The first significant figure is the first non-zero digit."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815421Z"^^xsd:dateTime .

oakcurric:keyword-lcm
  a curric:Keyword ;
  schema:name "LCM"@en ;
  schema:description "LCM is an abbreviation for lowest common multiple."@en ;
  dcterms:modified "2026-02-12T08:59:15.815442Z"^^xsd:dateTime .

oakcurric:keyword-metric-unit
  a curric:Keyword ;
  schema:name "Metric unit"@en ;
  schema:description "Metric units are based around the standard units of metre, gram and litre."@en ;
  dcterms:modified "2026-02-12T08:59:15.815447Z"^^xsd:dateTime .

oakcurric:keyword-imperial-unit
  a curric:Keyword ;
  schema:name "Imperial unit"@en ;
  schema:description """Imperial is a system of units for measuring, which was created in the early 1800s during the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815451Z"^^xsd:dateTime .

oakcurric:keyword-interest
  a curric:Keyword ;
  schema:name "Interest"@en ;
  schema:description "Interest is money added to savings or loans."@en ;
  dcterms:modified "2026-02-12T08:59:15.815455Z"^^xsd:dateTime .

oakcurric:keyword-cyclic-quadrilateral
  a curric:Keyword ;
  schema:name "Cyclic quadrilateral"@en ;
  schema:description """A cyclic quadrilateral is a quadrilateral where all four of its vertices lie on a single circle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815650Z"^^xsd:dateTime .

oakcurric:keyword-force
  a curric:Keyword ;
  schema:name "Force"@en ;
  schema:description """A force is a push or a pull on an object. A force is an influence that can cause an object to change its speed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815765Z"^^xsd:dateTime .

oakcurric:keyword-cross-section
  a curric:Keyword ;
  schema:name "Cross-section"@en ;
  schema:description "a 2D face made from cutting straight through any plane of a 3D object."@en ;
  dcterms:modified "2026-02-12T08:59:15.815901Z"^^xsd:dateTime .

oakcurric:keyword-cosine-rule
  a curric:Keyword ;
  schema:name "Cosine rule"@en ;
  schema:description """The cosine rule is a formula used for calculating either an unknown side length or the size of an unknown angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815905Z"^^xsd:dateTime .

oakcurric:keyword-experiment
  a curric:Keyword ;
  schema:name "Experiment"@en ;
  schema:description """An experiment is a repetition of a trial multiple times in order to observe how often each outcome occurs."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816043Z"^^xsd:dateTime .

oakcurric:keyword-percentage-profit
  a curric:Keyword ;
  schema:name "Percentage profit"@en ;
  schema:description """Percentage profit is the increase when referencing something that is sold for more than the cost price given as a percentage of the original amount."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816327Z"^^xsd:dateTime .

oakcurric:keyword-locusloci
  a curric:Keyword ;
  schema:name "Locus/loci"@en ;
  schema:description """A locus is a set of points that satisfy a given set of conditions. Multiple sets of points are referred to as loci."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816344Z"^^xsd:dateTime .

oakcurric:keyword-interpolation
  a curric:Keyword ;
  schema:name "Interpolation"@en ;
  schema:description """Interpolation is the process of estimating unknown values that are inside the range of existing data."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816348Z"^^xsd:dateTime .

oakcurric:keyword-measure-of-central-tendency
  a curric:Keyword ;
  schema:name "Measure of central tendency"@en ;
  schema:description """A summary that attempts to describe a whole set of data with a single value that represents the middle of the distribution."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816706Z"^^xsd:dateTime .

oakcurric:keyword-extrapolations
  a curric:Keyword ;
  schema:name "Extrapolations"@en ;
  schema:description """Extrapolation is the process of estimating unknown values that are outside the range of existing data."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816715Z"^^xsd:dateTime .

oakcurric:keyword-scalar
  a curric:Keyword ;
  schema:name "Scalar"@en ;
  schema:description "A scalar is a quantity that has magnitude but not direction."@en ;
  dcterms:modified "2026-02-12T08:59:15.816719Z"^^xsd:dateTime .

oakcurric:keyword-lower-bound
  a curric:Keyword ;
  schema:name "Lower bound"@en ;
  schema:description """The lower bound for a rounded number is the smallest value that the number could have taken prior to being rounded."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816785Z"^^xsd:dateTime .

oakcurric:keyword-upper-bound
  a curric:Keyword ;
  schema:name "Upper bound"@en ;
  schema:description """The upper bound for a rounded number is the smallest value that would round up to the next rounded value."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816789Z"^^xsd:dateTime .

oakcurric:keyword-domain
  a curric:Keyword ;
  schema:name "domain"@en ;
  schema:description """The three domain system of classification organises organisms into  three large groups: Bacteria, Archaea and Eukaryota."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816958Z"^^xsd:dateTime .

oakcurric:keyword-collinear
  a curric:Keyword ;
  schema:name "Collinear"@en ;
  schema:description """When three or more points lie on a single straight line, these points are said to be collinear."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817054Z"^^xsd:dateTime .

oakcurric:keyword-sine-rule
  a curric:Keyword ;
  schema:name "Sine rule"@en ;
  schema:description """The sine rule is a formula used for calculating either an unknown side length or the size of an unknown angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817582Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-interest
  a curric:Keyword ;
  schema:name "Rate of interest"@en ;
  schema:description "The rate of interest is the percentage by which an amount increases."@en ;
  dcterms:modified "2026-02-12T08:59:15.817649Z"^^xsd:dateTime .

oakcurric:keyword-loci
  a curric:Keyword ;
  schema:name "Loci"@en ;
  schema:description """A locus is a set of points that satisfy a given set of conditions. Multiple sets of points are referred to as loci."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817720Z"^^xsd:dateTime .

oakcurric:keyword-modal-class
  a curric:Keyword ;
  schema:name "Modal class"@en ;
  schema:description """The modal class is the interval, or group of values, with the highest frequency in a data set."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817851Z"^^xsd:dateTime .

oakcurric:keyword-median-class
  a curric:Keyword ;
  schema:name "Median class"@en ;
  schema:description """The median class is the class which contains the central (middle) datum when the data are in numerical order."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817856Z"^^xsd:dateTime .

oakcurric:keyword-cumulative-frequency
  a curric:Keyword ;
  schema:name "Cumulative frequency"@en ;
  schema:description """Cumulative frequency is the total of all frequencies up to a defined class. It is the 'running total' of frequencies."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817860Z"^^xsd:dateTime .

oakcurric:keyword-simple-interest
  a curric:Keyword ;
  schema:name "Simple interest"@en ;
  schema:description """Interest is money added to savings or loans. Simple interest is always calculated on the original amount."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817923Z"^^xsd:dateTime .

oakcurric:keyword-vertically-opposite-angles
  a curric:Keyword ;
  schema:name "Vertically opposite angles"@en ;
  schema:description """Vertical angles are pairs of opposite angles formed when two lines intersect at a point. They are equal."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818041Z"^^xsd:dateTime .

oakcurric:keyword-elimination
  a curric:Keyword ;
  schema:name "Elimination"@en ;
  schema:description """Elimination is a technique to help solve equations simultaneously and is where one of the variables in a problem is removed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818079Z"^^xsd:dateTime .

oakcurric:keyword-resultant
  a curric:Keyword ;
  schema:name "Resultant"@en ;
  schema:description """A resultant vector is the single vector that produces the same effect as a combination of other vectors."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818166Z"^^xsd:dateTime .

oakcurric:keyword-error-interval
  a curric:Keyword ;
  schema:name "Error interval"@en ;
  schema:description """An error interval for a number $$x$$ shows the range of possible values of $$x$$. It is written as an inequality $$a ≤ x < b$$"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818323Z"^^xsd:dateTime .

oakcurric:keyword-a-statistical-summary
  a curric:Keyword ;
  schema:name "A statistical summary"@en ;
  schema:description """sums up the features of a data set. It may contain the average (mean, median and/or mode) which measures the central tendency. It may also contain the range which measures the spread."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818354Z"^^xsd:dateTime .

oakcurric:keyword-tangent-of-a-circle
  a curric:Keyword ;
  schema:name "Tangent (of a circle)"@en ;
  schema:description "The tangent (of a circle) is a line that intersects the circle exactly once."@en ;
  dcterms:modified "2026-02-12T08:59:15.818417Z"^^xsd:dateTime .

oakcurric:keyword-questionnaire
  a curric:Keyword ;
  schema:name "Questionnaire"@en ;
  schema:description """A questionnaire is a set of written questions designed to collect information from a respondent."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818461Z"^^xsd:dateTime .

oakcurric:keyword-degree-of-accuracy
  a curric:Keyword ;
  schema:name "Degree of accuracy"@en ;
  schema:description "A degree of accuracy shows how precise a number or measurement is."@en ;
  dcterms:modified "2026-02-12T08:59:15.818487Z"^^xsd:dateTime .

oakcurric:keyword-simple-random-sample
  a curric:Keyword ;
  schema:name "Simple random sample"@en ;
  schema:description """A simple random sample is where every item in a population has an equal chance of being selected for the sample."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818729Z"^^xsd:dateTime .

oakcurric:keyword-weighting-factor
  a curric:Keyword ;
  schema:name "Weighting factor"@en ;
  schema:description """A weighting factor is a multiplier used to reflect the importance of a piece (or pieces) of data relative to the rest of the data."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818733Z"^^xsd:dateTime .

oakcurric:keyword-weighted-mean
  a curric:Keyword ;
  schema:name "Weighted mean"@en ;
  schema:description """A weighted mean is the mean calculated for a set of data where weighting factors have been applied."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818737Z"^^xsd:dateTime .

oakcurric:keyword-strata
  a curric:Keyword ;
  schema:name "Strata"@en ;
  schema:description """A population may be split intro strata (groups). Each stratum is distinct and each item in the population can only belong to one stratum."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818804Z"^^xsd:dateTime .

oakcurric:keyword-stratified-sample
  a curric:Keyword ;
  schema:name "Stratified sample"@en ;
  schema:description "A stratified sample is where a representative sample is taken from each stratum."@en ;
  dcterms:modified "2026-02-12T08:59:15.818809Z"^^xsd:dateTime .

oakcurric:keyword-product-of-primes
  a curric:Keyword ;
  schema:name "Product of primes"@en ;
  schema:description """Expressing a number as a product of primes means writing it uniquely as a product of its factors that are prime numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820941Z"^^xsd:dateTime .

oakcurric:keyword-solution-equality
  a curric:Keyword ;
  schema:name "Solution (equality)"@en ;
  schema:description """A solution to an equality with one variable is a value for the variable which, when substituted, maintains the equality between the expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820945Z"^^xsd:dateTime .

oakcurric:keyword-perfect-square
  a curric:Keyword ;
  schema:name "Perfect square"@en ;
  schema:description "A perfect square is the same as a square number."@en ;
  dcterms:modified "2026-02-12T08:59:15.821435Z"^^xsd:dateTime .

oakcurric:keyword-terminating-decimal
  a curric:Keyword ;
  schema:name "Terminating decimal"@en ;
  schema:description """A terminating decimal is one that has a finite number of digits after the decimal point..  E.g. 92.2, 193.3894, non-example:  $$1.\\\\dot9$$."""@en ;
  dcterms:modified "2026-02-12T08:59:15.824092Z"^^xsd:dateTime .

oakcurric:keyword-overestimate
  a curric:Keyword ;
  schema:name "Overestimate"@en ;
  schema:description "An estimate for a calculation which is greater than the exact answer."@en ;
  dcterms:modified "2026-02-12T08:59:15.824563Z"^^xsd:dateTime .

oakcurric:keyword-underestimate
  a curric:Keyword ;
  schema:name "Underestimate"@en ;
  schema:description "An estimate for a calculation which is less than the exact answer."@en ;
  dcterms:modified "2026-02-12T08:59:15.824567Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-flow
  a curric:Keyword ;
  schema:name "Rate of flow"@en ;
  schema:description """Rate of flow measures the volume of fluid that passes through a particular pipe/channel per unit of time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.825794Z"^^xsd:dateTime .

oakcurric:keyword-vinculum
  a curric:Keyword ;
  schema:name "Vinculum"@en ;
  schema:description """Vinculum is the horizontal line placed over an expression to show that everything below that line is one group."""@en ;
  dcterms:modified "2026-02-12T08:59:15.825824Z"^^xsd:dateTime .

oakcurric:keyword-indices
  a curric:Keyword ;
  schema:name "Indices"@en ;
  schema:description """An exponent is a number positioned above and to the right of a base value. It indicates repeated multiplication. An alternative word for this is index (plural indices)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.825841Z"^^xsd:dateTime .

oakcurric:keyword-recurring-decimal
  a curric:Keyword ;
  schema:name "Recurring decimal"@en ;
  schema:description """A recurring decimal is one that has an infinite number of digits after the decimal point."""@en ;
  dcterms:modified "2026-02-12T08:59:15.825971Z"^^xsd:dateTime .

oakcurric:keyword-radicand
  a curric:Keyword ;
  schema:name "Radicand"@en ;
  schema:description "The radicand is the value inside the radical symbol."@en ;
  dcterms:modified "2026-02-12T08:59:15.826013Z"^^xsd:dateTime .

oakcurric:keyword-rational-number
  a curric:Keyword ;
  schema:name "Rational number"@en ;
  schema:description """A rational number is one that can be written in the form a/b where a and b are integers and b is not equal to 0"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826320Z"^^xsd:dateTime .

oakcurric:keyword-subject-of-an-equation
  a curric:Keyword ;
  schema:name "Subject of an equation"@en ;
  schema:description """The subject of an equation/a formula is a variable that is expressed in terms of other variables. It should have an exponent of 1 and a coefficient of 1."""@en ;
  dcterms:modified "2026-02-12T08:59:15.826324Z"^^xsd:dateTime .

oakcurric:keyword-term-to-term
  a curric:Keyword ;
  schema:name "Term-to-term"@en ;
  schema:description """A term-to-term rule describes how to calculate the next term in the sequence from the previous term."""@en ;
  dcterms:modified "2026-02-12T08:59:15.826489Z"^^xsd:dateTime .

oakcurric:keyword-subject-equationformula
  a curric:Keyword ;
  schema:name "Subject (equation/formula)"@en ;
  schema:description """The subject of an equation/a formula is a variable that is expressed in terms of other variables. It should have an exponent of 1 and a coefficient of 1"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826744Z"^^xsd:dateTime .

oakcurric:keyword-quadratic-formula
  a curric:Keyword ;
  schema:name "Quadratic formula"@en ;
  schema:description """The quadratic formula is a formula for finding the solutions to any quadratic equation of the form $$ax^2 + bx + c = 0$$"""@en ;
  dcterms:modified "2026-02-12T08:59:15.826885Z"^^xsd:dateTime .

oakcurric:keyword-fibonacci
  a curric:Keyword ;
  schema:name "Fibonacci"@en ;
  schema:description """A Fibonacci sequence is a sequence where each term is the sum of the two previous terms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827402Z"^^xsd:dateTime .

oakcurric:keyword-alternating
  a curric:Keyword ;
  schema:name "Alternating"@en ;
  schema:description "An alternating sequence is a sequence where consecutive terms change sign."@en ;
  dcterms:modified "2026-02-12T08:59:15.827406Z"^^xsd:dateTime .

oakcurric:keyword-fibonacci-sequence
  a curric:Keyword ;
  schema:name "Fibonacci sequence"@en ;
  schema:description """A Fibonacci sequence is a sequence where each term is the sum of the two previous terms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827693Z"^^xsd:dateTime .

oakcurric:keyword-truncation
  a curric:Keyword ;
  schema:name "Truncation"@en ;
  schema:description """Truncation is when we simplifying a number by 'cutting off' one or more of the digits and replacing them with zeros if necessary to preserve place value."""@en ;
  dcterms:modified "2026-02-12T08:59:15.828013Z"^^xsd:dateTime .

oakcurric:keyword-composite-function
  a curric:Keyword ;
  schema:name "Composite function"@en ;
  schema:description """The composite function gf($$x$$) is the combination of f($$x$$) and g($$x$$). The output from f($$x$$) is the input for g($$x$$)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.828939Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-hard-spot-like-terms-multiple
  a curric:Misconception ;
  curric:statement """It can be hard to spot like terms where there are multiple variables with exponents. Therefore opportunities to simplify by collecting like terms can be missed."""@en ;
  curric:correction """When multiplying variables together, write the variables in alphabetical order. This will make it easier to identify like terms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675788Z"^^xsd:dateTime .

oakcurric:misconception-dividing-terms-coefficients-pupils-subtract
  a curric:Misconception ;
  curric:statement """When dividing terms with coefficients, pupils also subtract the coefficients as well as the exponents."""@en ;
  curric:correction """Pupils should be encouraged to rewrite their expression as a fraction, with the number parts grouped and powers grouped. This hopefully avoids this error as they can see the fraction line as a division."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679421Z"^^xsd:dateTime .

oakcurric:misconception-number-quite-written-standard-form
  a curric:Misconception ;
  curric:statement """When a number is not quite written in standard form, pupils can incorrectly convert the number."""@en ;
  curric:correction """When the A number is greater than 10, add the necessary multiplications of 10 to the index of 10. When the A number is less than 10, subtract the necessary multiplications of 10 from the index of 10."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681720Z"^^xsd:dateTime .

oakcurric:misconception-dividing-numbers-written-standard-form
  a curric:Misconception ;
  curric:statement """When the dividing numbers written in standard form changing the multiplication symbol between the number and power of ten to a division symbol."""@en ;
  curric:correction """Encourage pupils to write any division as a fraction.  This makes the maintenance of the multiplication symbol easier to see."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682103Z"^^xsd:dateTime .

oakcurric:misconception-incorrect-evaluation-expressions-common-negative
  a curric:Misconception ;
  curric:statement """Incorrect evaluation of expressions is common when negative values are substituted. Especially where negative values are squared or pupils rely on calculators without being confident of their use."""@en ;
  curric:correction """When substituting, always put brackets around the value which is substituted. This helps avoid mistakes when using a calculator as well."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682705Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-spot-congruent-triangles
  a curric:Misconception ;
  curric:statement "Pupils may struggle to spot congruent triangles if they only look for ASA."@en ;
  curric:correction """Encourage pupils to add any further information to diagrams, like the third angle, before starting to prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.683815Z"^^xsd:dateTime .

oakcurric:misconception-using-multipliers-pupils-mistake-decimal
  a curric:Misconception ;
  curric:statement """When using multipliers, pupils can mistake a decimal for the percentage decrease. e.g. 0.52 is a 52% decrease, rather than recognising a 48% decrease"""@en ;
  curric:correction """Reminding students that a decimal multiplier greater than 1 means an increase, and a decimal multiplier less than 1 means a decrease. The latter requires a subtraction from 1 or 100%"""@en ;
  dcterms:modified "2026-02-12T08:59:18.683826Z"^^xsd:dateTime .

oakcurric:misconception-angles-facts-cannot-used-shapes
  a curric:Misconception ;
  curric:statement """Angles facts cannot be used with shapes as shapes have line segments rather than lines."""@en ;
  curric:correction """It is the properties of the lines, such as whether they are parallel, that are important, not their length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687668Z"^^xsd:dateTime .

oakcurric:misconception-pupils-write-read-column-vector
  a curric:Misconception ;
  curric:statement """Pupils may write or read the column vector incorrectly by thinking the top element is for the vertical movement and the bottom element is for the horizontal movement."""@en ;
  curric:correction """Remind pupils that coordinates are horizontal before vertical and that is the same on a column vector."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687676Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miss-edge-calculating-perimeter
  a curric:Misconception ;
  curric:statement "Pupils may miss an edge when calculating the perimeter."@en ;
  curric:correction """Encourage the pupils to trace the perimeter to check that all edges have been included in the sum."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687864Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-rearrange-equivalent-fractions
  a curric:Misconception ;
  curric:statement "Pupils may struggle to rearrange the equivalent fractions."@en ;
  curric:correction "A ratio table may be easier for pupils to use instead."@en ;
  dcterms:modified "2026-02-12T08:59:18.687870Z"^^xsd:dateTime .

oakcurric:misconception-parallel-vectors-same-direction
  a curric:Misconception ;
  curric:statement "Parallel vectors can only be in the same direction."@en ;
  curric:correction """Two vectors are parallel if one can be written as a scalar multiple of the other. This scalar multiple can be negative therefore the direction can be opposite, but the gradients remain equivalent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687902Z"^^xsd:dateTime .

oakcurric:misconception-length-image-4-times-long
  a curric:Misconception ;
  curric:statement """If the length of an image is 4 times as long as its object, then its area will also be 4 times as big."""@en ;
  curric:correction """If the scale factor between lengths is 4, then the area of the image will be 16 times as big. The scale factor between the length of an object and image is different to the multiplier that shows how the area of an object changes after enlargement."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687908Z"^^xsd:dateTime .

oakcurric:misconception-lines-parallel-same-gradient
  a curric:Misconception ;
  curric:statement "Lines are parallel if they have the same gradient."@en ;
  curric:correction """Lines are parallel if they have the same gradient and different y-intercepts. Two lines are parallel if they are straight lines that are always the same non-zero distance apart."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687913Z"^^xsd:dateTime .

oakcurric:misconception-referring-context-question-comparing-data
  a curric:Misconception ;
  curric:statement "Not referring to the context of the question when comparing the data."@en ;
  curric:correction """Highlight that just saying the median or the interquartile is bigger is of little use unless you know what the data was about."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687917Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rotate-opposite-direction-stated
  a curric:Misconception ;
  curric:statement "Pupils may rotate in the opposite direction to the stated direction."@en ;
  curric:correction """Encourage pupils to read the question twice and highlight the key pieces of information before starting the question."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687922Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-write-completed-square
  a curric:Misconception ;
  curric:statement """Pupils may believe that to write in completed square form they can divide through by the coefficient of x^2"""@en ;
  curric:correction """This works for equations as equality can be maintained by dividing both sides of the equation. However if manipulating an expression, dividing through by a value changes the expression. Instead a value can be 'factored out' as necessary."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687926Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-constant-4-calculating
  a curric:Misconception ;
  curric:statement "Pupils may forget the constant '4' when calculating the surface area."@en ;
  curric:correction """Show the demonstration of the formula of the surface area using a different spherical fruit to see that it is always 4 regardless of the size of the sphere. You can also relate it to the 1/2 in the formula of the area of triangle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687931Z"^^xsd:dateTime .

oakcurric:misconception-line-segment-starting-centre-circle
  a curric:Misconception ;
  curric:statement "\"Any line segment starting from the centre of a circle is a radius.\""@en ;
  curric:correction """It is true that one endpoint of a radius must be at the centre of a circle. However, the other endpoint must be on the circumference of the circle. This second endpoint cannot be inside or outside of the circle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688284Z"^^xsd:dateTime .

oakcurric:misconception-pupils-omit-outcomes-include-repetitions
  a curric:Misconception ;
  curric:statement """Pupils may omit outcomes or include repetitions of the same outcomes in their lists."""@en ;
  curric:correction """For each problem, encourage pupils to be systematic with their ordering of outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688288Z"^^xsd:dateTime .

oakcurric:misconception-equations-one-solution
  a curric:Misconception ;
  curric:statement "Equations always have one solution."@en ;
  curric:correction """Some equations have one solution but, some have no solutions, some have two solutions, some have more than two solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688293Z"^^xsd:dateTime .

oakcurric:misconception-inequalities-graphed-solid-lines
  a curric:Misconception ;
  curric:statement "All inequalities are graphed with solid lines."@en ;
  curric:correction """When graphed, strict inequalities are indicated with a dashed line. This is important as it visually tells us that values on the line will not satisfy the inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688298Z"^^xsd:dateTime .

oakcurric:misconception-linear-scale-factor-found-finding
  a curric:Misconception ;
  curric:statement """A linear scale factor can only be found by finding the multiplicative relationship between two corresponding lengths."""@en ;
  curric:correction """A linear scale factor can also be found by square rooting an area scale factor, where an area scale factor is found from the multiplicative relationship between the area of two similar 2D shapes, or corresponding faces on two similar 3D shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688302Z"^^xsd:dateTime .

oakcurric:misconception-f-x-5-translation-5
  a curric:Misconception ;
  curric:statement """f$$(x)+5$$ is a translation of $$+5$$ in the $$y$$-direction so pupils may assume that f$$(x+5)$$ is a translation of $$+5$$ in the $$x$$-direction."""@en ;
  curric:correction """Visually showing pupils, using graphing technology, that f$$(x+5)$$ is not a translation to the right will help. Showing them a comparison of the two tables of values for both functions shows them why this happens."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688355Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confident-knowing-whether-apply
  a curric:Misconception ;
  curric:statement """Pupils may not be confident in knowing whether to apply Pythagoras' theorem or a trigonometric ratio."""@en ;
  curric:correction """Encourage pupils to label the diagram with all the information they have and then consider what they can deduce."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688359Z"^^xsd:dateTime .

oakcurric:misconception-intersection-two-different-graphs-speed
  a curric:Misconception ;
  curric:statement """The intersection of two different graphs on a speed-time graph is the point where the faster particle overtakes the slower moving particle."""@en ;
  curric:correction """Remind pupils that this is a speed-time graph and ask, "How do we find the distance travelled on a speed-time graph?". Then, ask pupils to calculate how far each particle has travelled at the point of intersection."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688364Z"^^xsd:dateTime .

oakcurric:misconception-pupils-their-calculator-set-radians
  a curric:Misconception ;
  curric:statement "Pupils may have their calculator set to radians instead of degrees."@en ;
  curric:correction """The first check for understanding is designed to catch this but it is worth checking that the correct unit of measurement is being used throughout the lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688371Z"^^xsd:dateTime .

oakcurric:misconception-pupils-represent-probabilities-wrong-position
  a curric:Misconception ;
  curric:statement """Pupils may represent probabilities in the wrong position on the probability scale by miscounting the number of intervals required."""@en ;
  curric:correction """Before using any probability scale, it can be helpful to make a note of the sizes for each major and minor interval."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688468Z"^^xsd:dateTime .

oakcurric:misconception-outlier-values-outside-range-dataset
  a curric:Misconception ;
  curric:statement """An outlier always has values that are outside the range of the dataset (i.e. at the start or end of a dataset)."""@en ;
  curric:correction """For bivariate data, a data point may be distinct from the rest of the data because the value of one of its variable is extremely less/greater than other points that have a similar value in its other variable."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688515Z"^^xsd:dateTime .

oakcurric:misconception-assuming-linear-graph-constant-positive
  a curric:Misconception ;
  curric:statement """Assuming that any linear graph with a constant positive gradient shows a directly proportional relationship."""@en ;
  curric:correction """Using examples in a context really helps here.  E.g. 'I change £0.  How many dollars do I get?, I travel 0 miles.  How many kilometres have I travelled?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688520Z"^^xsd:dateTime .

oakcurric:misconception-time-series-graphs-use-years
  a curric:Misconception ;
  curric:statement "Time series graphs always use years as the time interval."@en ;
  curric:correction """The time interval used in a time series graph depends on what the graph is intended to show."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688530Z"^^xsd:dateTime .

oakcurric:misconception-histograms-unequal-bar-widths-plotted
  a curric:Misconception ;
  curric:statement """Histograms with unequal bar widths are plotted against the frequency and/or pupils read the frequency density as the frequency of the class width."""@en ;
  curric:correction """Show what a histogram with unequal bar widths looks like when plotted against frequency. This visual aid will show pupils the distribution of data is difficult to see."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688534Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-whether-variable-represents
  a curric:Misconception ;
  curric:statement """Pupils may be unsure whether a variable represents a probability, frequency or a particular outcome."""@en ;
  curric:correction """Variables can be used to represent either of these pieces of information. It can be helpful to start a problem by writing down what any variables represent (e.g. "Let x = the total number of marbles)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688539Z"^^xsd:dateTime .

oakcurric:misconception-alternate-angles-equal-other
  a curric:Misconception ;
  curric:statement "Alternate angles are always equal to each other."@en ;
  curric:correction """Alternate angles are equal when a transversal intersects parallel lines. If the transversal intersects a pair of lines that are not parallel then the alternate angles will not be equal."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688543Z"^^xsd:dateTime .

oakcurric:misconception-rearranging-multiplicative-relationships-values-swap
  a curric:Misconception ;
  curric:statement "When rearranging multiplicative relationships, the values just 'swap'."@en ;
  curric:correction """Pupils should understand how to manipulate multiplicative relationships properly instead of relying on a 'trick'. This will be useful in other subject areas as well."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688857Z"^^xsd:dateTime .

oakcurric:misconception-looking-units-calculating-gradient-line
  a curric:Misconception ;
  curric:statement "Not looking at units when calculating the gradient of the line to find speed."@en ;
  curric:correction """A recap on compound measures and units may be helpful here. The units of compound measures tell us how to calculate the measure. E.g. km/h is the distance in km/ time in hours. Pupils need to check the units on their graphs and convert if needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688864Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-rearranging-sine-formula
  a curric:Misconception ;
  curric:statement "Incorrectly rearranging the sine formula."@en ;
  curric:correction """A ratio table can be helpful to see the relationship between the sides and therefore how to rearrange."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688868Z"^^xsd:dateTime .

oakcurric:misconception-failing-recognise-x-2-same
  a curric:Misconception ;
  curric:statement """Failing to recognise that x/2 is the same as 1/2 × x and therefore shows a directly proportional relationship where the value of k is 1/2."""@en ;
  curric:correction """It is useful to go back to looking at unit fractions.  E.g. 2/3 = 1/3 × 2 and 7/9 = 1/9 × 7, etc.  And, then look at algebraic terms leading up to for example, 2x/3.  'What is the the multiplier?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688873Z"^^xsd:dateTime .

oakcurric:misconception-p-point-such-ap-pb
  a curric:Misconception ;
  curric:statement """P is a point such that AP : PB is in the ratio of 1 : 3 means that point P is a third of the distance of AB from A."""@en ;
  curric:correction """There are 4 equal parts in total, meaning that point P is a quarter of the distance of AB from A."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688877Z"^^xsd:dateTime .

oakcurric:misconception-parabolas-upwards-downwards
  a curric:Misconception ;
  curric:statement "Parabolas are 'upwards' or 'downwards'."@en ;
  curric:correction """Encourage use of language such as "The turning point of this parabola is a maximum/minimum value" and "As the absolute values of $$x$$ increase, the $$y$$ values decrease/increase"."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688942Z"^^xsd:dateTime .

oakcurric:misconception-line-distance-time-graph-go
  a curric:Misconception ;
  curric:statement "The line on a distance time graph can go in any direction."@en ;
  curric:correction """The line may be horizontal, time changing without a change in distance, but it can not be vertical. That would be a change in distance without a change in time. Additionally, our line cannot go backwards; time is always moving forwards."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689054Z"^^xsd:dateTime .

oakcurric:misconception-becoming-familiar-arithmetic-sequences-pupils
  a curric:Misconception ;
  curric:statement """After becoming very familiar with arithmetic sequences pupils can find the difference between the first two terms and just assume the sequence is arithmetic."""@en ;
  curric:correction """Explore a large number of geometric and arithmetic sequences and see if pupils can articulate how they check if a sequence is geometric. They might say the terms of the sequence grow more quickly (for some geometric sequences)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689072Z"^^xsd:dateTime .

oakcurric:misconception-find-perimeter-add-together-numbers
  a curric:Misconception ;
  curric:statement "\"To find the perimeter, you just add together the numbers that you see.\""@en ;
  curric:correction """The perimeter of a polygon is the sum of the lengths of all the sides of that shape. Not all sides have their lengths explicitly written. This could be due to sides having equal length, and the lengths of some sides shown with hash marks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689080Z"^^xsd:dateTime .

oakcurric:misconception-pupils-measure-angle-north-simply
  a curric:Misconception ;
  curric:statement """Pupils do not measure the angle from North and simply measure the angle between two line segments."""@en ;
  curric:correction """Reiterate bearings are always measured from North, in a clockwise direction and stated as 3 figures. Encourage pupils to draw North on the correct position before attempting the question."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689085Z"^^xsd:dateTime .

oakcurric:misconception-one-shape-area-21-larger
  a curric:Misconception ;
  curric:statement "\"One shape has an area that is 21% larger than another shape. I can't find the area scale factor between the shapes, since I don't know the actual area of either shape.\""@en ;
  curric:correction """It is possible to find scale factors, even if only a percentage that describes their areas is given. One shape will have an area of 100%, so the other shape will have an area 21% larger, at 121%. The scale factor is 1.21 because 100% × 1.21 = 121%."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689089Z"^^xsd:dateTime .

oakcurric:misconception-reading-values-trigonometric-functions-explanation
  a curric:Misconception ;
  curric:statement """When reading the values of the trigonometric functions during the explanation slides and the tasks, pupils may think that all the values taken from the graphs are fully accurate."""@en ;
  curric:correction """Explain that many of the values from the trigonometric functions have digits beyond the second decimal place. However, two decimal places is a reasonable degree of accuracy for reading values from the graphs during this lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689332Z"^^xsd:dateTime .

oakcurric:misconception-e-g-4-5-hours
  a curric:Misconception ;
  curric:statement "E.g 4.5 hours is 4 hours and 50 minutes"@en ;
  curric:correction """Encouraging pupils to use ratio tables to represent proportional relationships using minutes allows them to appreciate the multiplier of 60 when converting hours to minutes, or minutes to seconds."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689336Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-pair-compasses-find
  a curric:Misconception ;
  curric:statement """Pupils may not use a pair of compasses to find the two positions of the third vertex and instead just try to use their ruler."""@en ;
  curric:correction "You could encourage them to draw the circle before the angle each time."@en ;
  dcterms:modified "2026-02-12T08:59:18.689341Z"^^xsd:dateTime .

oakcurric:misconception-matching-sketching-distance-time-speed
  a curric:Misconception ;
  curric:statement """When matching, or sketching, distance-time and speed-time graphs pupils may think these have a similar shape."""@en ;
  curric:correction "Questioning helps. Ask pupils to explain what is happening on a variety of graphs. For example, \"A diagonal line with positive gradient on a speed-time graph. What is happening?\" \"A horizontal line on distance-time graph. What is happening?\""@en ;
  dcterms:modified "2026-02-12T08:59:18.689345Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-opposite-adjacent-sides
  a curric:Misconception ;
  curric:statement "Pupils may confuse the opposite and adjacent sides."@en ;
  curric:correction """The orientation of the right-angled triangle is not important. Identifying the known angle is what determines which is is the opposite and which is the adjacent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689350Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-circle-theorems-angles
  a curric:Misconception ;
  curric:statement "Pupils may think that all circle theorems are about angles."@en ;
  curric:correction "Circle theorems can be about angles or lengths in diagrams containing a circle."@en ;
  dcterms:modified "2026-02-12T08:59:18.689354Z"^^xsd:dateTime .

oakcurric:misconception-use-term-multiplicative-relationship-talking
  a curric:Misconception ;
  curric:statement """We use the term 'multiplicative relationship' when talking about direct proportion.  Pupils may need reminding that division is equivalent to multiplying by the reciprocal."""@en ;
  curric:correction """Allow opportunities to explore division of a number and multiplication of its reciprocal.  Remind pupils that any non-zero number multiplied by its reciprocal is equal to 1."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689358Z"^^xsd:dateTime .

oakcurric:misconception-pupils-appreciate-steps-required-prove
  a curric:Misconception ;
  curric:statement """Pupils may not appreciate all the steps required to prove what type of shape is shown."""@en ;
  curric:correction """A warm-up for the lesson could be to review properties of shapes. Consider describing a shape, one property at a time. How much information is needed before pupils can be certain they know which shape is being described?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689365Z"^^xsd:dateTime .

oakcurric:misconception-single-digit-percentage-incorrectly-worked
  a curric:Misconception ;
  curric:statement """A single digit percentage is incorrectly worked out by dividing by 10 and not 100 e.g 3% = 0.3"""@en ;
  curric:correction """Two responses can be used to remind students that to covert a percentage into a decimal;  we divide by 100; using 3%, ask what 30% is as a decimal and 3% as a decimal. Pupils realise they cannot be the same. A place value chart also helps."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689543Z"^^xsd:dateTime .

oakcurric:misconception-bigger-sector-one-pie-chart
  a curric:Misconception ;
  curric:statement "A bigger sector on one pie chart compared to another means a larger frequency."@en ;
  curric:correction """Pie charts show proportion, but tell nothing about frequency. The total frequency of one pie chart could be significantly larger or smaller than the other pie chart."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689548Z"^^xsd:dateTime .

oakcurric:misconception-one-way-describe-happened-object
  a curric:Misconception ;
  curric:statement """There is only one way to describe what has happened to an object to create its image."""@en ;
  curric:correction """There may be multiple transformations or combinations of transformations that map the object to the image."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689556Z"^^xsd:dateTime .

oakcurric:misconception-cosine-formula-used-find-length
  a curric:Misconception ;
  curric:statement """The cosine formula is only used to find the length of a side adjacent to an angle."""@en ;
  curric:correction """The cosine formula can be used to find the length of a side adjacent to an angle. A rearrangement of the formula also allows us to find the length of the hypotenuse given the adjacent side. The arccosine function allows us to find the angle, itself."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689563Z"^^xsd:dateTime .

oakcurric:misconception-students-find-area-used-communicating
  a curric:Misconception ;
  curric:statement """When students find an area they are used to communicating the answer in units$$^2$$. The area under a speed-time graph tells us the distance travelled though."""@en ;
  curric:correction """On the graph the base is time and the height is speed which is distance over time. Distance over time, multiplied by time, leaves just distance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689572Z"^^xsd:dateTime .

oakcurric:misconception-pupils-construct-probability-trees-scenarios
  a curric:Misconception ;
  curric:statement """When pupils construct probability trees for scenarios where two marbles are removed from a bag, they may mistakenly subtract 2 from the denominators of the probabilities instead of 1."""@en ;
  curric:correction """Even though two marbles are removed from the bag at once, you can think of it at choosing one marble and then immediately choosing a second marble. At the end of the process, two marbles have been removed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689704Z"^^xsd:dateTime .

oakcurric:misconception-dividing-multiplying-1-change-inequality
  a curric:Misconception ;
  curric:statement "Dividing or multiplying by -1 does not change the inequality sign."@en ;
  curric:correction "2 < 3 becomes -2 > -3 when both sides are multiplied by -1."@en ;
  dcterms:modified "2026-02-12T08:59:18.689708Z"^^xsd:dateTime .

oakcurric:misconception-gradients-two-perpendicular-lines-number
  a curric:Misconception ;
  curric:statement "The gradients of two perpendicular lines are a number and its reciprocal."@en ;
  curric:correction """In order for two lines to be perpendicular, the two gradients cannot have the same sign. Therefore it is a number and its negative reciprocal."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689713Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-variable-plot-horizontal
  a curric:Misconception ;
  curric:statement """Pupils may be uncertain about which variable to plot on the horizontal axis if they are unsure about which is the independent variable and which is the dependent variable."""@en ;
  curric:correction """Getting it wrong should not affect your interpretations of the data too much and sometimes neither variable might be dependent on the other.  If you are unsure, consider which variable seems the most likely to be affecting the other in context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689851Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-horizontal-line-speed
  a curric:Misconception ;
  curric:statement """Pupils may think a horizontal line on a speed-time means the object is stationary."""@en ;
  curric:correction """The $$y$$ axis is plotting speed so a horizontal line means the speed has not changed in that time. But this can be at any speed. Pupils need to double check axes to know what sort of graph they are using."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689858Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-stretch-transformations-transformation
  a curric:Misconception ;
  curric:statement """Pupils confuse 'stretch' transformations. Does the transformation $$y=$$f$$(ax)$$ affect the $$x$$ or $$y$$ coordinates?"""@en ;
  curric:correction """Interpreting the notation is key. $$y=$$f$$(ax)$$ is the input of f$$(x)$$ being multiplied by $$a$$. Which coordinate is the input?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689864Z"^^xsd:dateTime .

oakcurric:misconception-claims-made-based-data-displayed
  a curric:Misconception ;
  curric:statement "Claims can be made based on the data displayed in a chart."@en ;
  curric:correction """A claim is only valid for the particular selection of data shown. This can mean that any conclusions are very limited."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690009Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-rearranging-pythagoras-theorem
  a curric:Misconception ;
  curric:statement "Incorrectly rearranging Pythagoras' theorem."@en ;
  curric:correction """It can be helpful to scaffold the steps for any pupils who are struggling with rearranging."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690015Z"^^xsd:dateTime .

oakcurric:misconception-samples-represent-population-drawn-come
  a curric:Misconception ;
  curric:statement """Samples always represent the population from which they are drawn as they come from that population."""@en ;
  curric:correction """Taking multiple large samples allows us to begin to generalise the results to the whole population."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690021Z"^^xsd:dateTime .

oakcurric:misconception-graphs-two-straight-line-equations
  a curric:Misconception ;
  curric:statement "\"The graphs of two straight line equations should always intersect at integer points on a coordinate grid.\""@en ;
  curric:correction """The location with which the graphs of two straight line equations intersect can be found by simultaneously solving the pair of equations. The graphs of two straight line equations can intersect at either integer or non-integer values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690026Z"^^xsd:dateTime .

oakcurric:misconception-pair-simultaneous-equations-one-linear
  a curric:Misconception ;
  curric:statement """For a pair of simultaneous equations (one linear and one quadratic), there will always be two intersections and therefore two solutions."""@en ;
  curric:correction """The linear graph might be tangent to the curve therefore only one intersection (solution). Alternatively, the straight line may never intersect the parabola and in this case, there is no solution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690031Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-edge-length-perpendicular
  a curric:Misconception ;
  curric:statement """Pupils may use the edge length as the perpendicular height when calculating the volume."""@en ;
  curric:correction """Remind pupils that for any volume calculation, three perpendicular lengths are multiplied and in most pyramids the edge of a triangle is not perpendicular to the base. Also the edge of the triangles can be different in the pyramid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690195Z"^^xsd:dateTime .

oakcurric:misconception-spreadsheets-used-data-analysis-perfect
  a curric:Misconception ;
  curric:statement "Spreadsheets should always be used for data analysis as they are perfect."@en ;
  curric:correction """Spreadsheet software is incredibly powerful but care should be taken as human error can lead to incorrect results."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690200Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-knowing-three-angles
  a curric:Misconception ;
  curric:statement """Pupils may believe that knowing the three angles is sufficient to prove two triangles are congruent."""@en ;
  curric:correction """Use an equilateral triangle to show that, although two equilateral triangles have the same angles, they are not guaranteed to be congruent. In fact they are similar."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690204Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-combine-inequalities
  a curric:Misconception ;
  curric:statement "Pupils may struggle to combine inequalities."@en ;
  curric:correction """Encourage pupils to use a number line and draw on the potential solutions. In order for a solution set to be valid for all the stated inequalities, it must include values that satisfy all potential solution restrictions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690209Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-scale-increases-1
  a curric:Misconception ;
  curric:statement """Pupils may assume every scale increases by 1 each time or that there are 10 increments."""@en ;
  curric:correction """Ensure pupils are counting how many gaps along the scale and calculating the increment size."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690314Z"^^xsd:dateTime .

oakcurric:misconception-considering-meter-readings-using-new
  a curric:Misconception ;
  curric:statement """When considering meter readings, using the 'new reading' rather than the units used to calculate the cost."""@en ;
  curric:correction """Emphasise that it is the change in readings that indicates the units used during a time period.  The 'new reading' alone shows the total number of units used since the meter was installed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690320Z"^^xsd:dateTime .

oakcurric:misconception-pupils-add-probabilities-along-branches
  a curric:Misconception ;
  curric:statement """Pupils may add the probabilities along branches of a probability tree, rather than multiplying them."""@en ;
  curric:correction """Remind pupils that probabilities cannot be greater than 1 and demonstrate that adding across the branches sometimes results in a probability that is greater than 1. Therefore, it must be wrong."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690325Z"^^xsd:dateTime .

oakcurric:misconception-curves-cannot-drawn-isometric-paper
  a curric:Misconception ;
  curric:statement "Curves cannot be drawn on isometric paper."@en ;
  curric:correction "It is perfectly possible to draw a curve on isometric paper."@en ;
  dcterms:modified "2026-02-12T08:59:18.690329Z"^^xsd:dateTime .

oakcurric:misconception-using-operations-vectors-pupils-use
  a curric:Misconception ;
  curric:statement """When using operations with vectors, pupils do not use the priority of operations."""@en ;
  curric:correction "The priority of operations applies to all calculations."@en ;
  dcterms:modified "2026-02-12T08:59:18.690336Z"^^xsd:dateTime .

oakcurric:misconception-subtract-constant-squared-constant-bracket
  a curric:Misconception ;
  curric:statement """That we subtract the constant squared when the constant in the bracket is positive and add the constant squared when the constant in the bracket is negative."""@en ;
  curric:correction """Squaring a negative value gives a positive value. Whether the constant in the bracket is positive or negative, the square of the constant must always be subtracted. This can be made clearer with algebra tiles or area models."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690343Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-showing-why-false
  a curric:Misconception ;
  curric:statement "Pupils may struggle with showing why the false proofs are false."@en ;
  curric:correction """Checking what each variable represents will help pupils see why each of the 'proofs' do not work."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690347Z"^^xsd:dateTime .

oakcurric:misconception-interested-points-region-satisfied-inequalities
  a curric:Misconception ;
  curric:statement """We are only interested in points that are in the region satisfied by all inequalities."""@en ;
  curric:correction """With practical contexts, such as project management, it is useful to know when one constraint is not being met as it can suggest where additional resources (if available) should be allocated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690352Z"^^xsd:dateTime .

oakcurric:misconception-calculating-resultant-vector-pupils-incorrectly
  a curric:Misconception ;
  curric:statement """When calculating the resultant vector, pupils can incorrectly sum vectors due to opposite directions or proportions of vectors,"""@en ;
  curric:correction """Encourage pupils to write a clear vector pathway: using highlighters can help to visualise this pathway."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690357Z"^^xsd:dateTime .

oakcurric:misconception-angles-straight-line-sum-180
  a curric:Misconception ;
  curric:statement "Angles on a straight line sum to 180°"@en ;
  curric:correction """Angles on a straight line only sum to 180° if all of those angles share a common vertex. Show two angles "on a line" at different points."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690511Z"^^xsd:dateTime .

oakcurric:misconception-find-median-class-stem-leaf
  a curric:Misconception ;
  curric:statement "You can only find the median class from a stem-and-leaf diagram."@en ;
  curric:correction """The data is organised into intervals based on place value. However the full data is still available so the middle value(s) can still be found. The diagram is a form of an ordered list so previous methods for finding the median still apply."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690532Z"^^xsd:dateTime .

oakcurric:misconception-solutions-context-based-problem-listed
  a curric:Misconception ;
  curric:statement """Solutions for context-based problem can be listed as coordinate pairs with units e.g. 6 workers, 60 hours."""@en ;
  curric:correction """Solutions should always be fully interpreted in relation to the context e.g. It would take 6 workers 60 hours to paint the building."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690539Z"^^xsd:dateTime .

oakcurric:misconception-trigonometry-involves-rounding
  a curric:Misconception ;
  curric:statement "Trigonometry always involves rounding."@en ;
  curric:correction "Try evaluating sin(0) on your calculator. What answer do you get?"@en ;
  dcterms:modified "2026-02-12T08:59:18.690543Z"^^xsd:dateTime .

oakcurric:misconception-pupils-read-incorrect-values-protractor
  a curric:Misconception ;
  curric:statement "Pupils read from the incorrect values on the protractor."@en ;
  curric:correction """Encourage pupils to consider the type of angle they are measuring. If it is an acute angle, will it really measure 122°?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690582Z"^^xsd:dateTime .

oakcurric:misconception-mode-useful-average-calculated-bar
  a curric:Misconception ;
  curric:statement """The mode is the most useful average as it can be calculated from bar charts, pie charts and frequency tables."""@en ;
  curric:correction """Although it is often the easiest of the averages to calculate, this does not make it the most useful."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690587Z"^^xsd:dateTime .

oakcurric:misconception-pupils-place-much-confidence-accuracy
  a curric:Misconception ;
  curric:statement """Pupils may place too much confidence in the accuracy of predictions based on extrapolating time series graphs into the future."""@en ;
  curric:correction """While extrapolating a time series graph provide an indication of what future results may be, predictions are not guaranteed. Context should also be considered in these cases (e.g. whether there is a natural limit to how high a variable may reach)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690591Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-confuse-circle-theorems
  a curric:Misconception ;
  curric:statement """Pupils may not recognise or confuse which circle theorems to apply in a multi-step problem."""@en ;
  curric:correction """Encourage pupils to add more to a diagram in order to deduce more information about the problem. Drawing an additional line segment, such chord or radius may a useful first step."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690596Z"^^xsd:dateTime .

oakcurric:misconception-using-highest-value-y-axis
  a curric:Misconception ;
  curric:statement """Using the highest value on the y-axis rather than the total frequency when calculating the values to read off for the lower quartile, median and upper quartile."""@en ;
  curric:correction """Ensure pupils understand that the total frequency must be used.  A graph where the y-axis goes up to 100 and the total frequency is 40 can be used to highlight this.  Then repeat with the same data, but with a graph where the y-axis goes up to 200."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690600Z"^^xsd:dateTime .

oakcurric:misconception-value-y-given-value-x
  a curric:Misconception ;
  curric:statement "There is only value for $$y$$ for any given value of $$x$$"@en ;
  curric:correction """Pythagoras' theorem on a coordinate grid shows that there are two possible places where the $$y$$-coordinate could be for any given value of $x$$. This is also true for the $$x$$-coordinate for any given value of $$y$$"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690605Z"^^xsd:dateTime .

oakcurric:misconception-line-best-fit-start-origin
  a curric:Misconception ;
  curric:statement "The line of best fit always start at the origin."@en ;
  curric:correction """The line of best fit could start at the origin but it does not always start there. This could be exemplified clearly with a scatter graph that has negative correlation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690663Z"^^xsd:dateTime .

oakcurric:misconception-plausible-conclusion-claim-true-presented
  a curric:Misconception ;
  curric:statement "A plausible conclusion or claim must be true when it is presented with data."@en ;
  curric:correction "Graphs can be misinterpreted, which can lead to invalid conclusions."@en ;
  dcterms:modified "2026-02-12T08:59:18.690667Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-direction-matters-determining
  a curric:Misconception ;
  curric:statement """Pupils may think that direction matters when determining the distance between two points."""@en ;
  curric:correction "Direction matters when dealing with displacement, not distance."@en ;
  dcterms:modified "2026-02-12T08:59:18.690671Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-negative-scale-factor
  a curric:Misconception ;
  curric:statement """Pupils may think that a negative scale factor creates a smaller image than the object."""@en ;
  curric:correction """Remind them that the absolute value will be less than 1 and greater than 0 to create a smaller image. Whether the scale factor is positive or negative does not affect this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690678Z"^^xsd:dateTime .

oakcurric:misconception-using-two-side-lengths-sine
  a curric:Misconception ;
  curric:statement "Using any two side lengths for the sine formula."@en ;
  curric:correction """It must be two side lengths and the angle between them. So any two side lengths of the triangle can be used so long as you also use the angle between them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690682Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-incorrect-assumptions-diagrams
  a curric:Misconception ;
  curric:statement "Pupils may make incorrect assumptions about diagrams containing a right angle."@en ;
  curric:correction """Remind pupils that they cannot assume there is a right angle, just because two line segments look as if they are perpendicular to each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690804Z"^^xsd:dateTime .

oakcurric:misconception-straight-line-graphs-show-direct
  a curric:Misconception ;
  curric:statement "All straight line graphs show direct proportion."@en ;
  curric:correction """Only straight line graphs that pass through the origin (0, 0) show direct proportion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690809Z"^^xsd:dateTime .

oakcurric:misconception-pupils-conflate-alternate-segment-theorem
  a curric:Misconception ;
  curric:statement """Pupils may conflate the alternate segment theorem with alternate angles on parallel lines, thinking that the chord that meets the tangent is a transversal between two equal angles."""@en ;
  curric:correction """Alternate angles are only equal when the transversal is between parallel lines. In many of the examples for the alternate segment theorem, the tangent is not parallel to a chord."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690816Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-radius-sphere-constant
  a curric:Misconception ;
  curric:statement "Pupils may multiply the radius of the sphere by the constant before cubing it."@en ;
  curric:correction """Remind pupils of the order of operations and the need to cube the radius before multiplying by the constants in the formula."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690971Z"^^xsd:dateTime .

oakcurric:misconception-questions-context-length-described-depth
  a curric:Misconception ;
  curric:statement """When questions are in context, the length may be described as the depth or height and this can cause some pupils to struggle if they have learned a formula with a particular word."""@en ;
  curric:correction """Remind pupils that the volume of a 3D shape comes from the area of a cross section multiplied by the height or depth. They may need to evaluate a perpendicular length from other given information, using trigonometry or Pythagoras' theorem."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690976Z"^^xsd:dateTime .

oakcurric:misconception-pupils-read-frequency-proportion-value
  a curric:Misconception ;
  curric:statement """Pupils may read the frequency or % proportion value off of the y-axis for each group on a composite bar chart."""@en ;
  curric:correction """Remind pupils that another name for composite bar charts is a stacked bar chart and the frequency needs to be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691099Z"^^xsd:dateTime .

oakcurric:misconception-using-incorrect-value-finding-percentage
  a curric:Misconception ;
  curric:statement """Using the incorrect value for finding the percentage, for instance, the area of the unshaded when it asks for the shaded region."""@en ;
  curric:correction """Encourage pupils to underline/highlight whether they are finding the percentage of the shaded or unshaded region."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691103Z"^^xsd:dateTime .

oakcurric:misconception-pupils-subtract-overlapping-faces-their
  a curric:Misconception ;
  curric:statement "Pupils may not subtract overlapping faces from their surface area calculation."@en ;
  curric:correction """Ask the pupils to visualise turning around/rotating the compound solid, and consider which faces of the component solids would always be hidden."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691180Z"^^xsd:dateTime .

oakcurric:misconception-draw-graph-points-joined-line
  a curric:Misconception ;
  curric:statement "To draw a graph, points should always be joined with line segments."@en ;
  curric:correction """For the graph of $$y=x^3$$ show the line joining $$(0,0)$$ and $$(1,1)$$ and ask pupils to test some coordinate pairs from that line in the original equation. For example, $$(1/2,1/2)$$ does not satisfy the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691186Z"^^xsd:dateTime .

oakcurric:misconception-direct-inverse-proportions-multiplicative-relationship
  a curric:Misconception ;
  curric:statement """For all direct and inverse proportions, the multiplicative relationship is with x and y."""@en ;
  curric:correction """The multiplicative relationship whether direct or inverse can be shown as y and x^n. Show a ratio table of y and 1/x^2 and  a table of y and 1/x. The inverse multiplicative relationship is seen with y and 1/x^2 and not with 1/x."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691196Z"^^xsd:dateTime .

oakcurric:misconception-thinking-x-4-line-parallel
  a curric:Misconception ;
  curric:statement """Thinking that x = 4 is a line parallel to the x axis and that y = 4 is parallel to the y axis."""@en ;
  curric:correction """Consider the points along the line. Writing valid coordinate pairs lets pupils identify which coordinate stays the same and which one changes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691202Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-f-x-f
  a curric:Misconception ;
  curric:statement """Pupils mix-up $$-$$f$$(x)$$ and f$$(-x)$$. Which is a reflection in the $$x$$-axis? Which is in the $$y$$-axis?"""@en ;
  curric:correction """f$$(-x)$$ is the input being multiplied by $$-1$$ before the function is applied. Which coordinate is the input? The $$x$$ coordinates change from positive to negative so this must be a reflection in the $$y$$ axis."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691207Z"^^xsd:dateTime .

oakcurric:misconception-pupils-conflate-meaning-mutually-exclusive
  a curric:Misconception ;
  curric:statement """Pupils may conflate the meaning of mutually exclusive with the meaning of independent."""@en ;
  curric:correction """Emphasise the word 'exclusive' in 'mutually exclusive' to suggest that one event excludes the other. Also, emphasise that the opposite of independent is dependent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691344Z"^^xsd:dateTime .

oakcurric:misconception-assuming-graph-eventually-intercept-axes
  a curric:Misconception ;
  curric:statement "Assuming the the graph will eventually intercept the axes."@en ;
  curric:correction """Pupils can experiment with very large numbers.  Here a spreadsheet is useful to generate numbers very quickly and show that although it gets very close to zero it never actually gets there."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691349Z"^^xsd:dateTime .

oakcurric:misconception-proofs-solely-algebraic-involve-diagrams
  a curric:Misconception ;
  curric:statement "Proofs have to be solely algebraic and do not involve diagrams."@en ;
  curric:correction """Proofs involve showing that a conjecture holds for multiple cases (general case). A diagram can represent multiple cases."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691354Z"^^xsd:dateTime .

oakcurric:misconception-pupils-familiar-exponents-introduction-subscript
  a curric:Misconception ;
  curric:statement """Pupils are very familiar with exponents but the introduction of 'subscript' notation may confuse them. For example, they may think $$x_2$$ must be a function of $$x$$ because $$x^2$$ is."""@en ;
  curric:correction """Use of language helps. When talking through an iterative formula like $$x_{t+1}=8x_t +6$$ say, "The next $$x$$ value is equal to eight lots of the current $$x$$ value plus six" whilst pointing at it. Get pupils to do the same back to you."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691358Z"^^xsd:dateTime .

oakcurric:misconception-outcome-occurs-outcome-b-experiment
  a curric:Misconception ;
  curric:statement """If outcome A occurs more often than outcome B, during an experiment, pupils may conclude that outcome A has a greater probability of occurring than outcome B in future trials."""@en ;
  curric:correction """Even when two outcomes are equally likely to happen, one may occur more often than the other due to chance. You could be more confident about your conclusion if you observe a large difference in results in an experiment with a large number of trials."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691426Z"^^xsd:dateTime .

oakcurric:misconception-simplifying-ratio-completely-simplifying-three
  a curric:Misconception ;
  curric:statement """Not simplifying the ratio completely or over-simplifying a three part ratio when two of the parts share a further common factor"""@en ;
  curric:correction """Link two part ratios back to simplifying fractions and remind pupils to consider if either number is a multiple of 3 as this is often missed. Remind pupils that to simplify a ratio, every part must share the common factor you are dividing by."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691431Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-one-type-diagram
  a curric:Misconception ;
  curric:statement """Pupils may think that only one type of diagram/table can be used to represent each probability problem and worry about choosing the correct one."""@en ;
  curric:correction """Emphasise that the same probability problem can often be represented using multiple diagrams or tables. In many cases, they will be able to find what they are looking for in any representation but it may be clearer to see in some more than others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691435Z"^^xsd:dateTime .

oakcurric:misconception-confusing-domain-range-considering-inverse
  a curric:Misconception ;
  curric:statement "Confusing domain and range when considering the inverse function."@en ;
  curric:correction "The range of a function is the domain of its inverse function."@en ;
  dcterms:modified "2026-02-12T08:59:18.691440Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-write-transformation-two
  a curric:Misconception ;
  curric:statement """Pupils may want to write the transformation as two transformations, a rotation of 180° followed by an enlargement by a positive scale factor, rather than a single transformation."""@en ;
  curric:correction """Remind pupils that a single transformation is more efficient than multiple transformations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691447Z"^^xsd:dateTime .

oakcurric:misconception-y-2-x-evaluates-0
  a curric:Misconception ;
  curric:statement "$$y = 2^x$$ evaluates to $$0$$ when $$x = 0$$"@en ;
  curric:correction "Remind pupils of the laws of indices that can be used to show that $$b^{0} = 1$$"@en ;
  dcterms:modified "2026-02-12T08:59:18.691451Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-solve-problems-surds
  a curric:Misconception ;
  curric:statement "Pupils may be uncertain how to solve problems with surds."@en ;
  curric:correction """Many problems can be solved through reasoning what you know, such as fully simplifying a surd."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691456Z"^^xsd:dateTime .

oakcurric:misconception-constant-proportionality-shows-gradient-inversely
  a curric:Misconception ;
  curric:statement """The constant of proportionality shows the gradient for inversely proportional graphs."""@en ;
  curric:correction """The constant of proportionality shows the gradient for directly proportional graphs only. The constant for a reciprocal graph in the form k/x^n, shows the distance of the reciprocal from the origin."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691460Z"^^xsd:dateTime .

oakcurric:misconception-using-product-rule-pupils-unsure
  a curric:Misconception ;
  curric:statement """When using the product rule, pupils may be unsure whether they should divide the product by 2."""@en ;
  curric:correction """Pay extra attention to the context of the problem. If the order of the two outcomes is irrelevant, then you should divide by two. If each of the two outcomes is allocated to a separate event (e.g. 1st and 2nd) then do not divide by 2."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691465Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-two-way
  a curric:Misconception ;
  curric:statement """Pupils may get confused between two-way tables that show outcomes and two-way tables that show frequencies (particularly when the outcomes are numbers, such as the sum of two dice rolls)."""@en ;
  curric:correction """Two-way tables can be either used to display the sample space of individual outcomes or the frequencies of outcomes. Therefore, when using a table, it can be helpful to note down what type of data the table shows."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691469Z"^^xsd:dateTime .

oakcurric:misconception-addition-make-result-bigger
  a curric:Misconception ;
  curric:statement "That addition will always make the result bigger."@en ;
  curric:correction """If pupils are struggling with the concept that adding can make an integer smaller encourage them to use counters and form zero pairs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691510Z"^^xsd:dateTime .

oakcurric:misconception-stem-same-number-digits
  a curric:Misconception ;
  curric:statement "That the stem always has to have the same number of digits."@en ;
  curric:correction """Data with a range between 93 cm and 147 cm, draw the stem-and-leaf diagram but how do they write a key for it? Stress the leaf is the final single digit (all truncated so final digits have same place value), and all other digits form the stem."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691715Z"^^xsd:dateTime .

oakcurric:misconception-writing-equations-form-y-mx
  a curric:Misconception ;
  curric:statement """Writing equations of the form y = mx + c and getting the gradient and y-intercept the wrong way round."""@en ;
  curric:correction """Graphing software can be used to show that adding a constant is a translation of the graph. Remind pupils that the y-intercept is when x is zero which is why it is the constant in the equation. They can substitute x = 0 to check."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691720Z"^^xsd:dateTime .

oakcurric:misconception-my-construction-didnt-accurately-bisect
  a curric:Misconception ;
  curric:statement "\"My construction didn't accurately bisect the line segment\""@en ;
  curric:correction """Check that your compasses construct a full circle, and do not slip (and create a spiral-shape). Tighten the screw on your compasses, if possible. Then, if only using construction arcs that look confusing, you can construct full circles to help."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691726Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-primary-data-means
  a curric:Misconception ;
  curric:statement """Pupils may think that primary data means data they collect first hand (and no one else can collect it)."""@en ;
  curric:correction """Primary data refers to data that are directly collected for specific use in an investigation. This means that a team of researchers could collect the data for you for your investigation and this is still primary data."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691731Z"^^xsd:dateTime .

oakcurric:misconception-y-b-x-reach-zero
  a curric:Misconception ;
  curric:statement "$$y=b^x$$ will reach zero; the curve will touch the $$x$$ axis eventually."@en ;
  curric:correction """Get pupils to input large absolute $$x$$ values to appreciate that no matter how small the $$y$$ value it is still a fraction greater than zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691736Z"^^xsd:dateTime .

oakcurric:misconception-procedural-understanding-sharing-ratio-pupils
  a curric:Misconception ;
  curric:statement """Procedural understanding of sharing in a ratio where pupils add the parts, divide the amount by this and then multiply by each part without considering the information in the question."""@en ;
  curric:correction """In the lesson encourage pupils to look for keywords in the question which indicate if the amount given is the total, one part or the difference. The use of a bar model to display the information can also be used to help pupils."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691751Z"^^xsd:dateTime .

oakcurric:misconception-giving-density-answer-wrong-units
  a curric:Misconception ;
  curric:statement "Giving a density answer in the wrong units."@en ;
  curric:correction """Read the question carefully and check the units of the mass and the volume.  It may be necessary to convert between metric units."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691756Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-given-lengths
  a curric:Misconception ;
  curric:statement "Pupils may multiply all given lengths."@en ;
  curric:correction """Remind pupils that area is found by multiplying two perpendicular lengths from the shape and in some cases a coefficient (half for a triangle, pi for a circle). Trapeziums use the mean length of the parallel sides (one length)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691764Z"^^xsd:dateTime .

oakcurric:misconception-ratio-1-400-scale-model
  a curric:Misconception ;
  curric:statement """A ratio of 1 : 400 for a scale model of a car to a real car will have units of cm and metres, because a scale model is measured in cm and a real car is measured in metres."""@en ;
  curric:correction """Unless the scale explicitly includes different units of measure for each part, you must always use the same unit for each part of a ratio. So, 1 : 400 should be seen as 1 cm : 400 cm, not 400 metres, which is far too long for a car!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691771Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-probability-event-given
  a curric:Misconception ;
  curric:statement """Pupils may confuse the probability of event A given B, P(A|B), with the probability of event A and B occurring."""@en ;
  curric:correction """Use the context of the question to make a judgement about what probability is to be calculated. Try to avoid using, or draw attention to, potentially ambiguous language/notation. E.g. Is P(AB) referring to P(A given B) or P(B given A) or P(A and B)?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691821Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-set-probabilities-relating
  a curric:Misconception ;
  curric:statement """Pupils may think that any set of probabilities relating to a scenario will always sum to 1."""@en ;
  curric:correction "Probabilities sum to 1 when the events are exhaustive and mutually exclusive."@en ;
  dcterms:modified "2026-02-12T08:59:18.691826Z"^^xsd:dateTime .

oakcurric:misconception-faced-quadrilateral-three-vertices-circle
  a curric:Misconception ;
  curric:statement """When faced with a quadrilateral which has three vertices on a circle and one vertex at the centre, pupils may think that the interior angle at the centre is twice the angle at the circumference."""@en ;
  curric:correction """The two angles need to be subtended by the same arc for this circle theorem to apply. Therefore, it is the reflex angle at the centre of the circle which is twice the angle at the circumference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691830Z"^^xsd:dateTime .

oakcurric:misconception-direct-proportion-determined-calculating-gradient
  a curric:Misconception ;
  curric:statement "Direct proportion can be determined by calculating the gradient."@en ;
  curric:correction """The equation of the line should be of the form y = kx and so the y-intercept should be calculated to check it is zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691835Z"^^xsd:dateTime .

oakcurric:misconception-pupils-using-given-measures-their
  a curric:Misconception ;
  curric:statement """Pupils may only using given measures in their calculations, even when these are not the lengths required for substitution into a volume formula."""@en ;
  curric:correction """Encourage pupils to annotate diagrams to show how the are breaking down a compound/composite shape. Pupils should label the diagram with any new lengths needed. They may need to use Pythagoras or trigonometry to find these new lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692078Z"^^xsd:dateTime .

oakcurric:misconception-thinking-multiplier-2-increase-either
  a curric:Misconception ;
  curric:statement "Thinking the multiplier for a 2% increase is either 0.02 or 1.2"@en ;
  curric:correction """A 2% increase is 100% + 2% of the original amount. 102% is equivalent to 1.02 as a decimal."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692084Z"^^xsd:dateTime .

oakcurric:misconception-pupils-give-probability-fraction-wrong
  a curric:Misconception ;
  curric:statement "Pupils may give the probability as a fraction with the wrong denominator."@en ;
  curric:correction """Check that pupils understand the difference between the probability of event A given B, P(A|B), and the probability of event A and B occurring."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692089Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-circle-equation-x
  a curric:Misconception ;
  curric:statement """Pupils may think that a circle with equation $$(x+a)^2 + (y+b)^2=r^2$$ has centre $$(a,b)$$"""@en ;
  curric:correction """The general form of an equation of a circle is $$(x-a)^2 + (y-b)^2=r^2$$ where $$(a,b)$$ is then the centre. Graphing software will be useful to show and explore this general form."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692093Z"^^xsd:dateTime .

oakcurric:misconception-x-y-ratio-1-2
  a curric:Misconception ;
  curric:statement "When $$x : y$$ are in the ratio 1 : 2 pupils write the equation as $$x = 2y$$"@en ;
  curric:correction "The bar models shown in this lesson can help to support pupils with this."@en ;
  dcterms:modified "2026-02-12T08:59:18.692100Z"^^xsd:dateTime .

oakcurric:misconception-correlation-two-variables-means-one
  a curric:Misconception ;
  curric:statement """Correlation between two variables always means that one variable has a causal effect on the other."""@en ;
  curric:correction """Two variables may have correlation because they are both dependent on a third variable. E.g. one slide shows correlation between the number of cell towers in a region and the amount of transport emissions, which both correlate with population."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692105Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-tangents-drawn-slightly
  a curric:Misconception ;
  curric:statement """Pupils may assume that tangents can be drawn in slightly different directions at the same point on a circle."""@en ;
  curric:correction """The tangent at a point on a circle can only be drawn in one possible direction. The tangent is always perpendicular to the radius at that point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692110Z"^^xsd:dateTime .

oakcurric:misconception-pupils-generalise-circle-theorem-assume
  a curric:Misconception ;
  curric:statement """Pupils may over-generalise the circle theorem by assume that all triangles that are inscribed in a circle are right-angled."""@en ;
  curric:correction """The triangle is only right-angled if one of its angles is subtended by the diameter. This also means that if the triangle is right-angled, then its hypotenuse is the diameter of the circle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692114Z"^^xsd:dateTime .

oakcurric:misconception-perpendicular-lines-drawn-horizontal-vertical
  a curric:Misconception ;
  curric:statement "Perpendicular lines have to be drawn as a horizontal and vertical pair."@en ;
  curric:correction """Some pupils may struggle to see that two lines are perpendicular when they are not drawn horizontally and vertically. Drawing this on paper and then rotating the paper will help them see that it is the angle between the lines that matters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692237Z"^^xsd:dateTime .

oakcurric:misconception-plotting-sequence-connect-points-line
  a curric:Misconception ;
  curric:statement "When plotting a sequence you should always connect the points with a line."@en ;
  curric:correction """Only the (term number, term value) should be plotted. Points should not be joined as these are discrete values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692241Z"^^xsd:dateTime .

oakcurric:misconception-number-spaces-translate-shape-worked
  a curric:Misconception ;
  curric:statement """The number of spaces to translate a shape can be worked out by counting the squares on the grid."""@en ;
  curric:correction """If there are axes, then it is important to check the scales. The length of one square does not always represent one unit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692346Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-protractor-rather-pair
  a curric:Misconception ;
  curric:statement "Pupils may use a protractor rather than a pair of compasses."@en ;
  curric:correction "Remind pupils that a construction is done using a pair of compasses and ruler."@en ;
  dcterms:modified "2026-02-12T08:59:18.692350Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-write-response-boxes
  a curric:Misconception ;
  curric:statement """Pupils may struggle to write response boxes that do not overlap for continuous data."""@en ;
  curric:correction "Remind pupils of how to write intervals using inequality symbols."@en ;
  dcterms:modified "2026-02-12T08:59:18.692355Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-acceptable-use-same
  a curric:Misconception ;
  curric:statement "Pupils may think it is acceptable to use the same letter for all expressions."@en ;
  curric:correction """It may be acceptable for the letter to be the same but that depends on what the letter is representing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692359Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-stretch-transformations-many
  a curric:Misconception ;
  curric:statement """Pupils confuse 'stretch' transformations. Many transformations of the form $$y=a$$f$$(x)$$ have the appearance of a compression towards the $$y$$-axis rather than a 'stretch' in the $$y$$-direction."""@en ;
  curric:correction """Interpreting the notation is key. $$y=a$$f$$(x)$$ is the output of f$$(x)$$ being multiplied by $$a$$. Which coordinate is the output? The $$y$$ coordinates change by a scale factor of $$a$$ so this must be a stretch in the $$y$$-direction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692366Z"^^xsd:dateTime .

oakcurric:misconception-finding-surface-area-cone-pupils
  a curric:Misconception ;
  curric:statement """When finding the surface area of the cone, pupils may find the curved surface area but forget to include circular base of the cone."""@en ;
  curric:correction """By re-reading the question, and inspecting any given diagram, pupils can check if the cone is open or closed and therefore if they need to include the circular base in their calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692375Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-slant-length-needed
  a curric:Misconception ;
  curric:statement """Pupils may confuse the slant length (which is needed to find the curved surface area of the cone or frustum) with the perpendicular (or vertical) height."""@en ;
  curric:correction """Encourage pupils to clearly label their diagrams, indicating the perpendicular height with a right-angle symbol. They may need to use Pythagoras' theorem or trigonometry to calculate the slant length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692380Z"^^xsd:dateTime .

oakcurric:misconception-first-two-binomials-multiplied-first
  a curric:Misconception ;
  curric:statement "The first two binomials have to be multiplied first."@en ;
  curric:correction """Look for features of the binomials that suggest which binomials will be easiest to multiply first. Any order will give the same final product but a particular order may reduce complexity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692606Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-slant-height-needed
  a curric:Misconception ;
  curric:statement """Pupils may confuse the slant height (which is needed to find the curved surface area of the cone) with the perpendicular height (which is needed to find the volume of the cone)."""@en ;
  curric:correction """Remind pupils that for any volume calculation, three perpendicular lengths are multiplied and the slant height is not perpendicular to the base in a right cone. They may need to use Pythagoras' theorem to find the perpendicular height."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692853Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-x-y-coordinates
  a curric:Misconception ;
  curric:statement "Pupils may mix-up the x and y coordinates."@en ;
  curric:correction """Remind pupils that the x value is read from the x-axis and is read first. The y value is read from the y-axis and is read second."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692857Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-radius-intersects-chord
  a curric:Misconception ;
  curric:statement """Pupils may assume that a radius which intersects a chord always bisects the chord."""@en ;
  curric:correction "A radius only bisects a chord if they are perpendicular."@en ;
  dcterms:modified "2026-02-12T08:59:18.692862Z"^^xsd:dateTime .

oakcurric:misconception-assuming-zero-digits-significant
  a curric:Misconception ;
  curric:statement "Assuming all zero digits are not significant."@en ;
  curric:correction """Within the lesson there are many examples where some zeros are significant. Relate significance back to the communication of accuracy and that some digits are significant as they preserve the place value of other digits."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693040Z"^^xsd:dateTime .

oakcurric:misconception-800-cm-further-80-m
  a curric:Misconception ;
  curric:statement "800 cm is further than 80 m because 800 is a larger number than 80."@en ;
  curric:correction """Each unit of distance (e.g. cm, metre, km) describes a different-sized distance.  1 cm is 1/100 the size of a metre, meaning that 800 cm = 8 m is a shorter distance than 80 m."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693063Z"^^xsd:dateTime .

oakcurric:misconception-name-shape-applies-regular-version
  a curric:Misconception ;
  curric:statement """The name for a shape only applies to the regular version of that shape. E.g. An irregular pentagon is just a shape, as pentagons must have 5 equal sides."""@en ;
  curric:correction """The name of a shape is known based on the number of sides and these do not have to be regular."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693067Z"^^xsd:dateTime .

oakcurric:misconception-neglecting-follow-3-conventions-bearings
  a curric:Misconception ;
  curric:statement """Neglecting to follow the 3 conventions of bearings.  Particularly, going anticlockwise when given a bearing over 180 degrees."""@en ;
  curric:correction """Pupils can be asked to stand and turn 90 degrees.  Some will turn clockwise and some anticlockwise. This will create a discussion point about the direction being important.  Having the clockwise convention means a direction does not need to be given."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693074Z"^^xsd:dateTime .

oakcurric:misconception-estimation-guessing
  a curric:Misconception ;
  curric:statement "That estimation is guessing."@en ;
  curric:correction """Estimation is a process with each step being logical. In this case the estimation is necessary because some of the detail is lost in a grouped frequency table."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693079Z"^^xsd:dateTime .

oakcurric:misconception-multiplier-1-3-used-increase
  a curric:Misconception ;
  curric:statement "A multiplier of 1.3 is used to increase a value by 3%"@en ;
  curric:correction "A multiplier of 1.3 is used to increase a value by 30%"@en ;
  dcterms:modified "2026-02-12T08:59:18.693083Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-link-transformations-manipulating
  a curric:Misconception ;
  curric:statement """Pupils may not see the link between transformations and manipulating algebraic expressions."""@en ;
  curric:correction """Be explicit in highlighting that the graph of $$y=x^2+10x+22$$ is the graph of $$y=(x+5)^2-3$$ which is the graph of $$y=x^2$$ transformed by the translation, "$$5$$ units left, $$3$$ units down"."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693107Z"^^xsd:dateTime .

oakcurric:misconception-congruent-shapes-similar-shapes
  a curric:Misconception ;
  curric:statement "Congruent shapes are not similar shapes."@en ;
  curric:correction """Congruent shapes are similar shapes. The scale factor, or multiplier, between them is one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693288Z"^^xsd:dateTime .

oakcurric:misconception-problems-squares-inscribed-inside-circles
  a curric:Misconception ;
  curric:statement """For the problems with squares inscribed inside circles, pupils may think that the length of the square is equal to the diameter of the circle."""@en ;
  curric:correction """This would be the case if the circle was inscribed inside a square. But when the square is inscribed inside a circle, the diagonal length of the square is equal to the diameter of the circle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693292Z"^^xsd:dateTime .

oakcurric:misconception-pupils-conflate-cyclic-quadrilaterals-cases
  a curric:Misconception ;
  curric:statement """Pupils may conflate cyclic quadrilaterals with cases of "the angle at the centre of a circle is twice the angle at the circumference" theorem, when the angle at the centre is a reflex angle."""@en ;
  curric:correction """While the two diagrams may look similar at a glance, pay extra attention to whether all four points of the quadrilateral are on the circumference or if one of the points is in the centre."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693297Z"^^xsd:dateTime .

oakcurric:misconception-using-total-surface-area-solid
  a curric:Misconception ;
  curric:statement """Using the total surface area of the solid rather than the area of the solid that is in contact with the floor/table."""@en ;
  curric:correction """Refer back to the high-heeled shoe and elephants foot example.  This should clarify that it is the area in contact with the foot that increases or decreases the pressure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693441Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-b-means-either
  a curric:Misconception ;
  curric:statement "Pupils may think that A ∪ B means 'to be either from A or B (but not both)'."@en ;
  curric:correction """A ∪ B represents all members that satisfy at least one of the events A or B. So it could be from A, from B or from both A and B."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693448Z"^^xsd:dateTime .

oakcurric:misconception-directly-proportional-graphs-start-0
  a curric:Misconception ;
  curric:statement "Directly proportional graphs all start from (0,0) and are above the y axis."@en ;
  curric:correction """Directly proportional means there is a multiplier between y and x. This graph is always y=kx and is linear passing through (0,0). A proportionality graphs show the multiplicative relationship between y and x^n and can be linear and non linear."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693452Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miss-faces-prism-calculating
  a curric:Misconception ;
  curric:statement "Pupils can miss out some faces of the prism when calculating the surface area."@en ;
  curric:correction """Encourage pupils to sketch out the net of the prism and label it clearly, to ensure that they include all faces in their calculation of the surface area. This will allow their answer to be checked more easily."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693596Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-whether-need-calculate
  a curric:Misconception ;
  curric:statement """Pupils may confuse whether they need to calculate the volume or surface area of a 3D shape, if not told specifically to do so in a problem."""@en ;
  curric:correction """Use the context to decide which calculation is needed. If the question refers to packaging or painting the shape, a surface area calculation is needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693600Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-order-list-data-finding
  a curric:Misconception ;
  curric:statement """Forgetting to order the list of data before finding the 5 key pieces of information."""@en ;
  curric:correction """Ask some pupils to stand at the front of the classroom.  Find the person in the middle, and pose the question "is they the median sized person?" Repeat with quartiles. This should highlight the importance of putting the numbers in order first."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693605Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-need-rule-sine
  a curric:Misconception ;
  curric:statement "Pupils may not see the need for this rule as they have the sine rule."@en ;
  curric:correction """The sine rule can be used in many cases but it is not always the most efficient. There will be problems where it will be much faster to use the cosine rule."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693610Z"^^xsd:dateTime .

oakcurric:misconception-calculating-area-counting-squares-rather
  a curric:Misconception ;
  curric:statement "Calculating area by counting squares rather than looking at the scales."@en ;
  curric:correction """Remind pupils that often on speed-time graphs the scales on the axes will be different. Check the scales before calculating distance. Check the final answer is realistic in context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693614Z"^^xsd:dateTime .

oakcurric:misconception-pupils-estimate-negative-gradients-incorrectly
  a curric:Misconception ;
  curric:statement """Pupils may estimate negative gradients incorrectly by drawing gradient triangles the wrong way round or ignoring the fact that the $$y$$ values are decreasing as $$x$$ increases."""@en ;
  curric:correction """Pupils should look at the shape of the graph between two points and decide if it is positive or negative before calculating. If $$y$$ is decreasing as $$x$$ increases then the gradient is negative."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693619Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-tangent-curve-given
  a curric:Misconception ;
  curric:statement """Pupils may think a tangent to a curve at a given point cannot intersect the curve at another point."""@en ;
  curric:correction """Define the tangent at a point as the line which has the same gradient as the curve at that point. If the graph is cubic then it is possible for the tangent at a point to intersect the graph again. There are examples in the lesson that show this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693623Z"^^xsd:dateTime .

oakcurric:misconception-pythagoras-theorem-cannot-applied-3d
  a curric:Misconception ;
  curric:statement "Pythagoras' theorem cannot be applied to 3D shapes."@en ;
  curric:correction """Pupils may benefit from imaging the cuboid is 'sliced' through and a triangle drawn on the now visible face."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693628Z"^^xsd:dateTime .

oakcurric:misconception-use-addition-instead-multiplication-decomposing
  a curric:Misconception ;
  curric:statement "Use of addition instead of multiplication when the decomposing the number."@en ;
  curric:correction "Reiterate that the product of prime factors is unique."@en ;
  dcterms:modified "2026-02-12T08:59:18.693755Z"^^xsd:dateTime .

oakcurric:misconception-due-many-thought-processes-involved
  a curric:Misconception ;
  curric:statement """Due to the many thought processes involved with these questions, pupils may end up choosing the incorrect value as the radius for a sector."""@en ;
  curric:correction """Encourage the use of words  in their working e.g. "Diameter of shape A = 4 cm" or "Width of parallelogram = 6 mm" so when the numbers are needed again it is clear what each one is. If needed remind pupils of key word definitions such as radius."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693810Z"^^xsd:dateTime .

oakcurric:misconception-questions-context-height-cylinder-described
  a curric:Misconception ;
  curric:statement """When questions are in context, the height of the cylinder may be described as the depth or length and this can cause some pupils to struggle if they have learned a formula with a particular word."""@en ;
  curric:correction """Remind pupils that the volume of a 3D shape comes from the area of a cross section multiplied by the height or depth. Discuss which length this would be, using a diagram to support."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693815Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-possible-determine-whether
  a curric:Misconception ;
  curric:statement """Pupils may assume that it possible to determine whether a coin (or other object/game) is biased by conducting an experiment with a small number of trials."""@en ;
  curric:correction """The greater the number of trial that an experiment contains, the closer the relative frequency of an outcome gets to its theoretical probability."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693820Z"^^xsd:dateTime .

oakcurric:misconception-pupils-measure-count-object-rather
  a curric:Misconception ;
  curric:statement "Pupils may measure/count from the object rather than the centre of enlargement."@en ;
  curric:correction "Have pupils check their answers using ray lines."@en ;
  dcterms:modified "2026-02-12T08:59:18.693825Z"^^xsd:dateTime .

oakcurric:misconception-leaving-key-information-sketching-graphs
  a curric:Misconception ;
  curric:statement "Leaving out key information when sketching graphs."@en ;
  curric:correction """Although sketches do not need to be to scale they do need to contain all key information. Getting pupils to write these on as coordinate pairs is the clearest way. Sketches still have to be useful for the purpose of a model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693832Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-mean-median-mode
  a curric:Misconception ;
  curric:statement """Pupils may believe that as mean, median and mode are all averages that they are all as useful as each other for every data set."""@en ;
  curric:correction """Using non qualitative data to show that the mean and median cannot be calculated, so the mode would be the only option. Showing data sets that have the same mean value but are considerably different to each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693837Z"^^xsd:dateTime .

oakcurric:misconception-describing-movement-vectors-across-used
  a curric:Misconception ;
  curric:statement """When describing the movement of vectors, "across" is used to describe a horizontal movement."""@en ;
  curric:correction """Embed the understanding that "across" refers to the horizontal component, but the direction must be described concisely as a vector has direction and magnitude."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693844Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-f-x
  a curric:Misconception ;
  curric:statement """Pupils can get confused between $$-$$f$$(x)$$ and f$$(-x)$$, which one is a reflection in the $$x$$-axis and which is a reflection in the $$y$$-axis?"""@en ;
  curric:correction """Interpreting the notation is key. Remind pupils that $$-$$f$$(x)$$ is the output of f$$(x)$$ being multiplied by $$-1$$. Which coordinate is the output? The $$y$$ coordinates are altered from positive to negative, that is a reflection in which axis?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693848Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-vertical-translation-depending
  a curric:Misconception ;
  curric:statement """Pupils may not see the vertical translation depending on the function used to show the effect of $$a$$."""@en ;
  curric:correction """Ensure pupils consider a range of functions so that they can see the movement of the graph."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693853Z"^^xsd:dateTime .

oakcurric:misconception-pupils-using-given-measures-terms
  a curric:Misconception ;
  curric:statement """Pupils may only using given measures or terms in their calculations, even when these are not the lengths required to form an expression for the volume or surface area."""@en ;
  curric:correction """Encourage pupils to annotate diagrams to clearly show how the are breaking down a compound shape, and label clearly any new or missing lengths they can determine."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694068Z"^^xsd:dateTime .

oakcurric:misconception-pupils-misconfigure-net-believing-long
  a curric:Misconception ;
  curric:statement """Pupils may misconfigure the net, believing that as long as the shapes of the faces are correct, the net will fold to be the desired 3D shape."""@en ;
  curric:correction """Have pupils mark/label/colour the edges that will join upon folding the net, this will ensure they are the correct length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694191Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-draw-triangle-using
  a curric:Misconception ;
  curric:statement """Pupils may try to draw the triangle using only a pencil and ruler, rather than construct it using a pair of compasses."""@en ;
  curric:correction """Remind pupils that if the task is to 'construct' then they must use their geometry equipment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694197Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-contexts-e-g
  a curric:Misconception ;
  curric:statement """Pupils may not consider that, in some contexts (e.g. a corded lawnmower), the shape of the locus will include sectors of different radii, if a shape/object is creating a barrier."""@en ;
  curric:correction "Have pupils consider the impact of going around the corner of a shape."@en ;
  dcterms:modified "2026-02-12T08:59:18.694202Z"^^xsd:dateTime .

oakcurric:misconception-interpolation-accurate-extrapolation
  a curric:Misconception ;
  curric:statement "Interpolation is always more accurate than extrapolation."@en ;
  curric:correction """If a graph is plotting data collected at set points then there is no way to know what is happening between the points. The trend between the points could be a curve, a line or could fluctuate. Interpolation could therefore be inaccurate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694207Z"^^xsd:dateTime .

oakcurric:misconception-iterative-formula-used-find-solutions
  a curric:Misconception ;
  curric:statement "An iterative formula can always be used to find the solutions to an equation."@en ;
  curric:correction """This lesson addresses limitations of iteration. Some formulas will cause an error becasue we are unable to evaluate the square root of a negative or divide by 0. Other formulas may not converge. Different values of $$x_0$$ produce different results."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694211Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miss-key-pictogram-axes
  a curric:Misconception ;
  curric:statement "Pupils may miss the key in a pictogram, or the axes labels on a bar chart."@en ;
  curric:correction """Pupils could be provided with a success criteria list, which they get in a habit of checking after constructing pictograms and bar charts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694383Z"^^xsd:dateTime .

oakcurric:misconception-double-radius-sector-its-area
  a curric:Misconception ;
  curric:statement "If I double the radius of a sector, its area also doubles."@en ;
  curric:correction """The radius and area of a sector (or circle) do not share a linear relationship, so you cannot apply direct proportional reasoning. However, angle of a sector and its area do share a linear relationship, as long as the angle is ≤ 360°."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694567Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-cone-pyramid
  a curric:Misconception ;
  curric:statement "Pupils may think that a cone is a pyramid."@en ;
  curric:correction """Remind pupils that a pyramid has a polygonal base, so a cone cannot be a pyramid as the base is a circle, which is not a polygon."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694572Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-four-five-six
  a curric:Misconception ;
  curric:statement """When pupils see four, five or six trapezia they want to work each one out individually, then, do another calculation adding those four, five, six areas together."""@en ;
  curric:correction """This is hugely inefficient. Write out the sum of the area of multiple trapeziums then, from there, look for efficiencies. This is where applying knowledge of factorisation can be beneficial as it reduces the work."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694585Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-reflecting-across-diagonal
  a curric:Misconception ;
  curric:statement """Pupils may find reflecting across a diagonal line more challenging than vertically or horizontally."""@en ;
  curric:correction """Pupils may find it easier with tracing paper, or rotating their book/paper so the line of reflection is vertical."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694750Z"^^xsd:dateTime .

oakcurric:misconception-pupils-draw-x-horizontal-line
  a curric:Misconception ;
  curric:statement """Pupils draw x = a as a horizontal line because the x axis is horizontal. Pupils draw y = a as a vertical line because the y axis is vertical."""@en ;
  curric:correction """Consider the points on the line x = 5 and ask pupils to plot 2-3 points. Can they see why it must be a vertical line?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.694754Z"^^xsd:dateTime .

oakcurric:misconception-fully-isolating-required-variable-leaving
  a curric:Misconception ;
  curric:statement """Not fully isolating the required variable by leaving other terms containing the variable in the expression."""@en ;
  curric:correction """To make a variable the subject, it must be expressed in terms of other variables only. Factorising helps isolate a variable if it is in multiple terms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694761Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-errors-given-dimensions
  a curric:Misconception ;
  curric:statement """Pupils can make errors if given the dimensions/measurements of the cylinder using different units (for example the radius is given in cm and the length in m)."""@en ;
  curric:correction """Remind pupils to convert all measurements to the same unit (such as cm or m) before starting the calculation. Usually there is a prompt in the question to use as a guide, for example give your answer in square centimetres."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694905Z"^^xsd:dateTime .

oakcurric:misconception-interpolation-extrapolation-produce-accurate-predictions
  a curric:Misconception ;
  curric:statement "Interpolation and extrapolation always produce accurate predictions."@en ;
  curric:correction """Extrapolation may not be valid as this is outside the observed set of data values (e.g. a linear trend might not continue indefinitely). Interpolation may not be valid due to the limitations of the data set."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694909Z"^^xsd:dateTime .

oakcurric:misconception-reflection-vector-x-y-axis
  a curric:Misconception ;
  curric:statement """A reflection of a vector in the x or y axis is not the reverse of a vector.  This is often seen with equilateral triangles and vectors."""@en ;
  curric:correction """When multiplying the vectors by -1 this gives the opposite direction of the vector only.  The magnitude remains the same.  Investigate with pupils by drawing column vectors and multiply by -1 and compare."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694914Z"^^xsd:dateTime .

oakcurric:misconception-get-different-linear-scale-factors
  a curric:Misconception ;
  curric:statement """I will get different linear scale factors if a measure corresponding lengths in cm vs inches."""@en ;
  curric:correction """Scale factors do not have dimensions, and aren't linked to specific units. If one length is 23 cm (9 inches), and a corresponding length is 69 cm (27 inches), then the scale factor between them is 3, regardless of whether we measured in cm or inches."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694921Z"^^xsd:dateTime .

oakcurric:misconception-combined-transformation-3-f-x
  a curric:Misconception ;
  curric:statement """For the combined transformation $$3$$f$$(x-2)$$ order does not matter so pupils may assume that order never matters."""@en ;
  curric:correction """For $$3$$f$$(x-2)$$ the $$3$$ affects the output, the $$y$$ value, and the $$-2$$ affects the input, the $$x$$ value. Model to show that these can happen in either order. Then point out that $$3$$f$$(x)-2$$ is two effects on the output."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694925Z"^^xsd:dateTime .

oakcurric:misconception-change-sign-indicates-solution-change
  a curric:Misconception ;
  curric:statement """A change in sign always indicates a solution. No change in sign means no solution."""@en ;
  curric:correction """A change in sign only indicates a solution if the equation is equal to zero and if the graph of the equation crosses the $$x$$ axis between those points. Where there is a repeated root or two solutions between them there may be no change in sign."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695095Z"^^xsd:dateTime .

oakcurric:misconception-1-0-evaluates-give-0
  a curric:Misconception ;
  curric:statement "$$1 / 0$$ evaluates to give $$0$$"@en ;
  curric:correction """Get pupils to consider what happens when $$x=1/2$$, $$x=1/3$$, $$x=1/4$$ etc. This will help them spot the role of the $$y$$ axis as asymptote for themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695373Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-use-criteria-without
  a curric:Misconception ;
  curric:statement """Pupils may try and use this criteria without knowing the angle between the two sides."""@en ;
  curric:correction """Pupils can construct triangles with two sides and an angle to see that there are two potential triangles, and therefore congruency is not guaranteed with SSA."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695378Z"^^xsd:dateTime .

oakcurric:misconception-pupils-reason-two-angles-same
  a curric:Misconception ;
  curric:statement """Pupils may reason that two angles are the same size, as they are subtended by the same chord."""@en ;
  curric:correction """Angles are equal, if they are in the same segment, subtended by the same arc, as well as subtended by the same chord."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695382Z"^^xsd:dateTime .

oakcurric:misconception-gradient-change-y-divided-change
  a curric:Misconception ;
  curric:statement "Gradient is change in $$y$$ divided by change in $$x$$."@en ;
  curric:correction """The gradient is calculated by considering the change in $$y$$ when moving one unit in the positive $$x$$ direction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695387Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-angle-pairs-side
  a curric:Misconception ;
  curric:statement "Pupils may be uncertain about which angle pairs with which side."@en ;
  curric:correction "The angle is paired with the side length that is opposite."@en ;
  dcterms:modified "2026-02-12T08:59:18.695526Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tempted-use-total-frequency
  a curric:Misconception ;
  curric:statement """Pupils may be tempted to always use the total frequency from a tree as the denominator of any fraction."""@en ;
  curric:correction """The denominator of the fraction should be the total frequency of the group that is being selected from. This could be the total population or it could be a subgroup of the population."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695661Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-one-point-equidistant
  a curric:Misconception ;
  curric:statement """Pupils may believe that there is only one point which is equidistant from two points."""@en ;
  curric:correction """Highlight that forming any isosceles triangle will mean that that the point is equidistant from both points."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695685Z"^^xsd:dateTime .

oakcurric:misconception-plan-elevations-show-aspect-solid
  a curric:Misconception ;
  curric:statement "The plan and elevations show every aspect of a solid."@en ;
  curric:correction "The plan and elevations do not show the features inside a solid."@en ;
  dcterms:modified "2026-02-12T08:59:18.695690Z"^^xsd:dateTime .

oakcurric:misconception-finding-perimeter-rectilinear-compound-shape
  a curric:Misconception ;
  curric:statement """When finding the perimeter of a rectilinear compound shape, pupils might sum the perimeters of each rectangle."""@en ;
  curric:correction """Part of the perimeter for each rectangle is inside the compound shape. Therefore, not all of the perimeter of each rectangle contributes towards the perimeter of the compound shape in this problem."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695843Z"^^xsd:dateTime .

oakcurric:misconception-interval-widths-need-constant-conversely
  a curric:Misconception ;
  curric:statement """That the interval widths need to be constant, or conversely that they can be anything."""@en ;
  curric:correction """If interested in people's ages it may be that decades makes sense once over 30 but that significant ages such as 16, 18 and 21 should form boundaries, depending on context. Encourage critical thinking for data with unequal intervals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695849Z"^^xsd:dateTime .

oakcurric:misconception-treating-ratio-total-amount-example
  a curric:Misconception ;
  curric:statement """Treating the ratio as the total amount. For example sweets : chocolates in the ratio 6 : 7 and 2 chocolates are eaten, thinking the ratio must now be 6 : 5"""@en ;
  curric:correction """Looking at how these problems are formed in learning cycle 1 will help and getting pupils to explore how the ratio changes when things are added or removed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695854Z"^^xsd:dateTime .

oakcurric:misconception-misidentifying-hypotenuse
  a curric:Misconception ;
  curric:statement "Misidentifying the hypotenuse."@en ;
  curric:correction """The hypotenuse is the longest side of a right-angled triangle. It is always opposite the right-angle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695859Z"^^xsd:dateTime .

oakcurric:misconception-pupils-reach-false-conclusions-following
  a curric:Misconception ;
  curric:statement """Pupils may reach false conclusions by not following the Statistical Enquiry Cycle and skipping stages."""@en ;
  curric:correction """Ask pupils to consider trying to draw conclusions from a large data set of raw values, where no processing or representation has taken place, to highlight the need for that stage in particular."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695865Z"^^xsd:dateTime .

oakcurric:misconception-pupils-equivalent-algebraic-expressions-without
  a curric:Misconception ;
  curric:statement "Some pupils may have an equivalent algebraic expressions without noticing."@en ;
  curric:correction """Tell pupils to always check if their expressions can be simplified or factorised before deeming themselves incorrect."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695870Z"^^xsd:dateTime .

oakcurric:misconception-plotting-midpoint-class-against-cumulative
  a curric:Misconception ;
  curric:statement "Plotting the midpoint of the class against the cumulative frequency."@en ;
  curric:correction """Ensure that the pupils are clear that each cumulative frequency includes all values up to the upper boundary of each group."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695876Z"^^xsd:dateTime .

oakcurric:misconception-pupils-count-triangles-row-determine
  a curric:Misconception ;
  curric:statement """Pupils count all the triangles in a row to determine length rather than only counting the ones which have an edge on the line."""@en ;
  curric:correction """Encourage pupils to consider what they are using to measure when they draw each line on isometric paper."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695942Z"^^xsd:dateTime .

oakcurric:misconception-finding-perimeter-sector-need-multiply
  a curric:Misconception ;
  curric:statement "\"When finding the perimeter of a sector, I need to multiply the radius by a fraction of a full circle, just like I did with the circumference to find the arc length.\""@en ;
  curric:correction """Reminder that only part (the arc length) of the formula for perimeter of a sector varies with the angle. A desmos or geogebra model can help to show this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695948Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-incorrect-trigonometric-formula
  a curric:Misconception ;
  curric:statement "Pupils may use the incorrect trigonometric formula."@en ;
  curric:correction """Encourage pupils to label their triangles with the name for each side. This helps to identify the opposite, adjacent and hypotenuse."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695955Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gradient-line-model
  a curric:Misconception ;
  curric:statement """Pupils may think the gradient of the line to model simple interest is always the interest rate."""@en ;
  curric:correction """This works when investing £100 but not with other start values. The gradient is the amount of interest added each time which depends on the amount invested and the interest rate. There are examples to show this in the lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695960Z"^^xsd:dateTime .

oakcurric:misconception-missing-partial-products
  a curric:Misconception ;
  curric:statement "Missing out partial products"@en ;
  curric:correction """Relating back to numerical examples and showing that 12 × 34 is not just 10 × 30 + 2 × 4. Using algebra tiles and area models can help to support student's understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696049Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-select-correct-process
  a curric:Misconception ;
  curric:statement "Pupils may struggle to select the correct process of perimeter or area."@en ;
  curric:correction """Pupils should consider whether a space is to be covered in which case it is most likely area."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696080Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-interpreting-inequality-diagram
  a curric:Misconception ;
  curric:statement "Incorrectly interpreting the inequality diagram."@en ;
  curric:correction """A filled in circle means the value is valid. An empty circle means the inequality is strict."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696089Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-interpreting-inequalities-due-phrasing
  a curric:Misconception ;
  curric:statement "Incorrectly interpreting inequalities due to the phrasing in English."@en ;
  curric:correction """It can be helpful to think about the context when interpreting the phrasing. If a speed limit of 30 mph, would it be acceptable to do more than 30 mph? Is the car allowed to travel at a lower speed at any point?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.696094Z"^^xsd:dateTime .

oakcurric:misconception-two-pairs-coordinates-needed-plot
  a curric:Misconception ;
  curric:statement "Only two pairs of coordinates are needed to plot a linear graph."@en ;
  curric:correction """Whilst true, this can cause issues if one pair of coordinates is calculated incorrectly. Encourage pupils to check a third point to ensure they are correct."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696098Z"^^xsd:dateTime .

oakcurric:misconception-pupils-erase-their-construction-marks
  a curric:Misconception ;
  curric:statement "Pupils may erase their construction marks."@en ;
  curric:correction """Remind pupils that they should always leave their construction marks on their diagrams but encourage them not to press to hard with their pencils."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696105Z"^^xsd:dateTime .

oakcurric:misconception-demonstration-proof
  a curric:Misconception ;
  curric:statement "A demonstration is a proof."@en ;
  curric:correction """A demonstration shows that it works for that one specific case. A proof allows us to know all cases that are true."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696109Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-two-x-values
  a curric:Misconception ;
  curric:statement """Pupils find the two $$x$$ values after solving the combined quadratic and declare that the solution."""@en ;
  curric:correction """It is important to substitute both $$x$$ values back in to one of the original equations to find the corresponding $$y$$ values. Without these, the solutions are incomplete."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696114Z"^^xsd:dateTime .

oakcurric:misconception-pupils-give-angle-rather-bearing
  a curric:Misconception ;
  curric:statement "Pupils may give an angle rather than a bearing."@en ;
  curric:correction """Remind pupils that a bearing is an angle, measured clockwise from North and given as three figures."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696762Z"^^xsd:dateTime .

oakcurric:misconception-graph-drawn-axes-scale-shown
  a curric:Misconception ;
  curric:statement """A graph drawn on axes with no scale shown means nothing is known about the graph."""@en ;
  curric:correction """Understanding the shape of a parabola, cubic curve, and reciprocal graph and then applying key features like positive/negative coefficients and $$y$$-intercepts enables pupils to infer much about the equation without needing actual coordinate values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696770Z"^^xsd:dateTime .

oakcurric:misconception-reciprocal-graphs-appear-two-quadrants
  a curric:Misconception ;
  curric:statement """All reciprocal graphs appear only in two quadrants and have both axes as asymptotes."""@en ;
  curric:correction """Show pupils the graphs of the $$y={1\\over{x}}$$, then $$y={1\\over{x}}+1$$, then $$y={1\\over{x+1}}$$ and get them to compare which forms have which axes as asymptotes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696774Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-constructed-congruent-triangles
  a curric:Misconception ;
  curric:statement """Some pupils may not recognise that they have constructed congruent triangles to one and another."""@en ;
  curric:correction """Use a piece of tracing paper to show that the triangles are congruent to each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696858Z"^^xsd:dateTime .

oakcurric:misconception-trigonometric-ratios-cannot-applied-3d
  a curric:Misconception ;
  curric:statement "Trigonometric ratios cannot be applied to 3D shapes."@en ;
  curric:correction """Pupils may benefit from imaging the cuboid is 'sliced' through and a triangle drawn on the now visible face."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696862Z"^^xsd:dateTime .

oakcurric:misconception-using-venn-diagram-students-mix
  a curric:Misconception ;
  curric:statement "When using a Venn diagram students often mix up HCF & LCM."@en ;
  curric:correction "Encourage students to check the reasonableness of their answer."@en ;
  dcterms:modified "2026-02-12T08:59:18.697057Z"^^xsd:dateTime .

oakcurric:misconception-pupils-feel-one-statistical-summary
  a curric:Misconception ;
  curric:statement "Pupils may feel that one statistical summary is enough to compare two data sets."@en ;
  curric:correction """Highlight to pupils that the more information you know, the better your understanding of a data set and therefore a more comprehensive comparison can take place. Compare the means of {-120, -100, -50, 0, 1000} and {145, 145, 146, 147, 147}."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697061Z"^^xsd:dateTime .

oakcurric:misconception-using-wrong-trigonometric-function
  a curric:Misconception ;
  curric:statement "Using the wrong trigonometric function."@en ;
  curric:correction """Encourage pupils to draw the right-angled triangle for the scenario if they are unsure so that they can label the sides and be confident about which trigonometric function is needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697066Z"^^xsd:dateTime .

oakcurric:misconception-y-x-3-one-root
  a curric:Misconception ;
  curric:statement "$$y=x^3$$ has one root so all cubic graphs have one root."@en ;
  curric:correction """Make sure pupils see a wide variety of cubic graphs; ones with one root, two roots and three roots and link every one back to its equation and that the highest exponent of the variable is $$3$$ so they are all cubic graphs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697070Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-locus-line-rectangle
  a curric:Misconception ;
  curric:statement "Pupils may think that the locus of a line is a rectangle."@en ;
  curric:correction """Choose the vertices of their rectangle and ask if they are the same distance from the line as another point. Link to Pythagoras' theorem if necessary to highlight that the diagonal length will be longer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697211Z"^^xsd:dateTime .

oakcurric:misconception-mean-median-mode-useful-close
  a curric:Misconception ;
  curric:statement "Mean, median and mode are only useful if they are close together."@en ;
  curric:correction """If the mean is significantly higher or lower than the other averages, this suggests an extreme value in the data set."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697268Z"^^xsd:dateTime .

oakcurric:misconception-pupils-divide-total-number-rows
  a curric:Misconception ;
  curric:statement """Pupils may divide the total by the number of rows in the frequency table when finding the mean."""@en ;
  curric:correction """On most occasions, the pupils calculated mean will be a value outside of the data set, so a sense-check should highlight that something is not quite right. Encourage pupils to always consider if their answer is reasonable."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697273Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-line-segment-touches
  a curric:Misconception ;
  curric:statement """Pupils may think that every line segment that touches a circle exactly once is a tangent (even when it is not perpendicular to the radius at that point)."""@en ;
  curric:correction """If unsure, try extending the line segment to beyond the edges of the circle to check whether it would intersect the circle again."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697282Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unintentionally-add-bias-their
  a curric:Misconception ;
  curric:statement "Pupils may unintentionally add bias to their questions."@en ;
  curric:correction """Have other pupils check questions for any bias and support their peers in rewording them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697287Z"^^xsd:dateTime .

oakcurric:misconception-finding-additive-relationship-two-numbers
  a curric:Misconception ;
  curric:statement """Finding the additive relationship between two numbers instead of the multiplicative one."""@en ;
  curric:correction """When dealing with any proportional relationships, such as ratios, pupils should be reminded to look for the multiplicative relationship. Using 1 as a middle step can help. e.g. to connect 5 and 8, divide by 5 to make 1 and then multiply by 8."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697292Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-use-protractor-draw
  a curric:Misconception ;
  curric:statement "Pupils may want to use a protractor to draw a right angle."@en ;
  curric:correction """Remind pupils that they need to construct the right angle with a pair of compasses and a ruler, using appropriate construction techniques."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697297Z"^^xsd:dateTime .

oakcurric:misconception-combining-ratios-without-using-equivalent
  a curric:Misconception ;
  curric:statement "Combining ratios without using equivalent ratios to equate the common part."@en ;
  curric:correction """Pupils may need to spend extra time finding equivalent ratios and looking at when it is ok to combine ratios or not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697301Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-start-problem
  a curric:Misconception ;
  curric:statement "Pupils may be uncertain over how to start a problem."@en ;
  curric:correction """Encourage pupils to draw a diagram if one is not provided and then to annotate the diagram with any given information as a first step. If a diagram is given then pupils should annotate that."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697306Z"^^xsd:dateTime .

oakcurric:misconception-3-x-9-valid-way
  a curric:Misconception ;
  curric:statement "3 > x > 9 is a valid way to combine x < 3 and x > 9"@en ;
  curric:correction """Test a value to show pupils that this does not make sense. When x = 0, it is true that x < 3 but not true that x > 9 so 3 > 0 > 9 does not work."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697311Z"^^xsd:dateTime .

oakcurric:misconception-lot-information-process-order-complete
  a curric:Misconception ;
  curric:statement """There is often a lot of information to process, in order to complete a three event Venn diagram accurately. Pupils may confuse which region to complete."""@en ;
  curric:correction """A three event Venn diagram is easier to complete if information from intersecting events is completed first."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697317Z"^^xsd:dateTime .

oakcurric:misconception-working-surface-area-pupil-find
  a curric:Misconception ;
  curric:statement """When working out the surface area, the pupil may only find the sum of the areas of three faces of a cuboid (for example the visible sides in a 3D drawing), instead of all six faces."""@en ;
  curric:correction """Encourage pupils to sketch the net of the cuboid as part of their solution. This will provide a visual reminder to the pupil to find the area of all six faces, as well as making it easier to check their answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697324Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-area-parallelograms-triangles
  a curric:Misconception ;
  curric:statement """Pupils might find the area of parallelograms and triangles by multiplying the length of two adjacent edges which are not perpendicular."""@en ;
  curric:correction """Calculating the area of a shape involves multiplying two perpendicular lengths. These may not be horizontal and vertical in the shape's initial orientation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697328Z"^^xsd:dateTime .

oakcurric:misconception-variables-used-diagrams-pupils-unsure
  a curric:Misconception ;
  curric:statement """When variables are used in diagrams, pupils may be unsure whether it represents a probability, frequency or a particular outcomes."""@en ;
  curric:correction """Variables can be used to represent either of these pieces of information. It can be helpful to start a problem by writing down what the variables represent (e.g. "Let x = the total number of marbles)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697351Z"^^xsd:dateTime .

oakcurric:misconception-misinterpreting-scale-particularly-given-units
  a curric:Misconception ;
  curric:statement "Misinterpreting a scale, particularly if given with no units."@en ;
  curric:correction """Encourage pupils to carefully convert the scale into a more useful scale.  E.g.  writing 1 : 20 0000 as 1 cm = 2 km"""@en ;
  dcterms:modified "2026-02-12T08:59:18.697424Z"^^xsd:dateTime .

oakcurric:misconception-lines-cannot-added-given-diagram
  a curric:Misconception ;
  curric:statement "Lines cannot be added to the given diagram."@en ;
  curric:correction """Often adding additional or found information to a given diagram can help progress towards a solution. Pupils should not be afraid to extend given line segments nor add notation if appropriate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697433Z"^^xsd:dateTime .

oakcurric:misconception-pupils-measure-count-object-instead
  a curric:Misconception ;
  curric:statement "Pupils may measure/count from the object instead of the centre of enlargement."@en ;
  curric:correction "Encourage pupils to check their answers by using ray lines."@en ;
  dcterms:modified "2026-02-12T08:59:18.697821Z"^^xsd:dateTime .

oakcurric:misconception-plan-elevations-look-exactly-same
  a curric:Misconception ;
  curric:statement """The plan and elevations should look exactly the same on squared paper as they do on a solid drawn on isometric paper."""@en ;
  curric:correction """The grid lines on the two types of paper are not the same which is why there is a visual difference. The measurements for each line however have not changed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697826Z"^^xsd:dateTime .

oakcurric:misconception-names-hat-simplest-way-perform
  a curric:Misconception ;
  curric:statement "Names in a hat is the simplest way to perform a simple random sample."@en ;
  curric:correction "This can be true for very small populations but becomes time consuming quickly."@en ;
  dcterms:modified "2026-02-12T08:59:18.697830Z"^^xsd:dateTime .

oakcurric:misconception-situations-weightings-subjective
  a curric:Misconception ;
  curric:statement "That for all situations the weightings are subjective."@en ;
  curric:correction """There are situations in which a subjective decision is made about weightings but there are also situations where the multipliers used are dictated by the context in a logical way. An example of this is combining groups and combining their means."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697839Z"^^xsd:dateTime .

oakcurric:misconception-stratified-sampling-biased-therefore-produces
  a curric:Misconception ;
  curric:statement "Stratified sampling is biased and therefore produces a bad sample."@en ;
  curric:correction """Stratified sampling is used to take a representative sample from the population. Selecting from within the strata can be done using a simple random sample."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697908Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-order-data-support
  a curric:Misconception ;
  curric:statement """Pupils may forget to order the data to support finding the median, mode and range."""@en ;
  curric:correction """Use small data (ordered and unordered) to find the range and the median based on position. Race to find range and median of a longer list with one "team" ordering first and the other team not. Ordering can help with speed, accuracy and give insight."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697913Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-cut-height-cone
  a curric:Misconception ;
  curric:statement """Pupils may think that if you cut the height of the cone in a half, the resulting frustrum will have half the volume of the original cone."""@en ;
  curric:correction """The frustrum is actually seven eighths of the volume of the original cone; the small cone that was removed to create the frustrum is one eighth the volume of the original cone if the frustrum and the small cone have the same height."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697919Z"^^xsd:dateTime .

oakcurric:misconception-long-equation-solved-value-sequence
  a curric:Misconception ;
  curric:statement "As long as the equation can be solved, the value will be in the sequence."@en ;
  curric:correction """For the value to be in the sequence, the value for $$n$$ must be a positive integer. If it is not, then the value is not in the sequence as the term number must be a positive integer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700432Z"^^xsd:dateTime .

oakcurric:misconception-including-solutions-valid-context-question
  a curric:Misconception ;
  curric:statement "Including solutions which are not valid in the context of the question."@en ;
  curric:correction """Pupils should finish every problem by substituting their solutions back into the original problem. This will help them check their answers but also make them think about whether their solutions are valid in context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700438Z"^^xsd:dateTime .

oakcurric:misconception-example-measurement-12-cm-given
  a curric:Misconception ;
  curric:statement """For example if a measurement of 12 cm has been given to the nearest centimetre assuming the upper bound is 12.4 cm."""@en ;
  curric:correction "Emphasise the infinite nature of a measurement."@en ;
  dcterms:modified "2026-02-12T08:59:18.700851Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-multiply-term-equation-scaling
  a curric:Misconception ;
  curric:statement """Forgetting to multiply every term in the equation when scaling or not multiplying every term by the same value."""@en ;
  curric:correction """Remind pupils that in order to maintain equality, the entire expression on both sides of the equals sign must be multiplied by the same value. Clear working and checking solutions can help pupils spot when they have made this mistake."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700920Z"^^xsd:dateTime .

oakcurric:misconception-leaving-answers-fully-factorised-required
  a curric:Misconception ;
  curric:statement "Leaving answers which are not fully factorised when they are required to."@en ;
  curric:correction """There should be a focus on reading questions to decipher what they are being asked to do. When they have to fully factorise they need the highest common factor of all the terms. LC3 focuses on situations where they are not going to fully factorise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701842Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-graph-displayed-shows
  a curric:Misconception ;
  curric:statement "Pupils assume that the graph displayed always shows the number of solutions."@en ;
  curric:correction """It is important to compare the range of values that the graph is displaying against what is being defined in the question."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702225Z"^^xsd:dateTime .

oakcurric:misconception-simplifying-frac-x-4-x
  a curric:Misconception ;
  curric:statement """Simplifying $$\\\\frac{(x+4)}{(x+5)}$$ by crossing out the $$x$$ terms and getting $$\\\\frac{4}{5}$$"""@en ;
  curric:correction """Refrain from crossing out factors. Instead pupils should write the numerator and denominator as products of the hightest common factor and see that HCF/HCF = 1."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702248Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-reciprocal-frac-1
  a curric:Misconception ;
  curric:statement """Pupils may think that the reciprocal of $$\\\\frac{1}{a} + \\\\frac{1}{b}$$ is $$a + b$$"""@en ;
  curric:correction """$$\\\\frac{1}{2} + \\\\frac{1}{4} = \\\\frac{3}{4}$$ which is not the reciprocal of 2 + 4 = 6. To find the reciprocal, it helps for the expression to be written as a single fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702253Z"^^xsd:dateTime .

oakcurric:misconception-substituting-negative-values
  a curric:Misconception ;
  curric:statement "Substituting with negative values."@en ;
  curric:correction "Putting brackets around all substituted values is good practice."@en ;
  dcterms:modified "2026-02-12T08:59:18.702873Z"^^xsd:dateTime .

oakcurric:misconception-since-common-difference-impossible-find
  a curric:Misconception ;
  curric:statement "Since there is no common difference, it is impossible to find the n^th term."@en ;
  curric:correction """The first learning cycle shows how we can build quadratic sequences from n^2 and a linear sequence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702878Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-domain-range
  a curric:Misconception ;
  curric:statement "Pupils may confuse the domain and the range."@en ;
  curric:correction """Drawing the graph of the function and labelling the axes correctly will help pupils connect domain and range."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703342Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-gradient-radius-length
  a curric:Misconception ;
  curric:statement "Pupils can confuse the gradient of the radius with the length of the radius."@en ;
  curric:correction """A sketch will help pupils apply the right skills. To find the equation of a straight line we need the gradient. You may wish to draw concentric circles to show pupils that the radii are different lengths but can have same gradient."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703346Z"^^xsd:dateTime .

oakcurric:misconception-multiplying-terms-coefficients-pupils-add
  a curric:Misconception ;
  curric:statement """When multiplying terms with coefficients, pupils also add the coefficients as well as the exponents."""@en ;
  curric:correction """Pupils should be encouraged to rewrite their expression using the associative and commutative laws, with the number parts grouped and powers grouped. This hopefully avoids this error as they can see it is the product of the numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703593Z"^^xsd:dateTime .

oakcurric:misconception-converting-units-correctly-question-forgetting
  a curric:Misconception ;
  curric:statement """Not converting the units correctly in a question or forgetting to have the same units before simplifying a ratio"""@en ;
  curric:correction """help pupils to set out ratio tables where they include the units and work through step by step to convert correctly before simplifying. The ratio table can help organise this working."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703642Z"^^xsd:dateTime .

oakcurric:misconception-assuming-increase-10-followed-decrease
  a curric:Misconception ;
  curric:statement """Assuming that an increase of 10% followed by a decrease of 10% takes you back to 100%, etc."""@en ;
  curric:correction """Provide plenty of examples to illustrate the structure of what happens.  If you increase a number by a percentage the number will increase meaning that you will be finding 10% of a larger number and hence decrease by more."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703647Z"^^xsd:dateTime .

oakcurric:misconception-one-method-superior-solving-simultaneous
  a curric:Misconception ;
  curric:statement "One method is superior when solving simultaneous equations."@en ;
  curric:correction """Understanding that there are often multiple ways to solve the same problem and then be able to accurately execute a variety of methods is very useful. In this topic, it can enable pupils to confirm their solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703938Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-multiply-100-converting
  a curric:Misconception ;
  curric:statement """Pupils understand they multiply by 100 when converting m to cm, but when converting m^2 to cm^2, fail to recognise the need to multiply by 100^2. This is also the same with volume conversions."""@en ;
  curric:correction """Illustrate a 1m^2 square and the equivalent 100cm^2 square, calculating the area and allowing pupils to see the equivalence of 1 m^2 = 10 000 cm^2. Also apply this to a 1m^3 and 100cm^3, thus allowing students to see 1m^2 = 100 000 cm^3."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703943Z"^^xsd:dateTime .

oakcurric:misconception-subtracting-numbers-standard-form-pupils
  a curric:Misconception ;
  curric:statement """When subtracting numbers in standard form, pupils can also add the exponents of 10."""@en ;
  curric:correction """The use of the place value chart shows how the magnitude does not change to the sum of the powers of 10. The place value chart can support pupils to make the correct addition or subtraction of large or small numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704296Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-raise-coefficient-power-well
  a curric:Misconception ;
  curric:statement "Forgetting to raise the coefficient to the power as well as the power term."@en ;
  curric:correction """Highlight that everything in the bracket is being affected by the power.  By showing examples where the bracket is written in expanded form and then the repeated multiplication helps with this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704356Z"^^xsd:dateTime .

oakcurric:misconception-truncating-pupils-tempted-round-truncating
  a curric:Misconception ;
  curric:statement """When truncating, pupils are tempted to round. Also, when truncating, they cut off the number without thinking about the magnitude."""@en ;
  curric:correction """The use of the place value table shows the magnitude of the number, thus preserving their place value when truncating."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704723Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-simple-interest
  a curric:Misconception ;
  curric:statement """Pupils get confused between simple interest and compound interest. When presented with a compound interest problem the common error is for pupils to add the same constant amount."""@en ;
  curric:correction """Visual representations are helpful here. The bar models in the first part of the lesson show how compound interest grows year on year. The graphical representation also demonstrates the fundamental difference between the two forms of interest."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704744Z"^^xsd:dateTime .

oakcurric:misconception-biased-samples-bad
  a curric:Misconception ;
  curric:statement "Biased samples are always bad."@en ;
  curric:correction """A biased sample is sometimes useful if the sample is proportional to the population and/or it focuses on a section of the population relevant to the investigation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704748Z"^^xsd:dateTime .

oakcurric:misconception-solutions-constants-binomials
  a curric:Misconception ;
  curric:statement "That the solutions are just the constants in the binomials."@en ;
  curric:correction """After factorising, pupils should be writing the one step equations, equal to zero, before writing the solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704991Z"^^xsd:dateTime .

oakcurric:misconception-pupils-pay-careful-attention-question
  a curric:Misconception ;
  curric:statement """Pupils should pay careful attention to what the question asks. Working out the overall amount after a simple or compound increase is different to working out the total interest only."""@en ;
  curric:correction """Pupils can underline or highlight the key instruction to the question e.g. Total amount or total interest, to remind them of the need to subtract from the original amount or not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704995Z"^^xsd:dateTime .

oakcurric:misconception-believing-constants-binomials-sum-coefficient
  a curric:Misconception ;
  curric:statement """Believing the constants in the binomials must sum to the coefficient of x and multiply to the constant in the quadratic."""@en ;
  curric:correction """Use an area model to show what is happening when the coefficient of x^2 is not 1. Pupils should always check their answers by expanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705000Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-see-why-using
  a curric:Misconception ;
  curric:statement "Pupils may struggle to see why using the difference of two squares is important."@en ;
  curric:correction """The grid method for multiplication can be used to explore why two of the terms cancel each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705144Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-base-fractional-exponent
  a curric:Misconception ;
  curric:statement "Pupils multiply the base by the fractional exponent. e.g 25^(1/2) = 12.5"@en ;
  curric:correction """The use of a calculator allows pupils to see the index of a fraction is not to be multiplied by the base. Embedding the laws of indices where two bases are the same and each number has an index of 1/2 helps recognize the 1/2 index as a square root."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705190Z"^^xsd:dateTime .

oakcurric:misconception-incorrect-use-calculator-finding-mean
  a curric:Misconception ;
  curric:statement """Incorrect use of the calculator when finding the mean of numbers.  Omitting the brackets when summing the values."""@en ;
  curric:correction """Encourage pupils to calculate the sum of the values and record this before dividing by the number of values.  This also encourages a record of a method."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705491Z"^^xsd:dateTime .

oakcurric:misconception-setting-initial-proportion-statement-hence
  a curric:Misconception ;
  curric:statement """Setting up the initial proportion statement and hence the general form of the equation the wrong way around."""@en ;
  curric:correction """Pay particularly attention to the language used.  Give pupils the opportunity to verbalise what different proportion statements mean.  E.g. y ∝ x^2, 'read this aloud using the correct mathematical vocabulary'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705497Z"^^xsd:dateTime .

oakcurric:misconception-mistakes-made-subtracting-negative-values
  a curric:Misconception ;
  curric:statement """Mistakes can be made when subtracting negative values. E.g. thinking that 5 - - 2 = 3."""@en ;
  curric:correction """Consider additive inverses, subtracting a negative is the same as adding the additive inverse. Pupils should be able to spot mistakes in learning cycle 1 by checking their new equation is still true."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705780Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-write-rounded-solutions
  a curric:Misconception ;
  curric:statement "Pupils may want to write rounded solutions when solving a quadratic equation."@en ;
  curric:correction "Remind them of the importance of accuracy and further calculations."@en ;
  dcterms:modified "2026-02-12T08:59:18.705784Z"^^xsd:dateTime .

oakcurric:misconception-ordering-decimals-significant-figures-greater
  a curric:Misconception ;
  curric:statement "When ordering decimals, the more significant figures the greater the number."@en ;
  curric:correction """When ordering decimals, having the same number of decimal places allows the pupils to see the magnitude of the number more clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705956Z"^^xsd:dateTime .

oakcurric:misconception-number-index-0-equates-0
  a curric:Misconception ;
  curric:statement "Any number with an index of 0 equates to 0"@en ;
  curric:correction """Reiterate the division of any number by itself is 1. This applies with laws of indices too. E.g 8^4 / 8^4 = 8^0. Any number divided by itself gives 1, therefore 8^0 = 1. For more advanced understanding, algebraic can be used instead of numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705981Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-applying-distributive-law
  a curric:Misconception ;
  curric:statement """Pupils may struggle with applying the distributive law to expressions involving surds."""@en ;
  curric:correction """The area model can be used here to demonstrate how terms are multiplied when expanding the bracket."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705986Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-simplest-form-means
  a curric:Misconception ;
  curric:statement "Pupils may think the simplest form means a simplified surd as a denominator."@en ;
  curric:correction """A fraction is not fully simplified if the denominator contains a surd term and must be rationalised as is convention."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706070Z"^^xsd:dateTime .

oakcurric:misconception-assuming-decimal-part-number-entirely
  a curric:Misconception ;
  curric:statement """Assuming that the decimal part of the number will entirely disappear in the subtraction step."""@en ;
  curric:correction """Ensure that pupils line up the decimal points and use squares in their books for each digit.  This should allow pupils to see the parts that cancel each other out and what is left when finding the difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706075Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-factorise-solve-without
  a curric:Misconception ;
  curric:statement "Pupils may try to factorise and solve without rearranging first."@en ;
  curric:correction """Being able to put the factors equal to zero only makes sense if we are using the property that if two values multiply to zero, one of them is zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706116Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-like-surds-need
  a curric:Misconception ;
  curric:statement """Pupils may think like surds need both the radicand and the coefficient to be the same."""@en ;
  curric:correction "Remind them of the distributive law: a(b+c) = ab + ac."@en ;
  dcterms:modified "2026-02-12T08:59:18.706121Z"^^xsd:dateTime .

oakcurric:misconception-pupils-simplify-multiplying-surds
  a curric:Misconception ;
  curric:statement "Pupils may not simplify after multiplying surds."@en ;
  curric:correction "Surds should always be written in their simplest form for the final answer."@en ;
  dcterms:modified "2026-02-12T08:59:18.706502Z"^^xsd:dateTime .

oakcurric:misconception-pupils-suggest-using-foil-similar
  a curric:Misconception ;
  curric:statement """Pupils may suggest using FOIL (or similar) to expand both brackets and make errors whilst doing so."""@en ;
  curric:correction """The grid method is derived from the area model and therefore the area model supports expanding both one binomial and two binomials."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706506Z"^^xsd:dateTime .

oakcurric:misconception-subtracting-variables-one-way-round
  a curric:Misconception ;
  curric:statement "Subtracting the variables one way round but the constants the other way."@en ;
  curric:correction """Pupils could rewrite their equations so the one they are subtracting is underneath in a column method. For this lesson, the answers are in context so pupils should spot when negative answers do not make sense."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706552Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-write-correct-opposing
  a curric:Misconception ;
  curric:statement "Pupils may struggle to write a correct opposing statement."@en ;
  curric:correction """Encourage pupils to discuss the various proposed opposing statements presented in the first learning cycle. What does each statement actually mean?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.706557Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-signs-incorrect-way
  a curric:Misconception ;
  curric:statement """Pupils often get signs the incorrect way round in the binomials. E.g. (x+2)(x-4) instead of (x-2)(x+4)"""@en ;
  curric:correction """Encourage pupils to always expand their binomials to check they are correct. Using representations such as an area model should reduce the likelihood of this as pupils focus on the structure and reason behind their choices."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706561Z"^^xsd:dateTime .

oakcurric:misconception-adding-numbers-standard-form-pupils
  a curric:Misconception ;
  curric:statement "When adding numbers in standard form, pupils can also add the exponents of 10."@en ;
  curric:correction """The use of the place value chart shows how the magnitude does not change to the sum of the powers of 10. The place value chart can support pupils to make the correct addition or subtraction of large or small numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706751Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-expanding-brackets-using-brackets
  a curric:Misconception ;
  curric:statement """Incorrectly expanding brackets or not using brackets when one expression is substituted into another."""@en ;
  curric:correction """Pupils should always use brackets when substituting. Remind them of the distributive law and that multiplying a negative value by a negative value gives a positive value. Checking final answers should catch these mistakes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707105Z"^^xsd:dateTime .

oakcurric:misconception-arithmetic-sequences-positive-integer-common
  a curric:Misconception ;
  curric:statement "Arithmetic sequences only have a positive integer as the common difference."@en ;
  curric:correction """Arithmetic sequences can be increasing or decreasing and can have any value for the common difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707288Z"^^xsd:dateTime .

oakcurric:misconception-assuming-cross-multiplying-best-way
  a curric:Misconception ;
  curric:statement """Assuming that 'cross multiplying' is always the best way to solve equations with fractions on both sides."""@en ;
  curric:correction """Examples are included in the lesson where this results in unnecessary quadratic equations. Factorising and looking for common factors allows pupils to spot efficient methods. This also links with fraction skills of finding a common denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707295Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-existing-coefficient-coefficient
  a curric:Misconception ;
  curric:statement """Pupils may not multiply the existing coefficient with the coefficient of the simplified surd."""@en ;
  curric:correction """Replace the unsimplified surd with the simplified form within the original expression so pupils can see they need to multiply coefficients."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707300Z"^^xsd:dateTime .

oakcurric:misconception-mistakes-occur-substituting-quadratic-formula
  a curric:Misconception ;
  curric:statement """Mistakes often occur when substituting into the quadratic formula with calculators, as pupils miss out brackets and change the priority of operations."""@en ;
  curric:correction """Values should always be put in brackets when substituted. This avoids mistakes when squaring and subtracting negative values. It also makes it easier to change the values of a , b , and c when working on a new question."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707516Z"^^xsd:dateTime .

oakcurric:misconception-using-laws-indices-dividing-number
  a curric:Misconception ;
  curric:statement """Using the laws of indices, when dividing by a number with a negative exponent pupils can incorrectly subtract the negative exponent."""@en ;
  curric:correction """When the bases of all the numbers are the same, forming an equation with the exponents can reduce errors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707568Z"^^xsd:dateTime .

oakcurric:misconception-pupils-insist-square-root-positive
  a curric:Misconception ;
  curric:statement "Pupils may insist that a square root can be both positive and negative."@en ;
  curric:correction "By convention, square root refers to the principal (positive) square root."@en ;
  dcterms:modified "2026-02-12T08:59:18.707575Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fully-simplify-due-identifying
  a curric:Misconception ;
  curric:statement "Pupils may not fully simplify due to not identifying the highest square factor."@en ;
  curric:correction "Encourage pupils to check the resulting radicand for any further square factors."@en ;
  dcterms:modified "2026-02-12T08:59:18.707714Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-simplifying-expressions-difference
  a curric:Misconception ;
  curric:statement """Pupils find simplifying expressions which are the difference of two bracketed expressions difficult."""@en ;
  curric:correction """There are two equivalent methods detailed in learning cycle two. Spend time on both, getting pupils to explore their equivalence. If pupils are struggling, considering subtraction as adding the negative value is the easiest to model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708134Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-formula-number-days
  a curric:Misconception ;
  curric:statement """Pupils can think the formula for the number of days in a week is w=7d because a week has seven days."""@en ;
  curric:correction """Pupils should always write down exactly what the letter is representing. E.g. 'the number of days' and 'the number of weeks'. Then think about what calculation they are doing. 'To find the number of days I multiply the number of weeks by 7'. d=7w."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708138Z"^^xsd:dateTime .

oakcurric:misconception-exterior-angle-equal-360-size
  a curric:Misconception ;
  curric:statement """An exterior angle is equal to 360° - the size of the interior angle because angles around a point sum to 360°."""@en ;
  curric:correction """An exterior angle is an angle on the outside of a polygon between an extension of an edge and the adjacent edge."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708143Z"^^xsd:dateTime .

oakcurric:misconception-common-multiplier-positive-integer-sequence
  a curric:Misconception ;
  curric:statement """The common multiplier must be a positive integer for the sequence to be geometric."""@en ;
  curric:correction """The multiplier needs to be the same between consecutive terms but it can be any value. Examples of this can be seen in the lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708147Z"^^xsd:dateTime .

oakcurric:misconception-alternating-sequences-cause-difficulty-negative
  a curric:Misconception ;
  curric:statement """Alternating sequences may cause difficulty if negative number skills are not secure."""@en ;
  curric:correction """A review of negative numbers would be useful. Prior lessons can be used for this review if required."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708152Z"^^xsd:dateTime .

oakcurric:misconception-simultaneous-equations-cannot-applied-usefully
  a curric:Misconception ;
  curric:statement "Simultaneous equations cannot be applied usefully to real-world scenarios."@en ;
  curric:correction """The skill of solving a pair of simultaneous equations can be applied to a wide variety of problems and provides us with answers in a wide variety of contexts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708156Z"^^xsd:dateTime .

oakcurric:misconception-incorrect-input-mixed-number-common
  a curric:Misconception ;
  curric:statement """The incorrect input of a mixed number is common i.e some pupils press a number then the fraction button. Others inefficiently sum the integer and proper fraction."""@en ;
  curric:correction "Reiterating the mixed number button is located above the proper fraction button."@en ;
  dcterms:modified "2026-02-12T08:59:18.708345Z"^^xsd:dateTime .

oakcurric:misconception-performing-different-operations-different-variables
  a curric:Misconception ;
  curric:statement """Performing different operations on different variables. E.g. subtracting one variable to eliminate then adding the other variable and constant. Pupils incorrectly think they are adding to eliminate."""@en ;
  curric:correction """This is caused by negative number skills. Subtracting two identical values always gives zero even if both are negative. If a term is the same in both equations, we subtract to eliminate. Clear working is crucial here."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708352Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-identifying-simultaneous-equations-formed
  a curric:Misconception ;
  curric:statement """Incorrectly identifying when simultaneous equations can be formed. This can lead to pupils using the same letter in two equations to represent different things."""@en ;
  curric:correction """Pupils should be writing down precisely what the variable represent in context. They can then compare whether they are using the same letter to represent the same thing in two different equations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708616Z"^^xsd:dateTime .

oakcurric:misconception-assuming-dividing-ub-result-ub
  a curric:Misconception ;
  curric:statement "Assuming that when dividing the UB will be the result of the UB ÷ UB."@en ;
  curric:correction """Get the pupils to investigate dividing numbers.  Keep the divisor the same and change the dividend.  Ask the question, "What happens as the dividend increases?"."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708622Z"^^xsd:dateTime .

oakcurric:misconception-converting-ratio-e-g-1
  a curric:Misconception ;
  curric:statement "Converting a ratio e.g. 1 : 3 to 1/3 as a fraction."@en ;
  curric:correction """Drawing out simple ratios using bars can help pupils to see how fractions can correctly be obtained from a given ratio."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708661Z"^^xsd:dateTime .

oakcurric:misconception-pupils-hesitant-start-problems-due
  a curric:Misconception ;
  curric:statement "Pupils may be hesitant to start the problems due to uncertainty."@en ;
  curric:correction """Encourage pupils to try an approach and then reflect on whether there has been progress towards a solution. Deducing something you didn't already know if progress even if it does not seem like it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708665Z"^^xsd:dateTime .

oakcurric:misconception-size-interior-angle-regular-shape
  a curric:Misconception ;
  curric:statement """The size of an interior angle in a regular shape cannot be found unless the size of the other angles are given."""@en ;
  curric:correction """A regular shape has the property that all of its interior angles are equal in size. This means that the size of each interior angle is very easy to find if, for example, the sum of the interior angles is known."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708670Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-u-1-means
  a curric:Misconception ;
  curric:statement "Pupils may think that $$u_1$$ means that $$u$$ has a value of one."@en ;
  curric:correction """$$u_1$$ refers to the first term in the sequence and $$u_2$$ refers to the second term. The subscript refers to the term number."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708674Z"^^xsd:dateTime .

oakcurric:misconception-solving-equations-fractional-coefficients-pupils
  a curric:Misconception ;
  curric:statement """When solving equations with fractional coefficients, pupils may divide by the reciprocal rather than multiply. E.g. $$\\\\frac{1}{2}x = 8$$ pupils may just halve $$8$$"""@en ;
  curric:correction """Start with integer coefficients, and get pupils used to the idea of multiplying by the reciprocal (not just dividing by the coefficient). This step should be written as part of the working. Answers can be checked by substitution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708920Z"^^xsd:dateTime .

oakcurric:misconception-once-shown-difference-two-squares
  a curric:Misconception ;
  curric:statement """Once shown the difference of two squares, pupils may think that squaring each term in a binomial is the correct way to expand binomials such as (x+3)^2"""@en ;
  curric:correction """Spend time investigating where the difference of two squares occurs, use representations such as algebra tiles and area models."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708925Z"^^xsd:dateTime .

oakcurric:misconception-trying-simplify-division-calculation-identifying
  a curric:Misconception ;
  curric:statement """Trying to simplify a division calculation by identifying common factors before calculating."""@en ;
  curric:correction """Pupils need to understand why this works with multiplication questions to understand why this does not work with division. Encourage pupils to write their division as a multiplication of the reciprocal before identifying common factors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709209Z"^^xsd:dateTime .

oakcurric:misconception-find-solution-given-degree-accuracy
  a curric:Misconception ;
  curric:statement """To find a solution to a given degree of accuracy an iteration can just be rounded."""@en ;
  curric:correction """Several successive iterations need to round to the same value to a given degree of accuracy. If in doubt efficient calculator use means many iterations can be generated easily until confident that a digit is fixed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709215Z"^^xsd:dateTime .

oakcurric:misconception-forming-expressions-brackets-missed-incorrectly
  a curric:Misconception ;
  curric:statement "When forming expressions brackets can be missed out or incorrectly used."@en ;
  curric:correction """Review priority of operations. Testing algebraic manipulations with numerical values can be useful when pupils are unsure if things are equivalent. E.g. the difference between 2(x + 4) and 2x + 4 can be shown with 2(5 + 4) and 2(5) + 4"""@en ;
  dcterms:modified "2026-02-12T08:59:18.709247Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-use-sine-cosine
  a curric:Misconception ;
  curric:statement "Pupils may think that they have to use the sine or cosine rule."@en ;
  curric:correction """Encourage pupils to consider all the trigonometric knowledge they have and choose the most appropriate piece for the problem they are dealing with."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709252Z"^^xsd:dateTime .

oakcurric:misconception-confusing-order-functions-evaluated
  a curric:Misconception ;
  curric:statement "Confusing the order in which functions are evaluated."@en ;
  curric:correction """Pupils can substitute their answer into the composite function to check their answer. Putting brackets around the functions can help with confirming the order."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709472Z"^^xsd:dateTime .

oakcurric:misconception-average-speed-found-adding-speeds
  a curric:Misconception ;
  curric:statement """The average speed is found by adding the speeds and dividing by how many average speeds are given."""@en ;
  curric:correction """The common misconception is calculating an average of an average. Show how the answers when calculating the average of the average speeds is not the same as calculating the average speed using the total distance and total time of the average speeds."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709654Z"^^xsd:dateTime .

oakcurric:misconception-failing-understand-difference-simple-compound
  a curric:Misconception ;
  curric:statement """Failing to understand the difference between simple and compound interest.  And, therefore finding the interest for one time period and multiplying it by the number of time periods."""@en ;
  curric:correction "Pupils can forget to transfer the year end balance as the starting balance of the next year.  Using repeated language can help.  E.g. \"At the end of year 2 there was ... in the account, so, at the beginning of year 3 there was ... in the account.\""@en ;
  dcterms:modified "2026-02-12T08:59:18.709665Z"^^xsd:dateTime .

oakcurric:misconception-conjectures-correct-its-really-hard
  a curric:Misconception ;
  curric:statement """Conjectures have to be correct so it's really hard to make a conjecture as you don't want to be wrong."""@en ;
  curric:correction """Conjectures are thought to be true but they may not be. This is why we test and see ways to prove whether a conjecture is true or not. It is perfectly acceptable for a conjecture to be proved wrong."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709669Z"^^xsd:dateTime .

oakcurric:misconception-small-slips-working-lead-wrong
  a curric:Misconception ;
  curric:statement """Small slips in working can lead to the wrong answer and pupils are not clear on how to check their working."""@en ;
  curric:correction """The lesson models how to check working so that the correct answer can be verified. This is good practice and helps pupils identify if there is an error."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709832Z"^^xsd:dateTime .

oakcurric:misconception-using-desmos-incorrect-brackets-used
  a curric:Misconception ;
  curric:statement "When using Desmos, incorrect brackets () are used to input raw data as elements."@en ;
  curric:correction """[] are used to denote a set of data elements or elements. Encourage pupils to think about set notation when using Venn diagrams. Desmos will reject the use of () as they do not denote a set of elements."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709836Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-clear-their-calculator
  a curric:Misconception ;
  curric:statement """Some pupils want to clear their calculator display and type every single level of iteration in each time."""@en ;
  curric:correction """Encourage the pupils to trust their 'Ans' button. Get them to work on an example whereby they physically type the input value in and type the whole formula again. Then get them to repeat the same question using the 'Ans' button. Time this if you can!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.709841Z"^^xsd:dateTime .

oakcurric:misconception-number-square-cube-number-because
  a curric:Misconception ;
  curric:statement "Any number is a square or cube number because it can be squared or cubed."@en ;
  curric:correction """A square number is the result of a number being multiplied by itself. Emphasis must be on the result. A cube number is a number that has been multiplied by itself three times. Emphasis must be on the result of the repeated multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710128Z"^^xsd:dateTime .

oakcurric:misconception-surds-number-root-symbol
  a curric:Misconception ;
  curric:statement "Surds are any number with a root symbol."@en ;
  curric:correction "√4 is not a surd as it is equivalent to 2."@en ;
  dcterms:modified "2026-02-12T08:59:18.710133Z"^^xsd:dateTime .

oakcurric:misconception-pupils-round-wrong-way-finding
  a curric:Misconception ;
  curric:statement """Pupils may round the wrong way when finding the term number for a particular term value."""@en ;
  curric:correction """By calculating the terms either side of the non-integer value of $$n$$, pupils can easily determine what the rounded value of $$n$$ should be."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710320Z"^^xsd:dateTime .

oakcurric:misconception-common-error-substitute-variable-terms
  a curric:Misconception ;
  curric:statement """A common error is to not substitute into all variable terms where there is more than one in a function. For example, 'Write a simplified expression for f$$(x+3)$$ when f$$(x)=x^2-4x$$'"""@en ;
  curric:correction """Use brackets when substituting. For example, for 'Write a simplified expression for f$$(x+3)$$ when f$$(x)=x^2-4x$$' you would write f$$(x+3)=(x+3)^2-4(x+3)$$"""@en ;
  dcterms:modified "2026-02-12T08:59:18.710435Z"^^xsd:dateTime .

oakcurric:misconception-truncating-numbers-rather-rounding-considering
  a curric:Misconception ;
  curric:statement """Truncating the numbers rather than rounding when considering the suitable degree of accuracy."""@en ;
  curric:correction """Emphasise that the numbers are being rounded and therefore the digit in the next decimal place must be considered."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710449Z"^^xsd:dateTime .

oakcurric:misconception-linear-equation-involves-brackets-expanded
  a curric:Misconception ;
  curric:statement "If a linear equation involves brackets, these always have to be expanded first."@en ;
  curric:correction """Get pupils to use knowledge of factors and collecting like terms to simplify problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710604Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-evaluate-composite-functions
  a curric:Misconception ;
  curric:statement "Pupils may try to evaluate composite functions by working from left to right."@en ;
  curric:correction """Remind pupils that they cannot do this as each function needs an input and with composite functions the input needs to be evaluated before it can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710608Z"^^xsd:dateTime .

oakcurric:misconception-since-common-difference-further-terms
  a curric:Misconception ;
  curric:statement """Since there is no common difference, further terms in the sequence cannot be generated."""@en ;
  curric:correction """Pupils have seen sequences where the first difference is not common and seen examples of other rules. In this lesson, the concept of a second difference is introduced and this can be used to generate the next first difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710613Z"^^xsd:dateTime .
