  dcterms:modified "2026-02-12T08:59:21.689533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-743-3
  a curric:KeyLearningPoint ;
  rdfs:label "By rearranging the formula, you can calculate either distance or time."@en ;
  dcterms:modified "2026-02-12T08:59:21.689539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-743-4
  a curric:KeyLearningPoint ;
