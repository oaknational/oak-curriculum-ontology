oakcurric:keylearningpoint-lesson-779-2
  a curric:KeyLearningPoint ;
  rdfs:label "The conjecture can be tested to see if it holds."@en ;
  dcterms:modified "2026-02-12T08:59:21.746564Z"^^xsd:dateTime .

