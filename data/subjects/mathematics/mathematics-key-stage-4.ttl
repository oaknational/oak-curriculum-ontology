  dcterms:modified "2026-02-12T08:59:21.743701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-495-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of a multiplier ensures greater efficiency."@en ;
  dcterms:modified "2026-02-12T08:59:21.743705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-497-1
  a curric:KeyLearningPoint ;
  rdfs:label "Calculators are very useful here as they can be programmed efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.744847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-497-2
  a curric:KeyLearningPoint ;
  rdfs:label "This saves time and can reduce error."@en ;
  dcterms:modified "2026-02-12T08:59:21.744851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-497-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is also quick to reverse the process to find the original amount."@en ;
  dcterms:modified "2026-02-12T08:59:21.744854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-497-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of a multiplier ensures greater efficiency."@en ;
  dcterms:modified "2026-02-12T08:59:21.744860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-565-1
  a curric:KeyLearningPoint ;
  rdfs:label "The first significant figure is the first non-zero digit to have place value."@en ;
  dcterms:modified "2026-02-12T08:59:21.744878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-565-2
  a curric:KeyLearningPoint ;
