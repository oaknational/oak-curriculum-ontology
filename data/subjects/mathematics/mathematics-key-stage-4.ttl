  dcterms:modified "2026-02-12T08:59:21.670388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-809-4
  a curric:KeyLearningPoint ;
  rdfs:label "This can also be shown algebraically"@en ;
  dcterms:modified "2026-02-12T08:59:21.670393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-733-1
  a curric:KeyLearningPoint ;
  rdfs:label "A Venn diagram can be used to calculate conditional probabilities"@en ;
  dcterms:modified "2026-02-12T08:59:21.670397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-733-2
  a curric:KeyLearningPoint ;
  rdfs:label """A Venn diagram can be used to calculate conditional probabilities involving sets of events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.670402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-733-3
  a curric:KeyLearningPoint ;
