  dcterms:modified "2026-02-12T08:59:21.688294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-714-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sine of an angle is the y-coordinate of the point where the radius has been rotated through that angle"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-714-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cosine of an angle is the x-coordinate of the point where the radius has been rotated through that angle"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-714-5
  a curric:KeyLearningPoint ;
  rdfs:label """The tangent of an angle is the length of the side opposite the angle along the tangent at x = 1 to the unit circle"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-757-1
  a curric:KeyLearningPoint ;
  rdfs:label "Not all real-life graphs can be drawn using sections of different linear graphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.688314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-757-2
  a curric:KeyLearningPoint ;
  rdfs:label "The graphs are models, which means that we want them to be useful."@en ;
  dcterms:modified "2026-02-12T08:59:21.688319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-613-1
  a curric:KeyLearningPoint ;
  rdfs:label "Knowledge of perimeter and area is useful for any space management contexts."@en ;
  dcterms:modified "2026-02-12T08:59:21.688857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-613-2
  a curric:KeyLearningPoint ;
  rdfs:label "Knowledge of perimeter and area is useful when costing a project."@en ;
  dcterms:modified "2026-02-12T08:59:21.688862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-613-3
  a curric:KeyLearningPoint ;
  rdfs:label "For each context, you need to decide whether perimeter or area is relevant."@en ;
  dcterms:modified "2026-02-12T08:59:21.688869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-808-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inequalities can be represented algebraically"@en ;
  dcterms:modified "2026-02-12T08:59:21.688899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-808-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inequalities can be represented graphically on a number line"@en ;
  dcterms:modified "2026-02-12T08:59:21.688904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-808-3
  a curric:KeyLearningPoint ;
  rdfs:label "The diagram can indicate whether the inequality is a strict inequality"@en ;
  dcterms:modified "2026-02-12T08:59:21.688908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-808-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple inequalities can be shown on one number line"@en ;
  dcterms:modified "2026-02-12T08:59:21.688913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inequalities are very common in real life"@en ;
  dcterms:modified "2026-02-12T08:59:21.688917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-811-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are used when a constraint is needed"@en ;
  dcterms:modified "2026-02-12T08:59:21.688922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-811-3
  a curric:KeyLearningPoint ;
  rdfs:label "An example could be ensuring you do not exceed your budget for the week"@en ;
  dcterms:modified "2026-02-12T08:59:21.688926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-584-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to identify the gradient and y-intercept when the equation is written in the form y = mx + c"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-584-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linear equations can be rearranged in order to reveal the gradient and y-intercept."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-584-3
  a curric:KeyLearningPoint ;
  rdfs:label """By substituting in values for one variable, you can find a corresponding values for the other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-584-4
  a curric:KeyLearningPoint ;
  rdfs:label "These pairs of values can be plotted to give the graph of the equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.688946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7818-1
  a curric:KeyLearningPoint ;
