  dcterms:modified "2026-02-12T08:59:21.671706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-589-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two lines are perpendicular if they meet at right angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.672161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-589-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product of the gradients of two perpendicular lines is -1"@en ;
  dcterms:modified "2026-02-12T08:59:21.672165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-589-3
  a curric:KeyLearningPoint ;
  rdfs:label "This can be derived from Pythagoras' theorem."@en ;
  dcterms:modified "2026-02-12T08:59:21.672170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-589-4
  a curric:KeyLearningPoint ;
  rdfs:label "The product of the gradients of two lines is -1 iff the lines are perpendicular."@en ;
  dcterms:modified "2026-02-12T08:59:21.672174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-793-1
  a curric:KeyLearningPoint ;
  rdfs:label "The n^th term rule can be generated from the sequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.672184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-793-2
  a curric:KeyLearningPoint ;
