  dcterms:modified "2026-02-12T08:59:21.740879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-788-3
  a curric:KeyLearningPoint ;
  rdfs:label "An alternating sequence alternates between positive and negative terms."@en ;
  dcterms:modified "2026-02-12T08:59:21.740883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Where a problem gives multiple ways of connecting two things, it may mean simultaneous equations can be written."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-488-2
  a curric:KeyLearningPoint ;
  rdfs:label """If simultaneous equations can be written, it is important to state what each variable stands for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-488-3
  a curric:KeyLearningPoint ;
  rdfs:label "The solutions should always be given in context."@en ;
  dcterms:modified "2026-02-12T08:59:21.740895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-502-1
  a curric:KeyLearningPoint ;
  rdfs:label """Where a calculation contains a mixture of fractions and decimals, conversion is useful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-502-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fluent use of your calculator is useful for both calculating and checking."@en ;
  dcterms:modified "2026-02-12T08:59:21.741496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-502-3
  a curric:KeyLearningPoint ;
  rdfs:label "Equivalent fractions can help to reduce the complexity of calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.741500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-479-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to find a solution that satisfies two equations with two unknowns by trial and error."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-479-2
  a curric:KeyLearningPoint ;
  rdfs:label """A more efficient method is to combine the two equations to create a third valid equation ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-479-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the third equation contains only one unknown, it is easy to solve ."@en ;
  dcterms:modified "2026-02-12T08:59:21.741512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-479-4
  a curric:KeyLearningPoint ;
  rdfs:label "Once you know one of the unknowns, you can substitute to find the other ."@en ;
  dcterms:modified "2026-02-12T08:59:21.741516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7224-1
  a curric:KeyLearningPoint ;
  rdfs:label """The features of the equations may mean one method is more preferable for solving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7224-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can use any of the methods that are valid."@en ;
  dcterms:modified "2026-02-12T08:59:21.741524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7224-3
  a curric:KeyLearningPoint ;
  rdfs:label "The solutions should always be given in context."@en ;
  dcterms:modified "2026-02-12T08:59:21.741533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-477-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relationships in context can be expressed using letters to represent the unknown values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-477-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to be clear about what each variable represents."@en ;
  dcterms:modified "2026-02-12T08:59:21.742494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-477-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two different statements can be connected via their variables."@en ;
  dcterms:modified "2026-02-12T08:59:21.742498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-477-4
  a curric:KeyLearningPoint ;
  rdfs:label "One pair of values could satisfy more than one equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.742502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-569-1
  a curric:KeyLearningPoint ;
  rdfs:label "The biggest possible product comes from multiplying the upper bounds together."@en ;
  dcterms:modified "2026-02-12T08:59:21.742506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-569-2
  a curric:KeyLearningPoint ;
  rdfs:label "The smallest possible product comes from multiplying the lower bounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.742512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-569-3
  a curric:KeyLearningPoint ;
  rdfs:label """The biggest possible quotient comes from dividing an upper bound by a lower bound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-569-4
  a curric:KeyLearningPoint ;
  rdfs:label """The smallest possible quotient comes from dividing a lower bound by an upper bound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-512-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is difficult to read very small numbers, due to the number of digits involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-512-2
  a curric:KeyLearningPoint ;
  rdfs:label "It can be more efficient to write these very small numbers in standard form."@en ;
  dcterms:modified "2026-02-12T08:59:21.742640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-512-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a convention for standard form."@en ;
  dcterms:modified "2026-02-12T08:59:21.742644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-577-1
  a curric:KeyLearningPoint ;
  rdfs:label "A multiplicative relationship can be described by a ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.742648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-577-2
  a curric:KeyLearningPoint ;
  rdfs:label "A multiplicative relationship can be described by a percentage."@en ;
  dcterms:modified "2026-02-12T08:59:21.742652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-577-3
  a curric:KeyLearningPoint ;
  rdfs:label "A multiplicative relationship can be described by a fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.742656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-577-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is therefore possible to move between ratio, percentages and fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.742662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7623-1
  a curric:KeyLearningPoint ;
  rdfs:label "At this point, you have multiple strategies available"@en ;
  dcterms:modified "2026-02-12T08:59:21.742666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7623-2
  a curric:KeyLearningPoint ;
  rdfs:label "By analysing the problem, you can determine which approach(es) might work"@en ;
  dcterms:modified "2026-02-12T08:59:21.742670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7623-3
  a curric:KeyLearningPoint ;
  rdfs:label "Keeping the goal in mind helps to focus your thinking"@en ;
  dcterms:modified "2026-02-12T08:59:21.742674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Consider the information you have and whether you need to know anything else in order to solve the problem"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7623-5
  a curric:KeyLearningPoint ;
  rdfs:label "If you are unsure where to start, begin by calculating/deducing what you can"@en ;
  dcterms:modified "2026-02-12T08:59:21.742681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-644-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any polygon can be split into triangles."@en ;
  dcterms:modified "2026-02-12T08:59:21.742685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-644-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using these triangles you can demonstrate the rule for the interior angle sum of a polygon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-644-3
  a curric:KeyLearningPoint ;
