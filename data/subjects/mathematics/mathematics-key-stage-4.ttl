  dcterms:modified "2026-02-12T08:59:21.669946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-842-3
  a curric:KeyLearningPoint ;
  rdfs:label "This allows you to perform further manipulations."@en ;
  dcterms:modified "2026-02-12T08:59:21.669951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-576-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bar models can help to represent a situation."@en ;
  dcterms:modified "2026-02-12T08:59:21.670088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-576-2
  a curric:KeyLearningPoint ;
