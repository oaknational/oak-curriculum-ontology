oakcurric:keylearningpoint-lesson-657-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the size has changed, one shape may be an enlargement of the other."@en ;
  dcterms:modified "2026-02-12T08:59:21.667544Z"^^xsd:dateTime .

