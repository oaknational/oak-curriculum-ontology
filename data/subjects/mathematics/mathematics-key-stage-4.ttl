oakcurric:keylearningpoint-lesson-615-4
  a curric:KeyLearningPoint ;
  rdfs:label "An exact answer may be given in terms of π"@en ;
  dcterms:modified "2026-02-12T08:59:21.688285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-714-1
  a curric:KeyLearningPoint ;
  rdfs:label "The unit circle is a circle with a radius of one"@en ;
  dcterms:modified "2026-02-12T08:59:21.688289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-714-2
  a curric:KeyLearningPoint ;
