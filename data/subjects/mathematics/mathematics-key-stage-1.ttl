  a curric:KeyLearningPoint ;
  rdfs:label """Use the language of first second and third to order numbers and sets of objects to 20."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2851-1
  a curric:KeyLearningPoint ;
