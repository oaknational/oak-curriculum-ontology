oakcurric:keylearningpoint-lesson-2900-2
  a curric:KeyLearningPoint ;
  rdfs:label "Addition is commutative because the addends can be combined in any order."@en ;
  dcterms:modified "2026-02-12T08:59:21.692548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2900-3
  a curric:KeyLearningPoint ;
  rdfs:label """An equation can be written to show that when the order of the addends is changed, they remain equal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2872-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can group representations of numbers according to whether they are made of pairs or not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2872-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shapes representing numbers can be grouped according their shape and to whether they are made of pairs or not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2872-3
  a curric:KeyLearningPoint ;
  rdfs:label """The language of odd and even can be used to describe numbers made of pairs or not made of pairs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2872-4
  a curric:KeyLearningPoint ;
  rdfs:label """--- is made of -- pairs. It is an even number but --- is not made of pairs. It is an odd number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2872-5
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can be sorted into odds and evens."@en ;
  dcterms:modified "2026-02-12T08:59:21.692761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2996-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we add one, we can see this as the number after in our count. We can think of this as one more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2996-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we subtract one, we can see this as the number before in our count. We can think of this as one less."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2996-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding two from an even/odd number, we can see this as the even/odd number after. We can think of this as two less."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2996-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subtracting two from an even/odd number, can be seen as the even/odd number before. We can think of this as two less."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3046-1
  a curric:KeyLearningPoint ;
  rdfs:label "Five is half of ten"@en ;
  dcterms:modified "2026-02-12T08:59:21.693374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3046-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 5 are half the value of multiples of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.693407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3046-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ten is double 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.693413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 are double the value of multiples of 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.693420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2841-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ordinal numbers indicate a single item or event rather than a quantity."@en ;
  dcterms:modified "2026-02-12T08:59:21.693427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Review how ordinal numbers are named and represented and show the shortened written names."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ordinal numbers contain part or all of the corresponding number words. First and second are exceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2841-4
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between cardinal and ordinal numbers is the difference between quantity and position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6772-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tens numbers can be added to or subtracted from a multiple of ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.693446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6772-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you add a tens number to a multiple of ten the tens number increases."@en ;
  dcterms:modified "2026-02-12T08:59:21.693450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6772-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you subtract a tens number from a multiple of ten the tens number decreases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6772-4
  a curric:KeyLearningPoint ;
  rdfs:label """If 3 + 1 is equal to 4 then 3 tens + 1 ten is equal to 4 tens which is equal to 40"""@en ;
  dcterms:modified "2026-02-12T08:59:21.693459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6772-5
  a curric:KeyLearningPoint ;
  rdfs:label """If 4 - 1 is equal to 3 then 4 tens subtract 1 ten is equal to 3 tens which is equal to 30"""@en ;
  dcterms:modified "2026-02-12T08:59:21.693464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6777-1
  a curric:KeyLearningPoint ;
  rdfs:label "Unitising and known facts help you to add and subtract multiples of ten"@en ;
  dcterms:modified "2026-02-12T08:59:21.693468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6777-2
  a curric:KeyLearningPoint ;
  rdfs:label """If 3 + 2 is equal to 5 then 3 tens + 2 tens is equal to 5 tens which is equal to 50"""@en ;
  dcterms:modified "2026-02-12T08:59:21.693473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6777-3
  a curric:KeyLearningPoint ;
  rdfs:label """If 5 - 2 is equal to 3 then 5 tens subtract 2 tens is equal to 3 tens which is equal to 30"""@en ;
  dcterms:modified "2026-02-12T08:59:21.693477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3011-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pictogram is a graph that uses pictures to represent information."@en ;
  dcterms:modified "2026-02-12T08:59:21.693481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3011-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pictogram’s key tells us what each picture represents."@en ;
  dcterms:modified "2026-02-12T08:59:21.693486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3011-3
  a curric:KeyLearningPoint ;
  rdfs:label "Whole − part = difference"@en ;
  dcterms:modified "2026-02-12T08:59:21.693490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3011-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can calculate the difference by counting on from the known part to the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.693495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2880-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a whole is partitioned into parts, it can be represented using the addition symbol."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2880-2
  a curric:KeyLearningPoint ;
  rdfs:label "The addition symbol shows that the parts combine to make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.693506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2880-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can describe the parts to help us understand how to represent them."@en ;
  dcterms:modified "2026-02-12T08:59:21.693511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2880-4
  a curric:KeyLearningPoint ;
  rdfs:label "A whole group can be partitioned in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.693516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2878-1
  a curric:KeyLearningPoint ;
  rdfs:label """Each of the numbers six to ten can be partitioned into two parts in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2878-2
  a curric:KeyLearningPoint ;
  rdfs:label """A part-part-whole model or a bar model can be used to represent the whole and the parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2878-3
  a curric:KeyLearningPoint ;
  rdfs:label "If we know one part we can find the other part."@en ;
  dcterms:modified "2026-02-12T08:59:21.693729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2878-4
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing about odd and even parts means you know if the missing part is odd or even."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2980-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is set counting sequence for counting to 100 and beyond."@en ;
  dcterms:modified "2026-02-12T08:59:21.693738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2980-2
  a curric:KeyLearningPoint ;
  rdfs:label "The patterns in the numbers make counting to 100 and beyond easier."@en ;
  dcterms:modified "2026-02-12T08:59:21.693743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2980-3
  a curric:KeyLearningPoint ;
  rdfs:label "The tens digit in a two-digit number indicates which decade it belongs to."@en ;
  dcterms:modified "2026-02-12T08:59:21.693747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2980-4
  a curric:KeyLearningPoint ;
  rdfs:label "The ones digit in two-digit number follows the pattern 1, 2, 3, 4, 5, 6, 7, 8, 9"@en ;
  dcterms:modified "2026-02-12T08:59:21.693751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2980-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can count the numbers in two ways. This is called dual counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.693756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2793-1
  a curric:KeyLearningPoint ;
  rdfs:label """Know the order of numbers will not change and will always be said in the same order (stable-order principle)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2793-2
  a curric:KeyLearningPoint ;
  rdfs:label "Know we can order numbers by counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.693765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2793-3
  a curric:KeyLearningPoint ;
  rdfs:label "Know we can order numbers using our knowledge of 'greater than' and 'less than'."@en ;
  dcterms:modified "2026-02-12T08:59:21.693769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3076-1
  a curric:KeyLearningPoint ;
  rdfs:label "A property of a 3D shape can be the number of faces, edges or vertices it has."@en ;
  dcterms:modified "2026-02-12T08:59:21.693776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3076-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each face of a 3D shape is a 2D shape."@en ;
  dcterms:modified "2026-02-12T08:59:21.693781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2950-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting can be used to work out how many 5 p coins are needed to make a given value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2950-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you reach the value needed, you must stop counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.693790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2950-3
  a curric:KeyLearningPoint ;
  rdfs:label "The number of 5 p coins needed will be less than the value of the item."@en ;
  dcterms:modified "2026-02-12T08:59:21.693794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2950-4
  a curric:KeyLearningPoint ;
  rdfs:label "Not all values can be made using only 5 p coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.693799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3125-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we are dividing by 2, you can use the 2 times table to find the number of groups or the number in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3125-2
  a curric:KeyLearningPoint ;
  rdfs:label "3 twos are equal to 6, so 6 divided into groups of 2 is equal to 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.694820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3125-3
  a curric:KeyLearningPoint ;
  rdfs:label "3 twos are equal to 6, so 6 divided into 2 groups is equal to 3 in each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.694824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Addition is the inverse of subtraction. Addition can 'undo' subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.694829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtraction is the inverse of addition. Subtraction can 'undo' addition."@en ;
  dcterms:modified "2026-02-12T08:59:21.694833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2898-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a given amount is added to the start of a story, to 'undo' the change, we must subtract the same amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2898-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a given amount is subtracted from the start of a story, to 'undo' the change we must add the same amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2884-1
  a curric:KeyLearningPoint ;
  rdfs:label "In an equation, each addend represents a part."@en ;
  dcterms:modified "2026-02-12T08:59:21.695318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2884-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can combine the addends to find the sum."@en ;
  dcterms:modified "2026-02-12T08:59:21.695323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2884-3
  a curric:KeyLearningPoint ;
  rdfs:label "To find how many objects there are altogether, you must count both addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.695327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Highlight language such as 15 is more than 10."@en ;
  dcterms:modified "2026-02-12T08:59:21.695332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2811-2
  a curric:KeyLearningPoint ;
  rdfs:label "What number comes before or is one less than 14?"@en ;
  dcterms:modified "2026-02-12T08:59:21.695336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2811-3
  a curric:KeyLearningPoint ;
  rdfs:label "Which number comes after or is one more than 14?"@en ;
  dcterms:modified "2026-02-12T08:59:21.695341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3055-1
  a curric:KeyLearningPoint ;
  rdfs:label "Doubles facts to 5 can help to double 2-digit numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.695346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3055-2
  a curric:KeyLearningPoint ;
  rdfs:label """To double, partition the 2-digit number, double the ones digit then the tens digit and recombine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3055-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling can be written as a multiplication equation where one of the factors is 2"""@en ;
  dcterms:modified "2026-02-12T08:59:21.695354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3055-4
  a curric:KeyLearningPoint ;
  rdfs:label "When one of the factors is 2, the product is double the other factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.695359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2962-1
  a curric:KeyLearningPoint ;
  rdfs:label "A rotation describes how something has been turned."@en ;
  dcterms:modified "2026-02-12T08:59:21.695364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2962-2
  a curric:KeyLearningPoint ;
  rdfs:label "Turns to the right and left can be used to give directions."@en ;
  dcterms:modified "2026-02-12T08:59:21.695370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3047-1
  a curric:KeyLearningPoint ;
  rdfs:label "Five is half of ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.695375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3047-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 5 are half the value of multiples of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.695380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3047-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ten is double 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.695386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3047-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 are double the value of multiples of 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.695391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Intervals of time can be compared using greater than, equal to and less than."@en ;
  dcterms:modified "2026-02-12T08:59:21.695395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3114-2
  a curric:KeyLearningPoint ;
