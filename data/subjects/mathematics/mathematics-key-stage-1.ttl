  a curric:KeyLearningPoint ;
  rdfs:label """The numbers from 0 to 100 have patterns that can help us to count backwards across the tens boundary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673087Z"^^xsd:dateTime .

