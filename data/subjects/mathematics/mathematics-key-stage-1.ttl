  dcterms:modified "2026-02-12T08:59:15.797879Z"^^xsd:dateTime .

oakcurric:keyword-one-more
  a curric:Keyword ;
  schema:name "One more"@en ;
  schema:description "One more is when there is a greater amount by one or another item in the set."@en ;
