oakcurric:keylearningpoint-lesson-2875-3
  a curric:KeyLearningPoint ;
  rdfs:label """When an even number is partitioned into two parts both parts will be odd or both parts will be even."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Count a set of 10 objects reliably."@en ;
  dcterms:modified "2026-02-12T08:59:21.669303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2865-2
  a curric:KeyLearningPoint ;
  rdfs:label """Develop fluency in counting and securing the cardinality principle and the stable order principle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2865-3
  a curric:KeyLearningPoint ;
  rdfs:label """Revisit and secure understanding of how the number tells the quantity of a group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3085-1
  a curric:KeyLearningPoint ;
  rdfs:label """Partitioning the addends can help us to solve problems involving two-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3085-2
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have written the equation, we must think carefully about the most efficient strategy to use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3085-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to be able to calculate mentally before adding two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3015-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two-digit numbers can be partitioned into two or more parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.669397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3015-2
  a curric:KeyLearningPoint ;
  rdfs:label """Known facts can be used to help partition a two-digit number into a multiple of ten and another part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3015-3
  a curric:KeyLearningPoint ;
  rdfs:label "The patterns in the tens can help to predict new equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.669405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3015-4
  a curric:KeyLearningPoint ;
  rdfs:label """Known facts can be used to help partition both the tens and the ones in a two-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2893-1
  a curric:KeyLearningPoint ;
  rdfs:label "Subtraction can be seen as both partitioning and as decreasing an amount."@en ;
