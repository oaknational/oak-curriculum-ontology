  dcterms:modified "2026-02-12T08:59:15.795341Z"^^xsd:dateTime .

oakcurric:keyword-data
  a curric:Keyword ;
  schema:name "Data"@en ;
  schema:description """Data is a collection of facts, such as numbers, words, measurements, observations or even just descriptions of things."""@en ;
  dcterms:modified "2026-02-12T08:59:15.795905Z"^^xsd:dateTime .

oakcurric:keyword-interpret
  a curric:Keyword ;
  schema:name "Interpret"@en ;
  schema:description "When we interpret anything, including data, we explain its meaning."@en ;
  dcterms:modified "2026-02-12T08:59:15.795911Z"^^xsd:dateTime .

oakcurric:keyword-dividend
  a curric:Keyword ;
  schema:name "Dividend"@en ;
