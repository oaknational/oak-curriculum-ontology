  dcterms:modified "2026-02-12T08:59:15.798667Z"^^xsd:dateTime .

oakcurric:keyword-combine
  a curric:Keyword ;
  schema:name "Combine"@en ;
  schema:description "To combine is to put parts together to make a whole."@en ;
  dcterms:modified "2026-02-12T08:59:15.798722Z"^^xsd:dateTime .

oakcurric:keyword-amount
  a curric:Keyword ;
  schema:name "Amount"@en ;
