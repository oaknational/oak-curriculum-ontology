oakcurric:keylearningpoint-lesson-3136-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard units of measure are useful because they are always the same size and do not change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3136-4
  a curric:KeyLearningPoint ;
