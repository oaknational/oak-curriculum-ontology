  dcterms:modified "2026-02-12T08:59:21.686286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2998-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use double facts to solve near-double calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.686290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2998-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can double the smaller addend and add 1   If 4 + 4 = 8, then 4 + 5 is one more than 8, which is 9"""@en ;
  dcterms:modified "2026-02-12T08:59:21.686295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2998-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can double the larger addend and subtract 1   If 5 + 5 = 10, then 4 + 5 is one less than 10, which is 9"""@en ;
  dcterms:modified "2026-02-12T08:59:21.686299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2881-1
  a curric:KeyLearningPoint ;
  rdfs:label "When parts of a whole are added together, each part is called an addend."@en ;
  dcterms:modified "2026-02-12T08:59:21.687545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2881-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can combine the parts in any order because they still make the same whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.687550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2881-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can write the addends in any order because, when combined, they still make the same whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2888-1
  a curric:KeyLearningPoint ;
  rdfs:label """In problems, if the whole and one part of the whole are known, subtraction can be used to find the missing part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2888-2
  a curric:KeyLearningPoint ;
  rdfs:label "This can be represented using a subtraction equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.687563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2888-3
  a curric:KeyLearningPoint ;
  rdfs:label """In problems, if the parts are known, they can be combined using addition to find the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2888-4
  a curric:KeyLearningPoint ;
  rdfs:label "This can be represented using an addition equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.687572Z"^^xsd:dateTime .

