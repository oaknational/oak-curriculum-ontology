  dcterms:modified "2026-02-12T08:59:21.659063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3040-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 10 times table can be represented using multiplication equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.659068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3037-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjacent multiples of 2 have a difference of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.659565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3037-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you add 2 to a multiple of 2 you get the next multiple of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.659570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3037-3
  a curric:KeyLearningPoint ;
  rdfs:label "If you subtract 2 from a multiple of 2 you get the previous multiple of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.659575Z"^^xsd:dateTime .

