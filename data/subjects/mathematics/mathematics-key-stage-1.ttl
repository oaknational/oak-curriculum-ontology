  dcterms:modified "2026-02-12T08:59:21.670923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2894-2
  a curric:KeyLearningPoint ;
  rdfs:label "When more are added, the number at the start increases."@en ;
  dcterms:modified "2026-02-12T08:59:21.670927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2894-3
  a curric:KeyLearningPoint ;
  rdfs:label "The more that are added, the greater the number at the end of the story will be."@en ;
  dcterms:modified "2026-02-12T08:59:21.670932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2894-4
  a curric:KeyLearningPoint ;
  rdfs:label "When some are subtracted, the number at the start decreases."@en ;
  dcterms:modified "2026-02-12T08:59:21.670936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2894-5
  a curric:KeyLearningPoint ;
  rdfs:label "The more that are subtracted, the smaller the amount at the end will be."@en ;
  dcterms:modified "2026-02-12T08:59:21.670941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2906-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding two to an odd number gives the odd number after."@en ;
  dcterms:modified "2026-02-12T08:59:21.670945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2906-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting two from an odd number gives the odd number before."@en ;
  dcterms:modified "2026-02-12T08:59:21.670952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2906-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we count forwards in odd numbers, we add two more each time."@en ;
  dcterms:modified "2026-02-12T08:59:21.670960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2906-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we count backwards in odd numbers, we subtract two each time. The result is two less."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2828-1
  a curric:KeyLearningPoint ;
  rdfs:label """Point to concrete and pictorial resources when counting to 10 to make links and identify how many in a set."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2828-2
  a curric:KeyLearningPoint ;
  rdfs:label "The order in which we count the items in a set is unimportant."@en ;
  dcterms:modified "2026-02-12T08:59:21.671124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2828-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of objects in a group is the same whether they are spread far apart or are close together (conservation)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2874-1
  a curric:KeyLearningPoint ;
  rdfs:label "Odd and even numbers alternate."@en ;
  dcterms:modified "2026-02-12T08:59:21.671136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2874-2
  a curric:KeyLearningPoint ;
  rdfs:label "Between two even numbers there is an odd number."@en ;
  dcterms:modified "2026-02-12T08:59:21.671141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2874-3
  a curric:KeyLearningPoint ;
  rdfs:label "Between two odd numbers there is an even number."@en ;
  dcterms:modified "2026-02-12T08:59:21.671145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2874-4
  a curric:KeyLearningPoint ;
  rdfs:label "Identify odd and even numbers using both the number names and numerals."@en ;
  dcterms:modified "2026-02-12T08:59:21.671150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting can be used to calculate the number of equal groups in a division story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3064-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can use skip counting to work out the number of shorter lengths that are equal to a longer length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3064-3
  a curric:KeyLearningPoint ;
  rdfs:label "50 cm divided into groups of 10 cm lengths is equal to 5; 50 cm ÷ 10 cm = 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.671163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3064-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are 5 groups of 10 cm lengths in 50 cm."@en ;
  dcterms:modified "2026-02-12T08:59:21.671168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2964-1
  a curric:KeyLearningPoint ;
  rdfs:label "A toy or person can be directed using the language of position and direction"@en ;
  dcterms:modified "2026-02-12T08:59:21.671172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Turns to the right and left can be used to give directions"@en ;
  dcterms:modified "2026-02-12T08:59:21.671177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2963-1
  a curric:KeyLearningPoint ;
  rdfs:label "Turns can be described using quarter, half and whole turns."@en ;
  dcterms:modified "2026-02-12T08:59:21.671181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Turns can be made to the right and left."@en ;
  dcterms:modified "2026-02-12T08:59:21.671185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2963-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quarter turns to the left and right can be used to give directions."@en ;
  dcterms:modified "2026-02-12T08:59:21.671190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2963-4
  a curric:KeyLearningPoint ;
  rdfs:label "When you make a whole turn, you will end facing the same way you started."@en ;
  dcterms:modified "2026-02-12T08:59:21.671194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2963-5
  a curric:KeyLearningPoint ;
  rdfs:label """When you make a half turn, you will end facing the opposite way to where you started."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3039-1
  a curric:KeyLearningPoint ;
  rdfs:label "Counting in tens is the pattern of the 10 times table."@en ;
  dcterms:modified "2026-02-12T08:59:21.671210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3039-2
  a curric:KeyLearningPoint ;
  rdfs:label "All multiples of 10 have a zero in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.671215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2951-1
  a curric:KeyLearningPoint ;
  rdfs:label "The size of a coin is not related to its value."@en ;
  dcterms:modified "2026-02-12T08:59:21.671222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2951-2
  a curric:KeyLearningPoint ;
  rdfs:label """The name of a 1 p, 2 p, 5 p and 10 p coin is related to the number of 1 p coins it is worth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.671227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2951-3
  a curric:KeyLearningPoint ;
  rdfs:label "Both a 5 p coin and a 10 p coin are smaller than a 2 p coin but are worth more."@en ;
  dcterms:modified "2026-02-12T08:59:21.671232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3052-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a multiplication, one factor represents the group size."@en ;
  dcterms:modified "2026-02-12T08:59:21.671923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3052-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a multiplication, one factor represents the number of groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.671928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3052-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identify the group size and the number of groups in the multiplication story."@en ;
  dcterms:modified "2026-02-12T08:59:21.671932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2930-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a ruler means that you all get the same measurement for the same object."@en ;
  dcterms:modified "2026-02-12T08:59:21.671937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2930-2
  a curric:KeyLearningPoint ;
  rdfs:label "When using a ruler always measure starting from zero cm."@en ;
  dcterms:modified "2026-02-12T08:59:21.671941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2930-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each number on the ruler represents one cm."@en ;
  dcterms:modified "2026-02-12T08:59:21.671946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2930-4
  a curric:KeyLearningPoint ;
  rdfs:label "cm is the short form of centimetres."@en ;
  dcterms:modified "2026-02-12T08:59:21.671950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2930-5
  a curric:KeyLearningPoint ;
  rdfs:label """The number on the ruler where the object ends tells you the length of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2796-1
  a curric:KeyLearningPoint ;
  rdfs:label "Secure understanding of one less as the number before."@en ;
  dcterms:modified "2026-02-12T08:59:21.671962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2796-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use a variety of manipulatives and the stem sentence to deepen understanding that the number before is one less than ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2796-3
  a curric:KeyLearningPoint ;
  rdfs:label "Answer questions such as 'What number comes before 5 when counting?'"@en ;
  dcterms:modified "2026-02-12T08:59:21.671971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2844-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the numbers one to five can be partitioned into two or more parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.671976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2844-2
  a curric:KeyLearningPoint ;
  rdfs:label "If one part is known, the other part can be found."@en ;
  dcterms:modified "2026-02-12T08:59:21.671980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2844-3
  a curric:KeyLearningPoint ;
  rdfs:label "Know what to do when the known part is zero or the missing part is zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.671985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2847-1
  a curric:KeyLearningPoint ;
  rdfs:label """Movement is magnitude. As you move forwards through the counting sequence the quantity increases by one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Movement is magnitude. As you move backwards through the counting sequence the quantity decreases by one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2847-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use a number line to model the counting sequence and include zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.672376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2868-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers 6 to 9 can be partitioned into 5 and a bit."@en ;
  dcterms:modified "2026-02-12T08:59:21.672380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2868-2
  a curric:KeyLearningPoint ;
  rdfs:label """Where the whole is 6, 7, 8, or 9 it can be partitioned into one part of 5 and one smaller part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2868-3
  a curric:KeyLearningPoint ;
  rdfs:label "A part-part-whole model can represent the five and a bit structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.672389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3109-1
  a curric:KeyLearningPoint ;
  rdfs:label "When a whole is divided in half, there are 2 equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.672394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3109-2
  a curric:KeyLearningPoint ;
  rdfs:label "When a whole is divided into quarters, there are 4 equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.672398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Two-quarters and one-half are equivalent because they describe the same amount when the wholes are the same size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2972-1
  a curric:KeyLearningPoint ;
  rdfs:label "The short hand on a clock face shows which hour we are at or near."@en ;
  dcterms:modified "2026-02-12T08:59:21.673035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2856-1
  a curric:KeyLearningPoint ;
