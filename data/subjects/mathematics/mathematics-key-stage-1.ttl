  dcterms:modified "2026-02-12T08:59:21.673124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2794-3
  a curric:KeyLearningPoint ;
  rdfs:label "Know groups can contain the same number of things."@en ;
  dcterms:modified "2026-02-12T08:59:21.673128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2879-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can represent measures when a part is missing."@en ;
  dcterms:modified "2026-02-12T08:59:21.673132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2879-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each of the numbers six to ten can be partitioned into two parts in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2879-3
  a curric:KeyLearningPoint ;
  rdfs:label "If we know one part we can find the other part."@en ;
  dcterms:modified "2026-02-12T08:59:21.673141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2879-4
  a curric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent the whole number and a missing part."@en ;
  dcterms:modified "2026-02-12T08:59:21.673146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing about odd and even parts means you know if the missing part is odd or even."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673153Z"^^xsd:dateTime .

