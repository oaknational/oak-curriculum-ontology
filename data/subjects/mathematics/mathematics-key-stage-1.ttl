  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of a turn and direction of a turn can be used to describe the rule of a pattern."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659588Z"^^xsd:dateTime .

