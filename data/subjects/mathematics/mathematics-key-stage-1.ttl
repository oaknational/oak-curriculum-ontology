  dcterms:modified "2026-02-12T08:59:21.686277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2920-4
  a curric:KeyLearningPoint ;
  rdfs:label "A number is odd if the ones digit is odd."@en ;
  dcterms:modified "2026-02-12T08:59:21.686281Z"^^xsd:dateTime .

