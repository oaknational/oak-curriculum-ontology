oakcurric:keylearningpoint-lesson-3048-3
  a curric:KeyLearningPoint ;
  rdfs:label "The product of zero and __ is zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.684583Z"^^xsd:dateTime .

