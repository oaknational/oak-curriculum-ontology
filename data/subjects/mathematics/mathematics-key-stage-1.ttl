  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ + ___ + ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.623406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3098-1
  a curric:KeyLearningPoint ;
  rdfs:label """£2 coins, £5 notes, £10 notes and £20 notes can be used to pay for items in pounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3098-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is more efficient to pay for items using fewer coins or notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.623418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3098-3
  a curric:KeyLearningPoint ;
  rdfs:label """When deciding how to pay efficiently, the tens and the ones in the price can be we can partitioned to help us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3098-4
  a curric:KeyLearningPoint ;
  rdfs:label """When making a given value, it is more efficient to use coins or notes with a greater value when you can."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3099-1
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies that are already known can be used to help when solving money problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3099-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addition and subtraction facts can also be used to solve money problems efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3099-3
  a curric:KeyLearningPoint ;
  rdfs:label """A larger value coin or note can be used to pay if the correct amount cannot be made with coins or notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3099-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a larger value coin or note is used to pay, the extra money is given back as change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3030-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can explain and represent multiplication when a group contains zero or one items."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3030-2
  a curric:KeyLearningPoint ;
  rdfs:label "The group size can be 1 and the number of groups can be 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.624965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3030-3
  a curric:KeyLearningPoint ;
  rdfs:label "If there are 3 groups of zero then we can write 0 + 0 + 0 or 3 x 0"@en ;
  dcterms:modified "2026-02-12T08:59:21.624971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2941-1
  a curric:KeyLearningPoint ;
  rdfs:label """A one-penny coin has a value which is independent of its size, shape, colour or mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2941-2
  a curric:KeyLearningPoint ;
  rdfs:label "A one-penny coin has a value of one pence or 1 p."@en ;
  dcterms:modified "2026-02-12T08:59:21.653285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2941-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can find the value of a group of 1 p coins by counting in ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.653290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2941-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use 1 p coins to make different amounts."@en ;
  dcterms:modified "2026-02-12T08:59:21.653294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2858-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recognise and know the difference between flat faces and curved surfaces."@en ;
  dcterms:modified "2026-02-12T08:59:21.653299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2858-2
  a curric:KeyLearningPoint ;
  rdfs:label "Know that when a shape is lying on a curved surface it will roll."@en ;
  dcterms:modified "2026-02-12T08:59:21.653303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2858-3
  a curric:KeyLearningPoint ;
  rdfs:label "Know that when a shape is lying on a flat face it will slide."@en ;
  dcterms:modified "2026-02-12T08:59:21.653308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2858-4
  a curric:KeyLearningPoint ;
  rdfs:label """Know that 3D shapes can have different shaped faces. For example, cones and cylinders have some circular faces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3115-1
  a curric:KeyLearningPoint ;
  rdfs:label "Left and right can be used to describe position."@en ;
  dcterms:modified "2026-02-12T08:59:21.653317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3115-2
  a curric:KeyLearningPoint ;
  rdfs:label """Position can be described using other vocabulary such as above, below and between."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2927-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lengths and heights can be measured using different objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.653326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2927-2
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure accurately, the objects you use to measure should be the same size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2927-3
  a curric:KeyLearningPoint ;
  rdfs:label "When you measure accurately, there should be no gaps between your objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.653340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2927-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure accurately, the objects should be in a straight line from one end to the other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2927-5
  a curric:KeyLearningPoint ;
  rdfs:label "Measurements can be recorded in a table."@en ;
  dcterms:modified "2026-02-12T08:59:21.653350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2983-1
  a curric:KeyLearningPoint ;
  rdfs:label """The order in which tens and ones are arranged does not affect the value of the number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2983-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use the patterns in numbers to help us represent new numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.653359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2871-1
  a curric:KeyLearningPoint ;
  rdfs:label """The position of numbers can be estimated on unmarked number lines using an understanding of relative size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2871-2
  a curric:KeyLearningPoint ;
  rdfs:label "The midpoint, five in this case, should be marked to support positioning"@en ;
  dcterms:modified "2026-02-12T08:59:21.653371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2871-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare numbers on a number line by looking at how far away from other numbers they are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2891-1
  a curric:KeyLearningPoint ;
  rdfs:label "Decreasing the first amount in a story is a type of subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.653380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2891-2
  a curric:KeyLearningPoint ;
  rdfs:label "It can be represented as a ‘First, then, now’ story."@en ;
  dcterms:modified "2026-02-12T08:59:21.653384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2891-3
  a curric:KeyLearningPoint ;
  rdfs:label "It can also be represented as an equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.653389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2891-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first amount in a ‘First, then, now’ story must be written first in an equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2903-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding one gives one more."@en ;
  dcterms:modified "2026-02-12T08:59:21.653398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting one gives one less."@en ;
  dcterms:modified "2026-02-12T08:59:21.653405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3121-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we multiply the same factor by 5 and 10, the product of the factor × 10 is double the product of the factor x 5"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3121-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we multiply the same factor by 5 and 10, the product of the factor × 5 is half of the product of the factor × 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3121-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the products are the same, the factor × 5 is double the factor × 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.653821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3121-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the products are the same, the factor × 5 is half of the factor × 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.653826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3092-1
  a curric:KeyLearningPoint ;
  rdfs:label "Consecutive numbers always have a difference of 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.654392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3092-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the whole and the known part in a subtraction equation are consecutive numbers, the missing part will always be 1"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3092-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the known part in a subtraction equation is 1, the whole and the missing part will be consecutive numbers"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3092-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the ones digits in the whole and the known part are the same, the missing part will be a multiple of 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2887-1
  a curric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent subtraction problems and equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.654410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2887-2
  a curric:KeyLearningPoint ;
  rdfs:label """Overlaying manipulatives on a bar model can be useful for helping to solve subtraction problems and equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2877-1
  a curric:KeyLearningPoint ;
  rdfs:label "Partitioning can be represented on a part-part-whole diagram."@en ;
  dcterms:modified "2026-02-12T08:59:21.654419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2877-2
  a curric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent ways to partition numbers into two parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.654423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2877-3
  a curric:KeyLearningPoint ;
  rdfs:label "The larger the number the greater the number of combinations."@en ;
  dcterms:modified "2026-02-12T08:59:21.654428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2877-4
  a curric:KeyLearningPoint ;
  rdfs:label "Being systematic helps you to find all the ways of partitioning a number."@en ;
  dcterms:modified "2026-02-12T08:59:21.654432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2792-1
  a curric:KeyLearningPoint ;
  rdfs:label "Know the ordinal number names are first, second, third, fourth and fifth."@en ;
  dcterms:modified "2026-02-12T08:59:21.654437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2792-2
  a curric:KeyLearningPoint ;
  rdfs:label """Know that ordinal numbers can be used to describe position in relation to something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2792-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how ordinal numbers are different from cardinal numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.654446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2788-1
  a curric:KeyLearningPoint ;
  rdfs:label """Know subitising is recognising how many things are in a group without having to count them one by one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2788-2
  a curric:KeyLearningPoint ;
  rdfs:label "See regular arrangements of small quantities e.g. a die face."@en ;
  dcterms:modified "2026-02-12T08:59:21.654458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2788-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recognise small amounts up to five when they are not in the regular arrangement."@en ;
  dcterms:modified "2026-02-12T08:59:21.654462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Secure understanding of one more and one less using a variety of manipulatives and pictures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2813-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use stem sentences including one more than and one less than."@en ;
  dcterms:modified "2026-02-12T08:59:21.654472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2957-1
  a curric:KeyLearningPoint ;
  rdfs:label "Part + part = whole"@en ;
  dcterms:modified "2026-02-12T08:59:21.654476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2957-2
  a curric:KeyLearningPoint ;
  rdfs:label "Whole − known part = unknown part"@en ;
  dcterms:modified "2026-02-12T08:59:21.654483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3041-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjacent multiples of 10 have a difference of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.655348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3041-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you add 10 to a multiple of 10 you get the next multiple of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.655353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3041-3
  a curric:KeyLearningPoint ;
  rdfs:label "If you subtract 10 from a multiple of 10 you get the previous multiple of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.655358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3081-1
  a curric:KeyLearningPoint ;
  rdfs:label """Known strategies can be used to help us prepare for the addition of two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3081-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to be able to calculate mentally before adding two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3000-1
  a curric:KeyLearningPoint ;
  rdfs:label "There can be three addends in an addition equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3000-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can represent this using a ten frame, a part-part-whole model or as an equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3008-1
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing numbers, we can look at the difference between them."@en ;
  dcterms:modified "2026-02-12T08:59:21.655557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3008-2
  a curric:KeyLearningPoint ;
  rdfs:label "The difference between two numbers has a value."@en ;
  dcterms:modified "2026-02-12T08:59:21.655562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3008-3
  a curric:KeyLearningPoint ;
  rdfs:label "The difference can be shown as a bar model."@en ;
  dcterms:modified "2026-02-12T08:59:21.655567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Difference can be calculated as subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.655571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3008-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different pairs of numbers can have the same difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.655576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2985-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing two-digit numbers, the number of tens can be compared to find the greater number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2985-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the tens in the numbers are the same, the greater number can be found by comparing the number of ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2985-3
  a curric:KeyLearningPoint ;
  rdfs:label "The greater number can also be found using a number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.655592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2985-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater number comes further in the counting sequence, so it will be further along the number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3137-1
  a curric:KeyLearningPoint ;
  rdfs:label "Length is measured in metres and centimetres."@en ;
  dcterms:modified "2026-02-12T08:59:21.655601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3137-2
  a curric:KeyLearningPoint ;
  rdfs:label "1 cm is about the width of your thumbnail."@en ;
  dcterms:modified "2026-02-12T08:59:21.655605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3137-3
  a curric:KeyLearningPoint ;
  rdfs:label "1 metre is about the height of the door handle."@en ;
  dcterms:modified "2026-02-12T08:59:21.655610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6771-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ten can be added to or subtracted from a multiple of ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.655960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6771-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you add ten to a multiple of ten the tens number increases by one"@en ;
  dcterms:modified "2026-02-12T08:59:21.655964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6771-3
  a curric:KeyLearningPoint ;
  rdfs:label "When you subtract ten from a multiple of ten the tens number decreases by one"@en ;
  dcterms:modified "2026-02-12T08:59:21.655969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6771-4
  a curric:KeyLearningPoint ;
  rdfs:label """If 3 + 1 is equal to 4 then 3 tens + 1 ten is equal to 4 tens which is equal to 40"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2869-1
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 6 to 9 can be represented as two parts, one part of 5 and a smaller part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2869-2
  a curric:KeyLearningPoint ;
  rdfs:label """Part-part-whole relationships can be represented as a bar model or on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2869-3
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of representations, including a number line, can be used to explore the five and a bit structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2797-1
  a curric:KeyLearningPoint ;
  rdfs:label """Secure knowledge and recognition of the digits 0-10 to work out missing numbers on both number track and number lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3127-1
  a curric:KeyLearningPoint ;
  rdfs:label "The dividend is the whole; it is what is being divided."@en ;
  dcterms:modified "2026-02-12T08:59:21.656773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3127-2
  a curric:KeyLearningPoint ;
  rdfs:label "The dividend can only be the dividend in a division equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.656777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3127-3
  a curric:KeyLearningPoint ;
