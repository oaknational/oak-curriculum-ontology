  dcterms:modified "2026-02-12T08:59:15.798066Z"^^xsd:dateTime .

oakcurric:keyword-inverse
  a curric:Keyword ;
  schema:name "Inverse"@en ;
  schema:description "Inverse means the opposite in effect. The reverse of."@en ;
  dcterms:modified "2026-02-12T08:59:15.798452Z"^^xsd:dateTime .

oakcurric:keyword-compare
  a curric:Keyword ;
  schema:name "Compare"@en ;
  schema:description """When you compare, you look for similarities and differences in an object or value."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798491Z"^^xsd:dateTime .

oakcurric:keyword-line-of-symmetry
  a curric:Keyword ;
  schema:name "Line of symmetry"@en ;
