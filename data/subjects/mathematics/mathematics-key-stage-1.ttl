  a curric:KeyLearningPoint ;
  rdfs:label "Partition the addend so that you can make a number pair to 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.659897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3006-2
  a curric:KeyLearningPoint ;
  rdfs:label "The remaining part can be added to 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.659902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3006-3
  a curric:KeyLearningPoint ;
  rdfs:label """Partition the part being subtracted so that one of its smaller parts is equal to the ones digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3006-4
  a curric:KeyLearningPoint ;
  rdfs:label "The remaining part can be subtracted from 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.659911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3006-5
  a curric:KeyLearningPoint ;
