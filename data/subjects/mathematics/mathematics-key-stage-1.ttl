oakcurric:keylearningpoint-lesson-2893-3
  a curric:KeyLearningPoint ;
  rdfs:label "In an addition story, the amount at the start of the story is increased."@en ;
  dcterms:modified "2026-02-12T08:59:21.669425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2893-4
  a curric:KeyLearningPoint ;
  rdfs:label "In an subtraction story, the amount at the start of the story is decreased."@en ;
  dcterms:modified "2026-02-12T08:59:21.669430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3001-1
  a curric:KeyLearningPoint ;
  rdfs:label """A 'First … then … then … now' story can represent an addition with three addends."""@en ;
