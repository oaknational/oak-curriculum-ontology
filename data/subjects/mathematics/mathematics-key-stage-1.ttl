  rdfs:label "Volume and capacity is measured in litres and millilitres."@en ;
  dcterms:modified "2026-02-12T08:59:21.673362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3142-2
  a curric:KeyLearningPoint ;
  rdfs:label "One litre is about the capacity of a large carton of juice."@en ;
  dcterms:modified "2026-02-12T08:59:21.673366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3142-3
  a curric:KeyLearningPoint ;
  rdfs:label "One millilitre is about the volume of a raindrop."@en ;
  dcterms:modified "2026-02-12T08:59:21.673371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3112-1
  a curric:KeyLearningPoint ;
  rdfs:label """When telling and writing the time to five minutes past and to on a clock face, both the hour and minute hand are used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3112-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we go past the half hour, we often say how many minutes to the next hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.673380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3112-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use how many minutes 'past' to help us say how many minutes 'to'."@en ;
  dcterms:modified "2026-02-12T08:59:21.673384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2948-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting can be used to work out how many 10 p coins are needed to make a given value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2948-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you reach the value needed, you must stop counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.673393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2948-3
  a curric:KeyLearningPoint ;
  rdfs:label "The number of 10 p coins needed will be less than the value of the item."@en ;
  dcterms:modified "2026-02-12T08:59:21.673398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2948-4
  a curric:KeyLearningPoint ;
  rdfs:label "Not all values can be made using only 10 p coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.673403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2843-1
  a curric:KeyLearningPoint ;
  rdfs:label "Know there are different ways to partition the numbers one to five."@en ;
  dcterms:modified "2026-02-12T08:59:21.673665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2843-2
  a curric:KeyLearningPoint ;
  rdfs:label "Know each of the numbers one to five can be partitioned in a systematic way."@en ;
  dcterms:modified "2026-02-12T08:59:21.673669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2843-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use part-part-whole models to record the different combinations systematically."@en ;
  dcterms:modified "2026-02-12T08:59:21.673674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2843-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use a table to record the different combinations systematically."@en ;
  dcterms:modified "2026-02-12T08:59:21.673707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2805-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers are always in the same order when we count up to 20."@en ;
  dcterms:modified "2026-02-12T08:59:21.673715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2805-2
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers are always in the same order when we count back from 20."@en ;
  dcterms:modified "2026-02-12T08:59:21.673720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2805-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting objects means matching one word to one object."@en ;
  dcterms:modified "2026-02-12T08:59:21.673724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2805-4
  a curric:KeyLearningPoint ;
  rdfs:label "The last number you say is the number in the set."@en ;
  dcterms:modified "2026-02-12T08:59:21.673729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2862-1
  a curric:KeyLearningPoint ;
  rdfs:label "Describe what the outside of a circle feels like."@en ;
  dcterms:modified "2026-02-12T08:59:21.673734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2862-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identify shapes that are circles because they are round and the outside is always an equal distance from the centre."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identify shapes that are not circles and explain why."@en ;
  dcterms:modified "2026-02-12T08:59:21.673743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2882-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can write an equation to show that the whole is equal to the sum of its parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2882-2
  a curric:KeyLearningPoint ;
  rdfs:label """The equals sign = represents ‘is equal to’. It shows us which parts of the equation are equal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2882-3
  a curric:KeyLearningPoint ;
  rdfs:label "When adding, the whole is called the sum."@en ;
  dcterms:modified "2026-02-12T08:59:21.674065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2882-4
  a curric:KeyLearningPoint ;
  rdfs:label "The sum is equal to the two addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.674072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2882-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can rearrange an equation as long as both sides of the equation remain equal to each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2831-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the symbols < > and = to compare pictorial representations."@en ;
  dcterms:modified "2026-02-12T08:59:21.674082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2831-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use the symbols < > and = to compare numerical expressions."@en ;
  dcterms:modified "2026-02-12T08:59:21.674086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2831-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compare 2 sets where the objects are not arranged linearly."@en ;
  dcterms:modified "2026-02-12T08:59:21.674091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2831-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use a number line to help with sense of number."@en ;
  dcterms:modified "2026-02-12T08:59:21.674095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2831-5
  a curric:KeyLearningPoint ;
  rdfs:label """Moving along the number line corresponds to an increase in the value of the numbers - movement is magnitude."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2845-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the numbers one to five can be partitioned into two parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.674104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the sentence, the whole is ___ and one part is ___ so the other part must be ___"""@en ;
  dcterms:modified "2026-02-12T08:59:21.674109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2845-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notice the smaller the number being partitioned, the fewer the number of combinations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2790-1
  a curric:KeyLearningPoint ;
  rdfs:label "Know a numeral is a symbol or name that stands for a number."@en ;
  dcterms:modified "2026-02-12T08:59:21.674118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2790-2
  a curric:KeyLearningPoint ;
  rdfs:label "Match a numeral with many ideas of a number."@en ;
  dcterms:modified "2026-02-12T08:59:21.674125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3066-1
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be shared into a number of groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.674129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3066-2
  a curric:KeyLearningPoint ;
  rdfs:label "The division symbol is used to represent sharing."@en ;
  dcterms:modified "2026-02-12T08:59:21.674136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3070-1
  a curric:KeyLearningPoint ;
  rdfs:label "A polygon has straight sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.674141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3070-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sides of a polygon meet at vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.674146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3070-3
  a curric:KeyLearningPoint ;
  rdfs:label "A polygon is a 2D shape."@en ;
  dcterms:modified "2026-02-12T08:59:21.674150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3070-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polygons can be sorted in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.674157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3070-5
  a curric:KeyLearningPoint ;
  rdfs:label "Properties of polygons include the number of sides and the number of vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.674162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2958-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to solve a problem, we must visualise and represent it. Once we can see a problem, we know what to calculate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2958-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can represent a problem in many different ways, including as bar models, ‘First, Then, Now’ models and equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2958-3
  a curric:KeyLearningPoint ;
  rdfs:label "To calculate a solution, we can use a range of strategies."@en ;
  dcterms:modified "2026-02-12T08:59:21.674175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2958-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our knowledge of addition facts to help us solve subtraction facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.674180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2958-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our knowledge of subtraction facts to help us solve addition facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.674184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21045-1
  a curric:KeyLearningPoint ;
  rdfs:label "When adding or subtracting 10, the ones digits does not change."@en ;
  dcterms:modified "2026-02-12T08:59:21.675127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21045-2
  a curric:KeyLearningPoint ;
  rdfs:label """When adding 10, the tens digit increases by one; when subtracting 10, the tens digit decreases by one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21045-3
  a curric:KeyLearningPoint ;
  rdfs:label """When numbers have the same ones digit and the tens digit has a difference of one, they will have a difference of 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.675136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the patterns when we add and subtract 10 can help us solve equations efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ten can be partitioned into pairs of numbers that sum to ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.675146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2901-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quickly remembering these number pairs is important for later work."@en ;
  dcterms:modified "2026-02-12T08:59:21.675150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of odd and even numbers can be used to decide if a pair of numbers sums to 10."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2901-4
  a curric:KeyLearningPoint ;
  rdfs:label "One number pair can be used to help you find another number pair."@en ;
  dcterms:modified "2026-02-12T08:59:21.675162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2987-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two-digit numbers can be partitioned into tens and ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.675167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2987-2
  a curric:KeyLearningPoint ;
  rdfs:label "The order of the digits indicates their value."@en ;
  dcterms:modified "2026-02-12T08:59:21.675171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2977-1
  a curric:KeyLearningPoint ;
  rdfs:label "All multiples of ten have a zero in the ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.675176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2977-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is the number 30 and the 3 represents three tens."@en ;
  dcterms:modified "2026-02-12T08:59:21.675181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2977-3
  a curric:KeyLearningPoint ;
  rdfs:label "__ tens is equal to __ty so three tens is equal to thirty."@en ;
  dcterms:modified "2026-02-12T08:59:21.675185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2984-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the intervals on a number line to help us find and position other numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2984-2
  a curric:KeyLearningPoint ;
  rdfs:label "The multiples of ten can help us find which decade a number is in."@en ;
  dcterms:modified "2026-02-12T08:59:21.675218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2984-3
  a curric:KeyLearningPoint ;
  rdfs:label "The midpoint we refer to is halfway between each multiple of ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.675222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2984-4
  a curric:KeyLearningPoint ;
  rdfs:label "The midpoint we refer to has a ones digit of five."@en ;
  dcterms:modified "2026-02-12T08:59:21.675227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2984-5
  a curric:KeyLearningPoint ;
  rdfs:label """The midpoint can help us position numbers that are not close to a multiple of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3059-1
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling is a multiplication where one of the factors is 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.675261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3059-2
  a curric:KeyLearningPoint ;
  rdfs:label "When one of the factors is 2, the other factor is half of the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.675269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3059-3
  a curric:KeyLearningPoint ;
  rdfs:label "Doubles facts to 5 can help to double and halve 2-digit numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.675273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2997-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we double, we add two equal addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.675278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2997-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we halve, we subtract one of the equal amounts from its double."@en ;
  dcterms:modified "2026-02-12T08:59:21.675287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2997-3
  a curric:KeyLearningPoint ;
  rdfs:label "Halving is the inverse of doubling."@en ;
  dcterms:modified "2026-02-12T08:59:21.675293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2997-4
  a curric:KeyLearningPoint ;
  rdfs:label "If I know double 4 is 8, I know half of 8 is 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.675297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3084-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding two-digit numbers that cross the tens boundary, both addends can be partitioned, then recombined."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3084-2
  a curric:KeyLearningPoint ;
  rdfs:label """When adding two-digit numbers that cross the tens boundary, one addend can be partitioned. This is more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3084-3
  a curric:KeyLearningPoint ;
  rdfs:label """A number line can be used to find a missing addend when the tens boundary is crossed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3088-1
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting a 2-digit number, the known part can be partitioned to subtract the tens and the ones separately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3088-2
  a curric:KeyLearningPoint ;
  rdfs:label """Partitioning both the whole and the parts when subtracting gives an correct answer when the ones digits bridge 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.676383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3088-3
  a curric:KeyLearningPoint ;
  rdfs:label """The tens and ones can be subtracted in any order and the remaining part will stay the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Addition is the inverse of subtraction. Addition can 'undo' subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.676392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2899-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtraction is the inverse of addition. Subtraction can 'undo' addition."@en ;
  dcterms:modified "2026-02-12T08:59:21.676396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2899-3
  a curric:KeyLearningPoint ;
  rdfs:label """When an amount is added to the start of a story, to 'undo' the change we must subtract the same amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2899-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a given amount is subtracted from the start of a story, to 'undo' the change we must add the same amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3007-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare two sets of items.  There are more ___ than ___. There are fewer ___ than ___."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3007-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of vocabulary to compare two measures. Longer/shorter, taller/shorter, heavier/lighter etc."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3007-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can see the difference between two numbers or measures as the ‘gap’ between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3007-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cubes, bar models and number lines can help us to visualise this ‘gap’"@en ;
  dcterms:modified "2026-02-12T08:59:21.676427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2789-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recognise amounts that have been rearranged."@en ;
  dcterms:modified "2026-02-12T08:59:21.676431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2789-2
  a curric:KeyLearningPoint ;
  rdfs:label """Generalise that if nothing has been added or taken away, then the amount is the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3042-1
  a curric:KeyLearningPoint ;
  rdfs:label "Counting in fives is the pattern of the 5 times table."@en ;
  dcterms:modified "2026-02-12T08:59:21.676443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3049-1
  a curric:KeyLearningPoint ;
  rdfs:label "The same multiplication can be represented in two different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.676471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3049-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you have 5 groups of 2 you have 2 five times so 5 x 2 = 2 x 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.676476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Factor pairs can be written in any order."@en ;
  dcterms:modified "2026-02-12T08:59:21.676480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3049-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can say that multiplication is commutative."@en ;
  dcterms:modified "2026-02-12T08:59:21.676485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2905-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding two to an even number gives the even number after."@en ;
  dcterms:modified "2026-02-12T08:59:21.676868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2905-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting two from an even number gives the even number before."@en ;
  dcterms:modified "2026-02-12T08:59:21.676872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2905-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we count forwards in even numbers, we add two more each time."@en ;
  dcterms:modified "2026-02-12T08:59:21.676879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2905-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we count backwards in even numbers, we subtract two each time."@en ;
  dcterms:modified "2026-02-12T08:59:21.676884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2883-1
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing a part-part-whole model can help you to understand a mathematical story or equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2883-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving counters or cubes within a part-part-whole model can help you to understand a mathematical story or equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2883-3
  a curric:KeyLearningPoint ;
  rdfs:label "Describing a problem or equation can help you understand it."@en ;
  dcterms:modified "2026-02-12T08:59:21.676903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2883-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can tell a story to represent an equation or completed part-part-whole model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2838-1
  a curric:KeyLearningPoint ;
  rdfs:label "Draw attention to the fact that each part is smaller than the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.676913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2838-2
  a curric:KeyLearningPoint ;
  rdfs:label "Partition objects into 3 parts in as many ways as possible."@en ;
  dcterms:modified "2026-02-12T08:59:21.676917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2787-1
  a curric:KeyLearningPoint ;
  rdfs:label """Secure understanding of counting principles explored so far (stable-order, one-to-one, cardinal)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2787-2
  a curric:KeyLearningPoint ;
  rdfs:label """Know that anything can be counted, including things that cannot be seen, touched or moved (the abstraction principle)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3124-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we are dividing by 5, you can use the 5 times table to find the number of groups or the number in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3124-2
  a curric:KeyLearningPoint ;
  rdfs:label "3 fives are equal to 15, so 15 divided into groups of 5 is equal to 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.676936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3124-3
  a curric:KeyLearningPoint ;
  rdfs:label """3 fives are equal to 15, so 15 divided into 5 groups is equal to 3 in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3102-1
  a curric:KeyLearningPoint ;
  rdfs:label "The whole has been split into 4 equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.676945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3102-2
  a curric:KeyLearningPoint ;
  rdfs:label """The whole has been split into 4 equal parts and each part is one quarter of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2944-1
  a curric:KeyLearningPoint ;
  rdfs:label "A single coin can represent the same amount as several one pennies."@en ;
  dcterms:modified "2026-02-12T08:59:21.676954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2944-2
  a curric:KeyLearningPoint ;
  rdfs:label """The value of a ten-pence coin is not related to its size, shape, colour or quantity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2944-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ten-pence coin has a value of ten pence or 10 p."@en ;
  dcterms:modified "2026-02-12T08:59:21.676963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2944-4
  a curric:KeyLearningPoint ;
  rdfs:label "The value of a ten-pence coin is equal to the value of ten one-pence coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.676968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2944-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can represent a ten-pence coin as a ten-spot token."@en ;
  dcterms:modified "2026-02-12T08:59:21.676973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting can be used to work out how many 2 p coins are needed to make a given value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2946-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you reach the value needed, you must stop counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.676985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2946-3
  a curric:KeyLearningPoint ;
  rdfs:label "The number of 2 p coins needed will be less than the value of the item.."@en ;
  dcterms:modified "2026-02-12T08:59:21.676989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2946-4
  a curric:KeyLearningPoint ;
  rdfs:label "Not all values can be made using only 2 p coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.676994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2978-1
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of ten can be represented with addition of tens."@en ;
  dcterms:modified "2026-02-12T08:59:21.677622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2978-2
  a curric:KeyLearningPoint ;
  rdfs:label "10 + 10 + 10 is equal to three tens which is equal to 30"@en ;
  dcterms:modified "2026-02-12T08:59:21.677627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2978-3
  a curric:KeyLearningPoint ;
  rdfs:label "An expression shows the number of groups being added."@en ;
  dcterms:modified "2026-02-12T08:59:21.677634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2978-4
  a curric:KeyLearningPoint ;
  rdfs:label "An equation includes the sum or total shown using ="@en ;
  dcterms:modified "2026-02-12T08:59:21.677639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2852-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radiating patterns start in the middle and grow around the outside."@en ;
  dcterms:modified "2026-02-12T08:59:21.677644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2852-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radiating pattern can be extended in different ways by choosing different pattern blocks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21043-1
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting multiples of ten from a two-digit number, the tens digit changes but the ones digit stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21043-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use number facts to help us subtract multiples of ten from a two-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2902-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our knowledge of pairs that sum can help when solving subtraction problems and equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quickly remembering these number pairs is important for later work."@en ;
  dcterms:modified "2026-02-12T08:59:21.678193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2867-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can be represented as numerals or using representations."@en ;
  dcterms:modified "2026-02-12T08:59:21.678199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2867-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can be compared to see which one is larger or smaller."@en ;
  dcterms:modified "2026-02-12T08:59:21.678203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2867-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equality and inequality symbols < > and = can be used to show which number is larger or smaller."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2867-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 5 and a bit structure can be used to compare by comparing the additional 'bit'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3058-1
  a curric:KeyLearningPoint ;
  rdfs:label "When one of the factors is 2, the other factor is half of the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.678217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3058-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our knowledge of doubling and halving to help us find a missing factor when the other factor is 2"""@en ;
  dcterms:modified "2026-02-12T08:59:21.678221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2929-1
  a curric:KeyLearningPoint ;
  rdfs:label "Individual cm cubes can be used to measure objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.678226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2929-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can use a 10 cm strip to replace the first 10 cubes, and start your count from 10 to measure more efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2929-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can record results in different types of tables."@en ;
  dcterms:modified "2026-02-12T08:59:21.678235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2960-1
  a curric:KeyLearningPoint ;
  rdfs:label "Left and right can be used to describe position and direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.678239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2960-2
  a curric:KeyLearningPoint ;
  rdfs:label "Directions can be given using left, right, up and down."@en ;
  dcterms:modified "2026-02-12T08:59:21.678244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2936-1
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be put into groups of 2 to make them easier to count."@en ;
  dcterms:modified "2026-02-12T08:59:21.678248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2936-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is more efficient to skip count in twos instead of ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.678256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2936-3
  a curric:KeyLearningPoint ;
  rdfs:label "Groups of 2 can be called twos."@en ;
  dcterms:modified "2026-02-12T08:59:21.678261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Counting back in twos from the amount altogether can be used to check that the count was accurate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2959-1
  a curric:KeyLearningPoint ;
  rdfs:label "When skip counting in twos, we say, 2, 4, 6, 8, 10 …"@en ;
  dcterms:modified "2026-02-12T08:59:21.678270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2959-2
  a curric:KeyLearningPoint ;
  rdfs:label """When skip counting in twos from any given number, we can see this as two more or two less than the odd or even number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2959-3
  a curric:KeyLearningPoint ;
  rdfs:label "When skip counting in fives, we say, 5, 10, 15, 20, 25 …"@en ;
  dcterms:modified "2026-02-12T08:59:21.678279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2959-4
  a curric:KeyLearningPoint ;
  rdfs:label "When skip counting in tens, we say, 10, 20, 30, 40, 50 …"@en ;
  dcterms:modified "2026-02-12T08:59:21.678283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3014-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding three addends, it is efficient to first add two addends using a known fact e.g. pair to 10 or double."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3014-2
  a curric:KeyLearningPoint ;
  rdfs:label "When adding, we can bridge 10 by partitioning a part so that we can ‘make 10’."@en ;
  dcterms:modified "2026-02-12T08:59:21.679009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3014-3
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting, we can bridge 10 by partitioning a part to create a part that is equal to the ones digit of whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3014-4
  a curric:KeyLearningPoint ;
  rdfs:label "The difference can be found through subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.679021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2829-1
  a curric:KeyLearningPoint ;
  rdfs:label "Make comparisons between 2 sets of the same objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.679026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2829-2
  a curric:KeyLearningPoint ;
  rdfs:label "Make comparisons between 2 sets of different objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.679031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2829-3
  a curric:KeyLearningPoint ;
  rdfs:label "Count the different objects separately."@en ;
  dcterms:modified "2026-02-12T08:59:21.679035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2829-4
  a curric:KeyLearningPoint ;
  rdfs:label "One set can contain more or fewer objects than the other."@en ;
  dcterms:modified "2026-02-12T08:59:21.679040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2829-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both sets can contain the same number of objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.679044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2839-1
  a curric:KeyLearningPoint ;
  rdfs:label """A whole group can be split into more than 2 parts and the parts may look different."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2839-2
  a curric:KeyLearningPoint ;
  rdfs:label "Make up a story that represents partitioning into three or more parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.679054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2830-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the symbol <  to represent is less than."@en ;
  dcterms:modified "2026-02-12T08:59:21.679058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2830-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use the symbol  > to represent is more than."@en ;
  dcterms:modified "2026-02-12T08:59:21.679063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2830-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the symbol =  to represent is equal to."@en ;
  dcterms:modified "2026-02-12T08:59:21.679067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2830-4
  a curric:KeyLearningPoint ;
  rdfs:label "The symbols should only be used between numerals."@en ;
  dcterms:modified "2026-02-12T08:59:21.679071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2919-1
  a curric:KeyLearningPoint ;
  rdfs:label "The teens numbers can be represented as ten and a bit."@en ;
  dcterms:modified "2026-02-12T08:59:21.679076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2919-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can solve addition and subtraction problems with the ones part or tens part missing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2919-3
  a curric:KeyLearningPoint ;
  rdfs:label """A part-part whole model can help to represent the missing whole or missing parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2784-1
  a curric:KeyLearningPoint ;
  rdfs:label "Keep one-to-one correspondence between number words and objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.679090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2784-2
  a curric:KeyLearningPoint ;
  rdfs:label """Know objects can be moved from an irregular arrangement into a line to aid counting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2784-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understand that the last number counted tells us 'how many' so far (the cardinal principle)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3063-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting can be used to calculate the number of equal groups in a division story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3063-2
  a curric:KeyLearningPoint ;
  rdfs:label "We say 50 divided into groups of 10 is equal to 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.679111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3063-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can write 50 ÷ 10 = 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.679116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2824-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can find missing numbers on number tracks in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.679120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2824-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can count forwards or backwards to find a number."@en ;
  dcterms:modified "2026-02-12T08:59:21.679125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2824-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can look at the number before or after the missing number to help find it."@en ;
  dcterms:modified "2026-02-12T08:59:21.679130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2824-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can find missing numbers on a number track by looking at the numbers it comes between."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2824-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can use the patterns in numbers to work out new facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.679139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2942-1
  a curric:KeyLearningPoint ;
  rdfs:label "A single coin can represent the same amount as several one pennies."@en ;
  dcterms:modified "2026-02-12T08:59:21.679144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2942-2
  a curric:KeyLearningPoint ;
  rdfs:label """The value of a two-pence coin is not related to its size, shape, colour or quantity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2942-3
  a curric:KeyLearningPoint ;
  rdfs:label "A two-pence coin has a value of two pence or 2 p."@en ;
  dcterms:modified "2026-02-12T08:59:21.679155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2942-4
  a curric:KeyLearningPoint ;
  rdfs:label "The value of a two-pence coin is equal to the value of two one-pence coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.679160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2942-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can represent a two-pence coin as a two-spot token."@en ;
  dcterms:modified "2026-02-12T08:59:21.679164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2952-1
  a curric:KeyLearningPoint ;
  rdfs:label "Coins can be added in any order and the total value will remain the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.679169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2952-2
  a curric:KeyLearningPoint ;
  rdfs:label """It can be easier to add coins if you move them, group together coins of the same value or start with the greatest value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2952-3
  a curric:KeyLearningPoint ;
  rdfs:label """When adding coins, you can use strategies you already know to help you add efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2952-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is more efficient to use fewer coins of greater value than a greater number of lower value coins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2837-1
  a curric:KeyLearningPoint ;
  rdfs:label "A whole group can be split in different ways and the 2 parts may look different."@en ;
  dcterms:modified "2026-02-12T08:59:21.679808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Add a numeral to the whole position when the objects have been moved out."@en ;
  dcterms:modified "2026-02-12T08:59:21.679844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2837-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use part-part-whole diagrams in different orientations."@en ;
  dcterms:modified "2026-02-12T08:59:21.679854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2837-4
  a curric:KeyLearningPoint ;
  rdfs:label "Include examples where the two parts contain the same number of items."@en ;
  dcterms:modified "2026-02-12T08:59:21.679859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2837-5
  a curric:KeyLearningPoint ;
  rdfs:label """Represent the whole and the parts using numerals alongside the concrete and pictorial representations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2981-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ten ones are equivalent to one ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.679868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2981-2
  a curric:KeyLearningPoint ;
  rdfs:label """When counting larger groups, it is more efficient to group objects into tens, then count the tens and extra ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2981-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can work out how many there are by counting in ones, or by counting the groups of ten and extra ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3129-1
  a curric:KeyLearningPoint ;
  rdfs:label "All numbers in the 10 times table have a ones digit of 0"@en ;
  dcterms:modified "2026-02-12T08:59:21.680393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3129-2
  a curric:KeyLearningPoint ;
  rdfs:label "All numbers in the 10 times table are divisible by 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.680397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3035-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 2 times table can be represented in different ways with groups of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.680425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3035-2
  a curric:KeyLearningPoint ;
  rdfs:label "The two times table can be recorded as skip counting in 2 on a number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.680429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3035-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of counts is one of the factors and the skip size of 2 is the other factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3035-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 2 times table can be represented using multiplication equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.680441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2974-1
  a curric:KeyLearningPoint ;
  rdfs:label "The long hand points to 12 when the time is on the hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.680446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2974-2
  a curric:KeyLearningPoint ;
  rdfs:label "We say ___ o'clock when the time is on the hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.680450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2974-3
  a curric:KeyLearningPoint ;
  rdfs:label "The minute hand moves all the way round the clock in one hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.680455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2974-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the minute hand is pointing to the 6, it is half past."@en ;
  dcterms:modified "2026-02-12T08:59:21.680459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3080-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use strategies we already know to help us prepare for the addition of two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3080-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to be able to calculate mentally before adding two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2989-1
  a curric:KeyLearningPoint ;
  rdfs:label """When tens and ones are combined to make a two-digit number, it can be represented as an addition equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2989-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a two-digit number is partitioned into tens and ones, it can be represented as a subtraction equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2989-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use bar models to help us understand and represent a problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.681653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2827-1
  a curric:KeyLearningPoint ;
  rdfs:label """Know the language used when comparing volume and capacity, more than, less than, equal to, the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2827-2
  a curric:KeyLearningPoint ;
  rdfs:label """Know less is used when the noun cannot be counted and fewer is used to descibe countable nouns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2866-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers 6 to 9 are composed of 5 and a bit."@en ;
  dcterms:modified "2026-02-12T08:59:21.681674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2866-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fingers and tens frame representations draw attention to the five and a bit structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2866-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are 5 fingers on each hand."@en ;
  dcterms:modified "2026-02-12T08:59:21.681682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2866-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ten is composed of 5 and 5."@en ;
  dcterms:modified "2026-02-12T08:59:21.681687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2934-1
  a curric:KeyLearningPoint ;
  rdfs:label "Addition and subtraction problems both involve a whole and its parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.681720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2934-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can think about addition and subtraction stories involving length and identify the whole and its parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2934-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you join two items together, you can add their lengths together to find the total length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2934-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you remove part of an object, you subtract the amount you have removed to find the length of the remaining part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2961-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most positional words describe where an object is in relation to one other position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2961-2
  a curric:KeyLearningPoint ;
  rdfs:label "In between describes where an object is in relation to two other positions."@en ;
  dcterms:modified "2026-02-12T08:59:21.681764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3077-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prism is a 3D shape that has identical opposite polygon faces at each end which are joined by rectangular faces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3077-2
  a curric:KeyLearningPoint ;
  rdfs:label """A pyramid is a 3D shape that has a base and an apex at the opposite end to the base."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3077-3
  a curric:KeyLearningPoint ;
  rdfs:label """A prism always has two opposite, identical polygon faces. A prism can be named after its identical polygon faces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3077-4
  a curric:KeyLearningPoint ;
  rdfs:label """A pyramid has a polygon as its base, which is the face opposite the apex. A pyramid can be named after its base."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2953-1
  a curric:KeyLearningPoint ;
  rdfs:label "A combination of different coins can be used to make the same total value."@en ;
  dcterms:modified "2026-02-12T08:59:21.681787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2953-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is more efficient to use fewer coins to pay for an item."@en ;
  dcterms:modified "2026-02-12T08:59:21.681791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2953-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using coins of a greater value where possible will result in fewer coins being used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2953-4
  a curric:KeyLearningPoint ;
  rdfs:label """With prices between 10 p and 20 p, partitioning the price into '10 and a bit' allows more efficient working."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3128-1
  a curric:KeyLearningPoint ;
  rdfs:label "All numbers in the two times table are even."@en ;
  dcterms:modified "2026-02-12T08:59:21.682452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3128-2
  a curric:KeyLearningPoint ;
  rdfs:label "All numbers in the two times table are divisible by 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.682461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3128-3
  a curric:KeyLearningPoint ;
  rdfs:label "If a number is even, it is in the two times table and is divisible by 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.682466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3128-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a number is odd, it is not divisible by 2 because when divided by 2, it does not give two whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2914-1
  a curric:KeyLearningPoint ;
  rdfs:label """Addition and subtraction facts for the pairs 5 and 3 and 6 and 3 can be related to known facts and strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2914-2
  a curric:KeyLearningPoint ;
  rdfs:label "5 and 3 can be calculated using the five and a bit context."@en ;
  dcterms:modified "2026-02-12T08:59:21.683782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2914-3
  a curric:KeyLearningPoint ;
  rdfs:label "6 and 3 can be calculated by relating it to 6 + 4 = 10 which is a known fact."@en ;
  dcterms:modified "2026-02-12T08:59:21.683786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2832-1
  a curric:KeyLearningPoint ;
  rdfs:label "A whole can be represented by one object."@en ;
  dcterms:modified "2026-02-12T08:59:21.683791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2832-2
  a curric:KeyLearningPoint ;
  rdfs:label "If some of the object is missing it is not a whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.683798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2832-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wholes can be different sizes."@en ;
  dcterms:modified "2026-02-12T08:59:21.683802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2832-4
  a curric:KeyLearningPoint ;
  rdfs:label "This is a whole ---- because I have all of it."@en ;
  dcterms:modified "2026-02-12T08:59:21.683807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2832-5
  a curric:KeyLearningPoint ;
  rdfs:label "This is not a whole --- because I do not have all of it."@en ;
  dcterms:modified "2026-02-12T08:59:21.683812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2982-1
  a curric:KeyLearningPoint ;
  rdfs:label "One item can be used to represent several other items. This is called unitising."@en ;
  dcterms:modified "2026-02-12T08:59:21.683816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2982-2
  a curric:KeyLearningPoint ;
  rdfs:label """The order in which tens and ones are arranged does not affect the value of the number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2982-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a one hundred square to help find the value of two-digit numbers more efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2795-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisit the idea of one more than as the next number."@en ;
  dcterms:modified "2026-02-12T08:59:21.683830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2795-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use manipulatives and stem sentences to deepen understanding the next number after a given number is one more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2795-3
  a curric:KeyLearningPoint ;
  rdfs:label "Answer questions such as  'What is the next number after 8 when counting?'"@en ;
  dcterms:modified "2026-02-12T08:59:21.683839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2808-1
  a curric:KeyLearningPoint ;
  rdfs:label "Secure the sequence of numbers to and from 20."@en ;
  dcterms:modified "2026-02-12T08:59:21.683844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2808-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practice one to one correspondence with actions and objects counting forwards and backwards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use understanding of the sequence of numbers to 20 to count on and back from different starting points securely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2928-1
  a curric:KeyLearningPoint ;
  rdfs:label "Individual cm cubes can be used to measure objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.683860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2928-2
  a curric:KeyLearningPoint ;
  rdfs:label """The cm cubes should be lined up exactly with one end of the object with no gaps between them to measure accurately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2928-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to measure in a straight line."@en ;
  dcterms:modified "2026-02-12T08:59:21.683869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2928-4
  a curric:KeyLearningPoint ;
  rdfs:label "The number of cubes tells you the length of the object."@en ;
  dcterms:modified "2026-02-12T08:59:21.683873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3139-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the units are the same, you can compare lengths in the same way as we compare 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3139-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the units are the same, you can order lengths in the same way as we order 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3139-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the units are different and the numbers are the same, you can compare lengths by looking at the unit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3072-1
  a curric:KeyLearningPoint ;
  rdfs:label "The names of polygons are linked to the number of sides they have."@en ;
  dcterms:modified "2026-02-12T08:59:21.683894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3072-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pentagon is any polygon with 5 sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.683902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3072-3
  a curric:KeyLearningPoint ;
  rdfs:label "A hexagon is any polygon with 6 sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.683907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3072-4
  a curric:KeyLearningPoint ;
  rdfs:label "An octagon is any polygon with 8 sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.683911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3074-1
  a curric:KeyLearningPoint ;
  rdfs:label """Polygons can be compared by looking at their properties such as number of sides or vertices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3074-2
  a curric:KeyLearningPoint ;
  rdfs:label """The space inside polygons can be described using informal language such as long, thin, short, wide, larger and smaller."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3074-3
  a curric:KeyLearningPoint ;
  rdfs:label """The vertices of a polygon can be described and compared using informal language such as sharp, pointy, wide and large."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3078-1
  a curric:KeyLearningPoint ;
  rdfs:label "3D shapes can be sorted by their properties"@en ;
  dcterms:modified "2026-02-12T08:59:21.683938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3078-2
  a curric:KeyLearningPoint ;
  rdfs:label "The properties of 3D shapes are the faces, edges and vertices"@en ;
  dcterms:modified "2026-02-12T08:59:21.683943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2971-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers 1 to 12 show the hours on a clock face."@en ;
  dcterms:modified "2026-02-12T08:59:21.683947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Knowing double facts helps you to calculate near-doubles."@en ;
  dcterms:modified "2026-02-12T08:59:21.684485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2912-2
  a curric:KeyLearningPoint ;
  rdfs:label "If 2 + 2 is equal to 4, then 2 + 3 is equal to one more than 4 which is 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.684489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2897-1
  a curric:KeyLearningPoint ;
  rdfs:label """When an amount is changed by subtracting, to undo the change, we must add the same amount back on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2897-2
  a curric:KeyLearningPoint ;
  rdfs:label "The amount that has been subtracted can be found using the known parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.684498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3003-1
  a curric:KeyLearningPoint ;
  rdfs:label "The order of the addends can be changed to make the addition easier"@en ;
