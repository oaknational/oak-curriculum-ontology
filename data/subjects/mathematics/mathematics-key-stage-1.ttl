  a curric:KeyLearningPoint ;
  rdfs:label "Know two or more groups can be compared using 'more than' and 'fewer than'."@en ;
  dcterms:modified "2026-02-12T08:59:21.673119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2794-2
  a curric:KeyLearningPoint ;
