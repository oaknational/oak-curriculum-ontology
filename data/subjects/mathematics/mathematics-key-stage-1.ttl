  dcterms:modified "2026-02-12T08:59:21.659915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2835-1
  a curric:KeyLearningPoint ;
  rdfs:label """If some of the objects in the group are missing, it is not the whole group it is part of the group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2835-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is a whole group of --- because I have all of them and none are missing."@en ;
  dcterms:modified "2026-02-12T08:59:21.659924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2835-3
  a curric:KeyLearningPoint ;
  rdfs:label """This is not the whole group of ---because I do not have all of them and some of them are missing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2835-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are ---- in the whole group and __ in this part of the group."@en ;
  dcterms:modified "2026-02-12T08:59:21.659934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2848-1
  a curric:KeyLearningPoint ;
  rdfs:label "Partitioning can be represented using the bar model."@en ;
  dcterms:modified "2026-02-12T08:59:21.659938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2848-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ objects. ___ is the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.659943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2848-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ and ___. ___ is a part. ___ is a part."@en ;
  dcterms:modified "2026-02-12T08:59:21.659947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2848-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combine the bars to form the full bar model, and compare this with the part-part-whole model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3134-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use times table facts to help solve division problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.659959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3134-2
  a curric:KeyLearningPoint ;
  rdfs:label "Even numbers with a ones digit of 0, 2, 4, 6 or 8 are divisible by 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.659964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3134-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers with a ones digit of 5 or 0 are divisible by 5; numbers with a ones digit of 0 are also divisible by 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.659968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3134-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the dividend is equal to the divisor, the quotient will be equal to 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.659973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3134-5
  a curric:KeyLearningPoint ;
  rdfs:label """When the divisor is 1, the quotient will be equal to the dividend. When the dividend is 0, the quotient will be 0"""@en ;
  dcterms:modified "2026-02-12T08:59:21.659980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3068-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skip counting can help to solve a sharing problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.659985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3068-2
  a curric:KeyLearningPoint ;
  rdfs:label "The whole is shared equally with one object being given to each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.659989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3068-3
  a curric:KeyLearningPoint ;
  rdfs:label "The size of each share is the number of times you have counted."@en ;
  dcterms:modified "2026-02-12T08:59:21.659994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3051-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers in the 10 times table are also in the 2 and 5 times tables."@en ;
  dcterms:modified "2026-02-12T08:59:21.660044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3051-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 2 are all even numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.660048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3051-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 all have a zero in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.660053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3051-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 5 all have a 5 or a 10 in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.660057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21047-1
  a curric:KeyLearningPoint ;
  rdfs:label "Known facts can be used to help us solve equations and problems efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.660689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21047-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can be partitioned to bridge ten to help us work efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.660694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21047-3
  a curric:KeyLearningPoint ;
  rdfs:label """When equations are solved, it is important to choose a strategy that allows you to solve the problem efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3093-1
  a curric:KeyLearningPoint ;
  rdfs:label """When solving problems, it must be decided whether to add or subtract in order to solve it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3093-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the ones digits crosses the tens boundary, it shows that the bridge 10 strategy can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3093-3
  a curric:KeyLearningPoint ;
  rdfs:label "A number line can be drawn or visualised to help solve problems efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.660713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3002-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we add three numbers, the sum will be the same whichever pair of addends we add first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3002-2
  a curric:KeyLearningPoint ;
  rdfs:label "The order of the addends can change and the sum will stay the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.660722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2818-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can count groups of 10 in two ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.660727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2818-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can count groups of 10 using decade numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.660733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2818-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can look at the digit before zero to find out how many tens are in a decade number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2911-1
  a curric:KeyLearningPoint ;
  rdfs:label "Halving is the inverse of doubling."@en ;
  dcterms:modified "2026-02-12T08:59:21.661403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2911-2
  a curric:KeyLearningPoint ;
  rdfs:label "Halving can be used to subtract a number from its double."@en ;
  dcterms:modified "2026-02-12T08:59:21.661410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3013-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding three addends, it is efficient to first add two addends using a known fact e.g. pair to 10 or double."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3013-2
  a curric:KeyLearningPoint ;
  rdfs:label "When adding, we can bridge 10 by partitioning a part so that we can ‘make 10’."@en ;
  dcterms:modified "2026-02-12T08:59:21.661419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3013-3
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting, we can bridge 10 by partitioning a part to create a part that is equal to the ones digit of whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3013-4
  a curric:KeyLearningPoint ;
  rdfs:label "The difference can be found through subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.661428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3126-1
  a curric:KeyLearningPoint ;
  rdfs:label "Halving is dividing into two equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.661433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3126-2
  a curric:KeyLearningPoint ;
  rdfs:label "Halving is the same as dividing by 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.661437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3126-3
  a curric:KeyLearningPoint ;
  rdfs:label "Halving can be used for a division equation where 2 is the divisor."@en ;
  dcterms:modified "2026-02-12T08:59:21.661442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3126-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use known halving facts when the divisor is 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.661448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3111-1
  a curric:KeyLearningPoint ;
  rdfs:label "The clock face shows 12 hours and 60 minutes on the same scale."@en ;
  dcterms:modified "2026-02-12T08:59:21.661454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3111-2
  a curric:KeyLearningPoint ;
  rdfs:label "Between the hours, the scale also shows 5 minutes."@en ;
  dcterms:modified "2026-02-12T08:59:21.661458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3111-3
  a curric:KeyLearningPoint ;
  rdfs:label """When telling and writing the time to five minutes past on a clock face, both the hour hand and the minute hand are used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3009-1
  a curric:KeyLearningPoint ;
  rdfs:label "You calculate the difference by counting on from the known part to the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.661962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3009-2
  a curric:KeyLearningPoint ;
  rdfs:label "The difference is the answer to a subtraction calculation."@en ;
  dcterms:modified "2026-02-12T08:59:21.661966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3009-3
  a curric:KeyLearningPoint ;
  rdfs:label "The difference is one of the parts that make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.661973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2833-1
  a curric:KeyLearningPoint ;
  rdfs:label "A whole can be split into two or more parts in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.661978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2833-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts may look different."@en ;
  dcterms:modified "2026-02-12T08:59:21.661983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2833-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each part will be smaller than the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.661987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2833-4
  a curric:KeyLearningPoint ;
  rdfs:label "The parts can be combined to  make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.661992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2791-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand that zero is a number which shows that there is no amount."@en ;
  dcterms:modified "2026-02-12T08:59:21.661997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2791-2
  a curric:KeyLearningPoint ;
  rdfs:label "Know the number word used is zero and the symbol used is 0"@en ;
  dcterms:modified "2026-02-12T08:59:21.662001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2791-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recite rhymes alongside representations to show zero in different contexts."@en ;
  dcterms:modified "2026-02-12T08:59:21.662006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3067-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skip counting can help to solve a sharing problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.662011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3067-2
  a curric:KeyLearningPoint ;
  rdfs:label "The whole is shared equally with one object being given to each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.662018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3067-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can describe division problems e.g. 35 fish divided between 5 penguins is equal to 7 fish each."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2823-1
  a curric:KeyLearningPoint ;
  rdfs:label """The numbers from 0 to 100 have patterns that can help us to count forwards and backwards across the tens boundary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2823-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are arranged differently on a number track and on a one hundred square."@en ;
  dcterms:modified "2026-02-12T08:59:21.662032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2823-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can count the numbers in two ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.662037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2823-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a number ends in a 9, it is always followed by a decade number when counting in ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3038-1
  a curric:KeyLearningPoint ;
  rdfs:label "5 groups of 2 can be said as 2, five times so 5 x 2 = 2 x 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.662048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3038-2
  a curric:KeyLearningPoint ;
  rdfs:label "Factor pairs can be written in any order."@en ;
  dcterms:modified "2026-02-12T08:59:21.662053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3038-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can say that multiplication is commutative."@en ;
  dcterms:modified "2026-02-12T08:59:21.662058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2943-1
  a curric:KeyLearningPoint ;
  rdfs:label "A single coin can represent the same amount as several one-pennies."@en ;
  dcterms:modified "2026-02-12T08:59:21.662062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2943-2
  a curric:KeyLearningPoint ;
  rdfs:label """The value of a five-pence coin is not related to its size, shape, colour or quantity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2943-3
  a curric:KeyLearningPoint ;
  rdfs:label "A five-pence coin has a value of five-pence or 5 p."@en ;
  dcterms:modified "2026-02-12T08:59:21.662071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2943-4
  a curric:KeyLearningPoint ;
  rdfs:label "The value of a five-pence coin is equal to the value of five one-pence coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.662079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2943-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can represent a five-pence coin as a five-spot token."@en ;
  dcterms:modified "2026-02-12T08:59:21.662083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2949-1
  a curric:KeyLearningPoint ;
  rdfs:label """A five-spot token can be used to represent one 5 p coin and has the same value as five pennies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2949-2
  a curric:KeyLearningPoint ;
  rdfs:label "The total value of set of 5 p coins can be found by skip counting in fives."@en ;
  dcterms:modified "2026-02-12T08:59:21.662093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2949-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can check we have counted accurately by counting backwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.662097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2949-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting in fives can only be used to count the complete set, if all the coins are 5 p coins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3087-1
  a curric:KeyLearningPoint ;
  rdfs:label """The known part can be partitioned into tens and ones before subtracting to help subtract two-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3087-2
  a curric:KeyLearningPoint ;
  rdfs:label """Known facts and the partitioning of numbers can be used to help solve missing number equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3107-1
  a curric:KeyLearningPoint ;
  rdfs:label "To find a third of a number, you divide the whole into 3 equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.662530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3107-2
  a curric:KeyLearningPoint ;
  rdfs:label "To find a quarter of a number, you divide the whole into 4 equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.662534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3107-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to use a bar model to help you find one-third or one-quarter of a number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3108-1
  a curric:KeyLearningPoint ;
  rdfs:label """To divide an object, shape, set of objects or quantity into quarters, you need to divide it into 4 equal parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3108-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you have 3 of those parts, you have three-quarters."@en ;
  dcterms:modified "2026-02-12T08:59:21.662548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3108-3
  a curric:KeyLearningPoint ;
  rdfs:label """It can be helpful to use a bar model to help you find three-quarters of a number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2913-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can visualise a problem to help us understand what it is asking."@en ;
  dcterms:modified "2026-02-12T08:59:21.663230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2913-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can represent addition and subtraction facts using bar models and manipulatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2913-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can calculate using a range of strategies to solve addition and subtraction problems within 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2819-1
  a curric:KeyLearningPoint ;
  rdfs:label """Decade numbers can be ordered on a number track by counting in tens or by looking at the number of tens in the number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2819-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can compare decade numbers using greater than and less than."@en ;
  dcterms:modified "2026-02-12T08:59:21.663271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3120-1
  a curric:KeyLearningPoint ;
  rdfs:label "All multiples of 10 are also multiples of 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.663278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3120-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 have a ones digit of 0"@en ;
  dcterms:modified "2026-02-12T08:59:21.663283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3120-3
  a curric:KeyLearningPoint ;
  rdfs:label """Even multiples of 5 have a ones digit of 0, and odd multiples of 5 have a ones digit of 5"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3120-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 are double the value of multiples of 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.663293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3120-5
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 5 are half the value of multiples of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.663297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2956-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can combine two parts to make a whole.  Part + part = whole"@en ;
  dcterms:modified "2026-02-12T08:59:21.663327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2956-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can partition a whole into two parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.663332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2956-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can partition a part from a whole. Whole − part = part"@en ;
  dcterms:modified "2026-02-12T08:59:21.663336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2785-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisit counting out or 'giving' a number of things from a larger group, not just counting the number there are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2785-2
  a curric:KeyLearningPoint ;
  rdfs:label "Focus on the stopping number which gives the cardinal value."@en ;
  dcterms:modified "2026-02-12T08:59:21.663688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2785-3
  a curric:KeyLearningPoint ;
  rdfs:label """Start counting at a number other than one and stop at a given number e.g. we can count from 5 to 8."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3122-1
  a curric:KeyLearningPoint ;
  rdfs:label """10 is double 5, so when the products are the same, the factor × 10 is half of the factor × 5"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3122-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we multiply the same factor by 5 and 10, the product of the factor × 10 is double the product of the factor × 5"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3122-3
  a curric:KeyLearningPoint ;
  rdfs:label """5 is half of 10, so when the products are the same, the factor × 5 is double the factor × 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3122-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we multiply the same factor by 5 and 10, the product of the factor × 5 is half of the product of the factor × 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3053-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two factors and one is equal to 1 then the product is equal to the other factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3053-2
  a curric:KeyLearningPoint ;
  rdfs:label "1 can represent the group size or the number of groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.663721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3053-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identify the group size and the number of groups in the multiplication story."@en ;
  dcterms:modified "2026-02-12T08:59:21.663725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Consecutive odd numbers have a difference of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.664374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2908-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use this knowledge to solve missing number problems when 2 is the known part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions are written using numerals to show how many equal parts the whole has been divided into and how many we have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3104-2
  a curric:KeyLearningPoint ;
  rdfs:label "1/2 The whole has been divided into 2 equal parts and 1 part has been shaded."@en ;
  dcterms:modified "2026-02-12T08:59:21.664387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3104-3
  a curric:KeyLearningPoint ;
  rdfs:label "1/3 The whole has been divided into 3 equal parts and 1 part has been shaded."@en ;
  dcterms:modified "2026-02-12T08:59:21.664392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3104-4
  a curric:KeyLearningPoint ;
  rdfs:label "1/4 The whole has been divided into 4 equal parts and 1 part has been shaded."@en ;
  dcterms:modified "2026-02-12T08:59:21.664396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2860-1
  a curric:KeyLearningPoint ;
  rdfs:label """Recognise 2D shapes that are the same, including when the rotation, size or proportion has changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2860-2
  a curric:KeyLearningPoint ;
  rdfs:label "Circles are round and have a curved line around the outside."@en ;
  dcterms:modified "2026-02-12T08:59:21.664408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2860-3
  a curric:KeyLearningPoint ;
  rdfs:label "Triangles have 3 straight sides and 3 vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.664413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2860-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rectangles have 4 straight sides and 4 vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.664417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2860-5
  a curric:KeyLearningPoint ;
  rdfs:label "Squares are a type of rectangle that have 4 sides the same length."@en ;
  dcterms:modified "2026-02-12T08:59:21.664422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3110-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are 60 minutes in an hour."@en ;
  dcterms:modified "2026-02-12T08:59:21.664426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3110-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are 24 hours in a day."@en ;
  dcterms:modified "2026-02-12T08:59:21.664431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3110-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understand that the clock face shows hours and minutes on the same scale."@en ;
  dcterms:modified "2026-02-12T08:59:21.664436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2909-1
  a curric:KeyLearningPoint ;
  rdfs:label "When zero is added to a number the number, the number does not change."@en ;
  dcterms:modified "2026-02-12T08:59:21.665650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2909-2
  a curric:KeyLearningPoint ;
  rdfs:label "When zero is subtracted from a number, the number does not change."@en ;
  dcterms:modified "2026-02-12T08:59:21.665654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2909-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting a number from itself gives a difference of zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.665659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3094-1
  a curric:KeyLearningPoint ;
  rdfs:label """When creating problems, we must decide whether we want to create an addition or a subtraction problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Addition problems can involve combining two parts to make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.665668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Addition problems can also involve increasing one part by the other part to reach the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3094-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subtraction problems can involve partitioning one part from the whole to find the remaining part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Subtraction problems can also involve decreasing the whole by one part to find the remaining part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2988-1
  a curric:KeyLearningPoint ;
  rdfs:label """When tens and ones are combined to make a two-digit number, this can be represented it as an addition equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2988-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a two-digit number is partitioned into tens and ones, this can be represented as a subtraction equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2975-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ten ones are equal to one ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.665698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2975-2
  a curric:KeyLearningPoint ;
  rdfs:label "One ten is equal to ten ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.665702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2975-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ten pennies are equal to one ten pence."@en ;
  dcterms:modified "2026-02-12T08:59:21.665707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2840-1
  a curric:KeyLearningPoint ;
  rdfs:label """Counting rhymes help to link the name with the numeral, the cardinal value and the position in the linear number system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2840-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers can represent how many objects there are in a set."@en ;
  dcterms:modified "2026-02-12T08:59:21.665716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2840-3
  a curric:KeyLearningPoint ;
  rdfs:label "For small sets, we can subitise to identify quantity instead of counting."@en ;
  dcterms:modified "2026-02-12T08:59:21.665721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2846-1
  a curric:KeyLearningPoint ;
  rdfs:label "The number before a given number is one less than it."@en ;
  dcterms:modified "2026-02-12T08:59:21.665725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2846-2
  a curric:KeyLearningPoint ;
  rdfs:label "The number after a given number is one more than it."@en ;
  dcterms:modified "2026-02-12T08:59:21.665730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2846-3
  a curric:KeyLearningPoint ;
  rdfs:label "A staircase of blocks can be used to highlight one more and one less."@en ;
  dcterms:modified "2026-02-12T08:59:21.665734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2916-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers 11 - 19 can be positioned on a number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.665739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2916-2
  a curric:KeyLearningPoint ;
  rdfs:label """Saying the teen numbers as one ten and __ ones helps you to position them on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2916-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a link with the position of the numbers 1 - 9 on a number line and the numbers 11 - 29."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing one more and one less than a number to 20 can help to estimate the position the teen numbers on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2918-1
  a curric:KeyLearningPoint ;
  rdfs:label "The teens numbers can be partitioned into ten and a bit."@en ;
  dcterms:modified "2026-02-12T08:59:21.665759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2918-2
  a curric:KeyLearningPoint ;
  rdfs:label """Problems can be represented using part-part-whole models, tens frames and sum equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2918-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 10 and a bit can be represented in the problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.665769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2933-1
  a curric:KeyLearningPoint ;
  rdfs:label "When you estimate length, you think carefully and make a sensible guess."@en ;
  dcterms:modified "2026-02-12T08:59:21.665774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2933-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you find a measurement, you use a ruler so it is more accurate."@en ;
  dcterms:modified "2026-02-12T08:59:21.665781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Estimates and measurements can be recorded in a table."@en ;
  dcterms:modified "2026-02-12T08:59:21.665785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2933-4
  a curric:KeyLearningPoint ;
  rdfs:label "Information in a table can be used to describe and compare lengths."@en ;
  dcterms:modified "2026-02-12T08:59:21.665790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3079-1
  a curric:KeyLearningPoint ;
  rdfs:label "3D shapes can be discussed and compared by their properties."@en ;
  dcterms:modified "2026-02-12T08:59:21.665795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3079-2
  a curric:KeyLearningPoint ;
  rdfs:label "The properties of 3D shapes are the faces, edges and vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.665799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3079-3
  a curric:KeyLearningPoint ;
  rdfs:label """3D shapes can be compared using informal language such as taller, shorter, wider, narrower, smaller and larger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3012-1
  a curric:KeyLearningPoint ;
  rdfs:label "A bar chart is a graph that uses bars to represent information."@en ;
  dcterms:modified "2026-02-12T08:59:21.666568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3012-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts can have different scales."@en ;
  dcterms:modified "2026-02-12T08:59:21.666573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3012-3
  a curric:KeyLearningPoint ;
  rdfs:label """The difference is one of the parts that make the whole. Whole - part = part (difference)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.666577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3012-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can calculate the difference by counting on from the known part to the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3123-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we are dividing by 10, you can use the 10 times table to find the number of groups or the number in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3123-2
  a curric:KeyLearningPoint ;
  rdfs:label "3 tens are equal to 30, so 30 divided into groups of 10 is equal to 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.666591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3123-3
  a curric:KeyLearningPoint ;
  rdfs:label """3 tens are equal to 30, so 30 divided into 10 groups is equal to 3 in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2820-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use the patterns in the one hundred square to help you count to and from 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.666600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2820-2
  a curric:KeyLearningPoint ;
  rdfs:label "The one hundred square is split into rows and these can help you count."@en ;
  dcterms:modified "2026-02-12T08:59:21.666605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2820-3
  a curric:KeyLearningPoint ;
  rdfs:label """All the numbers in a row start in the same way except the decade number at the end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2861-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use everyday language to compare shapes e.g. wide, narrow, tall, short."@en ;
  dcterms:modified "2026-02-12T08:59:21.666622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2861-2
  a curric:KeyLearningPoint ;
  rdfs:label "Be able to count the sides and vertices of different 2D shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.666627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2861-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how to sort shapes into two sets based on 'is' and 'is not' criteria."@en ;
  dcterms:modified "2026-02-12T08:59:21.666631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2861-4
  a curric:KeyLearningPoint ;
  rdfs:label """Be able to guess sorting rules by looking at how shapes have been sorted into two sets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3050-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers in the 10 times table are also in the 2 and 5 times tables."@en ;
  dcterms:modified "2026-02-12T08:59:21.666643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3050-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 2 are all even numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.666650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3050-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 all have a zero in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.666655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of 5 all have a 5 or a 10 in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.666660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3135-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can measure length in any direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.666667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3135-2
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure height, you start from the bottom of the object and measure to the top to find how tall something is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3135-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure length, you start at one end and measure to the other end to find how long or how wide something is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3135-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure distance, you start and stop where the object started and stopped to find how far it has travelled."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3091-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some problems involving the subtraction of two-digit numbers, can be solved by bridging 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3091-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can look to see if the ones digits cross the tens boundary to find out if we must use the bridge 10 strategy"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3089-1
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting, the known part of the whole can be partitioned further to subtract the tens and the ones separately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3089-2
  a curric:KeyLearningPoint ;
  rdfs:label """Partitioning both the whole and the parts when subtracting gives a correct answer when the ones digits bridge 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3089-3
  a curric:KeyLearningPoint ;
  rdfs:label """The tens and ones can be subtracted in any order and the remaining part will stay the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2825-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing different heights and lengths, know the language used varies depending on what we are describing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2825-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ___ is taller / shorter than the ___."@en ;
  dcterms:modified "2026-02-12T08:59:21.667259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2825-3
  a curric:KeyLearningPoint ;
  rdfs:label "The ___ is longer / shorter than the ___."@en ;
  dcterms:modified "2026-02-12T08:59:21.667266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2825-4
  a curric:KeyLearningPoint ;
  rdfs:label "When travelling, some objects travel further, and some objects travel less far."@en ;
  dcterms:modified "2026-02-12T08:59:21.667273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2876-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is more than one way to partition a number."@en ;
  dcterms:modified "2026-02-12T08:59:21.667278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2876-2
  a curric:KeyLearningPoint ;
  rdfs:label "When a number is partitioned into two parts the parts can be odd or even."@en ;
  dcterms:modified "2026-02-12T08:59:21.667283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2932-1
  a curric:KeyLearningPoint ;
  rdfs:label """Length can be estimated in the same way you estimate a position on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2932-2
  a curric:KeyLearningPoint ;
  rdfs:label "The width of your fingernail is about 1 cm in length."@en ;
  dcterms:modified "2026-02-12T08:59:21.667295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2932-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance from the end of your thumb to the side of your hand is about 10 cm in length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2859-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how to sort shapes into 2 sets using the criteria 'has' and 'has no'."@en ;
  dcterms:modified "2026-02-12T08:59:21.667304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2859-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cuboids have rectangular faces and cubes have square faces."@en ;
  dcterms:modified "2026-02-12T08:59:21.667309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2859-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cylinders and cones both have some circular faces."@en ;
  dcterms:modified "2026-02-12T08:59:21.667313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2859-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pyramids always have some triangular face and may have a different shape face as a base."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3086-1
  a curric:KeyLearningPoint ;
  rdfs:label "Known strategies can be used to help subtract two 2-digit numbers efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.667653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3086-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to be able to calculate mentally when beginning to subtract two 2-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6774-1
  a curric:KeyLearningPoint ;
  rdfs:label "Unitising and known facts help you to add and subtract multiples of ten"@en ;
  dcterms:modified "2026-02-12T08:59:21.667662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6774-2
  a curric:KeyLearningPoint ;
  rdfs:label """If 3 + 2 is equal to 5 then 3 tens + 2 tens is equal to 5 tens which is equal to 50"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6774-3
  a curric:KeyLearningPoint ;
  rdfs:label """If 5 - 2 is equal to 3 then 5 tens subtract 2 tens is equal to 3 tens which is equal to 30"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2849-1
  a curric:KeyLearningPoint ;
  rdfs:label "Partitioning of numbers to five can be represented using the bar model."@en ;
  dcterms:modified "2026-02-12T08:59:21.667705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2849-2
  a curric:KeyLearningPoint ;
  rdfs:label "The bar model and the part-part-whole diagram can be used to represent stories."@en ;
  dcterms:modified "2026-02-12T08:59:21.667713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2849-3
  a curric:KeyLearningPoint ;
  rdfs:label """Systematic thinking can be used to ensure all possible responses to a problem can be found."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2922-1
  a curric:KeyLearningPoint ;
  rdfs:label """Addition facts within ten can be applied to addition within 20, e.g. if 3 + 2 is equal to 5 then 13 + 2 is equal to 15"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2922-2
  a curric:KeyLearningPoint ;
  rdfs:label """A number line can be used to show the link between addition of one-digit numbers and teen numbers"""@en ;
  dcterms:modified "2026-02-12T08:59:21.667727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3103-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the whole has been divided into three equal parts, each part is one-third of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3103-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can find thirds of objects, shapes and sets of objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.667736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2938-1
  a curric:KeyLearningPoint ;
  rdfs:label "When counting in fives, each number ends in either 0 or 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.667741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2938-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each time there is an even number of fives, they fit together to makes a ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.667746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2938-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pattern when counting can be used to help us remember the numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.667751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21046-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding multiples of ten to a two-digit number, the tens digit changes but the ones digit stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Number facts can be used to help add and subtract multiples of ten to and from a two-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2979-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are ten jumps of ten on a line from 0 to 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.668109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2979-2
  a curric:KeyLearningPoint ;
  rdfs:label "The multiples of ten are equally spaced."@en ;
  dcterms:modified "2026-02-12T08:59:21.668114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2979-3
  a curric:KeyLearningPoint ;
  rdfs:label "Knowledge of counting to ten can help you count in tens to 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.668118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2821-1
  a curric:KeyLearningPoint ;
  rdfs:label """The numbers from 0 to 100 have patterns that can help us to count across the tens boundary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2821-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are arranged differently on a number track and on a one hundred square."@en ;
  dcterms:modified "2026-02-12T08:59:21.668127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2821-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can count the numbers in two ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.668132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2821-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a whole number ends in a 9, it is always followed by a decade number."@en ;
  dcterms:modified "2026-02-12T08:59:21.668137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3043-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 5 times table can be represented in different ways with groups of 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.668141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3043-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 5 times table can be recorded as skip counting in 5 on a number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.668146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3043-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of counts is one of the factors and the skip size of 5 is the other factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3043-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 5 times table can be represented using multiplication equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.668157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3136-1
  a curric:KeyLearningPoint ;
  rdfs:label """If we all choose our own way to measure, we will end up with different measurements of the same thing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668162Z"^^xsd:dateTime .

