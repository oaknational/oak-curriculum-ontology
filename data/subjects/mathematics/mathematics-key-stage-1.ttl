  dcterms:modified "2026-02-12T08:59:21.687581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2924-3
  a curric:KeyLearningPoint ;
  rdfs:label "If 3 + 2 is equal to 5 then 13 + 2 is equal to 15"@en ;
