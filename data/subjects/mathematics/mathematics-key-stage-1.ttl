  dcterms:modified "2026-02-12T08:59:21.668176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2955-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we count a number of objects, we can use a range of strategies to find the total."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2955-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can start a count from any number and count forwards or backwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.668185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2955-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use 'greater than', 'less than' and 'equal to' to compare numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.668190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2955-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can represent these using the mathematical symbols > , < and ="@en ;
  dcterms:modified "2026-02-12T08:59:21.668194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2945-1
  a curric:KeyLearningPoint ;
  rdfs:label """A two-spot token can be used to represent one 2 p coin and has the same value as two pennies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2945-2
  a curric:KeyLearningPoint ;
  rdfs:label "The total value of set of 2 p coins can be found by skip counting in twos."@en ;
  dcterms:modified "2026-02-12T08:59:21.669253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2945-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting backwards can be used to check the set has been counted accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.669257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skip counting in twos can only be used to count the complete set, if all the coins are 2 p coins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3073-1
  a curric:KeyLearningPoint ;
  rdfs:label """A line of symmetry is used to show that one half of a shape is a reflection of the other half."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3073-2
  a curric:KeyLearningPoint ;
  rdfs:label "When an image is folded along a line of symmetry, the two halves will match."@en ;
  dcterms:modified "2026-02-12T08:59:21.669271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3116-1
  a curric:KeyLearningPoint ;
  rdfs:label "Forwards and backwards can be used to describe movement in a straight line."@en ;
  dcterms:modified "2026-02-12T08:59:21.669275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3116-2
  a curric:KeyLearningPoint ;
  rdfs:label "Left and right can be used to describe movement in a straight line."@en ;
  dcterms:modified "2026-02-12T08:59:21.669280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3116-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direction is dependent on which way a person is facing."@en ;
  dcterms:modified "2026-02-12T08:59:21.669285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2875-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a number is partitioned into two parts one part can be odd and one part can be even or both parts are odd or even."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669289Z"^^xsd:dateTime .

