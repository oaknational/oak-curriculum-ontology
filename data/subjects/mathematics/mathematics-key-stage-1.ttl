  a curric:KeyLearningPoint ;
  rdfs:label """Objects can be divided into groups with the same number in each group. This shows ___ groups with ___ in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673092Z"^^xsd:dateTime .

