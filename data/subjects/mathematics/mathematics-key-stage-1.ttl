  dcterms:modified "2026-02-12T08:59:21.695400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2890-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a ‘First, then, now’ story, the first number is increased to make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.702372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2890-2
  a curric:KeyLearningPoint ;
  rdfs:label """When using addition to increase an amount, the number that is increased must always be represented first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2890-3
  a curric:KeyLearningPoint ;
  rdfs:label """This can be represented with practical equipment and as a bar model or a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2890-4
  a curric:KeyLearningPoint ;
  rdfs:label "An equation can be written to match these representations."@en ;
  dcterms:modified "2026-02-12T08:59:21.702389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2892-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a ‘First, then, now’ subtraction story, the number at the start of the story is decreased by subtracting a part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2892-2
  a curric:KeyLearningPoint ;
  rdfs:label """When using subtraction to decrease an amount, the number that is decreased must always be represented first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2892-3
  a curric:KeyLearningPoint ;
  rdfs:label """This can be represented with practical equipment and as a bar model or a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2892-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can write an equation to match these representations."@en ;
  dcterms:modified "2026-02-12T08:59:21.702619Z"^^xsd:dateTime .

