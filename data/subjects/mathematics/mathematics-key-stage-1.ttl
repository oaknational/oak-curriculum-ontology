  dcterms:modified "2026-02-12T08:59:21.685881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3075-2
  a curric:KeyLearningPoint ;
  rdfs:label "2D shapes can be folded and joined together to build 3D shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.685886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2954-1
  a curric:KeyLearningPoint ;
  rdfs:label """Coins can be added in any order, but it is more efficient to group coins of the same value together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2954-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is more efficient to add the greatest value coins first, or find coins that will help with using a mental strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2954-3
  a curric:KeyLearningPoint ;
  rdfs:label "When adding coins, known strategies can be used to help add efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.685902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2954-4
  a curric:KeyLearningPoint ;
