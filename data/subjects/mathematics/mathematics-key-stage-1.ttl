  dcterms:modified "2026-02-12T08:59:21.689638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2904-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spotting consecutive numbers in subtraction equations can help us to solve equations more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3083-1
