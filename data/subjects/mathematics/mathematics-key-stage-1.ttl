  dcterms:modified "2026-02-12T08:59:21.673043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2856-2
  a curric:KeyLearningPoint ;
  rdfs:label "3D shapes have 3 dimensions and are not flat."@en ;
  dcterms:modified "2026-02-12T08:59:21.673048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2856-3
  a curric:KeyLearningPoint ;
  rdfs:label "A sphere is shaped like a ball."@en ;
  dcterms:modified "2026-02-12T08:59:21.673052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2856-4
  a curric:KeyLearningPoint ;
  rdfs:label "A cylinder has 2 flat circle faces."@en ;
  dcterms:modified "2026-02-12T08:59:21.673057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2856-5
  a curric:KeyLearningPoint ;
  rdfs:label "A cone has 1 vertex and 1 flat circle face."@en ;
  dcterms:modified "2026-02-12T08:59:21.673062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2864-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rectangles have 4 straight sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.673069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2864-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rectangles have 4 vertices that are all the same. They are square corners."@en ;
  dcterms:modified "2026-02-12T08:59:21.673073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2864-3
  a curric:KeyLearningPoint ;
