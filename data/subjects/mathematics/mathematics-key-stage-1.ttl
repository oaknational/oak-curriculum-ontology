# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-3132-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the divisor is equal to the dividend, then the quotient will be 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.606329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3132-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any number divided by itself is equal to 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.606337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3032-1
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the number of groups and the group size you can work out the overall number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3032-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you know the factors you can calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.609854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3032-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can skip count in the group size to calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.609861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3096-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is more efficient to use 20 p and 50 p and £1 coins rather than using lots of smaller value coins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3096-2
  a curric:KeyLearningPoint ;
  rdfs:label "One pound has the same value as one hundred pence."@en ;
  dcterms:modified "2026-02-12T08:59:21.610090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3096-3
  a curric:KeyLearningPoint ;
  rdfs:label "When recording the number of pounds, we can use the pound sign."@en ;
  dcterms:modified "2026-02-12T08:59:21.610097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3096-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pound sign must be written before the number of pounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.610104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3096-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pound sign and the pence sign are never written together."@en ;
  dcterms:modified "2026-02-12T08:59:21.610111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3025-1
  a curric:KeyLearningPoint ;
  rdfs:label "The __ have been put into groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.610119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3025-2
  a curric:KeyLearningPoint ;
  rdfs:label "The groups are equal because there are the same number of __ in each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.610126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3025-3
  a curric:KeyLearningPoint ;
  rdfs:label "The groups are unequal because there are a different number of __ in each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.610133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Finding one more is the same as adding one; finding one less is the same as subtracting one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3017-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers that are one more or one less than each other have a difference of one."@en ;
  dcterms:modified "2026-02-12T08:59:21.610160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3017-3
  a curric:KeyLearningPoint ;
  rdfs:label """When one is added to a number with a ones digit of 9, the next multiple of ten will be reached."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3017-4
  a curric:KeyLearningPoint ;
  rdfs:label """When one is subtracted from a multiple of ten, the number reached will have a ones digit of 9"""@en ;
  dcterms:modified "2026-02-12T08:59:21.610174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3017-5
  a curric:KeyLearningPoint ;
  rdfs:label """When one ten is changed for ten ones, or ten ones for one ten, it is called regrouping."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3023-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we subtract a one-digit from a two-digit number, the equation may be solved more efficiently by 'bridging ten'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3023-2
  a curric:KeyLearningPoint ;
  rdfs:label """When bridging a multiple of ten, the  number that is subtracted is partitioned to reach the previous multiple of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3023-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bridging ten is an efficient strategy because number pairs to ten can be used to calculate more easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3097-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding coins, the multiples of tens, then the ones, can be added to find the total amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3097-2
  a curric:KeyLearningPoint ;
  rdfs:label "Counting on from the tens can also help to find the total."@en ;
  dcterms:modified "2026-02-12T08:59:21.612734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3097-3
  a curric:KeyLearningPoint ;
  rdfs:label "Knowledge of skip counting in twos can be used to count 20 p coins."@en ;
  dcterms:modified "2026-02-12T08:59:21.612740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3097-4
  a curric:KeyLearningPoint ;
  rdfs:label """The tens and ones in the total amount can be partitioned to help when using coins to make a given value ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3097-5
  a curric:KeyLearningPoint ;
  rdfs:label """When the tens and ones digits in the total are the same, we can use the same number fact to find the coins to use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3024-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use known facts to help us find new facts efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.613025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3029-1
  a curric:KeyLearningPoint ;
  rdfs:label "Multiplication can be used to represent equal groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.613032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3029-2
  a curric:KeyLearningPoint ;
  rdfs:label "The x symbol represents times."@en ;
  dcterms:modified "2026-02-12T08:59:21.613039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3029-3
  a curric:KeyLearningPoint ;
  rdfs:label """One number in the multiplication represents the number of groups and the other the number in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21044-1
  a curric:KeyLearningPoint ;
  rdfs:label """When finding 10 more or 10 less than any two-digit number, the ones digits does not change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21044-2
  a curric:KeyLearningPoint ;
  rdfs:label "When finding 10 more than a number below 100, the tens digit increases by one."@en ;
  dcterms:modified "2026-02-12T08:59:21.613272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21044-3
  a curric:KeyLearningPoint ;
  rdfs:label "When finding 10 less than a number below 100, the tens digit decreases by one."@en ;
  dcterms:modified "2026-02-12T08:59:21.613279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3022-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding a single digit and a two-digit number, the equation can be solved more efficiently by 'bridging ten.'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.613705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3022-2
  a curric:KeyLearningPoint ;
  rdfs:label """When bridging a multiple of ten, the second addend is partitioned so that it reaches the next multiple of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3022-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bridging ten is an efficient strategy because number pairs to ten can be used to calculate more easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identify the group size and the number of groups in the problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.613729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3034-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you know the factors you can calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.613737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3034-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can skip count in the group size to calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.613743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3020-1
  a curric:KeyLearningPoint ;
  rdfs:label """Known addition and subtraction facts can be used to to help solve problems more efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3020-2
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing a bar model can help with understanding the problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.614145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3019-1
  a curric:KeyLearningPoint ;
  rdfs:label "Known facts can be used to help find new facts efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.616389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3019-2
  a curric:KeyLearningPoint ;
  rdfs:label "Known facts can be used to solve addition and subtraction problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.616396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3019-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bar models can be drawn to help represent and understand problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.616402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3021-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the ones digits in an equation sum to ten, the sum in the equation will always be a multiple of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3021-2
  a curric:KeyLearningPoint ;
  rdfs:label """When subtracting a one-digit number from a multiple of ten, number bonds to ten can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3021-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number being subtracted and the ones digit in the answer will be a number bond to ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3016-1
  a curric:KeyLearningPoint ;
  rdfs:label """Finding one more is the same as adding 1. Finding one less is the same as subtracting 1"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3016-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers that are one more or one less than each other have a difference of one."@en ;
  dcterms:modified "2026-02-12T08:59:21.621016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2896-1
  a curric:KeyLearningPoint ;
  rdfs:label """The more that is added to an amount at the start of an addition, the greater the amount at the end of the story will be."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2896-2
  a curric:KeyLearningPoint ;
  rdfs:label """The more that is subtracted from the amount at the start of a subtraction, the smaller the amount at the end will be."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3018-1
  a curric:KeyLearningPoint ;
  rdfs:label "Known facts can be used to help solve equations with larger numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.621673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Partitioning a two-digit number into tens and ones can help with seeing the pattern in the ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3018-3
  a curric:KeyLearningPoint ;
  rdfs:label """When adding to or subtracting from the ones without crossing the tens boundary, the tens digit does not change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3028-1
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated addition can be written as a multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.621903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3028-2
  a curric:KeyLearningPoint ;
  rdfs:label "The x symbol represents times."@en ;
  dcterms:modified "2026-02-12T08:59:21.621909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3028-3
  a curric:KeyLearningPoint ;
  rdfs:label "3 groups of 5 can be represented as 5 + 5 + 5 or as 3 x 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.621915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3028-4
  a curric:KeyLearningPoint ;
  rdfs:label "3 represents the number of groups and 5 represents the number in each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.621920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3026-1
  a curric:KeyLearningPoint ;
  rdfs:label "The ___ have been put into groups of ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.622804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3026-2
  a curric:KeyLearningPoint ;
  rdfs:label "The groups are equal because there are the same number of ___ in each group."@en ;
  dcterms:modified "2026-02-12T08:59:21.622813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3026-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ groups of ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.622818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3031-1
  a curric:KeyLearningPoint ;
  rdfs:label "The number of groups is called a factor in a multiplication equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.623082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3031-2
  a curric:KeyLearningPoint ;
  rdfs:label "The group size is also called a factor in a multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.623088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3031-3
  a curric:KeyLearningPoint ;
  rdfs:label "The number of objects overall is called the product of the multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.623093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3033-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identify the group size and the number of groups in the problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.623099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3033-2
  a curric:KeyLearningPoint ;
  rdfs:label "If you know the factors you can calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.623104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3033-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can skip count in the group size to calculate the product."@en ;
  dcterms:modified "2026-02-12T08:59:21.623110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2895-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we know two parts of a ‘First, then, now’ story, we can find the missing part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3027-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ groups of ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.623387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3027-2
  a curric:KeyLearningPoint ;
  rdfs:label "The groups can be represented with an addition."@en ;
  dcterms:modified "2026-02-12T08:59:21.623395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3027-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are ___ and  ___ and ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.623401Z"^^xsd:dateTime .

