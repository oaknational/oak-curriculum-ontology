  dcterms:modified "2026-06-07T15:30:02.360578Z"^^xsd:dateTime .

oakcurric:keyword-angle
  a curric:Keyword ;
  schema:name "Angle"@en ;
  schema:description """An angle is a measure of turn, it is often displayed as the rotation between
  two line segments."""@en ;
  dcterms:modified "2026-06-07T15:30:02.360583Z"^^xsd:dateTime .

oakcurric:keyword-sector
  a curric:Keyword ;
  schema:name "Sector"@en ;
  schema:description """A sector is the region formed between two radii and their connecting
