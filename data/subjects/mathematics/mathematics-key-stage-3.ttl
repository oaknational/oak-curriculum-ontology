  dcterms:modified "2026-02-12T08:59:21.678528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-238-4
  a curric:KeyLearningPoint ;
  rdfs:label "Other sequences might have common structures you can investigate."@en ;
  dcterms:modified "2026-02-12T08:59:21.678533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-349-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pair of compasses can be used to draw circle with a particular radius."@en ;
