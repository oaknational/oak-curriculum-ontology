  dcterms:modified "2026-02-12T08:59:21.634875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ratio table can be a helpful tool for checking the multipliers."@en ;
  dcterms:modified "2026-02-12T08:59:21.634879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-4
  a curric:KeyLearningPoint ;
  rdfs:label """The multiplicative relationship between the sides of the object is preserved in its image."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634884Z"^^xsd:dateTime .

