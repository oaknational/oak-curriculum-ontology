  dcterms:modified "2026-06-07T15:30:29.382389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-325-1
  a curric:KeyLearningPoint ;
  rdfs:label """A circle can be cut into congruent sectors that are placed together to make a
  parallelogram."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-325-2
  a curric:KeyLearningPoint ;
  rdfs:label "The length of the parallelogram is half the circumference of the circle."@en ;
  dcterms:modified "2026-06-07T15:30:29.382399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-325-3
  a curric:KeyLearningPoint ;
  rdfs:label "The height of the parallelogram is the radius of the circle."@en ;
  dcterms:modified "2026-06-07T15:30:29.382403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-325-4
  a curric:KeyLearningPoint ;
  rdfs:label """The formula for the area of a circle can be derived from the area of this
  parallelogram."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-105-1
  a curric:KeyLearningPoint ;
