  dcterms:modified "2026-06-07T15:30:02.356485Z"^^xsd:dateTime .

oakcurric:keyword-variable
  a curric:Keyword ;
  schema:name "variable"@en ;
  schema:description "a factor that can be changed during an experiment"@en ;
  dcterms:modified "2026-06-07T15:30:02.357547Z"^^xsd:dateTime .

oakcurric:keyword-factor
  a curric:Keyword ;
