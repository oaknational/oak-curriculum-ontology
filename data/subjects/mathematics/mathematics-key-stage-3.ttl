  a curric:KeyLearningPoint ;
  rdfs:label "The angle sizes do not change."@en ;
  dcterms:modified "2026-02-12T08:59:21.633727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-367-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing two angles and a length in the triangle and image, you can prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-367-2
  a curric:KeyLearningPoint ;
