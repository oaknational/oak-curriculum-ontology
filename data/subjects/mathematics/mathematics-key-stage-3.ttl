  dcterms:modified "2026-06-07T15:30:29.396539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-286-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient tells us the constant of proportionality."@en ;
  dcterms:modified "2026-06-07T15:30:29.396543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-286-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using these features it is possible to identify direct proportion graphs."@en ;
  dcterms:modified "2026-06-07T15:30:29.396547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20039-1
  a curric:KeyLearningPoint ;
  rdfs:label "A strong understanding of time is necessary"@en ;
  dcterms:modified "2026-06-07T15:30:29.397697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20039-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personal assistants often book appointments for their clients"@en ;
  dcterms:modified "2026-06-07T15:30:29.397701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-413-1
  a curric:KeyLearningPoint ;
  rdfs:label "If you can spot a sequence, it is possible to predict behaviour."@en ;
  dcterms:modified "2026-06-07T15:30:29.397724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-413-2
  a curric:KeyLearningPoint ;
  rdfs:label "By predicting future behaviour, you can plan how to react."@en ;
  dcterms:modified "2026-06-07T15:30:29.397728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-413-3
  a curric:KeyLearningPoint ;
  rdfs:label "As with all predictions, it is not a guarantee."@en ;
  dcterms:modified "2026-06-07T15:30:29.397732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-122-1
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms and their coefficients can be identified."@en ;
  dcterms:modified "2026-06-07T15:30:29.398825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-122-2
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms can be represented using a bar model."@en ;
  dcterms:modified "2026-06-07T15:30:29.398829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-122-3
  a curric:KeyLearningPoint ;
  rdfs:label "Like terms can be collected together, paying careful attention to coefficients."@en ;
  dcterms:modified "2026-06-07T15:30:29.398833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-122-4
  a curric:KeyLearningPoint ;
  rdfs:label "Expressions are easier to use once you have collected all the like terms."@en ;
  dcterms:modified "2026-06-07T15:30:29.398837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-305-1
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be calculated from a line graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.398928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-305-2
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be calculated from an ungrouped frequency table."@en ;
  dcterms:modified "2026-06-07T15:30:29.398932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-305-3
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be calculated from a bar chart."@en ;
  dcterms:modified "2026-06-07T15:30:29.398936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-141-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can identify how to find the perimeter of compound shapes made of
  rectangles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-141-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can calculate the perimeter of compound shapes made from rectangles."@en ;
  dcterms:modified "2026-06-07T15:30:29.398978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-141-3
  a curric:KeyLearningPoint ;
