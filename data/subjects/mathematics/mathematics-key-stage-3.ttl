  schema:description """Like terms are terms that have the same set of variables and corresponding exponents."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790926Z"^^xsd:dateTime .

oakcurric:keyword-simplify
  a curric:Keyword ;
