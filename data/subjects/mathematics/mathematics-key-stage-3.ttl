  dcterms:modified "2026-06-07T15:30:29.429426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-74-3
  a curric:KeyLearningPoint ;
  rdfs:label "The cube root of any perfect cube will be an integer."@en ;
  dcterms:modified "2026-06-07T15:30:29.429432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-74-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cube root of any perfect cube will be an integer and can be calculated by using
  trial and improvement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-265-1
  a curric:KeyLearningPoint ;
  rdfs:label """When an equation is in the form Ax + B = C you can solve by first subtracting B from
  both sides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-265-2
