  dcterms:modified "2026-06-07T15:30:29.413536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-138-5
  a curric:KeyLearningPoint ;
  rdfs:label "The area of any parallelogram can be calculated."@en ;
  dcterms:modified "2026-06-07T15:30:29.413540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-381-1
  a curric:KeyLearningPoint ;
  rdfs:label "Possible outcomes for two events can be stated."@en ;
  dcterms:modified "2026-06-07T15:30:29.413544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-381-2
  a curric:KeyLearningPoint ;
  rdfs:label "Possible outcomes for two events can be listed."@en ;
  dcterms:modified "2026-06-07T15:30:29.413548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-381-3
  a curric:KeyLearningPoint ;
  rdfs:label "Possible outcomes for two events can be systematically listed."@en ;
  dcterms:modified "2026-06-07T15:30:29.413552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-392-1
  a curric:KeyLearningPoint ;
  rdfs:label "Probability is a measure of the likelihood of an outcome happening."@en ;
  dcterms:modified "2026-06-07T15:30:29.413556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-392-2
  a curric:KeyLearningPoint ;
  rdfs:label "An outcome can be assigned a numerical value from 0 to 1"@en ;
  dcterms:modified "2026-06-07T15:30:29.413560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-392-3
  a curric:KeyLearningPoint ;
  rdfs:label "The probability scales shows the numerical values that an outcome might have."@en ;
  dcterms:modified "2026-06-07T15:30:29.413567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-77-1
  a curric:KeyLearningPoint ;
  rdfs:label "Divisibility tests can help identify factors of a number."@en ;
  dcterms:modified "2026-06-07T15:30:29.413571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-77-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using factors pairs it is possible to systematically find all the factors of an
  integer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-77-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to identify common factors by finding all the factors of 2 or more
  numbers and comparing them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-77-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to identify common factors of large numbers by listing all the
  factors but this is time consuming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-77-5
  a curric:KeyLearningPoint ;
  rdfs:label "To simplify fractions it may be helpful to identify the highest common factor."@en ;
  dcterms:modified "2026-06-07T15:30:29.413587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-261-1
  a curric:KeyLearningPoint ;
  rdfs:label """Starting from a single value for a variable you can write equations that are
  equivalent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-261-2
  a curric:KeyLearningPoint ;
  rdfs:label "A solution to a linear equation is a value that makes the two sides equal ."@en ;
  dcterms:modified "2026-06-07T15:30:29.413596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-261-3
  a curric:KeyLearningPoint ;
  rdfs:label "All the equivalent equations will have the same solution."@en ;
  dcterms:modified "2026-06-07T15:30:29.413600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-436-1
  a curric:KeyLearningPoint ;
  rdfs:label "Trigonometry can be useful in many practical situations."@en ;
  dcterms:modified "2026-06-07T15:30:29.413604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-436-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can use it to find the height of objects."@en ;
  dcterms:modified "2026-06-07T15:30:29.413610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-436-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use it to find the length of an object given the length of its shadow."@en ;
  dcterms:modified "2026-06-07T15:30:29.413615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-436-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes it may be better to use Pythagoras' theorem."@en ;
  dcterms:modified "2026-06-07T15:30:29.413619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-178-1
  a curric:KeyLearningPoint ;
  rdfs:label "A ratio describes as connection between two values."@en ;
  dcterms:modified "2026-06-07T15:30:29.413623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-178-2
  a curric:KeyLearningPoint ;
  rdfs:label "This relationship is multiplicative, not additive."@en ;
  dcterms:modified "2026-06-07T15:30:29.413627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-178-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the same amount to each part of the ratio changes the ratio."@en ;
  dcterms:modified "2026-06-07T15:30:29.413631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-397-1
  a curric:KeyLearningPoint ;
  rdfs:label "The probability of an outcome can be calculated from each representation."@en ;
  dcterms:modified "2026-06-07T15:30:29.413670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-397-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different representations show the same information in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.413674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-397-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some representations may be easier to use than others, depending on the context."@en ;
  dcterms:modified "2026-06-07T15:30:29.413678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-314-1
  a curric:KeyLearningPoint ;
  rdfs:label "Statistical summaries can be compared to graphical representations of data."@en ;
  dcterms:modified "2026-06-07T15:30:29.413703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-314-2
  a curric:KeyLearningPoint ;
  rdfs:label """Statistical summaries can be used to produce a sketch of what the graphical
  representation could be."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-314-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different statistical representations can help form a more complete picture."@en ;
  dcterms:modified "2026-06-07T15:30:29.413714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-345-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sum of the exterior angles of a polygon can be demonstrated using a point."@en ;
  dcterms:modified "2026-06-07T15:30:29.414456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-345-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the exterior angles of a polygon can be proven using interior angles and
  the angles on a straight line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-345-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angle sum of a triangle can also be proven using exterior angles ."@en ;
  dcterms:modified "2026-06-07T15:30:29.414465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-345-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of the exterior angle of any polygon can be found using the sum of
  angles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-242-1
  a curric:KeyLearningPoint ;
  rdfs:label "An arithmetic sequence can be generated using an n^th term rule.."@en ;
  dcterms:modified "2026-06-07T15:30:29.414473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-242-2
  a curric:KeyLearningPoint ;
  rdfs:label "The term numbers and terms of a sequence can be converted onto coordinates."@en ;
  dcterms:modified "2026-06-07T15:30:29.414477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-242-3
  a curric:KeyLearningPoint ;
  rdfs:label "These coordinates will lie on a straight line when plotted."@en ;
  dcterms:modified "2026-06-07T15:30:29.414481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-242-4
  a curric:KeyLearningPoint ;
  rdfs:label "Often the rule will be written using a pair of variables."@en ;
  dcterms:modified "2026-06-07T15:30:29.414485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-242-5
  a curric:KeyLearningPoint ;
  rdfs:label "The points can be generated and plotted in the same way as with a sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.414489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-132-1
  a curric:KeyLearningPoint ;
  rdfs:label "Coordinates with any values can be plotted."@en ;
  dcterms:modified "2026-06-07T15:30:29.414493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-132-2
  a curric:KeyLearningPoint ;
