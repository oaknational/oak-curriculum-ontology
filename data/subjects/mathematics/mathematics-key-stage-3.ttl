  dcterms:modified "2026-06-07T15:30:29.393068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-208-3
  a curric:KeyLearningPoint ;
  rdfs:label """This distance is also multiplied by the scale factor to give the distance of the
  image's vertex"""@en ;
  dcterms:modified "2026-06-07T15:30:29.393072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6770-1
  a curric:KeyLearningPoint ;
  rdfs:label "Problems in context involving perimeter can be solved."@en ;
  dcterms:modified "2026-06-07T15:30:29.393076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6770-2
  a curric:KeyLearningPoint ;
  rdfs:label "Problems in context involving area can be solved."@en ;
  dcterms:modified "2026-06-07T15:30:29.393080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6770-3
  a curric:KeyLearningPoint ;
  rdfs:label "The units of measurement should be the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.393084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-419-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding or subtracting, terms may only be combined if the order of each variable
  in each term is the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-419-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the terms can be thought of as a term, despite being comprised of
  multiple terms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-419-3
  a curric:KeyLearningPoint ;
  rdfs:label "a + b = c also means that a = c − b"@en ;
  dcterms:modified "2026-06-07T15:30:29.393096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-419-4
  a curric:KeyLearningPoint ;
  rdfs:label "a = c − b can also be written as a = c + (−b)"@en ;
  dcterms:modified "2026-06-07T15:30:29.393100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-351-1
  a curric:KeyLearningPoint ;
  rdfs:label "A rhombus can be created from two isosceles triangles."@en ;
  dcterms:modified "2026-06-07T15:30:29.394679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-351-2
  a curric:KeyLearningPoint ;
  rdfs:label """An isosceles triangle can be constructed from a given base and side lengths using
  intersecting circles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-351-3
  a curric:KeyLearningPoint ;
  rdfs:label "A rhombus can be constructed from intersecting circles using triangles."@en ;
  dcterms:modified "2026-06-07T15:30:29.394689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-417-1
  a curric:KeyLearningPoint ;
  rdfs:label "The product of two binomials often produces three terms."@en ;
  dcterms:modified "2026-06-07T15:30:29.394694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-417-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are cases where the coefficient of the linear term is zero."@en ;
  dcterms:modified "2026-06-07T15:30:29.394697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-417-3
  a curric:KeyLearningPoint ;
  rdfs:label "The terms in the two binomials can indicate this."@en ;
  dcterms:modified "2026-06-07T15:30:29.394701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-417-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can use an area model to explore the structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.394705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data presented as a list can be represented as a pictogram"@en ;
  dcterms:modified "2026-06-07T15:30:29.394709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Data presented in a table can be represented as a pictogram"@en ;
  dcterms:modified "2026-06-07T15:30:29.394713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-293-3
  a curric:KeyLearningPoint ;
  rdfs:label "The icons chosen should not be distracting or ambiguous"@en ;
  dcterms:modified "2026-06-07T15:30:29.394716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-409-1
  a curric:KeyLearningPoint ;
  rdfs:label "Square number sequences are formed by squaring the position within the sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.394720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-409-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cube number sequences are formed by cubing the position within the sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.394724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-409-3
  a curric:KeyLearningPoint ;
  rdfs:label """Triangular number sequences are formed by increasing the difference by one between
  each consecutive term."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-409-4
  a curric:KeyLearningPoint ;
  rdfs:label "These special number sequences can be represented visually."@en ;
  dcterms:modified "2026-06-07T15:30:29.394732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-270-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets where an expression is multiplied by a term can be expanded."@en ;
  dcterms:modified "2026-06-07T15:30:29.394747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-270-2
  a curric:KeyLearningPoint ;
  rdfs:label """Like terms can then be collected so the equation is in a form that can be
  solved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-270-3
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple identical expressions can be collected together to simplify an
  equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-455-1
  a curric:KeyLearningPoint ;
  rdfs:label "More than one linear graph can be drawn on the same set of axes."@en ;
  dcterms:modified "2026-06-07T15:30:29.395348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-455-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pair of coordinates which lay on the line satisfy the equation of the line."@en ;
  dcterms:modified "2026-06-07T15:30:29.395353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-455-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pair of coordinates for the point of intersection satisfy both equations."@en ;
  dcterms:modified "2026-06-07T15:30:29.395357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-455-4
  a curric:KeyLearningPoint ;
  rdfs:label "Graphical software can be used to show this visually."@en ;
  dcterms:modified "2026-06-07T15:30:29.395360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rotations can be either clockwise or anti-clockwise."@en ;
  dcterms:modified "2026-06-07T15:30:29.395364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-201-2
  a curric:KeyLearningPoint ;
  rdfs:label "The size of the rotation is given in degrees."@en ;
  dcterms:modified "2026-06-07T15:30:29.395368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-203-1
  a curric:KeyLearningPoint ;
  rdfs:label "The length of the lines do not change when reflected."@en ;
  dcterms:modified "2026-06-07T15:30:29.395372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-203-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angles inside an object do not change when reflected."@en ;
  dcterms:modified "2026-06-07T15:30:29.395376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-203-3
  a curric:KeyLearningPoint ;
  rdfs:label "When an object is reflected, its image is congruent."@en ;
  dcterms:modified "2026-06-07T15:30:29.395379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-434-1
  a curric:KeyLearningPoint ;
  rdfs:label "The tangent ratio involves the opposite, adjacent and the angle."@en ;
  dcterms:modified "2026-06-07T15:30:29.395383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-434-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the opposite and the size of the angle, you can use the
  tangent ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-434-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the adjacent and the size of the angle, you can use the
  tangent ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-434-4
  a curric:KeyLearningPoint ;
  rdfs:label """If you know the length of the opposite and adjacent, you can use the tangent
  ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-168-1
  a curric:KeyLearningPoint ;
  rdfs:label """When multiplying you multiply the numerators together and the denominators
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-168-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any value can be written as a fraction with one as the denominator."@en ;
  dcterms:modified "2026-06-07T15:30:29.396444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-168-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use equivalent fractions to be more efficient."@en ;
  dcterms:modified "2026-06-07T15:30:29.396448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-155-1
  a curric:KeyLearningPoint ;
  rdfs:label "The line in a fraction means divide."@en ;
  dcterms:modified "2026-06-07T15:30:29.396452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-155-2
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator can be used to convert a fraction to a decimal using division."@en ;
  dcterms:modified "2026-06-07T15:30:29.396456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-155-3
  a curric:KeyLearningPoint ;
  rdfs:label "There might be limitations of the decimal representation of fractions."@en ;
  dcterms:modified "2026-06-07T15:30:29.396462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-356-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes made from triangles can be constructed."@en ;
  dcterms:modified "2026-06-07T15:30:29.396466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-356-2
  a curric:KeyLearningPoint ;
  rdfs:label "By investigation it is possible to accurately construct multiple polygons."@en ;
  dcterms:modified "2026-06-07T15:30:29.396470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-356-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shortest distances can be found using constructions with perpendicular lines."@en ;
  dcterms:modified "2026-06-07T15:30:29.396476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-219-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to use rounding and place value to know the size of a number without
  knowing the actual number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-219-2
  a curric:KeyLearningPoint ;
  rdfs:label "The first non-zero digit of a number is the first significant figure."@en ;
  dcterms:modified "2026-06-07T15:30:29.396485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-219-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can identify the place value of the first significant figure."@en ;
  dcterms:modified "2026-06-07T15:30:29.396488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-219-4
  a curric:KeyLearningPoint ;
  rdfs:label """A number can be located on a number line and numbers to 1 significant figure either
  side of it represented."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-219-5
  a curric:KeyLearningPoint ;
  rdfs:label """Any integer can be rounded to one significant figure and a number line can help with
  this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-344-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any polygon can be split into triangles."@en ;
  dcterms:modified "2026-06-07T15:30:29.396503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using these triangles you can demonstrate the rule for the interior angle sum of a
  polygon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-344-3
  a curric:KeyLearningPoint ;
  rdfs:label "A missing interior angle in any polygon can be found."@en ;
  dcterms:modified "2026-06-07T15:30:29.396510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-82-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common multiples can be found using the prime factorisation of numbers"@en ;
  dcterms:modified "2026-06-07T15:30:29.396514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-82-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lowest common multiple of two numbers can be found by comparing the prime
  factorisation of both numbers"""@en ;
  dcterms:modified "2026-06-07T15:30:29.396518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-82-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes a Venn diagram can help identify the lowest common multiple of two
  numbers"""@en ;
  dcterms:modified "2026-06-07T15:30:29.396522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-82-4
  a curric:KeyLearningPoint ;
  rdfs:label """The lowest common multiple of more than two numbers can be found using prime
  factorisation"""@en ;
  dcterms:modified "2026-06-07T15:30:29.396526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-286-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct proportion can be recognised graphically."@en ;
  dcterms:modified "2026-06-07T15:30:29.396530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-286-2
  a curric:KeyLearningPoint ;
