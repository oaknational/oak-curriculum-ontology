  dcterms:modified "2026-02-12T08:59:21.633484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-2
  a curric:KeyLearningPoint ;
  rdfs:label "The lengths of the lines may change when enlarged."@en ;
  dcterms:modified "2026-02-12T08:59:21.633491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angles inside an object do not change when enlarged."@en ;
  dcterms:modified "2026-02-12T08:59:21.633496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-4
  a curric:KeyLearningPoint ;
  rdfs:label "When an object is enlarged, the image is similar."@en ;
  dcterms:modified "2026-02-12T08:59:21.633501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-374-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hypotenuse is the side opposite the right angle."@en ;
  dcterms:modified "2026-02-12T08:59:21.633529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-374-2
  a curric:KeyLearningPoint ;
  rdfs:label "It does not matter which of the shorter sides is identified as a or b."@en ;
  dcterms:modified "2026-02-12T08:59:21.633534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two shapes are not similar if there is a pair of lengths with a different multiplicative relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-2
  a curric:KeyLearningPoint ;
