  dcterms:modified "2026-06-07T15:30:02.360676Z"^^xsd:dateTime .

oakcurric:keyword-sense
  a curric:Keyword ;
  schema:name "sense"@en ;
  schema:description "the physical abilities of sight, smell, hearing, touch and taste"@en ;
  dcterms:modified "2026-06-07T15:30:02.360869Z"^^xsd:dateTime .

oakcurric:keyword-estimate
  a curric:Keyword ;
  schema:name "Estimate"@en ;
  schema:description """A quick estimate for a calculation is obtained from using approximate
  values, often rounded to 1 significant figure."""@en ;
  dcterms:modified "2026-06-07T15:30:02.361096Z"^^xsd:dateTime .

oakcurric:keyword-significant-figures
  a curric:Keyword ;
