  dcterms:modified "2026-06-07T15:30:29.382352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-335-4
  a curric:KeyLearningPoint ;
  rdfs:label "The size of missing angles can be justified by using known facts."@en ;
  dcterms:modified "2026-06-07T15:30:29.382356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-139-1
  a curric:KeyLearningPoint ;
  rdfs:label "You can identify how to find the perimeter of polygons."@en ;
  dcterms:modified "2026-06-07T15:30:29.382375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-139-2
  a curric:KeyLearningPoint ;
  rdfs:label """The perimeter of any polygon can be found by adding but this may be time
  consuming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-139-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use a formula to find the perimeter of rectangle."@en ;
  dcterms:modified "2026-06-07T15:30:29.382383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-139-4
  a curric:KeyLearningPoint ;
