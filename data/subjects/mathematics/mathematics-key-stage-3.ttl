oakcurric:keylearningpoint-lesson-138-3
  a curric:KeyLearningPoint ;
  rdfs:label "The area of a parallelogram can be deduced from the area of a rectangle."@en ;
  dcterms:modified "2026-06-07T15:30:29.413531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-138-4
  a curric:KeyLearningPoint ;
