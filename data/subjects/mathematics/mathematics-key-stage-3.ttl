  dcterms:modified "2026-06-07T15:30:02.358276Z"^^xsd:dateTime .

oakcurric:keyword-metric
  a curric:Keyword ;
  schema:name "Metric"@en ;
  schema:description """Metric units are based around the standard units of metre, gram and
