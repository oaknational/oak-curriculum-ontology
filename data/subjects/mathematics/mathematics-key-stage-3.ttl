oakcurric:keylearningpoint-lesson-429-5
  a curric:KeyLearningPoint ;
  rdfs:label "The opposite side of this triangle has length tan⁡(θ)"@en ;
  dcterms:modified "2026-06-07T15:30:29.412373Z"^^xsd:dateTime .

