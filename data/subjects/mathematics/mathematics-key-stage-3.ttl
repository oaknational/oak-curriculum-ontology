  dcterms:modified "2026-06-07T15:30:29.414876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-239-1
  a curric:KeyLearningPoint ;
  rdfs:label "A graph can be used to identify if a particular number is a term in a sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.414880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-239-2
  a curric:KeyLearningPoint ;
  rdfs:label "The nth term rule can be used to determine if a number is in the sequence ."@en ;
  dcterms:modified "2026-06-07T15:30:29.414884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-239-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to justify if a number is or is not a term in a sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.414888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-394-1
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an outcome can be found by considering a table showing all
  possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-394-2
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of a set of outcomes can be found by considering a table showing all
  possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-394-3
  a curric:KeyLearningPoint ;
  rdfs:label """A table of all possible outcomes can help us find a probability, even when the
  outcomes are not equally likely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-246-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is always a common difference in an arithmetic sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.414905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-246-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is always a constant rate of change on a linear graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.414909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-246-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is always an initial value in an arithmetic sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.414913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-246-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is always an intercept point with the y-axis on a linear graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.414919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-246-5
  a curric:KeyLearningPoint ;
  rdfs:label "These two features uniquely describe any linear relationship."@en ;
  dcterms:modified "2026-06-07T15:30:29.414923Z"^^xsd:dateTime .

