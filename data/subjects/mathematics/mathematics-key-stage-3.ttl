  dcterms:modified "2026-06-07T15:30:29.414506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-426-2
  a curric:KeyLearningPoint ;
  rdfs:label "The lengths of the lines may change when enlarged."@en ;
  dcterms:modified "2026-06-07T15:30:29.414510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-426-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angles inside an object do not change when enlarged."@en ;
  dcterms:modified "2026-06-07T15:30:29.414514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-426-4
  a curric:KeyLearningPoint ;
  rdfs:label "When an object is enlarged, the image is similar."@en ;
  dcterms:modified "2026-06-07T15:30:29.414520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-196-1
  a curric:KeyLearningPoint ;
  rdfs:label "A congruent shape has not changed size"@en ;
  dcterms:modified "2026-06-07T15:30:29.414843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-196-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two shapes can be congruent even if one has been reflected or rotated"@en ;
  dcterms:modified "2026-06-07T15:30:29.414849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-196-3
  a curric:KeyLearningPoint ;
  rdfs:label "An image can be described in terms of its object"@en ;
  dcterms:modified "2026-06-07T15:30:29.414853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-196-4
  a curric:KeyLearningPoint ;
  rdfs:label "The description states how the object has been changed"@en ;
  dcterms:modified "2026-06-07T15:30:29.414857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-258-1
  a curric:KeyLearningPoint ;
  rdfs:label "An equation is a statement that two expressions are equal, indicated by =."@en ;
  dcterms:modified "2026-06-07T15:30:29.414861Z"^^xsd:dateTime .

