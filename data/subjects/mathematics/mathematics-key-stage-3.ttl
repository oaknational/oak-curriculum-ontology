  dcterms:modified "2026-06-07T15:30:29.383355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-319-2
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions are understood to be limited by any biases."@en ;
  dcterms:modified "2026-06-07T15:30:29.383359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-319-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions are understood to only be valid for this sample of data."@en ;
  dcterms:modified "2026-06-07T15:30:29.383363Z"^^xsd:dateTime .

