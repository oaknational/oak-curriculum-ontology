  a curric:KeyLearningPoint ;
  rdfs:label "The square root of any perfect square will be an integer."@en ;
  dcterms:modified "2026-06-07T15:30:29.429420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-74-2
  a curric:KeyLearningPoint ;
  rdfs:label """The square root of any perfect square will be an integer and can be calculated by
