  dcterms:modified "2026-06-07T15:30:02.351044Z"^^xsd:dateTime .

oakcurric:keyword-like-terms
  a curric:Keyword ;
  schema:name "Like terms"@en ;
  schema:description """Like terms are terms that have the same set of variables and corresponding
  exponents."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351462Z"^^xsd:dateTime .

oakcurric:keyword-simplify
  a curric:Keyword ;
  schema:name "Simplify"@en ;
  schema:description """Simplifying is to write an expression in a more efficient and compact form
  without affecting the value of the original expression. Fully simplifying means the
  expression cannot be simplified further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351466Z"^^xsd:dateTime .

oakcurric:keyword-additive-inverse
  a curric:Keyword ;
  schema:name "Additive inverse"@en ;
  schema:description """The additive inverse of a number is a number that, when added to the
  original number, gives the sum of 0."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351900Z"^^xsd:dateTime .

oakcurric:keyword-absolute-value
  a curric:Keyword ;
  schema:name "Absolute value"@en ;
  schema:description """The absolute value of a number is its distance from zero. E.g. 5 and (−5)
  are both 5 away from zero and so both have an absolute value of 5."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351907Z"^^xsd:dateTime .

oakcurric:keyword-origin
  a curric:Keyword ;
  schema:name "origin"@en ;
  schema:description """the source or beginning of something like the place, time or history of a
  word or idea"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352364Z"^^xsd:dateTime .

oakcurric:keyword-solution
  a curric:Keyword ;
  schema:name "solution"@en ;
  schema:description "a way to successfully solve a problem or overcome a challenge"@en ;
  dcterms:modified "2026-06-07T15:30:02.353131Z"^^xsd:dateTime .

oakcurric:keyword-forecast
  a curric:Keyword ;
  schema:name "forecast"@en ;
  schema:description """use of technology to predict the likelihood of a tropical storm, including
  its path, intensity and speed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353319Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description """The gradient on a displacement-time graph gives the instantaneous
  velocity."""@en ;
  dcterms:modified "2026-06-07T15:30:02.353605Z"^^xsd:dateTime .

oakcurric:keyword-proportion
  a curric:Keyword ;
  schema:name "proportion"@en ;
  schema:description "the size relationship between different elements of a design"@en ;
  dcterms:modified "2026-06-07T15:30:02.353865Z"^^xsd:dateTime .

oakcurric:keyword-population
  a curric:Keyword ;
  schema:name "population"@en ;
  schema:description """A group of organisms of the same type in the same place is called a
