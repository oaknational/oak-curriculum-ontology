  dcterms:modified "2026-06-07T15:30:02.349214Z"^^xsd:dateTime .

oakcurric:keyword-mixed-number
  a curric:Keyword ;
  schema:name "mixed number"@en ;
  schema:description """A number which combines both a whole number and a fraction is known as a
  mixed number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349236Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-nets
  a curric:Keyword ;
  schema:name "nets"@en ;
  schema:description "the flat or opened out shape of an object, such as a box"@en ;
  dcterms:modified "2026-06-07T15:30:02.349691Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "volume"@en ;
  schema:description """Volume is how much 3D space matter occupies. It is usually measured
  in cm³."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350297Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description """displacement at a point of a wave is the distance that the wave medium is
  from its rest position."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350752Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "frequency"@en ;
  schema:description """frequency is the number of waves produced each second. Frequency is measured
  in Hertz (Hz)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350761Z"^^xsd:dateTime .

oakcurric:keyword-urban
  a curric:Keyword ;
  schema:name "urban"@en ;
  schema:description """relating to a city or town; often busy, built-up areas with lots of human
  activity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350839Z"^^xsd:dateTime .

oakcurric:keyword-proportionality
  a curric:Keyword ;
  schema:name "Proportionality"@en ;
  schema:description """Proportionality means when variables are in proportion if they have a
  constant multiplicative relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350941Z"^^xsd:dateTime .

oakcurric:keyword-digit
  a curric:Keyword ;
  schema:name "digit"@en ;
  schema:description """refers to a single number from 0 to 9, like the digits we use when counting
  or writing numbers"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351031Z"^^xsd:dateTime .

oakcurric:keyword-expression
  a curric:Keyword ;
  schema:name "expression"@en ;
