  dcterms:modified "2026-02-12T08:59:21.634490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two shapes are not congruent if there is a pair of lengths with a scalar not equal to one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-2
  a curric:KeyLearningPoint ;
  rdfs:label "Congruent does not mean the orientation must be the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.634499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angle sizes do not change."@en ;
  dcterms:modified "2026-02-12T08:59:21.634504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-1
  a curric:KeyLearningPoint ;
