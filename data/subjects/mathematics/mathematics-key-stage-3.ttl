  dcterms:modified "2026-06-07T15:30:29.382421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-161-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a number line you can find numbers between two integers."@en ;
  dcterms:modified "2026-06-07T15:30:29.382723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-161-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a number line you can find numbers between two proper fractions."@en ;
  dcterms:modified "2026-06-07T15:30:29.382727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-161-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a number line you can find numbers between two decimals.."@en ;
  dcterms:modified "2026-06-07T15:30:29.382731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-161-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a number it is always possible to find a number between two other numbers."@en ;
  dcterms:modified "2026-06-07T15:30:29.382735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-259-1
  a curric:KeyLearningPoint ;
  rdfs:label "The equals sign means that the two sides of the equation have the same value."@en ;
  dcterms:modified "2026-06-07T15:30:29.382739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-259-2
  a curric:KeyLearningPoint ;
  rdfs:label "This can be described as the expressions balancing."@en ;
  dcterms:modified "2026-06-07T15:30:29.382743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-259-3
  a curric:KeyLearningPoint ;
  rdfs:label "The equality of the expressions can be represented with a bar model."@en ;
  dcterms:modified "2026-06-07T15:30:29.382747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-259-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to rearrange equations to find the family of alternative versions of
  the equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382751Z"^^xsd:dateTime .

