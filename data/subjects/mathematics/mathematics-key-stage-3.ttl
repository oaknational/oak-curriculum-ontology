  dcterms:modified "2026-06-07T15:30:02.355090Z"^^xsd:dateTime .

oakcurric:keyword-climate
  a curric:Keyword ;
  schema:name "climate"@en ;
  schema:description "the average weather conditions in a region over a long period of time"@en ;
  dcterms:modified "2026-06-07T15:30:02.355128Z"^^xsd:dateTime .

oakcurric:keyword-inequality
  a curric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "when things are not fair or equal for everyone"@en ;
  dcterms:modified "2026-06-07T15:30:02.356168Z"^^xsd:dateTime .

oakcurric:keyword-compass
  a curric:Keyword ;
  schema:name "compass"@en ;
