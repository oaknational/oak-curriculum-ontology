oakcurric:keylearningpoint-lesson-335-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sum of angles at a point can be used to find missing angles."@en ;
  dcterms:modified "2026-06-07T15:30:29.382344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-335-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angle sum of a straight line can be used to find missing angles."@en ;
  dcterms:modified "2026-06-07T15:30:29.382348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-335-3
  a curric:KeyLearningPoint ;
