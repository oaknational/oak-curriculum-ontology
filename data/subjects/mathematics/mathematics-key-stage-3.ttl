  dcterms:modified "2026-06-07T15:30:02.357572Z"^^xsd:dateTime .

oakcurric:keyword-systematic
  a curric:Keyword ;
  schema:name "Systematic"@en ;
  schema:description """Being systematic, means working in a set way, often according to a fixed
