# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-373-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the squares of the two shorter sides equals the square of the longest side."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the squares of the longest and known shorter sides is the square of the remaining side."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-3
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator can perform these calculations efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.630617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rounding gives a less accurate answer so there might be times you wish to leave your answer with an operator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-1
  a curric:KeyLearningPoint ;
  rdfs:label "If two triangles are congruent, then one of the proven criteria must apply."@en ;
  dcterms:modified "2026-02-12T08:59:21.631201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-2
  a curric:KeyLearningPoint ;
  rdfs:label """By stating the criteria (that you have already proven), you can prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to be clear why you know that two triangles are congruent."@en ;
  dcterms:modified "2026-02-12T08:59:21.631213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-365-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing the three side lengths of the triangle and its image, you can prove congruence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-365-2
  a curric:KeyLearningPoint ;
  rdfs:label "The corresponding angle pairs will be the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.632768Z"^^xsd:dateTime .

