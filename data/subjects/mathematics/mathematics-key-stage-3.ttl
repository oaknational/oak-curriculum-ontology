oakcurric:keylearningpoint-lesson-323-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a multiplicative relationship between the radius and diameter of a
  circle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-323-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ratio between the diameter and circumference of a circle is always the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.407584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-323-3
  a curric:KeyLearningPoint ;
  rdfs:label "That ratio is called π and it is an irrational number."@en ;
  dcterms:modified "2026-06-07T15:30:29.407588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-323-4
  a curric:KeyLearningPoint ;
  rdfs:label "The formula for the circumference of a circle is C = πd."@en ;
  dcterms:modified "2026-06-07T15:30:29.407592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-323-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using the definition of the diameter you can also write this as C = 2πr."@en ;
  dcterms:modified "2026-06-07T15:30:29.407596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-276-1
  a curric:KeyLearningPoint ;
