  dcterms:modified "2026-06-07T15:30:02.371219Z"^^xsd:dateTime .

oakcurric:keyword-round
  a curric:Keyword ;
  schema:name "round"@en ;
  schema:description """a song structure where multiple groups sing the same melody, but start at
  different times"""@en ;
  dcterms:modified "2026-06-07T15:30:02.371534Z"^^xsd:dateTime .

oakcurric:keyword-experiment
  a curric:Keyword ;
  schema:name "experiment"@en ;
  schema:description "testing ideas, materials, or techniques to discover possibilities"@en ;
  dcterms:modified "2026-06-07T15:30:02.371631Z"^^xsd:dateTime .

oakcurric:keyword-linear
  a curric:Keyword ;
  schema:name "linear"@en ;
  schema:description "in a straight, direct line"@en ;
  dcterms:modified "2026-06-07T15:30:02.372985Z"^^xsd:dateTime .

oakcurric:keyword-line
  a curric:Keyword ;
  schema:name "line"@en ;
  schema:description "a mark made by a moving point, such as a pencil or brush"@en ;
  dcterms:modified "2026-06-07T15:30:02.374643Z"^^xsd:dateTime .

oakcurric:keyword-transformation
  a curric:Keyword ;
  schema:name "transformation"@en ;
  schema:description """Transformation is the process of significant change, often resulting in a
  big shift in character, beliefs, or behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:02.374979Z"^^xsd:dateTime .

oakcurric:keyword-anti-clockwise
  a curric:Keyword ;
  schema:name "anti-clockwise"@en ;
  schema:description "moving or going in the opposite direction of a clock's hands"@en ;
  dcterms:modified "2026-06-07T15:30:02.374988Z"^^xsd:dateTime .

oakcurric:keyword-dividend
  a curric:Keyword ;
  schema:name "Dividend"@en ;
  schema:description "The dividend is what we are dividing."@en ;
  dcterms:modified "2026-06-07T15:30:02.375902Z"^^xsd:dateTime .

oakcurric:keyword-divisor
  a curric:Keyword ;
  schema:name "Divisor"@en ;
  schema:description "The divisor is what we are dividing by."@en ;
  dcterms:modified "2026-06-07T15:30:02.375906Z"^^xsd:dateTime .

oakcurric:keyword-quotient
  a curric:Keyword ;
  schema:name "Quotient"@en ;
  schema:description "The quotient is the result after division has taken place."@en ;
  dcterms:modified "2026-06-07T15:30:02.375913Z"^^xsd:dateTime .

oakcurric:keyword-arc
  a curric:Keyword ;
  schema:name "arc"@en ;
  schema:description "moving with a curving trajectory"@en ;
  dcterms:modified "2026-06-07T15:30:02.376086Z"^^xsd:dateTime .

oakcurric:keyword-quadrilateral
  a curric:Keyword ;
  schema:name "Quadrilateral"@en ;
  schema:description "A polygon with four straight sides."@en ;
  dcterms:modified "2026-06-07T15:30:02.377218Z"^^xsd:dateTime .

oakcurric:keyword-vertex
  a curric:Keyword ;
  schema:name "Vertex"@en ;
  schema:description "The point where two lines meet."@en ;
  dcterms:modified "2026-06-07T15:30:02.377223Z"^^xsd:dateTime .

oakcurric:keyword-partial-product
  a curric:Keyword ;
  schema:name "partial product"@en ;
  schema:description """Any of the multiplication results that lead up to an overall multiplication
  result."""@en ;
  dcterms:modified "2026-06-07T15:30:02.377409Z"^^xsd:dateTime .

oakcurric:keyword-net
  a curric:Keyword ;
  schema:name "net"@en ;
  schema:description "a flat or opened up shape of a 3D object"@en ;
  dcterms:modified "2026-06-07T15:30:02.377894Z"^^xsd:dateTime .

oakcurric:keyword-cross-section
  a curric:Keyword ;
  schema:name "cross-section"@en ;
  schema:description "the inside view of a 3D object when cut straight through"@en ;
  dcterms:modified "2026-06-07T15:30:02.377906Z"^^xsd:dateTime .

oakcurric:keyword-geometric-sequence
  a curric:Keyword ;
  schema:name "Geometric sequence"@en ;
  schema:description """A geometric sequence is a sequence with a constant multiplicative
  relationship between successive terms."""@en ;
  dcterms:modified "2026-06-07T15:30:02.378441Z"^^xsd:dateTime .

oakcurric:keyword-common-ratio
  a curric:Keyword ;
  schema:name "Common ratio"@en ;
  schema:description """In a geometric sequence, the constant multiplier between successive terms is
  called the common ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:02.378446Z"^^xsd:dateTime .

oakcurric:keyword-polygon
  a curric:Keyword ;
  schema:name "Polygon"@en ;
  schema:description "A 2D shape made up of three or more straight lines."@en ;
  dcterms:modified "2026-06-07T15:30:02.378594Z"^^xsd:dateTime .

oakcurric:keyword-bivariate-data
  a curric:Keyword ;
  schema:name "bivariate data"@en ;
  schema:description """data for two variables where one of those variables is believed to influence
  the other"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378727Z"^^xsd:dateTime .

oakcurric:keyword-interpolation
  a curric:Keyword ;
  schema:name "interpolation"@en ;
  schema:description """estimating unknown values within a data set based on other values within the
  set"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378736Z"^^xsd:dateTime .

oakcurric:keyword-extrapolation
  a curric:Keyword ;
  schema:name "extrapolation"@en ;
  schema:description """estimating unknown values beyond the data set based on the pattern or trend
  of the known values"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378740Z"^^xsd:dateTime .

oakcurric:keyword-denominator
  a curric:Keyword ;
  schema:name "Denominator"@en ;
  schema:description """A denominator is the bottom number in a fraction. It shows how many parts a
  whole has been divided into."""@en ;
  dcterms:modified "2026-06-07T15:30:02.378786Z"^^xsd:dateTime .

oakcurric:keyword-numerator
  a curric:Keyword ;
  schema:name "Numerator"@en ;
  schema:description """A numerator is the top number in a fraction. It shows how many parts we
  have."""@en ;
  dcterms:modified "2026-06-07T15:30:02.378791Z"^^xsd:dateTime .

oakcurric:keyword-intercept
  a curric:Keyword ;
  schema:name "intercept"@en ;
  schema:description """stopping or catching a pass from the other team before it reaches the
  intended target"""@en ;
  dcterms:modified "2026-06-07T15:30:02.378972Z"^^xsd:dateTime .

oakcurric:keyword-profit
  a curric:Keyword ;
  schema:name "profit"@en ;
  schema:description "the amount of money made after subtracting all costs from total revenue"@en ;
  dcterms:modified "2026-06-07T15:30:02.379313Z"^^xsd:dateTime .

oakcurric:keyword-constant
  a curric:Keyword ;
  schema:name "Constant"@en ;
  schema:description """A constant is a quantity that has a fixed value that does not change or
  vary, such as a number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.379354Z"^^xsd:dateTime .

oakcurric:keyword-proper-fraction
  a curric:Keyword ;
  schema:name "Proper fraction"@en ;
  schema:description """A proper fraction is a fraction where the numerator (the top number) is less
  than the denominator (the bottom number)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.379415Z"^^xsd:dateTime .

oakcurric:keyword-associative
  a curric:Keyword ;
  schema:name "associative"@en ;
  schema:description """The associative law states that it doesn't matter how you group or pair
  values (i.e. which we calculate first), the result is still the same. It applies for
  addition and multiplication."""@en ;
  dcterms:modified "2026-06-07T15:30:02.379986Z"^^xsd:dateTime .

oakcurric:keyword-commutative
  a curric:Keyword ;
  schema:name "commutative"@en ;
  schema:description """The commutative law states that you can write the values of a calculation in
  a different order without changing the calculation; the result is the same. It applies for
  addition and multiplication."""@en ;
  dcterms:modified "2026-06-07T15:30:02.379990Z"^^xsd:dateTime .

oakcurric:keyword-unknown
  a curric:Keyword ;
  schema:name "unknown"@en ;
  schema:description "a place, situation, or thing that is not known about or understood"@en ;
  dcterms:modified "2026-06-07T15:30:02.380102Z"^^xsd:dateTime .

oakcurric:keyword-equivalent-fraction
  a curric:Keyword ;
  schema:name "Equivalent fraction"@en ;
  schema:description """Equivalent fractions are fractions which have the same value, even though
  they may look different."""@en ;
  dcterms:modified "2026-06-07T15:30:02.380209Z"^^xsd:dateTime .

oakcurric:keyword-partitioning
  a curric:Keyword ;
  schema:name "Partitioning"@en ;
  schema:description "Splitting a number or object into smaller parts."@en ;
  dcterms:modified "2026-06-07T15:30:02.381105Z"^^xsd:dateTime .

oakcurric:keyword-line-of-reflection
  a curric:Keyword ;
  schema:name "Line of reflection"@en ;
  schema:description """The line of reflection is the fixed line about which an object is reflected.
  The object and image are equidistant from the line of reflection."""@en ;
  dcterms:modified "2026-06-07T15:30:02.381595Z"^^xsd:dateTime .

oakcurric:keyword-sum
  a curric:Keyword ;
  schema:name "Sum"@en ;
  schema:description "The result of adding two or more numbers"@en ;
  dcterms:modified "2026-06-07T15:30:02.382045Z"^^xsd:dateTime .

oakcurric:keyword-parallel
  a curric:Keyword ;
  schema:name "parallel"@en ;
  schema:description "side by side alignment of the feet on landing"@en ;
  dcterms:modified "2026-06-07T15:30:02.382525Z"^^xsd:dateTime .

oakcurric:keyword-unitising
  a curric:Keyword ;
  schema:name "Unitising"@en ;
  schema:description """Treating groups that contain the same number of things as ‘ones’ or ‘units’.
  It is important particularly in handling money and in understanding place value and
  supports us to think multiplicatively."""@en ;
  dcterms:modified "2026-06-07T15:30:02.382963Z"^^xsd:dateTime .

oakcurric:keyword-distributive-law
  a curric:Keyword ;
  schema:name "Distributive law"@en ;
  schema:description """The distributive law says that multiplying a number by a group of numbers
  added together is the same as doing each multiplication separately."""@en ;
  dcterms:modified "2026-06-07T15:30:02.382968Z"^^xsd:dateTime .

oakcurric:keyword-interior-angle
  a curric:Keyword ;
  schema:name "Interior angle"@en ;
  schema:description """An interior angle is an angle formed inside a polygon by two of its
  edges."""@en ;
  dcterms:modified "2026-06-07T15:30:02.383395Z"^^xsd:dateTime .

oakcurric:keyword-exterior-angle
  a curric:Keyword ;
  schema:name "Exterior angle"@en ;
  schema:description """An exterior angle is an angle on the outside of a polygon between an
  extension of an edge and its adjacent edge."""@en ;
  dcterms:modified "2026-06-07T15:30:02.383399Z"^^xsd:dateTime .

oakcurric:keyword-altitude
  a curric:Keyword ;
  schema:name "altitude"@en ;
  schema:description "height above sea level or ground level"@en ;
  dcterms:modified "2026-06-07T15:30:02.383549Z"^^xsd:dateTime .

oakcurric:keyword-zero-pair
  a curric:Keyword ;
  schema:name "Zero pair"@en ;
  schema:description "A number and its additive inverse make a zero pair."@en ;
  dcterms:modified "2026-06-07T15:30:02.384435Z"^^xsd:dateTime .

oakcurric:keyword-standard-form
  a curric:Keyword ;
  schema:name "Standard form"@en ;
  schema:description """Standard form is when a number is written in the form A × 10n, (where 1 ≤ A
  < 10 and n is an integer)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.384945Z"^^xsd:dateTime .

oakcurric:keyword-exponential-form
  a curric:Keyword ;
  schema:name "Exponential form"@en ;
  schema:description """When a number is multiplied by itself multiple times, it can be written more
  simply in exponential form."""@en ;
  dcterms:modified "2026-06-07T15:30:02.384951Z"^^xsd:dateTime .

oakcurric:keyword-systematically
  a curric:Keyword ;
  schema:name "systematically"@en ;
  schema:description """when something is done systematically it is done in a way that is done
  according to an agreed set of methods or organised plan"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384974Z"^^xsd:dateTime .

oakcurric:keyword-translate
  a curric:Keyword ;
  schema:name "Translate"@en ;
  schema:description "To translate something means to change it from one language to another."@en ;
  dcterms:modified "2026-06-07T15:30:02.385015Z"^^xsd:dateTime .

oakcurric:keyword-substitution
  a curric:Keyword ;
  schema:name "Substitution"@en ;
  schema:description """Substitute means to put in place of another. In Algebra, substitution can be
  used to replace variables with values."""@en ;
  dcterms:modified "2026-06-07T15:30:02.386041Z"^^xsd:dateTime .

oakcurric:keyword-square
  a curric:Keyword ;
  schema:name "square"@en ;
  schema:description "a pass that goes sideways across the pitch, not forward or backwards"@en ;
  dcterms:modified "2026-06-07T15:30:02.386331Z"^^xsd:dateTime .

oakcurric:keyword-right-angled-triangle
  a curric:Keyword ;
  schema:name "right-angled triangle"@en ;
  schema:description "A right-angled triangle has exactly one 90° interior angle."@en ;
  dcterms:modified "2026-06-07T15:30:02.386414Z"^^xsd:dateTime .

oakcurric:keyword-hypotenuse
  a curric:Keyword ;
  schema:name "hypotenuse"@en ;
  schema:description """A hypotenuse is the side of the right-angled triangle which is opposite the
  right-angle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.386419Z"^^xsd:dateTime .

oakcurric:keyword-congruent
  a curric:Keyword ;
  schema:name "Congruent"@en ;
  schema:description """If one shape can fit exactly on top of another using rotation, reflection or
  translation, then the shapes are congruent."""@en ;
  dcterms:modified "2026-06-07T15:30:02.386630Z"^^xsd:dateTime .

oakcurric:keyword-similar
  a curric:Keyword ;
  schema:name "Similar"@en ;
  schema:description """Two shapes are similar if the only difference between them is their size.
  Their side lengths are in the same proportions."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387279Z"^^xsd:dateTime .

oakcurric:keyword-scale-factor
  a curric:Keyword ;
  schema:name "Scale factor"@en ;
  schema:description """Scale factor is the multiplier between similar shapes that describes how
  large one shape is compared to the other."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387285Z"^^xsd:dateTime .

oakcurric:keyword-invariant
  a curric:Keyword ;
  schema:name "Invariant"@en ;
  schema:description """A property of a shape is invariant if that property has not changed after
  the shape is transformed."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387291Z"^^xsd:dateTime .

oakcurric:keyword-programmer
  a curric:Keyword ;
  schema:name "programmer"@en ;
  schema:description "a person who writes computer programs"@en ;
  dcterms:modified "2026-06-07T15:30:02.387348Z"^^xsd:dateTime .

oakcurric:keyword-co-interior-angles
  a curric:Keyword ;
  schema:name "Co-interior angles"@en ;
  schema:description """Co-interior angles are on the same side of the transversal line and in
  between the two other lines."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387680Z"^^xsd:dateTime .

oakcurric:keyword-compound-shape
  a curric:Keyword ;
  schema:name "Compound shape"@en ;
  schema:description "A compound shape is a shape created using two or more basic shapes."@en ;
  dcterms:modified "2026-06-07T15:30:02.387719Z"^^xsd:dateTime .

oakcurric:keyword-composite-shape
  a curric:Keyword ;
  schema:name "Composite shape"@en ;
  schema:description "A composite shape is an alternative for a compound shape."@en ;
  dcterms:modified "2026-06-07T15:30:02.387724Z"^^xsd:dateTime .

oakcurric:keyword-rotational-symmetry
  a curric:Keyword ;
  schema:name "Rotational symmetry"@en ;
  schema:description """Rotational symmetry describes when a shape appears the same after some
  rotation. The order of rotational symmetry is the number of times the image appears the
  same as the object in one full turn."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387740Z"^^xsd:dateTime .

oakcurric:keyword-perpendicular-height
  a curric:Keyword ;
  schema:name "perpendicular height"@en ;
  schema:description """The perpendicular height is the perpendicular distance from the base to the
  opposite vertex."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389246Z"^^xsd:dateTime .

oakcurric:keyword-likelihood
  a curric:Keyword ;
  schema:name "Likelihood"@en ;
  schema:description "Likelihood describes the chance that a particular event will occur."@en ;
  dcterms:modified "2026-06-07T15:30:02.390114Z"^^xsd:dateTime .

oakcurric:keyword-trial
  a curric:Keyword ;
  schema:name "Trial"@en ;
  schema:description "A trial is a single predefined test."@en ;
  dcterms:modified "2026-06-07T15:30:02.390119Z"^^xsd:dateTime .

oakcurric:keyword-sample-space
  a curric:Keyword ;
  schema:name "Sample space"@en ;
  schema:description """A sample space is all the possible outcomes of a trial. A sample space
  diagram is a systematic way of producing a sample space."""@en ;
  dcterms:modified "2026-06-07T15:30:02.390126Z"^^xsd:dateTime .

oakcurric:keyword-perimeter
  a curric:Keyword ;
  schema:name "Perimeter"@en ;
  schema:description "Perimeter is the distance around a two-dimensional shape."@en ;
  dcterms:modified "2026-06-07T15:30:02.391093Z"^^xsd:dateTime .

oakcurric:keyword-composite
  a curric:Keyword ;
  schema:name "composite"@en ;
  schema:description """A material made from two or more different types of materials. When combined
  they create a new material with improved properties."""@en ;
  dcterms:modified "2026-06-07T15:30:02.392428Z"^^xsd:dateTime .

oakcurric:keyword-cylinder
  a curric:Keyword ;
  schema:name "cylinder"@en ;
  schema:description "a 3D shape with two circular faces connected by a rectangular section"@en ;
  dcterms:modified "2026-06-07T15:30:02.394198Z"^^xsd:dateTime .

oakcurric:keyword-percentage-profit
  a curric:Keyword ;
  schema:name "Percentage profit"@en ;
  schema:description """is the increase when referencing something that is sold for more than the
  cost price given as a percentage of the original amount"""@en ;
  dcterms:modified "2026-06-07T15:30:02.395073Z"^^xsd:dateTime .

oakcurric:keyword-percentage-loss
  a curric:Keyword ;
  schema:name "Percentage loss"@en ;
  schema:description """is the decrease when referencing something that is sold for less than the
  cost price given as a percentage of the original amount"""@en ;
  dcterms:modified "2026-06-07T15:30:02.395078Z"^^xsd:dateTime .

oakcurric:keyword-theoretical-probability
  a curric:Keyword ;
  schema:name "Theoretical probability"@en ;
  schema:description """A theoretical probability is a probability based on counting the number of
  desired outcomes from a sample space where all individual outcomes are equally likely."""@en ;
  dcterms:modified "2026-06-07T15:30:02.395530Z"^^xsd:dateTime .

oakcurric:keyword-bimodal
  a curric:Keyword ;
  schema:name "Bimodal"@en ;
  schema:description "Sets of data which have two modes are known as bimodal data"@en ;
  dcterms:modified "2026-06-07T15:30:02.396492Z"^^xsd:dateTime .

oakcurric:keyword-trimodal
  a curric:Keyword ;
  schema:name "Trimodal"@en ;
  schema:description "Trimodal data has three modes"@en ;
  dcterms:modified "2026-06-07T15:30:02.396497Z"^^xsd:dateTime .

oakcurric:keyword-graphic-designer
  a curric:Keyword ;
  schema:name "graphic designer"@en ;
  schema:description """a person who creates visual content, such as logos, advertisements, and
  websites, to communicate messages and ideas"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396627Z"^^xsd:dateTime .

oakcurric:keyword-prism
  a curric:Keyword ;
  schema:name "Prism"@en ;
  schema:description """a polyhedron with a base that is a polygon and a parallel opposite face that
  is identical joined by parallelograms."""@en ;
  dcterms:modified "2026-06-07T15:30:02.396831Z"^^xsd:dateTime .

oakcurric:keyword-radius
  a curric:Keyword ;
  schema:name "Radius"@en ;
  schema:description "any line segment that joins the centre of a circle to its circumference."@en ;
  dcterms:modified "2026-06-07T15:30:02.396836Z"^^xsd:dateTime .

oakcurric:keyword-spreaddispersion
  a curric:Keyword ;
  schema:name "Spread/Dispersion"@en ;
  schema:description """The spread/dispersion of data values describes how far apart the pieces of
  data are."""@en ;
  dcterms:modified "2026-06-07T15:30:02.396841Z"^^xsd:dateTime .

oakcurric:keyword-forced-perspective
  a curric:Keyword ;
  schema:name "Forced perspective"@en ;
  schema:description """Forced perspective is a technique that makes an object appear larger,
  smaller, farther or closer than it really is."""@en ;
  dcterms:modified "2026-06-07T15:30:02.396849Z"^^xsd:dateTime .

oakcurric:keyword-prime-factor
  a curric:Keyword ;
  schema:name "Prime factor"@en ;
  schema:description "A prime factor is a factor of a number that is a prime number."@en ;
  dcterms:modified "2026-06-07T15:30:02.396857Z"^^xsd:dateTime .

oakcurric:keyword-ray
  a curric:Keyword ;
  schema:name "ray"@en ;
  schema:description """A ray is a straight line drawn to represent the direction that a light wave
  travels."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397031Z"^^xsd:dateTime .

oakcurric:keyword-parallelogram
  a curric:Keyword ;
  schema:name "Parallelogram"@en ;
  schema:description """A parallelogram is a quadrilateral with two pairs of parallel and equal
  sides."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397264Z"^^xsd:dateTime .

oakcurric:keyword-rhombus
  a curric:Keyword ;
  schema:name "Rhombus"@en ;
  schema:description "A rhombus is parallelogram where all the sides are the same length."@en ;
  dcterms:modified "2026-06-07T15:30:02.397269Z"^^xsd:dateTime .

oakcurric:keyword-trapezium
  a curric:Keyword ;
  schema:name "Trapezium"@en ;
  schema:description "A trapezium is a quadrilateral with exactly one pair of parallel sides."@en ;
  dcterms:modified "2026-06-07T15:30:02.397274Z"^^xsd:dateTime .

oakcurric:keyword-equilateral-triangle
  a curric:Keyword ;
  schema:name "Equilateral triangle"@en ;
  schema:description """Equilateral triangles have three equal-sized angles and three edges of equal
  length. They are regular triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397281Z"^^xsd:dateTime .

oakcurric:keyword-isosceles-triangle
  a curric:Keyword ;
  schema:name "Isosceles triangle"@en ;
  schema:description """Isosceles triangles have two angles that are equal. That is also true for
  its side lengths: two sides are of equal length."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397291Z"^^xsd:dateTime .

oakcurric:keyword-translation
  a curric:Keyword ;
  schema:name "Translation"@en ;
  schema:description """Translation is a transformation in which every point of a shape moves the
  same distance in the same direction."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397298Z"^^xsd:dateTime .

oakcurric:keyword-proper
  a curric:Keyword ;
  schema:name "Proper"@en ;
  schema:description """A proper fraction is a fraction where the numerator is less than the
  denominator."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397580Z"^^xsd:dateTime .

oakcurric:keyword-improper
  a curric:Keyword ;
  schema:name "Improper"@en ;
  schema:description """An improper fraction is a fraction where the numerator is greater than or
  equal to the denominator."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397585Z"^^xsd:dateTime .

oakcurric:keyword-composite-rectilinear-shape
  a curric:Keyword ;
  schema:name "Composite rectilinear shape"@en ;
  schema:description "A composite rectilinear shape is a composite shape made from rectangles."@en ;
  dcterms:modified "2026-06-07T15:30:02.397590Z"^^xsd:dateTime .

oakcurric:keyword-enlargement
  a curric:Keyword ;
  schema:name "Enlargement"@en ;
  schema:description "Enlargement is a transformation that causes a change of size."@en ;
  dcterms:modified "2026-06-07T15:30:02.397622Z"^^xsd:dateTime .

oakcurric:keyword-centre-of-rotation
  a curric:Keyword ;
  schema:name "Centre of rotation"@en ;
  schema:description """The centre of rotation is the fixed point about which an object is
  rotated."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397632Z"^^xsd:dateTime .

oakcurric:keyword-exchange-rate
  a curric:Keyword ;
  schema:name "Exchange rate"@en ;
  schema:description """An exchange rate is the rate at which one currency is exchanged for
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397643Z"^^xsd:dateTime .

oakcurric:keyword-prime-factorisation
  a curric:Keyword ;
  schema:name "Prime factorisation"@en ;
  schema:description "a method to find the prime factors of a given integer"@en ;
  dcterms:modified "2026-06-07T15:30:02.397650Z"^^xsd:dateTime .

oakcurric:keyword-highest-common-factor
  a curric:Keyword ;
  schema:name "Highest common factor"@en ;
  schema:description """The highest common factor of two or more integers which can be divided by
  all other possible common factors"""@en ;
  dcterms:modified "2026-06-07T15:30:02.397660Z"^^xsd:dateTime .

oakcurric:keyword-hcf
  a curric:Keyword ;
  schema:name "HCF"@en ;
  schema:description "an abbreviation for highest common factor"@en ;
  dcterms:modified "2026-06-07T15:30:02.397666Z"^^xsd:dateTime .

oakcurric:keyword-line-segment
  a curric:Keyword ;
  schema:name "Line segment"@en ;
  schema:description """A line segment is a part of a line with a fixed start point and a distinct
  fixed end point."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397691Z"^^xsd:dateTime .

oakcurric:keyword-generalise
  a curric:Keyword ;
  schema:name "Generalise"@en ;
  schema:description """To generalise is to formulate a statement or rule that applies correctly to
  all relevant cases."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397699Z"^^xsd:dateTime .

oakcurric:keyword-equivalent-fractions
  a curric:Keyword ;
  schema:name "Equivalent fractions"@en ;
  schema:description "Two fractions are equivalent if they have the same value"@en ;
  dcterms:modified "2026-06-07T15:30:02.397704Z"^^xsd:dateTime .

oakcurric:keyword-terminating-decimals
  a curric:Keyword ;
  schema:name "Terminating decimals"@en ;
  schema:description """A terminating decimal is one that has a finite number of digits after the
  decimal point."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398158Z"^^xsd:dateTime .

oakcurric:keyword-arithmetic-sequence
  a curric:Keyword ;
  schema:name "Arithmetic sequence"@en ;
  schema:description """An arithmetic (or linear) sequence is a sequence where the difference
  between terms is a constant."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398163Z"^^xsd:dateTime .

oakcurric:keyword-trigonometric-functions
  a curric:Keyword ;
  schema:name "Trigonometric functions"@en ;
  schema:description """Trigonometric functions are commonly defined as ratios of two sides of a
  right-angled triangle for a given angle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398289Z"^^xsd:dateTime .

oakcurric:keyword-sine-function
  a curric:Keyword ;
  schema:name "Sine function"@en ;
  schema:description """The sine of an angle (sin(θ°)) is the y-coordinate of point P on the
  triangle formed inside the unit circle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398295Z"^^xsd:dateTime .

oakcurric:keyword-cosine-function
  a curric:Keyword ;
  schema:name "Cosine function"@en ;
  schema:description """The cosine of an angle (cos(θ°)) is the x-coordinate of point P on the
  triangle formed inside the unit circle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398300Z"^^xsd:dateTime .

oakcurric:keyword-tangent-function
  a curric:Keyword ;
  schema:name "Tangent function"@en ;
  schema:description """The tangent of an angle (tan(θ°)) is the y-coordinate of point Q on the
  triangle which extends from the unit circle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398305Z"^^xsd:dateTime .

oakcurric:keyword-cube-number
  a curric:Keyword ;
  schema:name "Cube number"@en ;
  schema:description "A cube number is the product of three repeated whole numbers."@en ;
  dcterms:modified "2026-06-07T15:30:02.398427Z"^^xsd:dateTime .

oakcurric:keyword-probability
  a curric:Keyword ;
  schema:name "Probability"@en ;
  schema:description """The probability that an event will occur is the proportion of times the
  event is expected to happen in a suitably large experiment."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398443Z"^^xsd:dateTime .

oakcurric:keyword-mutually-exclusive
  a curric:Keyword ;
  schema:name "Mutually exclusive"@en ;
  schema:description "Mutually exclusive events have no outcomes in common."@en ;
  dcterms:modified "2026-06-07T15:30:02.398458Z"^^xsd:dateTime .

oakcurric:keyword-outlier
  a curric:Keyword ;
  schema:name "Outlier"@en ;
  schema:description """An outlier is a data point that is extremely large or small compared to the
  rest of the dataset. Visually, outliers lie far away from where the majority of the
  results are clustered."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398526Z"^^xsd:dateTime .

oakcurric:keyword-direct-proportion
  a curric:Keyword ;
  schema:name "Direct proportion"@en ;
  schema:description """Two variables are in direct proportion if they have a constant
  multiplicative relationship"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398531Z"^^xsd:dateTime .

oakcurric:keyword-common-multiple
  a curric:Keyword ;
  schema:name "Common multiple"@en ;
  schema:description "A common multiple is a number that is a multiple of two or more numbers."@en ;
  dcterms:modified "2026-06-07T15:30:02.398536Z"^^xsd:dateTime .

oakcurric:keyword-time-series-graph
  a curric:Keyword ;
  schema:name "Time series graph"@en ;
  schema:description """Time series graphs show data over a time period. The time period is always
  shown on the x-axis. Data points are joined chronologically by line segments."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398546Z"^^xsd:dateTime .

oakcurric:keyword-transversal
  a curric:Keyword ;
  schema:name "Transversal"@en ;
  schema:description """A transversal is a line, line segment, or ray that intersects through two or
  more lines at distinct (different) points."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398621Z"^^xsd:dateTime .

oakcurric:keyword-corresponding-angles
  a curric:Keyword ;
  schema:name "Corresponding angles"@en ;
  schema:description """Corresponding angles are a pair of angles at different vertices on the same
  side of a transversal in equivalent positions."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398628Z"^^xsd:dateTime .

oakcurric:keyword-alternate-angles
  a curric:Keyword ;
  schema:name "Alternate angles"@en ;
  schema:description """Alternate angles are a pair of angles both between or both outside two line
  segments that are on opposite sides of the transversal that cuts them."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398634Z"^^xsd:dateTime .

oakcurric:keyword-supplementary-angles
  a curric:Keyword ;
  schema:name "Supplementary angles"@en ;
  schema:description "Supplementary angles are a pair of angles that sum to 180°."@en ;
  dcterms:modified "2026-06-07T15:30:02.398639Z"^^xsd:dateTime .

oakcurric:keyword-conjugate-angles
  a curric:Keyword ;
  schema:name "Conjugate angles"@en ;
  schema:description "Conjugate angles are a pair of angles that sum to 360°."@en ;
  dcterms:modified "2026-06-07T15:30:02.398647Z"^^xsd:dateTime .

oakcurric:keyword-equation-of-a-line
  a curric:Keyword ;
  schema:name "Equation of a line"@en ;
  schema:description "Any equation whose graph forms a straight line."@en ;
  dcterms:modified "2026-06-07T15:30:02.398839Z"^^xsd:dateTime .

oakcurric:keyword-coefficient
  a curric:Keyword ;
  schema:name "Coefficient"@en ;
  schema:description "A constant numerical multiplier of the variables in a term."@en ;
  dcterms:modified "2026-06-07T15:30:02.398845Z"^^xsd:dateTime .

oakcurric:keyword-trapeziumstrapezia
  a curric:Keyword ;
  schema:name "Trapeziums/trapezia"@en ;
  schema:description "The plural of trapezium can be referred to as trapezia or trapeziums."@en ;
  dcterms:modified "2026-06-07T15:30:02.398852Z"^^xsd:dateTime .

oakcurric:keyword-theoretical-probabilities
  a curric:Keyword ;
  schema:name "Theoretical probabilities"@en ;
  schema:description """A theoretical probability is a probability based on counting the number of
  desired outcomes from a sample space where all individual outcomes are equally likely."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398858Z"^^xsd:dateTime .

oakcurric:keyword-position-to-term
  a curric:Keyword ;
  schema:name "Position-to-term"@en ;
  schema:description """A position-to-term rule describes how to generate the term from the term
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398863Z"^^xsd:dateTime .

oakcurric:keyword-adjacent
  a curric:Keyword ;
  schema:name "Adjacent"@en ;
  schema:description """The adjacent side of a right-angled triangle is the side which is next to
  both the right angle and the marked angle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398868Z"^^xsd:dateTime .

oakcurric:keyword-trigonometric-ratios
  a curric:Keyword ;
  schema:name "Trigonometric ratios"@en ;
  schema:description """The trigonometric ratios are ratios between each pair of lengths in a
  right-angled triangle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.398873Z"^^xsd:dateTime .

oakcurric:keyword-subject-of-an-equationformula
  a curric:Keyword ;
  schema:name "Subject of an equation/formula"@en ;
  schema:description """The subject of an equation/a formula is a variable that is expressed in
  terms of other variables. It should have an exponent of 1 and a coefficient of 1"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398879Z"^^xsd:dateTime .

oakcurric:keyword-prime
  a curric:Keyword ;
  schema:name "Prime"@en ;
  schema:description "A prime number is an integer greater than one with exactly two factors."@en ;
  dcterms:modified "2026-06-07T15:30:02.399056Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change
  a curric:Keyword ;
  schema:name "Rate of change"@en ;
  schema:description """The rate of change is how quickly one variable changes in relation to
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399197Z"^^xsd:dateTime .

oakcurric:keyword-faces
  a curric:Keyword ;
  schema:name "Faces"@en ;
  schema:description "Faces are the flat 2D surfaces of a 3D shape."@en ;
  dcterms:modified "2026-06-07T15:30:02.399203Z"^^xsd:dateTime .

oakcurric:keyword-co-interior
  a curric:Keyword ;
  schema:name "Co-interior"@en ;
  schema:description """Co-interior angles are on the same side of the transversal line and in
  between the two other lines."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399219Z"^^xsd:dateTime .

oakcurric:keyword-substitute
  a curric:Keyword ;
  schema:name "Substitute"@en ;
  schema:description """Substitute means to put in place of another and it can be used to replace a
  fraction with another fraction of equal value."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399389Z"^^xsd:dateTime .

oakcurric:keyword-outcome-table
  a curric:Keyword ;
  schema:name "Outcome table"@en ;
  schema:description "An outcome table is a table that shows all the possible outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:02.399411Z"^^xsd:dateTime .

oakcurric:keyword-tree-diagram
  a curric:Keyword ;
  schema:name "Tree diagram"@en ;
  schema:description """Tree diagrams are a representation used to model statistical/probability
  questions. Branches represent different possible events or outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399416Z"^^xsd:dateTime .

oakcurric:keyword-outcome-tree
  a curric:Keyword ;
  schema:name "Outcome tree"@en ;
  schema:description """Each branch of an outcome tree shows a possible outcome from an event or
  from a stage of a trial. The full outcome tree shows all possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399428Z"^^xsd:dateTime .

oakcurric:keyword-pair-of-compasses
  a curric:Keyword ;
  schema:name "Pair of compasses"@en ;
  schema:description """A pair of compasses is a tool which can be used to draw circles and arcs. A
  pair of compasses is sometimes referred to just as a compass."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399435Z"^^xsd:dateTime .

oakcurric:keyword-equidistant
  a curric:Keyword ;
  schema:name "Equidistant"@en ;
  schema:description """Points A and B are equidistant from a third point C if the distance AC is
  equal to the distance BC."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399441Z"^^xsd:dateTime .

oakcurric:keyword-quadrant
  a curric:Keyword ;
  schema:name "Quadrant"@en ;
  schema:description """Any of the four areas made when a plane is divided by an x and y axis is
  called a quadrant."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399592Z"^^xsd:dateTime .

oakcurric:keyword-average
  a curric:Keyword ;
  schema:name "average"@en ;
  schema:description """An average is a number that is calculated by adding amounts together and
  then dividing the total by the number of quantities."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399605Z"^^xsd:dateTime .

oakcurric:keyword-percentage
  a curric:Keyword ;
  schema:name "Percentage"@en ;
  schema:description "A percentage is a proportion of a whole."@en ;
  dcterms:modified "2026-06-07T15:30:02.399613Z"^^xsd:dateTime .

oakcurric:keyword-bisect
  a curric:Keyword ;
  schema:name "Bisect"@en ;
  schema:description "To bisect means to cut or divide an object into two equal parts."@en ;
  dcterms:modified "2026-06-07T15:30:02.399629Z"^^xsd:dateTime .

oakcurric:keyword-associative-law
  a curric:Keyword ;
  schema:name "Associative law"@en ;
  schema:description """The associative law states that a repeated application of the operation
  produces the same result regardless of how pairs of values are grouped. We can group using
  brackets."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399635Z"^^xsd:dateTime .

oakcurric:keyword-median
  a curric:Keyword ;
  schema:name "Median"@en ;
  schema:description """The median is the central (middle) piece of data when the data are in
  numerical order. It is a measure of central tendency representing the average of the
  values."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399640Z"^^xsd:dateTime .

oakcurric:keyword-degrees
  a curric:Keyword ;
  schema:name "Degrees"@en ;
  schema:description "A degree is a unit of measure for angles."@en ;
  dcterms:modified "2026-06-07T15:30:02.399816Z"^^xsd:dateTime .

oakcurric:keyword-composite-number
  a curric:Keyword ;
  schema:name "Composite number"@en ;
  schema:description """A composite number is an integer with more than two factors. All integers
  greater than 1 are either composite or prime."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399822Z"^^xsd:dateTime .

oakcurric:keyword-probability-tree
  a curric:Keyword ;
  schema:name "Probability tree"@en ;
  schema:description """Each branch of a probability tree shows a possible outcome from an event or
  from a stage of a trial, along with the probability of that outcome happening."""@en ;
  dcterms:modified "2026-06-07T15:30:02.399830Z"^^xsd:dateTime .

oakcurric:keyword-front-elevation
  a curric:Keyword ;
  schema:name "Front elevation"@en ;
  schema:description "The front elevation of a solid is the view of it from the front."@en ;
  dcterms:modified "2026-06-07T15:30:02.400014Z"^^xsd:dateTime .

oakcurric:keyword-side-elevation
  a curric:Keyword ;
  schema:name "Side elevation"@en ;
  schema:description "The side elevation of a solid is the view of it from the side."@en ;
  dcterms:modified "2026-06-07T15:30:02.400021Z"^^xsd:dateTime .

oakcurric:keyword-equilateral
  a curric:Keyword ;
  schema:name "Equilateral"@en ;
  schema:description """Equilateral triangles have three equal-sized angles and three edges of equal
  length. They are regular triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400234Z"^^xsd:dateTime .

oakcurric:keyword-scalene
  a curric:Keyword ;
  schema:name "Scalene"@en ;
  schema:description """Scalene triangles have three different-sized angles and three
  different-sized edges (sides)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400240Z"^^xsd:dateTime .

oakcurric:keyword-isosceles
  a curric:Keyword ;
  schema:name "Isosceles"@en ;
  schema:description """Isosceles triangles have two equal-sized angles and two sides of the same
  length."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400245Z"^^xsd:dateTime .

oakcurric:keyword-logistics
  a curric:Keyword ;
  schema:name "Logistics"@en ;
  schema:description """Logistics is the careful organisation of a complicated project (set of
  activities) so that it happens in a successful and effective way."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400251Z"^^xsd:dateTime .

oakcurric:keyword-numerical-factor
  a curric:Keyword ;
  schema:name "Numerical factor"@en ;
  schema:description "A numerical factor is a factor that is an integer."@en ;
  dcterms:modified "2026-06-07T15:30:02.400259Z"^^xsd:dateTime .

oakcurric:keyword-cube
  a curric:Keyword ;
  schema:name "Cube"@en ;
  schema:description "A cube number is the product of three repeated integers."@en ;
  dcterms:modified "2026-06-07T15:30:02.400265Z"^^xsd:dateTime .

oakcurric:keyword-nth-term
  a curric:Keyword ;
  schema:name "n^th term"@en ;
  schema:description """The nth term of a sequence is the position of a term in a sequence where n
  stands for the term number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400270Z"^^xsd:dateTime .

oakcurric:keyword-quadratic
  a curric:Keyword ;
  schema:name "Quadratic"@en ;
  schema:description """A quadratic is an equation, graph, or sequence whereby the highest exponent
  of the variable is 2; the graph of which forms a parabola."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400284Z"^^xsd:dateTime .

oakcurric:keyword-square-number
  a curric:Keyword ;
  schema:name "Square number"@en ;
  schema:description """A square number is the result of multiplying a whole number (not a fraction)
  by itself."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400397Z"^^xsd:dateTime .

oakcurric:keyword-prime-number
  a curric:Keyword ;
  schema:name "prime number"@en ;
  schema:description """A prime number is a whole number greater than one which has exactly two
  factors."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400408Z"^^xsd:dateTime .

oakcurric:keyword-parabola
  a curric:Keyword ;
  schema:name "Parabola"@en ;
  schema:description """A parabola is a curve where any point on the curve is an equal distance from
  a fixed point (the focus) and a fixed straight line (the directrix)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400413Z"^^xsd:dateTime .

oakcurric:keyword-statistical-summary
  a curric:Keyword ;
  schema:name "statistical summary"@en ;
  schema:description "A statistical summary sums up the features of a data set."@en ;
  dcterms:modified "2026-06-07T15:30:02.400418Z"^^xsd:dateTime .

oakcurric:keyword-spread
  a curric:Keyword ;
  schema:name "spread"@en ;
  schema:description """The spread/dispersion of data values describes how far apart the pieces of
  data are."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400424Z"^^xsd:dateTime .

oakcurric:keyword-central-tendency
  a curric:Keyword ;
  schema:name "central tendency"@en ;
  schema:description """a summary measure that attempts to describe a whole set of data with a
  single value that represents the middle or centre of its distribution"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400429Z"^^xsd:dateTime .

oakcurric:keyword-significant-figure
  a curric:Keyword ;
  schema:name "significant figure"@en ;
  schema:description "a person who has done something important that influenced the world"@en ;
  dcterms:modified "2026-06-07T15:30:02.400481Z"^^xsd:dateTime .

oakcurric:keyword-fixed-point
  a curric:Keyword ;
  schema:name "Fixed point"@en ;
  schema:description "A point that does not change or move."@en ;
  dcterms:modified "2026-06-07T15:30:02.400630Z"^^xsd:dateTime .

oakcurric:keyword-single-transferable-vote-stv
  a curric:Keyword ;
  schema:name "Single Transferable Vote (STV)"@en ;
  schema:description """With the Single Transferable Vote (STV) , the opinions in parliament match
  the strength of support in the country."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400649Z"^^xsd:dateTime .

oakcurric:keyword-alternative-vote-av
  a curric:Keyword ;
  schema:name "Alternative vote (AV)"@en ;
  schema:description """With the Alternative Vote (AV), your constituency gets an MP the majority
  support."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400655Z"^^xsd:dateTime .

oakcurric:keyword-vertical-angles
  a curric:Keyword ;
  schema:name "Vertical angles"@en ;
  schema:description """Vertical angles are pairs of opposite angles formed when two lines intersect
  at a point. They are equal."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400793Z"^^xsd:dateTime .

oakcurric:keyword-diameter
  a curric:Keyword ;
  schema:name "Diameter"@en ;
  schema:description """The diameter of a circle is any line segment that starts and ends on the
  edge of the circle and passes through the centre."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400799Z"^^xsd:dateTime .

oakcurric:keyword-inverse-proportion
  a curric:Keyword ;
  schema:name "Inverse proportion"@en ;
  schema:description """Two variables are inversely proportional if there is a constant
  multiplicative relationship between one variable and the reciprocal of the other."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400828Z"^^xsd:dateTime .

oakcurric:keyword-lowest-common-multiple
  a curric:Keyword ;
  schema:name "Lowest common multiple"@en ;
  schema:description """The lowest common multiple is the lowest number that is a multiple of two or
  more numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400857Z"^^xsd:dateTime .

oakcurric:keyword-centre-of-enlargement
  a curric:Keyword ;
  schema:name "Centre of enlargement"@en ;
  schema:description "The centre of enlargement is the point from which a shape is enlarged."@en ;
  dcterms:modified "2026-06-07T15:30:02.401002Z"^^xsd:dateTime .

oakcurric:keyword-circumference
  a curric:Keyword ;
  schema:name "Circumference"@en ;
  schema:description "The circumference of a circle is the perimeter of the circle."@en ;
  dcterms:modified "2026-06-07T15:30:02.401742Z"^^xsd:dateTime .

oakcurric:keyword-divisibility
  a curric:Keyword ;
  schema:name "Divisibility"@en ;
  schema:description """Divisibility is when division of a number results in another whole
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.401915Z"^^xsd:dateTime .

oakcurric:keyword-scalene-triangle
  a curric:Keyword ;
  schema:name "Scalene triangle"@en ;
  schema:description "Scalene triangles have no equal sides and no equal angles."@en ;
  dcterms:modified "2026-06-07T15:30:02.401980Z"^^xsd:dateTime .

oakcurric:keyword-arithmeticlinear-sequence
  a curric:Keyword ;
  schema:name "Arithmetic/linear sequence"@en ;
  schema:description """An arithmetic (or linear) sequence is a sequence where the difference
  between successive terms is constant."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402039Z"^^xsd:dateTime .

oakcurric:keyword-triangular
  a curric:Keyword ;
  schema:name "Triangular"@en ;
  schema:description """A triangular number is a number that can be represented by a pattern of dots
  arranged into an equilateral triangle. The term number is the number of dots in a side of
  the triangle"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402044Z"^^xsd:dateTime .

oakcurric:keyword-truncate
  a curric:Keyword ;
  schema:name "Truncate"@en ;
  schema:description """Simplifying a number by 'cutting off' one or more of the digits and
  replacing them with zeros if necessary to preserve place value."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402186Z"^^xsd:dateTime .

oakcurric:keyword-commute
  a curric:Keyword ;
  schema:name "Commute"@en ;
  schema:description """A commute is a regular journey made between a person’s home and their place
  of work."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402191Z"^^xsd:dateTime .

oakcurric:keyword-statstical-summary
  a curric:Keyword ;
  schema:name "Statstical Summary"@en ;
  schema:description """A statistical summary sums up the features of a data set. It may contain the
  mean, median and/or mode which measure the central tendency. It may also contain the range
  which measures the spread."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402213Z"^^xsd:dateTime .

oakcurric:keyword-exponent
  a curric:Keyword ;
  schema:name "Exponent"@en ;
  schema:description """An exponent is a number positioned above and to the right of a base value.
  It indicates repeated multiplication."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402323Z"^^xsd:dateTime .

oakcurric:keyword-tree-diagrams
  a curric:Keyword ;
  schema:name "Tree diagrams"@en ;
  schema:description """Tree diagrams are a representation used to model statistical/probability
  questions. Branches represent different possible events or outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402521Z"^^xsd:dateTime .

oakcurric:keyword-trapeziatrapeziums
  a curric:Keyword ;
  schema:name "Trapezia/trapeziums"@en ;
  schema:description "The plural of trapezium can be referred to as trapezia or trapeziums."@en ;
  dcterms:modified "2026-06-07T15:30:02.402608Z"^^xsd:dateTime .

oakcurric:keyword-binomial
  a curric:Keyword ;
  schema:name "Binomial"@en ;
  schema:description """A binomial is an algebraic expression representing the sum of exactly two
  unlike terms."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402832Z"^^xsd:dateTime .

oakcurric:keyword-conjecture
  a curric:Keyword ;
  schema:name "Conjecture"@en ;
  schema:description """A conjecture is a (mathematical) statement that is thought to be true but
  has not been proved yet."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402843Z"^^xsd:dateTime .

oakcurric:keyword-regular
  a curric:Keyword ;
  schema:name "Regular"@en ;
  schema:description "A regular polygon has all sides equal and all angles equal."@en ;
  dcterms:modified "2026-06-07T15:30:02.402946Z"^^xsd:dateTime .

oakcurric:keyword-factorise
  a curric:Keyword ;
  schema:name "Factorise"@en ;
  schema:description """A ratio shows the relative sizes of 2 or more values and allows you to
  compare a part with another part in a whole."""@en ;
  dcterms:modified "2026-06-07T15:30:02.402959Z"^^xsd:dateTime .

oakcurric:keyword-rhombi
  a curric:Keyword ;
  schema:name "Rhombi"@en ;
  schema:description "The plural of rhombus can be referred to as rhombi."@en ;
  dcterms:modified "2026-06-07T15:30:02.403470Z"^^xsd:dateTime .

oakcurric:keyword-triangular-number
  a curric:Keyword ;
  schema:name "Triangular number"@en ;
  schema:description """A triangular number is a number that can be represented by a pattern of dots
  arranged into an equilateral triangle. The term number is the number of dots in a side of
  the triangle"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403477Z"^^xsd:dateTime .

oakcurric:keyword-simultaneous-equations
  a curric:Keyword ;
  schema:name "Simultaneous equations"@en ;
  schema:description """Equations which represent different relationships between the same variables
  are called simultaneous equations."""@en ;
  dcterms:modified "2026-06-07T15:30:02.403667Z"^^xsd:dateTime .

oakcurric:keyword-prime-factors
  a curric:Keyword ;
  schema:name "Prime factors"@en ;
  schema:description "Prime factors are the factors of a number that are, themselves, prime."@en ;
  dcterms:modified "2026-06-07T15:30:02.403970Z"^^xsd:dateTime .

oakcurric:keyword-recurring-decimals
  a curric:Keyword ;
  schema:name "Recurring decimals"@en ;
  schema:description """A recurring decimal is one that has an infinite number of digits after the
  decimal point"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403975Z"^^xsd:dateTime .

oakcurric:keyword-lcm
  a curric:Keyword ;
  schema:name "LCM"@en ;
  schema:description "LCM is an abbreviation for lowest common multiple."@en ;
  dcterms:modified "2026-06-07T15:30:02.403980Z"^^xsd:dateTime .

oakcurric:keyword-impossible
  a curric:Keyword ;
  schema:name "Impossible"@en ;
  schema:description "An outcome is impossible if there is no possibility that it can happen."@en ;
  dcterms:modified "2026-06-07T15:30:02.404325Z"^^xsd:dateTime .

oakcurric:keyword-certain
  a curric:Keyword ;
  schema:name "Certain"@en ;
  schema:description "An outcome is certain if it is guaranteed to happen."@en ;
  dcterms:modified "2026-06-07T15:30:02.404333Z"^^xsd:dateTime .

oakcurric:keyword-even-chance
  a curric:Keyword ;
  schema:name "Even chance"@en ;
  schema:description """An outcome has even chance if its likelihood of happening is the same as its
  likelihood of not happening."""@en ;
  dcterms:modified "2026-06-07T15:30:02.404341Z"^^xsd:dateTime .

oakcurric:keyword-compoundcomposite-shape
  a curric:Keyword ;
  schema:name "compound/composite shape"@en ;
  schema:description "a shape created using two or more basic shapes"@en ;
  dcterms:modified "2026-06-07T15:30:02.404453Z"^^xsd:dateTime .

oakcurric:keyword-dispersion
  a curric:Keyword ;
  schema:name "Dispersion"@en ;
  schema:description """The spread/dispersion of data values describes how far apart the pieces of
  data are."""@en ;
  dcterms:modified "2026-06-07T15:30:02.405047Z"^^xsd:dateTime .

oakcurric:keyword-exterior-angles
  a curric:Keyword ;
  schema:name "Exterior angles"@en ;
  schema:description """An exterior angle is an angle on the outside of a polygon between an
  extension of an edge and its adjacent edge."""@en ;
  dcterms:modified "2026-06-07T15:30:02.405331Z"^^xsd:dateTime .

oakcurric:keyword-fractional-form
  a curric:Keyword ;
  schema:name "Fractional form"@en ;
  schema:description """A number is in fractional form when it is displayed as one integer divided
  by another integer."""@en ;
  dcterms:modified "2026-06-07T15:30:02.405339Z"^^xsd:dateTime .

oakcurric:keyword-measure-of-central-tendency
  a curric:Keyword ;
  schema:name "Measure of central tendency"@en ;
  schema:description """A summary that attempts to describe a whole set of data with a single value
  that represents the middle of the distribution."""@en ;
  dcterms:modified "2026-06-07T15:30:02.405346Z"^^xsd:dateTime .

oakcurric:keyword-trigonometric-function
  a curric:Keyword ;
  schema:name "Trigonometric function"@en ;
  schema:description """Trigonometric functions are commonly defined as ratios of two sides of a
  right-angled triangle for a given angle."""@en ;
  dcterms:modified "2026-06-07T15:30:02.405352Z"^^xsd:dateTime .

oakcurric:keyword-vertically-opposite-angles
  a curric:Keyword ;
  schema:name "Vertically opposite angles"@en ;
  schema:description """Vertical angles are pairs of opposite angles formed when two lines intersect
  at a point. They are equal."""@en ;
  dcterms:modified "2026-06-07T15:30:02.407560Z"^^xsd:dateTime .

oakcurric:keyword-arithmetic-linear-sequence
  a curric:Keyword ;
  schema:name "Arithmetic (linear) sequence"@en ;
  schema:description "A sequence where the difference between successive terms is a constant."@en ;
  dcterms:modified "2026-06-07T15:30:02.407681Z"^^xsd:dateTime .

oakcurric:keyword-error-interval
  a curric:Keyword ;
  schema:name "Error interval"@en ;
  schema:description """An error interval for a number $$x$$ shows the range of possible values of
  $$x$$. It is written as an inequality $$a ≤ x < b$$"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407857Z"^^xsd:dateTime .

oakcurric:keyword-independentexplanatory
  a curric:Keyword ;
  schema:name "Independent/Explanatory"@en ;
  schema:description """An independent (explanatory) variable is a measure that is predicted to have
  an effect on another variable"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407863Z"^^xsd:dateTime .

oakcurric:keyword-dependentresponse
  a curric:Keyword ;
  schema:name "Dependent/Response"@en ;
  schema:description """A dependent (response) variable is a measure whose value is predicted to be
  affected by an explanatory variable"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407868Z"^^xsd:dateTime .

oakcurric:keyword-degree-of-accuracy
  a curric:Keyword ;
  schema:name "Degree of accuracy"@en ;
  schema:description "A degree of accuracy shows how precise a number or measurement is."@en ;
  dcterms:modified "2026-06-07T15:30:02.408024Z"^^xsd:dateTime .

oakcurric:keyword-supplementary-angle
  a curric:Keyword ;
  schema:name "Supplementary angle"@en ;
  schema:description "a pair of angles that sum to 180°."@en ;
  dcterms:modified "2026-06-07T15:30:02.408257Z"^^xsd:dateTime .

oakcurric:keyword-product-of-primes
  a curric:Keyword ;
  schema:name "Product of primes"@en ;
  schema:description """Expressing a number as a product of primes means writing it uniquely as a
  product of its factors that are prime numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:02.410901Z"^^xsd:dateTime .

oakcurric:keyword-factorising
  a curric:Keyword ;
  schema:name "Factorising"@en ;
  schema:description "Factorising means to express a term as the product of its factors."@en ;
  dcterms:modified "2026-06-07T15:30:02.411701Z"^^xsd:dateTime .

oakcurric:keyword-perfect-square
  a curric:Keyword ;
  schema:name "Perfect square"@en ;
  schema:description "A perfect square is the same as a square number."@en ;
  dcterms:modified "2026-06-07T15:30:02.411707Z"^^xsd:dateTime .

oakcurric:keyword-perfect-cube
  a curric:Keyword ;
  schema:name "Perfect cube"@en ;
  schema:description "A perfect cube is the same as a cube number."@en ;
  dcterms:modified "2026-06-07T15:30:02.411712Z"^^xsd:dateTime .

oakcurric:keyword-astrophysicist
  a curric:Keyword ;
  schema:name "Astrophysicist"@en ;
  schema:description """An astrophysicist tries to understand the universe and its contents by
  applying the laws of physics."""@en ;
  dcterms:modified "2026-06-07T15:30:02.412784Z"^^xsd:dateTime .

oakcurric:keyword-distributive
  a curric:Keyword ;
  schema:name "Distributive"@en ;
  schema:description """The distributive law says that multiplying a sum is the same as multiplying
  each addend and summing the result."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417029Z"^^xsd:dateTime .

oakcurric:keyword-terminating-decimal
  a curric:Keyword ;
  schema:name "Terminating decimal"@en ;
  schema:description """A terminating decimal is one that has a finite number of digits after the
  decimal point.. E.g. 92.2, 193.3894, non-example: $$1.\\\\dot9$$."""@en ;
  dcterms:modified "2026-06-07T15:30:02.418808Z"^^xsd:dateTime .

oakcurric:keyword-overestimate
  a curric:Keyword ;
  schema:name "Overestimate"@en ;
  schema:description "An estimate for a calculation which is greater than the exact answer."@en ;
  dcterms:modified "2026-06-07T15:30:02.423586Z"^^xsd:dateTime .

oakcurric:keyword-underestimate
  a curric:Keyword ;
  schema:name "Underestimate"@en ;
  schema:description "An estimate for a calculation which is less than the exact answer."@en ;
  dcterms:modified "2026-06-07T15:30:02.423591Z"^^xsd:dateTime .

oakcurric:keyword-a-degree-of-accuracy
  a curric:Keyword ;
  schema:name "A degree of accuracy"@en ;
  schema:description "A degree of accuracy shows how precise a number or measurement is."@en ;
  dcterms:modified "2026-06-07T15:30:02.424170Z"^^xsd:dateTime .

oakcurric:keyword-recurring-decimal
  a curric:Keyword ;
  schema:name "Recurring decimal"@en ;
  schema:description """A recurring decimal is one that has an infinite number of digits after the
  decimal point."""@en ;
  dcterms:modified "2026-06-07T15:30:02.424999Z"^^xsd:dateTime .

oakcurric:keyword-term-to-term
  a curric:Keyword ;
  schema:name "Term-to-term"@en ;
  schema:description """A term-to-term rule describes how to calculate the next term in the sequence
  from the previous term."""@en ;
  dcterms:modified "2026-06-07T15:30:02.425226Z"^^xsd:dateTime .

oakcurric:keyword-fully-factorise
  a curric:Keyword ;
  schema:name "Fully factorise"@en ;
  schema:description """To fully factorise is to factorise to the point that remaining term or terms
  cannot be factorised any further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.425402Z"^^xsd:dateTime .

oakcurric:keyword-lowest-common-multiple-lcm
  a curric:Keyword ;
  schema:name "Lowest common multiple (LCM)"@en ;
  schema:description """The lowest common multiple is the lowest number that is a multiple of two or
  more numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:02.427811Z"^^xsd:dateTime .

oakcurric:keyword-highest-common-factor-hcf
  a curric:Keyword ;
  schema:name "Highest common factor (HCF)"@en ;
  schema:description """The highest common factor of two or more integers which can be divided by
  all other possible common factors."""@en ;
  dcterms:modified "2026-06-07T15:30:02.427816Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-using-multiplication-repeated-addition-leads
  a curric:Misconception ;
  curric:statement """Using multiplication as repeated addition leads to incorrect additive
  strategies of ratios."""@en ;
  curric:correction """Focus on the multiplicative relationships between parts to whole or whole to
  parts. Ratio tables can help see this more easily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085127Z"^^xsd:dateTime .

oakcurric:misconception-minus-minus-make-plus-2
  a curric:Misconception ;
  curric:statement """Minus and a minus make a plus, 2 negatives make a positive, double negative
  makes a positive, etc."""@en ;
  curric:correction """The use of additive inverses should avoid this common misconception. Be aware
  that pupils maybe already be familiar with this statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085784Z"^^xsd:dateTime .

oakcurric:misconception-assumption-calculator-gives-answer-correct
  a curric:Misconception ;
  curric:statement """The assumption that if the calculator gives an answer then it must be
  correct!"""@en ;
  curric:correction """It is really important to encourage pupils to both check calculator inputs
  carefully and consider the reasonableness of their answers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088557Z"^^xsd:dateTime .

oakcurric:misconception-kilo-gram-1000-bigger-gram
  a curric:Misconception ;
  curric:statement "Kilo gram is 1000 bigger than a gram, so 40 g = 1000 x 40 kg"@en ;
  curric:correction "Kilo gram is 1000 bigger than a gram so 1 kg = 1000 g."@en ;
  dcterms:modified "2026-06-07T15:30:15.089497Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-inputting-mixed-number-scientific
  a curric:Misconception ;
  curric:statement "Incorrectly inputting a mixed number into the scientific calculator."@en ;
  curric:correction """A mixed number has it's own separate button. Incorrectly inputting in the
  mixed number will return brackets on the calculator screen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089834Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-assign-correct-variable
  a curric:Misconception ;
  curric:statement """Pupils may struggle to assign the correct variable to the y-axis when graphing
  on a spreadsheet."""@en ;
  curric:correction """Explain that the word \"series\" is used to mean the y-axis in this
  software."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090226Z"^^xsd:dateTime .

oakcurric:misconception-1-necessary-put-function-2
  a curric:Misconception ;
  curric:statement """1) = not necessary to put into function, 2) students type in number to
  calculate, not click the cell"""@en ;
  curric:correction """1) the = at the start tells the spreadsheet to start a calculation, 2)
  clicking the cell means if input data chances, outputs auto-update"""@en ;
  dcterms:modified "2026-06-07T15:30:15.090575Z"^^xsd:dateTime .

oakcurric:misconception-division-0-5-same-doubling
  a curric:Misconception ;
  curric:statement "Division by 0.5 is the same as doubling."@en ;
  curric:correction """Reiterate the division of a number is the same as the multiplication of the
  reciprocal e.g The division of 0.5 is the same as multiplying by 2. e.g The division of
  0.1 is the same as multiplying by 10."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090883Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-bar-model-fraction
  a curric:Misconception ;
  curric:statement """Pupils see the bar model and/or fraction as the whole as opposed to the
  proportion of the whole."""@en ;
  curric:correction """Emphasise equivalent fractions and equivalent bar models which show different
  parts to whole, but are the same proportion. e.g 3/5 = 60/100"""@en ;
  dcterms:modified "2026-06-07T15:30:15.091650Z"^^xsd:dateTime .

oakcurric:misconception-temperature-tells-us-hot-feel
  a curric:Misconception ;
  curric:statement "The temperature tells us how hot it will feel."@en ;
  curric:correction """The temperature given in a weather report is normally the air temperature.
  The 'feel like' temperature may be different depending on multiple factors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092016Z"^^xsd:dateTime .

oakcurric:misconception-question-right-angled-triangle-use
  a curric:Misconception ;
  curric:statement """Every question that has a right-angled triangle must use Pythagoras' theorem
  to be solved."""@en ;
  curric:correction """It is easy to get into a habit of using Pythagoras' theorem when learning the
  topic, but it is likely you have seen several maths problems in the past with right-angled
  triangles, which ask to find areas and angles, without using Pythagoras' theorem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092314Z"^^xsd:dateTime .

oakcurric:misconception-difference-3-9-6-12
  a curric:Misconception ;
  curric:statement "That the difference between 3 & -9 is 6 and not 12."@en ;
  curric:correction """In the early stages of the negative numbers work the use of number lines to
  highlight misconceptions can be very powerful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092348Z"^^xsd:dateTime .

oakcurric:misconception-need-start-axis-scatter-graph
  a curric:Misconception ;
  curric:statement "You always need to start the axis of a scatter graph at (0,0)."@en ;
  curric:correction """The axis of a scatter graph should use a scale that makes the points as clear
  to see as possible, without distorting the shape of the data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097746Z"^^xsd:dateTime .

oakcurric:misconception-pupils-solve-angle-problems-using
  a curric:Misconception ;
  curric:statement """Pupils may solve angle problems by using methods which are less efficient than
  others."""@en ;
  curric:correction """While less efficient methods are fine, encourage pupils to review their work
  each time they solve a problem to consider alternative methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109556Z"^^xsd:dateTime .

oakcurric:misconception-addition-make-result-bigger
  a curric:Misconception ;
  curric:statement "That addition will always make the result bigger."@en ;
  curric:correction """If pupils are struggling with the concept that adding can make an integer
  smaller encourage them to use counters and form zero pairs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110625Z"^^xsd:dateTime .

oakcurric:misconception-object-rotated-orientation-stays-same
  a curric:Misconception ;
  curric:statement """After an object has been rotated, the orientation stays the same if the image
  looks the same."""@en ;
  curric:correction """This is only true if the object is rotated through 360°. Otherwise, the
  orientation is different as each vertex is in a different position."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110971Z"^^xsd:dateTime .

oakcurric:misconception-method-finding-length-shorter-side
  a curric:Misconception ;
  curric:statement """The method for finding the length of a shorter side of a right-angled triangle
  using Pythagoras' theorem is exactly the same as when finding the hypotenuse."""@en ;
  curric:correction """Whilst the initial setup of \"the sum of the squares of the two shorter sides
  equals the square of the hypotenuse\" will be the same, finding the length of a shorter
  side will require an extra step of rearranging terms in the equation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113303Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-know-actual
  a curric:Misconception ;
  curric:statement """Pupils may think they need to know the actual size or length to be able to
  prove congruence."""@en ;
  curric:correction """Remind pupils that if they can show that the corresponding angles or sides
  are the same length, then that is all that is needed. For example, if the corresponding
  edges are both edges of the same regular polygon, then they will be the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113466Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-sides-fix-angles
  a curric:Misconception ;
  curric:statement """Pupils may believe that as the sides fix the angles, that this implies it is
  true conversely."""@en ;
  curric:correction """Use any regular polygon to highlight that the angles will always be the same,
  but the edge lengths are not always the same length. Regular polygons are always similar
  but not necessarily congruent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113949Z"^^xsd:dateTime .

oakcurric:misconception-pair-similar-shapes-same-orientation
  a curric:Misconception ;
  curric:statement """When a pair of similar shapes are not in the same orientation, pupils may
  select an incorrect pair of lengths to calculate the scale factor."""@en ;
  curric:correction """Encourage pupils to take a systematic approach to locating pairs of
  corresponding lengths by looking for the longest edge in each shape, then the second
  longest, third longest, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114118Z"^^xsd:dateTime .

oakcurric:misconception-use-pythagoras-theorem-find-length
  a curric:Misconception ;
  curric:statement """I can only use Pythagoras' theorem to find the length of a side of a
  right-angled triangle when the right-angle marker is labelled, so I know which side is the
  hypotenuse."""@en ;
  curric:correction """The right-angle marker doesn't need to be explicitly labelled in order to be
  able to identify the right-angle. You can use knowledge of \"interior angles in a triangle
  sum to 180°\" to find the right angle, given two other angles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114124Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-match-corresponding
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to match up corresponding measurements on two
  congruent shapes when they are in different orientations."""@en ;
  curric:correction """Look lengths which are between any pairs of known angles or look for angles
  which are between pairs of adjacent known lengths. Also, tracing paper could be used to
  reflect/rotate/translate one shape onto the other."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114174Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-spot-congruent-triangles
  a curric:Misconception ;
  curric:statement "Pupils may struggle to spot congruent triangles if they only look for ASA."@en ;
  curric:correction """Encourage pupils to add any further information to diagrams, like the third
  angle, before starting to prove congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114578Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-enough-information-shape
  a curric:Misconception ;
  curric:statement """Pupils may think that they do not have enough information about a shape to
  determine whether it is congruent to another shape, when in fact they do."""@en ;
  curric:correction """Pupils could attempt the draw the shape based on the information that they
  have. They can then consider whether there are multiple way that the shape can be drawn
  while still satisfying all the given information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114592Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-meanings-congruence-similarity
  a curric:Misconception ;
  curric:statement """Pupils may mix up the meanings of congruence and similarity or struggle with
  the hierarchy of their nested sets (e.g. thinking that all similar shapes are congruent
  rather than the other way around)."""@en ;
  curric:correction """Frequently refer to a Venn diagram showing the set of congruence shapes
  inside the set of similar shapes when examining pairs of shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114677Z"^^xsd:dateTime .

oakcurric:misconception-rotating-shape-count-its-order
  a curric:Misconception ;
  curric:statement """When rotating a shape to count its order of rotational symmetry, pupils may
  count the starting position twice: once at the start and then again at the end of the full
  turn."""@en ;
  curric:correction """Encourage pupils to be consistent with when they count the starting position,
  either always counting it before they begin rotating the shape or always counting it at
  the end of the full turn."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114683Z"^^xsd:dateTime .

oakcurric:misconception-outcomes-trial-equally-likely-occur
  a curric:Misconception ;
  curric:statement """The outcomes of a trial are always equally likely to occur (e.g. each of the
  two players in a tennis match are equally likely to win)."""@en ;
  curric:correction """There are factors that may affect how likely one outcome is compared to
  another (e.g. the skill or experience of one tennis player compared to the other)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114903Z"^^xsd:dateTime .

oakcurric:misconception-pythagoras-theorem-relationship-three-sides
  a curric:Misconception ;
  curric:statement """Pythagoras' theorem is just a relationship between the three sides of a
  right-angled triangle."""@en ;
  curric:correction """Whilst this is true, Pythagoras' theorem can more visually be represented as
  three squares whose sides are equal in length to the three sides of the triangle. The sum
  of the areas of the two smaller squares is equal to the area of the larger square."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114968Z"^^xsd:dateTime .

oakcurric:misconception-pythagorean-triples-trio-rational-numbers
  a curric:Misconception ;
  curric:statement """Pythagorean triples can be a trio of any rational numbers that, when
  constructed into a triangle, always produces a right-angled triangle."""@en ;
  curric:correction """Pythagorean triples are conventionally a trio of integer side lengths of a
  right-angled triangle, such as the 3, 4, 5 triangle. Other, similar triangles can be
  generated from Pythagorean triples, whose side lengths are rational, such as 0.3, 0.4, 0.5"""@en ;
  dcterms:modified "2026-06-07T15:30:15.115443Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-assumptions-diagrams-containing
  a curric:Misconception ;
  curric:statement """Pupils may make assumptions about diagrams containing a right angle
  incorrectly."""@en ;
  curric:correction """Remind pupils, that they cannot assume there is a right angle, just because
  it may look like the two edges are perpendicular to each other."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115479Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-angle-doesnt-need
  a curric:Misconception ;
  curric:statement """Pupils may believe that the angle doesn't need to be in between the two known
  sides."""@en ;
  curric:correction """Use the Geogebra files to demonstrate that more than one triangle can be
  formed at times, and therefore it does not guarantee congruence between two triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115546Z"^^xsd:dateTime .

oakcurric:misconception-need-given-triangle-order-use
  a curric:Misconception ;
  curric:statement "I need to be given a triangle in order to use Pythagoras' theorem."@en ;
  curric:correction """You do not need to be given a triangle. It is an important skill to be able
  to sketch and label a triangle for yourself from given information, or go straight into an
  algebraic stage of calculation if aware that lengths given are perpendicular."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115575Z"^^xsd:dateTime .

oakcurric:misconception-students-incorrectly-insert-digit-wrong
  a curric:Misconception ;
  curric:statement "Students can incorrectly insert a digit in the wrong place value column."@en ;
  curric:correction """Printing or white board drawings of a place value chart will support student
  understanding of the different column headings and place value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115920Z"^^xsd:dateTime .

oakcurric:misconception-rolling-6-dice-less-likely
  a curric:Misconception ;
  curric:statement """Rolling a 6 on a dice is less likely to happen than rolling other numbers. Or
  ticket 001 is less likely to be drawn in a raffle than other tickets."""@en ;
  curric:correction """The random nature of picking a raffle or rolling a dice means all outcomes
  are equally likely as each other."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116498Z"^^xsd:dateTime .

oakcurric:misconception-pupils-incorrectly-write-number-standard
  a curric:Misconception ;
  curric:statement """Pupils can incorrectly write a number in standard form or use a number in
  incorrect standard form whereby the number A does not satisfy 1 ≤ A < 10 or pupils use
  division of positive powers of 10."""@en ;
  curric:correction """Standard form represents a multiplicative relationship, so there should
  always be a multiplication. Embedding the understanding that negative exponents refer to
  1/10^n is important. Using the place value chart with fractional and exponent form helps."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123636Z"^^xsd:dateTime .

oakcurric:misconception-pupils-count-number-outcomes-state
  a curric:Misconception ;
  curric:statement "Pupils may count the number of outcomes and state this as the probability."@en ;
  curric:correction """Remind pupils that the probability scale is between 0 and 1, so an answer of
  3 is not correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124490Z"^^xsd:dateTime .

oakcurric:misconception-small-number-trials-experiment-enough
  a curric:Misconception ;
  curric:statement """A small number of trials in an experiment is enough to provide conclusive
  findings."""@en ;
  curric:correction """Even in situations where we know that the different outcomes of a trial are
  equally likely happen, one outcome may happen more often than the others. E.g. when we
  flip a coin 10 times, we don't always get the exact same number of heads and tails."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124770Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-feature-data-set
  a curric:Misconception ;
  curric:statement """Pupils may not understand what feature of a data set they're trying to find
  when identifying a mode"""@en ;
  curric:correction """Phrase the question as 'What is the modal colour?' for instance, rather than
  just 'What is the mode?'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.125562Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-length-radius-squaring
  a curric:Misconception ;
  curric:statement "Pupils may multiply the length and radius before squaring."@en ;
  curric:correction """Remind students of the order of operations and link to the volume of a prism
  formula: finding the area of the cross-section first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125932Z"^^xsd:dateTime .

oakcurric:misconception-pupils-write-range-3-10
  a curric:Misconception ;
  curric:statement """Pupils may often write the range as '3 to 10' or '10 - 3' rather than a single
  value."""@en ;
  curric:correction """Remind pupils that the range is a single value which describes how far apart
  the extreme values are."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125938Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-first-learning-cycle
  a curric:Misconception ;
  curric:statement """Pupils may struggle in the first learning cycle with where each object should
  be placed."""@en ;
  curric:correction """The closer to the observation point an object is, the larger it appears to
  be. So if we want an object to appear larger than something else, we need to place it
  closer to the camera."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125943Z"^^xsd:dateTime .

oakcurric:misconception-sequences-constant-additive-multiplicative-patterns
  a curric:Misconception ;
  curric:statement "That sequences can only have constant additive or multiplicative patterns."@en ;
  curric:correction """Give students two numbers and get them to carry the sequence on in different
  ways. Anything they come up with can be a sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126327Z"^^xsd:dateTime .

oakcurric:misconception-subtract-variable-numerical-terms-subtracting
  a curric:Misconception ;
  curric:statement """To subtract from both the variable and numerical terms when subtracting from
  both sides."""@en ;
  curric:correction """To subtract $$2$$ from $$5x+3$$ leaves $$5x+1$$, not $$3x+1$$. Use visual
  representations like balance scales and bar models to show this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126334Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-initially-difficult-see
  a curric:Misconception ;
  curric:statement """Pupils may find it initially difficult to see how Pythagoras' theorem can be
  used when a right-angled triangle is not immediately available."""@en ;
  curric:correction """Encourage pupils to draw their own diagram in cases where there is not one
  provided. In cases where pairs of coordinates are being used, encourage pupils to draw on
  horizontal and vertical line segments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126347Z"^^xsd:dateTime .

oakcurric:misconception-priority-operations-apply-fractions
  a curric:Misconception ;
  curric:statement "Priority of operations does not apply to fractions"@en ;
  curric:correction """Priority of operations applies to all numbers. They can check with a
  scientific calculator as the priority of operations is programmed in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126748Z"^^xsd:dateTime .

oakcurric:misconception-mixed-number-confused-integer-multiplying
  a curric:Misconception ;
  curric:statement """A mixed number can be confused with an integer multiplying by the proper
  fraction."""@en ;
  curric:correction "Emphasise the language eg. 3 and a 1/2  means 3 + 1/2."@en ;
  dcterms:modified "2026-06-07T15:30:15.126756Z"^^xsd:dateTime .

oakcurric:misconception-substituting-wrong-values-formulas
  a curric:Misconception ;
  curric:statement "Substituting the wrong values into the formulas."@en ;
  curric:correction """The formulas are written in words so ensure pupils check that what they are
  substituting is the correct value by rereading the description for each value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126762Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-combine-lengths-parallel
  a curric:Misconception ;
  curric:statement """Pupils may try to combine lengths that are not parallel to a known side
  length."""@en ;
  curric:correction """For two sets of side lengths to be equal, one set must be parallel to the
  other and none of the lengths can overlap."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126767Z"^^xsd:dateTime .

oakcurric:misconception-common-factors-put-intersection-venn
  a curric:Misconception ;
  curric:statement """Common factors are put into the intersection of the Venn diagram twice instead
  of once."""@en ;
  curric:correction """Encourage students to check that the product of the factors in each set is
  the correct integer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126906Z"^^xsd:dateTime .

oakcurric:misconception-frequencies-frequency-table-angles-plot
  a curric:Misconception ;
  curric:statement """The frequencies on the frequency table are the angles you plot onto the pie
  chart."""@en ;
  curric:correction """Challenge the misconception by using an example with frequencies that clearly
  add to more or less than 360 e.g. {90, 90, 180, 90, 60)"""@en ;
  dcterms:modified "2026-06-07T15:30:15.126912Z"^^xsd:dateTime .

oakcurric:misconception-draw-7-cm-line-my
  a curric:Misconception ;
  curric:statement "I can draw a 7 cm line with my ruler."@en ;
  curric:correction """A line is a linear path that continues forever in both directions. We can
  draw line segments with a ruler, which have distinct endpoints."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126924Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-pattern-increasing-3
  a curric:Misconception ;
  curric:statement """Pupils might think that a pattern increasing by 3 each time has the rule add
  3."""@en ;
  curric:correction """Pupils should think about the number of lines per square and the relationship
  between squares and lines. Avoid consecutive patterns to start"""@en ;
  dcterms:modified "2026-06-07T15:30:15.126929Z"^^xsd:dateTime .

oakcurric:misconception-denominator-larger-value-fraction-larger
  a curric:Misconception ;
  curric:statement "As the denominator is larger the value of the fraction is larger."@en ;
  curric:correction """An analogy of sharing pizza helps students understand. Would pupils get a
  bigger slice of pizza if it was shared between more people?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.126935Z"^^xsd:dateTime .

oakcurric:misconception-denominators-multiples-10-give-terminating
  a curric:Misconception ;
  curric:statement "Denominators that are multiples of 10 will give a terminating decimal."@en ;
  curric:correction """Investigate the difference between powers of 10 and multiples of 10. e.g 7/30
  and 7/100"""@en ;
  dcterms:modified "2026-06-07T15:30:15.127801Z"^^xsd:dateTime .

oakcurric:misconception-sequences-go-infinitely
  a curric:Misconception ;
  curric:statement "All sequences can go on infinitely."@en ;
  curric:correction """When we think abstractly and start a sequence such as 8, 10, 12, 14, 16, ...
  it is possible that it goes on infinitely. However, if we applied this sequence to a
  context such as pairs of pupils getting on a bus, then a physical limit will apply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127806Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-digit-card-0
  a curric:Misconception ;
  curric:statement "Pupils may think the digit card 0 has to have significant place value."@en ;
  curric:correction """If the question doesn't specify the number of digits, leading zeros can be
  used (and not written) to create integers with fewer digits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127816Z"^^xsd:dateTime .

oakcurric:misconception-pupils-label-vertical-axis-frequency
  a curric:Misconception ;
  curric:statement """Pupils may label the vertical axis with the frequency values rather than a
  scale."""@en ;
  curric:correction """Remind the pupils that the scale should go up in the same jumps. i.e. 0, 5,
  10, 15 etc and have them check theirs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128764Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistakenly-choose-bars-same
  a curric:Misconception ;
  curric:statement """Pupils may mistakenly choose the bars which have the same heights to be the
  mode."""@en ;
  curric:correction """By reminding the pupils of the definition of the mode and asking the question
  in the context of the data, this should support students."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128777Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-halve-multiplying-base
  a curric:Misconception ;
  curric:statement """Pupils may forget to halve after multiplying the base and the perpendicular
  height."""@en ;
  curric:correction """The area of a triangle is equal to half the area of the parallelogram formed
  by two of those triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128783Z"^^xsd:dateTime .

oakcurric:misconception-adding-length-side-onto-wrong
  a curric:Misconception ;
  curric:statement "Adding the length of the side onto the wrong value within a coordinate."@en ;
  curric:correction """Use sketches/ erasable axis/ Desmos to plot points and see if they are
  reasonable. Encourage writing/drawing on diagrams as working out."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128789Z"^^xsd:dateTime .

oakcurric:misconception-common-multiple-integers-1
  a curric:Misconception ;
  curric:statement "A common multiple of all integers is 1."@en ;
  curric:correction """Get students to list multiples. This is to highlight the fact that 1 is only
  a multiple of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129087Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-drawing-graph-broken
  a curric:Misconception ;
  curric:statement "Pupils may think that drawing a graph with a broken axis is incorrect."@en ;
  curric:correction """It is fine to do this (and is sometimes necessary) but it is important to
  acknowledge this when trying to draw conclusions from the graph."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129198Z"^^xsd:dateTime .

oakcurric:misconception-pupils-work-missing-angles-without
  a curric:Misconception ;
  curric:statement """Pupils may work out missing angles without writing out their
  justifications."""@en ;
  curric:correction """Each time a number which is not on the original diagram is used or found, an
  explanation should be given for where it has come from."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129209Z"^^xsd:dateTime .

oakcurric:misconception-order-two-angles-supplementary-lie
  a curric:Misconception ;
  curric:statement """In order for two angles to be supplementary, they must both lie about a point
  on a straight line."""@en ;
  curric:correction """For two angles to be supplementary, they must sum to 180°. They do not also
  need to both lie on a straight line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129219Z"^^xsd:dateTime .

oakcurric:misconception-numerators-divided-denominators-divided
  a curric:Misconception ;
  curric:statement "Numerators are divided and denominators are divided."@en ;
  curric:correction """Emphasize the definition of division. \"How many times does.... fit into
  it?\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.129229Z"^^xsd:dateTime .

oakcurric:misconception-assuming-triangles-certain-types-because
  a curric:Misconception ;
  curric:statement "Assuming triangles are certain types because of how they look."@en ;
  curric:correction """Unless there is notation or it has stated the type of triangle you cannot
  assume."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129794Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-graphs-linear-written
  a curric:Misconception ;
  curric:statement "Pupils may think graphs are only linear if written in the form y=mx+c"@en ;
  curric:correction """Use the first learning cycle as an opportunity to show graphs in many
  formats. y=mx+c makes the gradient and y intercept clear."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129803Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-area-multiplying-lengths
  a curric:Misconception ;
  curric:statement """Pupils may find the area by multiplying lengths which are not
  perpendicular."""@en ;
  curric:correction """Area is measured in square units. The base and height of a square are
  perpendicular. We multiply perpendicular lengths to make square units."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129810Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-theoretical-probabilities-found
  a curric:Misconception ;
  curric:statement """Pupils may assume that theoretical probabilities can be also found in cases
  where individual outcomes are not equally likely (e.g. picking a sweet out of a box where
  the sweets are different shapes)."""@en ;
  curric:correction """If the sweets in a box are different shapes then picking a sweet out of the
  box is not necessarily random. Someone could find their favourite flavour sweet by feeling
  the different shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129816Z"^^xsd:dateTime .

oakcurric:misconception-position-term-rule-initial-term
  a curric:Misconception ;
  curric:statement "The position-to-term rule is the initial term add the common difference."@en ;
  curric:correction """Once pupils have found the additive pattern get them to write each term as a
  value add the difference."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129825Z"^^xsd:dateTime .

oakcurric:misconception-sin-60-double-sin-30
  a curric:Misconception ;
  curric:statement "sin(60°) is double sin(30°)."@en ;
  curric:correction """The values of the sine or cosine of an angle do not scale linearly. We can
  see from the unit circle that an angle of 30° meets the circle at a height of 0.5 units,
  whilst an angle of 60° meets the circle at a height of approximately 0.87 units."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129831Z"^^xsd:dateTime .

oakcurric:misconception-1-prime-number
  a curric:Misconception ;
  curric:statement "1 is a prime number"@en ;
  curric:correction """1 is not a prime number as it only has one factor and a prime number has
  exactly two factors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130078Z"^^xsd:dateTime .

oakcurric:misconception-shapes-same-area-same-perimeter
  a curric:Misconception ;
  curric:statement "Shapes with the same area also have the same perimeter."@en ;
  curric:correction """Demonstrate that component parts being rearranged has no effect on its area,
  but may affect its perimeter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130092Z"^^xsd:dateTime .

oakcurric:misconception-20-50-100-partition-2
  a curric:Misconception ;
  curric:statement """20 × 50 = 100, they partition the 2 and 5 to give 10 but count the zero as one
  of the 2 zeroes."""@en ;
  curric:correction """Make sure that partitions are written out fully. E.g. 20 × 50 = 2 × 5 × 10 ×
  10 = 10 × 100 = 1000"""@en ;
  dcterms:modified "2026-06-07T15:30:15.130296Z"^^xsd:dateTime .

oakcurric:misconception-line-distance-time-graph-go
  a curric:Misconception ;
  curric:statement "The line on a distance time graph can go in any direction."@en ;
  curric:correction """The line may be horizontal, time changing without a change in distance, but
  it can not be vertical. That would be a change in distance without a change in time.
  Additionally, our line cannot go backwards; time is always moving forwards."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130302Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-key-pictogram-mislabel
  a curric:Misconception ;
  curric:statement """Pupils may forget the key with a pictogram or mislabel the vertical scale for
  bar charts."""@en ;
  curric:correction """By asking the pupils how they know there are 'x things', to highlight the
  need for the key."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130307Z"^^xsd:dateTime .

oakcurric:misconception-becoming-familiar-arithmetic-sequences-pupils
  a curric:Misconception ;
  curric:statement """After becoming very familiar with arithmetic sequences pupils can find the
  difference between the first two terms and just assume the sequence is arithmetic."""@en ;
  curric:correction """Explore a large number of geometric and arithmetic sequences and see if
  pupils can articulate how they check if a sequence is geometric. They might say the terms
  of the sequence grow more quickly (for some geometric sequences)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130351Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-avoid-sketching-nets
  a curric:Misconception ;
  curric:statement """Pupils may try to avoid sketching of nets or faces and in turn miss
  information."""@en ;
  curric:correction """Reassure pupils that a sketch does not need to be perfect and just needs to
  convey the key information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130370Z"^^xsd:dateTime .

oakcurric:misconception-use-outcome-tables-categorise-outcomes
  a curric:Misconception ;
  curric:statement """I can use outcome tables to categorise outcomes into as many events as
  I want."""@en ;
  curric:correction """Outcome tables are limited to categorising outcomes into only two events. You
  can use more tables to categorise outcomes into three or more events, but the number of
  tables you need quickly becomes massive!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.130916Z"^^xsd:dateTime .

oakcurric:misconception-reading-values-trigonometric-functions-explanation
  a curric:Misconception ;
  curric:statement """When reading the values of the trigonometric functions during the explanation
  slides and the tasks, pupils may think that all the values taken from the graphs are fully
  accurate."""@en ;
  curric:correction """Explain that many of the values from the trigonometric functions have digits
  beyond the second decimal place. However, two decimal places is a reasonable degree of
  accuracy for reading values from the graphs during this lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130931Z"^^xsd:dateTime .

oakcurric:misconception-dividing-number-line-confusion-intervals
  a curric:Misconception ;
  curric:statement """When dividing a number line, there is confusion between the intervals and
  lines."""@en ;
  curric:correction """Pupils can write the number on each mark on the number line to ensure equal
  intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131271Z"^^xsd:dateTime .

oakcurric:misconception-use-ruler-measure-midpoint-line
  a curric:Misconception ;
  curric:statement """I can use a ruler to measure the midpoint of a line segment, and a protractor
  to find 90°."""@en ;
  curric:correction """Constructions, such as perpendicular bisectors, are methods of creating &
  modifying shapes & angles in ways that don't require measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131277Z"^^xsd:dateTime .

oakcurric:misconception-referring-alternate-angles-z-angles
  a curric:Misconception ;
  curric:statement """Referring to alternate angles as 'Z' angles because of the arrangement of the
  lines."""@en ;
  curric:correction """Modelling the justification correctly through every example and using
  exterior alternate angles to highlight the limitations of 'Z' angles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131282Z"^^xsd:dateTime .

oakcurric:misconception-single-digit-percentage-incorrectly-worked
  a curric:Misconception ;
  curric:statement """A single digit percentage is incorrectly worked out by dividing by 10 and not
  100 e.g 3% = 0.3"""@en ;
  curric:correction """Two responses can be used to remind students that to covert a percentage into
  a decimal; we divide by 100; using 3%, ask what 30% is as a decimal and 3% as a decimal.
  Pupils realise they cannot be the same. A place value chart also helps."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131296Z"^^xsd:dateTime .

oakcurric:misconception-cosine-formula-used-find-length
  a curric:Misconception ;
  curric:statement """The cosine formula is only used to find the length of a side adjacent to an
  angle."""@en ;
  curric:correction """The cosine formula can be used to find the length of a side adjacent to an
  angle. A rearrangement of the formula also allows us to find the length of the hypotenuse
  given the adjacent side. The arccosine function allows us to find the angle, itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131429Z"^^xsd:dateTime .

oakcurric:misconception-equations-form-y-mx-c
  a curric:Misconception ;
  curric:statement """Only equations in the form $$y=mx+c$$ are linear. All equations are
  linear."""@en ;
  curric:correction """There are many forms that linear equations can take, however they always
  share a common feature. The variables have exponents of $$1$$."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131771Z"^^xsd:dateTime .

oakcurric:misconception-averages-mean-median-mode-change
  a curric:Misconception ;
  curric:statement """Averages (mean, median, mode) will always change if a data point needs to be
  added, removed, edited."""@en ;
  curric:correction """The mean, median, or mode will remain invariant if a data point is added with
  the same value as that average."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131776Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-phrasing-language-trying
  a curric:Misconception ;
  curric:statement """Pupils may struggle with the phrasing and language, when trying to identify
  the correct regions of the Venn diagram."""@en ;
  curric:correction """Encourage the pupils to describe each region of the Venn diagram, in context
  where appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131782Z"^^xsd:dateTime .

oakcurric:misconception-probability-event-product-probability-outcome
  a curric:Misconception ;
  curric:statement """The probability of an event is the product of the probability of each outcome
  in the event."""@en ;
  curric:correction """The probability of an event is the sum of the probability of each outcome in
  the event seen in the sample space of a diagram. For example, in the sample space at the
  end of a probability tree, or by adding the outcomes in the sample space of a table."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131790Z"^^xsd:dateTime .

oakcurric:misconception-using-additive-strategies-instead-multiplicative
  a curric:Misconception ;
  curric:statement "Using additive strategies instead of multiplicative."@en ;
  curric:correction """Emphasise that proportional relationships maintain a constant multiplier so
  we are looking for a multiplicative relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131798Z"^^xsd:dateTime .

oakcurric:misconception-2-z-7-3-z
  a curric:Misconception ;
  curric:statement "2(z+7)+3(z+7)+5(z+7) must be expanded first before simplifying."@en ;
  curric:correction """Think of 'Unitising'. What is it we are adding together? In this case, we are
  summing multiples of (z+7). How many lots do we have?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.132012Z"^^xsd:dateTime .

oakcurric:misconception-pupils-substitute-incorrectly
  a curric:Misconception ;
  curric:statement "Pupils may substitute incorrectly."@en ;
  curric:correction """Each variable in a formula represents something. Substituting for one
  variable at a time may help ensure that values are in the correct places."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132020Z"^^xsd:dateTime .

oakcurric:misconception-making-3-digit-integer-pupils
  a curric:Misconception ;
  curric:statement """When making a 3-digit integer pupils use 0 as the first digit. However 057 is
  not a 3-digit integer."""@en ;
  curric:correction """Leading zeros are not written. They are not needed to preserve the place
  value of other digits. 057 is still a 2-digit integer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132028Z"^^xsd:dateTime .

oakcurric:misconception-students-count-closest-two-vertices
  a curric:Misconception ;
  curric:statement """Students may count between the closest two vertices rather than corresponding
  points."""@en ;
  curric:correction """Remind frequently that it needs to be between corresponding vertices,
  labelling may help for this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132035Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-repeated-rounding-gives
  a curric:Misconception ;
  curric:statement "Pupils think that repeated rounding gives the correct answer."@en ;
  curric:correction """Use a number line to support pupils’ understanding. Locate the number to be
  rounded on the line and identify the critical values."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132246Z"^^xsd:dateTime .

oakcurric:misconception-variable-unknown-same-thing
  a curric:Misconception ;
  curric:statement "A variable and an unknown are the same thing."@en ;
  curric:correction """A variable's value is not fixed. It can take any value within a given range.
  This means algebraic statements using variables can form proofs"""@en ;
  dcterms:modified "2026-06-07T15:30:15.132252Z"^^xsd:dateTime .

oakcurric:misconception-horizontal-side-length-isosceles-triangle
  a curric:Misconception ;
  curric:statement """The horizontal side length of an isosceles triangle is always the base
  side."""@en ;
  curric:correction """The base side of an isosceles triangle can have any orientation. It is
  important to look at the hash marks, angle markers, or measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132258Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-mathematical-proof-especially
  a curric:Misconception ;
  curric:statement """Pupils may struggle with mathematical proof, especially using other knowledge
  within it."""@en ;
  curric:correction """Explain to pupils that there are many different styles of mathematical proof
  but all are showing that a particular fact holds true for all."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132264Z"^^xsd:dateTime .

oakcurric:misconception-pupils-count-squares-calculate-gradient
  a curric:Misconception ;
  curric:statement "Pupils count squares to calculate gradient instead of looking at scales."@en ;
  curric:correction """Encourage pupils to pick points on the graph to use to find the gradient and
  write down the coordinates rather than count squares."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132273Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-maximum-bins-learning
  a curric:Misconception ;
  curric:statement "Pupils may not consider the maximum of the 'bins' in learning cycle 1."@en ;
  curric:correction """It can be helpful for pupils to have a running total for the values assigned
  to each 'bin' so that they know when it is full and no more values can be assigned there."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132281Z"^^xsd:dateTime .

oakcurric:misconception-confusion-factors-multiples
  a curric:Misconception ;
  curric:statement "There is often confusion between factors and multiples."@en ;
  curric:correction """Highlight that the number of dots in an array is the multiple and the number
  of dots in each column & row are the factors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132287Z"^^xsd:dateTime .

oakcurric:misconception-sequence-6-11-16-21
  a curric:Misconception ;
  curric:statement """That the sequence 6,11,16,21, ... is 5n+6 because it goes up by 5 and starts
  at 6."""@en ;
  curric:correction """Compare 6,11,16,21, ... to 5,10,15,20, ... \"What is the shift? The
  translation? If that is 5n then this is 5n with how much more?\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.132293Z"^^xsd:dateTime .

oakcurric:misconception-dividing-amount-sum-parts-ratio
  a curric:Misconception ;
  curric:statement """Always dividing the amount by the sum of the 'parts' of the ratio to get one
  'part'."""@en ;
  curric:correction """Offer opportunities to match problems to bar models ensure the same numbers
  are used to highlight the differences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132298Z"^^xsd:dateTime .

oakcurric:misconception-distance-time-graph-constructed-straight
  a curric:Misconception ;
  curric:statement "A distance time graph will always be constructed with straight lines."@en ;
  curric:correction """A straight line represents a consistent rate of a change, a consistent speed.
  In reality we need to model acceleration and deceleration which will involve curved lines."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132604Z"^^xsd:dateTime .

oakcurric:misconception-either-mean-median-mode-used
  a curric:Misconception ;
  curric:statement """Either the mean, median or mode could be used as an average in any
  situation."""@en ;
  curric:correction """The choice of average can depend on the type of data. For example, in a list
  of colours, you can find the mode but not the mean."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132613Z"^^xsd:dateTime .

oakcurric:misconception-winning-election-means-receiving-half
  a curric:Misconception ;
  curric:statement "Winning an election means receiving over half the vote."@en ;
  curric:correction """Under the First Past the Post system, a winning candidate must receive more
  votes than any other candidate. This may not mean receiving over half of the total vote."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132693Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-spot-patterns-consecutive
  a curric:Misconception ;
  curric:statement """Pupils may try to spot patterns between consecutive coordinates. E.g. the y
  value goes up in ones."""@en ;
  curric:correction """Get pupils to think about the relationship between x and y within a
  coordinate. Include non-integer values and coordinates not in order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132996Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-values-add-subtract
  a curric:Misconception ;
  curric:statement """Pupils can be unsure which values to add and which to subtract when collecting
  like terms."""@en ;
  curric:correction """Rewrite the equation with like terms grouped together before combining like
  terms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133022Z"^^xsd:dateTime .

oakcurric:misconception-mixing-stv-av-involve-ranking
  a curric:Misconception ;
  curric:statement """Mixing up STV and AV as both involve ranking candidates from favourite to
  least."""@en ;
  curric:correction "With STV, excess votes from the winning candidates are also reassigned."@en ;
  dcterms:modified "2026-06-07T15:30:15.133029Z"^^xsd:dateTime .

oakcurric:misconception-angles-straight-line-sum-180
  a curric:Misconception ;
  curric:statement "Angles on a straight line sum to 180°"@en ;
  curric:correction """Angles on a straight line only sum to 180° if all of those angles share a
  common vertex. Show two angles \"on a line\" at different points."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133307Z"^^xsd:dateTime .

oakcurric:misconception-pupils-count-sides-calculating-perimeter
  a curric:Misconception ;
  curric:statement """Pupils may not count all sides when calculating the perimeter due to the
  complexity of the shape."""@en ;
  curric:correction """Encourage pupils to mark the sides as they record the measurement to ensure
  they count every side length."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133313Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-formula-area-2
  a curric:Misconception ;
  curric:statement """Pupils may confuse the formula for area with the 2πr version of the formula
  for circumference."""@en ;
  curric:correction """Area is a 2-dimensional space so its formula requires the multiplication of
  two lengths. This happens when we square the radius."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133323Z"^^xsd:dateTime .

oakcurric:misconception-40-thousands-placing-4-thousands
  a curric:Misconception ;
  curric:statement "40 thousands placing the 4 in the thousands column."@en ;
  curric:correction "As there are 40 thousands the 4 is in the ten thousands column."@en ;
  dcterms:modified "2026-06-07T15:30:15.133329Z"^^xsd:dateTime .

oakcurric:misconception-decimals-go-beyond-thousandths-cannot
  a curric:Misconception ;
  curric:statement """When decimals go beyond thousandths you cannot find a number between 2
  numbers."""@en ;
  curric:correction "Use a 'zoomable' number line to show what happens as we zoom in."@en ;
  dcterms:modified "2026-06-07T15:30:15.133446Z"^^xsd:dateTime .

oakcurric:misconception-10-x-2-means-2
  a curric:Misconception ;
  curric:statement "10 - x = 2 means that 2 - x = 10"@en ;
  curric:correction """Using bar models can help pupils understand rearranging additive
  relationships at an early stage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133452Z"^^xsd:dateTime .

oakcurric:misconception-findings-data-investigation-using-sample
  a curric:Misconception ;
  curric:statement """The findings for a data investigation using a sample can always be generalised
  to the population."""@en ;
  curric:correction """The generalisability of results can depend on how representative the sample
  is of the population which it is being compared to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133727Z"^^xsd:dateTime .

oakcurric:misconception-arrangement-6-square-faces-result
  a curric:Misconception ;
  curric:statement "Any arrangement of 6 square-faces will result in the net of a cube."@en ;
  curric:correction """Some arrangements of 6 squares will result in some of them overlapping when
  the shape is folded into 3D, resulting in an incomplete cube."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133733Z"^^xsd:dateTime .

oakcurric:misconception-calculating-diameter-pupils-use-rounded
  a curric:Misconception ;
  curric:statement """When calculating the diameter, pupils may use rounded numbers to perform
  subsequent calculations."""@en ;
  curric:correction """Repeat one of the demonstrations of finding the diameter but round each
  decimal as they appear and compare the accuracy of the final answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133741Z"^^xsd:dateTime .

oakcurric:misconception-enlargement-refers-increase-size
  a curric:Misconception ;
  curric:statement "Enlargement only refers to an increase in size."@en ;
  curric:correction """The transformation 'enlargement' refers to a change of size that can be
  either a stretch or a shrink."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133747Z"^^xsd:dateTime .

oakcurric:misconception-rounding-number-pupils-write-first
  a curric:Misconception ;
  curric:statement """When rounding a number, pupils write the first significant digit(s). e.g 36
  789 is 4."""@en ;
  curric:correction """The use of the place value table shows the magnitude of the number, thus
  preserving their place value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134026Z"^^xsd:dateTime .

oakcurric:misconception-writing-gradient-constant-y-intercept
  a curric:Misconception ;
  curric:statement """Writing the gradient as the constant and the y intercept as the coefficient of
  x."""@en ;
  curric:correction """Link to linear sequences where the coefficient of n is the common difference
  in the sequence to help pupils see why (m) is the gradient."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134286Z"^^xsd:dateTime .

oakcurric:misconception-urban-area-implement-strategies-make
  a curric:Misconception ;
  curric:statement """An urban area should implement all of the strategies to make itself
  greener."""@en ;
  curric:correction """Not all strategies are viable for every urban area and some will be more
  effective than others depending on the location."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134291Z"^^xsd:dateTime .

oakcurric:misconception-factors-integers-appear-12-12
  a curric:Misconception ;
  curric:statement "All factors of all integers will appear in a 12 by 12 times table grid."@en ;
  curric:correction """It is not possible to identify all factors of 24 using a 12 by 12 times table
  grid."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134313Z"^^xsd:dateTime .

oakcurric:misconception-solving-equations-pupils-use-inverse
  a curric:Misconception ;
  curric:statement "When solving equations pupils may not use the inverse operation."@en ;
  curric:correction """Working out should include each step then pupils can check each step using
  substitution."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134319Z"^^xsd:dateTime .

oakcurric:misconception-centre-rotation-centre-object
  a curric:Misconception ;
  curric:statement "The centre of rotation is always in the centre of an object."@en ;
  curric:correction """The centre of rotation can be anywhere. If it's outside the shape, imagine it
  like a pole in the ground, attached to the object by a rope."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134327Z"^^xsd:dateTime .

oakcurric:misconception-calculators-used-add-subtract-multiply
  a curric:Misconception ;
  curric:statement "Calculators can only be used to add, subtract, multiply or divide."@en ;
  curric:correction """They can be used to perform basic calculations but they can also do so much
  more."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134590Z"^^xsd:dateTime .

oakcurric:misconception-considering-decimal-part-number-integer
  a curric:Misconception ;
  curric:statement "Considering the decimal part of a number to be an integer."@en ;
  curric:correction """Reinforce the use of a place value table and working from left to right when
  comparing decimals. It can be useful to use money here."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134598Z"^^xsd:dateTime .

oakcurric:misconception-drawing-circles-pupils-find-start
  a curric:Misconception ;
  curric:statement """When drawing circles, pupils may find that the start and end of their arcs do
  not join together."""@en ;
  curric:correction """This can be caused by the pair of compasses opening or closing mid-drawing.
  Hold it with one hand and rest the pencil gently on the page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134604Z"^^xsd:dateTime .

oakcurric:misconception-pupils-thing-letters-represent-item
  a curric:Misconception ;
  curric:statement """Pupils may thing that letters represent an item e.g a week equals 7 days so
  w=7d"""@en ;
  curric:correction """Get pupils to identify what value the letter represents e.g the number of
  days then say a number sentence that describes the relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134613Z"^^xsd:dateTime .

oakcurric:misconception-increasing-probability-50-pupils-choose
  a curric:Misconception ;
  curric:statement """When increasing a probability by 50%, pupils may choose to add 50% onto the
  existing probability rather than multiplying by 1.5."""@en ;
  curric:correction """Make links to any previous work pupils may have done on increasing by a
  percentage and emphasise that a percentage increase is being applied to the probability."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134624Z"^^xsd:dateTime .

oakcurric:misconception-diagonal-reflections-incorrectly-look-like
  a curric:Misconception ;
  curric:statement """Diagonal reflections that incorrectly look like rotations or translations of
  the object."""@en ;
  curric:correction """False reflections that look like this are due to students not counting
  diagonals of grid squares, perpendicular to the mirror line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134630Z"^^xsd:dateTime .

oakcurric:misconception-assuming-convert-1-metre-squared
  a curric:Misconception ;
  curric:statement """Assuming that to convert 1 metre squared to cm squared you multiply by 100 and
  not 10 000"""@en ;
  curric:correction """Encourage any pupil who initially finds this challenging to ensure that the
  values are in the required unit for the answer before doing the calculation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134636Z"^^xsd:dateTime .

oakcurric:misconception-students-see-implicit-brackets-eg
  a curric:Misconception ;
  curric:statement """Students do not see the implicit brackets. Eg. Sqrt(49 + 36) is not sqrt(49) +
  sqrt(36)"""@en ;
  curric:correction """Look for extended lines or operations which indicate an implicit
  brackets."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134869Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-exponents-especially-value
  a curric:Misconception ;
  curric:statement """Pupils may struggle with exponents especially which value to square when
  variables have coefficients"""@en ;
  curric:correction """Reminder of priority of operations and the exponent acts on the value it is
  directly preceded by."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134875Z"^^xsd:dateTime .

oakcurric:misconception-one-answer-everything-maths
  a curric:Misconception ;
  curric:statement "There is one answer to everything in maths."@en ;
  curric:correction """We often see arithmetic and equations with one answer but, maths can be used
  to compare and justify multiple answers to a single problem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134881Z"^^xsd:dateTime .

oakcurric:misconception-writing-answers-terms-pupils-think
  a curric:Misconception ;
  curric:statement "When writing answers in terms of π, pupils may think that π is the units."@en ;
  curric:correction """π is a constant and makes up part of the numerical component of the answer.
  Units (such as square metres) still need to be stated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134886Z"^^xsd:dateTime .

oakcurric:misconception-seeing-multiplication-repeated-addition-leads
  a curric:Misconception ;
  curric:statement """Only seeing multiplication as repeated addition leads to incorrect additive
  strategies for ratios."""@en ;
  curric:correction """Focus on the multiplicative relationships between parts to whole or whole to
  parts. Ratios allow the multiplicative relationship to be seen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135073Z"^^xsd:dateTime .

oakcurric:misconception-cant-accurately-draw-perpendicular-point
  a curric:Misconception ;
  curric:statement """You can't accurately draw the perpendicular to a point on a line segment close
  to its endpoint."""@en ;
  curric:correction """The perpendicular to a line segment through any point can be found; some line
  segments just require extending in length first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135186Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-decide-mark
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to decide where to mark the centre point of each
  circle during Task A."""@en ;
  curric:correction """Pupils could start the task by drawing a pair of circles and labelling it
  with the question that presents the matching description."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135191Z"^^xsd:dateTime .

oakcurric:misconception-confusion-1-4-4-1
  a curric:Misconception ;
  curric:statement """Confusion between which is which out of (1,4) and (4,1). Is it up and along?
  Along and up?"""@en ;
  curric:correction """Clarity of language helps. Coordinates are written x, then y coordinate. Move
  first in the x-direction. There are no 'corridors and stairs'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135199Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-find-percentage-change
  a curric:Misconception ;
  curric:statement "Forgetting to find the percentage change."@en ;
  curric:correction """Emphasise the word change. Encourage pupils to write down the 2 percentages
  with their relevant values. Go back to the question and calculate the actual change they
  should notice that this is neither of the 2 values but the difference between them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135205Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-drawing-scaled-axis-common
  a curric:Misconception ;
  curric:statement "Incorrectly drawing a scaled axis is common."@en ;
  curric:correction """Use the approach where pupils count the number of intervals of the scale and
  divide the difference bewteen the intervals. For example, if there are 5 intervals and the
  difference is between 20 and 30, they divide 10 by 2, so each interval is 2."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135211Z"^^xsd:dateTime .

oakcurric:misconception-changing-subject-equation-formula-done
  a curric:Misconception ;
  curric:statement """Changing the subject of an equation or formula is only done when you are told
  to."""@en ;
  curric:correction """Having students practise rearranging before substituting and vice versa
  allows them to decide when the skill could be useful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135340Z"^^xsd:dateTime .

oakcurric:misconception-algebra-particular-solving-equations-abstract
  a curric:Misconception ;
  curric:statement """That algebra, in particular solving equations, is abstract and not related to
  the world around us."""@en ;
  curric:correction """Ask pupils to solve $$4(x+3)=20$$. Then show a square with length $$x+3$$,
  tell them the perimeter is $$20$$ and ask them to find $$x$$."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135346Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-term-transformation-translation
  a curric:Misconception ;
  curric:statement "Students may confuse the term transformation for translation."@en ;
  curric:correction "Translation is one type of transformation."@en ;
  dcterms:modified "2026-06-07T15:30:15.135524Z"^^xsd:dateTime .

oakcurric:misconception-use-written-methods-solve-equations
  a curric:Misconception ;
  curric:statement "That we always have to use written methods to solve equations."@en ;
  curric:correction """Use Desmos to show that equations like $$3x-1=17$$ and $$3x-1=x+9$$ can be
  solved by drawing both lines and finding the intersection."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135558Z"^^xsd:dateTime .

oakcurric:misconception-reading-solutions-graph-pupils-read
  a curric:Misconception ;
  curric:statement """When reading solutions from a graph pupils may read the solution as the
  y-coordinate."""@en ;
  curric:correction """The solution to the equation is the value of the variable that makes both
  sides balance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135568Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-finding-probability-b
  a curric:Misconception ;
  curric:statement """Pupils may struggle with finding the probability of A or B, and may count the
  outcomes that belong to A and B twice."""@en ;
  curric:correction """If you use an example, such as visiting particular countries, ask the pupils
  how someone would respond to the question 'have you visited X or Y' if they have in fact
  visited both countries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135579Z"^^xsd:dateTime .

oakcurric:misconception-two-sectors-two-different-pie
  a curric:Misconception ;
  curric:statement """Two sectors on two different pie charts that have the same angle represent the
  same frequency."""@en ;
  curric:correction """90° of a pie chart of 4 data points represents less frequency (frequency of
  1) than 90° of a pie chart of 200 data points (frequency of 50)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135586Z"^^xsd:dateTime .

oakcurric:misconception-students-try-divide-integer-integer
  a curric:Misconception ;
  curric:statement "Students try to divide an integer with an integer without simplifying."@en ;
  curric:correction """Student are required to convert the divisor into an integer. Simplifying the
  denominator into a single integer digit is preferable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135592Z"^^xsd:dateTime .

oakcurric:misconception-performing-divisions-calculate-maximum-number
  a curric:Misconception ;
  curric:statement """When performing divisions to calculate the maximum number of plants that fit
  into a space, pupils may round decimal answers up to the nearest integer (e.g. round 4.5
  plants up to 5 plants)."""@en ;
  curric:correction """The context would suggest that it may be more appropriate to truncate decimal
  answers to an integer rather than rounding them up to the nearest integer (e.g. there is
  not enough space available to fit the 5th plant)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136031Z"^^xsd:dateTime .

oakcurric:misconception-calculating-amount-emissions-per-mile
  a curric:Misconception ;
  curric:statement """When calculating the amount of emissions per mile, pupils may forget to
  convert the information given from grams to kilograms."""@en ;
  curric:correction """Always check whether the units for any values given in the information match
  the units that are required for the formula."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136047Z"^^xsd:dateTime .

oakcurric:misconception-pupils-join-their-coordinates-extend
  a curric:Misconception ;
  curric:statement "Pupils may join up their coordinates but not extend their line."@en ;
  curric:correction """Lines are used to represent all coordinates that follow a rule. Unless given
  restrictions, lines should be infinitely long."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136059Z"^^xsd:dateTime .

oakcurric:misconception-converting-english-algebra-pupils-mix
  a curric:Misconception ;
  curric:statement "When converting English to algebra, pupils can mix up 4x + 2 and 4(x + 2)"@en ;
  curric:correction """Reviewing priority of operations and expanding brackets may be helpful. The
  multiplier operates on all terms in the bracket."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136070Z"^^xsd:dateTime .

oakcurric:misconception-solving-x-5-10-pupils
  a curric:Misconception ;
  curric:statement "When solving x - 5 = 10 pupils may see the -5 and calculate 10 - 5 = 5"@en ;
  curric:correction """Focus on understanding zero pairs and why adding the additive inverse gives
  the solution. Bar models are a helpful representation here."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136081Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-reflections-rotations-depending
  a curric:Misconception ;
  curric:statement "Students may confuse reflections and rotations depending on the object."@en ;
  curric:correction """A reflection is the only transformation that changes the sense of the object,
  so check that first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136091Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-non-metric-units
  a curric:Misconception ;
  curric:statement "Pupils may consider non-metric units in discussion."@en ;
  curric:correction """Remind them that the metric units are based around the metre, gram and litre
  only."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136305Z"^^xsd:dateTime .

oakcurric:misconception-completing-inverse-translation-students-believe
  a curric:Misconception ;
  curric:statement """When completing an inverse translation, students may believe they need to flip
  the vector."""@en ;
  curric:correction """Ask students to say in words how you would return to the starting point, to
  highlight the direction needed and then link to the vector."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136664Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-avoid-writing-lists
  a curric:Misconception ;
  curric:statement "Pupils want to avoid writing lists of outcomes."@en ;
  curric:correction """Always model and bring explicit attention to a systematic list. The benefits
  of working systematically is the likelihood of error is reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136670Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-division-calculated-multiplication
  a curric:Misconception ;
  curric:statement """Pupils think division has to be calculated before multiplication and addition
  before subtraction."""@en ;
  curric:correction """Show pupils different ways of working out the same calculation that gives the
  same answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136676Z"^^xsd:dateTime .

oakcurric:misconception-transversals-intersect-pair-parallel-lines
  a curric:Misconception ;
  curric:statement "Transversals must intersect a pair of parallel lines."@en ;
  curric:correction """Transversals can intersect any set of lines or line segments, no matter
  whether any of those lines or line segments are parallel or not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137209Z"^^xsd:dateTime .

oakcurric:misconception-estimation-approximation-required-skills-working
  a curric:Misconception ;
  curric:statement """Estimation and approximation are only required skills when working solely with
  number problems."""@en ;
  curric:correction """In problem solving it can be really useful to sketch an approximation of a
  certain graph such as a linear equation. Seeing where the $$y$$-intercept is and drawing
  an approximate gradient could help us identify solutions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137218Z"^^xsd:dateTime .

oakcurric:misconception-pupils-worry-event-stage-trial
  a curric:Misconception ;
  curric:statement """Pupils may worry about which event/stage of the trial should be the rows and
  which should be the columns in an outcome table."""@en ;
  curric:correction """Explain that the rows and columns can be transposed. Depending on the context
  AB and BA may be the same outcome, whereas in other contexts they may be two different
  outcomes, so a little care is needed in interpretation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137225Z"^^xsd:dateTime .

oakcurric:misconception-many-ways-multiply-decimals-large
  a curric:Misconception ;
  curric:statement """There are many ways to multiply decimals or large numbers. With decimals, some
  pupils choose to multiply decimals using the column method and incorrectly use a decimal
  point when calculating answers."""@en ;
  curric:correction """When multiplying decimals, converting the calculation using integers and
  powers of 10 makes the calculation easier to work with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137231Z"^^xsd:dateTime .

oakcurric:misconception-line-segments-connecting-corresponding-points
  a curric:Misconception ;
  curric:statement """Line segments connecting corresponding points on an image and object can
  intersect each other."""@en ;
  curric:correction """Corresponding point line segments after a reflection never intersect. If they
  do, then corresponding points have not been paired correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137247Z"^^xsd:dateTime .

oakcurric:misconception-occasions-pupils-cannot-find-tool
  a curric:Misconception ;
  curric:statement """There may be occasions when pupils cannot find the tool they are
  looking for."""@en ;
  curric:correction """Ask them to click 'more' in the toolbar, scroll down and then click 'more'
  again."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137252Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-mixed-metric-imperial
  a curric:Misconception ;
  curric:statement "Pupils may get mixed up between metric and imperial units."@en ;
  curric:correction """You may wish to refer to Lesson 6 of this unit, which explains the metric
  system’s use of prefixes, and compare this with imperial measures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137437Z"^^xsd:dateTime .

oakcurric:misconception-pupils-incorrectly-identify-base-triangle
  a curric:Misconception ;
  curric:statement "Pupils may incorrectly identify the base of the triangle in the trapezium."@en ;
  curric:correction """Drawing a trapezium on paper, colouring the sides and cutting it will help
  them see where the base of the triangle comes from."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137443Z"^^xsd:dateTime .

oakcurric:misconception-use-protractor-measure-angle-half
  a curric:Misconception ;
  curric:statement """I can use a protractor to measure an angle, then half that angle to
  bisect it."""@en ;
  curric:correction """Constructions, such as bisecting an angle, are methods of creating &
  modifying shapes & angles in ways that don't require measurement tools."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137449Z"^^xsd:dateTime .

oakcurric:misconception-taking-20-amount-percentage-change
  a curric:Misconception ;
  curric:statement """Taking 20% off an amount after a percentage change will result in the original
  amount before 20% was added."""@en ;
  curric:correction """These are percentages of different amounts so, given that we are calculating
  20% in both cases, this will not work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137585Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miscalculate-mixed-number-improper
  a curric:Misconception ;
  curric:statement "Some pupils can miscalculate the mixed number to an improper fraction."@en ;
  curric:correction """For smaller numbers, encourage pupils to draw bar models or diagrams to show
  the relationship between the whole and the improper fraction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137812Z"^^xsd:dateTime .

oakcurric:misconception-subtracting-expression-pupils-forget-subtract
  a curric:Misconception ;
  curric:statement """When subtracting expression pupils forget to subtract both terms from the
  second espression."""@en ;
  curric:correction """Watch out for mistakes with negatives here. Pupils should find it much easier
  to re-write subtractions as additions of additive inverses and that way they only need to
  add."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137817Z"^^xsd:dateTime .

oakcurric:misconception-weather-report-rain-icon-means
  a curric:Misconception ;
  curric:statement "If the weather report has the rain icon, it means it will rain."@en ;
  curric:correction """The rain symbol is to denote what type of rain it is likely to be should it
  rain. The percentage chance of rain then informs us about how likely it is to rain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137826Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-mathematical-conventions-rounding
  a curric:Misconception ;
  curric:statement "Pupils may think the mathematical conventions for rounding should apply."@en ;
  curric:correction """This is rounding in a practical context and pupils should consider what the
  effects of rounding up and down are and how they affect the answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137832Z"^^xsd:dateTime .

oakcurric:misconception-pupils-initially-unsure-enlarging-shapes
  a curric:Misconception ;
  curric:statement """Pupils may initially be unsure when enlarging shapes on different background
  in Q2 of Task B."""@en ;
  curric:correction """Stress that they can use the same methods as for square or plain backgrounds
  (e.g. using a ruler, counting units along gridlines)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137906Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-determine-whether-question
  a curric:Misconception ;
  curric:statement """Pupils may struggle to determine whether a question is asking about the
  perimeter or the area."""@en ;
  curric:correction """Encourage pupils to draw a diagram to represent the situation as this can
  make it clearer as to whether perimeter or area is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137911Z"^^xsd:dateTime .

oakcurric:misconception-rearranging-equations-means-swap-terms
  a curric:Misconception ;
  curric:statement "Rearranging equations means you can just swap where terms are."@en ;
  curric:correction """Remind pupils that subtraction and division are not commutative so swapping
  the order will matter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137917Z"^^xsd:dateTime .

oakcurric:misconception-pupils-avoid-using-pair-compasses
  a curric:Misconception ;
  curric:statement "Pupils may avoid using the pair of compasses and opt for a ruler instead."@en ;
  curric:correction """Emphasise the efficiency and accuracy of using compasses instead of a ruler
  in the construction of their triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138557Z"^^xsd:dateTime .

oakcurric:misconception-squaring-binomial-same-squaring-term
  a curric:Misconception ;
  curric:statement """Squaring a binomial is the same as just squaring each term. This can then
  cause confusion with difference of two squares where expanding a pair of binomials does
  result in just two terms."""@en ;
  curric:correction """Using an area model and taking time to check the partial products each time,
  particularly with negative terms, should help students to check if they have expanded
  correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138566Z"^^xsd:dateTime .

oakcurric:misconception-icon-pupils-choose-complicated-duplicate
  a curric:Misconception ;
  curric:statement """The icon that the pupils choose is too complicated to duplicate and cannot be
  divided well."""@en ;
  curric:correction """Have the pupils try and find an icon with reflective symmetry and simple
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138572Z"^^xsd:dateTime .

oakcurric:misconception-square-numbers-number-squared
  a curric:Misconception ;
  curric:statement "Square numbers are any number that can be squared."@en ;
  curric:correction """Give students counters or let them draw dot patterns to explore square
  numbers geometrically as well as numerically."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138580Z"^^xsd:dateTime .

oakcurric:misconception-one-way-solve-given-equation
  a curric:Misconception ;
  curric:statement "That there is only one way to solve any given equation."@en ;
  curric:correction """In maths we will often see multiple ways to solve the same one problem. To be
  able to use multiple methods is a demonstration of fluency."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138588Z"^^xsd:dateTime .

oakcurric:misconception-one-way-solve-linear-equations
  a curric:Misconception ;
  curric:statement """There is only one way to solve linear equations; by manipulation and isolating
  the variable(s)."""@en ;
  curric:correction """When we plot more than one linear equation on a graph we can use the
  intersection to find the solution."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138800Z"^^xsd:dateTime .

oakcurric:misconception-right-means-clockwise-left-means
  a curric:Misconception ;
  curric:statement "\"Right means clockwise\" and \"left means anti-clockwise\""@en ;
  curric:correction """This is only true when referencing the top of the object being rotated.
  Rotating \"left\" and \"right\" is incorrect for all other vertices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138806Z"^^xsd:dateTime .

oakcurric:misconception-because-sense-changed-doesnt-mean
  a curric:Misconception ;
  curric:statement """Just because the sense has changed, it doesn't mean a reflection has
  occurred."""@en ;
  curric:correction """If an image has a different sense to its object, there has definitely been a
  reflection - the line of reflection may be at an obscure angle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138811Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-fraction-opposite-adjacent
  a curric:Misconception ;
  curric:statement """Pupils may get the fraction (opposite/adjacent) inverted and this will still
  return an answer so they may believe they are correct."""@en ;
  curric:correction """Remind pupils to sense check their answers. The larger the angle, the longer
  the opposite side will be."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138820Z"^^xsd:dateTime .

oakcurric:misconception-multiplying-fraction-integer-multiplying-numerator
  a curric:Misconception ;
  curric:statement """When multiplying a fraction by an integer multiplying the numerator and
  denominator by the integer."""@en ;
  curric:correction """If they do this they will have effectively multiplied by 1. Use an example to
  show you end up with the same fraction that you started with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139153Z"^^xsd:dateTime .

oakcurric:misconception-incorrect-inputting-negative-numbers-exponents
  a curric:Misconception ;
  curric:statement "Incorrect inputting of negative numbers and/or exponents."@en ;
  curric:correction "Encourage the use of brackets when using exponents."@en ;
  dcterms:modified "2026-06-07T15:30:15.139159Z"^^xsd:dateTime .

oakcurric:misconception-need-draw-circles-same-size
  a curric:Misconception ;
  curric:statement """You always need to draw circles that are the same size to construct any
  polygon."""@en ;
  curric:correction """Some polygons, such as kites, require you to construct two circles of
  different size, as long as they still intersect at two points."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139164Z"^^xsd:dateTime .

oakcurric:misconception-assuming-zero-digits-significant
  a curric:Misconception ;
  curric:statement "Assuming all zero digits are not significant."@en ;
  curric:correction """Within the lesson there are many examples where some zeros are significant.
  Relate significance back to the communication of accuracy and that some digits are
  significant as they preserve the place value of other digits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139170Z"^^xsd:dateTime .

oakcurric:misconception-splitting-polygon-triangles-pupils-draw
  a curric:Misconception ;
  curric:statement """When splitting a polygon into triangles, pupils may draw line segments that
  cross inside the shape."""@en ;
  curric:correction """By choosing a single common vertex for all the triangles, the line segments
  will not cross inside the shape."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139175Z"^^xsd:dateTime .

oakcurric:misconception-using-venn-diagram-misplacement-factors
  a curric:Misconception ;
  curric:statement "When using a Venn diagram misplacement of factors is common."@en ;
  curric:correction """Encourage students to check that the product of factors in each set is the
  correct integer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139183Z"^^xsd:dateTime .

oakcurric:misconception-assuming-graph-constant-positive-gradient
  a curric:Misconception ;
  curric:statement """Assuming that any graph with a constant positive gradient represents variables
  that are in direct proportion."""@en ;
  curric:correction """Encourage the useful check of reading a pairs of values from the graph,
  doubling one of them and checking the graph to see if the other variable has doubled. If
  it has it shows a directly proportional relationship if not it doesn't."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139189Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unfamiliar-train-timetables-interpret
  a curric:Misconception ;
  curric:statement "Pupils may be unfamiliar with train timetables and how to interpret them."@en ;
  curric:correction """Each column of times can be given a header of Train 1, Train 2 etc. This will
  make it clearer that the times in a column refer to when that train will reach a station."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139458Z"^^xsd:dateTime .

oakcurric:misconception-combine-two-sequences-same-type
  a curric:Misconception ;
  curric:statement """If you combine two sequences of the same type the resulting sequence will
  still be that type."""@en ;
  curric:correction """Adding corresponding terms of two sequences will be good preparation for
  future units but it also a way to explore what sequences can be generated by combining
  other sequences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139472Z"^^xsd:dateTime .

oakcurric:misconception-simplifying-means-grouping-algebraic-terms
  a curric:Misconception ;
  curric:statement "Simplifying means just grouping the algebraic terms."@en ;
  curric:correction """Remind pupils that fully simplifying means the expression cannot be
  simplified further."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139806Z"^^xsd:dateTime .

oakcurric:misconception-pupils-choose-middle-bar-bar
  a curric:Misconception ;
  curric:statement """Pupils may choose the middle bar on the bar chart or the middle value on the
  x-axis as their median."""@en ;
  curric:correction """Pull off the data from the bar chart or line graph to show where the median
  value is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139831Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-double-length-width
  a curric:Misconception ;
  curric:statement """Pupils may think they can always double the length and width to calculate the
  perimeter."""@en ;
  curric:correction """This only works for composite rectilinear shapes if the lengths do not
  overlap."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139846Z"^^xsd:dateTime .

oakcurric:misconception-equal-chance-means-same-even
  a curric:Misconception ;
  curric:statement "'Equal chance' means the same as 'even chance'."@en ;
  curric:correction """When a trial has more than two possible outcomes which are all equally likely
  to happen, each outcome has less than an even chance of happening. E.g. each number on a
  dice has the same likelihood of being rolled, but each is less than an even chance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139852Z"^^xsd:dateTime .

oakcurric:misconception-summing-given-lengths-given-lengths
  a curric:Misconception ;
  curric:statement """Summing all of the given lengths and only the given lengths to find the
  perimeter."""@en ;
  curric:correction """With each example discuss which lengths are part of the perimeter, which
  lengths are not and whether any lengths are equal to others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140133Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-lengths-diagram-rather
  a curric:Misconception ;
  curric:statement """Pupils may multiply all lengths on the diagram rather than find the area of
  the cross-section."""@en ;
  curric:correction """Draw the cross-sectional polygon out, find the area and then multiply by the
  length of the prism."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140139Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-able-rotate-anticlockwise
  a curric:Misconception ;
  curric:statement """Pupils may struggle with only being able to rotate anticlockwise on
  Desmos."""@en ;
  curric:correction """Turning clockwise x degrees is equivalent to turning anticlockwise (360 - x)
  degrees."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140169Z"^^xsd:dateTime .

oakcurric:misconception-pupils-thing-given-graph-continuous
  a curric:Misconception ;
  curric:statement """Pupils may thing that given the graph is continuous, the sequence can contain
  all of the values represented by the line."""@en ;
  curric:correction """It is important that pupils know when it is appropriate to draw a line to
  graph sequences and whether values on the line have any meaning. Sequences are often given
  as a list of terms and without context we cannot assume the sequence is continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140380Z"^^xsd:dateTime .

oakcurric:misconception-probability-tree-two-branches
  a curric:Misconception ;
  curric:statement "A probability tree can only have two branches."@en ;
  curric:correction """A probability tree can have any number of branches on a layer, but the more
  branches you want to include, the trickier and less practical the probability tree is to
  draw and use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140386Z"^^xsd:dateTime .

oakcurric:misconception-use-addition-instead-multiplication-decomposing
  a curric:Misconception ;
  curric:statement "Use of addition instead of multiplication when the decomposing the number."@en ;
  curric:correction "Reiterate that the product of prime factors is unique."@en ;
  dcterms:modified "2026-06-07T15:30:15.140392Z"^^xsd:dateTime .

oakcurric:misconception-sequences-such-triangular-numbers-linear
  a curric:Misconception ;
  curric:statement """Sequences such as triangular numbers which have a linear sequence in their
  differences are linear."""@en ;
  curric:correction "Terms in an arithmetic sequence have to have a common first difference."@en ;
  dcterms:modified "2026-06-07T15:30:15.140397Z"^^xsd:dateTime .

oakcurric:misconception-answer-handshake-problem-15-15x15
  a curric:Misconception ;
  curric:statement "The answer to the 'handshake' problem is 15, or 15x15"@en ;
  curric:correction """Group pupils into 3s and ask them to record how many handshakes are made.
  Then group as 4s and repeat. What do they notice?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.140403Z"^^xsd:dateTime .

oakcurric:misconception-plotting-sequences-line-drawn-points
  a curric:Misconception ;
  curric:statement "When plotting sequences, a line must be drawn through the points."@en ;
  curric:correction """Plot (1,5), (2,10), (3,15), draw a line and find other coordinates. When n =
  1.5 the term value is 7.5. Is 7.5 in the sequence 5n??"""@en ;
  dcterms:modified "2026-06-07T15:30:15.140408Z"^^xsd:dateTime .

oakcurric:misconception-tasks-pupils-use-ruler-draw
  a curric:Misconception ;
  curric:statement """During tasks, pupils may use a ruler to draw or check whether points are
  equidistant from a centre."""@en ;
  curric:correction """While the tasks could be completed with a ruler, it may be quicker, easier
  and more accurate to use a pair of compasses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140738Z"^^xsd:dateTime .

oakcurric:misconception-table-values-filled-points-plotted
  a curric:Misconception ;
  curric:statement """A table of values should always be filled in and all points plotted in order
  to graph a linear equation."""@en ;
  curric:correction """A linear equation will form a straight line graph therefore we only need to
  know two points in order to draw the line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140746Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-lines-gradients-2
  a curric:Misconception ;
  curric:statement "Pupils may think lines with gradients 2 and -2 are parallel."@en ;
  curric:correction """Lines have to have the exact same gradient to be parallel. A line with a
  negative gradient will intersect a line with a positive gradient ."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140758Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-given-graph-continuous
  a curric:Misconception ;
  curric:statement """Pupils may think that given a graph is continuous, the sequence can contain
  all of the values represented by the line."""@en ;
  curric:correction """It is important that pupils know when it is appropriate to draw a line to
  graph sequences and whether values on the line have any meaning. Sequences are often given
  as a list of terms and without context we cannot assume the sequence is continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140764Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-position-median-medians
  a curric:Misconception ;
  curric:statement """Pupils may confuse the position of the median with the median's actual
  value."""@en ;
  curric:correction """Choose data where the position number would not be a reasonable median value
  and ensure pupils sense check their answers every time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140770Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-height-triangle-slanted
  a curric:Misconception ;
  curric:statement """Pupils may think the height of the triangle is the slanted height rather than
  perpendicular."""@en ;
  curric:correction """The base and height to be used must be perpendicular (at a right angle) to
  each other."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140778Z"^^xsd:dateTime .

oakcurric:misconception-outcome-tree-doesnt-sample-space
  a curric:Misconception ;
  curric:statement "An outcome tree doesn't have a sample space."@en ;
  curric:correction """Each representation of the outcomes of a trial have a sample space as a part
  of it. For an outcome table, the table itself is the sample space. For an outcome tree, a
  sample space must always be constructed after drawing the two layers of branches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140785Z"^^xsd:dateTime .

oakcurric:misconception-outcome-tree-maximum-three-layers
  a curric:Misconception ;
  curric:statement "An outcome tree can only have a maximum of three layers of branches."@en ;
  curric:correction """An outcome tree can have as many layers of branches as needed, depending on
  the number of stages there are in a trial. For example, if a trial involved flipping 7
  coins, then there would be 7 layers of branches! That's too probably too many to draw!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.140791Z"^^xsd:dateTime .

oakcurric:misconception-identifying-integer-multiple-its-given
  a curric:Misconception ;
  curric:statement """Identifying if integer is a multiple when its given in its prime
  factor form."""@en ;
  curric:correction """Only the bases need to be considered, not the exponents. e.g if it is a
  multiple of 3 it must be a multiple of 3^2, 3^3, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140796Z"^^xsd:dateTime .

oakcurric:misconception-using-wrong-limits-dividing-subtracting
  a curric:Misconception ;
  curric:statement """Using the wrong limits when dividing or subtracting in order to find the upper
  limit of a calculation or lower limit of a calculation."""@en ;
  curric:correction """Drawing a number line to show with subtraction will help students see how to
  achieve an upper or lower limits of an error interval calculation. When using division,
  reiterating the division of number is the same as multiplying by its reciprocal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140897Z"^^xsd:dateTime .

oakcurric:misconception-fractions-denominators-factors-10-n
  a curric:Misconception ;
  curric:statement """Fractions with denominators that are not a factors of 10^n cannot be converted
  into a decimal."""@en ;
  curric:correction """This is a good opportunity to reiterate that fractions are an alternative way
  of writing a division."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140970Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confused-whether-multiply-divide
  a curric:Misconception ;
  curric:statement """Pupils may be confused about whether to multiply or divide when dealing with
  reversing percentage change."""@en ;
  curric:correction """The first learning cycle addresses this and you may wish to display the
  example on a whiteboard for the entire lesson for pupils to refer to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140975Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-describing-patterns-grow
  a curric:Misconception ;
  curric:statement """Pupils can mix up describing how patterns grow or the relationships between
  objects in the pattern."""@en ;
  curric:correction """Pupils should verbalise their description, using the keyword 'term' , making
  it clear which way they are describing their pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140983Z"^^xsd:dateTime .

oakcurric:misconception-trying-double-expression-doubling-one
  a curric:Misconception ;
  curric:statement "Trying to double an expression and only doubling one term."@en ;
  curric:correction """Use the numerical examples to show why this does not work. Use of brackets in
  working out is also helpful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140989Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-horizontal-edge-triangle
  a curric:Misconception ;
  curric:statement """Pupils may believe the horizontal edge of the triangle is always the
  adjacent."""@en ;
  curric:correction """Emphasise that the labelling of the triangle is based around the focus angle
  and use right-angled triangles with various orientations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140995Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-1-b-2
  a curric:Misconception ;
  curric:statement "Pupils often think a=1 b=2 ... or that a letter represents an object"@en ;
  curric:correction """Letters represent a numerical value either unknown or variable. Avoid always
  using the first letter of the words used in a scenario."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141317Z"^^xsd:dateTime .

oakcurric:misconception-plotting-integer-coordinate-pairs-quadratic
  a curric:Misconception ;
  curric:statement """After plotting the integer coordinate pairs of a quadratic, they should be
  joined with a straight line."""@en ;
  curric:correction """Use graphing technology to plot coordinate pairs that use smaller and smaller
  non-integer steps between $$x$$-coordinates. This will reveal the true, curved nature of
  the line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141331Z"^^xsd:dateTime .

oakcurric:misconception-coordinate-2-5-2-5
  a curric:Misconception ;
  curric:statement """Where is coordinate (−2,5)? 2 down, 5 right from the origin? 5 right, 2 down
  from the origin?"""@en ;
  curric:correction """Coordinates in (<i>x,y</i>) form. −2 is <i>x</i>-instruction. From (0,0) will
  we travel in a positive or negative <i>x</i>-direction?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141337Z"^^xsd:dateTime .

oakcurric:misconception-calculating-gradient-coordinates-pupils-get
  a curric:Misconception ;
  curric:statement """When calculating gradient from coordinates, pupils get positive and negative
  gradients mixed up."""@en ;
  curric:correction """Encourage pupils to sketch the coordinates first and then always look at a
  positive increase in x."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141346Z"^^xsd:dateTime .

oakcurric:misconception-writing-y-intercept-single-value
  a curric:Misconception ;
  curric:statement """Writing the y intercept as a single value or getting the x and y coordinates
  the wrong way around."""@en ;
  curric:correction """Encourage writing the y intercept as a coordinate. Stating 'lines cross the y
  axis when x=0' can help pupils write the coordinate correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141352Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-sequence-arithmetic-check
  a curric:Misconception ;
  curric:statement "Pupils assume a sequence is arithmetic and only check the first few terms."@en ;
  curric:correction """Encourage pupils to check all the terms of a sequence they are given to check
  that the pattern they think they have spotted is continuing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141358Z"^^xsd:dateTime .

oakcurric:misconception-two-datasets-same-mean-distribution
  a curric:Misconception ;
  curric:statement """If two datasets have the same mean, then the distribution of data points will
  look similar."""@en ;
  curric:correction """Even with the same mean, two datasets could have vastly different ranges. One
  dataset could be bimodal, whilst the other could be unimodal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141365Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-coordinates-make-square
  a curric:Misconception ;
  curric:statement """Pupils may think that coordinates that make a square/ rectangle follow a
  linear pattern."""@en ;
  curric:correction """In order for coordinates to follow a rule written as an equation, there needs
  to be a relationship between the values within a coordinate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141371Z"^^xsd:dateTime .

oakcurric:misconception-group-branches-same-number-branches
  a curric:Misconception ;
  curric:statement "Every group of branches should have the same number of branches."@en ;
  curric:correction """In a multi-staged trial, each stage may have a different number of outcomes.
  The number of branches in each group reflects the number of outcomes of a stage. This
  means each group of branches can be made from a different number of branches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141377Z"^^xsd:dateTime .

oakcurric:misconception-use-inefficient-methods-multiply-fractions
  a curric:Misconception ;
  curric:statement """Use of inefficient methods to multiply fractions, i.e. not considering common
  factors."""@en ;
  curric:correction """The use of fractions with large numerators and denominators can be used to
  highlight when this is a useful method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141659Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-data-presented-using
  a curric:Misconception ;
  curric:statement """Pupils may think that data is only presented using the types of graphs that
  they learn in school."""@en ;
  curric:correction """Data can presented visually in anyway that helps people to understand it.
  Explore other types of graphs and infographics used in the media."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141666Z"^^xsd:dateTime .

oakcurric:misconception-line-y-x-y-x
  a curric:Misconception ;
  curric:statement """From the line $$y=x$$ to $$y=x+1$$ to $$y=x-1$$ the lines are moving
  left/right rather than up/down."""@en ;
  curric:correction """It can be shown by using a $$(x,c)$$ coordinate in desmos. That coordinate
  moves up and down with the change in '$$c$$'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141671Z"^^xsd:dateTime .

oakcurric:misconception-comparing-modal-class-two-datasets
  a curric:Misconception ;
  curric:statement """When comparing the modal class for two datasets, pupils may think that the
  dataset with the greatest modal class is the one which has the greatest frequency for its
  modal class"""@en ;
  curric:correction """Use the frequency to identify the modal class for each dataset, but then
  compare the values within each class to determine which dataset has the greatest modal
  class."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141677Z"^^xsd:dateTime .

oakcurric:misconception-assuming-100-minutes-hour-converting
  a curric:Misconception ;
  curric:statement """Assuming that there are 100 minutes in an hour and converting 3.25 hours to 3
  hours 25 minutes."""@en ;
  curric:correction """Start with half an hour, pupils should be happy that half an hour is 30 mins,
  show it written as a decimal to highlight it's not 3.3 hours"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141806Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-multiply-term-bracket
  a curric:Misconception ;
  curric:statement """Pupils forget to multiply every term in the bracket by the term outside the
  bracket."""@en ;
  curric:correction """Remind pupils about the distributive law with numerical examples, e.g. 4(3 +
  7) and show that this is not equivalent to 12 + 7. Using algebra tiles can also help
  pupils to make sense of this skill."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141815Z"^^xsd:dateTime .

oakcurric:misconception-since-linear-equations-typically-one
  a curric:Misconception ;
  curric:statement """Since linear equations (typically) have one solution, all equations have one
  solution."""@en ;
  curric:correction """Ask pupils to compare the graphical solution to a linear equation with the
  graphical solution to a quadratic equation. This will enable them to see that it is
  possible for a quadratic equation to have more than one solution."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141821Z"^^xsd:dateTime .

oakcurric:misconception-rounding-incorrectly-stated-context
  a curric:Misconception ;
  curric:statement "Rounding incorrectly for the stated context."@en ;
  curric:correction """Pupils should consider the situation and ask - if rounding down, will there
  be enough? If rounding up, does this cover all cases? Thinking about the situation and
  trying different values to see what works can also help."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141827Z"^^xsd:dateTime .

oakcurric:misconception-pie-charts-bar-charts-show
  a curric:Misconception ;
  curric:statement """Pie charts but not bar charts can show what proportion of a dataset a
  particular subgroup represents"""@en ;
  curric:correction """You can figure out proportion from a bar chart by comparing the frequency of
  one subgroup to the total frequency, by adding heights of bars."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141832Z"^^xsd:dateTime .

oakcurric:misconception-correlation-means-one-variables-affecting
  a curric:Misconception ;
  curric:statement """Correlation always means that one of the variables is affecting the other
  variable."""@en ;
  curric:correction """Correlation only suggests variables may be related somehow. Show examples
  where variables correlate because they both depend on population."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141844Z"^^xsd:dateTime .

oakcurric:misconception-pupils-overlook-whether-given-diameter
  a curric:Misconception ;
  curric:statement """Pupils may overlook whether they have been given the diameter or radius of the
  circles."""@en ;
  curric:correction """Encourage pupils to always write down the radius before any calculation of
  the surface area is started."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141849Z"^^xsd:dateTime .

oakcurric:misconception-pupils-list-possible-outcomes-unsystematic
  a curric:Misconception ;
  curric:statement """Pupils may list the possible outcomes in an unsystematic way, potentially
  causing them to miss or repeat outcomes."""@en ;
  curric:correction """Demonstrate how our system of counting is a systematic method for listing
  numbers and compare it to some of the listing strategies used in the lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141858Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-drawing-interpreting-scales-axes
  a curric:Misconception ;
  curric:statement "Incorrectly drawing or interpreting the scales on axes."@en ;
  curric:correction """Use the approach where pupils count the number of intervals of the scale and
  divide the difference between the intervals. For example, if there are 5 intervals and the
  difference is between 20 and 30, they divide 10 by 2, so each interval is 2"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141869Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-start-angle-problem
  a curric:Misconception ;
  curric:statement """Pupils might not know how to start an angle problem if they focus too much on
  the final solution."""@en ;
  curric:correction """You can start an angle problem by working out any angle on the diagram. The
  more angles you work out, the easier the final solution becomes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141967Z"^^xsd:dateTime .

oakcurric:misconception-one-trend-line-appearing-higher
  a curric:Misconception ;
  curric:statement """One trend line appearing higher on a graph than a different trend line means
  the higher line shows more change over time."""@en ;
  curric:correction """It is the gradient of a trend line that informs how quickly something is
  changing with respect to time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141974Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-sides-right-angled
  a curric:Misconception ;
  curric:statement """Pupils mix-up the sides of the right-angled triangle when using Pythagoras'
  theorem."""@en ;
  curric:correction """Pupils may benefit from labelling the right-angled triangle so that the
  hypotenuse is clearly identified."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141979Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-divide-2-calculating
  a curric:Misconception ;
  curric:statement "Pupils may forget to divide by 2 when calculating the area of a trapezium."@en ;
  curric:correction """The area of a trapezium is half of the area of the parallelogram formed from
  two identical trapeziums."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141985Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-best-buy-deal
  a curric:Misconception ;
  curric:statement """Pupils may think that it is always best to buy a 'deal' as deals are always a
  good thing."""@en ;
  curric:correction """Throughout the lesson it is demonstrated that a deal or promotion may not
  always be right for every customer. Is a deal worth it if you don't need to buy that much?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141996Z"^^xsd:dateTime .

oakcurric:misconception-mean-meaningful-average
  a curric:Misconception ;
  curric:statement "The mean is the most meaningful average."@en ;
  curric:correction """Looking at bimodal data, trimodal data or data with extreme outliers. Context
  may be relevant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142068Z"^^xsd:dateTime .

oakcurric:misconception-sine-formula-used-find-length
  a curric:Misconception ;
  curric:statement """The sine formula is only used to find the length of a side opposite an
  angle."""@en ;
  curric:correction """Whilst the sine formula can be used to find the length of a side opposite an
  angle, a rearrangement of the formula also allows us to find the length of the hypotenuse
  given the opposite side. The arcsine function allows us to find the angle, itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142073Z"^^xsd:dateTime .

oakcurric:misconception-students-forget-scroll-operation-function
  a curric:Misconception ;
  curric:statement "Students often forget to scroll out of an operation or function."@en ;
  curric:correction """Emphasis the cursor buttons allow users to scroll around the apps, functions
  and calculations on the calculator."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142250Z"^^xsd:dateTime .

oakcurric:misconception-word-population-refers-entire-population
  a curric:Misconception ;
  curric:statement """The word 'population' always refers to the entire population of a country or
  the world."""@en ;
  curric:correction """The population in a given context is defined by the entire set of
  people/creatures/items that are being considered."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142256Z"^^xsd:dateTime .

oakcurric:misconception-pupils-draw-rectangle-their-venn
  a curric:Misconception ;
  curric:statement "Pupils may not draw the rectangle in their Venn diagrams."@en ;
  curric:correction """Refer back to the rectangle hosting all possible outcomes; the sample space
  and therefore a vital part of a Venn diagram."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142267Z"^^xsd:dateTime .

oakcurric:misconception-use-addition-instead-multiplication-finding
  a curric:Misconception ;
  curric:statement "Use of addition instead of multiplication when finding factors."@en ;
  curric:correction "Reiterate that the product of prime factors is unique."@en ;
  dcterms:modified "2026-06-07T15:30:15.142273Z"^^xsd:dateTime .

oakcurric:misconception-graph-representing-inversely-proportional-relationship
  a curric:Misconception ;
  curric:statement """The graph representing a inversely proportional relationship is of the form x
  + y = a and will eventually meet the axes."""@en ;
  curric:correction """The dimensions of the rectangle are ideal for highlighting this, particularly
  the latter part as a you cannot have a rectangle with a length of 0 cm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142279Z"^^xsd:dateTime .

oakcurric:misconception-using-unitising-method-remainder-remainder
  a curric:Misconception ;
  curric:statement """Using the unitising method with a remainder, the remainder is not written as a
  fraction of the unit."""@en ;
  curric:correction """Drawing bar models, ensure that the unit is subdivided so the remainder can
  be seen as a fraction of the unit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142462Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-co-interior-angles
  a curric:Misconception ;
  curric:statement """Pupils may believe that the co-interior angles are equal, like alternate and
  corresponding angles."""@en ;
  curric:correction """Have pupils draw a pair of parallel lines and a transversal line themselves,
  identify the co-interior angles, are they equal?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.142473Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-connection-variables-scatter
  a curric:Misconception ;
  curric:statement """Pupils may assume that all there is always a connection between variables in
  scatter graphs."""@en ;
  curric:correction """Emphasise examples showing no/weak connections, but explain that the tasks
  use data containing stronger connections for purpose of practice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142488Z"^^xsd:dateTime .

oakcurric:misconception-breaking-shape-rectangles-best-approach
  a curric:Misconception ;
  curric:statement "Breaking the shape into rectangles is always the best approach."@en ;
  curric:correction """There is not always enough information to use that method so flexible
  thinking is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142496Z"^^xsd:dateTime .

oakcurric:misconception-want-find-radius-semicircle-its
  a curric:Misconception ;
  curric:statement """If I want to find the radius of a semicircle from its area, I halve the area
  first."""@en ;
  curric:correction """You must double the area. This calculates the area of a full circle, whose
  radius can be found by first dividing by π, then square rooting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142502Z"^^xsd:dateTime .

oakcurric:misconception-n-term-sequence-n-10
  a curric:Misconception ;
  curric:statement """That $$n$$ is a term in the sequence. That $$n=10$$ means 10 is in the
  sequence."""@en ;
  curric:correction """Reiterate that $$n$$ is the term number. \"$$n=10$$ means the 10th term. What
  is the 10th term number?\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.142510Z"^^xsd:dateTime .

oakcurric:misconception-x-times-five-plus-three
  a curric:Misconception ;
  curric:statement """That \"$$x$$ times five, plus three\" is the same as \"$$x$$ plus three, times
  five\"."""@en ;
  curric:correction """Use visual representations to demonstrate why and how they are different. Use
  algebra tiles if you have them, or get pupils to draw them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142665Z"^^xsd:dateTime .

oakcurric:misconception-drawing-object-tracing-paper-take
  a curric:Misconception ;
  curric:statement """After drawing an object on the tracing paper, you take the tracing paper off
  the table to rotate it."""@en ;
  curric:correction """This is especially dangerous if the centre of rotation wasn't drawn on the
  tracing paper, too. The image will lose its correct location."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142673Z"^^xsd:dateTime .

oakcurric:misconception-finding-10-divide-10-finding
  a curric:Misconception ;
  curric:statement "When finding 10% we divide by 10, so when finding 5% we divide by 5."@en ;
  curric:correction """Use a bar model to show the division of 10 means one tenth of the amount.
  When dividing by 5 it means one fifth has been found."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142679Z"^^xsd:dateTime .

oakcurric:misconception-lines-double-number-line-start
  a curric:Misconception ;
  curric:statement """Both lines of a double number line must start at zero and these zeros must be
  aligned."""@en ;
  curric:correction """When drawing double number lines, ensure to align the zeros and the known
  equivalents. Showing how a graph is formed from a DNL can help."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142725Z"^^xsd:dateTime .

oakcurric:misconception-students-omit-place-holders-subtracting
  a curric:Misconception ;
  curric:statement "Students often omit any place holders when subtracting decimals."@en ;
  curric:correction """Encourage all place holders to be used in all written calculations so they
  are not omitted when they need to be there."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142839Z"^^xsd:dateTime .

oakcurric:misconception-pupils-divide-many-groups-bars
  a curric:Misconception ;
  curric:statement """Pupils may divide by how many groups/bars there are, instead of the total
  frequency."""@en ;
  curric:correction """By reminding students frequently that averages need to give a 'typical' value
  of the data set, ask them to sense check their mean value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142845Z"^^xsd:dateTime .

oakcurric:misconception-2y-3y-like-terms-because
  a curric:Misconception ;
  curric:statement "2y and 3y are not like terms because they have different coefficients."@en ;
  curric:correction """Think of 'Unitising'. 3cm and 8cm. What are the units? 8mg and 10mg. What are
  the units? 2y and 3y. What are we 'unitising' here?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.142853Z"^^xsd:dateTime .

oakcurric:misconception-number-prime-divisible-2-3
  a curric:Misconception ;
  curric:statement "A number is a prime if it is not divisible by 2, 3, 5 or 10."@en ;
  curric:correction "A factor of a number can be greater than 10."@en ;
  dcterms:modified "2026-06-07T15:30:15.142859Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-symbol-represents-variable
  a curric:Misconception ;
  curric:statement """Pupils may think that the π symbol represents a variable, similar to letters
  such as r and d."""@en ;
  curric:correction """Reiterate the difference between variables and constants. Explain that while
  the radius may differ between circles, π is always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142905Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-diagonal-shape-vertical
  a curric:Misconception ;
  curric:statement """Pupils may struggle with a diagonal of a shape being vertical or
  horizontal."""@en ;
  curric:correction """By reminding pupils of the definition, ask them to check if it fits and the
  shape could be rotated as well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143119Z"^^xsd:dateTime .

oakcurric:misconception-missing-partial-products
  a curric:Misconception ;
  curric:statement "Missing out partial products"@en ;
  curric:correction """Relating back to numerical examples and showing that 12 × 34 is not just 10 ×
  30 + 2 × 4. Using algebra tiles and area models can help to support student's
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143444Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-justifications-rather-getting
  a curric:Misconception ;
  curric:statement """Pupils may struggle with the justifications rather than getting to the
  answer."""@en ;
  curric:correction """Keep asking pupils \"why?\" and encourage them to ask themselves, whenever
  they are working out an angle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143450Z"^^xsd:dateTime .

oakcurric:misconception-interior-angles-sum-180-times
  a curric:Misconception ;
  curric:statement """Interior angles always sum to 180 times the number of component triangles it
  is split into."""@en ;
  curric:correction """If line segments drawn make new vertices in the polygon, its angles won't
  contribute to the sum of interior angles in the initial polygon."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143456Z"^^xsd:dateTime .

oakcurric:misconception-students-think-numbers-square-numbers
  a curric:Misconception ;
  curric:statement """Students think that all numbers are square numbers as you can square any
  integer."""@en ;
  curric:correction "A square is the product of 2 repeated integers."@en ;
  dcterms:modified "2026-06-07T15:30:15.143467Z"^^xsd:dateTime .

oakcurric:misconception-sequence-3n-2-starts-3
  a curric:Misconception ;
  curric:statement """That the sequence $$3n+2$$ starts with 3 and adds 2, or starts with 2 and adds
  3."""@en ;
  curric:correction """Calculate the first few terms. Ask, \"When $$n = 1$$ what is the term
  value?\" This is the first value for our sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143475Z"^^xsd:dateTime .

oakcurric:misconception-factors-apply-whole-numbers-factor
  a curric:Misconception ;
  curric:statement """That factors only apply to whole numbers and a factor needs to be a whole
  number."""@en ;
  curric:correction """Whilst this is true for numerical factors, the factors of 7ab are 1, 7, a, b,
  7a, 7b and ab."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143668Z"^^xsd:dateTime .

oakcurric:misconception-deal-exponents-y-2-times
  a curric:Misconception ;
  curric:statement """How to deal with exponents. y^2 times by y makes 3y. Or at least has a
  coefficient that is not 1."""@en ;
  curric:correction """Unsimplifying first. Not sure? Break it down. What is it? a^2 is a x a. So
  a^2 x a must be a x a x a."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143677Z"^^xsd:dateTime .

oakcurric:misconception-plotting-sequence-3n-1-using
  a curric:Misconception ;
  curric:statement """When plotting the sequence $$3n-1$$ using technology you need to type each
  coordinate individually."""@en ;
  curric:correction """\"We use technology to make things easier. There must be a quicker way!\"
  Look for the 'table' function."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143683Z"^^xsd:dateTime .

oakcurric:misconception-calculating-amount-electricity-produced-solar
  a curric:Misconception ;
  curric:statement """When calculating the amount of electricity produced by a solar panel, pupils
  may forget to convert its power rating from watts to kilowatts."""@en ;
  curric:correction """Always check whether the units for any values given in the informatin match
  the units that are required for the formula."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143691Z"^^xsd:dateTime .

oakcurric:misconception-graphs-linear-graphs-linear-join
  a curric:Misconception ;
  curric:statement """All graphs are linear and if graphs are not linear you join points with
  straight line segments."""@en ;
  curric:correction """Explore $$n+2, 2n$$ and $$x^2$$. \"I see $$n$$ and 2; they must be similar\"
  pupils think. Get them to compare numerically, then graphically."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143840Z"^^xsd:dateTime .

oakcurric:misconception-draw-graph-using-gradient-intercept
  a curric:Misconception ;
  curric:statement """To draw the graph using the gradient and intercept you can just count the
  squares."""@en ;
  curric:correction """Encourage pupils to look at the scales on the axes carefully when drawing a
  line given the gradient and y-intercept."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143846Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-use-division-instead
  a curric:Misconception ;
  curric:statement "Pupils may want to use division instead of fractional scale factors."@en ;
  curric:correction """Dividing by 2 gives the same result as multiplying by a half. However, the
  scale factor is defined as a multiplier, not a divisor."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143852Z"^^xsd:dateTime .

oakcurric:misconception-subtracting-write-bigger-number-smaller
  a curric:Misconception ;
  curric:statement """When subtracting you always write the bigger number above the smaller
  number."""@en ;
  curric:correction """The context of spending money should help with this, as they will end up with
  a positive balance which is not possible ."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144029Z"^^xsd:dateTime .

oakcurric:misconception-subtracting-dividing-largest-value-found
  a curric:Misconception ;
  curric:statement """When subtracting or dividing, the largest value is found by subtracting or
  dividing the upper limit of a number by the upper limit of the divisor or additive
  inverse."""@en ;
  curric:correction """Drawing a number line to show with subtraction will help students see how to
  achieve an upper or lower limits of an error interval calculation. When using division,
  reiterating the division of number is the same as multiplying by its reciprocal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144035Z"^^xsd:dateTime .

oakcurric:misconception-3-y-2-expands-3y
  a curric:Misconception ;
  curric:statement "3(y+2) expands to 3y+2."@en ;
  curric:correction """3 lots of 12 isn't 3x10+2 so 3 lots of (y+2) isn't 3y+2. Get students to draw
  this out. To visualise it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144041Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-letters-represent-set
  a curric:Misconception ;
  curric:statement """Pupils may think that letters always represent a set value that can be
  'found'."""@en ;
  curric:correction """Highlight the distinction between unknowns and variables. Allow pupils to
  explore expressions intrinsically before substituting in values."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144047Z"^^xsd:dateTime .

oakcurric:misconception-task-b-q2-pupils-choose
  a curric:Misconception ;
  curric:statement "Task B Q2 - Pupils may choose to go up in 100s on the vertical axis."@en ;
  curric:correction """Highlight that all of their data points will be in the bottom half of the
  graph and suggest going up in 50s."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144052Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-diamond-example-quadrilateral
  a curric:Misconception ;
  curric:statement "Pupils may think a diamond is an example of a quadrilateral."@en ;
  curric:correction """Rhombus is the correct mathematical name for the shape that pupils may refer
  to as a diamond."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144058Z"^^xsd:dateTime .

oakcurric:misconception-find-area-quarter-circle-divide
  a curric:Misconception ;
  curric:statement """To find the area of a quarter-circle divide the radius by 4 to use as part of
  the calculation."""@en ;
  curric:correction """You must divide the area by 4, not the radius. The radius gets squared when
  calculating area so the division of r would be applied twice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144063Z"^^xsd:dateTime .

oakcurric:misconception-using-venn-diagram-students-mix
  a curric:Misconception ;
  curric:statement "When using a Venn diagram students often mix up HCF & LCM."@en ;
  curric:correction "Encourage students to check the reasonableness of their answer."@en ;
  dcterms:modified "2026-06-07T15:30:15.144069Z"^^xsd:dateTime .

oakcurric:misconception-adding-removing-data-point-dataset
  a curric:Misconception ;
  curric:statement """\"Adding or removing a data point from a dataset will always change the value
  of the range\""""@en ;
  curric:correction """The range only changes if: the data point added becomes a new max or min
  value, or the data point removed is the current max or min value."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144250Z"^^xsd:dateTime .

oakcurric:misconception-tell-3d-shape-prism-because
  a curric:Misconception ;
  curric:statement """I can tell a 3D shape is a prism because the 2D faces on both ends are
  congruent."""@en ;
  curric:correction """The cross-sectional face must be the same throughout, not just at the two
  ends of the shape. Also, the two end faces must be parallel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144258Z"^^xsd:dateTime .

oakcurric:misconception-reporting-two-averages-asked-make
  a curric:Misconception ;
  curric:statement """Reporting two averages when asked to make two comparisons between sets of
  data."""@en ;
  curric:correction """Mean, media and mode essentially measure the same thing: central tendency. So
  use one of the comparisons to comment on the spread of data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144342Z"^^xsd:dateTime .

oakcurric:misconception-2-3-2-3-2
  a curric:Misconception ;
  curric:statement """(-2,3), (2,-3), (-2,-3) can be confusing as pupils can confuse $$x$$ and
  $$y$$."""@en ;
  curric:correction """Talk about positive $$x$$-direction, negative $$x$$-direction. This will help
  the students to visualise which quadrant to plot in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144348Z"^^xsd:dateTime .

oakcurric:misconception-students-translate-vertically-horizontally
  a curric:Misconception ;
  curric:statement "Students may translate vertically before horizontally."@en ;
  curric:correction """Remind the students that the column vectors work in the same way as
  coordinates."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144355Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-right-angled
  a curric:Misconception ;
  curric:statement "Pupils may struggle to identify a right-angled triangle in the problem."@en ;
  curric:correction """Encourage pupils to sketch the question out and add any known right angles or
  perpendicular lines, as this may lead to a right-angled triangle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144466Z"^^xsd:dateTime .

oakcurric:misconception-see-probability-tree-multiply-probabilities
  a curric:Misconception ;
  curric:statement "When I see a probability tree, I always multiply the probabilities."@en ;
  curric:correction """If a probability tree shows a two-stage trial, then the probability of an
  outcome is the product of the probabilities of the outcomes at each stage. The probability
  of an event is the sum of the probabilities of each outcome in the event."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144472Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-decide-whether-question
  a curric:Misconception ;
  curric:statement """Pupils may struggle to decide whether the question is needing length, area or
  volume."""@en ;
  curric:correction """Support could be given by providing the units for the answer or pupils may be
  encouraged to think of contexts for each before hand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144477Z"^^xsd:dateTime .

oakcurric:misconception-pupils-ignore-data-point-zero
  a curric:Misconception ;
  curric:statement "Pupils may ignore a data point of zero in their calculation of the mean."@en ;
  curric:correction """Data points of zero will not add to the total but does impact the number of
  values, so the mean will be incorrect with its omission."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144821Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-think-different-context
  a curric:Misconception ;
  curric:statement """Pupils may struggle to think of a different context to apply to finding the
  perimeter."""@en ;
  curric:correction """An alternative context could be: putting a ribbon around a cake and leaving
  space for decoration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144827Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-perimeter-area
  a curric:Misconception ;
  curric:statement "Pupils may confuse perimeter and area."@en ;
  curric:correction """Perimeter is the distance around a 2D shape. Area is the size of the
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146367Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-likely-scale-likelihoods
  a curric:Misconception ;
  curric:statement """Pupils think that 'likely' from the scale of likelihoods is only equal to a
  specific probability (e.g. 75%)."""@en ;
  curric:correction """All probabilities that are greater than 50% but less than 100% are equivalent
  to 'likely' on the scale of likelihoods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146382Z"^^xsd:dateTime .

oakcurric:misconception-students-use-adhoc-approach-listing
  a curric:Misconception ;
  curric:statement """Students often use an adhoc approach to listing multiples this often leads to
  pairs being missed out"""@en ;
  curric:correction "Encourage a systematic approach starting with 1 and the integer."@en ;
  dcterms:modified "2026-06-07T15:30:15.146398Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-value-added-term
  a curric:Misconception ;
  curric:statement "Pupils may think a value has to be added to each term in an expression."@en ;
  curric:correction """When adding a term to an expression we can write it as a single addition and
  then collect like terms if necessary. Show with numbers first"""@en ;
  dcterms:modified "2026-06-07T15:30:15.146404Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-find-right-angled
  a curric:Misconception ;
  curric:statement """Pupils may struggle to find a right-angled triangle within the context of the
  question."""@en ;
  curric:correction """Encourage the pupils to sketch the question and consider adding a
  perpendicular line to the diagram."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146414Z"^^xsd:dateTime .

oakcurric:misconception-venn-diagrams-useful-generating-complete
  a curric:Misconception ;
  curric:statement """Venn diagrams are useful when generating a complete list of outcomes and
  showing the probabilities of that list."""@en ;
  curric:correction """Venn diagrams can be very useful when categorising already known outcomes
  into events. The Venn diagram can then be used to calculate probabilities. However, Venn
  diagrams are not as useful when generating a list of outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146429Z"^^xsd:dateTime .

oakcurric:misconception-mean-median-close-frequent-values
  a curric:Misconception ;
  curric:statement """The mean and median will always be close to the most frequent values (or
  peaks) in a dataset."""@en ;
  curric:correction """The mean and median may be at the lower or lowest frequency parts of a
  distribution. This is especially likely if the data is bimodal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146441Z"^^xsd:dateTime .

oakcurric:misconception-exterior-angle-entire-reflex-angle
  a curric:Misconception ;
  curric:statement """The exterior angle is the entire reflex angle that is on the outside of each
  vertex of a shape."""@en ;
  curric:correction """Ask a pupil to stand and walk around the room to trace a shape. The angle
  that the pupil turns at each vertex is an exterior angle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146696Z"^^xsd:dateTime .

oakcurric:misconception-plotted-points-arithmetic-sequence-form
  a curric:Misconception ;
  curric:statement """The plotted points of an arithmetic sequence form a line so we draw a line
  connecting them."""@en ;
  curric:correction """Sequences are an ordered list and do not always need to follow a rule, so we
  often only find and use the positive integer term numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146702Z"^^xsd:dateTime .

oakcurric:misconception-coordinates-exist-plotted-lines-graph
  a curric:Misconception ;
  curric:statement """That coordinates only exist, and can only be plotted, on the lines of graph
  paper."""@en ;
  curric:correction """Between any two vertices there are infinitely more points. Ask pupils to
  consider what numbers are between 1 and 2."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146711Z"^^xsd:dateTime .

oakcurric:misconception-need-know-lengths-angles-pair
  a curric:Misconception ;
  curric:statement """You need to know all the lengths or all of the angles in a pair of triangles
  to know that they are similar."""@en ;
  curric:correction """Remind pupils that they do not necessarily need to know all of the length and
  angles to determine whether two triangles are congruent, so they don't all need to be
  known to determine similarity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146717Z"^^xsd:dateTime .

oakcurric:misconception-students-believe-two-shapes-congruent
  a curric:Misconception ;
  curric:statement """Students may believe two shapes are congruent based purely on the shape and
  not the size as well."""@en ;
  curric:correction """Consider squares - all squares have the same angles and are visually
  identical but if the lengths are different they're not congruent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146878Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-equations-straight-lines
  a curric:Misconception ;
  curric:statement """Pupils may think all equations are for straight lines so can be plotted from 2
  points."""@en ;
  curric:correction """Explore different relationships, most relationships are not linear but we
  focus a lot on linear relationships and their unique structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146884Z"^^xsd:dateTime .

oakcurric:misconception-impossible-tell-174-368-sequence
  a curric:Misconception ;
  curric:statement "It is impossible to tell if 174 368 is in the sequence -8,-3,2,7, ..."@en ;
  curric:correction """Generalising the rule for forming a given sequence can help us see if a value
  is in the sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146890Z"^^xsd:dateTime .

oakcurric:misconception-finding-probability-outcome-based-frequency
  a curric:Misconception ;
  curric:statement """When finding the probability of an outcome based on a frequency table, pupils
  may use the number of different categories as the denominator rather than the total
  frequency."""@en ;
  curric:correction """When strawberry flavoured sweets have a frequency of 11, it means that 11 of
  the sweets in the box are strawberry flavoured. The box of sweets could be visually
  represented with each sweet being shown by the first letter of its flavour."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146895Z"^^xsd:dateTime .

oakcurric:misconception-arithmetic-sequence-5n-2-starts
  a curric:Misconception ;
  curric:statement """The arithmetic sequence 5n+2 starts at 7 so the linear equation y=5x+2
  'starts' somewhere."""@en ;
  curric:correction """y=5x+2 has no start and no end; it goes on infinitely. However, all linear
  equations have a y-intercept and this helps define them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146901Z"^^xsd:dateTime .

oakcurric:misconception-students-unsure-start-problem-solving
  a curric:Misconception ;
  curric:statement "Students are unsure where to start on problem solving questions."@en ;
  curric:correction """Starting with one sentence at a time and isolating what the strategy is first
  before doing any calculation is important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147433Z"^^xsd:dateTime .

oakcurric:misconception-choosing-find-product-denominators-order
  a curric:Misconception ;
  curric:statement """Choosing to the find the product of the denominators in order to compare
  fractions."""@en ;
  curric:correction """Although this is not wrong it can be inefficient. This can be illustrated
  using large denominators which have a much lower HCF."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150526Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-decimals-use-column
  a curric:Misconception ;
  curric:statement """When pupils multiply decimals, they use the column method and align the
  decimal points."""@en ;
  curric:correction """If the column method is used, encourage integer multiplication and use of
  powers of 10 to adjust the answer to the original calculation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151500Z"^^xsd:dateTime .

oakcurric:misconception-root-integer-half-integer
  a curric:Misconception ;
  curric:statement "The root of an integer is half of the integer."@en ;
  curric:correction """The square root is the inverse of a square number. A square is the product of
  2 repeated integers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151512Z"^^xsd:dateTime .

oakcurric:misconception-pupils-convinced-right-angled-triangle
  a curric:Misconception ;
  curric:statement "Pupils may not be convinced that a right angled triangle is formed."@en ;
  curric:correction """For the model, we assume that the terrain feature is perpendicular to the
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152719Z"^^xsd:dateTime .

oakcurric:misconception-students-consider-last-2-digits
  a curric:Misconception ;
  curric:statement """Often students only consider the last 2 digits of a number to check for
  divisibility for 8."""@en ;
  curric:correction "The last 2 digits check for divisibility for 4 not 8."@en ;
  dcterms:modified "2026-06-07T15:30:15.152736Z"^^xsd:dateTime .

oakcurric:misconception-outcome-tables-outcome-trees-work
  a curric:Misconception ;
  curric:statement """Outcome tables and outcome trees only work for outcomes that are all equally
  likely."""@en ;
  curric:correction """Outcome tables can be separated into more rows and columns, and outcome trees
  split into more branches, to show outcomes that are more or less likely than other ones.
  This does mean these diagrams do get massive very quickly!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.153142Z"^^xsd:dateTime .

oakcurric:misconception-use-negatives-confused-subtractions
  a curric:Misconception ;
  curric:statement "The use of negatives are confused with subtractions."@en ;
  curric:correction """Writing the negative numbers in brackets and using the additive inverse will
  help minimise errors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155742Z"^^xsd:dateTime .

oakcurric:misconception-finding-product-integers-fractional-parts
  a curric:Misconception ;
  curric:statement """Only finding the product of the integers and fractional parts when multiplying
  mixed numbers."""@en ;
  curric:correction """Link back to the area model, there will be 2 parts which they have not found
  the area of."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157161Z"^^xsd:dateTime .

oakcurric:misconception-common-multiplier-number-seen-common
  a curric:Misconception ;
  curric:statement """The common multiplier is the number seen to be common eg. 1.2 x 20 + 1.2 x 30
  + 1.2 x 10"""@en ;
  curric:correction """Students can use the associative law to find more common multipliers eg. 1.2
  x 10 x 2 + 1.2 x 10 x3 + 1.2 x 10 = 12 x 2 + 12 x 3 + 12 x 1"""@en ;
  dcterms:modified "2026-06-07T15:30:15.157167Z"^^xsd:dateTime .

oakcurric:misconception-real-life-measurements-arent-integers
  a curric:Misconception ;
  curric:statement """Real life measurements aren't always integers. Use of integers can give more a
  practical application"""@en ;
  curric:correction """e.g. find the largest with 200 blocks, the cbrt(200) is not an integer so we
  use 5 x 5 x 5 =125"""@en ;
  dcterms:modified "2026-06-07T15:30:15.157177Z"^^xsd:dateTime .

oakcurric:misconception-factors-mentioned-lesson-factors-consider
  a curric:Misconception ;
  curric:statement """The factors mentioned in the lesson are the only factors to consider when
  considering costs/profits of livestock."""@en ;
  curric:correction """There are many more factors to consider. Pupils could research these or
  brainstorm with a partner. An example could be selling the wool from any sheep owned."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157880Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-divide-values-correctly
  a curric:Misconception ;
  curric:statement """Pupils may struggle to divide values correctly to find a multiplier,
  especially when fractional."""@en ;
  curric:correction """Pupils should write their sequence out with arrows to show which direction
  their multiplier is operating."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157893Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-amount-proportion-e
  a curric:Misconception ;
  curric:statement """Pupils only see the amount, not proportion. e.g £30 from £100 is no different
  to £30 from £60."""@en ;
  curric:correction """Referring to the whole using bar models or fractions can emphasise the amount
  with respect to the whole."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157905Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-get-rid-integers
  a curric:Misconception ;
  curric:statement """Pupils may think they just 'get rid' of integers which appear in both
  numerator and denominator."""@en ;
  curric:correction """Reinforce that you are multiplying by 1, which doesn't change the value and
  therefore can be omitted from further calculations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158897Z"^^xsd:dateTime .

oakcurric:misconception-see-amount-proportion-e-g
  a curric:Misconception ;
  curric:statement """Only see the amount, not proportion. E.g £30 from £100 is no different to £30
  from £60."""@en ;
  curric:correction """Referring to the whole using bar models or fractions can emphasise the amount
  with respect to the whole."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158903Z"^^xsd:dateTime .

oakcurric:misconception-pupils-select-additional-cells-cause
  a curric:Misconception ;
  curric:statement """Pupils may select additional cells which will cause their chart to look
  strange."""@en ;
  curric:correction "They can edit the data selected or delete the chart and start again."@en ;
  dcterms:modified "2026-06-07T15:30:15.160404Z"^^xsd:dateTime .

oakcurric:misconception-pupils-generalise-think-sum-possible
  a curric:Misconception ;
  curric:statement """Pupils may over generalise and think that the sum of all possible events sum
  to 1. E.g. when rolling a standard six-sided dice, P(multiple of 6) + P(factor of 6) = 1."""@en ;
  curric:correction """Emphasise that probabilities sum to 1 when the events are mutually exclusive
  and exhaustive. E.g. in the calculation P(multiple of 6) + P(factor of 6), the outcome '6'
  is counted twice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160608Z"^^xsd:dateTime .

oakcurric:misconception-find-one-part-students-simply
  a curric:Misconception ;
  curric:statement """To find one part, some students simply divide the amount by the sum of the
  'parts' of the ratio."""@en ;
  curric:correction """Strengthen understanding of which amount represents which part of the ratio.
  Matching problems to bar models helps."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161161Z"^^xsd:dateTime .

oakcurric:misconception-absolute-value-considered-integer-its
  a curric:Misconception ;
  curric:statement """That just the absolute value is considered and not the integer in its
  entirety."""@en ;
  curric:correction """Encourage pupils to consider the integers as temperatures even if there are
  no temperature units."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162442Z"^^xsd:dateTime .

oakcurric:misconception-tan-60-double-tan-30
  a curric:Misconception ;
  curric:statement "tan(60°) is double tan(30°)."@en ;
  curric:correction """The values of tan of an angle do not scale linearly. From the unit circle, we
  see that an angle of 30° meets a tangent to the circle at a height of approx. 0.58 units,
  whilst an angle of 60° meets the same tangent at a height of approx. 1.73 units."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162448Z"^^xsd:dateTime .

oakcurric:misconception-seeing-amount-proportion-e-g
  a curric:Misconception ;
  curric:statement """Only seeing the amount, not proportion. E.g £30 from £100 is no different to
  £30 from £60."""@en ;
  curric:correction """Referring to the whole using bar models or fractions can emphasise the amount
  with respect to the whole."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162453Z"^^xsd:dateTime .

oakcurric:misconception-converting-fraction-recurring-decimal-rounding
  a curric:Misconception ;
  curric:statement """Converting a fraction to a recurring decimal and then rounding the decimal,
  gives an accurate answer"""@en ;
  curric:correction """The use of fractions is more preferred for accuracy than decimals. e.g 1/3 +
  1/3 + 1/3 is not 0.3 + 0.3 + 0.3"""@en ;
  dcterms:modified "2026-06-07T15:30:15.164243Z"^^xsd:dateTime .

oakcurric:misconception-truncating-pupils-tempted-round-truncating
  a curric:Misconception ;
  curric:statement """When truncating, pupils are tempted to round. Also, when truncating, they cut
  off the number without thinking about the magnitude."""@en ;
  curric:correction """The use of the place value table shows the magnitude of the number, thus
  preserving their place value when truncating."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164875Z"^^xsd:dateTime .

oakcurric:misconception-equations-contain-brackets-need-expand
  a curric:Misconception ;
  curric:statement """If equations contain brackets you always need to expand them before
  solving."""@en ;
  curric:correction """Try to encourage pupils to use their factors and multiples knowledge to
  decide if it is more efficient to expand first or not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164881Z"^^xsd:dateTime .

oakcurric:misconception-convert-same-unit-decide-measure
  a curric:Misconception ;
  curric:statement """You have to convert to the same unit to decide if a measure is the same as
  another."""@en ;
  curric:correction """For metric units it is possible to compare the digits. Any conversion within
  metric has the same digits in the same order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164886Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-improvement-comes-choosing
  a curric:Misconception ;
  curric:statement """Pupils may think that improvement comes from choosing the maximum options for
  training straight away."""@en ;
  curric:correction """In order to protect the body and give it time to adjust/grow, coaches will
  gradually increase the intensity of a training programme. This helps to prevent injury to
  the athlete."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165133Z"^^xsd:dateTime .

oakcurric:misconception-gradient-line-given-equation-line
  a curric:Misconception ;
  curric:statement """That the gradient of a line given the equation of the line is always just the
  coefficient of the x term."""@en ;
  curric:correction "Using graphing software to explore this could help."@en ;
  dcterms:modified "2026-06-07T15:30:15.165154Z"^^xsd:dateTime .

oakcurric:misconception-10-3-means-10-x
  a curric:Misconception ;
  curric:statement "10^3 means 10 x 3"@en ;
  curric:correction "10 x 3 = 30.  10^3 = 10 x 10 x 10 = 1000."@en ;
  dcterms:modified "2026-06-07T15:30:15.165160Z"^^xsd:dateTime .

oakcurric:misconception-dividing-fraction-integer-divide-numerator
  a curric:Misconception ;
  curric:statement """When dividing a fraction by an integer, some divide the numerator and
  denominator by the integer."""@en ;
  curric:correction """Embed the understanding that when dividing by an integer, only the numerator
  is divided as the number of equal parts remains the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165420Z"^^xsd:dateTime .

oakcurric:misconception-decimal-places-greater-number
  a curric:Misconception ;
  curric:statement "The more decimal places there are, the greater the number."@en ;
  curric:correction """Pupils can investigate this by looking at the numbers 0.23 and 0.1237 and
  using a common denominator or 10000."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165714Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-statements-logic-part
  a curric:Misconception ;
  curric:statement """Pupils may struggle with the 'and' statements in the logic part of the
  lesson."""@en ;
  curric:correction """For the statement to be true, the whole statement must be true. This refers
  to both clauses that are joined by the word 'and'. If even one of the clauses is not true,
  then the entire statement can be declared not true (even if one clause is true)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165725Z"^^xsd:dateTime .

oakcurric:misconception-subject-formula-first-term-formula
  a curric:Misconception ;
  curric:statement "The subject of a formula is just the first term in the formula."@en ;
  curric:correction """Draw attention to the variety of equations and formulae used in the
  lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165980Z"^^xsd:dateTime .

oakcurric:misconception-rounding-prematurely-multi-step-calculations
  a curric:Misconception ;
  curric:statement "Rounding prematurely during multi-step calculations."@en ;
  curric:correction """Encourage to use of fractions (where possible) or the use of the ANS
  button."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166101Z"^^xsd:dateTime .

oakcurric:misconception-sequences-arithmetic-linear-geometric
  a curric:Misconception ;
  curric:statement "All sequences have to be arithmetic (linear) or geometric."@en ;
  curric:correction """There are many types of sequences; arithmetic and geometric are just two
  types."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166125Z"^^xsd:dateTime .

oakcurric:misconception-incorrect-use-error-interval-e
  a curric:Misconception ;
  curric:statement """Incorrect use of the error interval i.e $$a ≤ x ≤ b$$ or writing the error
  interval as $$a ≤ x > b$$"""@en ;
  curric:correction """As a check, encourage students to round the upper limit interval by the
  degree of accuracy to see if it evaluates to the rounded number. Also, draw a number line
  to show the meaning of $$a ≤ x > b$$ and allow students to see the error."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166209Z"^^xsd:dateTime .

oakcurric:misconception-changing-fractions-decimals-common-format
  a curric:Misconception ;
  curric:statement """Changing all fractions and decimals to a common format without considering
  obvious comparisons."""@en ;
  curric:correction """This could be an opportunity to talk about familiar conversions including
  halves, quarters and fifths."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166376Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-summing-digits-integer-identify
  a curric:Misconception ;
  curric:statement "Incorrectly summing the digits of an integer to identify a multiple of 3."@en ;
  curric:correction "Use number bonds to sum large numbers of digits."@en ;
  dcterms:modified "2026-06-07T15:30:15.166384Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-coefficient-b-2b
  a curric:Misconception ;
  curric:statement "Pupils may think the coefficient of b in a-2b is 2 instead of -2 ."@en ;
  curric:correction """Show subtraction as addition of a negative value. This can be done with
  negative algebra tiles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166498Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-whether-image-rotational
  a curric:Misconception ;
  curric:statement "Pupils may be uncertain as to whether an image has rotational symmetry."@en ;
  curric:correction """Tracing paper may be useful here. Pupils can trace the image and then rotate
  the tracing paper to determine if an image has rotational symmetry."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166565Z"^^xsd:dateTime .

oakcurric:misconception-calculator-rounds-recurring-non-terminating
  a curric:Misconception ;
  curric:statement """The calculator rounds recurring/non-terminating decimals to 10 d.p. and it is
  not terminating."""@en ;
  curric:correction """The fractional form will give a clearer idea if the decimal equivalent is
  terminating or not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166570Z"^^xsd:dateTime .

oakcurric:misconception-0-0004-one-thousand-times
  a curric:Misconception ;
  curric:statement """That 0.0004 is one thousand times smaller than 4 as there are three zeros
  after the decimal point."""@en ;
  curric:correction """The use of a place value or Gattegno chart is invaluable here to highlight
  this misconception . The 4 is in the 10 thousandths column."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166577Z"^^xsd:dateTime .

oakcurric:misconception-difference-given-terms-divided-number
  a curric:Misconception ;
  curric:statement """The difference in the given terms divided by the number of missing terms gives
  the common difference"""@en ;
  curric:correction """Write the sequence out with gaps for the missing terms. Model how many
  additions (jumps) to get from one known term to the next."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166652Z"^^xsd:dateTime .

oakcurric:misconception-working-counters-students-count-them
  a curric:Misconception ;
  curric:statement """When working with counters students may count them and not appreciate they
  represent negatives."""@en ;
  curric:correction """Stress the importance of 2 different coloured counters as there is a need to
  represent positive and negative integers differently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166810Z"^^xsd:dateTime .

oakcurric:misconception-2-3y-9-factorised
  a curric:Misconception ;
  curric:statement "2(3y+9) is not factorised."@en ;
  curric:correction """It is factorised; just not fully. The distinction is important as sometimes
  it can be beneficial to not fully factorise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168220Z"^^xsd:dateTime .

oakcurric:misconception-pupils-write-a3-instead-3a
  a curric:Misconception ;
  curric:statement "Pupils may write a3 instead of 3a to represent multiplication of a and 3."@en ;
  curric:correction """Use algebra tiles to show a x 3 gives 3 lots of a. Highlight that conventions
  make mathematics clearer to read and avoids miscommunication."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168389Z"^^xsd:dateTime .

oakcurric:misconception-rather-learning-rearrange-multiplicative-relationships
  a curric:Misconception ;
  curric:statement """Rather than learning to rearrange multiplicative relationships pupils can just
  learn the rearrangements or use a trick."""@en ;
  curric:correction """There are many situations in school and out where this skill is valuable and
  understanding how to manipulate these relationships will help pupils to understand the
  mathematics rather than just learn a set of procedures or lots of formulae."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168607Z"^^xsd:dateTime .

oakcurric:misconception-different-bases-used-student-multiply
  a curric:Misconception ;
  curric:statement """When different bases are used student multiply the bases. e.g. 2 x 5^2
  = 10^2"""@en ;
  curric:correction "Calculate and compare the 2, 2 x 5^2 = 50 & 10^2 = 100"@en ;
  dcterms:modified "2026-06-07T15:30:15.168749Z"^^xsd:dateTime .

oakcurric:misconception-errors-zero-required-rounding-e
  a curric:Misconception ;
  curric:statement """Errors when a zero is required when rounding. E.g 5.99 rounds to 6 to
  1 d.p."""@en ;
  curric:correction """Embedding that 6 and 6.0 may be written like that to convey the accuracy
  they've been rounded to. To show that 5.99 has been rounded to 1 d.p. we write it as 6.0
  not 6."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168837Z"^^xsd:dateTime .

oakcurric:misconception-negative-exponent-implies-entire-value
  a curric:Misconception ;
  curric:statement "A negative exponent implies that the entire value is negative."@en ;
  curric:correction """Refer back to the table showing the structure of how the negative exponents
  occur and highlight that none of the decimal values are negative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169068Z"^^xsd:dateTime .

oakcurric:misconception-assumption-cannot-find-fraction-greater
  a curric:Misconception ;
  curric:statement "An assumption that you cannot find a fraction greater than 1 of an amount."@en ;
  curric:correction """Recognising that 'of' and multiplication are equivalent should help with this
  , as pupils are familiar with multiplying fractions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169075Z"^^xsd:dateTime .

oakcurric:misconception-simply-adding-subtracting-numerators-denominators
  a curric:Misconception ;
  curric:statement "Simply adding or subtracting the numerators and denominators."@en ;
  curric:correction """Emphasise that the denominator tells us the name of the unit. In order to add
  or subtract things they must have a common name."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169102Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-cost-per-hour
  a curric:Misconception ;
  curric:statement """Pupils may think the cost per hour can be reduced if less than an hour is
  required (venue hire)."""@en ;
  curric:correction """This may be possible but should not be assumed when costing for an event as
  otherwise this could lead to a loss rather than a profit. If unknown, assume not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169108Z"^^xsd:dateTime .

oakcurric:misconception-brackets-expanded-solve-equation-brackets
  a curric:Misconception ;
  curric:statement """That all brackets have to be expanded before we solve an equation with
  brackets it in."""@en ;
  curric:correction """How would you solve $$2y=50$$? You would divide both sides by $$2$$. So why
  not start with 'divide $$2$$' when solving $$2(y-7)=50$$?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.169113Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-5-y-1
  a curric:Misconception ;
  curric:statement "Pupils may think 5(y+1)-2(y+3) = 5y+5-2y+6"@en ;
  curric:correction """Correct use of the distributive law with either algebra tiles or an area
  model will demonstrate why this is wrong."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169219Z"^^xsd:dateTime .

oakcurric:misconception-reducing-cost-increase-sales-best
  a curric:Misconception ;
  curric:statement "Reducing the cost to increase sales is always the best option."@en ;
  curric:correction """Although this may seem a good idea, increasing the number of units sold means
  increasing the amount made and therefore the cost to the business. Therefore the situation
  needs to be carefully considered."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169307Z"^^xsd:dateTime .

oakcurric:misconception-misinterpreting-values-expression-n-th
  a curric:Misconception ;
  curric:statement """Misinterpreting the values in an expression for the n^th term. For example,
  given the n^th term $$3n-5$$ pupils may think that this relates to a sequence that is
  decreasing by 5 each time"""@en ;
  curric:correction """Remind students about how the expression for the n^th term relates to
  multiples of a number (times tables) and then a shift. For example, 4, 9, 14, 19, ... can
  be seen as the 5 times table shifted down 1."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169312Z"^^xsd:dateTime .

oakcurric:misconception-students-forget-scroll-right-exit
  a curric:Misconception ;
  curric:statement "Students forget to scroll right to exit the exponent function."@en ;
  curric:correction """Encourage students to check what they have on their screen matches the
  calculation exactly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169318Z"^^xsd:dateTime .

oakcurric:misconception-pupil-get-confused-increasing-decreasing
  a curric:Misconception ;
  curric:statement """Pupil can often get confused with increasing and decreasing an amount e.g
  Increase 45 by 23% and decreasing 45 by 23% have the same multiplier."""@en ;
  curric:correction """Encourage students to draw double number lines or ratio tables so they can
  see the increase and multiplier or decrease and multiplier."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169572Z"^^xsd:dateTime .

oakcurric:misconception-pupils-multiply-5-turn-2x
  a curric:Misconception ;
  curric:statement """Pupils often \"multiply through by $$5$$\" and turn $${{2x+1}\\over5}={10}$$
  into $${{10x+5}}={50}$$"""@en ;
  curric:correction """Use equivalent fractions as opposed to multiplying through. In one simple
  step $${{2x+1}\\over5}={10}$$ becomes $${{2x+1}\\over5}={50\\over5}$$"""@en ;
  dcterms:modified "2026-06-07T15:30:15.170163Z"^^xsd:dateTime .

oakcurric:misconception-fractions-compared-using-common-denominator
  a curric:Misconception ;
  curric:statement "That fractions can only be compared using a common denominator."@en ;
  curric:correction """Lots of visual representations are useful here looking at what happens to the
  size of the 'parts' as the denominator increases."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170269Z"^^xsd:dateTime .

oakcurric:misconception-confusing-unfamiliar-units-measure
  a curric:Misconception ;
  curric:statement "Confusing unfamiliar units of measure."@en ;
  curric:correction """Pupils may benefit from having two lists of metric and imperial measures to
  reference should they need to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170275Z"^^xsd:dateTime .

oakcurric:misconception-using-phrase-2-negatives-make
  a curric:Misconception ;
  curric:statement "Using the phrase '2 negatives make a positive'."@en ;
  curric:correction """Ensuring pupils understand the structure of the maths and not 'tricks' is so
  important. Encourage the use of correct language at all times"""@en ;
  dcterms:modified "2026-06-07T15:30:15.170498Z"^^xsd:dateTime .

oakcurric:misconception-longer-digits-number-greater
  a curric:Misconception ;
  curric:statement "A \"longer\" (with more digits) number must be greater."@en ;
  curric:correction "35.67208 < 36"@en ;
  dcterms:modified "2026-06-07T15:30:15.170508Z"^^xsd:dateTime .

oakcurric:misconception-mistakes-partial-products-even-common
  a curric:Misconception ;
  curric:statement """Mistakes with partial products are even more common where algebraic terms in
  the binomials have coefficients greater than 1. It is common to find pupils writing that
  the product of 2x and 3x is 5x"""@en ;
  curric:correction """Reminding pupils that because multiplication is commutative the product of 2x
  and 3x can be thought of as 2 × 3 × x × x"""@en ;
  dcterms:modified "2026-06-07T15:30:15.170613Z"^^xsd:dateTime .

oakcurric:misconception-sequences-either-arithmetic-geometric
  a curric:Misconception ;
  curric:statement "Sequences are either arithmetic or geometric."@en ;
  curric:correction """There are many ways sequences can be generated and you can usually find more
  than one rule than can fit the first few terms of a sequence. Exploring these will ensure
  pupils don't have a narrow experience of sequences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170618Z"^^xsd:dateTime .

oakcurric:misconception-partitioning-mixed-numbers-subtracting-incorrectly
  a curric:Misconception ;
  curric:statement """When partitioning mixed numbers and subtracting incorrectly subtracting the
  fractional part."""@en ;
  curric:correction """Use an integer example to show the structure of partitioning. E.g. 28 - 15 =
  (20 + 8) - (10 + 5) = (20 - 10) + (8 - 5) not (20 - 10)-(8 - 5)"""@en ;
  dcterms:modified "2026-06-07T15:30:15.170733Z"^^xsd:dateTime .

oakcurric:misconception-pupils-add-together-costs-expressed
  a curric:Misconception ;
  curric:statement """Pupils may add together costs that are expressed in different units (e.g. the
  cost of petrol in pence and the cost of a car park in pounds) without considering the
  implications on place value."""@en ;
  curric:correction """Writing units on your answers to each stage of working can help you to double
  check whether numbers in subsequent calculations are expressed in the same units."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170738Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-summing-digits-identify-multiple
  a curric:Misconception ;
  curric:statement "Incorrectly summing the digits to identify a multiple of 3 or 9."@en ;
  curric:correction "Use number bonds to sum large numbers of digits."@en ;
  dcterms:modified "2026-06-07T15:30:15.170952Z"^^xsd:dateTime .

oakcurric:misconception-number-largest-value-greatest-measurement
  a curric:Misconception ;
  curric:statement "The number with the largest value is the greatest measurement."@en ;
  curric:correction """Converting to the same unit can be helpful before comparing the place value
  of the digits. e.g. 0.4 m is bigger than 40 mm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171108Z"^^xsd:dateTime .

oakcurric:misconception-assumption-number-ends-2-zeros
  a curric:Misconception ;
  curric:statement """The assumption that if a number ends in 2 zeros it must have been rounded to
  the nearest hundred."""@en ;
  curric:correction """Choose examples that round to the same value when rounded to the nearest ten
  and hundred in this case. E.g. 398, rounds to 400 to the nearest ten and 400 to the
  nearest hundred."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171233Z"^^xsd:dateTime .
