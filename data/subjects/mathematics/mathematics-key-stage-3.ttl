  a curric:KeyLearningPoint ;
  rdfs:label "Certain statistical measures may not make sense within the context of the data."@en ;
  dcterms:modified "2026-06-07T15:30:29.380396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20046-1
  a curric:KeyLearningPoint ;
