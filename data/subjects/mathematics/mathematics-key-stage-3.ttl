  schema:description "Clockwise is the direction that the hands of an analogue clock travel"@en ;
  dcterms:modified "2026-06-07T15:30:02.360573Z"^^xsd:dateTime .

oakcurric:keyword-pie-chart
  a curric:Keyword ;
  schema:name "Pie chart"@en ;
  schema:description """A pie chart (pie graph) is a circular graph where sectors represent
