  dcterms:modified "2026-06-07T15:30:02.360589Z"^^xsd:dateTime .

oakcurric:keyword-surface-area
  a curric:Keyword ;
  schema:name "surface area"@en ;
  schema:description "Surface area is the area of a surface."@en ;
  dcterms:modified "2026-06-07T15:30:02.360636Z"^^xsd:dateTime .

oakcurric:keyword-improper-fraction
  a curric:Keyword ;
