  dcterms:modified "2026-06-07T15:30:02.363326Z"^^xsd:dateTime .

oakcurric:keyword-integer
  a curric:Keyword ;
  schema:name "Integer"@en ;
  schema:description """An integer is any positive or negative whole number or zero. E.g. -2, 0, 153
  are all examples of integers."""@en ;
  dcterms:modified "2026-06-07T15:30:02.363357Z"^^xsd:dateTime .

oakcurric:keyword-place-value
  a curric:Keyword ;
  schema:name "place value"@en ;
  schema:description "a digit's value based on its position in a number"@en ;
  dcterms:modified "2026-06-07T15:30:02.363714Z"^^xsd:dateTime .

oakcurric:keyword-outcome
  a curric:Keyword ;
  schema:name "outcome"@en ;
  schema:description "the finished artwork created by an artist after planning and development"@en ;
  dcterms:modified "2026-06-07T15:30:02.364159Z"^^xsd:dateTime .

oakcurric:keyword-base
  a curric:Keyword ;
  schema:name "base"@en ;
  schema:description "A substance that neutralises an acid to form a salt and water."@en ;
  dcterms:modified "2026-06-07T15:30:02.364583Z"^^xsd:dateTime .

oakcurric:keyword-reflection
  a curric:Keyword ;
  schema:name "reflection"@en ;
  schema:description "a careful thought or consideration"@en ;
  dcterms:modified "2026-06-07T15:30:02.364787Z"^^xsd:dateTime .

oakcurric:keyword-term
