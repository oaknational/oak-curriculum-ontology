# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-183-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a multiplicative relationship between the ratio parts, and other equivalent
  ratios."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-183-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ratios can be expressed as fractions."@en ;
  dcterms:modified "2026-06-07T15:30:29.004242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-183-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are infinitely many equivalent fractions."@en ;
  dcterms:modified "2026-06-07T15:30:29.004246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-183-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are infinitely many equivalent ratios."@en ;
  dcterms:modified "2026-06-07T15:30:29.004251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any subtraction can be re-written as an equivalent addition."@en ;
  dcterms:modified "2026-06-07T15:30:29.251926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9865-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting a postive number is the same as adding a negative number."@en ;
  dcterms:modified "2026-06-07T15:30:29.251931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9865-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subtracting a negative number is the same as adding a positive number."@en ;
  dcterms:modified "2026-06-07T15:30:29.251936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-85-1
  a curric:KeyLearningPoint ;
  rdfs:label "The decimal point determines the place value of each digit."@en ;
  dcterms:modified "2026-06-07T15:30:29.260212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-85-2
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator needs the decimal point to determine the place value of each digit."@en ;
  dcterms:modified "2026-06-07T15:30:29.260216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-85-3
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator produces the correct answer for the values inputted."@en ;
  dcterms:modified "2026-06-07T15:30:29.260220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-85-4
  a curric:KeyLearningPoint ;
  rdfs:label "The answer can be checked to see if it appears too big or too small."@en ;
  dcterms:modified "2026-06-07T15:30:29.260224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-109-1
  a curric:KeyLearningPoint ;
  rdfs:label "In order to compare metric measures, conversion may be necessary."@en ;
  dcterms:modified "2026-06-07T15:30:29.262657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-109-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metric measures can be converted by using place value."@en ;
  dcterms:modified "2026-06-07T15:30:29.262661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Real-world examples can help us see if the conversions have the correct
  magnitude."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-174-1
  a curric:KeyLearningPoint ;
  rdfs:label "When calculating with fractions and decimals, a common form can be easier."@en ;
  dcterms:modified "2026-06-07T15:30:29.263642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-174-2
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator removes the need for a common form."@en ;
  dcterms:modified "2026-06-07T15:30:29.263647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-174-3
  a curric:KeyLearningPoint ;
  rdfs:label "The commutative law can be applied to make calculations easier."@en ;
  dcterms:modified "2026-06-07T15:30:29.263652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-300-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scatter graphs can be constructed quickly using spreadsheets."@en ;
  dcterms:modified "2026-06-07T15:30:29.265548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-300-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scatter graphs can be constructed quickly using Desmos."@en ;
  dcterms:modified "2026-06-07T15:30:29.265553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-300-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing which axis is used for which variable affects how the scatter graph
  appears."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-297-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pie charts can be constructed quickly using Excel."@en ;
  dcterms:modified "2026-06-07T15:30:29.266379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-297-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angle of each part can be quickly calculated in Excel."@en ;
  dcterms:modified "2026-06-07T15:30:29.266385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-297-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of pie chart can be created."@en ;
  dcterms:modified "2026-06-07T15:30:29.266389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-223-1
  a curric:KeyLearningPoint ;
  rdfs:label "All numbers can be rounded to a given number of significant figures."@en ;
  dcterms:modified "2026-06-07T15:30:29.267247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-223-2
  a curric:KeyLearningPoint ;
  rdfs:label "Estimating gives you an idea of the size of an answer in context."@en ;
  dcterms:modified "2026-06-07T15:30:29.267251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-223-3
  a curric:KeyLearningPoint ;
  rdfs:label "To estimate an answer you will often round to one significant figure."@en ;
  dcterms:modified "2026-06-07T15:30:29.267255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-223-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes it makes sense to round to a different degree of accuracy when making an
  estimate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-180-1
  a curric:KeyLearningPoint ;
  rdfs:label """By expressing the multiplicative relationship as a ratio, it can be easier to scale
  further."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-180-2
  a curric:KeyLearningPoint ;
  rdfs:label "The relationship can be represented using a bar model."@en ;
  dcterms:modified "2026-06-07T15:30:29.269485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-180-3
  a curric:KeyLearningPoint ;
  rdfs:label "A bar model shows both parts of the ratio as well as the whole."@en ;
  dcterms:modified "2026-06-07T15:30:29.269489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-180-4
  a curric:KeyLearningPoint ;
  rdfs:label "A multiplicative relationship can be expressed as a fraction."@en ;
  dcterms:modified "2026-06-07T15:30:29.269493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-180-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different ways to express the relationship."@en ;
  dcterms:modified "2026-06-07T15:30:29.269497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20020-1
  a curric:KeyLearningPoint ;
  rdfs:label "Weather reports contain a considerable amount of data"@en ;
  dcterms:modified "2026-06-07T15:30:29.270316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20020-2
  a curric:KeyLearningPoint ;
  rdfs:label "This data can be interpreted in real terms"@en ;
  dcterms:modified "2026-06-07T15:30:29.270319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20020-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weather data can help when making decisions"@en ;
  dcterms:modified "2026-06-07T15:30:29.270323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-376-1
  a curric:KeyLearningPoint ;
  rdfs:label """Right-angled triangles can be seen in real-life (e.g. ladder against a vertical
  wall)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-376-2
  a curric:KeyLearningPoint ;
  rdfs:label """A ratio table can help you find the scalar and functional multipliers in similar
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-376-3
  a curric:KeyLearningPoint ;
  rdfs:label """It can be initially difficult to identify whether Pythagoras' theorem can be
  used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-86-1
  a curric:KeyLearningPoint ;
  rdfs:label "Negative numbers are present in everyday life."@en ;
  dcterms:modified "2026-06-07T15:30:29.271243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-86-2
  a curric:KeyLearningPoint ;
  rdfs:label "Negative numbers exist as they represent values below an agreed zero."@en ;
  dcterms:modified "2026-06-07T15:30:29.271247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-86-3
  a curric:KeyLearningPoint ;
  rdfs:label "It can help to think of a context when doing a calculation."@en ;
  dcterms:modified "2026-06-07T15:30:29.271250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-318-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphical representations should effectively represent the data."@en ;
  dcterms:modified "2026-06-07T15:30:29.287670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-318-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some graphical representations are easier to understand than others."@en ;
  dcterms:modified "2026-06-07T15:30:29.287674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Graphical representations may be chosen to emphasise a particular conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.287680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-346-1
  a curric:KeyLearningPoint ;
  rdfs:label "Exterior angles of a regular polygon are equal."@en ;
  dcterms:modified "2026-06-07T15:30:29.320008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-346-2
  a curric:KeyLearningPoint ;
  rdfs:label "The size of the exterior angle of a regular polygon can be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.320012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-346-3
  a curric:KeyLearningPoint ;
  rdfs:label "Interior angles of regular polygons are equal."@en ;
  dcterms:modified "2026-06-07T15:30:29.320016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-346-4
  a curric:KeyLearningPoint ;
  rdfs:label "The size of the interior angle of a regular polygon can be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.320020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-346-5
  a curric:KeyLearningPoint ;
  rdfs:label """The number of sides in a regular polygon can be determined from the size of the
  interior or exterior angle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-87-1
  a curric:KeyLearningPoint ;
  rdfs:label "It can help to think of a context when doing a calculation."@en ;
  dcterms:modified "2026-06-07T15:30:29.323484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-87-2
  a curric:KeyLearningPoint ;
  rdfs:label "Addition of negative integers can be made easier by considering zero pairs."@en ;
  dcterms:modified "2026-06-07T15:30:29.323487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-87-3
  a curric:KeyLearningPoint ;
  rdfs:label """Addition of large negative integers can be made easier using partioning to make zero
  pairs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-200-1
  a curric:KeyLearningPoint ;
  rdfs:label "The length of the lines do not change when rotated"@en ;
  dcterms:modified "2026-06-07T15:30:29.324387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-200-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angles inside an object do not change when rotated"@en ;
  dcterms:modified "2026-06-07T15:30:29.324393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-200-3
  a curric:KeyLearningPoint ;
  rdfs:label "When an object is rotated, its image is congruent"@en ;
  dcterms:modified "2026-06-07T15:30:29.324399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-200-4
  a curric:KeyLearningPoint ;
  rdfs:label """Unless a full rotation occurs, the object and its image will not have the same
  orientation"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the squares of the two shorter sides equals the square of the longest
  side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the squares of the longest and known shorter sides is the
  square of the remaining side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-3
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator can perform these calculations efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:29.330956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rounding gives a less accurate answer so there might be times you wish to leave your
  answer with an operator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-1
  a curric:KeyLearningPoint ;
  rdfs:label "If two triangles are congruent, then one of the proven criteria must apply."@en ;
  dcterms:modified "2026-06-07T15:30:29.331630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-2
  a curric:KeyLearningPoint ;
  rdfs:label """By stating the criteria (that you have already proven), you can prove
  congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-370-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to be clear why you know that two triangles are congruent."@en ;
  dcterms:modified "2026-06-07T15:30:29.331639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-365-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing the three side lengths of the triangle and its image, you can prove
  congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-365-2
  a curric:KeyLearningPoint ;
  rdfs:label "The corresponding angle pairs will be the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.333148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-1
  a curric:KeyLearningPoint ;
  rdfs:label "An enlargement means a change in size."@en ;
  dcterms:modified "2026-06-07T15:30:29.333710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-2
  a curric:KeyLearningPoint ;
  rdfs:label "The lengths of the lines may change when enlarged."@en ;
  dcterms:modified "2026-06-07T15:30:29.333714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angles inside an object do not change when enlarged."@en ;
  dcterms:modified "2026-06-07T15:30:29.333718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-359-4
  a curric:KeyLearningPoint ;
  rdfs:label "When an object is enlarged, the image is similar."@en ;
  dcterms:modified "2026-06-07T15:30:29.333722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-374-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hypotenuse is the side opposite the right angle."@en ;
  dcterms:modified "2026-06-07T15:30:29.333726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-374-2
  a curric:KeyLearningPoint ;
  rdfs:label "It does not matter which of the shorter sides is identified as a or b."@en ;
  dcterms:modified "2026-06-07T15:30:29.333730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two shapes are not similar if there is a pair of lengths with a different
  multiplicative relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-2
  a curric:KeyLearningPoint ;
  rdfs:label "Similar shapes are not always easy to spot visually."@en ;
  dcterms:modified "2026-06-07T15:30:29.333887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ratio table can help you find the scalar and functional multipliers in similar
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-4
  a curric:KeyLearningPoint ;
  rdfs:label "The angle sizes do not change."@en ;
  dcterms:modified "2026-06-07T15:30:29.333896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-367-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing two angles and a length in the triangle and image, you can prove
  congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-367-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angle pairs must be identical."@en ;
  dcterms:modified "2026-06-07T15:30:29.334873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-367-3
  a curric:KeyLearningPoint ;
  rdfs:label "This rule is derived from the SAS criteria for congruence."@en ;
  dcterms:modified "2026-06-07T15:30:29.334877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two shapes are not congruent if there is a pair of lengths with a scalar not equal
  to one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-2
  a curric:KeyLearningPoint ;
  rdfs:label "Congruent does not mean the orientation must be the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.334905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-362-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angle sizes do not change."@en ;
  dcterms:modified "2026-06-07T15:30:29.334910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-1
  a curric:KeyLearningPoint ;
  rdfs:label "If two shapes are congruent, then they are similar."@en ;
  dcterms:modified "2026-06-07T15:30:29.335124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-2
  a curric:KeyLearningPoint ;
  rdfs:label "Congruent shapes have a scalar of one."@en ;
  dcterms:modified "2026-06-07T15:30:29.335128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ratio table can be a helpful tool for checking the multipliers."@en ;
  dcterms:modified "2026-06-07T15:30:29.335133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-363-4
  a curric:KeyLearningPoint ;
  rdfs:label """The multiplicative relationship between the sides of the object is preserved in its
  image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-364-1
  a curric:KeyLearningPoint ;
  rdfs:label "Congruent shapes can be used to investigate rotational symmetry."@en ;
  dcterms:modified "2026-06-07T15:30:29.335143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-364-2
  a curric:KeyLearningPoint ;
  rdfs:label "The centre of rotation is the centre of the shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.335148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-364-3
  a curric:KeyLearningPoint ;
  rdfs:label "You must be careful not to count the starting point twice."@en ;
  dcterms:modified "2026-06-07T15:30:29.335152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-378-1
  a curric:KeyLearningPoint ;
  rdfs:label "Events with outcomes that are likely to not be equally likely can be identified"@en ;
  dcterms:modified "2026-06-07T15:30:29.335777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-378-2
  a curric:KeyLearningPoint ;
  rdfs:label "Outcomes that are not equally likely can be identified and compared"@en ;
  dcterms:modified "2026-06-07T15:30:29.335781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-378-3
  a curric:KeyLearningPoint ;
  rdfs:label """Factors can be identified that can cause one outcome to be more/less likely than
  another"""@en ;
  dcterms:modified "2026-06-07T15:30:29.335785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-371-1
  a curric:KeyLearningPoint ;
  rdfs:label """A visual approach can help you understand the structure behind Pythagoras'
  theorem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-371-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is a difference between proof and demonstration."@en ;
  dcterms:modified "2026-06-07T15:30:29.336163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-371-3
  a curric:KeyLearningPoint ;
  rdfs:label """A demonstration would be showing Pythagoras' theorem works for specific right-angled
  triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-371-4
  a curric:KeyLearningPoint ;
  rdfs:label """A proof is generalised i.e. using four congruent triangles arranged in a particular
  way inside a square."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-371-5
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the squares of the two shorter sides equals the square of the longest
  side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-372-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the squares of the two shorter sides equals the square of the longest
  side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-372-2
  a curric:KeyLearningPoint ;
  rdfs:label "The longest side is always opposite the right angle."@en ;
  dcterms:modified "2026-06-07T15:30:29.337429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-372-3
  a curric:KeyLearningPoint ;
  rdfs:label "A calculator can perform these calculations efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:29.337433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-372-4
  a curric:KeyLearningPoint ;
  rdfs:label "Priority of operations makes the order clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.337437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-369-1
  a curric:KeyLearningPoint ;
  rdfs:label """For a right-angled triangle, you need the hypotenuse and one other side length to
  prove congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Right-angled triangles, by definition, have a right-angle."@en ;
  dcterms:modified "2026-06-07T15:30:29.337571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-369-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a special relationship between the sides in a right-angled triangle."@en ;
  dcterms:modified "2026-06-07T15:30:29.337576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-366-1
  a curric:KeyLearningPoint ;
  rdfs:label """By knowing two side lengths and the angle between them in the triangle and image,
  you can prove congruence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-366-2
  a curric:KeyLearningPoint ;
  rdfs:label "The angle between the sides must be the same in both object and image."@en ;
  dcterms:modified "2026-06-07T15:30:29.337857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-366-3
  a curric:KeyLearningPoint ;
  rdfs:label "The given sides must have the same multiplicative relationship."@en ;
  dcterms:modified "2026-06-07T15:30:29.337861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29647-1
  a curric:KeyLearningPoint ;
  rdfs:label """A visual approach can help you understand the structure behind Pythagoras'
  theorem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29647-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is a difference between proof and demonstration."@en ;
  dcterms:modified "2026-06-07T15:30:29.337907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29647-3
  a curric:KeyLearningPoint ;
  rdfs:label """A demonstration would be showing Pythagoras' theorem works for specific right-angled
  triangles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29647-4
  a curric:KeyLearningPoint ;
  rdfs:label """A proof is generalised i.e. using four congruent triangles arranged in a particular
  way inside a square."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29647-5
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the squares of the two shorter sides equals the square of the longest
  side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-375-1
  a curric:KeyLearningPoint ;
  rdfs:label """Within context, it can be difficult to initially identify whether Pythagoras'
  theorem can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pythagoras' theorem may be used if a right-angled triangle can be drawn, even if
  drawn within a different shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pythagoras' theorem can be used to check for properties of other shapes involving
  right-angles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The column headings for decimals can be expressed in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.339193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-107-2
  a curric:KeyLearningPoint ;
  rdfs:label "A decimal can be represented by using exponentials in the column headings."@en ;
  dcterms:modified "2026-06-07T15:30:29.339197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-107-3
  a curric:KeyLearningPoint ;
  rdfs:label "A decimal can be represented by using fractions in the column headings."@en ;
  dcterms:modified "2026-06-07T15:30:29.339201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-107-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can state place value in decimals with column headings expressed in different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-377-1
  a curric:KeyLearningPoint ;
  rdfs:label "A set of possible outcomes can be stated."@en ;
  dcterms:modified "2026-06-07T15:30:29.340697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-377-2
  a curric:KeyLearningPoint ;
  rdfs:label "Outcomes can be evaluated to decide how likely they are."@en ;
  dcterms:modified "2026-06-07T15:30:29.340701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-377-3
  a curric:KeyLearningPoint ;
  rdfs:label "Outcomes with the same likelihood can be identified."@en ;
  dcterms:modified "2026-06-07T15:30:29.340707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-445-1
  a curric:KeyLearningPoint ;
  rdfs:label "It can be easier to compare numbers if they are all in standard form."@en ;
  dcterms:modified "2026-06-07T15:30:29.359335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-445-2
  a curric:KeyLearningPoint ;
  rdfs:label "If all numbers are in standard form, you can compare the powers of 10"@en ;
  dcterms:modified "2026-06-07T15:30:29.359339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-445-3
  a curric:KeyLearningPoint ;
  rdfs:label "When powers of 10 are the same, you can compare the digits of what remains."@en ;
  dcterms:modified "2026-06-07T15:30:29.359345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-396-1
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an outcome can be found by considering a Venn diagram showing all
  possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-396-2
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of a set of outcomes can be found by considering a Venn diagram
  showing all possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-396-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Venn diagram can help us find a probability, even when the outcomes are not
  equally likely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-380-1
  a curric:KeyLearningPoint ;
  rdfs:label "An experiment can be designed to determine how likely an outcome is."@en ;
  dcterms:modified "2026-06-07T15:30:29.363508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-380-2
  a curric:KeyLearningPoint ;
  rdfs:label "An experiment can be carried out and the outcomes recorded."@en ;
  dcterms:modified "2026-06-07T15:30:29.363514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-380-3
  a curric:KeyLearningPoint ;
  rdfs:label "The outcomes can be considered and the likelihood of each outcome stated."@en ;
  dcterms:modified "2026-06-07T15:30:29.363521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-306-1
  a curric:KeyLearningPoint ;
  rdfs:label "The mode is a measure of central tendency."@en ;
  dcterms:modified "2026-06-07T15:30:29.366147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-306-2
  a curric:KeyLearningPoint ;
  rdfs:label "The mode is the most frequently occurring value in a data set."@en ;
  dcterms:modified "2026-06-07T15:30:29.366151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-306-3
  a curric:KeyLearningPoint ;
  rdfs:label "There can be more than one mode."@en ;
  dcterms:modified "2026-06-07T15:30:29.366171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6812-1
  a curric:KeyLearningPoint ;
  rdfs:label "A cylinder is not a prism but has a similar structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.367110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6812-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formula for the volume of a cylinder can be derived by using the formula for a
  prism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6812-3
  a curric:KeyLearningPoint ;
  rdfs:label "This can be used to find the volume of any cylinder."@en ;
  dcterms:modified "2026-06-07T15:30:29.367118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6812-4
  a curric:KeyLearningPoint ;
  rdfs:label "Unknown lengths can be found when the volume of a cylinder is known."@en ;
  dcterms:modified "2026-06-07T15:30:29.367122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-308-1
  a curric:KeyLearningPoint ;
  rdfs:label "The range is a measure of spread."@en ;
  dcterms:modified "2026-06-07T15:30:29.367126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-308-2
  a curric:KeyLearningPoint ;
  rdfs:label "The range is difference between the highest and lowest data point."@en ;
  dcterms:modified "2026-06-07T15:30:29.367132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-308-3
  a curric:KeyLearningPoint ;
  rdfs:label """The range shows how spread out (far apart) the extreme values in the data
  set are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20036-1
  a curric:KeyLearningPoint ;
