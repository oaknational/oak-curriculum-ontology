  dcterms:modified "2026-06-07T15:30:02.368059Z"^^xsd:dateTime .

oakcurric:keyword-conventions
  a curric:Keyword ;
  schema:name "conventions"@en ;
  schema:description "accepted rules or practices in a particular type of writing or genre"@en ;
  dcterms:modified "2026-06-07T15:30:02.368765Z"^^xsd:dateTime .

oakcurric:keyword-formula
  a curric:Keyword ;
  schema:name "formula"@en ;
  schema:description "performs calculations in a spreadsheet"@en ;
  dcterms:modified "2026-06-07T15:30:02.370049Z"^^xsd:dateTime .

oakcurric:keyword-irregular
  a curric:Keyword ;
  schema:name "irregular"@en ;
  schema:description "not even or changing"@en ;
  dcterms:modified "2026-06-07T15:30:02.370534Z"^^xsd:dateTime .

oakcurric:keyword-rotation
  a curric:Keyword ;
  schema:name "rotation"@en ;
  schema:description "spinning or turning something around a central point"@en ;
  dcterms:modified "2026-06-07T15:30:02.370599Z"^^xsd:dateTime .

oakcurric:keyword-unit
  a curric:Keyword ;
  schema:name "unit"@en ;
  schema:description "a subgroup within a team"@en ;
  dcterms:modified "2026-06-07T15:30:02.370634Z"^^xsd:dateTime .

oakcurric:keyword-pictogram
  a curric:Keyword ;
  schema:name "pictogram"@en ;
  schema:description """A pictogram (pictograph) is a graph consisting of pictures to visually
  represent the frequency of objects or groups."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371167Z"^^xsd:dateTime .

oakcurric:keyword-bar-chart
  a curric:Keyword ;
  schema:name "bar chart"@en ;
  schema:description """A bar chart (bar graph) is a graph consisting of bars visually representing
  the frequency of objects or groups."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371172Z"^^xsd:dateTime .

oakcurric:keyword-vector
  a curric:Keyword ;
  schema:name "vector"@en ;
  schema:description """graphics made up of paths defined by mathematical equations, scalable
