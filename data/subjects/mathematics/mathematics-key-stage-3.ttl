  a curric:KeyLearningPoint ;
  rdfs:label "Graphs can be described by looking at how quickly they rise."@en ;
  dcterms:modified "2026-06-07T15:30:29.379585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-247-2
  a curric:KeyLearningPoint ;
  rdfs:label """The amount y changes when x increases by one is the rate of change and is called the
  gradient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-247-3
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient will be positive if y increases as the graph moves to the right."@en ;
  dcterms:modified "2026-06-07T15:30:29.379592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-247-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient can be found from any linear graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.379596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-247-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient tells you important information about the relationship."@en ;
  dcterms:modified "2026-06-07T15:30:29.379600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20038-1
  a curric:KeyLearningPoint ;
  rdfs:label "Problem solving techniques can be usefully applied"@en ;
  dcterms:modified "2026-06-07T15:30:29.379604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20038-2
  a curric:KeyLearningPoint ;
  rdfs:label "New information must be interpreted quickly and correctly"@en ;
  dcterms:modified "2026-06-07T15:30:29.379610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20038-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'optimal' solution may mean different things to different people"@en ;
  dcterms:modified "2026-06-07T15:30:29.379614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-66-1
  a curric:KeyLearningPoint ;
  rdfs:label "Multiples of a given number are the product of that number and an integer."@en ;
  dcterms:modified "2026-06-07T15:30:29.379618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-66-2
  a curric:KeyLearningPoint ;
  rdfs:label """Factors of an integer can be identified by checking for a remainder when
  dividing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-66-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the statement factor x factor = product, the product is a multiple of each of the
  factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-66-4
  a curric:KeyLearningPoint ;
  rdfs:label "If a is a factor of b then b is a multiple of a"@en ;
  dcterms:modified "2026-06-07T15:30:29.379630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-237-1
  a curric:KeyLearningPoint ;
  rdfs:label "Finding the common difference can help when finding the n^th term rule."@en ;
  dcterms:modified "2026-06-07T15:30:29.379634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-237-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing the sequence to an appropriate multiplication table can help identify the
  translation that has been made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-237-3
  a curric:KeyLearningPoint ;
  rdfs:label "The n^th term can be found for all arithmetic sequences."@en ;
  dcterms:modified "2026-06-07T15:30:29.379642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-237-4
  a curric:KeyLearningPoint ;
  rdfs:label """The n^th term rule can be used to identify the term number of a given number in a
  sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-194-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any fraction can be turned into a ratio."@en ;
  dcterms:modified "2026-06-07T15:30:29.379650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-194-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving between fractions and ratios can make a problem easier."@en ;
  dcterms:modified "2026-06-07T15:30:29.379653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-194-3
  a curric:KeyLearningPoint ;
