  dcterms:modified "2026-06-07T15:30:29.416679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-159-1
  a curric:KeyLearningPoint ;
  rdfs:label "When a fraction is multiplied by 1 it remains the same but may look different."@en ;
  dcterms:modified "2026-06-07T15:30:29.425993Z"^^xsd:dateTime .

