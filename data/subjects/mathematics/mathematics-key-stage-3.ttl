  dcterms:modified "2026-06-07T15:30:29.383374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-326-1
  a curric:KeyLearningPoint ;
  rdfs:label "The area of any circle can be found if the radius is known."@en ;
