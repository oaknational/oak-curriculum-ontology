# ----------------------------------------------------------------------
# Units
# ----------------------------------------------------------------------

oakcurric:unit-16
  a curric:Unit ;
  rdfs:label "Understanding multiplicative relationships: fractions and ratio"@en ;
  curric:slug "understanding-multiplicative-relationships-fractions-and-ratio" ;
  rdfs:comment """This unit introduces the concept of multiplicative relationsihps, and connects
  fractions to the idea of ratios. Ratios are then explored in depth and used to solve
  contextual problems such as those involving exchange rates and general conversions."""@en ;
  curric:whyThisWhyNow """This unit finishes our work with fractions in Year 7, relying upon pupil
  understanding of multiplication of fractions, and explicitly connecting fractions with ratios
  and general multiplicative relationships.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-16-1 ,
    oakcurric:priorknowledge-16-2 ,
    oakcurric:priorknowledge-16-3 ;
  curric:id "16"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.651727Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-ratio-and-proportion ,
    oakcurric:thread-number .

oakcurric:unit-9
  a curric:Unit ;
  rdfs:label "Arithmetic procedures with integers and decimals"@en ;
  curric:slug "arithmetic-procedures-with-integers-and-decimals" ;
  rdfs:comment """In this unit pupils develop their ability and efficacy with the four operations
  including more complicated and challenging calculations involving fractions, decimals and
  negative numbers. This leads into an exploration of the priority order of operations."""@en ;
  curric:whyThisWhyNow """This unit builds on knowledge established in work on factors, multiples
  squares and cubes, building on the understanding that any positive integer can be expressed
  as a product of its factors. This skill is used here to explore multiplying and dividing with
  decimals.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-9-1 ,
    oakcurric:priorknowledge-9-2 ,
    oakcurric:priorknowledge-9-3 ;
  curric:id "9"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.805883Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-number .

oakcurric:unit-10
  a curric:Unit ;
  rdfs:label "Place value"@en ;
  curric:slug "place-value" ;
  rdfs:comment """In this unit pupils revisit, secure and develop their understanding of place value
  with integers, decimals, fractions, metric and imperial units. This knowledge is then
  extended to order and compare numbers of increasing complexity."""@en ;
  curric:whyThisWhyNow """We begin year 7 with checking, securing and further development of place
  value in order to prepare adequately for further work on number in the following units for
  this term.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-10-1 ,
    oakcurric:priorknowledge-10-2 ,
    oakcurric:priorknowledge-10-3 ;
  curric:id "10"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.421612Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-number .

oakcurric:unit-15
  a curric:Unit ;
  rdfs:label "Arithmetic procedures with fractions"@en ;
  curric:slug "arithmetic-procedures-with-fractions" ;
  rdfs:comment """This unit revisits and secures fraction operations and extends pupil understanding
  to division of whole numbers by fractions and division of fractions by fractions."""@en ;
  curric:whyThisWhyNow """This unit continues from the previous one in deepening pupil understanding
  of fractions whilst also being explicitly linked to the 'arithmetic procedures with integers
  and decimals' unit.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-15-1 ,
    oakcurric:priorknowledge-15-2 ,
    oakcurric:priorknowledge-15-3 ;
  curric:id "15"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.464210Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-number .

oakcurric:unit-23
  a curric:Unit ;
  rdfs:label "Graphical representations of data"@en ;
  curric:slug "graphical-representations-of-data" ;
  rdfs:comment """In this unit pupils will interpret and construct a range of representations of
  data including bar charts, pie charts and scatter graphs."""@en ;
  curric:whyThisWhyNow """Pupils have prepared for this unit earlier in the year by looking at
  graphical representations of sequences. We build upon that knowledge to show that data can be
  represented in further ways as well as how to construct and interpret those representations.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-23-1 ,
    oakcurric:priorknowledge-23-2 ,
    oakcurric:priorknowledge-23-3 ;
  curric:id "23"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.529895Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-statistics .

oakcurric:unit-18
  a curric:Unit ;
  rdfs:label "Estimation and rounding"@en ;
  curric:slug "estimation-and-rounding" ;
  rdfs:comment """This unit helps pupils understand rounding to different decimal places, and
  significant figures. Pupils will also learn how to truncate numbers and understand the
  contexts in which these skills are useful. The unit ends will an exploration of rounding
  and inequality errors."""@en ;
  curric:whyThisWhyNow """Students up to this point have been working with integer values and have
  had few opportunities to work explicitly on estimation. We are starting the year with
  something that is familiar for students and extend knowledge of estimation and rounding to
  include more work on rounding with decimals and significant figures.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-18-1 ,
    oakcurric:priorknowledge-18-2 ,
    oakcurric:priorknowledge-18-3 ;
  curric:id "18"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.596062Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-mathematics-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-number .

oakcurric:unit-2582
  a curric:Unit ;
  rdfs:label "Maths and the environment"@en ;
  curric:slug "maths-and-the-environment" ;
  rdfs:comment "[TO BE ADDED]"@en ;
  curric:whyThisWhyNow "[TO BE ADDED]" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2582-1 ,
    oakcurric:priorknowledge-2582-2 ,
    oakcurric:priorknowledge-2582-3 ;
  curric:id "2582"^^xsd:positiveInteger;
