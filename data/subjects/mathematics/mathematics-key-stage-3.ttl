oakcurric:keylearningpoint-lesson-211-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are many benefits to using this tool."@en ;
  dcterms:modified "2026-06-07T15:30:29.399774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-211-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different transformations can be carried out quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.399777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-408-1
  a curric:KeyLearningPoint ;
  rdfs:label "A geometric sequence looks like a curve when sketched (common ratio > 1 or < 1)."@en ;
  dcterms:modified "2026-06-07T15:30:29.400343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-408-2
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient increases sharply (common ratio > 1 or < 1)."@en ;
  dcterms:modified "2026-06-07T15:30:29.400347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-408-3
  a curric:KeyLearningPoint ;
  rdfs:label "Although the graph is continuous, the sequence is not."@en ;
  dcterms:modified "2026-06-07T15:30:29.400351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-408-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each geometric sequence is made up of discrete terms."@en ;
  dcterms:modified "2026-06-07T15:30:29.400354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-395-1
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of an outcome can be found by considering a probability tree diagram
  showing all possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-395-2
  a curric:KeyLearningPoint ;
  rdfs:label """The probability of a set of outcomes can be found by considering a probability tree
  showing all possible outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-395-3
  a curric:KeyLearningPoint ;
  rdfs:label """A probability tree can help us find a probability, even when the outcomes are not
  equally likely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-1
  a curric:KeyLearningPoint ;
  rdfs:label "Every composite number has prime number factors."@en ;
  dcterms:modified "2026-06-07T15:30:29.400373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-2
  a curric:KeyLearningPoint ;
  rdfs:label "All the factors of a number can be broken down into prime factors."@en ;
  dcterms:modified "2026-06-07T15:30:29.400377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-3
  a curric:KeyLearningPoint ;
  rdfs:label "Every positive integer can be broken down into prime factors."@en ;
  dcterms:modified "2026-06-07T15:30:29.400381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-4
  a curric:KeyLearningPoint ;
  rdfs:label "Every positive integer can be written as a product of its prime factors."@en ;
  dcterms:modified "2026-06-07T15:30:29.400385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prime factor products can be simplified by using index notation."@en ;
  dcterms:modified "2026-06-07T15:30:29.400389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-1
  a curric:KeyLearningPoint ;
  rdfs:label """Finding the difference between each term can help you identify different types of
  sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sequences with a constant difference are arithmetic sequences."@en ;
  dcterms:modified "2026-06-07T15:30:29.400397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arithmetic sequences can be uniquely described with an initial term and a common
  difference."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to identify which sequences are arithmetic."@en ;
  dcterms:modified "2026-06-07T15:30:29.400405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-1
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns can be described using sequences."@en ;
  dcterms:modified "2026-06-07T15:30:29.400409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sequences can be found for given terms even if they are not sequential ."@en ;
  dcterms:modified "2026-06-07T15:30:29.400415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to identify which term in a sequence a number is from the rule."@en ;
  dcterms:modified "2026-06-07T15:30:29.400419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-4
  a curric:KeyLearningPoint ;
  rdfs:label "Real life sequences can be represented on a graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.400424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-238-1
  a curric:KeyLearningPoint ;
  rdfs:label "The terms in a sequence can be written as coordinates."@en ;
  dcterms:modified "2026-06-07T15:30:29.400439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-238-2
  a curric:KeyLearningPoint ;
  rdfs:label "The coordinates can be plotted on a grid."@en ;
  dcterms:modified "2026-06-07T15:30:29.400444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-238-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arithmetic sequences have common structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.400448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-238-4
  a curric:KeyLearningPoint ;
  rdfs:label "Other sequences might have common structures you can investigate."@en ;
  dcterms:modified "2026-06-07T15:30:29.400452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-349-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pair of compasses can be used to draw circle with a particular radius."@en ;
  dcterms:modified "2026-06-07T15:30:29.401399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-349-2
  a curric:KeyLearningPoint ;
  rdfs:label "All the points on the circle will be the same distance from the centre."@en ;
  dcterms:modified "2026-06-07T15:30:29.401404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-349-3
  a curric:KeyLearningPoint ;
  rdfs:label """The centre of a circle is the point that is the same distance from every point on
  the circle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-349-4
  a curric:KeyLearningPoint ;
  rdfs:label "The collection of points an equal distance from a given point form a circle."@en ;
  dcterms:modified "2026-06-07T15:30:29.401412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-452-1
  a curric:KeyLearningPoint ;
  rdfs:label """By choosing pairs of values that satisfy the equation, you can draw it
  accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-452-2
  a curric:KeyLearningPoint ;
  rdfs:label "For linear graphs, only two pairs of coordinates are required."@en ;
  dcterms:modified "2026-06-07T15:30:29.401420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-452-3
  a curric:KeyLearningPoint ;
  rdfs:label "The distance between the points should not be too small."@en ;
  dcterms:modified "2026-06-07T15:30:29.401424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-248-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphs can be described by looking at how quickly they fall."@en ;
  dcterms:modified "2026-06-07T15:30:29.401440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-248-2
  a curric:KeyLearningPoint ;
  rdfs:label """The amount y decreases when x increases by one is the rate of change and is called
  the gradient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-248-3
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient will be negative if y decreases as the graph moves to the right."@en ;
  dcterms:modified "2026-06-07T15:30:29.401450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-248-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient can be found from any linear graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.401454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-248-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient tells us important information about the relationship."@en ;
  dcterms:modified "2026-06-07T15:30:29.401461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-411-1
  a curric:KeyLearningPoint ;
  rdfs:label "Visual representations of a sequence can help with identification."@en ;
  dcterms:modified "2026-06-07T15:30:29.401465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-411-2
  a curric:KeyLearningPoint ;
  rdfs:label "Special number sequences can produce interesting graphs."@en ;
  dcterms:modified "2026-06-07T15:30:29.401469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-304-1
  a curric:KeyLearningPoint ;
  rdfs:label "The median is a measure of central tendency."@en ;
  dcterms:modified "2026-06-07T15:30:29.401473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-304-2
  a curric:KeyLearningPoint ;
  rdfs:label "The median is the middle (or average middle) value in an ordered data set."@en ;
  dcterms:modified "2026-06-07T15:30:29.401477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-304-3
  a curric:KeyLearningPoint ;
  rdfs:label "The median can be seen as the halfway point of a set of values."@en ;
  dcterms:modified "2026-06-07T15:30:29.401481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-143-1
  a curric:KeyLearningPoint ;
  rdfs:label "0.5 x base x perpendicular height can be used to find the area of any triangle."@en ;
  dcterms:modified "2026-06-07T15:30:29.401485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-143-2
  a curric:KeyLearningPoint ;
  rdfs:label "Missing sides can be found if the area is known."@en ;
  dcterms:modified "2026-06-07T15:30:29.401489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6853-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fluency in moving between the representations is important."@en ;
  dcterms:modified "2026-06-07T15:30:29.401493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes it is better to display the outcomes using a particular
  representation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-386-1
  a curric:KeyLearningPoint ;
  rdfs:label """Possible outcomes for more than two events can be shown in an outcome tree
  diagram."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-386-2
  a curric:KeyLearningPoint ;
  rdfs:label "The outcome tree diagram can be used to generate a list."@en ;
  dcterms:modified "2026-06-07T15:30:29.401507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-386-3
  a curric:KeyLearningPoint ;
  rdfs:label "An outcome tree can be generated from a list."@en ;
  dcterms:modified "2026-06-07T15:30:29.401511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-80-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating a product of primes will give a unique positive integer."@en ;
  dcterms:modified "2026-06-07T15:30:29.401515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-80-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to compare numbers using their prime factor product without evaluating
  the numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-80-3
  a curric:KeyLearningPoint ;
  rdfs:label "Square numbers can be identified from their product of primes."@en ;
  dcterms:modified "2026-06-07T15:30:29.401523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-80-4
  a curric:KeyLearningPoint ;
  rdfs:label "Common factors can be found by comparing the products of their primes."@en ;
  dcterms:modified "2026-06-07T15:30:29.401529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6794-1
  a curric:KeyLearningPoint ;
  rdfs:label "It may be helpful to estimate an answer to check the magnitude is correct."@en ;
  dcterms:modified "2026-06-07T15:30:29.401893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6794-2
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to use rounding to significant figures when dealing with very big
  or very small numbers in context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6794-3
  a curric:KeyLearningPoint ;
  rdfs:label """Estimates can help when making decisions about maximum or minimum possible answers
  in real life contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6794-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can use Fermi estimation to find approximate solutions to problems."@en ;
  dcterms:modified "2026-06-07T15:30:29.401910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-158-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fractions can be converted to decimals by division."@en ;
  dcterms:modified "2026-06-07T15:30:29.402090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-158-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fractions can be compared by converting them to decimals."@en ;
  dcterms:modified "2026-06-07T15:30:29.402094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-158-3
  a curric:KeyLearningPoint ;
  rdfs:label "A list of fractions can be ordered by converting them all to decimals."@en ;
  dcterms:modified "2026-06-07T15:30:29.402098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20041-1
  a curric:KeyLearningPoint ;
  rdfs:label "Percentages are regularly used to calculate percentage profit"@en ;
  dcterms:modified "2026-06-07T15:30:29.402104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20041-2
  a curric:KeyLearningPoint ;
  rdfs:label "Averages are used to track performance over a set period"@en ;
  dcterms:modified "2026-06-07T15:30:29.402108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20041-3
  a curric:KeyLearningPoint ;
  rdfs:label "Performance data may be easier to analyse if presented graphically"@en ;
  dcterms:modified "2026-06-07T15:30:29.402112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-231-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pattern of objects can be made by following a rule."@en ;
  dcterms:modified "2026-06-07T15:30:29.402116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-231-2
  a curric:KeyLearningPoint ;
  rdfs:label "These rules can be described in words."@en ;
  dcterms:modified "2026-06-07T15:30:29.402120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-231-3
  a curric:KeyLearningPoint ;
  rdfs:label "The number of objects each time is the term."@en ;
  dcterms:modified "2026-06-07T15:30:29.402124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-231-4
  a curric:KeyLearningPoint ;
  rdfs:label "Missing terms in the sequence can be found using the rule."@en ;
  dcterms:modified "2026-06-07T15:30:29.402128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-257-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bar models can be used to compare expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.402132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-257-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the expressions are equal the bars will be the same length."@en ;
  dcterms:modified "2026-06-07T15:30:29.402136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-257-3
  a curric:KeyLearningPoint ;
  rdfs:label "Operations can be performed on the bars that maintain equality."@en ;
  dcterms:modified "2026-06-07T15:30:29.402140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-257-4
  a curric:KeyLearningPoint ;
  rdfs:label "This can be extended to operations on statements expressed algebraically."@en ;
  dcterms:modified "2026-06-07T15:30:29.402144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-435-1
  a curric:KeyLearningPoint ;
  rdfs:label """When selecting the appropriate trigonometric ratio, consider what information you
  have been given."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-435-2
  a curric:KeyLearningPoint ;
  rdfs:label """When selecting the appropriate trigonometric ratio, consider what you are trying to
  find."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-435-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you do not have enough information, consider what you need and how you will get
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-435-4
  a curric:KeyLearningPoint ;
  rdfs:label "Trigonometric ratios involve two lengths and an angle."@en ;
  dcterms:modified "2026-06-07T15:30:29.402159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-115-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter can be used to represent an unknown number in context."@en ;
  dcterms:modified "2026-06-07T15:30:29.403216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-115-2
  a curric:KeyLearningPoint ;
  rdfs:label "A letter can be used to represent a variable number in context."@en ;
  dcterms:modified "2026-06-07T15:30:29.403220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-115-3
  a curric:KeyLearningPoint ;
  rdfs:label "A letter can be used in an expression to represent a number in an expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.403224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-115-4
  a curric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent an expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.403228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-450-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different types of equations."@en ;
  dcterms:modified "2026-06-07T15:30:29.403255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-450-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can plot the graph of an equation if you have two variables (one for
  each axis)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-450-3
  a curric:KeyLearningPoint ;
  rdfs:label "Certain types of equation give rise to certain graph shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.403264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-450-4
  a curric:KeyLearningPoint ;
  rdfs:label "Linear equations produce a straight line."@en ;
  dcterms:modified "2026-06-07T15:30:29.403268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-450-5
  a curric:KeyLearningPoint ;
  rdfs:label "Quadratic equations produce a parabola."@en ;
  dcterms:modified "2026-06-07T15:30:29.403272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-241-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to plot coordinates approximately in the correct quadrant."@en ;
  dcterms:modified "2026-06-07T15:30:29.403276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-241-2
  a curric:KeyLearningPoint ;
  rdfs:label "Coordinates can be plotted exactly when the axes are labelled."@en ;
  dcterms:modified "2026-06-07T15:30:29.403280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-241-3
  a curric:KeyLearningPoint ;
  rdfs:label """By careful consideration of coordinates the missing vertices of a shape can be
  found."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-249-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two coordinate pairs can be plotted and joined with a line."@en ;
  dcterms:modified "2026-06-07T15:30:29.403313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-249-2
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of this line can be calculated."@en ;
  dcterms:modified "2026-06-07T15:30:29.403318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-249-3
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient between two points can be calculated without drawing the line."@en ;
  dcterms:modified "2026-06-07T15:30:29.403322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-249-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient between two points can be calculated without drawing the points."@en ;
  dcterms:modified "2026-06-07T15:30:29.403326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-249-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient between any two points on a straight line is the gradient of
  the line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-250-1
  a curric:KeyLearningPoint ;
  rdfs:label "The y-intercept can be found by considering the graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.403334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-250-2
  a curric:KeyLearningPoint ;
