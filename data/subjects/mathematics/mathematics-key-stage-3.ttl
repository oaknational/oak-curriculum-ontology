  schema:description """Significant figures are the digits in a number that contribute to the
  accuracy of the number."""@en ;
  dcterms:modified "2026-06-07T15:30:02.361101Z"^^xsd:dateTime .

oakcurric:keyword-identity
  a curric:Keyword ;
  schema:name "identity"@en ;
  schema:description """who a person is, or the qualities of a person or group that make them
  different than others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361296Z"^^xsd:dateTime .

oakcurric:keyword-product
  a curric:Keyword ;
  schema:name "Product"@en ;
  schema:description "The product is the result of two numbers (factors) multiplied together."@en ;
  dcterms:modified "2026-06-07T15:30:02.361887Z"^^xsd:dateTime .

oakcurric:keyword-data
  a curric:Keyword ;
  schema:name "data"@en ;
  schema:description "facts and figures in their raw form"@en ;
  dcterms:modified "2026-06-07T15:30:02.361985Z"^^xsd:dateTime .

oakcurric:keyword-sample
  a curric:Keyword ;
  schema:name "sample"@en ;
  schema:description "the measurement of a sound wave at a point in time"@en ;
  dcterms:modified "2026-06-07T15:30:02.361999Z"^^xsd:dateTime .

oakcurric:keyword-ratio
  a curric:Keyword ;
  schema:name "Ratio"@en ;
  schema:description """shows the relative sizes of 2 or more values and allows you to compare a
  part with another part in a whole."""@en ;
  dcterms:modified "2026-06-07T15:30:02.362397Z"^^xsd:dateTime .

oakcurric:keyword-equation
  a curric:Keyword ;
  schema:name "Equation"@en ;
  schema:description """An equation is used to show that one number or calculation is equal to
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:02.362466Z"^^xsd:dateTime .

oakcurric:keyword-imperial
  a curric:Keyword ;
  schema:name "imperial"@en ;
  schema:description """imperial refers to things or people which were part of the British
  Empire"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363261Z"^^xsd:dateTime .

oakcurric:keyword-pythagoras-theorem
