  dcterms:modified "2026-02-12T08:59:21.678467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-1
  a curric:KeyLearningPoint ;
  rdfs:label """Finding the difference between each term can help you identify different types of sequence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-2
  a curric:KeyLearningPoint ;
