  dcterms:modified "2026-02-12T08:59:21.678478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arithmetic sequences can be uniquely described with an initial term and a common difference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-234-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to identify which sequences are arithmetic."@en ;
  dcterms:modified "2026-02-12T08:59:21.678488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-1
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns can be described using sequences."@en ;
  dcterms:modified "2026-02-12T08:59:21.678495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sequences can be found for given terms even if they are not sequential ."@en ;
  dcterms:modified "2026-02-12T08:59:21.678500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to identify which term in a sequence a number is from the rule."@en ;
  dcterms:modified "2026-02-12T08:59:21.678507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-240-4
  a curric:KeyLearningPoint ;
