  dcterms:modified "2026-06-07T15:30:29.380410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-133-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pairs of coordinates that follow a rule can be found."@en ;
  dcterms:modified "2026-06-07T15:30:29.381474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-133-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pairs of coordinates that follow a rule can be plotted."@en ;
  dcterms:modified "2026-06-07T15:30:29.381479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-133-3
  a curric:KeyLearningPoint ;
  rdfs:label "Coordinates that follow a rule will follow a pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.381489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-133-4
  a curric:KeyLearningPoint ;
  rdfs:label "A rule can be identified from the pairs of coordinates."@en ;
  dcterms:modified "2026-06-07T15:30:29.381494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-264-1
  a curric:KeyLearningPoint ;
  rdfs:label """An equation with both a multiplicative and additive step can be solved using a bar
  model."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-264-2
  a curric:KeyLearningPoint ;
  rdfs:label "The solution can be formalised using algebra."@en ;
  dcterms:modified "2026-06-07T15:30:29.381522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-264-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any linear equation written in the form Ax + B = C can be solved."@en ;
  dcterms:modified "2026-06-07T15:30:29.381526Z"^^xsd:dateTime .

