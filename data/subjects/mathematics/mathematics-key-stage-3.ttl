  dcterms:modified "2026-02-12T08:59:21.633718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-361-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ratio table can help you find the scalar and functional multipliers in similar shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633723Z"^^xsd:dateTime .

