  a curric:KeyLearningPoint ;
  rdfs:label """By choosing pairs of values that satisfy the equation, you can draw it accurately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-452-2
  a curric:KeyLearningPoint ;
