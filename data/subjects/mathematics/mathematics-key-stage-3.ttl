  dcterms:modified "2026-06-07T15:30:41.119927Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-166
  a curric:PupilLessonOutcome ;
  rdfs:label """I can generalise and fluently use addition and subtraction strategies to calculate
  with fractions and mixed numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120021Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20019
  a curric:PupilLessonOutcome ;
  rdfs:label "I can plan a journey and consider which available form of transport is best."@en ;
  dcterms:modified "2026-06-07T15:30:41.120025Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-70
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify and explain whether a number is or is not a multiple of a given
  integer."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120183Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-112
  a curric:PupilLessonOutcome ;
  rdfs:label "I can confidently order and compare a variety of numbers and measures."@en ;
  dcterms:modified "2026-06-07T15:30:41.120305Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-215
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise when values have been rounded and state sensible suggestions of what
  the unrounded value could have been."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120414Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-283
  a curric:PupilLessonOutcome ;
  rdfs:label """I can calculate the original value, given the final value after a stated percentage
  decrease."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120418Z"^^xsd:dateTime .

