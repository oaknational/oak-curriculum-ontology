  dcterms:modified "2026-06-07T15:30:29.368256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-230-2
  a curric:KeyLearningPoint ;
  rdfs:label "This rule can be demonstrated with a diagram."@en ;
  dcterms:modified "2026-06-07T15:30:29.368262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-230-3
  a curric:KeyLearningPoint ;
