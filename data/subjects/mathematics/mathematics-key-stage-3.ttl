  dcterms:modified "2026-06-07T15:30:02.356474Z"^^xsd:dateTime .

oakcurric:keyword-interior-angles
  a curric:Keyword ;
  schema:name "Interior angles"@en ;
  schema:description """Interior angles are the angles formed inside a polygon by two of its
