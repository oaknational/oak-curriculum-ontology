  a curric:KeyLearningPoint ;
  rdfs:label """A probability tree can help us find a probability, even when the outcomes are not equally likely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-1
  a curric:KeyLearningPoint ;
  rdfs:label "Every composite number has prime number factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.678449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-2
  a curric:KeyLearningPoint ;
  rdfs:label "All the factors of a number can be broken down into prime factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.678453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-3
  a curric:KeyLearningPoint ;
