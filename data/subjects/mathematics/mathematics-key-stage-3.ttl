  dcterms:modified "2026-06-07T15:30:29.379657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-456-1
  a curric:KeyLearningPoint ;
  rdfs:label """When presented with a real-life problem, it can help to sketch what is
