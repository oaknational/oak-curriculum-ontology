  dcterms:modified "2026-02-12T08:59:21.678458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-4
  a curric:KeyLearningPoint ;
  rdfs:label "Every positive integer can be written as a product of its prime factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.678462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-79-5
  a curric:KeyLearningPoint ;
