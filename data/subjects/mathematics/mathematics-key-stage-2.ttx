  dcterms:modified "2026-02-12T08:59:21.612476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3913-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The grid can represent the array."@en ;
  dcterms:modified "2026-02-12T08:59:21.612483Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3913-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiply the ones and tens separately and recombine."@en ;
  dcterms:modified "2026-02-12T08:59:21.612494Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7402-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the single digit and the tens number is greater than 100 then you regroup ten tens into one hundred."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7402-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the single digit and the tens number is greater than 100 the partial product will be a 3-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7402-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are similarities between the representations of multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.612550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7608-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the multiplicative relationship between the numerator and denominator is the same, the fractions will be equivalent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612768Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7608-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If a fraction has been simplified, the numerator and denominator are as small as they can be to keep the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7608-3
  a oakcurric:KeyLearningPoint ;
