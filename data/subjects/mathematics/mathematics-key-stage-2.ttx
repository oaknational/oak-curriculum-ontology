oak:keylearningpoint-lesson-4043-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If 1m = 100cm then 3m = 3 x 100cm = 300cm"@en ;
  dcterms:modified "2026-02-12T08:59:21.623713Z"^^xsd:dateTime .

