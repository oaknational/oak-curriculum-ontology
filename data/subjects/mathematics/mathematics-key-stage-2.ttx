  dcterms:modified "2026-02-12T08:59:21.621710Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3640-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different parts of the same sized whole can be directly compared based on their size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621716Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3862-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the dividend is a multiple of the divisor, there will be no remainder."@en ;
  dcterms:modified "2026-02-12T08:59:21.621926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3862-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the dividend is not a multiple of the divisor, there will be a remainder."@en ;
  dcterms:modified "2026-02-12T08:59:21.621931Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3862-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Times table knowledge can help to identify if there will be a remainder."@en ;
  dcterms:modified "2026-02-12T08:59:21.621937Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3862-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The rules of divisibility can help to identify if there will be a remainder."@en ;
  dcterms:modified "2026-02-12T08:59:21.621942Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3978-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use place value to convert the decimal fraction by multiplication to a whole number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622146Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3978-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use unitising, known facts and/or the distributive law to multiply the whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622155Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3978-3
  a oakcurric:KeyLearningPoint ;
