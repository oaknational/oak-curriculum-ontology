  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 is ten times smaller than 10 or one tenth the size."@en ;
  dcterms:modified "2026-02-12T08:59:21.664665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3794-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Dividing by ten makes the number ten times smaller or one tenth the size."@en ;
  dcterms:modified "2026-02-12T08:59:21.664672Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3794-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Dividing by ten is the inverse of multiplying by ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.664677Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7135-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The more you subtract the smaller the difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.664700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7135-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The less you subtract the greater the difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.664705Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7135-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent the change in the subtrahend."@en ;
  dcterms:modified "2026-02-12T08:59:21.664709Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7134-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The more you subtract the less you are left with."@en ;
  dcterms:modified "2026-02-12T08:59:21.664714Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7134-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The less you subtract the more you are left with."@en ;
  dcterms:modified "2026-02-12T08:59:21.664718Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7134-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent the change in the subtrahend."@en ;
  dcterms:modified "2026-02-12T08:59:21.664723Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7238-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Identify the next and previous whole numbers to the number being rounded."@en ;
  dcterms:modified "2026-02-12T08:59:21.664727Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7238-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Identify which whole number is nearest to the number being rounded."@en ;
  dcterms:modified "2026-02-12T08:59:21.664732Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7238-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the value of the tenths is 5 or greater then round up to the next whole number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7238-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the value of the tenths is less than 5, ignore the tenths and round down to the whole number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664741Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7238-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To round a number with hundredths to the nearest whole number, you only need to look at the tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664746Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3790-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The distributive law allows you to add or subtract known times tables to solve problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664925Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3790-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can partition the group number or the size of a group to solve problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.664963Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3790-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Factors can be re-combined or subtracted to simplify 2-part problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.664969Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4035-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Number lines and scales represent fractions in a continuous context."@en ;
  dcterms:modified "2026-02-12T08:59:21.664974Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4035-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into __ equal parts and the line shows __ of them."@en ;
  dcterms:modified "2026-02-12T08:59:21.664981Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3874-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number of tenths can be represented as repeated addition and multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.664986Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3874-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Decimal numbers (tenths) greater than 1 can be represented as a multiplication equation with 0.1 as a factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664991Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3874-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Decimal numbers (tenths) greater than one can be written as an improper fraction of tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664995Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3931-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the hundreds number is not a multiple of the divisor then the remainder is regrouped for tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665002Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3931-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the tens number is not a multiple of the divisor then the remainder is regrouped for ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665007Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3931-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the ones number is not a multiple of the divisor then there will be a remainder in the answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665012Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3931-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Regrouping and remainders can be represented practically using place value counters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4153-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Calculate the partial products."@en ;
  dcterms:modified "2026-02-12T08:59:21.665021Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4153-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Add the partial products to recombine."@en ;
  dcterms:modified "2026-02-12T08:59:21.665025Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4153-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Regroup when numbers bridge 10, 100, 1,000, 10,000"@en ;
  dcterms:modified "2026-02-12T08:59:21.665030Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3753-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "All multiples of 6 are multiples of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.665035Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3753-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Not all multiples of 3 are multiples of 6"@en ;
  dcterms:modified "2026-02-12T08:59:21.665039Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3753-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 6 are double the multiples of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.665044Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3753-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 3 are half the multiples of 6"@en ;
  dcterms:modified "2026-02-12T08:59:21.665048Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3827-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be partitioned in the same way as whole numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.665229Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3827-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If fractions have the same denominator, they can be subtracted."@en ;
  dcterms:modified "2026-02-12T08:59:21.665234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3827-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To subtract fractions with the same denominator, the language of unitising can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665239Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3611-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Start with the ones column so that regrouping can be represented"@en ;
  dcterms:modified "2026-02-12T08:59:21.665243Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3611-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the sum of the ones digits is ten or greater, regrouping is needed"@en ;
  dcterms:modified "2026-02-12T08:59:21.665248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3611-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Any complete tens are regrouped into the tens column"@en ;
  dcterms:modified "2026-02-12T08:59:21.665252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3806-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The horizontal distance from the origin is recorded first."@en ;
  dcterms:modified "2026-02-12T08:59:21.665257Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3806-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Points on a coordinate grid are measured from the origin."@en ;
  dcterms:modified "2026-02-12T08:59:21.665262Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3806-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Points have a horizontal and vertical distance from the origin."@en ;
  dcterms:modified "2026-02-12T08:59:21.665266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3806-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Points are marked where the lines of the grid cross."@en ;
  dcterms:modified "2026-02-12T08:59:21.665271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4228-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The model can represent a scaling structure with one part being __ times the size of the other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665275Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4228-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The model can represent an additive structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.665280Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4228-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The model can represent values of measures in a problem involving shape."@en ;
  dcterms:modified "2026-02-12T08:59:21.665287Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4228-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The model can represent different elements of a problem involving shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.665292Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3847-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you reflect a shape, it will be the same distance from the mirror line on both sides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3847-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You can reflect a shape by counting the position of each vertex and making a mark, and then joining the marks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665301Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4108-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Numbers can be represented using place value counters or a Gattegno chart"@en ;
  dcterms:modified "2026-02-12T08:59:21.665306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4108-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A zero in a number shows that there is no digit value in that column - this is called a placeholder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665313Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4108-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When we read numbers, we group the digits into threes from the right."@en ;
  dcterms:modified "2026-02-12T08:59:21.665320Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3767-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjacent multiples of 7 have a difference of 7"@en ;
  dcterms:modified "2026-02-12T08:59:21.665811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3767-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you add 7 to a multiple of 7 you get the next multiple of 7"@en ;
  dcterms:modified "2026-02-12T08:59:21.665815Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3767-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you subtract 7 from a multiple of 7 you get the previous multiple of 7"@en ;
  dcterms:modified "2026-02-12T08:59:21.665820Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3555-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Word problems can be represented in a bar model by identifying the parts and the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3555-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To find the whole, we need to add the parts together."@en ;
  dcterms:modified "2026-02-12T08:59:21.665829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3555-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To find a part, we need to subtract the part we know from the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.665833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3555-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the units are different, they need to be converted to the same unit."@en ;
  dcterms:modified "2026-02-12T08:59:21.665838Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4103-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Measuring scales can be interpreted by counting in steps of 1,000, 2,000, 2,500 and 5,000"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4103-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Measuring scales can be interpreted by counting in steps of 10,000, 20,000, 25,00 and 50,000"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4103-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Graph scales can be read and interpreted by counting in multiples of 1,000 and 10,000"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3665-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the numerator and denominator have the same value, the fraction is equal to one whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665861Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3665-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the numerator is less than the denominator, the fraction is less than one whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3665-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fractions that have numerators and denominators with the same values are also equal to each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6806-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you can count in 2s, you can count in 20s. The 1s or 10s digit follows the pattern of 2, 4, 6, 8 and 0"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665875Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6806-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you can count in 5s, you can count in 50s. The 1s or 10s digit follows the pattern of 5 and 0"""@en ;
  dcterms:modified "2026-02-12T08:59:21.665879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6806-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you count up in 25s, the 10s and 1s digits are always 25, 50, 75 or 0"@en ;
  dcterms:modified "2026-02-12T08:59:21.665884Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4001-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Scales are often marked in factors of 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.665888Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4001-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearranging calculations to make use of factors of 100 can simplify them"@en ;
  dcterms:modified "2026-02-12T08:59:21.665893Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7610-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the multiplicative relationship between the numerator and denominator is the same, the fractions will be equivalent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666686Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7610-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In equivalent fractions the numerators will share a common factor and the denominators will share a common factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666690Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7610-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In equivalent fractions, the numerators and denominators have been scaled up or down by the same factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666695Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3809-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Move the point in the horizontal direction in the translation."@en ;
  dcterms:modified "2026-02-12T08:59:21.666700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3809-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Move the point in the vertical direction in the translation,"@en ;
  dcterms:modified "2026-02-12T08:59:21.666704Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3809-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The shape made with the new points should be exactly the same shape and size as the original shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3837-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rods or number lines can be used to support subtracting fractions from whole or mixed numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666716Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3837-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be expressed as improper fractions to aid subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.666720Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3837-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If an answer to a calculation is an improper fraction, this should be expressed as a mixed number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3837-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Improper fractions can be subtracted in the same way as proper fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.666729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3593-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By looking carefully at the minuend and subtrahend, we can choose the most efficient subtraction strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666734Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3593-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When numbers are close together, finding the difference is the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666738Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3593-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sometimes, we can use known addition facts to make finding the difference even more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666743Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4241-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When the total value of the set increases, the mean average increases."@en ;
  dcterms:modified "2026-02-12T08:59:21.666747Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4241-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When the total value of the set decreases, the mean average decreases."@en ;
  dcterms:modified "2026-02-12T08:59:21.666752Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4241-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the number of values changes, the total quantity must be divided by the new number of values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3566-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The mass of objects can be measured in grams."@en ;
  dcterms:modified "2026-02-12T08:59:21.666761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3566-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different scales can be marked with different intervals."@en ;
  dcterms:modified "2026-02-12T08:59:21.666766Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3566-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The mass of objects can be compared using scales."@en ;
  dcterms:modified "2026-02-12T08:59:21.666773Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3922-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use times tables and place value to estimate the product of a 3-digit by a 1-digit multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666778Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3922-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use expanded short multiplication to multiply a 3-digit by a 1-digit number."@en ;
  dcterms:modified "2026-02-12T08:59:21.666783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3922-3
  a oakcurric:KeyLearningPoint ;
