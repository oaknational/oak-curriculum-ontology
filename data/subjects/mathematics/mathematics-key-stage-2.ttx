  dcterms:modified "2026-02-12T08:59:21.622161Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7150-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fraction and decimal equivalence can be used to convert fraction remainders to decimals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622392Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7150-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """1 one is equivalent to 10 tenths so a 1 can be exchanged for 10 tenths in the tenths column."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622397Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7150-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Continue to regroup until the number of the decimal fraction is a multiple of the divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622406Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3944-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Using squares means that there are no gaps or overlaps."@en ;
  dcterms:modified "2026-02-12T08:59:21.622412Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3944-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fractions of squares can be added to make whole squares."@en ;
  dcterms:modified "2026-02-12T08:59:21.622418Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3652-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the whole is the same, the greater the number of equal parts, the smaller each equal part is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622542Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3652-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the whole is the same, the smaller the number of equal parts, the larger each equal part is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622548Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3652-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing and ordering unit fractions, the greater the denominator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3652-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing and ordering unit fractions, the smaller the denominator, the larger the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622559Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3645-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into __ equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.623011Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3645-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each equal part is one-__ of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.623017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3645-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can represent fractions with an image, symbol and name."@en ;
  dcterms:modified "2026-02-12T08:59:21.623023Z"^^xsd:dateTime .

