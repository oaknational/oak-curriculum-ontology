  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 pint is just greater than 0.4l."@en ;
  dcterms:modified "2026-02-12T08:59:21.623854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4021-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Finding a fraction of a number is the same as multiplying the number by the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623860Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4021-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying a number by a unit fraction is equivalent to dividing the number by the denominator of the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4021-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into__ equal parts describes dividing by __"@en ;
  dcterms:modified "2026-02-12T08:59:21.623870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3661-1
  a oakcurric:KeyLearningPoint ;
