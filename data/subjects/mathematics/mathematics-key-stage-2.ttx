  dcterms:modified "2026-02-12T08:59:21.675329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3676-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If fractions have the same denominator they can be subtracted."@en ;
  dcterms:modified "2026-02-12T08:59:21.675333Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4142-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Area and perimeter are calculated from the side lengths of 2D shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.675364Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4142-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Area is measured in square units."@en ;
  dcterms:modified "2026-02-12T08:59:21.675368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4142-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Perimeter is measured in units of length."@en ;
  dcterms:modified "2026-02-12T08:59:21.675373Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3572-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The size of something does not determine how much mass (or matter) an object has."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675378Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3572-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Taller containers do not always hold a greater volume of liquid."@en ;
  dcterms:modified "2026-02-12T08:59:21.675382Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3572-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you know the mass and volume of some objects, it is easier to estimate others by comparing them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675387Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3519-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearranging the addends identifies the pairs that total 10."@en ;
  dcterms:modified "2026-02-12T08:59:21.675391Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3519-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Place value means we can add a single digit to 10."@en ;
  dcterms:modified "2026-02-12T08:59:21.675396Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3519-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Representations help us to see the pair that makes 10 and the extra ones number."@en ;
  dcterms:modified "2026-02-12T08:59:21.675400Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3945-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you have the same number of squares, the area will be the same however they are arranged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675405Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3945-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There must be no gaps or overlaps between the shapes for the area to be the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675409Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3829-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A fraction with a numerator that is equal to or greater than the denominator is called an improper fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676490Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3829-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Improper fractions have values that are equal to or greater than one."@en ;
  dcterms:modified "2026-02-12T08:59:21.676495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3829-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A mixed number can be written as an improper fraction of equal value."@en ;
  dcterms:modified "2026-02-12T08:59:21.676499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4164-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The area of a parallelogram is equal to the area of the rectangle created by rearranging the parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4164-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Any parallelogram has a base and a perpendicular height."@en ;
  dcterms:modified "2026-02-12T08:59:21.676508Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4164-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The area of a parallelogram is equal to its base multiplied by its perpendicular height."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3839-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning is a strategy that can be used to subtract mixed numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.676538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3839-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When partitioning, the whole number part and the fractional part of the minuend must be greater than the subtrahend's."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3839-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using number-sense can support us to determine the most efficient method to use when subtracting from mixed numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4184-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you multiply by a unit fraction you find that fraction of the other factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.676552Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4184-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplication can be represented by the word of."@en ;
  dcterms:modified "2026-02-12T08:59:21.676559Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4184-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One-half multiplied by one-quarter is the same as one half of one-quarter."@en ;
  dcterms:modified "2026-02-12T08:59:21.676564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4184-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying by a proper fraction will give a product smaller than the value of the other factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676568Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4236-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Division can be combined with addition and subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.676575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4236-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When there are no brackets, the division is completed first."@en ;
  dcterms:modified "2026-02-12T08:59:21.676583Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4236-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Where there are brackets, the calculation within the brackets is completed first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676588Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3557-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Place value helps us count on and back in 10s and 100s."@en ;
  dcterms:modified "2026-02-12T08:59:21.676592Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3557-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Place value helps us to know which digits change as we cross the 100s or 10s boundaries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676597Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3557-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1s and 10s digits don’t change when you add a 100 to or subtract 100 from a 3-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676601Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3610-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Estimate the answer first to improve your accuracy"@en ;
  dcterms:modified "2026-02-12T08:59:21.676998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3610-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The addends are written in columns with the same value digits in the same column"@en ;
  dcterms:modified "2026-02-12T08:59:21.677003Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3610-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sum is recorded underneath the addends with the same value digits in the same column"""@en ;
  dcterms:modified "2026-02-12T08:59:21.677008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4181-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In fractions equivalent to a whole, the numerator is the same as the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677012Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4181-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The size of the denominator tells you the size of one part of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.677017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4181-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The greater the denominator, the smaller the parts of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.677021Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4181-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The smaller the denominator, the smaller the parts of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.677026Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3574-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Visualising a word problem helps us see the mathematics."@en ;
  dcterms:modified "2026-02-12T08:59:21.677030Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3574-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Word problems can be represented as a bar model by identifying the parts and the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677037Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3574-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The bar model helps us to understand the structure of the maths and to form a calculation to help solve the problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3574-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Number facts can be used when solving problems involving mass."@en ;
  dcterms:modified "2026-02-12T08:59:21.677047Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4151-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Calculate the partial products."@en ;
  dcterms:modified "2026-02-12T08:59:21.677051Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4151-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Add the partial products to recombine."@en ;
  dcterms:modified "2026-02-12T08:59:21.677056Z"^^xsd:dateTime .

