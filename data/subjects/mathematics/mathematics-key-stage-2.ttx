  a oakcurric:KeyLearningPoint ;
  rdfs:label "The part-whole structure can be used to represent additive problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.660906Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7130-2
  a oakcurric:KeyLearningPoint ;
