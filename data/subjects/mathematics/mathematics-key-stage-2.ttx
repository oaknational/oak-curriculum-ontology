  a oakcurric:KeyLearningPoint ;
  rdfs:label "Regroup when numbers bridge 10 or 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677060Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3669-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the whole is the same, the greater the number of equal parts, the smaller each equal part is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677067Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3669-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the whole is the same, the smaller the number of equal parts, the larger each equal part is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3669-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing unit fractions, the greater the denominator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677077Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3669-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing unit fractions, the smaller the denominator, the larger the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677084Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3702-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When using column addition, start by adding the numbers with the smallest place value first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677089Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3702-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the sum of the tens digits is ten or greater, regrouping is needed."@en ;
  dcterms:modified "2026-02-12T08:59:21.677093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3702-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Any complete hundreds are regrouped into the hundreds column."@en ;
  dcterms:modified "2026-02-12T08:59:21.677098Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3578-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Quadrilaterals always have four sides, vertices and angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.677102Z"^^xsd:dateTime .

