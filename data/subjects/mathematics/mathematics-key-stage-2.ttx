  dcterms:modified "2026-02-12T08:59:21.624616Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3662-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A non-unit fraction has a numerator greater than 1; it is composed of more than one unit fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624976Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3662-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We say, 'the whole has been divided into ___ equal parts, and I have ___ of them'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624981Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3662-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When writing fractions, the numerator is the top number showing the number of equal parts we have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624987Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3662-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The denominator is the bottom number showing the number of equal parts the whole has been divided into."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4169-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the lengths of the sides of a shape have been doubled, the perimeter will be double."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4169-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the side lengths of a shape are multiplied by the same factor the perimeter will be multiplied by the same factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4169-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The number which all the sides have been multiplied by is called a scale factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.641569Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3705-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Estimation gives you a value close to the correct answer."@en ;
  dcterms:modified "2026-02-12T08:59:21.646355Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3705-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Start with the digits with the smallest place value so that regrouping can be represented."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646360Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3705-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Look carefully at the ones number of the sum to find missing addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.646364Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7140-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When solving problems, the column addition and column subtraction algorithms are sometimes the most efficient methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651385Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7140-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the numbers have different amounts of digits, ensure the digits are aligned in their appropriate place value columns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651389Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7140-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Identify when regrouping is needed when carrying out column addition and subtraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651394Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3998-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A common factor is a factor which is shared by two or more numbers"@en ;
  dcterms:modified "2026-02-12T08:59:21.653143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3641-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you know one part and how many parts there are we can construct the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.653148Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3641-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you know that the part is one out of 4 equal parts we can draw the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.653152Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3641-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole can be one shape or a group of objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.653157Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3845-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you fold a shape on a line of symmetry, the two halves will match exactly."@en ;
  dcterms:modified "2026-02-12T08:59:21.653161Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3845-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A line of symmetry is not always horizontal or vertical."@en ;
  dcterms:modified "2026-02-12T08:59:21.653166Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3845-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some quadrilaterals, such as a parallelogram, have no lines of symmetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.653171Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3845-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Others, such as a kite, have one line of symmetry. Others, such as a rectangle, can have more than one line of symmetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653175Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4231-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A trial and improvement approach can be used if a model can't easily be drawn."@en ;
  dcterms:modified "2026-02-12T08:59:21.653180Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4231-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A table can be used to record and check all possible solutions have been found."@en ;
  dcterms:modified "2026-02-12T08:59:21.653184Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4231-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some problems with two unknowns have an infinite number of solutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.653191Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3581-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The definition of a square is a rectangle with all four sides the same length."@en ;
  dcterms:modified "2026-02-12T08:59:21.653196Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3581-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A square has four right angles at its vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.653200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3581-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A square can rest on a side or a vertex."@en ;
  dcterms:modified "2026-02-12T08:59:21.653207Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4014-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partition the mixed number into a whole number and a fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.653212Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4014-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiply the whole number part by the whole number factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.653216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4014-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiply the fraction by the whole number using unitising language."@en ;
  dcterms:modified "2026-02-12T08:59:21.653221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4014-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recombine the partial products to calculate the overall product."@en ;
  dcterms:modified "2026-02-12T08:59:21.653225Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4102-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "100,000 is composed of two 50,000s"@en ;
  dcterms:modified "2026-02-12T08:59:21.653230Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4102-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "100,000 is composed of four 25,000s"@en ;
  dcterms:modified "2026-02-12T08:59:21.653234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4102-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "100,000 is composed of five 20,000s"@en ;
  dcterms:modified "2026-02-12T08:59:21.653239Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3671-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Non-unit fractions are composed from unit fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.653243Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3671-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Repeated addition of unit fractions forms non-unit fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.653250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3671-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line represents the repeated addition of unit fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.653255Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4179-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You can use knowledge of common multiples to convert fractions to an equivalent with a common denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653260Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4179-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Common denominators for non-related fractions can be found using common multiples of the denominators."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653264Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4179-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the denominators are the same, the greater the numerator, the larger the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653269Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4179-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the denominators are the same, the smaller the numerator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4167-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The area of a triangle is half the area of a parallelogram with the same perpendicular base and height."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653831Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4167-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The area of a triangle can be calculated using the formula area = base × perpendicular height ÷ 2"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653835Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4167-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A missing perpendicular height in a triangle can be found using the formula area × 2 ÷ base"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653839Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4167-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A missing base in a triangle can be found using the formula area × 2 ÷ perpendicular height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653844Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3609-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When using column addition, start by adding numbers with the smallest place value first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3609-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use zero to show that there are no tens or ones in a 3-digit number."@en ;
  dcterms:modified "2026-02-12T08:59:21.653853Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3609-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partition each number carefully into hundreds, tens and ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.653857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3728-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Equivalent calculations can be used with the same difference or same sum to make calculations ‘easier’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653862Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3728-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent more efficient methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.653866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3728-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Inverse, the relationship between addition and subtraction, can be used to solve missing number problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653874Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4027-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "This is __ of the whole so one part of the whole is __"@en ;
  dcterms:modified "2026-02-12T08:59:21.653879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4027-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There will be __ of these parts in the whole"@en ;
  dcterms:modified "2026-02-12T08:59:21.653883Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4027-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you work out the size of a unit fraction from the non-unit fraction, you can work out the size of the whole"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653888Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4100-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you don't cross a boundary, only one digit changes when you count in 10s, 100s and 1,000s"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653892Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4100-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you count across a boundary, two or more digits will change."@en ;
  dcterms:modified "2026-02-12T08:59:21.653899Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4100-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Unitising when counting can help when crossing boundaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.653904Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4229-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The model can represent a scaling structure with one part being __ times the size of the other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653909Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4229-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The model can represent an additive structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.653913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3538-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Knowledge of number facts to 20 can support calculation across the 100 boundary."@en ;
  dcterms:modified "2026-02-12T08:59:21.654488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3538-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 8 plus 7 is equal to 15 then 98 plus 7 is equal to 90 plus 15 which equals 105"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3538-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Knowledge of place value can help when counting forwards across the 100 boundary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654497Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3632-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Start by subtracting the number with the smallest place value first."@en ;
  dcterms:modified "2026-02-12T08:59:21.654502Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3632-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The minuend always appears first in a column subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.654506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3632-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The subtrahend is written underneath the minuend."@en ;
  dcterms:modified "2026-02-12T08:59:21.654511Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3817-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers are composed of a whole number part and a fractional part."@en ;
  dcterms:modified "2026-02-12T08:59:21.654515Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3817-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The composition of mixed numbers can be written as an addition equation, adding the whole part and the fractional part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654522Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3817-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be represented on a part-part-whole model."@en ;
  dcterms:modified "2026-02-12T08:59:21.654527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3817-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The part-part-whole model can be used to form addition and subtraction equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654532Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3819-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Word problems can involve mixed numbers. Mixed numbers may be used as part of the question or may form the answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3819-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be used to represent measures."@en ;
  dcterms:modified "2026-02-12T08:59:21.654543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3819-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Representing problems as part-part-whole model can support us to form equations that we can then solve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654548Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7430-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the hundreds digit is smaller than the divisor then it is exchanged for tens and included with the tens digit"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7430-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the 100s digit is smaller than the divisor then no partial product is recorded above the 100s digit of the dividend"""@en ;
  dcterms:modified "2026-02-12T08:59:21.654557Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3991-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To simplify a multiplication calculation, you can change the order of the factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654562Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3991-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To simplify a multiplication calculation you can group the factors in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654566Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3707-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Start by subtracting the number with the smallest place value."@en ;
  dcterms:modified "2026-02-12T08:59:21.654571Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3707-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The minuend appears first in a column subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.654575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3707-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The subtrahend is written underneath the minuend."@en ;
  dcterms:modified "2026-02-12T08:59:21.654580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3707-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use zero to show where there are no ones, tens or hundreds represented."@en ;
  dcterms:modified "2026-02-12T08:59:21.654584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3583-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An angle can be exactly a right angle."@en ;
  dcterms:modified "2026-02-12T08:59:21.654589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3583-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An angle can be less than or greater than a right angle."@en ;
  dcterms:modified "2026-02-12T08:59:21.654593Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3583-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you cut a square using two diagonal lines, you get four identical triangles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3583-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you cut a rectangle that is not a square using two diagonal lines, you get two pairs of identical triangles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654606Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3800-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one factor is made ten times the size, the product will be ten times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654611Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3800-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One factor has been multiplied by 10 so the product is multiplied by 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.654618Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3800-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When multiplying two numbers, if either factor is made 10 times the size, the product will be 10 times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3800-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "6 multiplied by 30 is equal to 60 multiplied by 3 or 6 tens multiplied by 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.654628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3799-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "100 is ten groups of ten or ten times ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.654635Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3799-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying by 100 is equivalent to multiplying by 10 and then multiplying by 10 again."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3799-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Each time you multiply by 10 the digits move one place to the left in the place value chart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654644Z"^^xsd:dateTime .

