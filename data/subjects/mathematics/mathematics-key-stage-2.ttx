  rdfs:label "There are four 25s in 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677130Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3527-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are five 20s in 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677134Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3695-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some analogue clock faces display Roman numerals instead of Arabic numerals for the hours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677138Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3695-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The methods for telling the time remain the same whether the clock face has Roman or Arabic numerals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3620-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of 4 are all multiples of 2 but not all multiples of 2 are multiples of 4"""@en ;
  dcterms:modified "2026-02-12T08:59:21.677653Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3620-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 4 are double the multiples of 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.677660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3620-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 2 are half the multiples of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.677664Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3656-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you know a part and the fraction it represents, you can construct the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.677669Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3656-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If one-__________ is a part, then the whole is __________ times as much."@en ;
  dcterms:modified "2026-02-12T08:59:21.677673Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3656-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Take __________ parts and put them together to make one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.677678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3865-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When solving division problems, sometimes a remainder is recorded as the number left over."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3865-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When solving division problems, sometimes a remainder can be ignored."@en ;
  dcterms:modified "2026-02-12T08:59:21.677687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3865-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When solving division problems, sometimes an extra group is made to include the remainder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3865-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question asked in the problem shows whether we should ignore or include the remainder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677698Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3565-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of ten that total one hundred can help with adding and subtracting 3-digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3565-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Doubles and near doubles can be helpful when adding multiples of ten together."@en ;
  dcterms:modified "2026-02-12T08:59:21.677733Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3565-3
  a oakcurric:KeyLearningPoint ;
