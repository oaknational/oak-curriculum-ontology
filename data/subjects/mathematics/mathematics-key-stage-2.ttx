oak:keylearningpoint-lesson-7239-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 100 one thousandths in one tenth."@en ;
  dcterms:modified "2026-02-12T08:59:21.611378Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7239-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 1,000 one thousandths in one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.611388Z"^^xsd:dateTime .

