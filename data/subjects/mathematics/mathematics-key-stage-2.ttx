  dcterms:modified "2026-02-12T08:59:21.654846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3967-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sentence 'The __________ is ___ times the size of the __________' supports us to describe a comparison or change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654850Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3967-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If units are different, we should convert so that they are the same - this supports us to calculate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654855Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3967-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To find a missing factor, we can divide the product by the known factor."@en ;
  dcterms:modified "2026-02-12T08:59:21.654859Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7127-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I increase this addend by __ then the sum will increase by the same amount."@en ;
  dcterms:modified "2026-02-12T08:59:21.655171Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7127-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I decrease this addend by __ then the sum will decrease by the same amount."@en ;
  dcterms:modified "2026-02-12T08:59:21.655176Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7127-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A balance beam can represent unequal expressions or inequalities."@en ;
  dcterms:modified "2026-02-12T08:59:21.655180Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3795-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Dividing by ten moves all the digits one column to the right making them one tenth times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655185Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3795-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you divide a multiple of 10 by ten, the numbers move one place to the right and the zero in the ones disappears."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655189Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3795-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The zero only disappears if you are dividing a multiple of 10 by ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.655194Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3843-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The mirror line shows where a mirror is placed."@en ;
  dcterms:modified "2026-02-12T08:59:21.655198Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3843-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Patterns are symmetrical when they are exactly the same on each side of the mirror line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655203Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3843-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When placing a mirror on the line of symmetry, the image seen is the same as the other half of the symmetrical pattern."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655208Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3843-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pattern will be the same distance from the mirror line on both sides."@en ;
  dcterms:modified "2026-02-12T08:59:21.655212Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3535-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Representations help to identify the calculation needed to solve a problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.655217Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3535-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different strategies can be applied to solve different problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.655221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3535-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Evaluating or discussing strategies helps to find the most efficient one."@en ;
  dcterms:modified "2026-02-12T08:59:21.655226Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3811-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An item can be a whole or a part depending on the situation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655231Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3811-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use of ‘If the ___ is the whole, then the ___ are a part of the whole.’ supports us to identify the whole and parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655238Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3811-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole can be different in different situations."@en ;
  dcterms:modified "2026-02-12T08:59:21.655245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3811-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A part is always smaller than the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.655249Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3687-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three points on a geoboard can be joined to make a triangle."@en ;
  dcterms:modified "2026-02-12T08:59:21.655256Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3687-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Triangles can have different properties."@en ;
  dcterms:modified "2026-02-12T08:59:21.655261Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3687-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different triangles can be created on the same geoboard."@en ;
  dcterms:modified "2026-02-12T08:59:21.655266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3667-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To compare non-unit fractions, the whole must be the same for each fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.655270Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3667-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the numerators are the same, the greater the denominator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655275Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3667-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the denominators are the same, the greater the numerator, the greater the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655279Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3674-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If fractions have the same denominator they can be added on."@en ;
  dcterms:modified "2026-02-12T08:59:21.655284Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3674-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 2 plus 3 is equal to 5 then 2 one sevenths plus 3 one sevenths is equal to 5 one sevenths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655288Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3674-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To add fractions with the same denominator you use the language of unitising."@en ;
  dcterms:modified "2026-02-12T08:59:21.655293Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4062-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Angles describe and measure a turn or rotation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4062-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Protractors can be used to measure and draw angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.655304Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4062-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use knowledge of right angles to estimate and compare angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.655309Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3774-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of 3 have a digit sum of a multiple of 3 and multiples of 6 are even multiples of 3"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3774-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you can halve a number twice and get a whole number then the original number is a multiple of 4"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655318Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3774-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you can halve a multiple of 4 and get a whole number then the original number is a multiple of 8"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655323Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4221-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one addend is increased and the other is decreased by the same amount, the sum stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655614Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4221-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the minuend and subtrahend are changed by the same amount, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655619Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4036-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Equivalent fractions have different numerators and denominators but represent the same value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655624Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4036-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equivalent fractions have the same position on a number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.655628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4036-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equivalent fractions represent the same quantity or area."@en ;
  dcterms:modified "2026-02-12T08:59:21.655632Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3833-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Times table knowledge can help to convert an improper fraction to a mixed number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655639Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3833-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Work out how many wholes can be made from the numerator of the improper fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655644Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3833-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Any fractions left over form the fraction part of the mixed number."@en ;
  dcterms:modified "2026-02-12T08:59:21.655651Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4099-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting on and back identifies the unlabelled marks on the number line."@en ;
  dcterms:modified "2026-02-12T08:59:21.655656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4099-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Thinking about the value of the digits helps to position numbers on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4099-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Work out which points a number lies between to help position it on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3921-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the ones digits is greater than 10 then you regroup ten ones into one ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3921-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the 1-digit number and the tens digit is greater than 100 then you regroup ten 10s into one 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655674Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3921-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the 1-digit number and the 100s digit is greater than 1,000 then you regroup ten 100s into one 1,000"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655679Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4237-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "5 divided by ___ minus 3 divided by ___ is equal to 2 divided by ___"@en ;
  dcterms:modified "2026-02-12T08:59:21.655683Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4237-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Where there is a common divisor, the dividends can be subtracted and the difference divided by the divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655688Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4237-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The distributive law can be very useful for solving problems where there is a common divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655692Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4237-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You can use brackets in an equation to show that you have used the distributive law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655697Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3736-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In a regular polygon, the sides are all the same length and the angles are all the same size"""@en ;
  dcterms:modified "2026-02-12T08:59:21.655701Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3736-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In an irregular polygon the sides and angles are not all the same sizes"@en ;
  dcterms:modified "2026-02-12T08:59:21.655706Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3736-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Irregular polygons can have some angles and sides the same sizes"@en ;
  dcterms:modified "2026-02-12T08:59:21.655710Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3559-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Knowing where multiples of 100 are placed on an unmarked number line supports in positioning 3-digit numbers accurately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655715Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3559-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Marking halfway steps helps to estimate the positions of numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.655719Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3559-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Counting in steps of 1, 10 and 100 helps us to position a number on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655726Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3812-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The parts that make up a whole can be equal or unequal in size."@en ;
  dcterms:modified "2026-02-12T08:59:21.655731Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3812-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole can be made of many parts, many parts can make the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.655736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3812-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We can describe the parts in the whole using the stem sentence: there are ___ equal/unequal parts in the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655741Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7241-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Apply known facts and place value to solve problems involving up to 3 decimal places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655745Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7241-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Extend column addition and subtraction to include numbers with up to 3 decimal places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655750Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7241-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use number facts to 10 to bridge through ones, tenths and hundredths."@en ;
  dcterms:modified "2026-02-12T08:59:21.655755Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4065-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A representation helps to identity the parts and wholes."@en ;
  dcterms:modified "2026-02-12T08:59:21.655759Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4065-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A representation helps to identify a missing part."@en ;
  dcterms:modified "2026-02-12T08:59:21.655764Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4065-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A representation helps to identify the calculation needed to find the missing part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655770Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3623-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 8 are double the multiples of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.655999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3623-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 4 are half the multiples of 8"@en ;
  dcterms:modified "2026-02-12T08:59:21.656004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3623-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of 8 are all multiples of 4 but not all multiples of 4 are multiples of 8"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3982-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use scaling to convert the decimal fraction to a whole number; after dividing, use scaling to adjust the answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656034Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3982-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Short division can be used to divide; the decimal point in the answer must be aligned with that in the decimal fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656038Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3982-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Estimation should be used to sense-check answers."@en ;
  dcterms:modified "2026-02-12T08:59:21.656043Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3818-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mixed numbers are quantities that are made up of a whole number part and a fractional part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656048Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3818-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Addition and subtraction calculations represent how mixed numbers can be composed or decomposed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656052Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3818-3
  a oakcurric:KeyLearningPoint ;
