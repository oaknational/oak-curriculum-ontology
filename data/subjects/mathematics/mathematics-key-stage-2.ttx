  a oakcurric:KeyLearningPoint ;
  rdfs:label "The change in the sum is equal to the change in the missing addend."@en ;
  dcterms:modified "2026-02-12T08:59:21.666851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7129-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To calculate the missing addend, the known addend must be subtracted from the sum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7129-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent a calculation with a missing addend."@en ;
  dcterms:modified "2026-02-12T08:59:21.666860Z"^^xsd:dateTime .

