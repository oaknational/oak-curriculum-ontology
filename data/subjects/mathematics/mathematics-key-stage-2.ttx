  dcterms:modified "2026-02-12T08:59:15.814226Z"^^xsd:dateTime .

oak:keyword-redistribution
  a oakcurric:Keyword ;
  schema:name "Redistribution"@en ;
  schema:description """Redistribution is where part of one addend is moved to another addend. It is sometimes known as the same sum rule."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814230Z"^^xsd:dateTime .

oak:keyword-decimal-fraction
  a oakcurric:Keyword ;
  schema:name "Decimal fraction"@en ;
  schema:description """A decimal fraction is a fraction written as a decimal. A decimal point separates whole numbers from decimal fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814236Z"^^xsd:dateTime .

oak:keyword-graph
  a oakcurric:Keyword ;
  schema:name "graph"@en ;
  schema:description """A graph is a visual way of showing information. A Bar Graph uses bars of different lengths or heights to represent information."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814286Z"^^xsd:dateTime .

oak:keyword-axis
  a oakcurric:Keyword ;
  schema:name "axis"@en ;
  schema:description """An axis on a graph is a fixed measuring line that runs horizontally (left to right) and/or vertically from zero:"""@en ;
  dcterms:modified "2026-02-12T08:59:15.814290Z"^^xsd:dateTime .

oak:keyword-right-angle
  a oakcurric:Keyword ;
  schema:name "Right angle"@en ;
  schema:description "A right angle is a quarter of a full turn. It can be known as a ‘square corner’."@en ;
  dcterms:modified "2026-02-12T08:59:15.814346Z"^^xsd:dateTime .

oak:keyword-order-of-operations
