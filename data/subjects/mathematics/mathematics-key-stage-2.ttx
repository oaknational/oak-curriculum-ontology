  dcterms:modified "2026-02-12T08:59:21.691319Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4073-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one part is increased and the other is decreased by the same amount, the whole stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691324Z"^^xsd:dateTime .

