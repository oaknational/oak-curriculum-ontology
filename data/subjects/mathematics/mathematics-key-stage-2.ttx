  dcterms:modified "2026-02-12T08:59:21.660913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7130-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A balance beam can be used to represent equivalence and compensation."@en ;
  dcterms:modified "2026-02-12T08:59:21.660918Z"^^xsd:dateTime .

