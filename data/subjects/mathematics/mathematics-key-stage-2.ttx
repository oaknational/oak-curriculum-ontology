# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oak:keyword-comma
  a oakcurric:Keyword ;
  schema:name "comma"@en ;
  schema:description "a punctuation mark used after a fronted adverbial of time"@en ;
  dcterms:modified "2026-02-12T08:59:15.789603Z"^^xsd:dateTime .

oak:keyword-tenth
  a oakcurric:Keyword ;
  schema:name "tenth"@en ;
  schema:description "A tenth is the name you give to one part of ten equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:15.789802Z"^^xsd:dateTime .

oak:keyword-decimal-number
  a oakcurric:Keyword ;
  schema:name "decimal number"@en ;
  schema:description """A decimal number has a decimal point followed by digits that show the fractional part."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789807Z"^^xsd:dateTime .

oak:keyword-fraction
  a oakcurric:Keyword ;
  schema:name "fraction"@en ;
  schema:description "A fraction shows us how many equal parts in a whole."@en ;
  dcterms:modified "2026-02-12T08:59:15.789811Z"^^xsd:dateTime .

oak:keyword-mixed-number
  a oakcurric:Keyword ;
  schema:name "mixed number"@en ;
  schema:description """A number which combines both a whole number and a fraction is known as a mixed number."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789815Z"^^xsd:dateTime .

oak:keyword-systematically
  a oakcurric:Keyword ;
  schema:name "systematically"@en ;
  schema:description """when something is done systematically it is done in a way that is done according to an agreed set of methods or organised plan"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790007Z"^^xsd:dateTime .

oak:keyword-groups
  a oakcurric:Keyword ;
  schema:name "Groups"@en ;
  schema:description """Grouping is when we divide a number of objects into equal groups. We know the total number of objects and the number of objects in each group, but we do not know how many equal groups there are."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790595Z"^^xsd:dateTime .

oak:keyword-remainder
  a oakcurric:Keyword ;
  schema:name "Remainder"@en ;
  schema:description """A remainder is the amount left over after division when the dividend does not divide exactly by the divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790604Z"^^xsd:dateTime .

oak:keyword-divided
  a oakcurric:Keyword ;
  schema:name "Divided"@en ;
  schema:description """Division means splitting into equal parts or groups. ___ is divided into groups of ___"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790609Z"^^xsd:dateTime .

oak:keyword-deduce
  a oakcurric:Keyword ;
  schema:name "deduce"@en ;
  schema:description """to reach a conclusion or form an opinion based on available information or evidence"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790613Z"^^xsd:dateTime .

oak:keyword-simplify
  a oakcurric:Keyword ;
  schema:name "Simplify"@en ;
  schema:description """Simplifying is to write an expression in a more efficient and compact form without affecting the value of the original expression. Fully simplifying means the expression cannot be simplified further."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790930Z"^^xsd:dateTime .

oak:keyword-value
  a oakcurric:Keyword ;
  schema:name "value"@en ;
