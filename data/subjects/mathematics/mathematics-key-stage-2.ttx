  dcterms:modified "2026-02-12T08:59:21.694797Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3773-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A square number of objects can be arranged into a square array."@en ;
  dcterms:modified "2026-02-12T08:59:21.694802Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3773-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A square number can be represented as the product of two factors which are the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3773-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When both factors have the same value, the product is called a square number."@en ;
  dcterms:modified "2026-02-12T08:59:21.694811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3618-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjacent multiples of 4 have a difference of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.695404Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3618-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you add 4 to a multiple of 4 you get the next multiple of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.695411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3618-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you subtract 4 from a multiple of 4 you get the previous multiple of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.695416Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4177-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Common multiples help you to convert a fraction to a common denominator."@en ;
  dcterms:modified "2026-02-12T08:59:21.695420Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4177-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When adding fractions the denominators have to be the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.695425Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4177-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The language of unitising helps you to add fractions with the same denominators."@en ;
  dcterms:modified "2026-02-12T08:59:21.695429Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4177-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When adding fractions with the same denominators you just add the numerators,"@en ;
  dcterms:modified "2026-02-12T08:59:21.695436Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3910-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Coordinates can include negative values"@en ;
  dcterms:modified "2026-02-12T08:59:21.705989Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3910-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The x or horizontal value is always the first value in a coordinate"@en ;
  dcterms:modified "2026-02-12T08:59:21.705994Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3910-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The y or vertical value is always the second value in a coordinate"@en ;
  dcterms:modified "2026-02-12T08:59:21.705998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3950-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The area of a rectangle is similar to an array for multiplication."@en ;
  dcterms:modified "2026-02-12T08:59:21.707432Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3950-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Times table knowledge helps you to calculate the area of a rectangle."@en ;
  dcterms:modified "2026-02-12T08:59:21.707437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3950-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To find the area of a rectangle you multiply the length by the width."@en ;
  dcterms:modified "2026-02-12T08:59:21.707441Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3976-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.1 can be represented as the fraction 1/10"@en ;
  dcterms:modified "2026-02-12T08:59:21.707836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3976-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 0.1 is the same as multiplying by 1/10"@en ;
  dcterms:modified "2026-02-12T08:59:21.707843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3976-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 1/10 is the same as dividing by 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.707848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3976-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 0.1 is the same as dividing by 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.707854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3900-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Informal calculation strategies such as rounding and compensating can be applied to calculating with money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3900-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Same sum generalisation can be applied to calculating with money."@en ;
  dcterms:modified "2026-02-12T08:59:21.707938Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3900-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Column subtraction can be used to calculate with money but is not always the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707942Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4130-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Identify the digit in the place value place the number is being rounded to - then find the previous and next multiples."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4130-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Then identify the digit to the right of this - this is the critical digit."@en ;
  dcterms:modified "2026-02-12T08:59:21.708589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4130-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the critical digit is a four or less, we round to the previous multiple."@en ;
  dcterms:modified "2026-02-12T08:59:21.708593Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4130-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the critical digit is a five of more, we round to the next multiple."@en ;
  dcterms:modified "2026-02-12T08:59:21.708598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4096-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We use commas to separate the thousands from the ones and the millions from the thousands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712855Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4096-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Grouping the digits in threes helps to read numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.712859Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4096-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Grouping the digits in threes helps to write numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.712866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4131-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fluent calculation requires flexibility to move between mental and written methods and supports us to be efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713920Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4131-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Looking at the numbers within a calculation supports us to know whether to use a mental strategy or written method."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713925Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4131-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mental strategies work best when known facts are used."@en ;
  dcterms:modified "2026-02-12T08:59:21.713932Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4131-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Written methods work best when the numbers given are precise or when exchanging is involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713937Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4104-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One million is composed of one thousand thousands."@en ;
  dcterms:modified "2026-02-12T08:59:21.714175Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4104-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The powers of 10 are the column headings in a place value chart."@en ;
  dcterms:modified "2026-02-12T08:59:21.714179Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4104-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each column is ten times the value of the column to its right."@en ;
  dcterms:modified "2026-02-12T08:59:21.714184Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4129-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sometimes numbers are rounded as approximations or to give an estimate or average."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4129-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To round to the nearest multiple of 1,000,000 identify the previous and next multiples of one million and the midpoint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714557Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4129-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When we round to the nearest multiple of one million, the critical digit is the 100,000s digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4129-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the critical digit is a 4 or less, we round to the previous multiple of one million."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714569Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4129-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the critical digit is a 5 or more, we round to the next multiple of one million."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714573Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4120-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The number of digits can help when ordering numbers - usually the more digits, the greater the number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714837Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4120-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing numbers, the greatest value digit that is different determines the greater number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4120-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The stem sentence: 'the value of the digit in the ___ column is ___’ supports us to compare numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4132-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Looking at the numbers involved and using number-sense supports us to know which strategy is more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714916Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4132-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A number line is a useful mental strategy when it is obvious what to add or subtract."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714921Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4132-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When using a formal written method the concept of constant difference can be used to make the calculation easier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714925Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3977-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.01 can be represented as the fraction 1/100"@en ;
  dcterms:modified "2026-02-12T08:59:21.714987Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3977-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 0.01 is the same as multiplying by 1/100"@en ;
  dcterms:modified "2026-02-12T08:59:21.714991Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3977-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 1/100 is the same as dividing by 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.714995Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3977-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplying by 0.01 is the same as dividing by 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.715000Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4133-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We know different strategies for addition and subtraction including mental and written strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4133-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Looking at the numbers helps us see which strategy is most efficient."@en ;
  dcterms:modified "2026-02-12T08:59:21.715168Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4133-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Missing number problems can be rearranged to identify an efficient strategy to solve the problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715172Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3778-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When zero is a factor, the product is zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.719551Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3778-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Zero can represent the group size or the number of groups in a multiplication context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3778-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In a division, zero can be the dividend but not the divisor."@en ;
  dcterms:modified "2026-02-12T08:59:21.719559Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3999-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A common multiple is a multiple which is shared by 2 or more numbers"@en ;
  dcterms:modified "2026-02-12T08:59:21.719564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4182-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the numerator is the same, the greater the denominator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4182-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the numerator is the same, the greater the numerator, the larger the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719863Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4182-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In fractions equivalent to a whole, the numerator is the same as the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719867Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4182-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In fractions equivalent to a half, the numerator is half the value of the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719871Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4080-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If I add __ to the minuend and add the same number to the subtrahend, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4080-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If I subtract __ from the minuend and add the same number to the subtrahend, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719880Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4080-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent the 'same difference' generalization."@en ;
  dcterms:modified "2026-02-12T08:59:21.719887Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3854-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 7 days in a week"@en ;
  dcterms:modified "2026-02-12T08:59:21.720549Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3854-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 12 months in a year"@en ;
  dcterms:modified "2026-02-12T08:59:21.720554Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3854-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are between 28 and 31 days in a month"@en ;
  dcterms:modified "2026-02-12T08:59:21.720558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4082-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Compensation can be used to simplify subtraction calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.722046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4082-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equivalence can be used to simplify subtraction calculations."@en ;
  dcterms:modified "2026-02-12T08:59:21.722051Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4082-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent compensation and equivalence."@en ;
  dcterms:modified "2026-02-12T08:59:21.722055Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7231-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the dividend is multiplied by 100 then the quotient will be one hundred times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723277Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7231-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The dividend is equivalent to the product in the inverse calculation."@en ;
  dcterms:modified "2026-02-12T08:59:21.723282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7231-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """18 divided by 6 is equal to 3 so 1,800 divided by 6 is equal to 300 or 18 hundreds divided by 6 is equal to 3 hundreds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723286Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4175-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A common factor is a number which is a factor of both the numerator and denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723845Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4175-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A fraction is in its simplest form when there is no common factor of the numerator and the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723849Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4222-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one addend is increased and the other is decreased by the same amount, the sum stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4222-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the minuend and subtrahend are changed by the same amount, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3602-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equations can be represented using part-part-whole or bar models."@en ;
  dcterms:modified "2026-02-12T08:59:21.723862Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3602-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the minuend is missing, you add the subtrahend and difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.723866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3602-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To find a missing part in a subtraction equation, subtract the other part from the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723871Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4123-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Powers of 10 and their multiples can be subtracted using the language of unitising."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4123-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Known facts can be used alongside unitising to subtract powers of 10 and their multiples."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4123-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Subtraction of powers of 10 and their multiples can be represented on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725674Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4094-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ten one thousands make ten thousand."@en ;
  dcterms:modified "2026-02-12T08:59:21.727691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4094-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One hundred hundreds make ten thousand."@en ;
  dcterms:modified "2026-02-12T08:59:21.727697Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4094-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One thousand tens make ten thousand."@en ;
  dcterms:modified "2026-02-12T08:59:21.727702Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3720-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use known facts to solve problems involving measures."@en ;
  dcterms:modified "2026-02-12T08:59:21.727707Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3720-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use informal methods such as partitioning and bridging to solve problems involving measures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3720-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Convert between units of measure to simplify problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.727715Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3660-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole can be a set of objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.728626Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3660-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Calculating the value of a part, is the same as dividing the whole by the number of equal parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3660-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The denominator tells us the number of equal parts in the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.728635Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3660-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Drawing a bar model supports us to visualise the problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.728639Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3660-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Times table and division facts help us to find a fraction of a set of objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.728644Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3763-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 3 are also multiples of 9"@en ;
  dcterms:modified "2026-02-12T08:59:21.728922Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3763-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In any product in the 9 times table, there will always be three times the number of 3s as there are 9s"""@en ;
  dcterms:modified "2026-02-12T08:59:21.728926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7229-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the dividend is multiplied by 10 then the quotient will be ten times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7229-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The dividend is equivalent to the product in the inverse calculation."@en ;
  dcterms:modified "2026-02-12T08:59:21.728938Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7229-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """18 divided by 6 is equal to 3 so 180 divided by 6 is equal to 30 or 18 tens divided by 6 is equal to 3 tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728942Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4183-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are many ways to compare and order fractions."@en ;
  dcterms:modified "2026-02-12T08:59:21.730863Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4183-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the numerator is the same, the greater the denominator, the smaller the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730869Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4183-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the denominator is the same, the greater the numerator, the larger the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4183-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In fractions equivalent to a whole, the numerator is the same as the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730880Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4183-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In fractions equivalent to a half, the numerator is half the value of the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730885Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3759-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 9 is equal to 10 subtract 1 then 9 groups of 15 is equal to 10 groups of 15 subtract 1 group of 15"""@en ;
  dcterms:modified "2026-02-12T08:59:21.731921Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3759-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Facts from the 10 times table can be used to solve problems involving the 9 times table."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731925Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3759-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "10 times a number and 9 times a number are adjacent multiples."@en ;
  dcterms:modified "2026-02-12T08:59:21.731929Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3972-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 1,000 ml in 1 l"@en ;
  dcterms:modified "2026-02-12T08:59:21.733039Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3972-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 1.000 g in 1 kg"@en ;
  dcterms:modified "2026-02-12T08:59:21.733043Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3972-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 10 dl in 1 l"@en ;
  dcterms:modified "2026-02-12T08:59:21.733049Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3972-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 100 cl in 1 l"@en ;
  dcterms:modified "2026-02-12T08:59:21.733053Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3972-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We can use knowledge of multiplying and dividing by 10, 100 and 1,000 to convert between units of mass and capacity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733057Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3974-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are one hundred hundredths in one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.733063Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3974-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are ten hundredths in one tenth."@en ;
  dcterms:modified "2026-02-12T08:59:21.733067Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3974-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Unitising can help to multiply hundredths by whole numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.733071Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3974-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sentence: ___ times ___ ones is equal to ___ ones so ___ times ___ hundredths is equal to ___ hundredths supports us"""@en ;
  dcterms:modified "2026-02-12T08:59:21.733075Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3975-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using knowledge of multiplying decimal numbers with whole numbers can help us solve measures problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733472Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3975-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """__ times __ ones is equal to __ ones, so __ times __ tenths/hundredths is equal to __ tenths/hundredths.’ supports us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3975-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Unitising of known facts can be used to support calculating with decimal fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3975-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When we multiply by ten, the digits move one place value place to the left."@en ;
  dcterms:modified "2026-02-12T08:59:21.733484Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3764-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """For a number to be divisible by three, the dgit sum of the number must be a divisible by 3"""@en ;
  dcterms:modified "2026-02-12T08:59:21.733488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3764-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "For a number to be divisible by 6, it must be divisible by both 2 and 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.733491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3764-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you halve a number and the digit sum of the half is a multiple of 3 then the number is divisible by 6"""@en ;
  dcterms:modified "2026-02-12T08:59:21.733495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4079-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is easier to use a written strategy for subtraction when no exchanging is required."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4079-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the minuend and subtrahend are both increased by the same amount, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733503Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4079-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the minuend and subtrahend are both decreased by the same amount, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733507Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3791-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "10 is ten times the size of 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.734811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3791-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A digit in the tens column is 10 times the value of a digit in the ones column"@en ;
  dcterms:modified "2026-02-12T08:59:21.734815Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3791-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 have a zero in the ones column"@en ;
  dcterms:modified "2026-02-12T08:59:21.734819Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3596-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Addition and subtraction can be done in any order"@en ;
  dcterms:modified "2026-02-12T08:59:21.735423Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3596-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you do the addition and subtraction in a different order, the answer will be the same"""@en ;
  dcterms:modified "2026-02-12T08:59:21.735427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3596-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Problems can have equal answers even when different numbers are added and subtracted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735431Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3981-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When we divide decimal fractions by 1-digit numbers, make the decimal into a whole number by multiplying by 10 or 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.735876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3981-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Then use unitising and known facts to divide."@en ;
  dcterms:modified "2026-02-12T08:59:21.735882Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3981-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The answer can then be adjusted by division."@en ;
  dcterms:modified "2026-02-12T08:59:21.735886Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4122-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Powers of 10 and their multiples can be added using the language of unitising."@en ;
  dcterms:modified "2026-02-12T08:59:21.735890Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4122-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Known facts can be used alongside unitising to add powers of 10 and their multiples."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735894Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4122-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Addition of powers of 10 and their multiples can be represented on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735898Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3775-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are divisibility rules for 2, 4 and 8 which involve halving, halving twice and halving three times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736104Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3775-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of 10 have a zero in the ones and multiples of 5 have a 5 or a zero in the ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736108Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3775-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 3 have a digit sum of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.736112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3775-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 6 are even numbered multiples of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.736116Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3897-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Prices are often 1p or £1 lower than the next whole number of pounds so £2.99 not £3.00"""@en ;
  dcterms:modified "2026-02-12T08:59:21.736120Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3897-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line supports rounding and adjusting strategies"@en ;
  dcterms:modified "2026-02-12T08:59:21.736124Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3897-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You might round one addend or all the addends"@en ;
  dcterms:modified "2026-02-12T08:59:21.736128Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3897-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjust the answer according to the rounding"@en ;
  dcterms:modified "2026-02-12T08:59:21.736131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3930-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the hundreds number is not a multiple of the divisor then the remainder is regrouped for tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736907Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3930-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the tens number is not a multiple of the divisor then the remainder is regrouped for ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736910Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3930-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Place value resources can represent the division and the regrouping."@en ;
  dcterms:modified "2026-02-12T08:59:21.736914Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3973-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 10 tenths in one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.737133Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3973-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Unitising can help to multiply tenths by whole numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.737137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3973-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplication of tenths can be represented as repeated addition of tenths."@en ;
  dcterms:modified "2026-02-12T08:59:21.737140Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3973-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘___ times ___ ones is equal to ___ ones so ___ times ___ tenths is equal to ___ tenths’ supports us to multiply tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737144Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3765-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Knowing the 3 times table can help you to solve problems"@en ;
  dcterms:modified "2026-02-12T08:59:21.737989Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3765-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Knowing the 6 times table can help you to solve problems"@en ;
  dcterms:modified "2026-02-12T08:59:21.737993Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3765-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Knowing the 9 times table can help you to solve problems"@en ;
  dcterms:modified "2026-02-12T08:59:21.737999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3899-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Informal calculation strategies such as rounding and compensating can be applied to calculating with money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738161Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3899-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Same sum generalisation can be applied to calculating with money."@en ;
  dcterms:modified "2026-02-12T08:59:21.738164Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3899-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Column addition can be used to calculate with money but is not always the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738168Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3771-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Knowing if the product will be odd or even can help to solve problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.738788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3771-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the times table is odd, the products will alternate between odd and even."@en ;
  dcterms:modified "2026-02-12T08:59:21.738792Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3771-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the times table is even, the products will all be even."@en ;
  dcterms:modified "2026-02-12T08:59:21.738795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4176-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You divide the numerator and denominator by the same factor to create the equivalent fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4176-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A fraction is in its simplest form when there is no common factor of the numerator and the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738803Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4176-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fractions greater than 1 can be simplified in the same way."@en ;
  dcterms:modified "2026-02-12T08:59:21.738807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4107-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Numbers can be read and written by identifying the number of millions, thousands and hundreds, tens and ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4107-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Digits are grouped in threes to show the ones, thousands and millions."@en ;
  dcterms:modified "2026-02-12T08:59:21.738815Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4107-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The groups of 3 digits are separated with a comma."@en ;
  dcterms:modified "2026-02-12T08:59:21.738820Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4107-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """We assume that the digit on the right hand side is the ones digit unless we have a decimal fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738825Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4121-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Known facts to 10 can be applied when adding and subtracting 100s, 1,000s, 10,000s and 100,000s"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739024Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4121-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When adding and subtracting mentally, the language of unitising supports us in addition to using known facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739028Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4121-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An understanding of the structure of numbers and place value supports when we add and subtract mentally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739034Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4174-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A fraction in its simplest form is equivalent to the original fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.741425Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4174-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equivalent fractions have the same value."@en ;
  dcterms:modified "2026-02-12T08:59:21.741429Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4174-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To simplify fractions you divide the numerator and denominator by a common factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741433Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3603-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When a whole is missing, add the parts together."@en ;
  dcterms:modified "2026-02-12T08:59:21.741437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3603-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To find a missing part, subtract the other part from the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.741441Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3603-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearrange the equation to make it easier to calculate the missing number."@en ;
  dcterms:modified "2026-02-12T08:59:21.741445Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7143-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplication can be simplified by factorising one of the factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.742753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7143-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the multiplication will involve regrouping then a written method may be more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742759Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7143-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the multiplication will not involve regrouping then a mental or informal method may be more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742763Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3980-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one factor is made ___ times the size and the other factor remains the same, the product will be ___ times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743643Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3980-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When a number is multiplied by a value less than one, the product is smaller than the original number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743647Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3980-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When a number is multiplied by a value greater than one, the product is greater than the original number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743651Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3757-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjacent multiples of nine have a difference of 9"@en ;
