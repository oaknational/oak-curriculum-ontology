  dcterms:modified "2026-02-12T08:59:15.799094Z"^^xsd:dateTime .

oak:keyword-scaling
  a oakcurric:Keyword ;
  schema:name "Scaling"@en ;
  schema:description """Scaling is when a given quantity is made ___ times the size. It can be used to adjust the size of a factor. In this lesson, scaling will involve making values 10 or 100 times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799182Z"^^xsd:dateTime .

oak:keyword-represent
  a oakcurric:Keyword ;
  schema:name "Represent"@en ;
