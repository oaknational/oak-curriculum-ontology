  dcterms:modified "2026-02-12T08:59:21.623753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4044-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 inch is approximately equal to 2.5cm."@en ;
  dcterms:modified "2026-02-12T08:59:21.623844Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4044-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 pound (lb) is approximately 0.5kg."@en ;
  dcterms:modified "2026-02-12T08:59:21.623849Z"^^xsd:dateTime .

