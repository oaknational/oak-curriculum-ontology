  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the value of the digit you are looking at is 5 or more you round to the next multiple."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659543Z"^^xsd:dateTime .

