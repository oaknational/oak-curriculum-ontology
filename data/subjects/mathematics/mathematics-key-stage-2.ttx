  dcterms:modified "2026-02-12T08:59:21.612335Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4033-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into __ equal parts and you have __ of them."@en ;
  dcterms:modified "2026-02-12T08:59:21.612342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7149-1
  a oakcurric:KeyLearningPoint ;
