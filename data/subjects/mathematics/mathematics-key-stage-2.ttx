  dcterms:modified "2026-02-12T08:59:21.611894Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3648-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One equal part is shaded so each equal part is __ of the whole"@en ;
  dcterms:modified "2026-02-12T08:59:21.611901Z"^^xsd:dateTime .

