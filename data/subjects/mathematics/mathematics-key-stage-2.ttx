  dcterms:modified "2026-02-12T08:59:21.611927Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4033-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you compare two fractions, the whole must be the same."@en ;
