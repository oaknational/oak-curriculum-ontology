  dcterms:modified "2026-02-12T08:59:21.682496Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4056-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One and a half right angles are 135 degrees."@en ;
  dcterms:modified "2026-02-12T08:59:21.682501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4139-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The area of a parallelogram is equal to the area of the rectangle created by rearranging the parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4139-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A parallelogram can be decomposed into a rectangle and 2 identical triangles."@en ;
  dcterms:modified "2026-02-12T08:59:21.682510Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4139-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearranging the parts of a parallelogram helps to calculate the area."@en ;
  dcterms:modified "2026-02-12T08:59:21.682515Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3649-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equal parts may not look the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.682519Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3649-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into __ equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.682524Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3649-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One equal part has been filled so each equal part is __ of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.682531Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3650-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The whole has been divided into __ equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.682536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3650-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each equal part is one-__ of the whole."@en ;
