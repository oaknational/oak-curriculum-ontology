  dcterms:modified "2026-02-12T08:59:15.791180Z"^^xsd:dateTime .

oak:keyword-inequality
  a oakcurric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "inequality is when something is not shared evenly between everyone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791205Z"^^xsd:dateTime .

oak:keyword-whole
  a oakcurric:Keyword ;
