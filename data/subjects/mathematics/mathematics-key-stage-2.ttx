oak:keylearningpoint-lesson-4201-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I know about a part, I can work out the whole from that part."@en ;
  dcterms:modified "2026-02-12T08:59:21.666817Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4201-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I know what 10% is, I can multiply by 10 to calculate 100%."@en ;
  dcterms:modified "2026-02-12T08:59:21.666824Z"^^xsd:dateTime .

