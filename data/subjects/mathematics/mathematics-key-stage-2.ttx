  dcterms:modified "2026-02-12T08:59:15.814492Z"^^xsd:dateTime .

oak:keyword-halve
  a oakcurric:Keyword ;
  schema:name "Halve"@en ;
  schema:description "To divide into two equal parts."@en ;
  dcterms:modified "2026-02-12T08:59:15.814538Z"^^xsd:dateTime .

oak:keyword-half-turn
  a oakcurric:Keyword ;
