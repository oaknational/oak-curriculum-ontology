  dcterms:modified "2026-02-12T08:59:15.798986Z"^^xsd:dateTime .

oak:keyword-volume
  a oakcurric:Keyword ;
  schema:name "Volume"@en ;
  schema:description """Volume is the amount of space that an object takes up. In this case, the specific amount of liquid in a container. Volume can be measured in millilitres and litres."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798990Z"^^xsd:dateTime .

oak:keyword-symmetrical
