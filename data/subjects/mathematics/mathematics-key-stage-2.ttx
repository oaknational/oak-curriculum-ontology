  dcterms:modified "2026-02-12T08:59:21.677771Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3526-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 100 ones in 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3526-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "100 can be represented in different ways and in different contexts"@en ;
  dcterms:modified "2026-02-12T08:59:21.677780Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3530-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Number facts to 10 can be applied to multiples of 10"@en ;
  dcterms:modified "2026-02-12T08:59:21.677785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3530-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Using pairs to 10 and pairs to 100 we can find pairs to 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3530-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If we have a pair to 10 then the tens have to total 90 for the whole to be 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.677794Z"^^xsd:dateTime .

