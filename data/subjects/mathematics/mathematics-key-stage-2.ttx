  dcterms:modified "2026-02-12T08:59:21.680464Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3619-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 2 are half the multiples of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.680471Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3619-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiples of 4 are all multiples of 2 but not all multiples of 2 are multiples of 4"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4040-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 mm = 0.001km"@en ;
  dcterms:modified "2026-02-12T08:59:21.680485Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4040-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 g = 0.001 kg"@en ;
  dcterms:modified "2026-02-12T08:59:21.680490Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4040-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 ml = 0.001 l"@en ;
  dcterms:modified "2026-02-12T08:59:21.680494Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4040-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "1 m = 0.001 km"@en ;
  dcterms:modified "2026-02-12T08:59:21.680499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3838-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To subtract mixed numbers, we need to use our fraction-sense to determine the most appropriate strategy to use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3838-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mixed numbers can be subtracted by counting back using a number line or by converting them to improper fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680508Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3838-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If mixed numbers are close, it is more efficient to ‘find the difference’ by counting forwards from part to whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3896-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 100p in £1.00 so £3.00 is equivalent to 300p"@en ;
  dcterms:modified "2026-02-12T08:59:21.680517Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3896-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 10 pennies in 10p so 4 ten pences are equivalent to 40 one pences."@en ;
  dcterms:modified "2026-02-12T08:59:21.680522Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3896-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use knowledge of equivalent values to convert between pounds and pence."@en ;
  dcterms:modified "2026-02-12T08:59:21.680527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3896-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "£3.45 is equivalent to 300p + 45p which is equal to 345p"@en ;
  dcterms:modified "2026-02-12T08:59:21.680532Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4188-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you divide a fraction by a whole number, you can calculate this efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4188-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the numerator is a multiple of the divisor, you can unitise to make the calculation easier to manage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680541Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4188-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the numerator is not a multiple of the whole, you can convert the equation to to multiply by a unit fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680545Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4188-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you divide a non-unit fraction by a whole number, you notice the denominator is multiplied by the whole number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3737-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Perimeter is a measurement of length."@en ;
  dcterms:modified "2026-02-12T08:59:21.680575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3737-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Perimeter is the distance around a 2D shape."@en ;
  dcterms:modified "2026-02-12T08:59:21.680580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4217-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Two similar shapes can be described as being 'x' times greater or smaller than each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4217-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If one similar shape is smaller than another, the scale factor is a fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.680589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4217-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Shapes related by a scale factor are similar."@en ;
  dcterms:modified "2026-02-12T08:59:21.680593Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3750-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If 4 times 5 is 20 then 4 times 6 is four more than 20"@en ;
  dcterms:modified "2026-02-12T08:59:21.680600Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3750-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you know 5 times a number you can add the number again to work out 6 times the number"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680605Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3750-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "5 times a number and 6 times a number are adjacent multiples"@en ;
  dcterms:modified "2026-02-12T08:59:21.680609Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3562-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Known facts can be used to help  calculate with multiples of a hundred."@en ;
  dcterms:modified "2026-02-12T08:59:21.680614Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3562-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If we know that 2 ones plus 4 ones equals 6 ones we know that 2 100s plus 4 100s equals 6 100s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680618Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3562-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Number facts to 10 can help us to add and subtract multiples of a hundred."@en ;
  dcterms:modified "2026-02-12T08:59:21.680623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3577-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Triangles always have three sides, vertices and angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.680627Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3577-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Triangles always have straight sides and sharp vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.680632Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3577-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Triangles can have right angles."@en ;
  dcterms:modified "2026-02-12T08:59:21.680636Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3577-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vertices are the corners of a shape."@en ;
  dcterms:modified "2026-02-12T08:59:21.680641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3693-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The minute hand moves around the full circle in one hour"@en ;
  dcterms:modified "2026-02-12T08:59:21.680648Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3693-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The minute hand shows how many minutes past the hour it is"@en ;
  dcterms:modified "2026-02-12T08:59:21.680652Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3693-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Between the hours on the clock face the scale also shows 5 minutes"@en ;
  dcterms:modified "2026-02-12T08:59:21.680657Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3600-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Equations can be represented using part-part-whole or bar models."@en ;
  dcterms:modified "2026-02-12T08:59:21.680662Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3600-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The subtrahend and difference are parts and the minuend is the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.680666Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3600-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Subtraction equations can start with the minuend or the difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.680670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3780-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying a number by a group of numbers added together is the same as doing each multiplication separately."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3780-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """This means a factor can be partitioned to solve multiplication problems more efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3780-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is important to consider which factor to partition so that it enables you to solve a problem more efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3780-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The factor being partitioned can represent the group size or the number of groups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7240-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To compare two numbers, you compare digits with the same place value, starting with the largest place-value digit"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7240-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If whole numbers. tenths and hundredths are the same, look at the value of the thousandths digit to compare and order"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3628-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you can halve a multiple of 4 then it is a multiple of 8 and divisible by 8"@en ;
  dcterms:modified "2026-02-12T08:59:21.681805Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3628-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "All numbers divisible by 8 are also divisible by 4 and 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.681810Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3628-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 8 are all multiples of both 2 and 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.681814Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3769-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting in sevens can help solve problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.681844Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3769-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting in sevens can be represented in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.681848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3769-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 7 times table can be represented as multiplication equations."@en ;
  dcterms:modified "2026-02-12T08:59:21.681853Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3727-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Column subtraction can be used to subtract 4-digit numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.681858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3727-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Work from the ones column on the right so that regrouping can be represented."@en ;
  dcterms:modified "2026-02-12T08:59:21.681865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3727-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the tens value of the subtrahend is greater than the tens value of the minuend, regroup 1 hundred as 10 tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3727-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the hundreds value of the subtrahend is greater than the hundreds of the minuend, regroup 1 thousand as 10 hundreds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681874Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3633-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Start with the numbers with the smallest place value."@en ;
  dcterms:modified "2026-02-12T08:59:21.681879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3633-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Regroup when the ones digit of the subtrahend is greater than the ones digit of the minuend."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681884Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3633-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Change the number of ones and tens in the minuend."@en ;
  dcterms:modified "2026-02-12T08:59:21.681888Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3551-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To convert between cm and mm, we can use the relationship between 1 cm and 10 mm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681893Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3551-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To convert between mm, and cm and mm, we can use partitioning."@en ;
  dcterms:modified "2026-02-12T08:59:21.681900Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3551-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Estimating the length or height of an object helps us to decide which unit to use when measuring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681904Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3920-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the ones digits is greater than 10 then you regroup ten ones into one ten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681930Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3920-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the 1-digit number and the tens digit is greater than 100 then you regroup ten 10s into one 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.681935Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3920-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the product of the 1-digit number and the 100s digit is greater than 1,000 then you regroup ten 100s into one 1,000"""@en ;
  dcterms:modified "2026-02-12T08:59:21.681939Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3561-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the 100s digits are different, the numbers can be compared or ordered by looking at the 100s digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681944Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3561-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the 100s digits are the same, the numbers can be compared or ordered by looking at the 10s digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681948Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3561-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the 100s and 10s digits are the same, the numbers can be compared or ordered by looking at the 1s digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681953Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3534-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The language of unitising helps us to use number facts to 20 to subtract multiples of 10 crossing the hundreds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3534-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 14 subtract 6 is equal to 8 then 14 tens subtract 6 tens is equal to 8 tens or 80."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681964Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3534-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning the subtrahend helps us to cross the 100s boundary."@en ;
  dcterms:modified "2026-02-12T08:59:21.681970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3853-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 60 minutes in an hour"@en ;
  dcterms:modified "2026-02-12T08:59:21.681974Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3853-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 60 seconds in a minute"@en ;
  dcterms:modified "2026-02-12T08:59:21.681979Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3853-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 6 and 10 times tables help to multiply and divide by 60"@en ;
  dcterms:modified "2026-02-12T08:59:21.681983Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3793-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 10 have a zero in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.681988Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3793-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A digit in the tens column is 10 times the value of a digit in the ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.681992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3793-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying by ten moves all the digits one column to the left making them ten times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3793-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When a number is multiplied by ten the product is a multiple of ten."@en ;
  dcterms:modified "2026-02-12T08:59:21.682004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4051-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A quadrilateral is a shape with four sides and four vertices."@en ;
  dcterms:modified "2026-02-12T08:59:21.682475Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4051-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Interior angles in a quadrilateral are composed of two triangles."@en ;
  dcterms:modified "2026-02-12T08:59:21.682480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4051-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Interior angles in a quadrilateral are equal to 360 degrees."@en ;
  dcterms:modified "2026-02-12T08:59:21.682484Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4056-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can estimate angles by comparing to a right angle of 90 degrees."@en ;
  dcterms:modified "2026-02-12T08:59:21.682491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4056-2
  a oakcurric:KeyLearningPoint ;
