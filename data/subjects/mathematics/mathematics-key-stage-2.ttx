  dcterms:modified "2026-02-12T08:59:15.799310Z"^^xsd:dateTime .

oak:keyword-associative
  a oakcurric:Keyword ;
  schema:name "associative"@en ;
  schema:description """The associative law states that it doesn't matter how you group or pair values (i.e. which we calculate first), the result is still the same. It applies for addition and multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799422Z"^^xsd:dateTime .

oak:keyword-commutative
  a oakcurric:Keyword ;
  schema:name "commutative"@en ;
  schema:description """The commutative law states that you can write the values of a calculation in a different order without changing the calculation; the result is the same. It applies for addition and multiplication."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799426Z"^^xsd:dateTime .

oak:keyword-change
  a oakcurric:Keyword ;
  schema:name "change"@en ;
