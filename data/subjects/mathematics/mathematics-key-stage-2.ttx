  dcterms:modified "2026-02-12T08:59:21.666829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7230-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If one factor is made one hundred times the size, the product will be one hundred times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7230-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One factor has been multiplied by 100 so the product is multiplied by 100"@en ;
  dcterms:modified "2026-02-12T08:59:21.666838Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7230-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When multiplying two numbers, if either factor is made 100 times the size, the product will be 100 times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666842Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7230-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """6 multiplied by 300 is equal to 600 multiplied by 3  or 6 hundreds multiplied by 3"""@en ;
  dcterms:modified "2026-02-12T08:59:21.666846Z"^^xsd:dateTime .

