  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bar models can represent the maths in a story or problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.623163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4064-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A story can represent the maths presented in a representation."@en ;
  dcterms:modified "2026-02-12T08:59:21.623172Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4064-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The structure of the maths can be represented by a model or a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.623178Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3965-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many things change and we need to describe the change mathematically."@en ;
  dcterms:modified "2026-02-12T08:59:21.623692Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3965-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sentence 'The __________ is ___ times the __________ of the __________' supports understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623697Z"^^xsd:dateTime .

