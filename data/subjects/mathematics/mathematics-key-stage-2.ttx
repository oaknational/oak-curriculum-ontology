  a oakcurric:KeyLearningPoint ;
  rdfs:label """Properties of number allow us to talk about numbers and to sort and classify them"""@en ;
  dcterms:modified "2026-02-12T08:59:21.661256Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3625-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 8 are multiples of 2 and of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.661469Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3625-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you double the multiples of 2 you get the multiples of 4"@en ;
  dcterms:modified "2026-02-12T08:59:21.661474Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3625-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you double the multiples of 4 you get the multiples of 8"@en ;
  dcterms:modified "2026-02-12T08:59:21.661479Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3625-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you double the multiples of 2 and double again you get the multiples of 8"@en ;
  dcterms:modified "2026-02-12T08:59:21.661486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4057-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 360 degrees in a full turn."@en ;
  dcterms:modified "2026-02-12T08:59:21.661491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4057-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use mental or written strategies to calculate with angles up to 360 degrees."@en ;
  dcterms:modified "2026-02-12T08:59:21.661495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3964-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A change in time or amount of money can be described multiplicatively."@en ;
  dcterms:modified "2026-02-12T08:59:21.661500Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3964-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sentence 'The __________ is ___ times the __________ of the __________' supports understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3964-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Comparisons of measure can be represented as multiplication or division equations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661512Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3831-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An improper fraction is a fraction where the value of the numerator is greater than the value of the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3831-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An improper fraction is greater than 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.661521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3831-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Four quarters are equal to one whole or 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.661525Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3831-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If there are quarters left, they form the fraction part of the mixed number."@en ;
  dcterms:modified "2026-02-12T08:59:21.661530Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3805-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use knowledge of polygon properties to identify a missing vertex."@en ;
  dcterms:modified "2026-02-12T08:59:21.661534Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3805-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Use known coordinates to plot a missing coordinate."@en ;
  dcterms:modified "2026-02-12T08:59:21.661539Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3586-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning can be used to add 3-digit numbers"@en ;
  dcterms:modified "2026-02-12T08:59:21.661544Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3586-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Unitising means we can use known facts to add larger numbers. For example, 370 + 260 is equal to 37 tens add 26 tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661548Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3902-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Informal calculation strategies such as rounding and compensating can be applied to calculating with money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3902-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'Same sum' and 'Same difference' can be applied to calculating with money."@en ;
  dcterms:modified "2026-02-12T08:59:21.661558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3902-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Column addition and subtraction can be used to calculate with money but is not always the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661562Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7142-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplication can be simplified by factorising one of the factors."@en ;
  dcterms:modified "2026-02-12T08:59:21.661567Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7142-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Look at the factors to identify which are composite numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.661574Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7142-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Composite numbers can be factorised."@en ;
  dcterms:modified "2026-02-12T08:59:21.661578Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7142-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiplication is commutative."@en ;
  dcterms:modified "2026-02-12T08:59:21.661584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7142-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Factors can be grouped in different ways and the product remains the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.661588Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3814-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the whole is the same, then two parts can be compared directly."@en ;
  dcterms:modified "2026-02-12T08:59:21.661593Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3814-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the whole increases whilst the part stays the same, then the part becomes a smaller part of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661597Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3814-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the whole decreases whilst the part stays the same, then the part becomes a bigger part of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661602Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3814-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Part and whole need consideration when judging whether a relatively large or small part of the whole is identified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661609Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7133-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The more you subtract the less you are left with."@en ;
  dcterms:modified "2026-02-12T08:59:21.661614Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7133-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The less you subtract the more you are left with."@en ;
  dcterms:modified "2026-02-12T08:59:21.661618Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7133-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent the change in the subtrahend."@en ;
  dcterms:modified "2026-02-12T08:59:21.661623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3826-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be combined in the same way as whole numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.662108Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3826-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If fractions have the same denominator, they can be added."@en ;
  dcterms:modified "2026-02-12T08:59:21.662113Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3826-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To add fractions with the same denominator, the language of unitising can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662118Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3548-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using the known fact that 100 cm are equivalent to 1 m can help us convert between cm and m."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662122Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3548-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Partitioning and using the relationship between 1 m and 100 cm can help us convert between cm, and m and cm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3548-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to estimate so you know if your answer is near to the real value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7141-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The digits in a number indicate its structure so it can be decomposed."@en ;
  dcterms:modified "2026-02-12T08:59:21.662136Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7141-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Numbers can be decomposed, or partitioned, according to the value of their digits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662140Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7141-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Missing parts can be determined by comparison of known parts to the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.662145Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4216-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ratio and scaling problems can be represented in similar ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.662149Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4216-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ratio and scaling problems can be solved in similar ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.662154Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4216-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A ratio table can be used to solve ratio and scaling problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.662158Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4203-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I know the value of the whole, I can calculate the value of a part."@en ;
  dcterms:modified "2026-02-12T08:59:21.662163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4203-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If I know the value of a part, I can calculate the value of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.662168Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4203-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Addition, subtraction, multiplication and division can be used to calculate a new percentage from known percentages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662172Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3606-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In column addition, one addend is written below the other."@en ;
  dcterms:modified "2026-02-12T08:59:21.662591Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3606-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The equals sign shows it is an equation."@en ;
  dcterms:modified "2026-02-12T08:59:21.662597Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3606-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The sum appears within the equals sign."@en ;
  dcterms:modified "2026-02-12T08:59:21.662601Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3821-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Within a mixed number, the whole number is the most significant part."@en ;
  dcterms:modified "2026-02-12T08:59:21.662606Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3821-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The whole number part of a mixed number can be used to decide which integers it will be placed between on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662611Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3821-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The fractional part of the mixed number can be used to establish exactly where it will be placed between these numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662615Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3923-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Skip counting in steps of the divisor can be used to divide 2-digit numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.662620Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3923-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Dividends can be partitioned into multiples of the divisor to divide efficiently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662624Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3923-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Unitising language is used to describe the process of division."@en ;
  dcterms:modified "2026-02-12T08:59:21.662629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3547-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When measuring, it is more efficient to start at zero."@en ;
  dcterms:modified "2026-02-12T08:59:21.662633Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3547-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The length of the object is the difference between the numbers on the ruler at the start and the end of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3547-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Measures can be given in metres or centimetres."@en ;
  dcterms:modified "2026-02-12T08:59:21.662642Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3547-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Estimating helps us to decide if it is better to measure in centimetres or metres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662647Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3894-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are two decimal places after the pounds when you record money."@en ;
  dcterms:modified "2026-02-12T08:59:21.662652Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3894-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The first decimal place records how many 10ps up to 90p"@en ;
  dcterms:modified "2026-02-12T08:59:21.662656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3894-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The second decimal place records how many 1ps up to 9p"@en ;
  dcterms:modified "2026-02-12T08:59:21.662661Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3894-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """£3.04 is read as three pounds and 4 pence but £3.40 is read as three pounds and 40 pence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3919-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Expanded multiplication of a 3-digit by a 1-digit number will give three numbers to add to calculate the overall product"""@en ;
  dcterms:modified "2026-02-12T08:59:21.662670Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3919-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Short multiplication builds the overall product from the ones column to the hundreds with no regrouping."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3919-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The partial products can be seen in the expanded and short multiplication strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3706-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The minuend and subtrahend are written in columns with the same value digits in the same column."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3706-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The subtrahend is written beneath the minuend."@en ;
  dcterms:modified "2026-02-12T08:59:21.662691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3706-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The difference is recorded beneath the subtrahend."@en ;
  dcterms:modified "2026-02-12T08:59:21.662696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3848-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you reflect a shape, each vertex will be the same distance from the line of symmetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3848-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you reflect a polygon that has a side that is touching the mirror line, you can sometimes create a new shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662707Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3878-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The whole is divided into one hundred equal parts and one of them is one hundredth of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662712Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3878-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 100 hundredths in one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.662717Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3878-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are 10 hundredths in one tenth."@en ;
  dcterms:modified "2026-02-12T08:59:21.662721Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3868-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The whole is divided into ten equal parts and one of the parts is one tenth of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662726Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3868-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are ten tenths in one whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.662730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3868-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One whole can be divided into ten tenths."@en ;
  dcterms:modified "2026-02-12T08:59:21.662735Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3772-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A square number of objects can be arranged into a square array."@en ;
  dcterms:modified "2026-02-12T08:59:21.663343Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3772-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A square number can be represented as the product of two factors which are the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3772-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When both factors have the same value, the product is called a square number."@en ;
  dcterms:modified "2026-02-12T08:59:21.663353Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3830-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A mixed number can be written as an improper fraction of equal value."@en ;
  dcterms:modified "2026-02-12T08:59:21.663358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3830-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The generalisation, ‘First we multiply the whole number by the denominator then we add the numerator’ can help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3546-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The length or height of an object can be estimated using the standardised unit of metres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663367Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3546-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One hundred, 1 cm lengths are the same as 1 m."@en ;
  dcterms:modified "2026-02-12T08:59:21.663374Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3546-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Ten, 10 cm lengths are the same as 100 cm, which is the same as 1 m."@en ;
  dcterms:modified "2026-02-12T08:59:21.663379Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4224-1
  a oakcurric:KeyLearningPoint ;
