oak:keylearningpoint-lesson-4220-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the minuend and subtrahend are changed by the same amount, the difference stays the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683965Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4220-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If you increase or decrease the minuend, the difference increases or decreases by the same amount."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684002Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4220-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you increase the subtrahend then the difference decreases."@en ;
  dcterms:modified "2026-02-12T08:59:21.684011Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4220-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you decrease the subtrahend then the difference increases."@en ;
  dcterms:modified "2026-02-12T08:59:21.684018Z"^^xsd:dateTime .

