  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 3 tenths plus 4 tenths is equal to 7 tenths then 7 tenths subtract 4 tenths is equal to 3 tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692286Z"^^xsd:dateTime .

