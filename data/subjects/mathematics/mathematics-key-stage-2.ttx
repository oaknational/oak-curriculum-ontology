  a oakcurric:KeyLearningPoint ;
  rdfs:label "By rearranging a calculation it can be made easier to solve mentally"@en ;
  dcterms:modified "2026-02-12T08:59:21.654649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3967-1
  a oakcurric:KeyLearningPoint ;
