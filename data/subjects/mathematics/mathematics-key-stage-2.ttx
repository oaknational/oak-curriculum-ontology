  rdfs:label """When you multiply two fractions you can multiply the numerators and multiply the denominators."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672945Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4185-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A fraction is in its simplest form when there is no common factor of the numerator and the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672949Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3588-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If we subtract 1 from one addend, we must add one to the other added for the sum to remain the same"""@en ;
  dcterms:modified "2026-02-12T08:59:21.672954Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3588-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When we redistribute, the total amount stays the same at all times"@en ;
  dcterms:modified "2026-02-12T08:59:21.672958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3588-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Depending on the addends, we  redistribute 1s or 10s"@en ;
  dcterms:modified "2026-02-12T08:59:21.672963Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4143-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Area and perimeter are calculated from the side lengths of 2D shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.672983Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4143-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Area and perimeter are measured in different units."@en ;
  dcterms:modified "2026-02-12T08:59:21.672988Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4143-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Compound shapes can be decomposed and rearranged in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.672992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3927-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the tens number is not a multiple of the divisor then the remainder is recorded next to the ones digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3927-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If there is a remainder after dividing the tens digit the tens are regrouped and the ones digit becomes a 2-digit number"""@en ;
  dcterms:modified "2026-02-12T08:59:21.673001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3927-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the number of ones, including any regrouped tens, is a multiple of the divisor, there will be no remainder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7621-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.1 is equal to 1/10"@en ;
  dcterms:modified "2026-02-12T08:59:21.673013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7621-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.2 is equal to 1/5"@en ;
  dcterms:modified "2026-02-12T08:59:21.673018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7621-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.25 is equal to 1/4"@en ;
  dcterms:modified "2026-02-12T08:59:21.673022Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7621-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.5 is equal to 1/2"@en ;
  dcterms:modified "2026-02-12T08:59:21.673026Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7621-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "0.75 is equal to 3/4"@en ;
  dcterms:modified "2026-02-12T08:59:21.673031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3787-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning a factor is called distribution or using the distributive law."@en ;
  dcterms:modified "2026-02-12T08:59:21.673407Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3787-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioned factors can be subtracted to simplify two-part subtraction problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.673412Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3787-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Eight 9s subtract three 9s is equal to five 9s."@en ;
  dcterms:modified "2026-02-12T08:59:21.673418Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7137-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Known facts and unitising can be applied when partitioning 7-digit numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.673513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7137-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the missing part is an addend then the other addend is subtracted from the sum"""@en ;
  dcterms:modified "2026-02-12T08:59:21.673518Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7137-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the missing part is the subtrahend then the difference is subtracted from the minuend"""@en ;
  dcterms:modified "2026-02-12T08:59:21.673523Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3766-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting in sevens is the pattern of the 7 times table."@en ;
  dcterms:modified "2026-02-12T08:59:21.673748Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3766-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting in sevens can be represented in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.673752Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3766-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Counting in sevens can help you to solve problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.673756Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3788-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you know the 2 and 10 times tables you can work out the 12 times table."@en ;
  dcterms:modified "2026-02-12T08:59:21.673761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3788-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you know the 10 times table you can work out the 9 times table."@en ;
  dcterms:modified "2026-02-12T08:59:21.673766Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3788-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The distributive law allows you to add or subtract known times tables to work out new times table facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673770Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3539-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you count in tens, the ones digit stays the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.673774Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3539-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you count in tens, the tens and hundreds digits may change."@en ;
  dcterms:modified "2026-02-12T08:59:21.673779Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3539-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Knowledge of place value can help when counting forwards across the 100 boundary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3929-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Partitioning the dividend into hundreds, tens and ones helps when dividing a 3-digit by a 1-digit number."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3929-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Use times tables and unitising to divide the hundreds, tens and ones by the divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673792Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3929-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Place value resources can represent the division."@en ;
  dcterms:modified "2026-02-12T08:59:21.673799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3752-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "All multiples of 6 are multiples of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.673804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3752-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Not all multiples of 3 are multiples of 6"@en ;
  dcterms:modified "2026-02-12T08:59:21.673811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3752-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 6 are double the multiples of 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.673818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3752-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 3 are half the multiples of 6"@en ;
  dcterms:modified "2026-02-12T08:59:21.673825Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3560-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Place value representations help us to compare and order numbers with 1, 2 or 3 digits"""@en ;
  dcterms:modified "2026-02-12T08:59:21.673830Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3560-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The symbols < and > can be used to compare numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.673834Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3560-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When ordering or comparing 3-digit numbers, look at the 100s digit first, then the 10s digit, and then the 1s digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673839Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3813-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Equal parts of the same-sized whole may not look the same - they can be different shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3813-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A whole can be made from equal-sized parts that are different shapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.673848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3813-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each equal part of a whole must represent the same amount of the whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.673852Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3521-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning addends supports bridging 10."@en ;
  dcterms:modified "2026-02-12T08:59:21.673857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3521-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pairs to 10 can be used to add two or more addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.673861Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3872-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To compare two numbers, you compare digits with the same place value, starting with the largest place-value digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3872-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the whole numbers are the same, look at the value of the tenths digit to compare and order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4170-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Coordinate grids are not always presented with grid lines, and the axes are not always fully-labelled."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674189Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4170-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When this is the case, it is essential to consider the known coordinates to work out missing coordinates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4170-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Missing coordinates sometimes appear on the same horizontal or vertical line as known coordinates, so they are the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674198Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4170-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sometimes we need to use known vertices to calculate unknown side lengths when working out missing coordinates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674202Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3961-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A change in length can be described using division."@en ;
  dcterms:modified "2026-02-12T08:59:21.674207Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3961-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Division can be represented as multiplication by a unit fraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.674211Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3961-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The stem sentence, 'The ___ is ___ times the length of the ___' can be used to support understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3961-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Comparison and change problems can be represented visually to support understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674220Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3823-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mixed numbers can be positioned on a number line to help compare and order them."@en ;
  dcterms:modified "2026-02-12T08:59:21.674225Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3823-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When comparing or ordering mixed numbers, identify the integers that the mixed numbers sit between."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674229Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3823-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mixed numbers where the whole number part is different can be compared or ordered based on their whole number part."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3822-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To estimate the position of mixed numbers on a number line, first identify which integers it sits between."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674240Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3822-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Then use the fractional part and fraction-sense to decide where, within the known interval, the mixed number sits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7619-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pattern of counting in 50s can be seen in whole numbers and decimals."@en ;
  dcterms:modified "2026-02-12T08:59:21.674250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7619-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pattern of counting in 25s can be seen in whole numbers and decimals."@en ;
  dcterms:modified "2026-02-12T08:59:21.674255Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7619-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pattern of counting in 20s can be seen in whole numbers and decimals."@en ;
  dcterms:modified "2026-02-12T08:59:21.674259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7611-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the multiplicative relationship between the numerator and denominator is the same, the fractions will be equivalent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7611-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In equivalent fractions the numerators will share a common factor and the denominators will share a common factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7611-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In equivalent fractions, the numerators and denominators have been scaled up or down by the same factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674272Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3926-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Short division helps us to organise division by partitioning."@en ;
  dcterms:modified "2026-02-12T08:59:21.674279Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3926-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The language of unitising helps to explain what is happening in short division."@en ;
  dcterms:modified "2026-02-12T08:59:21.674284Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3926-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are similarities between the representations of division and short division."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674289Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3926-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The partial quotients are recorded above the dividend in the correct place value columns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674293Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4138-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The area of the compound shape is equal to the total areas of its parts"@en ;
  dcterms:modified "2026-02-12T08:59:21.674298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4138-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "2D shapes can be decomposed and rearranged in different ways"@en ;
  dcterms:modified "2026-02-12T08:59:21.674303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4138-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """2D shapes can be decomposed and rearranged in different ways but the total area stays the same"""@en ;
  dcterms:modified "2026-02-12T08:59:21.674307Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3591-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the minuend and subtrahend are close in value, finding the difference can be an efficient strategy for subtraction"""@en ;
  dcterms:modified "2026-02-12T08:59:21.674314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3591-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Finding the difference means we count on from the subtrahend or count back from the minuend"""@en ;
  dcterms:modified "2026-02-12T08:59:21.674319Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3591-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line or a bar model can represent finding the difference"@en ;
  dcterms:modified "2026-02-12T08:59:21.674324Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4239-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The mean is the size of each part when a quantity is shared equally."@en ;
  dcterms:modified "2026-02-12T08:59:21.674330Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4239-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The mean value of a set of data is the total of the numbers divided by how many numbers there are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674335Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7147-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Factors of a divisor can be used to divide a dividend."@en ;
  dcterms:modified "2026-02-12T08:59:21.674340Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7147-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Listing multiples of the divisor improves efficiency and accuracy with written division methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674344Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7147-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Listing multiples helps to reduce the number of steps in the long division."@en ;
  dcterms:modified "2026-02-12T08:59:21.674349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3797-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Multiples of 100 have zero in the tens and ones column."@en ;
  dcterms:modified "2026-02-12T08:59:21.674353Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3797-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When a number is multiplied by one hundred the product is a multiple of one hundred."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3797-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Multiplying by one hundred moves all the digits two columns to the left making the digits one hundred times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4076-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """I've added __ to this part so I need to subtract __ from the other part to keep the sum the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674367Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4076-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """I've subtracted __ from this part so I need to add __ to this part to keep the sum the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4076-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A balance beam can represent equivalent expressions."@en ;
  dcterms:modified "2026-02-12T08:59:21.674376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3970-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you multiply by 10, 100 or 1,000, the digits move one, two or three places to the left respectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675302Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3970-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When you divide by 10, 100 or 1,000, the digits move one, two or three places to the right respectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3614-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Consider each calculation to see whether column addition is the most efficient method to use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675311Z"^^xsd:dateTime .

