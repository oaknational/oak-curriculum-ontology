  dcterms:modified "2026-02-12T08:59:15.799976Z"^^xsd:dateTime .

oak:keyword-degree
  a oakcurric:Keyword ;
  schema:name "degree"@en ;
  schema:description """a degree is a certificate to show someone has completed studying a subject at university"""@en ;
  dcterms:modified "2026-02-12T08:59:15.800007Z"^^xsd:dateTime .

oak:keyword-strategy
  a oakcurric:Keyword ;
  schema:name "strategy"@en ;
  schema:description "a strategy is a plan of action designed to achieve a long-term or overall goal"@en ;
  dcterms:modified "2026-02-12T08:59:15.800195Z"^^xsd:dateTime .

oak:keyword-bridging
  a oakcurric:Keyword ;
  schema:name "Bridging"@en ;
