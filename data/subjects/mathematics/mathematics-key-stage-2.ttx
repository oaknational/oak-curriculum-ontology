oak:keylearningpoint-lesson-3869-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If a digit is moved one place value column to the right it becomes one tenth the size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692118Z"^^xsd:dateTime .

