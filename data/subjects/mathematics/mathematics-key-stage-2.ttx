  a oakcurric:KeyLearningPoint ;
  rdfs:label """Facts about whole numbers can be applied to the numerators of fractions with the same denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692282Z"^^xsd:dateTime .

