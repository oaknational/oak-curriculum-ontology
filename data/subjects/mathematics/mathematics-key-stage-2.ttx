  a oakcurric:KeyLearningPoint ;
  rdfs:label "If 100cm = 1m then 500cm = 5 x 100cm = 5m"@en ;
  dcterms:modified "2026-02-12T08:59:21.623718Z"^^xsd:dateTime .

