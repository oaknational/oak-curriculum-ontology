  dcterms:modified "2026-02-12T08:59:21.623940Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3661-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When describing a fraction of the whole, the whole could be a shape, a line or a group of objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623946Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3644-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can represent fractions with a picture."@en ;
  dcterms:modified "2026-02-12T08:59:21.623954Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3644-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can represent fractions with symbols."@en ;
  dcterms:modified "2026-02-12T08:59:21.623959Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3644-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You can represent fractions with names."@en ;
  dcterms:modified "2026-02-12T08:59:21.623965Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3844-1
  a oakcurric:KeyLearningPoint ;
