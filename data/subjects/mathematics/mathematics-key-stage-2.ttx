oak:keylearningpoint-lesson-4073-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Redistributing between parts with the whole staying the same is sometimes known as the 'same sum' rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.691333Z"^^xsd:dateTime .

