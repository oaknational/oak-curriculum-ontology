oak:keylearningpoint-lesson-3997-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "All numbers can be written as a product of 2 or more prime numbers."@en ;
  dcterms:modified "2026-02-12T08:59:21.666808Z"^^xsd:dateTime .

