  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for Mathematics KS2."""@en ;

  owl:versionInfo "0.1.31" ;
  owl:versionIRI <https://w3id.org/uk/curriculum/oak-data/mathematics-ks2/0.1.31> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Mathematics KS2, including exam board-specific unit variants and lesson sequences."""@en ;
