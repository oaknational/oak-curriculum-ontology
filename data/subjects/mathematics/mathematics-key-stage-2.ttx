oak:keylearningpoint-lesson-3844-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When you fold a shape on a line of symmetry, the two halves will match exactly."@en ;
  dcterms:modified "2026-02-12T08:59:21.624600Z"^^xsd:dateTime .

