  dcterms:modified "2026-02-12T08:59:21.677738Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3517-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Addition of three addends can be described with a first …, then …, then …, now structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677743Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3517-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A bar model can be used to represent a problem with three addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.677747Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3517-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A number line can be used to represent a problem with three addends."@en ;
  dcterms:modified "2026-02-12T08:59:21.677752Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3533-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The language of unitising helps us to use number facts to 20 to add multiples of 10 crossing the hundreds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677756Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3533-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Crossing the tens boundary helps us to cross the 100s boundary if we think in tens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3533-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Partitioning an addend helps us to cross the 100 boundary when adding."@en ;
  dcterms:modified "2026-02-12T08:59:21.677766Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3526-1
  a oakcurric:KeyLearningPoint ;
