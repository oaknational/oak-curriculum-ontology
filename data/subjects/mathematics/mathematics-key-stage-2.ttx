  dcterms:modified "2026-02-12T08:59:15.799195Z"^^xsd:dateTime .

oak:keyword-regrouping
  a oakcurric:Keyword ;
  schema:name "regrouping"@en ;
  schema:description """The process of unitising and exchanging between place values is known as regrouping."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799291Z"^^xsd:dateTime .

oak:keyword-short-multiplication
  a oakcurric:Keyword ;
