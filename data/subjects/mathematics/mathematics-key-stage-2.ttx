  schema:description """Times the mass/capacity/volume is a phrase that is used to compare and describe. For example, one bear might be three times the mass of another bear - it is three times as heavy."""@en ;
  dcterms:modified "2026-02-12T08:59:15.798976Z"^^xsd:dateTime .

oak:keyword-mass
