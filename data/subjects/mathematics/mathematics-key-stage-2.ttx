  schema:name "Week"@en ;
  schema:description "A time period of 7 days."@en ;
  dcterms:modified "2026-02-12T08:59:15.818271Z"^^xsd:dateTime .

oak:keyword-scalescaling
  a oakcurric:Keyword ;
  schema:name "Scale/scaling"@en ;
  schema:description "Scaling is when a quantity is made ___ times the size."@en ;
  dcterms:modified "2026-02-12T08:59:15.818297Z"^^xsd:dateTime .

oak:keyword-thousand
  a oakcurric:Keyword ;
  schema:name "Thousand"@en ;
  schema:description "A thousand is a 4-digit number equal to 10 groups of one hundred."@en ;
  dcterms:modified "2026-02-12T08:59:15.818319Z"^^xsd:dateTime .

oak:keyword-acute-angle
  a oakcurric:Keyword ;
  schema:name "Acute angle"@en ;
  schema:description "An angle that is smaller than a right angle is an acute angle."@en ;
  dcterms:modified "2026-02-12T08:59:15.818391Z"^^xsd:dateTime .

oak:keyword-obtuse-angle
  a oakcurric:Keyword ;
  schema:name "Obtuse angle"@en ;
  schema:description """An angle that is greater than a right angle but smaller than a straight line is an obtuse angle."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818395Z"^^xsd:dateTime .

oak:keyword-kilogram
  a oakcurric:Keyword ;
  schema:name "Kilogram"@en ;
  schema:description """Kilograms are use to measure the mass objects that are heavy. A pineapple has a mass of about 1 kilogram.  The abbreviation is kg."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818399Z"^^xsd:dateTime .

oak:keyword-property-properties
  a oakcurric:Keyword ;
  schema:name "Property / properties"@en ;
  schema:description "A property is a character or quality something has."@en ;
  dcterms:modified "2026-02-12T08:59:15.818404Z"^^xsd:dateTime .

oak:keyword-set
  a oakcurric:Keyword ;
  schema:name "Set"@en ;
  schema:description "A collection of items."@en ;
  dcterms:modified "2026-02-12T08:59:15.818457Z"^^xsd:dateTime .

oak:keyword-one-tenth-the-size
  a oakcurric:Keyword ;
  schema:name "one tenth the size"@en ;
  schema:description """When a whole is divided into ten equal parts, we can say one of those parts is one tenth the size of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818465Z"^^xsd:dateTime .

oak:keyword-tenths-column
  a oakcurric:Keyword ;
  schema:name "tenths column"@en ;
  schema:description "The tenths column places the number of tenths a given number has."@en ;
  dcterms:modified "2026-02-12T08:59:15.818470Z"^^xsd:dateTime .

oak:keyword-grid
  a oakcurric:Keyword ;
  schema:name "Grid"@en ;
  schema:description "A set of lines used to help us accurately draw graphs is known as grid."@en ;
  dcterms:modified "2026-02-12T08:59:15.818566Z"^^xsd:dateTime .

oak:keyword-number-facts
  a oakcurric:Keyword ;
  schema:name "Number facts"@en ;
  schema:description """Simple calculations using two numbers are known as number facts. For example 2 + 4 = 6"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818713Z"^^xsd:dateTime .

oak:keyword-width
  a oakcurric:Keyword ;
  schema:name "Width"@en ;
  schema:description "Width is the distance from side to side."@en ;
  dcterms:modified "2026-02-12T08:59:15.821229Z"^^xsd:dateTime .

oak:keyword-powers-of-10
  a oakcurric:Keyword ;
  schema:name "Powers of 10"@en ;
  schema:description "A power of 10 is when 10 is multiplied by itself a certain number of times."@en ;
  dcterms:modified "2026-02-12T08:59:15.822639Z"^^xsd:dateTime .

oak:keyword-power-of-10
  a oakcurric:Keyword ;
  schema:name "Power of 10"@en ;
  schema:description "A power of 10 is when 10 is multiplied by itself a certain number of times."@en ;
  dcterms:modified "2026-02-12T08:59:15.824859Z"^^xsd:dateTime .

oak:keyword-reorder
  a oakcurric:Keyword ;
  schema:name "Reorder"@en ;
  schema:description "Reorder means arrange something in a different way."@en ;
  dcterms:modified "2026-02-12T08:59:15.826603Z"^^xsd:dateTime .

oak:keyword-separator-comma
  a oakcurric:Keyword ;
  schema:name "Separator comma"@en ;
  schema:description """A place value separator comma is used to partition longer numbers to aid in the efficient reading of numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827162Z"^^xsd:dateTime .

oak:keyword-rearrange
  a oakcurric:Keyword ;
  schema:name "rearrange"@en ;
  schema:description """Rearrange means to change an equation. It could mean moving the parts or the whole or changing it from an addition into a subtraction equation."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827477Z"^^xsd:dateTime .

oak:keyword-efficient-efficiently
  a oakcurric:Keyword ;
  schema:name "Efficient / efficiently"@en ;
  schema:description """Working efficiently means finding a way to solve a problem quickly whilst also maintaining accuracy."""@en ;
  dcterms:modified "2026-02-12T08:59:15.827700Z"^^xsd:dateTime .

oak:keyword-adjacent-multiple
  a oakcurric:Keyword ;
  schema:name "Adjacent multiple"@en ;
  schema:description "An adjacent multiple is a multiple next to another. It could be before or after."@en ;
  dcterms:modified "2026-02-12T08:59:15.828037Z"^^xsd:dateTime .

oak:keyword-number-bonds
  a oakcurric:Keyword ;
  schema:name "Number bonds"@en ;
  schema:description "Number bonds are pairs of numbers which sum together to make another number."@en ;
  dcterms:modified "2026-02-12T08:59:15.828166Z"^^xsd:dateTime .

oak:keyword-decimetre
  a oakcurric:Keyword ;
  schema:name "Decimetre"@en ;
  schema:description """A decimetre is a metric unit of length, equal to one-tenth of a metre. Decimetre can be abbreviated to dm."""@en ;
  dcterms:modified "2026-02-12T08:59:15.828261Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oak:misconception-pupils-write-whole-numbers-tenths
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils write whole numbers as tenths incorrectly, for example as eight tenths not eighty tenths."""@en ;
  oakcurric:correction """Reiterate that ten tenths are equal to one whole so twenty tenths are equal to two wholes. Continue this to build generalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675558Z"^^xsd:dateTime .

oak:misconception-writing-equations-represent-part-part
  a oakcurric:Misconception ;
  oakcurric:statement """When writing equations to represent part-part-whole models, children may have difficulty recording the number of groups (as this numeral is not written in the model) and revert to repeated addition."""@en ;
  oakcurric:correction """Encourage children to articulate their thinking as they record, e.g. there are ___ groups of ___ and a remainder of ___"""@en ;
  dcterms:modified "2026-02-12T08:59:18.675737Z"^^xsd:dateTime .

oak:misconception-pupils-think-large-objects-things
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might think that large objects or things such as England cannot be a part of a whole due to its size."""@en ;
  oakcurric:correction """Encourage pupils to work with parts and wholes that they can handle and experience but where parts are large, such as their school or class environment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675983Z"^^xsd:dateTime .

oak:misconception-pupils-count-fractions-square-such
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils count fractions of a square, such as a right-angles triangle, as a whole square unit."""@en ;
  oakcurric:correction """Cut out the shape to show that two ‘parts’ of a square sometimes go together to make a complete square unit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676033Z"^^xsd:dateTime .

oak:misconception-pupils-find-difficult-solve-problems
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may find it difficult to solve problems or misunderstand questions."@en ;
  oakcurric:correction """Model clearly how to identify key phrases and words which will identify the operation and equation required for word problems. This could involve drawing bar models or other representations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676486Z"^^xsd:dateTime .

oak:misconception-children-struggle-identify-explain-pattern
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to identify or explain the pattern or to identify the number of steps from the first given number to the last instead just giving the number of missing values."""@en ;
  oakcurric:correction """If children struggle to identify the pattern ask them to start by identifying the part of the number that is changing. Model the 'steps' rather than the missing parts to support children to see this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676798Z"^^xsd:dateTime .

oak:misconception-crossing-tenth-boundary-pupils-count
  a oakcurric:Misconception ;
  oakcurric:statement """When crossing the tenth boundary, pupils count ten hundredths as 'zero point zero ten'."""@en ;
  oakcurric:correction """Use cardinal representations to guide the pupil's counting so ten hundredths and one tenth equivalence can be discussed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676882Z"^^xsd:dateTime .

oak:misconception-drawing-tables-graphs-scratch-tricky
  a oakcurric:Misconception ;
  oakcurric:statement "Drawing tables and graphs from scratch can be tricky for some children."@en ;
  oakcurric:correction "Provide scaffolds of tables and graphs where necessary."@en ;
  dcterms:modified "2026-02-12T08:59:18.677982Z"^^xsd:dateTime .

oak:misconception-lack-fluency-3s-9s-times
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in the 3s and 9s times tables can lead to pupils being slower to grasp the generalisation about the relationship between the 3 and 9 times tables."""@en ;
  oakcurric:correction """Model using arrays and other representations. Pupils who may struggle to triple / find one third of a number may require more time to work through calculations. Multiplication grids could also be provided while pupils become more fluent in recall."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678367Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-recognise-numbers-exist
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to recognise that numbers exist to the left of zero."@en ;
  oakcurric:correction """Expose pupils to images in familiar contexts showing negative numbers. Take lots of opportunities to count bridging zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678872Z"^^xsd:dateTime .

oak:misconception-faced-bar-model-showing-example
  a oakcurric:Misconception ;
  oakcurric:statement """When faced with a bar model showing for example 5 parts, children often want to write a 5 in each part as they misunderstand how the grouping in fives relates to a sharing context."""@en ;
  oakcurric:correction """Imagine arrays beneath the five parts of the bar model to secure understanding that the five parts represent five groups of ___ / the number of groups we are sharing between. Physically share a group of objects into these parts at any one time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678975Z"^^xsd:dateTime .

oak:misconception-using-expanded-method-pupils-align
  a oakcurric:Misconception ;
  oakcurric:statement """When using the expanded method, pupils may not align the digits correctly with the same place value."""@en ;
  oakcurric:correction """Use clear teacher modelling and continue to ask what each digit that has been recorded represents and link back to the place value chart."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678999Z"^^xsd:dateTime .

oak:misconception-pupils-forget-many-days-month
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may forget how many days are in each month. They do not particularly follow a pattern or sequence. For example, pupils might be tempted to say that August has 30 days because it follows July."""@en ;
  oakcurric:correction """You could 'interrupt the forgetting' by providing frequent opportunities for pupils to recall these facts outside the Maths lesson, using flashcards for each month with the month on the front and the number of days on the back."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679038Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-keywords-lesson-use
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils often confuse the keywords of this lesson and use them interchangeably or incorrectly."""@en ;
  oakcurric:correction """Model correct usage in a range of contexts including labelling abstract equations and using the terms to identify the known elements in worded problems. Choral response can also support pupils using these words correctly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679066Z"^^xsd:dateTime .

oak:misconception-pupils-use-known-fact-add
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils use a known fact but add or subtract with different place values (e.g. 0.6 + 0.04 = 0.1)."""@en ;
  oakcurric:correction """Unitise through the use of language to help identify this for pupils. For example: 6 hundredths plus 4 hundredths is equal to 10 hundredths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679071Z"^^xsd:dateTime .

oak:misconception-lack-fluency-multiplication-facts-understanding
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in multiplication facts and / or understanding of word problems. 'Adding a 0' at the end."""@en ;
  oakcurric:correction """Use language of unitisation to support pupils mathematical thinking. Clear modelling of steps in how to find the operation for the calculation. Use gattegno chart or place value chart to highlight scaling by 10."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679160Z"^^xsd:dateTime .

oak:misconception-pupils-record-numbers-like-29
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils record numbers like 29 thousandths incorrectly as 0.0029"@en ;
  oakcurric:correction """Continue to link representations of thousandths to the place value chart and use language of ten thousandths being equal to one hundredth."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679170Z"^^xsd:dateTime .

oak:misconception-lack-fluency-2s-4s-8s
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in 2s, 4s and 8s times tables and not understanding the divisibility rules or the problems."""@en ;
  oakcurric:correction """To clearly model use of gattegno chart or place value chart to highlight scaling up and down by 10. Highlight key words of worded problems to understand the problem and the operation required for the calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679211Z"^^xsd:dateTime .

oak:misconception-number-digits-decimal-point-greater
  a oakcurric:Misconception ;
  oakcurric:statement """A number with more digits after the decimal point is greater than a number with fewer digits."""@en ;
  oakcurric:correction """Create the numbers using place value counters or base 10 blocks and re-iterate the magnitude of each digit within the number."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679249Z"^^xsd:dateTime .

oak:misconception-children-find-hard-create-their
  a oakcurric:Misconception ;
  oakcurric:statement """Children might find it hard to create their own puzzles in the final part of Task B as the dotted lines can be overwhelming."""@en ;
  oakcurric:correction """Model the process heavily for those who need it, where possible using a visualiser and sharing finished examples. Make good use of the template. A bigger version can be found in the additional materials."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679255Z"^^xsd:dateTime .

oak:misconception-children-difficulty-interpreting-problem-unsure
  a oakcurric:Misconception ;
  oakcurric:statement """Children may have difficulty interpreting the problem and be unsure whether to ignore or include the remainder in the answer."""@en ;
  oakcurric:correction """Throughout, ask and encourage children to articulate what each part of the equation represents from the problem in order to link the concrete and the abstract representation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679261Z"^^xsd:dateTime .

oak:misconception-children-think-fractions-look-different
  a oakcurric:Misconception ;
  oakcurric:statement """Children may think that fractions that look different cannot represent the same part of a whole. They may also still think that a bigger denominator means a bigger fraction."""@en ;
  oakcurric:correction """Give plenty of opportunity to use manipulatives and representations to show sets and groups of objects divided in different ways so that they see practically that the same part of a whole can be described and represented by different fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679325Z"^^xsd:dateTime .

oak:misconception-pupils-make-link-fractions-division
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not make the link between fractions and division and therefore do not understand why a remainder can be written as a fraction."""@en ;
  oakcurric:correction """Show that fractions can be the result of division e.g. one-quarter is one divided by four. Use models and examples to show that a remainder can be written as a fraction of a whole group (the divisor)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679331Z"^^xsd:dateTime .

oak:misconception-children-try-reflect-diagonal-line
  a oakcurric:Misconception ;
  oakcurric:statement """Children may try to reflect in a diagonal line but not at a 45 degree angle, leading to inaccuracies when marking each vertex."""@en ;
  oakcurric:correction """Encourage children to work horizontally and then vertically, rather than trying to reflect in a diagonal line. Explore how this can be done in either order, orienting the paper, and notice how the same point will still be marked on the grid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679336Z"^^xsd:dateTime .

oak:misconception-pupils-regroup-correctly-understand-place
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not regroup correctly if they do not understand the place value of digits in a factor."""@en ;
  oakcurric:correction """Encourage pupils to use the stem sentences / array to identify when they may need to regroup."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679350Z"^^xsd:dateTime .

oak:misconception-pupils-align-regroup-correctly-leading
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not align or regroup correctly leading to an inaccurate calculation."@en ;
  oakcurric:correction """Model accurately what happens when we regroup from 10s to 100s. Why did this happen? How do we record this?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.679355Z"^^xsd:dateTime .

oak:misconception-pupils-see-fraction-its-simplified
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not see that the fraction and its simplified version are equivalent. Pupils may not have a deep understanding of how factors relate to fractions."""@en ;
  oakcurric:correction """Stress the equivalence of fractions when simplifying and make use of representations to show that fractions are equivalent using parts of a whole and position on a number line. Discuss the language of factors, common factors and prime numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679395Z"^^xsd:dateTime .

oak:misconception-negative-temperatures-relate-positive-e
  a oakcurric:Misconception ;
  oakcurric:statement """Negative temperatures relate to positive e.g.  −5℃ is warmer than −3℃ because 5℃ is warmer than 3℃."""@en ;
  oakcurric:correction """Emphasise directional relationship e.g. numbers decrease as they move to the right. Practical examples can help e.g. freezer temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679400Z"^^xsd:dateTime .

oak:misconception-pupils-recognise-new-shape-identify
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not recognise the new shape and only identify the smaller shapes it is composed of."""@en ;
  oakcurric:correction """Using plastic shapes to compose a new shape and drawing around the shape can support pupils to see the properties of the new shape. Drawing around removes the joined sides inside the new polygon."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679417Z"^^xsd:dateTime .

oak:misconception-pupils-unable-connect-scale-divisions
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils unable to connect scale divisions with knowledge of composition of 1,000"@en ;
  oakcurric:correction """Spend time developing confidence in counting in multiples of 100 and 200 to 1,000 before making explicit links between this and scales and measures. Use 'The whole is 1,000 and we have divided it into ___ parts of ___' when doing this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679456Z"^^xsd:dateTime .

oak:misconception-addition-fractions-many-children-try
  a oakcurric:Misconception ;
  oakcurric:statement """In the addition of fractions, many children will try to add together both the numerator and denominator."""@en ;
  oakcurric:correction """Show the children many completed examples using representations alongside the fraction notation. Encourage them to make generalisations and spot that the denominator remains the same because it is the unit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679460Z"^^xsd:dateTime .

oak:misconception-pupils-believe-subtraction-commutative-therefore
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils believe that subtraction is commutative and therefore equations can be written in any order."""@en ;
  oakcurric:correction """Model with physical resources such as marbles in a bag that 4 - 6 results in a negative change but 6 - 4 results in a positive change."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679476Z"^^xsd:dateTime .

oak:misconception-children-say-ten-times-heavier
  a oakcurric:Misconception ;
  oakcurric:statement """Children may say 'ten times heavier' which is imprecise. Children are more familiar with multiplication resulting in an increase and need to appreciate that it can also result in a decrease."""@en ;
  oakcurric:correction """We say, 'ten times the original mass' because this is more precise, especially when the scale factor is fractional. When we multiply by a unit fraction, it is the same as dividing the whole by the number of equal parts in it, resulting in a decrease."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679540Z"^^xsd:dateTime .

oak:misconception-children-think-rectangular-flag-diagonal
  a oakcurric:Misconception ;
  oakcurric:statement "Children may think that a rectangular flag has diagonal lines of symmetry."@en ;
  oakcurric:correction """Allow children to cut out and fold the flags to help them see that a rectangle does not have any diagonal lines of symmetry."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679545Z"^^xsd:dateTime .

oak:misconception-children-think-part-needs-something
  a oakcurric:Misconception ;
  oakcurric:statement """Children may think that a part only needs to be something smaller than the whole and not part of it."""@en ;
  oakcurric:correction """Spend some time identifying wholes in the classroom and then get the children to identify a part of it. Get the children to play games involving spotting non-examples to strengthen their understanding. Ensure the wholes you use are clearly defined."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679578Z"^^xsd:dateTime .

oak:misconception-concept-constant-difference-difficult-understand
  a oakcurric:Misconception ;
  oakcurric:statement """The concept of constant difference is difficult to understand when looking simply at abstract equations and numerals and pupils may find it challenging to 'see' the underlying structure of the maths."""@en ;
  oakcurric:correction """Make good use of physical resources to reinforce the idea of constant difference. Number rods coupled with rulers or number lines can be very useful here. Take time with smaller values so pupils can generalise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679583Z"^^xsd:dateTime .

oak:misconception-fractions-decimals-less-one-positioned
  a oakcurric:Misconception ;
  oakcurric:statement """Fractions and decimals less than one are positioned to the left of zero or are negative in value."""@en ;
  oakcurric:correction """Using a number line 0 to 1, label different fractions and decimals and show pupils that, though small in size, they are greater than zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679603Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-compare-fractions-half
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to compare fractions to a half as they mainly consider it in its simplest form."""@en ;
  oakcurric:correction """Encourage pupils to visualise their fractions on a number line. Also spend time thinking about the relationship between the numerator and the denominator in fractions equivalent to one-half and use this generalisation to help moving forward."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679613Z"^^xsd:dateTime .

oak:misconception-short-multiplication-algorithm-correctly-aligned
  a oakcurric:Misconception ;
  oakcurric:statement "The short multiplication algorithm may not be correctly aligned."@en ;
  oakcurric:correction """Check that the decimal point aligns in the decimal fraction and the product. Scaffolding with place value columns may support further."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679669Z"^^xsd:dateTime .

oak:misconception-pupils-resort-procedure-little-understanding
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils resort to a procedure with little understanding for how we convert between improper fractions and mixed numbers."""@en ;
  oakcurric:correction """Encourage pupils to make connections between improper fractions and mixed numbers using both area models and number lines. Focus on reasoning by manipulating parts to complete wholes and where the wholes and parts are represented on the number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679674Z"^^xsd:dateTime .

oak:misconception-pupils-write-negative-numbers-beginning
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not write negative numbers beginning with the negative symbol e.g. writing 3- and not -3."""@en ;
  oakcurric:correction """Take time to model the writing of a negative number. "I know it is negative so I begin with the negative symbol.""""@en ;
  dcterms:modified "2026-02-12T08:59:18.679678Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-visualise-considering-3d
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to visualise when considering 3D parts and wholes and cannot identify a given fractional part of a 3D whole, particularly when presented on a screen as a picture."""@en ;
  oakcurric:correction """Provide opportunities for pupils to experience fractional parts of 3D shapes in real life situations e.g. base 10 blocks or using cuboids such as small cereal variety boxes or photocopying paper boxes. Physical manipulation can support visualisation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679733Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-solve-unknown-factor
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to solve unknown factor calculations where the volume is known."@en ;
  oakcurric:correction """Ensure pupils record missing factor problems as a multiplication equation. You may choose to build up the number of missing factors from one to two. You may also choose to build up from a missing factor in a 2 factor equation to a 3 factor equation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679830Z"^^xsd:dateTime .

oak:misconception-children-fully-aware-two-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Some children may not be fully aware that two shapes can have the same name but be differently shapes. For example, there are several different types of triangle."""@en ;
  oakcurric:correction """Maintain a real focus on 'What's the same and what's different?'. Don't shy away from any questions or misconceptions about categories of shape, use them to further any learning."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679853Z"^^xsd:dateTime .

oak:misconception-children-either-choose-use-multiple
  a oakcurric:Misconception ;
  oakcurric:statement """Children may either choose to use a multiple higher than the dividend, e.g. 53 ÷ 9 = , or choose a multiple that is too low, e.g. 57 ÷ 8 = , which results in a remainder greater than the divisor."""@en ;
  oakcurric:correction """When solving equations, refer back to the largest multiple that is less than or equal to the dividend and use number lines to allow children to visualise this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679891Z"^^xsd:dateTime .

oak:misconception-pupils-look-rod-representing-number
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may look at each rod as representing a number rather than focusing on the colour."""@en ;
  oakcurric:correction """Remind pupils that the rods have no numerical value and encourage pupils discuss the rods by their colour name. They may notice proportional relationships but these should not be labelled numerically."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679997Z"^^xsd:dateTime .

oak:misconception-children-need-understand-equivalent-fractions
  a oakcurric:Misconception ;
  oakcurric:statement """Children need to understand that equivalent fractions must be part of the same whole and that they can be represented as parts of a whole or as a number with a unique position on the number line."""@en ;
  oakcurric:correction """Use the stem sentences to draw attention to how we describe equivalence and use representations to support this. Be clear about when the representation is showing a part of a whole and when it is labelling a point on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680001Z"^^xsd:dateTime .

oak:misconception-pupils-see-example-3-25
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may see, for example, 3.25 kg and convert it to 3 kg and 25 g rather than 3 kg and 250 g."""@en ;
  oakcurric:correction """The lesson presents fractions and decimals as parts of whole circles. As long as pupils know that 1 kg = 1,000 g, they should see from the representation that 0.25 kg = 250 g as 250 + 250 + 250 + 250 = 1,000"""@en ;
  dcterms:modified "2026-02-12T08:59:18.680033Z"^^xsd:dateTime .

oak:misconception-using-short-method-pupils-align
  a oakcurric:Misconception ;
  oakcurric:statement """When using the short method, pupils may not align the digits correctly with the same place value."""@en ;
  oakcurric:correction """Continue to ask what each digit that has been recorded represents, linking back to the place value chart."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680038Z"^^xsd:dateTime .

oak:misconception-parts-deceptive-look-equal-fact
  a oakcurric:Misconception ;
  oakcurric:statement """Sometimes parts can be deceptive and look equal but are in fact unequal. For example, the rhombus that has been split into parts with lines that are equally distributed."""@en ;
  oakcurric:correction """Explore this further by presenting several examples like this if needed. You could ask the children to try and think of some examples where the parts look equal but are in fact unequal. Getting the children thinking of this will boost understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680097Z"^^xsd:dateTime .

oak:misconception-pupils-think-8-45-20
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils might think 8:45 + 20 mins = 8:65. As our system of time is not based around the decimal system,  this is incorrect."""@en ;
  oakcurric:correction """Some pupils may still not be fully au fait with telling the time, though the lesson presumes they are. Providing them with a mini-clock with movable hands will help to reinforce the idea of bridging to and then from the o'clock time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680150Z"^^xsd:dateTime .

oak:misconception-inaccuracy-reading-horizontally-top-bar
  a oakcurric:Misconception ;
  oakcurric:statement """Inaccuracy when reading horizontally from the top of a bar to the y axis on a bar chart."""@en ;
  oakcurric:correction """Model and encourage the use of rulers to follow a straight horizontal line from the top of a bar to the y axis."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680154Z"^^xsd:dateTime .

oak:misconception-pupils-regroup-incorrectly-particularly-subtracting
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils regroup incorrectly, particularly when subtracting e.g. exchanging one ten for ten ones."""@en ;
  oakcurric:correction """Build the calculation using place value counters on a grid set out like a column method. Ask pupils to represent regrouping with counters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680261Z"^^xsd:dateTime .

oak:misconception-pupils-record-partitioned-factors-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not record partitioned factors as tens and ones leading to incorrect calculation."""@en ;
  oakcurric:correction """Encourage pupils to use the stem sentences to support their thinking. Use the language of ___ tens to support place value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680309Z"^^xsd:dateTime .

oak:misconception-pupils-answer-question-like-difference
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils sometimes answer a question like ‘What is the difference between −5℃ and 3℃?’ with ‘−8℃’."""@en ;
  oakcurric:correction """Remind pupils that these differences are always positive by asking them to count forwards from the lower value to the higher value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680313Z"^^xsd:dateTime .

oak:misconception-children-choose-multiple-higher-closest
  a oakcurric:Misconception ;
  oakcurric:statement """Children may choose the multiple that is higher than or closest to the dividend, for example to solve 47 divided by 6, they may choose 8 x 6 = 48 instead of 7 x 6 = 42"""@en ;
  oakcurric:correction """Choose smaller numbers to demonstrate the concept, using practical equipment and number lines to demonstrate why the number must be equal to or less than the dividend."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680336Z"^^xsd:dateTime .

oak:misconception-manipulating-equations-result-errors
  a oakcurric:Misconception ;
  oakcurric:statement "Manipulating equations can result in errors."@en ;
  oakcurric:correction """To find a missing factor, we can use known facts where applicable, or we can divide the product by the known factor. Always encourage children to describe each part of the equation and what it represents."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680360Z"^^xsd:dateTime .

oak:misconception-children-still-fall-habit-considering
  a oakcurric:Misconception ;
  oakcurric:statement """Children may still fall into the habit of considering the greater denominator to be a greater fraction."""@en ;
  oakcurric:correction """Continue to revisit a fraction wall where possible and use real life contexts and images. Ensure that the statement, 'When the whole is equal, the greater the denominator, the smaller the fraction.' is visible and constantly refer to it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680399Z"^^xsd:dateTime .

oak:misconception-pupils-regroup-correctly
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not regroup correctly."@en ;
  oakcurric:correction """Encourage pupils to use the stem sentences / array to identify when they may need to regroup."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680415Z"^^xsd:dateTime .

oak:misconception-pupils-come-unstuck-misreading-misunderstanding
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can come unstuck by misreading or misunderstanding the information being presented."""@en ;
  oakcurric:correction """Encourage pupils to consider what information they do know, and plot this on an empty number line, to help work out the unknown information."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680420Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-find-way-solving
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to find a way into solving the number puzzles at first."@en ;
  oakcurric:correction """It is important that pupils can identify what the whole is for each problem. Encourage pupils to draw a bar model to help link the problem to its part and wholes. This may help them identify the parts and whole and how to calculate any missing parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680424Z"^^xsd:dateTime .

oak:misconception-pupils-realise-necessary-consider-digits
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils do not realise that it is not always necessary to consider all of the digits when comparing or ordering numbers. For example, when comparing 3,974 and 7,832, the thousands are different."""@en ;
  oakcurric:correction """Develop a systematic approach, such that pupils always begin by checking to see if the thousands are the same, then if necessary the hundreds, then the tens, then the ones. Counters and place value grids can really help to exemplify this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680507Z"^^xsd:dateTime .

oak:misconception-pupils-find-difficult-identify-multiples
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it difficult to identify the multiples of 10 a number is between when estimating."""@en ;
  oakcurric:correction """Provide a number line and continue to use stem sentences to support pupils in their thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680511Z"^^xsd:dateTime .

oak:misconception-children-confuse-different-methods-used
  a oakcurric:Misconception ;
  oakcurric:statement """Children may confuse the different methods used to compare fractions of amounts and their wholes."""@en ;
  oakcurric:correction """Guide through questioning. What is the same/different? Can you represent this visually? What is the size/value of the parts? What fraction of the whole is each part?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.680697Z"^^xsd:dateTime .

oak:misconception-common-mistake-pupils-make-faced
  a oakcurric:Misconception ;
  oakcurric:statement """The most common mistake pupils will make when faced with these sorts of questions is not taking into account the unit conversion that needs to take place if the units of measure are mixed."""@en ;
  oakcurric:correction """You may wish to consider drawing extra attention to the fact that the units of measure are different when presenting the Practice tasks, for example highlighting them in different colours if appropriate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680759Z"^^xsd:dateTime .

oak:misconception-children-understand-division-repeated-subtraction
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not understand division as repeated subtraction because they can count forwards to find the number of equal groups in a number."""@en ;
  oakcurric:correction """On a number line, show how counting forwards and backwards in multiples results in the same answer. Discuss the difficulty of using tables facts to count backwards when there is a remainder, so they understand why counting forwards is more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680763Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-fraction-part-whole
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils confuse the fraction part of each whole with the value of the number of items in each part."""@en ;
  oakcurric:correction """Progressively build from looking at the size of each part in relation to the whole using bar models to start with. After pupils are secure with this, introduce the quantities and be clear to distinguish between the value and size of each part."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680774Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-using-number
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes when using number lines to represent fractions, especially with bar representations that do not begin at zero."""@en ;
  oakcurric:correction """Link teaching to measurement. When measuring the length of a object, the measurement needs to begin at zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680779Z"^^xsd:dateTime .

oak:misconception-comparing-pair-numbers-such-3
  a oakcurric:Misconception ;
  oakcurric:statement """When comparing a pair of numbers such as 3 and −3, pupils may think they are of equal value."""@en ;
  oakcurric:correction """Use of number lines, ideally displayed in the classroom, will help pupils to see that numbers increase in value the further right they are."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680829Z"^^xsd:dateTime .

oak:misconception-part-changes-size-whole-changes
  a oakcurric:Misconception ;
  oakcurric:statement "The part changes size when the whole changes."@en ;
  oakcurric:correction """Use the bottles example in the slides to overcome this. Have a range of different sized containers for water and demonstrate the concept practically."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680834Z"^^xsd:dateTime .

oak:misconception-children-work-inefficiently-e-g
  a oakcurric:Misconception ;
  oakcurric:statement """Children may work inefficiently, e.g. they may find the digit sum of 27 to find if it is a multiple of 6, instead of first reasoning that it cannot be because it is an odd number."""@en ;
  oakcurric:correction """Encourage children to consider what they know about a number first (e.g. all even numbers have even multiples) before applying other parts of rules so that they work in the most efficient way. Display models of these to enable recall of them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680881Z"^^xsd:dateTime .

oak:misconception-children-scale-decimal-fraction-inaccurately
  a oakcurric:Misconception ;
  oakcurric:statement """Children may scale the decimal fraction inaccurately or may forget to scale the product accordingly to solve the original equation."""@en ;
  oakcurric:correction """If a decimal fraction has only tenths, we multiply by 10 to form a whole number. If the decimal fraction has hundredths, we multiply by 100 to form a whole number.  Remember to adjust the product to answer the original equation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680913Z"^^xsd:dateTime .

oak:misconception-pupils-convert-fractions-decimals-accurately
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils do not convert fractions to decimals accurately."@en ;
  oakcurric:correction """Take time to remind pupils about key equivalences such as one-half is 0.5 and one-fifth is 0.2   Pupils can use these to check the reasonableness of their answers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680965Z"^^xsd:dateTime .

oak:misconception-pupils-count-part-square-such
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils might count a part square - such as a triangle - as one square unit."@en ;
  oakcurric:correction """The slides show two parts moving together to make a whole square. Cutting out and physically moving the parts is an effective strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680969Z"^^xsd:dateTime .

oak:misconception-children-fall-trap-thinking-greater
  a oakcurric:Misconception ;
  oakcurric:statement """Children will often fall into the trap of thinking that a greater denominator creates a bigger fraction."""@en ;
  oakcurric:correction """Ensure the children have good access to fraction walls to reinforce the fact that the greater the denominator the smaller the fraction. Fraction walls that can be dismantled and arranged are very useful for this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680999Z"^^xsd:dateTime .

oak:misconception-children-used-sorting-diagram
  a oakcurric:Misconception ;
  oakcurric:statement "Children may not be used to a sorting diagram."@en ;
  oakcurric:correction """Show them some more simplified versions that they can understand easily (like the fruit and veg in the slides) before moving onto using their understanding of unit-fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681331Z"^^xsd:dateTime .

oak:misconception-lots-practice-taken-place-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """Lots of practice has taken place for pupils to convert between kilometres and metres. Pupils may expect kilometres and miles to have a similar relationship and expect one mile to equal 1,000 metres."""@en ;
  oakcurric:correction """Bar models and double number lines are excellent visual representations of the relationship and should help pupils to form a more concrete understanding of the equivalence between units. Displaying these will provide a prompt for pupils."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681359Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-identify-appropriate-sized
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to identify appropriate sized bars that fit the problem as well as equate to the size of the whole."""@en ;
  oakcurric:correction """Find parts that fit the structure of the problem first, then ask what the whole would be. Change the size of the whole and ask pupils which rod(s) would need to change. Encourage children to reason their decisions by comparing the size of the rods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681368Z"^^xsd:dateTime .

oak:misconception-children-familiar-multiplication-resulting-increase
  a oakcurric:Misconception ;
  oakcurric:statement """Children are more familiar with multiplication resulting in an increase, and need to appreciate that it can also result in a decrease."""@en ;
  oakcurric:correction """When we multiply an integer by a unit fraction, the effect is the same as dividing the whole by the denominator. It results in a decrease."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681461Z"^^xsd:dateTime .

oak:misconception-pupils-need-support-decimal-representation
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils may need support with the decimal representation of measures and how to convert from larger units to smaller e.g. 1.2 l into ml."""@en ;
  oakcurric:correction """Allow pupils to go back to previous work completed where necessary to see the units of measure divided up into 2, 4, 5 and 10 parts and represented with decimals, to provide a scaffold for them to use whilst completing the problems in this lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681468Z"^^xsd:dateTime .

oak:misconception-pupils-consider-context-identifying-remainder
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not consider the context when identifying what to do with the remainder."""@en ;
  oakcurric:correction """Pupils often respond well to ridiculous examples here such as suggesting some of the class are left behind on a school trip in order to have equal-sized teams. These more extreme examples help consideration of context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681473Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-see-whole-several
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to see the 'whole'. If several sets are presented together (e.g. different types of fruit in a bowl), is the whole the sum of all the sets or just one of them?"""@en ;
  oakcurric:correction """Encourage children to identify the noun they are finding a fraction of. Is it the apples or bananas, the pandas with hats on or without. From there, they can then go on to identify the part they are being asked to find e.g. the bananas in the bowl."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681477Z"^^xsd:dateTime .

oak:misconception-two-unrelated-units-measure-called
  a oakcurric:Misconception ;
  oakcurric:statement """Two unrelated units of measure are called 'pounds' - the money version and the mass version. Pupils may confuse one for the other."""@en ;
  oakcurric:correction """In this lesson, the word pounds (as in mass) is used with the abbreviation lb in brackets. It is recommended that you use both of these until pupils reach a point where they can automatically read lb as pounds and and record it as such."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681496Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-unpick-maths-required
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to unpick the maths required of them from the worded problems."@en ;
  oakcurric:correction """Encourage pupils to draw a bar model for each problem. This will help them to identify what information is known, for example, whether the problem indicates if the whole, the value of a part, or the size of a part is known."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681504Z"^^xsd:dateTime .

oak:misconception-pupils-recognise-total-number-equal
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not recognise the total number of equal parts that make up the whole and may instead just count the number they have / are shaded for example."""@en ;
  oakcurric:correction """Encourage pupils to count the total number of equal parts that make up the whole and then the number that are shaded. Stress that the denominator shows the number of equal parts that make up the whole and that the numerator shows the number we have."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681568Z"^^xsd:dateTime .

oak:misconception-common-children-generalise-linguistic-pattern
  a oakcurric:Misconception ;
  oakcurric:statement """It is very common for children to generalise the linguistic pattern of adding the suffix of 'th' to create fraction names even though there are special cases mentioned in the slides."""@en ;
  oakcurric:correction """Make good use of your learning wall here and display the names prominently paired with their fractional notation. Inject some fun by making a game of it: say incorrect fraction names during your own explanations and get the children to correct you."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681573Z"^^xsd:dateTime .

oak:misconception-children-think-parallelogram-symmetrical-because
  a oakcurric:Misconception ;
  oakcurric:statement """Some children will think that a parallelogram is symmetrical because it can be divided in half."""@en ;
  oakcurric:correction """Demonstrate with folding and by using mirrors why dividing a parallelogram in half does not result in a line of symmetry. Allow children to explore this concept with cut-outs of different parallelograms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681775Z"^^xsd:dateTime .

oak:misconception-pupils-count-number-equal-parts
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may count the number of equal parts that are shaded and write the numerator and then count the number that are not shaded and write the denominator."""@en ;
  oakcurric:correction """Ensure that pupils count all of the equal parts to find the denominator.  The denominator is the number of equal parts that make up whole. We encourage children to find, and then describe, the denominator before the numerator."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681847Z"^^xsd:dateTime .

oak:misconception-pupils-remember-scale-one-sides
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may remember to scale one of the sides (or pairs of sides) of a shape but forget to scale the others."""@en ;
  oakcurric:correction """Focus attention on what it means when a shape is similar, drawing on examples and non-examples to support learners to understand how scaling affects all side lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685254Z"^^xsd:dateTime .

oak:misconception-pupils-make-accurate-estimates-their
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not make very accurate estimates for their calculations."@en ;
  oakcurric:correction """This lesson explores inaccurate estimations. Estimations should be quick and easy to calculate, but when adding two addends, it's sensible to make one larger and one smaller so that the estimate is as accurate as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:18.686161Z"^^xsd:dateTime .

oak:misconception-mis-align-numbers-setting-algorithms
  a oakcurric:Misconception ;
  oakcurric:statement """Mis-align numbers when setting up algorithms if the numbers have different amount of digits. When finding 1 missing part out of 3 parts, children may perform two subtractions, which is inefficient."""@en ;
  oakcurric:correction """When setting up the algorithm, ensure digits in the same place value place are aligned. When finding 1 missing part of 3 parts, first we add the known parts then we subtract from the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687144Z"^^xsd:dateTime .

oak:misconception-pupils-record-prime-factor-once
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may only record a prime factor once in the Venn diagram even though it might be used more than once in the composition of the number."""@en ;
  oakcurric:correction """It is important the clarify that we are finding common prime factors that are used in the composition of two numbers, and this might include a prime factor being used more than once."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687406Z"^^xsd:dateTime .

oak:misconception-children-think-shape-draw-around
  a oakcurric:Misconception ;
  oakcurric:statement """Children might think that any shape they draw around or use is a whole and the new shapes they create represent lots of wholes joined together."""@en ;
  oakcurric:correction """Ensure the children understand that a whole can be anything and can change as you add parts to it. A piggy bank is a good analogy for this as you are constantly adding money to the whole and it is made up of many parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687410Z"^^xsd:dateTime .

oak:misconception-children-recognise-line-symmetry-neither
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not recognise a line of symmetry when it is neither horizontal nor vertical."""@en ;
  oakcurric:correction """Allow opportunities for exploring lines of symmetry practically by folding cut outs of lots of different shapes. Encourage children to view and describe these in different orientations to help them see that a line of symmetry can be in any direction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687415Z"^^xsd:dateTime .

oak:misconception-pupils-attempt-represent-problems-bar
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils attempt to represent the problems with bar models rather than take a systematic, trial and improvement approach."""@en ;
  oakcurric:correction """Encourage pupils to represent each problem how they would like. Pupils should take time to notice why it is that the bar model if not appropriate to help solve these problems and identify these clues within the questions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687422Z"^^xsd:dateTime .

oak:misconception-pupils-realise-squares-rectangles
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not realise that squares are rectangles."@en ;
  oakcurric:correction """Emphasise to pupils that all squares are rectangles but not all rectangles are squares. Rectangles are quadrilaterals with 4 right angles, but squares have 4 sides of equal length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687428Z"^^xsd:dateTime .

oak:misconception-pupils-find-difficult-represent-problem
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils find it difficult to represent the problem as an expression or equation as they misinterpret what the whole is."""@en ;
  oakcurric:correction """Draw attention to what the whole is in each example. You might like to build up each image with a whole at a time, describing the fraction of the whole that is shaded/represented."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687433Z"^^xsd:dateTime .

oak:misconception-pupils-misread-values-bars-graph
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils misread the values of bars on each graph."@en ;
  oakcurric:correction """Encourage pupils to mark on as many gridlines that they can for themselves once they have recognised the size of the whole. This may then help pupils to estimate the value of each bar more accurately until they can do it by imagining the gridlines."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687437Z"^^xsd:dateTime .

oak:misconception-children-develop-misconception-unit-fractions
  a oakcurric:Misconception ;
  oakcurric:statement """Children may develop the misconception that unit fractions must be adjacent to be part of a repeated addition."""@en ;
  oakcurric:correction """When using a number line, match it with another representation where possible in which the unit fractions aren't adjacent so children see that it is about the quantity of unit fractions rather than their position."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687444Z"^^xsd:dateTime .

oak:misconception-pupils-try-compare-fractions-whole
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils try to compare fractions where the whole is not the same size."@en ;
  oakcurric:correction """Give an example where fractions represent different sized wholes. Discuss how fractions may not help us compare the area used/shaded if the wholes are different. Instead, highlight the show the relationship between the whole and its part(s)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687448Z"^^xsd:dateTime .

oak:misconception-drawing-triangles-given-area-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """When drawing triangles with a given area pupils may create a factor pair of the triangle's area when drawing the base and perpendicular height. The factor pair refers to the surrounding parallelogram."""@en ;
  oakcurric:correction """For pupils who are making this mistake, encourage them to sketch the parallelogram around the triangle, reminding them to double the triangle area before finding the factor pairs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687621Z"^^xsd:dateTime .

oak:misconception-pupils-use-zero-show-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not use zero to show that there are no tens or ones number in a 3-digit number. They may also use a zero to show that there are no hundreds when adding a 2-digit to a 3-digit number."""@en ;
  oakcurric:correction """Emphasise with pupils that they need to use a zero only when needed. The number 75 would not be written as 075, so should not be written like this in column addition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687625Z"^^xsd:dateTime .

oak:misconception-using-adjustment-e-g-456
  a oakcurric:Misconception ;
  oakcurric:statement """When using adjustment (e.g. 456 − 199), pupils may forget to subtract or add 1 to both parts."""@en ;
  oakcurric:correction """The emphasis of same difference can encourage children to ensure they have subtracted or added to both parts of the calculation. Clearly display the visuals in this lesson to support with this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687630Z"^^xsd:dateTime .

oak:misconception-pupils-multiply-non-unit-fraction
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils multiply the non-unit fraction by the denominator to create the whole."@en ;
  oakcurric:correction """Ensure pupils spend time breaking down non-unit fractions back into unit fractions. Encourage pupils to recognise this as two stages. Firstly, find the unit fraction. Secondly, re-create the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687636Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-count-boundaries-multiples
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to count over the boundaries for multiples of ten thousand and one hundred thousand."""@en ;
  oakcurric:correction """Ensure children focus on the number of thousands they have within the number. This should effectively be the same as counting in ones over tens and hundreds boundaries, with the exception of the unit changing from ones to thousands."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687641Z"^^xsd:dateTime .

oak:misconception-pupils-opt-represent-problem-using
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils opt to represent the problem using two separate bar models that are stacked on top of one another."""@en ;
  oakcurric:correction """Whilst pupils can represent the maths how they wish, these problems tend to be more efficiently represented using a singular bar model with the whole at the top. Further iterations of these bar models can then be represented underneath."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687646Z"^^xsd:dateTime .

oak:misconception-pupils-partition-numbers-efficient-ways
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not partition numbers in efficient ways to add and subtract them."@en ;
  oakcurric:correction """Encourage pupils to add or subtract to make 100 (e.g. when calculating 103-7, subtract 3 to equal 100, then subtract 4 to equal 96)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687795Z"^^xsd:dateTime .

oak:misconception-pupils-make-errors-subtracting-zero
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make errors when subtracting zero or when writing zero in the ones, tens or hundreds column of the difference."""@en ;
  oakcurric:correction """Encourage pupils to write zero, using the examples given in the slide deck. Write zero in the hundreds column of the difference when using column subtraction; explain this is not written when the calculation is presented as a horizontal equation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687800Z"^^xsd:dateTime .

oak:misconception-children-confused-write-mixed-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Children may be confused about how to write mixed numbers. Children may say 'five and one-eight, rather than five and one-eighth."""@en ;
  oakcurric:correction """As a school, establish how mixed numbers will be recorded so that you have consistency. Ensure children are accurately expressing the fraction part."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687805Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-terminology-dividend-divisor
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may confuse the terminology of dividend and divisor. Pupils may regroup the incorrect amount."""@en ;
  oakcurric:correction """Ensure pupils can identify the dividend and the divisor. Use language of unitisation to correct any place value misconceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687809Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-understand-3-factor
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to understand that a 3 factor calculation problem with two unknown factors can be represented as a 2 factor calculation with one unknown factor."""@en ;
  oakcurric:correction """Spend time manipulating 2 factor calculations into 3 factors and vice versa. Once pupils are confident with this, apply this to a context where the numbers are kept simple to support pupils to see the structure of the problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687814Z"^^xsd:dateTime .

oak:misconception-pupils-write-minuend-subtrahend-wrong
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may write the minuend and subtrahend the wrong way around."@en ;
  oakcurric:correction """Model setting out column subtraction, starting with the minuend. This can be taught alongside manipulatives such as Base 10 blocks so that pupils understand that the minuend is the number that we start with."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687818Z"^^xsd:dateTime .

oak:misconception-pupils-find-hard-recognise-angle
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it hard to recognise when an angle is greater than a right angle."""@en ;
  oakcurric:correction """You can model this by trying to move the obtuse angle (though pupils don't need to know the term yet) within a right angle checker. They should be able to see that it is too large to fit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687823Z"^^xsd:dateTime .

oak:misconception-place-value-counters-dont-proportionality
  a oakcurric:Misconception ;
  oakcurric:statement """Place value counters don't have proportionality in the same way that Base 10 does which can make the concepts here more abstract."""@en ;
  oakcurric:correction """Smaller multiplications can be used with Base 10 to model scaling to start off with. Try 2 × 1 or 3 × 1  scaling up to  become 2 × 10 or 3 × 10 with Base 10 and then put this modelling side-by-side with place value counters to make the links."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687828Z"^^xsd:dateTime .

oak:misconception-pupils-much-experience-using-gattegno
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not have much experience in using a Gattegno chart."@en ;
  oakcurric:correction "Consider pre-teaching for children who lack confidence using Gattegno chart."@en ;
  dcterms:modified "2026-02-12T08:59:18.687834Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-find-factors-number
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to find factors of a number if they do not have automatic recall of their times tables."""@en ;
  oakcurric:correction """Provide children with a multiplication grid to help pupils understand the process of the calculations, however ensure additional support is in place for children to build towards automatic recall of times tables."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687839Z"^^xsd:dateTime .

oak:misconception-pupils-find-hard-understand-recalculating
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it hard to understand that recalculating the adjusted part is an unnecessary step."""@en ;
  oakcurric:correction """Display two sets of workings side-by-side. In the 1st, show the adjusted part being recalculated. In the 2nd, show it without recalculating the part. Pupils will hopefully see that the solution emerges from both."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687968Z"^^xsd:dateTime .

oak:misconception-many-pupils-believe-subtracting-zero
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils believe that 'subtracting zero' is dividing by 10 which can lead to difficulties later on when they are introduced to decimal numbers."""@en ;
  oakcurric:correction """Don't dismiss it. It's a pattern that has been spotted and generalised. Do encourage the children to work with physical resources that don't involve the numbers themselves so they can see that it's not subtracting zero but changing place value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687973Z"^^xsd:dateTime .

oak:misconception-children-spot-unit-repeat-draw
  a oakcurric:Misconception ;
  oakcurric:statement """Children might spot the unit of repeat and draw a repeating pattern rather than a symmetrical pattern."""@en ;
  oakcurric:correction """Allow children to fold and unfold painted patterns on the mirror line to see where each part of the pattern would be reflected. Printing is a great tool to create symmetrical patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687979Z"^^xsd:dateTime .

oak:misconception-pupils-understanding-problem-asking-them
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils not understanding what the problem is asking them to find out and identifying the operation."""@en ;
  oakcurric:correction """Model the use of bar models and manipulatives to represent the problem and how to identify the operation and calculations needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687984Z"^^xsd:dateTime .

oak:misconception-pupils-think-larger-objects-cannot
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might think that larger objects cannot be a part of a whole due to their size. Children may not appreciate that the same item can be a whole or a part depending on the context."""@en ;
  oakcurric:correction """Encourage pupils to work with parts and wholes that they can handle and experience but where parts are large and have them look at example where the same object can be a whole or a part."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687997Z"^^xsd:dateTime .

oak:misconception-pupils-overgeneralise-way-triangle-look
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may overgeneralise about the way a triangle should look e.g. not recognising a scalene triangle as a triangle."""@en ;
  oakcurric:correction """Throughout the lesson, model different triangles in different orientations. Ensure pupils see boundary examples such as scalene triangles with one very small acute angle, or long and thin isosceles triangles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688002Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-compare-fractions-same
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to compare fractions with the same numerator or denominator."@en ;
  oakcurric:correction """Encourage pupils to use fraction representations to help them visualise. Reference the size of the parts (same numerator, greater denominator means smaller parts) or how many there are (same denominator, greater numerator means more parts)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688006Z"^^xsd:dateTime .

oak:misconception-adding-fractions-same-denominator-many
  a oakcurric:Misconception ;
  oakcurric:statement """When adding fractions with the same denominator many children may try and add both the numerator and denominator."""@en ;
  oakcurric:correction """This is a misunderstanding of the unitisation. Practise counting in different set of objects such as cubes, counters, children. Move children on to counting in fractions and explain that this is simply a different unit, shown by the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688011Z"^^xsd:dateTime .

oak:misconception-pupils-think-composing-larger-polygons
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that composing larger polygons of smaller triangles that are not formed as a result of drawing a line from one vertex to another will help them to identify the sum of the angles."""@en ;
  oakcurric:correction """Highlight how the formation of triangles within a polygon must be from vertex to vertex and demonstrate how the angles of each triangle where they meet sum to the internal angle of the polygon."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688015Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-divisibility-rules-apply
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may confuse the divisibility rules or apply them incorrectly."@en ;
  oakcurric:correction """Display the rules so pupils can be reminded of them. Clarify each rule with clear examples and practice problems (e.g., a number is divisible by 3 if the sum of its digits is divisible by 3)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688020Z"^^xsd:dateTime .

oak:misconception-pupils-inefficient-calculating-perimeter-rectangle
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils are inefficient when calculating the perimeter of a rectangle or do not recognise why more efficient strategies (summing length and width and doubling) works."""@en ;
  oakcurric:correction """Encourage pupils to see the efficient calculation and connection with smaller integers to support the generalisation before progressing to values in the lesson. Consider adapting values for some learners where required."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688094Z"^^xsd:dateTime .

oak:misconception-children-learn-spot-create-equivalent
  a oakcurric:Misconception ;
  oakcurric:statement """Children learn how to spot and create equivalent fractions without realising that they have the same value and have the same position on a number line. The understanding of equivalence is important."""@en ;
  oakcurric:correction """Use the = symbol to record fractions with the same value and the language 'is equal to'. Make use of manipulatives and representations to model equivalence and highlight the equality."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688099Z"^^xsd:dateTime .

oak:misconception-children-make-mistakes-using-generalisation
  a oakcurric:Misconception ;
  oakcurric:statement """Children may make mistakes when using the generalisation if they are unaware of the structure behind it and the reason that we divide."""@en ;
  oakcurric:correction """Find how many groups of the denominator can be made from the numerator by dividing. This tells us how many full groups we can make, which gives us the whole number part of the mixed number. The remainder tells us the fractional part."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688103Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-position-five-digit
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to position five-digit multiples of 1,000 on a 0-1,000,000 number line."""@en ;
  oakcurric:correction """It is important to check if pupils are secure in placing numbers on a 0-1,000 number line. This is a fundamental prerequisite to be able to achieve with this learning, so spending time securing this prior learning may be necessary."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688110Z"^^xsd:dateTime .

oak:misconception-incorrectly-regrouping-forgetting-record-regrouped
  a oakcurric:Misconception ;
  oakcurric:statement "Incorrectly regrouping or forgetting to record a regrouped amount."@en ;
  oakcurric:correction """Clear teacher modelling. 'What does this digit represent?' 'Where do we place the regrouped amount?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688117Z"^^xsd:dateTime .

oak:misconception-writing-subtraction-expression-within-equation
  a oakcurric:Misconception ;
  oakcurric:statement """When writing the subtraction expression within the equation, children may write the parts to be divided in the order they appear in the problem, rather than putting the greatest one first."""@en ;
  oakcurric:correction """Explore where the parts to be divided need to be written in a different order to how they appear in the problem. Compare this with addition and explore commutativity so that children can see how addition is commutative but subtraction is not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688121Z"^^xsd:dateTime .

oak:misconception-many-polygons-appear-regular-sides
  a oakcurric:Misconception ;
  oakcurric:statement """Many polygons appear regular as all of the sides are the same length. However, it is possible (as the lesson shows) to have polygons which are the same length sides but different interior angles."""@en ;
  oakcurric:correction """Pupils should have previous experience of right angles. Use a right angle 'measurer' to prove that some of the angles in a shape are greater than a right angle and some smaller; as the angles are not all equal, it is not a regular polygon."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688126Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-positioning-numbers-0
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle with positioning numbers on 0-1,000 lines."@en ;
  oakcurric:correction """Relate the positioning of numbers on 0-100 number lines with 0-1,000 number lines (e.g. 19 and 190, 37 and 370)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688130Z"^^xsd:dateTime .

oak:misconception-pupils-look-adopt-formal-written
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may look to adopt a formal written strategy straight away when this is not necessary."""@en ;
  oakcurric:correction """Share different strategies utilised by pupils within the lesson and compare these to expand pupils' understanding of efficiency."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688135Z"^^xsd:dateTime .

oak:misconception-pupils-think-missing-part-s
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the missing part(s) must be a different colour rod to those parts already used within the example."""@en ;
  oakcurric:correction """Provide pupils with various examples, in particular examples where there are two or more of the same part, drawing on the repeated addition/multiplicative structure not just the additive structure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688141Z"^^xsd:dateTime .

oak:misconception-lack-fluency-4s-8s-times
  a oakcurric:Misconception ;
  oakcurric:statement "Lack of fluency in the 4s and 8s times tables and generalisation of the rule."@en ;
  oakcurric:correction """Encourage children to test generalisation - model this clearly using key words and identifying why the rule applies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688210Z"^^xsd:dateTime .

oak:misconception-short-division-algorithm-correctly-aligned
  a oakcurric:Misconception ;
  oakcurric:statement "The short division algorithm may not be correctly aligned."@en ;
  oakcurric:correction "Check that the decimal point aligns in the decimal fraction and the answer."@en ;
  dcterms:modified "2026-02-12T08:59:18.688218Z"^^xsd:dateTime .

oak:misconception-pupils-find-protractors-tricky-drawing
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can find protractors tricky, sometimes drawing the wrong angle because the outer scale has been used rather than the inner-scale, or vice-versa."""@en ;
  oakcurric:correction """Emphasise estimation through knowledge of angle types. Model discussion of whether an angle is acute or obtuse and use this knowledge to identify which value on which scale is the measurement."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688231Z"^^xsd:dateTime .

oak:misconception-magic-squares-children-miss-fact
  a oakcurric:Misconception ;
  oakcurric:statement """On the magic squares, children will often miss the fact that it is a two step problem involving addition and subtraction. They may think you have to add the two numbers in the row/column or diagonal."""@en ;
  oakcurric:correction """Start with a simpler magic square. The easier ones feature the numbers 1-9 and total 15 diagonally, vertically or horizontally. Once they understand them, introduce 2-digit and 3-digit magic squares."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688236Z"^^xsd:dateTime .

oak:misconception-pupils-think-zero-values-need
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils may think that zero values do not need to be included when dividing by how many values there are in the set of data."""@en ;
  oakcurric:correction """Show that even if a value is zero, it is still a value in the set of data. It doesn't affect the total of the set but does need to be included in the total number of values in the set."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688241Z"^^xsd:dateTime .

oak:misconception-pupils-unitise-using-long-division
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not unitise when using long division and make errors (e.g. when dividing 7 hundreds by 12)."""@en ;
  oakcurric:correction """Explain to pupils that they are looking for multiples of the divisor (1 hundred × 12 = 1,200). This becomes clearer when dividing the tens digits (6 tens × 12 = 72 tens)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688245Z"^^xsd:dateTime .

oak:misconception-pupils-think-larger-size-arc
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the larger the size of the arc between the two lines, the larger the angle must be."""@en ;
  oakcurric:correction """Ensure pupils compare the same angle where the arc has been drawn on either closer to the vertex or further away from the vertex. Generalise that the position of the arc doesn't matter, though it is convention to draw it closer to the vertex."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688405Z"^^xsd:dateTime .

oak:misconception-children-say-ten-times-shorter
  a oakcurric:Misconception ;
  oakcurric:statement """Children may say 'ten times shorter' which is imprecise. Children are more familiar with multiplication resulting in an increase, and need to appreciate that it can also result in a decrease."""@en ;
  oakcurric:correction """We say, 'ten times the original height' because this is more precise especially when the scale factor is fractional. When we multiply by a unit fraction, it is the same as dividing the whole by the denominator. This results in a decrease in length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688410Z"^^xsd:dateTime .

oak:misconception-pupils-see-prefix-milli-think
  a oakcurric:Misconception ;
  oakcurric:statement "Some pupils may see the prefix 'milli' and think it is related to 'million'."@en ;
  oakcurric:correction """Part of the lesson focuses on the etymology of the words and the fact that the prefix 'milli' means 'thousandth'; a millimetre is a thousandth of a litre and a millilitre is one thousandth of a litre. Consider displaying this in your environment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688417Z"^^xsd:dateTime .

oak:misconception-calculating-length-side-overall-dimension
  a oakcurric:Misconception ;
  oakcurric:statement """Calculating the length of a side when the overall dimension and part dimensions are known and understanding when a part of the overall dimension is needed to calculate part of the area."""@en ;
  oakcurric:correction """Look at shapes with missing dimensions and discussing that the overall length and width of a compound rectilinear shape is the total of the shorter side lengths in a particular direction. This allows missing or overall dimensions to be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688421Z"^^xsd:dateTime .

oak:misconception-pupils-use-trial-improvement-approach
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils use a trial and improvement approach to solve these problems only."@en ;
  oakcurric:correction """At first, pupils may put numbers into the equation to see what happens each time. Encourage pupils to move beyond this to notice what happens to each example. Pupils should aim to use the relationships between addends or subtrahends to help them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688433Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-identify-whether-factor
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to identify whether a factor is representing the group size or the number of groups, particularly when their position in the equation is swapped to show commutativity."""@en ;
  oakcurric:correction """Give children concrete examples to look at, such as jars of marbles, boxes of erasers or pots of pencils and write corresponding multiplication equations, identifying the factor that represents group size and the one that represents number of groups."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688440Z"^^xsd:dateTime .

oak:misconception-pupils-find-incorrect-volume-cuboid
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils find the incorrect volume of a cuboid or cube by only counting what they can see. This may be the faces or whole cubes that are forward facing."""@en ;
  oakcurric:correction """Encourage pupils to create the cuboids or cubes for themselves as well as show pupils how the cuboids or cubes are constructed as layers of rows and columns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688445Z"^^xsd:dateTime .

oak:misconception-pupils-think-taller-object-greater
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may think that the taller the object, the greater its volume."@en ;
  oakcurric:correction """Use 3D objects as much as possible to compare, so pupils can develop their appreciation for multiple dimensions that contribute to the object's volume."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688573Z"^^xsd:dateTime .

oak:misconception-pupils-know-stop-looking-factors
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils do not know when to stop looking for more factors."@en ;
  oakcurric:correction """Build up finding factors of numbers systematically by arranging into rows and columns, starting with 1 row. Encourage pupils to generalise that when the number of rows becomes larger than the number of columns, you can stop looking for factors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688577Z"^^xsd:dateTime .

oak:misconception-part-lesson-requires-pupils-decide
  a oakcurric:Misconception ;
  oakcurric:statement """Part of the lesson requires pupils to decide whether times are before midday, at midday or after midday. Pupils can find categorising 12:00 and 00:00 tricky."""@en ;
  oakcurric:correction """Explicit teaching points are made based around this in the slide deck. However, it is worth really focusing on these points as they come up and, when assessing the pupils during the Practice tasks, paying particular attention to those times."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688581Z"^^xsd:dateTime .

oak:misconception-children-overwhelmed-amount-visual-data
  a oakcurric:Misconception ;
  oakcurric:statement """Children can often be overwhelmed by the amount of visual data they are presented with."""@en ;
  oakcurric:correction """Expose children to graphical data as much as possible outside of maths lessons. Encourage children to make simple bar charts with cubes so they understand their formation and liken the searching for specific values to search and find books."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688586Z"^^xsd:dateTime .

oak:misconception-pupils-appreciate-equivalent-fractions-equivalent
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not appreciate that equivalent fractions and equivalent fractions and decimals have exactly the same value and can be substituted which may be beneficial when solving problems."""@en ;
  oakcurric:correction """Model the thinking when there is a mixture of fractions and decimal representations in a problem and identify the decision as to whether to convert all to decimals or all to fractions as a step in the the problem solving process."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688593Z"^^xsd:dateTime .

oak:misconception-pupils-misled-meaning-prefix-milli
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can be misled by the meaning of the prefix 'milli', as it sounds like one million. They therefore presume a millimetre is one millionth of a metre, or that one metre is one million millimetres."""@en ;
  oakcurric:correction """The etymology of the prefixes 'milli' and 'kilo' are discussed in the lesson. You may wish to extend this by talking about other examples. Adding the words and their meanings to your Maths area will serve as a useful reminder, as will flash cards."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688597Z"^^xsd:dateTime .

oak:misconception-children-confuse-use-base-10
  a oakcurric:Misconception ;
  oakcurric:statement """Children may confuse use of the Base 10 equipment. They may also confuse the equivalence between dividing by 10/100/1,000 and multiplying by 0.1/0.01/0.001."""@en ;
  oakcurric:correction """The large cube now represents one whole. The smaller blocks represent decimal fraction numbers. Use stem sentences to support common mistakes: when a number is divided by ___, it is the same as multiplying by ___"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688606Z"^^xsd:dateTime .

oak:misconception-pupils-forget-record-remainder
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may forget to record the remainder."@en ;
  oakcurric:correction """Remind children that if the ones are not divisible there will be a remainder and that this is expressed as 'r'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688739Z"^^xsd:dateTime .

oak:misconception-working-algorithmically-without-understanding-regrouped
  a oakcurric:Misconception ;
  oakcurric:statement """Working through algorithmically without having an understanding of the regrouped amount."""@en ;
  oakcurric:correction """Clear modelling with PVC. Ask children 'What does this number represent?'. Continue to use sentence stems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688744Z"^^xsd:dateTime .

oak:misconception-perfectly-possible-pupils-highly-numerate
  a oakcurric:Misconception ;
  oakcurric:statement """It is perfectly possible for pupils to be highly numerate but struggle with the spatial awareness needed to visualise / imagine whether a 2D net will fold together to form a 2D shape."""@en ;
  oakcurric:correction """As part of the lesson design process you may wish to incorporate manipulatives such as construction materials for those pupils whose learning needs scaffolding. As with all scaffolding, aim to move pupils away from this when you can."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688750Z"^^xsd:dateTime .

oak:misconception-pupils-multiply-numerator-denominator-whole
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils multiply both the numerator and denominator by the whole number."@en ;
  oakcurric:correction """Ensure pupils are given time to explore how equations are represented using multiple representations and avoiding 'finding the answer' initially. Encourage children to reason how each equation is linked to the representations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688755Z"^^xsd:dateTime .

oak:misconception-pupils-believe-one-way-add
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may believe that there is only one way to add the perimeter of a shape - typically clockwise, starting from the top. This is untrue and will limit the efficiency of the arithmetic."""@en ;
  oakcurric:correction """The lesson presents the idea of the side lengths being given in counters. The counters can then be re-ordered, for example so that a number bond to ten can be utilised. Using counters or sticky notes or similar may support pupils."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688761Z"^^xsd:dateTime .

oak:misconception-pupils-explain-relationship-multiples-10
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may explain the relationship with multiples of 10 as 'adding a zero' (e.g. 37 x 10 = 370)."""@en ;
  oakcurric:correction """Pupils should be discouraged from doing this. Instead, explore place value, reminding pupils that each 100 represents 10 lots of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688766Z"^^xsd:dateTime .

oak:misconception-pupils-incorrectly-partition-subtrahend
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may incorrectly partition the subtrahend."@en ;
  oakcurric:correction """Partition the subtrahend to count back to ten or a tens number. Use number pairs that total ten to help subtract whatever is left."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688772Z"^^xsd:dateTime .

oak:misconception-pupils-need-look-interior-angles
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils need to look at the interior angles in the shape. They may think that an interior angle of 270° is a right angle."""@en ;
  oakcurric:correction """Explain to pupils that we need to measure the interior angles of a shape. Show them examples of this (e.g. an arrowhead) to illustrate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688777Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-measuring-protractor
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes measuring with a protractor, reading the wrong scale to get a measurement."""@en ;
  oakcurric:correction """Encourage pupils to check that each answer is sensible. Is the angle greater or less than a right angle? Have they drawn an angle greater/less than a right angle? Do all the angles add up to a sum of 360°?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688782Z"^^xsd:dateTime .

oak:misconception-pupils-identify-correct-bar-model
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils identify the correct bar model as the model with the correct numbers with equal parts."""@en ;
  oakcurric:correction """Whilst this may represent the problem with regards to the numbers involved, encourage pupils to consider the size of each part in proportion to the whole as this may help when estimating answers to missing parts or wholes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688788Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-know-add-one
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to know what to add if just one of the factors changes."@en ;
  oakcurric:correction """Refer to 'lots of' when discussing calculations. For example, if pupils know that 3 × 84 = 252, then 3 × 85 must be 3 more. 3 × 84 is '84 lots of 3' and 3 × 85 is '85 lots of 3'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.688958Z"^^xsd:dateTime .

oak:misconception-pupils-recognise-patterns-odd-even
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might not recognise patterns of odd and even numbers across different times tables."""@en ;
  oakcurric:correction """Recap what an odd and even number is. Remind children even numbers result from multiplying by even factors and odd numbers result from odd factors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689010Z"^^xsd:dateTime .

oak:misconception-pupils-understanding-why-regroup-regrouped
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils not understanding why they may have to regroup or what the regrouped amount represents."""@en ;
  oakcurric:correction """Ask pupils 'What does this digit represent?' draw attention to place value and use continue to use language of unitisation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689014Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-group-items-form
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to group items to form unitised groups."@en ;
  oakcurric:correction """Ensure time is spent labelling items in relation to the whole then move to grouping these items. Use the sentence stem: There are ___ lots of ___ _________. This is equal to ___ _________."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689021Z"^^xsd:dateTime .

oak:misconception-pupils-likely-understand-different-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will most likely understand that different shapes can and most often do have different perimeters. They may not realise that the perimeters can potentially be the same."""@en ;
  oakcurric:correction """Allowing pupils to recreate perimeters using string or number rods and rearranging themselves to make a new shape is a powerful way of showing that different shapes can have equal perimeters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689025Z"^^xsd:dateTime .

oak:misconception-lack-understanding-key-terms-such
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of understanding of key terms such as: 'digit,' 'number.' Pupils may also forget how to identify an even number."""@en ;
  oakcurric:correction """Remind children that even numbers end in 0, 2, 4, 6 or 8. Explain clearly the difference between the key terms and encourage children to test the divisibility rule on both 3 digit and 4 digit numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689030Z"^^xsd:dateTime .

oak:misconception-difference-found-counting-back
  a oakcurric:Misconception ;
  oakcurric:statement "Difference can only be found by counting back."@en ;
  oakcurric:correction """Difference can be calculated by subtracting the subtrahend from the minuend or by counting between the subtrahend and the minuend."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689034Z"^^xsd:dateTime .

oak:misconception-pupils-well-recent-experience-perimeter
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may well have had recent experience of perimeter. Perimeter and area are easily confused."""@en ;
  oakcurric:correction """Remind pupils that running their finger around a 2D shape will give the perimeter. Running it inside the shape will give the area."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689039Z"^^xsd:dateTime .

oak:misconception-pupils-cannot-visualise-calculate-unknown
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils cannot visualise how to calculate the unknown dimensions on the compound shape."""@en ;
  oakcurric:correction """Spend time encouraging pupils to note down 'what they know' onto each shape. Allowing pupils to manipulate the shape with concrete apparatus and to run their finger along the edges of the shape will help visualise what is known and unknown."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689043Z"^^xsd:dateTime .

oak:misconception-pupils-need-help-using-number
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may need help using number pairs that total 10 to support their thinking in this lesson."""@en ;
  oakcurric:correction """Make explicit connections between number pairs that total ten and the learning (e.g. 10 - 3 = 7 so 100 - 7 = 93 and 100 - 30 = 70)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689116Z"^^xsd:dateTime .

oak:misconception-using-addition-subtraction-rather-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement """Using addition and subtraction rather than multiplication and division to solve problems."""@en ;
  oakcurric:correction """Continue to model the use of the language and notation of multiplication to calculate missing values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689123Z"^^xsd:dateTime .

oak:misconception-pupils-find-concept-different-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find the concept of different shapes (and sizes, for number of objects) a little confusing."""@en ;
  oakcurric:correction """Show pupils images where parts are different shapes (area fractions - parts of a whole shape) but can easily be seen to be the same size."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689127Z"^^xsd:dateTime .

oak:misconception-pupils-write-1-because-order
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils write 1£ because that is the order in which the expression is said."@en ;
  oakcurric:correction """Provide plenty of opportunities for pupils to see and use the correct notation as well as highlighting wrong examples."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689131Z"^^xsd:dateTime .

oak:misconception-pupils-forget-change-necessary-digits
  a oakcurric:Misconception ;
  oakcurric:statement """Sometimes pupils forget to change all of the necessary digits when rounding. For example, when rounding 4,698 to the nearest hundred, they might say 4,798"""@en ;
  oakcurric:correction """Make sure you spend time really focusing on the parts of the slide deck that show that when rounding to the nearest thousand, the answer must be a multiple of 1,000; the same principle applies when rounding to the nearest 100 or 10"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689136Z"^^xsd:dateTime .

oak:misconception-tricky-digit-many-pupils-consider
  a oakcurric:Misconception ;
  oakcurric:statement """A tricky digit for many pupils to consider is 0 because the rounded number is often the same as the original number. Pupils are often tempted to round to the multiple before the one they should."""@en ;
  oakcurric:correction """Spend some time establishing with pupils that occasionally when zeroes are involved, the number does not actually change when it is rounded. Number lines are a great visual support when rounding, including in this aspect."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689143Z"^^xsd:dateTime .

oak:misconception-pupils-try-subtract-numerators-denominators
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils try to subtract the numerators and the denominators from one another for each fraction."""@en ;
  oakcurric:correction """Represent each fraction using a model that draws out the equivalence of the fractions and the need for the same counting unit (denominator). Revisit previous analogies regarding sharing a common counting unit such as animals for cats and dogs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689147Z"^^xsd:dateTime .

oak:misconception-pupils-misunderstand-contexts-language-within
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may misunderstand the contexts or language within worded problems and therefore not understand the calculation required to solve."""@en ;
  oakcurric:correction """Model clearly how to identify key phrases and words which will identify the operation and equation required for word problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689274Z"^^xsd:dateTime .

oak:misconception-pupils-incorrectly-place-protractor-angle
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils incorrectly place the protractor on the angle and therefore cannot measure the angle. Pupils use the incorrect scale to read the angle."""@en ;
  oakcurric:correction """Stress the importance of using the middle spot on the protractor to line this up with the vertex of the angle as well as placing one of the lines on a zero line, ensuring the remaining line crosses the scale of the protractor."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689280Z"^^xsd:dateTime .

oak:misconception-pupils-think-one-strategy-finding
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that there is only one strategy for finding a solution and struggle to see that there is more than one way of partitioning a factor."""@en ;
  oakcurric:correction """Spend some time discussing how many combinations of partitioned factor you could use with the distributive law and evaluate each combination for efficiency. This would be a worthwhile guided group task."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689285Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-crossing-hundreds-boundary
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle crossing over the hundreds boundary (99 to 100, and back from 100 to 99)."""@en ;
  oakcurric:correction """It may help pupils to understand that 100 is ten lots of ten. This is the lesson focus and pupils will have lots of practise opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689289Z"^^xsd:dateTime .

oak:misconception-children-struggle-idea-two-fractions
  a oakcurric:Misconception ;
  oakcurric:statement """Children might struggle with the idea that two fractions, each with the same numerator and denominator but different numbers, can be equivalent. For example, four-fourths is equal to ten-tenths."""@en ;
  oakcurric:correction """Use a fraction wall to help with this. Compare the rows and establish that the whole is the same so they are equivalent. Ask the children to list as many as they can which will help build confidence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689296Z"^^xsd:dateTime .

oak:misconception-pupils-able-identify-whether-question
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not be able to identify whether a question is a 1-step or 2-step problem."""@en ;
  oakcurric:correction """Read and highlight key words which identify the operation. Highlight the numbers which will lead to the calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689301Z"^^xsd:dateTime .

oak:misconception-seeing-multiplication-division-inverse-operations
  a oakcurric:Misconception ;
  oakcurric:statement """Seeing multiplication and division as inverse operations e.g. dividing by 2 and multiplying by half."""@en ;
  oakcurric:correction """Encourage pupils to express the relationships between values using both multiplication and division."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689305Z"^^xsd:dateTime .

oak:misconception-pupils-misidentify-sum-addends-within
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may misidentify the sum and addends within column addition."@en ;
  oakcurric:correction """Emphasise the use of the 'equals' symbol within the column addition. This is where the sum appears. It is important that pupils understand commutativity and that the addends can appear in any order and will still result in the same sum."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689310Z"^^xsd:dateTime .

oak:misconception-pupils-initially-find-tricky-use
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may initially find it tricky to use known facts to add multiples of 100"@en ;
  oakcurric:correction """When explaining that we can use 3 ones + 6 ones = 9 ones to find 3 hundreds + 6 hundreds = ___, stress that the only thing that changes here is the noun."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689314Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-represent-problem-accurate
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to represent each problem with an accurate bar model."@en ;
  oakcurric:correction """You could continue to use number rods to represent each of the problems at first and then draw around these as a second scaffold, however, pupils do need to make the leap to representing as bar models for themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689318Z"^^xsd:dateTime .

oak:misconception-uncommon-pupils-mix-x-y
  a oakcurric:Misconception ;
  oakcurric:statement """It is not uncommon for pupils to mix up the x- and y-coordinates, meaning they end up plotting in the wrong position or giving the wrong coordinates."""@en ;
  oakcurric:correction """A stem sentence has been included in the lesson which should be regularly referred to. Rhymes can also be used as an aide memoir but this should be in tandem with deep conceptual understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689461Z"^^xsd:dateTime .

oak:misconception-pupils-consider-whole-number-represent
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils consider the whole number to represent an area as well as the fraction."@en ;
  oakcurric:correction """Take time to discuss what each of the numbers in the expressions represent and link this to the context it is set in."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689470Z"^^xsd:dateTime .

oak:misconception-pupils-make-efficient-use-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not make efficient use of multiplication facts when answering long division problems, especially 10 or 100 times the divisor."""@en ;
  oakcurric:correction """Encourage pupils to make estimations using multiplication facts. Once the multiplication facts are completed, they could be used to ask quick-fire questions (e.g. what is 20 × 18? 50 × 18? 200 × 18?)"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689475Z"^^xsd:dateTime .

oak:misconception-finding-missing-numbers-column-addition
  a oakcurric:Misconception ;
  oakcurric:statement """When finding missing numbers in column addition, pupils may find it difficult to identify whether they can add or subtract."""@en ;
  oakcurric:correction """Remind pupils that addends are parts and the sum is the whole. To find a missing part, we subtract the known part from the whole. To find a missing whole, we add the known parts together. Bar models or part-part-whole models can model this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689479Z"^^xsd:dateTime .

oak:misconception-children-include-original-part-constructing
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not include the original part when constructing a whole. E.g. if the given part is one of four equal parts of the whole, they may construct five parts together in total."""@en ;
  oakcurric:correction "How many parts does your whole have?"@en ;
  dcterms:modified "2026-02-12T08:59:18.689484Z"^^xsd:dateTime .

oak:misconception-tempting-say-need-add-12
  a oakcurric:Misconception ;
  oakcurric:statement """It is tempting to say that we need to add 12 hours to any pm times to turn them into 24 hour times. However, it is a slight over-generalisation and does not apply to 12:00 pm up to 12:59 pm."""@en ;
  oakcurric:correction """A teaching point is made of this and opportunities to apply the knowledge are given in the Practice tasks. It is worth really focusing on this as it comes up and paying attention to it while pupils are engaged with the Practice tasks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689505Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-second-cycle
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes in the second cycle, where they find the whole after a percentage change. They may think the part given (e.g. the new cost) is represented by the percentage change."""@en ;
  oakcurric:correction """Use bar models to help make it clear that the price given is the part remaining after the percentage change. If pupils are struggling with this, simplify the problem by giving numbers easy to calculate with (e.g. 30% off; new price £7)"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689509Z"^^xsd:dateTime .

oak:misconception-pupils-find-hard-understand-neednt
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might find it hard to understand that they needn't recalculate the parts after adjustment if the question wants the new whole."""@en ;
  oakcurric:correction """Show jottings and workings for two examples side-by-side. In the 1st example, calculate all the parts after adjustment as well as the new whole. In the 2nd, calculate only the new whole. Discuss with the pupils which is the most efficient and why."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689514Z"^^xsd:dateTime .

oak:misconception-pupils-insecure-their-times-tables
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils who are insecure with their times tables may not be efficient at finding factors and multiples."""@en ;
  oakcurric:correction """Provide children with a multiplication grid to support them in identifying factors and multiples. When finding a multiple, ask: 'Is it in the x times table?' When finding a factor, ask: 'Which times tables is this number in?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689587Z"^^xsd:dateTime .

oak:misconception-largest-angle-created-360-degree
  a oakcurric:Misconception ;
  oakcurric:statement "The largest angle that can be created is a 360 degree angle or one full turn."@en ;
  oakcurric:correction """Explore examples in everyday life where rotations are greater than one full turn. Discuss how multiples of 180 degrees or 360 degrees are often used to describe movements in sports and other contexts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689640Z"^^xsd:dateTime .

oak:misconception-children-fully-convert-leave-fractional
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not fully convert and may leave the fractional part of the mixed number as an improper fraction e.g. 13/4 = 2 and 5/4"""@en ;
  oakcurric:correction """Support via questioning: How many quarters make one whole? How many full groups of four quarters can you make? Emphasise the fractional part needs to have a numerator smaller than the denominator and take time to discuss why."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689644Z"^^xsd:dateTime .

oak:misconception-pupils-correctly-identify-type-polygon
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not correctly identify the type of polygon (e.g., rectangle, square, parallelogram), leading to errors in determining the missing coordinate."""@en ;
  oakcurric:correction """Encourage pupils to first identify the polygon by examining the given vertices. Review the properties of common polygons (e.g., opposite sides of a rectangle are equal and parallel). Use visual aids or models to reinforce these properties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689649Z"^^xsd:dateTime .

oak:misconception-pupils-understand-tens-counter-value
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand that a tens counter has a value of ten. For example, they may think that 14 tens and 11 tens make 25 altogether, forgetting to convert 25 tens into 250."""@en ;
  oakcurric:correction """Encourage counting in tens using counters to begin with. Move onto modelling questions using base ten so the children can count the tens blocks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689653Z"^^xsd:dateTime .

oak:misconception-pupils-see-words-like-altogether
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can sometimes see words like 'altogether' in a problem and assume it is an addition problem."""@en ;
  oakcurric:correction """Provide lots of examples of contextualised problems and focus on mathematical language, including where it might be misleading."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689660Z"^^xsd:dateTime .

oak:misconception-pupils-identify-factors-2-digit
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can identify factors of a 2-digit number but do not consider efficiency when multiplying."""@en ;
  oakcurric:correction """Draw attention to factor pairs and those which result in easier calculations e.g. pupils often find multiplying by 4 or 5 easier than 7, or can apply doubling when multiplying by 2"""@en ;
  dcterms:modified "2026-02-12T08:59:18.689666Z"^^xsd:dateTime .

oak:misconception-children-struggle-understand-parts-change
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to understand that parts change size when the whole changes. A relative size of a part that stays the same whilst the whole changes is a tricky concept."""@en ;
  oakcurric:correction "What do you notice? What is the same? What is different?"@en ;
  dcterms:modified "2026-02-12T08:59:18.689671Z"^^xsd:dateTime .

oak:misconception-pupils-think-subtrahend-increases-decreases
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might think that if the subtrahend increases or decreases then so too does the difference. They might find it initially difficult to understand the idea of the inverse in the context."""@en ;
  oakcurric:correction """Give lots of practical examples of this such as emptying out bottles or eating sweets demonstrating an increase in the subtrahend and its effect on the difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689676Z"^^xsd:dateTime .

oak:misconception-children-add-incorrect-parts-mixed
  a oakcurric:Misconception ;
  oakcurric:statement """Children may add the incorrect parts of the mixed numbers and/or proper fractions together."""@en ;
  oakcurric:correction """Guide pupils through with questioning. What is the whole number part? What is the fractional part? First we add the whole number parts then we add the fractional parts using unitising."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689795Z"^^xsd:dateTime .

oak:misconception-children-think-300-cm-bigger
  a oakcurric:Misconception ;
  oakcurric:statement """Some children may think that 300 cm is bigger than 3 m because 300 is a bigger number than 3."""@en ;
  oakcurric:correction """1 m is equivalent to 100 cm. So 3 m is equivalent to 300 cm. 3 m and 300 cm are equal in length or height."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689800Z"^^xsd:dateTime .

oak:misconception-child-give-incorrect-value-digit
  a oakcurric:Misconception ;
  oakcurric:statement """A child may give the incorrect value for a digit or struggle to see how to partition larger numbers in a non-standard way."""@en ;
  oakcurric:correction """Use a place value chart or counters to prove the value of the digit and use a Gattegno chart to support partitioning."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689804Z"^^xsd:dateTime .

oak:misconception-identifying-whether-scaling-part-whole
  a oakcurric:Misconception ;
  oakcurric:statement """Not identifying whether they are scaling up a part or the whole amount and how this is represented."""@en ;
  oakcurric:correction """Ask if it is a part or the whole that you are being asked to work out and articulating where this is in the representation or ratio table."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689809Z"^^xsd:dateTime .

oak:misconception-finding-price-reduced-25-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """When finding a price has reduced by 25%, pupils may give the answer as 25% of the number, rather than seeing it as 75% of the whole."""@en ;
  oakcurric:correction """Emphasise that '25% off' means that the price has been reduced by 25%. The whole, subtract 25%, is equal to 75% of the whole. Bar models are useful for showing this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689813Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-find-parts-whole
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to find the parts and the whole in column addition."@en ;
  oakcurric:correction """Emphasise the sum as being within the 'equals' sign in column addition. Take time to write equations, bar models and column addition and make connections between these."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689915Z"^^xsd:dateTime .

oak:misconception-children-count-marks-rather-equal
  a oakcurric:Misconception ;
  oakcurric:statement """Children may count the marks rather than the equal parts between integers thereby determining the unit that we are working with incorrectly."""@en ;
  oakcurric:correction """Show that we need to count the equal parts in between the given integers, not the marks. You could model this with the same line with increasing parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689920Z"^^xsd:dateTime .

oak:misconception-children-continue-share-one-one
  a oakcurric:Misconception ;
  oakcurric:statement "Some children may continue to share one by one when dividing."@en ;
  oakcurric:correction """Encourage children to skip count in the divisor and remind children that it is an efficient way of dividing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689924Z"^^xsd:dateTime .

oak:misconception-length-height-object-numerical-value
  a oakcurric:Misconception ;
  oakcurric:statement """The length or height of an object is the numerical value at the end of the ruler (if not at zero)."""@en ;
  oakcurric:correction """If an object is not measured from zero, its length is the difference between the numerical value at the start and end of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689931Z"^^xsd:dateTime .

oak:misconception-pupils-incorrectly-record-money-example
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils incorrectly record money, for example omitting the decimal point and using the pound notation"""@en ;
  oakcurric:correction """Draw attention to both correct and incorrect notation and ensure they have opportunities to see, say and record in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689935Z"^^xsd:dateTime .

oak:misconception-misalignment-digits-setting-short-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement "Misalignment of digits when setting out short multiplication."@en ;
  oakcurric:correction """Clear teacher modelling, ask pupils 'what does this digit represent?' Return to expanded layout briefly, before re-doing the problem."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689944Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-column-subtraction-column
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may confuse column subtraction and column addition, and forget where the whole appears in both."""@en ;
  oakcurric:correction """Emphasise starting with the whole. The minuend appears first in column subtraction. One part (the subtrahend) is subtracted and the difference appears beneath this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689948Z"^^xsd:dateTime .

oak:misconception-children-miscount-number-squares-mirror
  a oakcurric:Misconception ;
  oakcurric:statement """Children may miscount the number of squares from the mirror line when plotting each vertex to reflect the shape."""@en ;
  oakcurric:correction """Encourage children to work systematically by only marking one vertex at a time to reduce the chance of errors. Also encourage use of mirrors to check."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689953Z"^^xsd:dateTime .

oak:misconception-pupils-attribute-one-hundredth-area
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may only attribute one hundredth to an area model being broken into one hundred equal parts."""@en ;
  oakcurric:correction "Ensure pupils see one hundredth in both linear and cardinal examples too."@en ;
  dcterms:modified "2026-02-12T08:59:18.689957Z"^^xsd:dateTime .

oak:misconception-pupils-think-one-tenth-consists
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils think one tenth consists of one shaded part and ten un-shaded parts."@en ;
  oakcurric:correction """Encourage children to use the stem sentence to identify the whole and how many parts make it up each time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.689962Z"^^xsd:dateTime .

oak:misconception-pupils-think-square-number-simply
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might think that a square number is simply any number or a number multiplied by 2"""@en ;
  oakcurric:correction """Remind children that a square number is the product of a number multiplied by itself (e.g., 4 × 4 = 16). Take time to use square arrays to demonstrate this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690143Z"^^xsd:dateTime .

oak:misconception-children-add-whole-number-part
  a oakcurric:Misconception ;
  oakcurric:statement """Children may just add the whole number part of the mixed number to the numerator or may forget to add the fractional part of the mixed number."""@en ;
  oakcurric:correction """Encourage children to check their work using the stem sentence or generalisation developed in the lesson, 'first we multiply the whole number by the denominator, then we add the numerator'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690148Z"^^xsd:dateTime .

oak:misconception-100-cm-bigger-1-m
  a oakcurric:Misconception ;
  oakcurric:statement "100 cm is bigger than 1 m."@en ;
  oakcurric:correction """1 m is equal in length or height to 100 cm.  100 cm make up 1 m.  They are the same length or height."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690153Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-understand-represent-number
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to understand how to represent the number rods to show the difference when trying to find the missing rod."""@en ;
  oakcurric:correction """Ensure pupils spend time representing each question with an equation then match this with the number rods. This may help them to visualise the missing part as well."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690161Z"^^xsd:dateTime .

oak:misconception-pupils-find-difficult-understand-equations
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it more difficult to understand equations that start with the whole (e.g. 20 = 50 - 30)"""@en ;
  oakcurric:correction """Emphasise the need for balance in equations. To be equal, both sides must have the same value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690166Z"^^xsd:dateTime .

oak:misconception-number-one-itself-factor-number
  a oakcurric:Misconception ;
  oakcurric:statement "Every number has one and itself as a factor, so every number is a prime number."@en ;
  oakcurric:correction """Ensure pupils explore the different arrangements that numbers can make with tiles in arrays. Point out that the numbers which cannot be arranged in any way except for one row or column are prime numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690170Z"^^xsd:dateTime .

oak:misconception-pupils-select-efficient-ways-scaling
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not select efficient ways of scaling numbers to calculate the product."""@en ;
  oakcurric:correction """Discuss possible solutions, encouraging pupils to think about whether they can use known facts (e.g. times tables, multiples of 10) to calculate products after scaling."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690175Z"^^xsd:dateTime .

oak:misconception-children-misidentify-parts-wholes-problem
  a oakcurric:Misconception ;
  oakcurric:statement "Children may misidentify the parts or wholes in a problem."@en ;
  oakcurric:correction """Children should be encouraged to visualise the problem to help them identify the parts and whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690233Z"^^xsd:dateTime .

oak:misconception-pupils-understand-key-term-adjacent
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand the key term 'adjacent,' and have difficult understanding the word problems."""@en ;
  oakcurric:correction """Model correct usage in a range of contexts including labelling abstract equations and using the terms to identify the known elements in worded problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690248Z"^^xsd:dateTime .

oak:misconception-pupils-understand-angles-static-created
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils understand angles as static, created where two immovable lines meet. Pupils also believe angles are only created by two lines that are completely straight."""@en ;
  oakcurric:correction """Provide opportunities for pupils to use angle strips in order to create their own angles, manipulating either arm of the angle strip to create the angle. Ensure pupils are provided with examples where angles are formed by partially straight lines."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690253Z"^^xsd:dateTime .

oak:misconception-pupils-forget-use-zero-show
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may forget to use zero to show that there are no 10s or 1s (e.g. in 60), or may use zero to show that there are no 100s when it is not needed (e.g. they may write 068)."""@en ;
  oakcurric:correction """Explain to pupils that zero is needed to show that there are no 10s or 1s in a 3-digit number although it isn't needed to show that there are no 100s. We don't write 68 as 068, so we do not do this with column addition either."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690260Z"^^xsd:dateTime .

oak:misconception-children-believe-greater-denominator-bigger
  a oakcurric:Misconception ;
  oakcurric:statement "Children often believe that the greater the denominator the bigger the fraction."@en ;
  oakcurric:correction """Reinforce this using the fraction wall. Constantly refer back to it and ensure that the children become experts at using it as a tool for comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690264Z"^^xsd:dateTime .

oak:misconception-pupils-say-previous-multiple-one
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils say the previous multiple of one as a whole before e.g. previous multiple of 3.4 as 2 or 2.4"""@en ;
  oakcurric:correction "Place the number on a number line and clarify the whole numbers it sits between."@en ;
  dcterms:modified "2026-02-12T08:59:18.690269Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-identify-expressions-relate
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to identify how each of the expressions relate to each other."@en ;
  oakcurric:correction """Ensure connections are made between the bar models, your language and the expressions. Give particular attention to how the fraction links to how the bar model can be drawn, particularly when dividing the bar model into ___ parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690273Z"^^xsd:dateTime .

oak:misconception-pupils-look-calculate-expression-straight
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may look to calculate each expression straight away."@en ;
  oakcurric:correction """Ensure pupils are encouraged to estimate expressions, showing how this can be more efficient particularly when looking to compare expressions. The product is not always needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690278Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-lay-column
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it challenging to lay out column addition where they are adding a 3-digit number and a 2-digit number."""@en ;
  oakcurric:correction """Emphasise the place value. Continually ask the pupils, 'Where is the tens column? Where is the hundreds column? How many tens does this number have? How many hundreds does this number have?' so that they begin asking these questions themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690287Z"^^xsd:dateTime .

oak:misconception-recording-ten-tenths-0-10
  a oakcurric:Misconception ;
  oakcurric:statement "Recording ten tenths as 0.10 rather than 1 or 1.0"@en ;
  oakcurric:correction """Be sure to address this regularly with pupils whilst counting. Demonstrate the regrouping using place value counters to help."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690291Z"^^xsd:dateTime .

oak:misconception-pupils-immediately-calculate-expressions-instead
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils immediately calculate expressions instead of considering the relationship between expressions."""@en ;
  oakcurric:correction """Take time to model interrogation of values within expressions, identifying relationships between them. Encourage this reasoning and show how it can be more efficient than calculation especially in situations with larger values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690418Z"^^xsd:dateTime .

oak:misconception-pupils-see-link-partitioning-100
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not see the link between partitioning 100 into 2, 4, 5 and 10 equal parts and partitioning 1,000 into those equal parts."""@en ;
  oakcurric:correction """You may wish to revisit partitioning 100 into equal parts, using representations familiar to pupils, to help them to understand that their knowledge of partitioning 100 can be applied to partitioning 1,000"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690424Z"^^xsd:dateTime .

oak:misconception-reading-bar-graphs-unmarked-intervals
  a oakcurric:Misconception ;
  oakcurric:statement """When reading bar graphs with unmarked intervals, some pupils might assume each interval equals 1. In the case of the graphs presented in this lesson, the intervals go up in 100s, 200s, 250s and 500s."""@en ;
  oakcurric:correction """Encourage children to apply their knowledge of converting a unit into 1,000 (such as 1 litre being converted into 1,000 ml) and then exploring its composition in 2, 4, 5 and 10 equal parts. Check the unmarked intervals by counting in those steps."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690429Z"^^xsd:dateTime .

oak:misconception-pupils-forget-add-regrouped-hundred
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may forget to add the 'regrouped' hundred when calculating the total for the hundreds column."""@en ;
  oakcurric:correction """Model regrouping and finding column totals clearly, reminding pupils to add together all of the numbers in the column to get the total."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690436Z"^^xsd:dateTime .

oak:misconception-one-way-split-compound-shape
  a oakcurric:Misconception ;
  oakcurric:statement "There is only one way to split a compound shape to calculate the area."@en ;
  oakcurric:correction """Make time in the lesson to model and discuss different ways of calculating the area of compound shapes. Include strategies that move parts of the shape to simplify the shape and the calculations needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690441Z"^^xsd:dateTime .

oak:misconception-misreading-scales-counting-marks-rather
  a oakcurric:Misconception ;
  oakcurric:statement """Misreading of scales by counting marks rather than equal parts in between the marked intervals."""@en ;
  oakcurric:correction """Remember to look at the number of equal parts in between the marked intervals then use your knowledge of the composition of 100."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690450Z"^^xsd:dateTime .

oak:misconception-number-higher-its-value-greater
  a oakcurric:Misconception ;
  oakcurric:statement """When a number is higher, its value is greater. Pupils may struggle to understand that as the denominator gets larger / greater, the size of the parts get smaller."""@en ;
  oakcurric:correction """Show pupils lots of images, comparing fractions with the same numerator (e.g. one-fifth and one-third and then two-fifths and two-thirds). Highlight that even though the number of parts we have is the same, the size of those parts is different."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690454Z"^^xsd:dateTime .

oak:misconception-pupils-try-compare-fractions-wholes
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may try to compare fractions where the wholes are not the same."@en ;
  oakcurric:correction """It's important that pupils understand that for comparison of fractions the wholes must be the same. This lesson uses one example of comparing distances in miles versus distance in kilometres as well as comparing pizzas of different shape and size."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690461Z"^^xsd:dateTime .

oak:misconception-pupils-regroup-ones-tens-column
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not regroup ones into the tens column."@en ;
  oakcurric:correction """Model regrouping from the ones to the tens. Encourage pupils to consider the size of the numbers, thinking about an approximate sum of the two addends. Is their answer reasonable?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690466Z"^^xsd:dateTime .

oak:misconception-pupils-understand-line-graphs-used
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand that line graphs are only used for continuous data, where the points between those that are plotted have meaning."""@en ;
  oakcurric:correction """Show children examples of graphs where there is no meaning between divisions on the x-axis (e.g. heights of children). Here, the points cannot be joined to make a line graph."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690472Z"^^xsd:dateTime .

oak:misconception-pupils-make-errors-interpreting-information
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make errors interpreting information from pie charts, especially with making links between angles, fractions, percentages and working out an answer to a question."""@en ;
  oakcurric:correction """Display 'benchmarks' in the classroom, showing a pie chart with labelled sectors (e.g. showing that 10% is equal to one tenth or 36° of the chart; 25% is equal to one quarter or 90°)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690477Z"^^xsd:dateTime .

oak:misconception-first-learning-seconds-pupils-come
  a oakcurric:Misconception ;
  oakcurric:statement """When first learning about seconds, pupils come to realise they are very quick. They count seconds at the same speed in which they count other numbers - usually too quickly."""@en ;
  oakcurric:correction """The classic way to slow down counting speed so that it more closely matches the pace of seconds is to use 'one Mississippi, two Mississippi' etc. For most pupils that is an obscure reference point - counting elephants is suggested as an alternative."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690482Z"^^xsd:dateTime .

oak:misconception-one-tenth-times-size-confusing
  a oakcurric:Misconception ;
  oakcurric:statement """One-tenth times the size may be a confusing phrase to use because pupils are used to seeing an increase when using '___ times as many'."""@en ;
  oakcurric:correction """Ensure that children understand that a one is one-tenth times the size of a ten. Base 10 is an excellent resource for this. Then gradually increase the ones and the corresponding tens."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690486Z"^^xsd:dateTime .

oak:misconception-many-pupils-try-adjust-difference
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils will try to adjust the difference in the same way that the subtrahend has been adjusted without considering the use of the inverse."""@en ;
  oakcurric:correction "Start simply with double-sided counters to show the concept practically."@en ;
  dcterms:modified "2026-02-12T08:59:18.690498Z"^^xsd:dateTime .

oak:misconception-proportionality-bar-models-something-children
  a oakcurric:Misconception ;
  oakcurric:statement """The proportionality of bar models is something that children sometimes find tricky and causes them concern."""@en ;
  oakcurric:correction """Remind them that accuracy is not completely necessary so long as they have roughly sized the parts (subtrahend and difference in these contexts). Alternatively, give them number rods to arrange as bar models and then draw around."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690502Z"^^xsd:dateTime .

oak:misconception-pupils-mistake-previous-multiple-one
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may mistake the previous multiple of one for example: previous multiple of 6.38 being 5."""@en ;
  oakcurric:correction """Ensure pupils are given plenty of opportunities to place numbers on number lines, identifying the previous and next multiples of one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690507Z"^^xsd:dateTime .

oak:misconception-pupils-less-familiar-names-properties
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may be less familiar with the names and properties of polygons and this may be a distraction from the focus of the learning."""@en ;
  oakcurric:correction """Consider providing scaffolds for some pupils or pre-learning to revise shape names and properties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690552Z"^^xsd:dateTime .

oak:misconception-children-need-understand-fractions-fractions
  a oakcurric:Misconception ;
  oakcurric:statement """Children need to understand that fractions can also be fractions of 1 and have an exact position on a number line. There may be confusion over labelling an exact point rather than a part of the line."""@en ;
  oakcurric:correction """Use the language of labelling a point on the line and avoid talking about 'half of the line' which is the language of parts of a whole. This helps children to see that fractions are numbers in their own right with a unique position on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690557Z"^^xsd:dateTime .

oak:misconception-pupils-write-equations-involving-addition
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils write equations involving both addition and multiplication incorrectly."@en ;
  oakcurric:correction """Encourage pupils to match their equation to an image provided and be clear about where the numbers in their equation come from."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690561Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-keep-track
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils find it challenging to keep track of multiple regroupings in the long multiplication layout and therefore forget to add these to partial products."""@en ;
  oakcurric:correction """Estimation can support checking of magnitude. Discuss and agree on a position for regrouped values and continuously model noting and using these."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690566Z"^^xsd:dateTime .

oak:misconception-children-subtract-incorrect-parts-mixed
  a oakcurric:Misconception ;
  oakcurric:statement """Children may subtract the incorrect parts of the mixed numbers and/or proper fractions."""@en ;
  oakcurric:correction """What is the number that we are subtracting? If this number is a mixed number, partition it into its whole number part and fractional part.Use unitising to support subtraction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690609Z"^^xsd:dateTime .

oak:misconception-pupils-regroup-incorrectly-forget-write
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may regroup incorrectly, forget to write the regrouped ten or forget to add any regrouped tens when calculating the total for the tens column."""@en ;
  oakcurric:correction """Emphasise that the regrouped number is a ten and that it needs to be added to the tens total. If necessary, revisit the use of base ten blocks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690618Z"^^xsd:dateTime .

oak:misconception-pupils-start-counting-origin-0
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might not start counting from the origin (0,0) but from another point on the grid, leading to incorrect placement of the point."""@en ;
  oakcurric:correction """Emphasise the importance of always starting from the origin when plotting or describing coordinates. Have students physically point to or touch the origin before plotting any point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690622Z"^^xsd:dateTime .

oak:misconception-pupils-cannot-identify-lengths-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils cannot identify the lengths of the shapes that make up the length provided in each problem."""@en ;
  oakcurric:correction """Encourage pupils to draw a line over the sides of the shapes that represent the length within the problem. This can help pupils to see how many 'lots of' the smaller shapes length are used and how many 'lots of' the larger shapes lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690627Z"^^xsd:dateTime .

oak:misconception-children-translate-copy-shape-rather
  a oakcurric:Misconception ;
  oakcurric:statement """Children may translate or copy a shape rather than 'flipping it' over the line of symmetry."""@en ;
  oakcurric:correction """Use mirrors to support children's understanding of how a shape flips when it is reflected. Explore this idea with a wide variety of shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690634Z"^^xsd:dateTime .

oak:misconception-children-incorrectly-write-numbers-using
  a oakcurric:Misconception ;
  oakcurric:statement "Children may incorrectly write numbers by not using a placeholder zero."@en ;
  oakcurric:correction """Use place value counters or a Gattegno chart to represent the number. Are there digits for each place? If not, we need to use a placeholder zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690638Z"^^xsd:dateTime .

oak:misconception-pupils-see-adjacent-multiples-seven
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not see that adjacent multiples of seven differ by exactly seven."@en ;
  oakcurric:correction """Show that each step in the 7 times table is adding seven to the previous multiple, reinforcing the concept with number lines or skip counting, use visual aids such as a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690766Z"^^xsd:dateTime .

oak:misconception-converting-units-interpreting-word-problem
  a oakcurric:Misconception ;
  oakcurric:statement """Converting between units; interpreting a word problem; confusing parts and wholes."""@en ;
  oakcurric:correction """When representing as a bar model, visualise the problem to help determine what the parts are and what the whole is."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690770Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-create-axis-their
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to create axis for their graphs that have equal intervals."@en ;
  oakcurric:correction """You could spend some time with pupils simply practising drawing each axis. Ensure pupils do not draw a line and then try to divide into equal intervals. Instead encourage marking the intervals as the line is drawn."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690776Z"^^xsd:dateTime .

oak:misconception-pupils-think-fractions-higher-value
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that fractions with a higher value numerator are larger in size."""@en ;
  oakcurric:correction """Show pupils images where fractions with the same numerators and denominators are equal in size (e.g. nine-ninths is equal to three-thirds)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690781Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-counting-particularly
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes with counting, particularly when crossing a 100s boundary."""@en ;
  oakcurric:correction """Encourage pupils to use the pattern to help them count accurately, using this to predict the next number in the count."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690786Z"^^xsd:dateTime .

oak:misconception-pupils-decompose-wrong-factor-therefore
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils decompose the wrong factor therefore find it difficult to find a pair of factors that are equal to 100"""@en ;
  oakcurric:correction """Scaffold pupil's thinking when they begin to tackle a 2 digit by 2 digit calculation. Encourage them to ask questions of the numbers, for example: 'Is one of the numbers I have to start with a factor of 100?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690792Z"^^xsd:dateTime .

oak:misconception-equivalent-fractions-same-value-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """That equivalent fractions do not have the same value. Pupils can create them but do not always understand that they are equal in value."""@en ;
  oakcurric:correction """Explore representations which show the same whole divided in different ways to show the same proportion of the whole. Represent equivalent fractions at the same point on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690886Z"^^xsd:dateTime .

oak:misconception-pupils-mistakenly-alter-shape-size
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might mistakenly alter the shape or size of the polygon during translation, thinking the process involves resizing or reshaping."""@en ;
  oakcurric:correction """Emphasise that translation is a "sliding" motion that moves the shape without changing its size or orientation. Demonstrate this with cut-out shapes that can be physically moved on a grid, showing that the shape remains identical after translation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690895Z"^^xsd:dateTime .

oak:misconception-children-understand-one-exchanged-whole
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not understand that a one can be exchanged from a whole and the fraction rewritten. E.g. four can be rewritten as three and five-fifths to add subtraction of an amount of fifths."""@en ;
  oakcurric:correction """Use of rods or drawings will support children to understand this exchange. Four is the same as three and one; one is the same as five fifths so four is the same and three and five fifths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690899Z"^^xsd:dateTime .

oak:misconception-children-reverse-minuend-subtrahend-because
  a oakcurric:Misconception ;
  oakcurric:statement """Children will often reverse the minuend and subtrahend because they don't always appear in the order that they would in an expression."""@en ;
  oakcurric:correction """Ensure that the children spend time understanding the context, either through discussion of the problem or through visual representations such as bar models. It's also worth spending time on vocabulary by playing fun word games or charades."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690904Z"^^xsd:dateTime .

oak:misconception-realising-change-number-values-set
  a oakcurric:Misconception ;
  oakcurric:statement """Not realising that if you change the number of values in the set, you must divide the total by the new number of values and that this affects the value of the mean average."""@en ;
  oakcurric:correction """Use the definition of the mean average to check that the total of the set of data is correctly calculated and that the number of values in the set of data is correctly identified in all examples and contexts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690908Z"^^xsd:dateTime .

oak:misconception-comparing-masses-scales-different-intervals
  a oakcurric:Misconception ;
  oakcurric:statement """When comparing masses - if the scales have different intervals or the zero is in different places."""@en ;
  oakcurric:correction """Remind children that the scale is a number line and we always read number lines from zero; the further the arrow travels, the greater mass."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690913Z"^^xsd:dateTime .

oak:misconception-pupils-attempt-estimate-using-approximations
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils attempt to estimate using approximations that do not allow for quick mental calculation."""@en ;
  oakcurric:correction """Spend time estimating yourself and modelling the simplicity of it. Use estimations regularly to check the magnitude of an answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690917Z"^^xsd:dateTime .

oak:misconception-pupils-lack-fluency-pairs-10
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils lack fluency in pairs for 10 and so struggle to connect this to 2-digit numbers."""@en ;
  oakcurric:correction """Promote fluency through games and chants and consider providing a scaffold of pairs for 10 which will help pupils develop automaticity"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690922Z"^^xsd:dateTime .

oak:misconception-pupils-try-compose-numbers-additively
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils try to compose numbers additively using prime factors."@en ;
  oakcurric:correction """Ensure pupils are confident with finding the factors of a number first before extending to finding prime factors of known factors. Give time to building numbers with prime factors in arrays to help emphasise their multiplicative composition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690926Z"^^xsd:dateTime .

oak:misconception-pupils-instantly-recognise-percentage-part
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not always instantly recognise that a percentage part is a factor of 100"""@en ;
  oakcurric:correction """Discuss factors of 100 with the pupils, for example, as factor pairs. Allow them to keep these displayed to refer to throughout the lesson if needed to help make this connection."""@en ;
  dcterms:modified "2026-02-12T08:59:18.690933Z"^^xsd:dateTime .

oak:misconception-children-inclined-look-previous-equations
  a oakcurric:Misconception ;
  oakcurric:statement """The children might be inclined not to look at previous equations to help them. They might not make use of the adjustments to the whole."""@en ;
  oakcurric:correction """Practise some really simple versions. Start with 1 + 2 = 3 and then ask them to adjust 3 by a single-digit number. Write this underneath and then ask them which part has changed and by how much? How do they know?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.690940Z"^^xsd:dateTime .

oak:misconception-thinking-fraction-decimal-use-same
  a oakcurric:Misconception ;
  oakcurric:statement """Thinking that the fraction and decimal use the same digits so that one fifth is 1.5 as a decimal. Some may not see that equivalent fractions and decimals represent the same value."""@en ;
  oakcurric:correction """Use representations that allow pupils to see fractions as parts of 10 and 100 to secure the understanding of their equivalent decimal values. Revisit equivalent fractions to model how to convert fractions to their decimal equivalents and vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691040Z"^^xsd:dateTime .

oak:misconception-pupils-miscount-number-squares-moved
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might miscount the number of squares moved horizontally or vertically, resulting in an inaccurate translation."""@en ;
  oakcurric:correction """Encourage pupils to count the number of squares carefully from the original position, possibly using a ruler or finger to help guide their counting. Practice with simpler shapes before moving to more complex polygons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691044Z"^^xsd:dateTime .

oak:misconception-pupils-think-translating-shape-changes
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might think that translating a shape changes its size, shape, or orientation, rather than just its position."""@en ;
  oakcurric:correction """Clarify that translation only changes the position of the shape on the grid; the shape itself remains identical in size, shape, and orientation. Use visual examples to compare the shape before and after translation to reinforce this concept."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691051Z"^^xsd:dateTime .

oak:misconception-pupils-change-division-symbol-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils change the division symbol to a multiplication symbol and then multiply the fraction by a whole number."""@en ;
  oakcurric:correction """The act of dividing the fraction part is highlighted within the representations provided. Ensure pupils are given time to explore how the area model represents the division and encourage pupils to create their own examples."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691055Z"^^xsd:dateTime .

oak:misconception-pupils-able-identify-right-angles
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils are not able to identify right angles and therefore struggle to identify pairs of perpendicular sides."""@en ;
  oakcurric:correction """Provide children with a right angle checker. Take time to model its use, focusing on aligning one edge of the checker with a side of the angle they want to check."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691144Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-partition-10s-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to partition 10s numbers to help them bridge a 100s boundary."""@en ;
  oakcurric:correction """Encourage pupils to calculate the number of tens needed to add or subtract to the 100s number, then add or subtract the remainder."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691149Z"^^xsd:dateTime .

oak:misconception-children-struggle-use-unitising-make
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to use unitising to make connections between the composition of 1,000 or 10,000 and one million or ten million."""@en ;
  oakcurric:correction """Use the suggested stem sentences e.g. '250 is one quarter of 1,000, so one-quarter of 1,000 thousands must be 250 thousand' to support developing the unitising concept."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691153Z"^^xsd:dateTime .

oak:misconception-lack-fluency-2s-4s-times
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in 2s and 4s times tables and not understanding the divisibility rules or the problems."""@en ;
  oakcurric:correction """To clearly model highlighting key words of worded problems to understand the problem and the operation required for the calculation. Continue to use language stems such as 'If I know...' 'Then I know...,' to support mathematical thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691252Z"^^xsd:dateTime .

oak:misconception-children-say-times-longer-imprecise
  a oakcurric:Misconception ;
  oakcurric:statement "Children may say, 'Times longer' but this is imprecise."@en ;
  oakcurric:correction "We say 'Times the length' because this is more precise."@en ;
  dcterms:modified "2026-02-12T08:59:18.691256Z"^^xsd:dateTime .

oak:misconception-children-choose-efficient-strategy-adding
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not always choose an efficient strategy when adding or subtracting mixed numbers. This may result in calculation errors being made."""@en ;
  oakcurric:correction """Look at the numbers in the calculation. What do you notice? Which strategy would be most efficient to use with these numbers? Check your answer using a different strategy. If you get the same answer, you are likely to be correct."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691263Z"^^xsd:dateTime .

oak:misconception-pupils-need-confident-addition-subtraction
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils need to be confident with the addition and subtraction of two digit numbers to other two digit numbers to be able to work out intervals or calculate using the intervals."""@en ;
  oakcurric:correction """The idea of using tracing paper to create 15 minute, 30 minute and 45 minute time intervals is suggested and modelled. This can support the arithmetic in the lesson along with counting in 5s around the clock face."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691272Z"^^xsd:dateTime .

oak:misconception-aware-pupils-describing-scaling-using
  a oakcurric:Misconception ;
  oakcurric:statement """Be aware of pupils describing scaling using division as 'making three times smaller'. This language can cause misconceptions around the nature of division and should be avoided."""@en ;
  oakcurric:correction """Encourage pupils to describe relationships using division by a whole number (divided by 3) or through the use of fractional language (one-third the size)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691311Z"^^xsd:dateTime .

oak:misconception-pupils-compare-expressions-ever-calculating
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils compare expressions by only ever calculating the value of each expression before comparing."""@en ;
  oakcurric:correction """Encourage pupils to consider the magnitude of the fractions they are adding or subtracting. Comparing fractions to one-half is an effective way to help identify their magnitude and whether then expression would be larger or smaller."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691370Z"^^xsd:dateTime .

oak:misconception-pupils-see-two-rectilinear-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils may not see that two rectilinear shapes can look very different but have the same area."""@en ;
  oakcurric:correction """Cut out a large rectangle. Cut it into two rectangles. Ask pupils to move one of the rectangles and reposition it. Has the area changed?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691374Z"^^xsd:dateTime .

oak:misconception-children-overgeneralise-appearance-polygons-such
  a oakcurric:Misconception ;
  oakcurric:statement """Children overgeneralise about the appearance of polygons such as rectangles and pentagons and do not recognise them when they are less typical."""@en ;
  oakcurric:correction """Ensure modelling and examples show a range of shapes. For example, show a range of rectangles and focus on the key properties of parallel and perpendicular sides to identify that they are all rectangles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691379Z"^^xsd:dateTime .

oak:misconception-pupils-make-errors-regrouping-ones
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make errors with regrouping in the ones and tens, particularly where there is regrouping in both."""@en ;
  oakcurric:correction """Model examples of regrouping with the pupils, including questions where regrouping in the ones causes regrouping in the tens. If necessary, use Base 10 blocks to help with the modelling."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691383Z"^^xsd:dateTime .

oak:misconception-children-rely-one-strategy-adding
  a oakcurric:Misconception ;
  oakcurric:statement """Children rely on one strategy for adding to find a sum and do not consider the values."""@en ;
  oakcurric:correction """Discuss when it is most efficient to use doubles, near doubles, number pairs to 10. Model efficient approaches."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691390Z"^^xsd:dateTime .

oak:misconception-children-find-difficult-create-triangles
  a oakcurric:Misconception ;
  oakcurric:statement "Children might find it difficult to create triangles with equal angles."@en ;
  oakcurric:correction """Allow time to play and explore constructing triangles using items such as lolly sticks and matchsticks. Develop children's understanding of angles in a triangle using angle strips to check whether the angles are equal or not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691394Z"^^xsd:dateTime .

oak:misconception-pupils-find-tricky-using-scales
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it tricky using scales to read bar charts, especially when the scale uses multiples of five."""@en ;
  oakcurric:correction """Encourage pupils to think about where intermediate numbers are on bar charts (e.g. numbers from 10 to 15). They may count from one number to another or make marks to show approximately where numbers would be found."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691399Z"^^xsd:dateTime .

oak:misconception-10-times-size-10-times
  a oakcurric:Misconception ;
  oakcurric:statement """10 times the size and 10 times as many are achieved through the same operation but they are different."""@en ;
  oakcurric:correction """Use sticky-tack or plasticine. Create 10 blobs that are equal in length to 1 blob that has been stretched. Encourage the children to see that the value of their length is the same but one is made of countable objects whereas the other is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691406Z"^^xsd:dateTime .

oak:misconception-children-struggle-immediately-rush-making
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to not immediately rush to making use of a written method such as columns addition."""@en ;
  oakcurric:correction """Encourage the children to be resilient and remind them that practice makes perfect."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691411Z"^^xsd:dateTime .

oak:misconception-because-multiplication-commutative-division-isnt
  a oakcurric:Misconception ;
  oakcurric:statement """Because multiplication is commutative and division isn't, finding related division facts can be tricky. For example, 15 ÷ 3 = 5 is related to 3 × 5 = 15 despite the factor's positions swapping."""@en ;
  oakcurric:correction """Get children to write 2 related multiplication facts from a division fact. For example, 3 × 5 = 15 and 5 × 3 = 15 are related to 15 ÷ 3"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691515Z"^^xsd:dateTime .

oak:misconception-many-pupils-believe-subtracting-2
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils believe that 'subtracting 2 zeros' is dividing by 100 which can lead to difficulties later on when they are introduced to decimal numbers."""@en ;
  oakcurric:correction """Don't dismiss it. It's a pattern that has been spotted and generalised. Do encourage the children to work with physical resources that don't involve the numbers themselves so they can see that it's not subtracting 2 zeros but changing place value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691519Z"^^xsd:dateTime .

oak:misconception-pupils-find-calculating-75-number
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may find calculating 75% of a number difficult."@en ;
  oakcurric:correction """First focus on teaching one strategy for finding 75% of a number. Pupils may find it easiest to add 50% and 25% together. Show representations of this (e.g. bar models showing the proportion of the whole) alongside calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691526Z"^^xsd:dateTime .

oak:misconception-pupils-perceive-equals-sign-answer
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils perceive the equals sign = as 'where the answer goes' and struggle with writing equations."""@en ;
  oakcurric:correction """Show pupils that the equals sign represents balance and that equations are equal on both sides of the sign. Balance scales can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691531Z"^^xsd:dateTime .

oak:misconception-mistakes-made-comparison-problems-e
  a oakcurric:Misconception ;
  oakcurric:statement """Mistakes may be made on comparison problems. E.g. how much further does one child jump than another?"""@en ;
  oakcurric:correction """When we compare, we are finding the difference.  To find the difference, we need to subtract the smaller value from the larger value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691535Z"^^xsd:dateTime .

oak:misconception-pupils-refer-adding-numbers-tens
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may refer to adding numbers in the tens as 3 + 6 rather than 30 + 60"@en ;
  oakcurric:correction """Encourage them to refer to the tens numbers as tens, and use the language appropriately. In 34 + 44, we add 4 and 4 together and then we add 30 and 40 together. This will support their reasoning as they progress in this unit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691540Z"^^xsd:dateTime .

oak:misconception-90-degrees-classified-acute-angle
  a oakcurric:Misconception ;
  oakcurric:statement """90 degrees is classified as an acute angle and 180 degrees is classified as an obtuse angle."""@en ;
  oakcurric:correction """Provide opportunities for pupils to classify angle sizes and build towards understanding that acute angles are between 0-89 degrees and obtuse angles are between 91-179 degrees. Classifying multiples of right angles as a separate group may help."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691615Z"^^xsd:dateTime .

oak:misconception-right-angles-horizontal-vertical-line
  a oakcurric:Misconception ;
  oakcurric:statement """Right angles are only where a horizontal and vertical line meet to create a square corner."""@en ;
  oakcurric:correction """Ensure pupils are shown a wide range of right angles in a variety of orientations and contexts so that pupils can better generalise the features of a right angle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691619Z"^^xsd:dateTime .

oak:misconception-pupils-difficultly-partitioning-10s-crossing
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may have difficultly partitioning 10s when crossing the 100s boundary. (e.g. 125 - 40)"""@en ;
  oakcurric:correction """Pupils practice adding to/subtracting from multiples of 10 (e.g. 130 - 50) before exploring non-multiples of 10 (e.g. 85 + 30)"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691623Z"^^xsd:dateTime .

oak:misconception-pupils-spend-long-trying-make
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may spend too long trying to make a very accurate estimate for their calculations."""@en ;
  oakcurric:correction """Pupils need to understand that an estimation should be quick and easy to calculate. Encourage them to think about the nearest hundreds numbers so that these can be added together very quickly to give a value close enough to the answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691628Z"^^xsd:dateTime .

oak:misconception-children-say-tens-times-taller
  a oakcurric:Misconception ;
  oakcurric:statement "Children may say, 'Tens times taller', which is imprecise."@en ;
  oakcurric:correction """We say, 'Ten times the original height' because this is more precise and can be used when the scale factor is fractional."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691633Z"^^xsd:dateTime .

oak:misconception-children-compare-fractional-part-mixed
  a oakcurric:Misconception ;
  oakcurric:statement """Children may compare the fractional part of the mixed number first rather than the more significant whole number part."""@en ;
  oakcurric:correction """What do you notice? If the whole number is the same, we need to look at the fractional part. If the numerators are the same, we need to compare the denominators - the smaller the denominator the greater the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691637Z"^^xsd:dateTime .

oak:misconception-typically-many-children-add-numerators
  a oakcurric:Misconception ;
  oakcurric:statement """Typically, many children add both the numerators and denominators together to get the sum."""@en ;
  oakcurric:correction """Pupils need to grasp units and unitising. Get them to move around the classroom/school performing simple additions with different sets of objects. Revisit fractions explaining that they're using unit fractions and this is shown by the denominator."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691645Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-identify-many-intervals
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to identify how many intervals there are on the y-axis of graphs or are less familiar with graphs and so find it more challenging."""@en ;
  oakcurric:correction """Encourage pupils to focus on the gaps between each gridline as opposed to the number of gridlines there are themselves. You could generalise that there is always one fewer gridline than the number of gaps."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691650Z"^^xsd:dateTime .

oak:misconception-children-incorrectly-place-number-number
  a oakcurric:Misconception ;
  oakcurric:statement """Children may incorrectly place a number on a number line according to just counting the parts rather than working out the scale."""@en ;
  oakcurric:correction """Determine the multiples that the number line is increasing in first: find the difference between the given start and end numbers and divide by the number of parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691655Z"^^xsd:dateTime .

oak:misconception-children-forget-use-order-operations
  a oakcurric:Misconception ;
  oakcurric:statement """Children may forget to use the order of operations and revert back to working from left to right."""@en ;
  oakcurric:correction """Encourage them to identify all the operations in an equation before they begin to solve it so that they can apply their knowledge of the order of operations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691662Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-converting-angle
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may make mistakes converting an angle of a sector into a percentage."@en ;
  oakcurric:correction """Choose to work with angles that can easily be converted into percentages (e.g. 72° is equal to 20% of the whole chart). You could have these readily available in the classroom as part of a display to refer to throughout the lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691666Z"^^xsd:dateTime .

oak:misconception-many-pupils-understand-equals-symbol
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils understand the equals symbol as 'makes' or a the symbol you simply place in front of the answer. This can make the idea of a balanced equation tricky, undoing concepts like adjustment."""@en ;
  oakcurric:correction """Get all the pupils to write an expression (as unique as possible) that is equal to 10 and display them in the classroom. Ask the children what symbol could be placed between all of them and explore why."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691673Z"^^xsd:dateTime .

oak:misconception-its-important-pupils-avoid-saying
  a oakcurric:Misconception ;
  oakcurric:statement """It's important that pupils avoid saying, 'ten times smaller' to avoid misconceptions around the structure of division."""@en ;
  oakcurric:correction """Describe relationships by saying, 'divide by ten', or referring to the amounts involved e.g. 'The dividend is seven hundred. It is divided by ten. The dividend is now seventy.'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.691678Z"^^xsd:dateTime .

oak:misconception-pupils-double-halve-factors-instead
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may double or halve both factors, instead of doubling one and halving the other."""@en ;
  oakcurric:correction """Spend time exploring arrays and the area models (from Cycle B of the lesson). Model these misconceptions, showing why they are incorrect (e.g. show how 4 x 8 cannot be equivalent to 8 x 16)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691682Z"^^xsd:dateTime .

oak:misconception-pupils-create-bar-models-parts
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils create bar models where the parts do not equal the whole or vice versa."@en ;
  oakcurric:correction """Whilst this may be a calculation error, it is important that the context of the story is considered when looking to re-adjust the bar model. Take time to work through the context again building the bar model from the what is known."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691857Z"^^xsd:dateTime .

oak:misconception-brackets-intended-make-easier-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """The brackets are intended to make it easier for pupils to distinguish between different parts of the expression. Brackets are unfamiliar to learners so may cause errors."""@en ;
  oakcurric:correction """If the brackets lead to confusion then remove them and use colour or some other signifier. Pupils needs to be able to see, understand and analyse any changes through redistribution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691862Z"^^xsd:dateTime .

oak:misconception-idea-extra-cost-addition-saving
  a oakcurric:Misconception ;
  oakcurric:statement """The idea of an extra cost being an addition and a saving being a subtraction can seem counter-intuitive to some children."""@en ;
  oakcurric:correction """Talk through a more basic version using a pound for a budget and sweets at a tuck shop."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691866Z"^^xsd:dateTime .

oak:misconception-remembering-60-minutes-hour-values
  a oakcurric:Misconception ;
  oakcurric:statement """Remembering that there are 60 minutes in an hour and the values for quarter, half and three quarters of an hour. Calculations are often to and from 60 when working within an hour rather than 100"""@en ;
  oakcurric:correction """Make sure children have a clock face available so that they can visualise the times and see the minute hour hands. Children may find it useful to move the minute hand to count on and back in 5s to support their calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691871Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-recognise-properties
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it challenging to recognise that the properties of composed shapes may be different from the shapes they are composed of."""@en ;
  oakcurric:correction """Drawing around compound shapes can really support children thinking about this as a 'new' shape with new properties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691876Z"^^xsd:dateTime .

oak:misconception-pupils-identify-polygon-one-pair
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not identify when a polygon has more than one pair of parallel or perpendicular sides especially when the polygon is not a rectangle."""@en ;
  oakcurric:correction """Make use of right angle checkers to identify that some shapes have more than one right angle and take time to link this to perpendicular sides."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691880Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-identify-specific
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it challenging to identify specific quadrilaterals e.g. trapeziums when making them out of construction sticks as it can be harder to see the properties."""@en ;
  oakcurric:correction """Using a ruler to draw the shape, using the inside of the construction sticks, can support pupils in seeing and identifying the key properties to help them classify a quadrilateral."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691887Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-remember-number-degrees
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to remember the number of degrees in a triangle as they only know it as a disconnected fact."""@en ;
  oakcurric:correction """Apply pupils' knowledge of angles in a quadrilateral to understanding the sum of the angles in a triangle. Spend time showing how a quadrilateral is constructed using triangles and what happens to the angles as the quadrilateral is partitioned."""@en ;
  dcterms:modified "2026-02-12T08:59:18.691896Z"^^xsd:dateTime .

oak:misconception-pupils-highly-familiar-finding-area
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils highly familiar with finding the area of a rectangle by multiplying its side lengths might overgeneralise and multiply the base by a side length rather than by the perpendicular height."""@en ;
  oakcurric:correction """Some 'red herring' examples are given in the Practice questions where the side length is given unnecessarily. You may wish to make an extra teaching point of how this is superfluous. Remind pupils of the formula, which does not include side lengths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692006Z"^^xsd:dateTime .

oak:misconception-pupils-misread-numbers-using-number
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may misread numbers when using number lines (e.g. read 105 as 95)."@en ;
  oakcurric:correction """Encourage children to say the 10s number before and after (e.g. the number is in between 100 and 110)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692011Z"^^xsd:dateTime .

oak:misconception-children-make-mistakes-using-generalisations
  a oakcurric:Misconception ;
  oakcurric:statement """Children may make mistakes when using the generalisations if they are unaware of the structure behind them."""@en ;
  oakcurric:correction """Check your answers using the corresponding stem sentences or by representing the number. Ensure that, when you compare amounts that are presented as different fraction types, you convert to the same fraction type."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692015Z"^^xsd:dateTime .

oak:misconception-adding-fractional-part-mixed-number
  a oakcurric:Misconception ;
  oakcurric:statement """Adding the fractional part of a mixed number to a proper fraction may result in an improper fraction, which may be recombined with the whole number part of the mixed number and left as improper."""@en ;
  oakcurric:correction """In a mixed number, the numerator of the fractional part must always be smaller than the denominator. If it is greater, a final conversion is needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692022Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-partitioning-hundreds-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle when partitioning hundreds and tens (e.g. partitioning 340 into 220 and 120)."""@en ;
  oakcurric:correction """Give pupils opportunities to manipulate base ten blocks, rearranging them and partitioning both the hundreds and the tens."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692027Z"^^xsd:dateTime .

oak:misconception-pupils-make-errors-using-halfway
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make errors using the halfway steps between numbers (e.g. wrongly label 374 as 379)."""@en ;
  oakcurric:correction """Encourage pupils to find and label the halfway steps (e.g. the 5 or the 50s numbers)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692032Z"^^xsd:dateTime .

oak:misconception-pupils-encouraged-think-adding-zero
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils should not be encouraged to think about 'adding a zero' to the 2-digit numbers."""@en ;
  oakcurric:correction """Make careful use of the stem sentences and representations to make sure that pupils are clear that e.g. 12 tens is equal to 120."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692038Z"^^xsd:dateTime .

oak:misconception-pupils-instinctively-believe-midnight-12
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might instinctively believe that midnight is 12 pm. There is often confusion about the use of am and pm with midnight and midday."""@en ;
  oakcurric:correction """Utilise opportunities for quickfire counting outside the Maths lesson, from different starting points. For example, 10 am, 11 am, 12 pm, 1 pm, 2pm, or 9 pm, 10 pm, 11 pm, 12 am. 1 am."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692148Z"^^xsd:dateTime .

oak:misconception-identifying-parts-wholes-problem-given
  a oakcurric:Misconception ;
  oakcurric:statement "Identifying the parts and wholes in a problem or given context."@en ;
  oakcurric:correction """Use the stem sentences and representations of part-part-whole and bar models to support pupils in identifying the parts and whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692152Z"^^xsd:dateTime .

oak:misconception-pupils-see-connection-known-facts
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not see the connection between known facts and calculating using multiples of one hundred."""@en ;
  oakcurric:correction """Place value counters or Base 10 blocks may be helpful with getting children to unitise and see the connection between, for example,  14 − 7 and 1,400 − 700"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692157Z"^^xsd:dateTime .

oak:misconception-pupils-need-make-accurate-use
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils need to make accurate use of place value, especially with numbers that have zero ones, tens or hundreds."""@en ;
  oakcurric:correction """Give pupils opportunities to set out calculations such as two hundred and thirty add three hundred and four. Can they use zero correctly to represent zero ones and zero tens?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692162Z"^^xsd:dateTime .

oak:misconception-pupils-find-remembering-types-properties
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils find remembering the types and properties of quadrilaterals challenging."@en ;
  oakcurric:correction """Take time to repeat and revisit the key properties within the lesson and beyond. Consider providing a scaffold for some pupils so they can create quadrilaterals without having to recall the specific properties each time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692169Z"^^xsd:dateTime .

oak:misconception-children-overgeneralise-parallel-lines-come
  a oakcurric:Misconception ;
  oakcurric:statement """Children may overgeneralise that parallel lines can only come in pairs or must be horizontal or vertical in orientation."""@en ;
  oakcurric:correction """These misconceptions are addressed in the lesson. You may wish to use these to create additional examples and non-examples to compare and share."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692173Z"^^xsd:dateTime .

oak:misconception-many-pupils-want-use-written
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils will want to use a written method/algorithm immediately such as column method. This lesson is to support mental addition strategies."""@en ;
  oakcurric:correction """Encourage the children to forget about using written procedures because they are inefficient when the addends are suited to adjustment. As class teacher, use adjustment and race the children desperate to use columns to see who is fastest!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692178Z"^^xsd:dateTime .

oak:misconception-children-see-link-sharing-grouping
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not see the link between sharing and grouping as sharing has traditionally been done by sharing out objects one by one. This becomes far less efficient when working with larger numbers."""@en ;
  oakcurric:correction """To develop understanding of 'dividing between', ensure that physical objects are shared out in groups each time (forming an array beneath a bar model), rather than one by one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692182Z"^^xsd:dateTime .

oak:misconception-pupils-taught-choose-vertex-count
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils are taught to choose a vertex then count horizontally and / or vertically when translating that vertex. Pupils may forget which vertex they started with and end up translating the wrong vertex."""@en ;
  oakcurric:correction """You may wish to consider asking pupils to mark the starting vertex with a small circle as a reminder of which one they started with."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692187Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-regroup-ones-tens
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to regroup in the ones and tens when the tens digit is zero."@en ;
  oakcurric:correction """Explain that pupils may need to regroup from the hundreds first, and then regroup in the ones. They still need to start with the numbers with the smallest place value. When crossing out, pupils need to cross out the '10' tens and replace with 9"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692288Z"^^xsd:dateTime .

oak:misconception-pupils-try-use-written-method
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will often try to use a written method/algorithm which they know gives an accurate answer but don't understand why it works."""@en ;
  oakcurric:correction """Encourage the pupils to be brave and remind them that this is about mental subtraction so, with practice, will be quicker than any written methods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692293Z"^^xsd:dateTime .

oak:misconception-confusion-terms-capacity-volume
  a oakcurric:Misconception ;
  oakcurric:statement "Confusion between the terms capacity and volume."@en ;
  oakcurric:correction """Capacity is the whole amount of liquid that a container can hold. Volume is the actual amount of liquid in the container."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692300Z"^^xsd:dateTime .

oak:misconception-pupils-quick-try-use-written
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may be very quick to try and use a written method such as columns here, particularly as the numbers get larger."""@en ;
  oakcurric:correction """Encourage the children to refrain and reward them taking risks and avoiding using written methods as much as possible. Prove to them that it's quicker to do it in your head or with jottings by racing your fastest 'columns ' exponent!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692305Z"^^xsd:dateTime .

oak:misconception-lots-children-understanding-goal-difference
  a oakcurric:Misconception ;
  oakcurric:statement """Lots of children have an understanding of goal difference from experiences outside the classroom but this might be the first time some children have encountered it and it may cause confusion."""@en ;
  oakcurric:correction """Consider pre-teaching if that is a possibility or introduce it in a PE context to begin with. You could even keep score of any playtime games for the days leading up to the lesson to give some real life context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692309Z"^^xsd:dateTime .

oak:misconception-pupils-count-interval-markers-find
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils count the interval markers to find how many parts the whole has been divided into."""@en ;
  oakcurric:correction """Identify clearly which whole you are dividing and link the bar model to the numberline to show how the intervals reveal the number of parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692314Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-draw-bar-model
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to draw a bar model to represent an equation without a context."@en ;
  oakcurric:correction """Refer back to the language of parts and wholes to help pupils identify which numbers in the equation represent the parts and which number represent the whole. You may like to reduce the numbers to number within 10 to emphasise the structure at first."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692321Z"^^xsd:dateTime .

oak:misconception-pupils-think-know-perimeter-shape
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that if they know the perimeter of a shape, and a new shape has been made from duplicates of it, they can simply multiply the perimeter by how many shapes make up the new one."""@en ;
  oakcurric:correction """The lesson highlights this misconception and tackles it but it is worth being aware of it as pupils work. Point out to them that some of the sides from the original shape are now inside the new shapes so do not count as part of its perimeter."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692398Z"^^xsd:dateTime .

oak:misconception-multiplying-fraction-larger-whole-number
  a oakcurric:Misconception ;
  oakcurric:statement """Multiplying a fraction by a larger whole number means the product will be larger."""@en ;
  oakcurric:correction """In these examples, encourage children to see the whole number as a multiplier. Relate this back to representations where the fraction is shown to represent an area or a quantity. This should help to identify the fraction's magnitude when reasoning."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692405Z"^^xsd:dateTime .

oak:misconception-pupils-ever-calculate-equation-left
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils only ever calculate an equation from left to right."@en ;
  oakcurric:correction """Ensure pupils are given time to explore where the commutative law might be best used and where the associative law might be better used. Pupils should be expected to reason why they have chosen to adopt a strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692412Z"^^xsd:dateTime .

oak:misconception-pupils-procedurally-multliply-denominators-add
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils procedurally multliply the denominators and add the numerators, or vice versa. Pupils may also only mutliply the denominators and not the numerators or again vice versa."""@en ;
  oakcurric:correction """Ensure pupils connect the area model to the equations and continue to visualise the magnitude of each fraction. Often mistakes are made when pupils follow a procedure with little awareness for whether their answer makes sense mathematically."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692417Z"^^xsd:dateTime .

oak:misconception-pupils-remove-add-ones-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will sometimes remove or add ones or tens to one addend and forget to amend the other addend so that the calculation has been transformed but doesn't give the same sum as the original."""@en ;
  oakcurric:correction """Encourage buddy checking of jottings as the children practise so that they can help each other to be reminded."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692422Z"^^xsd:dateTime .

oak:misconception-numbers-used-side-lengths-lesson
  a oakcurric:Misconception ;
  oakcurric:statement """The numbers used as side lengths in this lesson are generally relatively low, and based around times tables. As a result, pupils might be tempted to guess / estimate the missing side lengths."""@en ;
  oakcurric:correction """Remind pupils that the shapes are not to scale and encourage them to use subtraction skills instead - what is the difference between this known side length and this known side length?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692426Z"^^xsd:dateTime .

oak:misconception-pupils-understanding-recording-regrouped-amount
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils not understanding and/or recording the regrouped amount."@en ;
  oakcurric:correction """Continue to use language of unitisation. For example '7 tens ÷ 3 is 2 tens remainder 1 ten.' Ask what the regrouped amount represents."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692431Z"^^xsd:dateTime .

oak:misconception-knowing-understanding-one-fifth-fraction
  a oakcurric:Misconception ;
  oakcurric:statement """Knowing and understanding that one-fifth as a fraction is equivalent to 0.2 as a decimal and that counting in steps of 0.2 is the same as counting in fifths."""@en ;
  oakcurric:correction """Make sure that pupils have the opportunity to rehearse the fact that one-fifth is equivalent to 0.2 more frequently during the lesson and at other times when looking at fractions and decimals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692435Z"^^xsd:dateTime .

oak:misconception-looking-expression-such-5-6
  a oakcurric:Misconception ;
  oakcurric:statement """When looking at an expression such as 5 × 6 − 5 × 3 children might be tempted to subtract first leading to an expression like this: 5 × 1 × 3"""@en ;
  oakcurric:correction """Ensure that you support the equation with the arrays so that pupils understand where the multiplication expressions come from and they can match the partial products to the arrays."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692584Z"^^xsd:dateTime .

oak:misconception-children-find-difficult-comprehend-e
  a oakcurric:Misconception ;
  oakcurric:statement """Children may find it difficult to comprehend that e.g. 1,200,000 may have a digit '2' in the one hundred thousands place but is actually composed of 12 hundred thousands."""@en ;
  oakcurric:correction """Even though the digit in the 100,000s place is a 2, the number 1,200,000 is composed of 12 hundred thousands because one million is composed of 10 hundred thousands."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692602Z"^^xsd:dateTime .

oak:misconception-pupils-think-7-times-table
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that the 7 times table is just counting by sevens without recognising it as multiplication."""@en ;
  oakcurric:correction """Emphasise that the 7 times table is not just counting by sevens but a series of products of 7 and whole numbers (e.g., 7 × 1, 7 × 2, etc.)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692651Z"^^xsd:dateTime .

oak:misconception-pupils-make-errors-crossing-100s
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make errors when crossing the 100s boundary, either when adding or subtracting."""@en ;
  oakcurric:correction """Emphasise that ten 10s are equal to 100. When using base ten blocks, pupils should be encouraged to change ten 10s into one hundred."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692656Z"^^xsd:dateTime .

oak:misconception-lack-understanding-place-value-lead
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of understanding of place value may lead to the rise of incorrect partial quotients."""@en ;
  oakcurric:correction """Encourage children to identify what each digit represents. If misconceptions persist - use place value counters to divide by skip counting."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692662Z"^^xsd:dateTime .

oak:misconception-lack-fluency-3s-6s-times
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in the 3s and 6s times tables can lead to pupils being slower to grasp the generalisation about the relationship between the 3 and 6 times tables."""@en ;
  oakcurric:correction """Use arrays and other representations to draw clear comparisons. Multiplication grids could also be provided while pupils become more fluent in recall."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692667Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-comparing-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it challenging when comparing numbers made from the same digits (e.g. 245 and 254)."""@en ;
  oakcurric:correction """Base ten blocks, place value grids and number lines can all be used so pupils can see the size of numbers and see which is larger."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692671Z"^^xsd:dateTime .

oak:misconception-children-think-parts-unequal-because
  a oakcurric:Misconception ;
  oakcurric:statement "Children might think that parts are unequal just because they look different."@en ;
  oakcurric:correction "If you cut the shapes out, do they take up the same amount of space?"@en ;
  dcterms:modified "2026-02-12T08:59:18.692678Z"^^xsd:dateTime .

oak:misconception-pupils-partition-one-addends-incorrectly
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils partition one of the addends incorrectly to help them bridge ten."@en ;
  oakcurric:correction """Pupils use number pairs that total ten to help them partition the addend. They consider what they have to add to make ten."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692683Z"^^xsd:dateTime .

oak:misconception-pupils-think-because-representation-images
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that because a representation has more images/items then it is a larger number."""@en ;
  oakcurric:correction """Encourage pupils to consider the value of each image/item and say this verbally as ___ wholes and ___ tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692687Z"^^xsd:dateTime .

oak:misconception-pupils-need-proficiency-bridging-across
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils need to have proficiency in bridging across zero with negative numbers, in the range of −10 to 10. Grid lines that might help to support such calculations are not given in this lesson."""@en ;
  oakcurric:correction """Pupils not secure will need a resource within the lesson to support their calculations, such as a number line going from −10 to 10."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692778Z"^^xsd:dateTime .

oak:misconception-children-struggle-estimate-position-mixed
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to estimate the position of a mixed number on a number line if their 'fraction sense' is not secure."""@en ;
  oakcurric:correction """What do you notice about the mixed number? Remember, the whole number part is the most significant part - looking at this whole number part, which integers must the mixed number sit between? What do you notice about the fractional part?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692782Z"^^xsd:dateTime .

oak:misconception-pupils-see-connection-common-divisions
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not see the connection between the common divisions of 1,000, 100, 10 and 1 and they may not see the multiplication sign representing the word of when reading the equations."""@en ;
  oakcurric:correction """Allow pupils time to explore the representations of the divisions of 1,000, 100, 10 and 1 alongside each other. Encourage the equations to be read using multiplied by and also of which is more commonly used with fractions of amounts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692787Z"^^xsd:dateTime .

oak:misconception-pupils-still-think-because-equivalent
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils may still think that, because equivalent fractions look different, they do not have the same value."""@en ;
  oakcurric:correction """Use representations such as bar models and shapes as well as number lines to ensure that this understanding is secured both in interpreting fractions as parts of a whole and as numbers with a fixed position on a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692794Z"^^xsd:dateTime .

oak:misconception-pupils-incorrectly-arrange-dividend-divisor
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may incorrectly arrange the dividend or divisor and quotient."@en ;
  oakcurric:correction """Clear modelling. Ask children 'What does this number represent?' - 'The dividend and it is placed inside the division frame.'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.692798Z"^^xsd:dateTime .

oak:misconception-children-assume-shapes-larger-area
  a oakcurric:Misconception ;
  oakcurric:statement """Children may assume some shapes have a larger area than others by comparison of a certain dimension. In this lesson, pattern blocks can be arranged to create shapes with very different dimensions."""@en ;
  oakcurric:correction """Encourage pupils to rearrange the composing shapes to prove that the compound shapes have the same area. This can be done effectively with tangrams or pattern blocks, both of which feature heavily in this lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692803Z"^^xsd:dateTime .

oak:misconception-understanding-mean-average-way-creating
  a oakcurric:Misconception ;
  oakcurric:statement """Understanding that the mean average is a way of creating one value to represent a set of data. It is calculated by sharing equally but doesn't always mean that a set is being shared."""@en ;
  oakcurric:correction """Be clear about what the mean average value represents and how it might be useful in the contexts presented."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692807Z"^^xsd:dateTime .

oak:misconception-pupils-overwhelmed-long-division-algorithm
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may be overwhelmed by the long division algorithm, especially with using multiples of the divisor and  subsequent subtraction calculations."""@en ;
  oakcurric:correction """Encourage pupils to complete and make use of the multiplication facts tables to support them in their calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692814Z"^^xsd:dateTime .

oak:misconception-many-pupils-believe-adding-2
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils believe that 'adding 2 zeros' is multiplying by 100 which can lead to difficulties later on when they are introduced to decimal numbers."""@en ;
  oakcurric:correction """Don't dismiss it. It's a pattern that has been spotted and generalised. Do encourage the children to work with physical resources that don't involve the numbers themselves so they can understand that it isn't adding zero but changing place value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692820Z"^^xsd:dateTime .

oak:misconception-pupils-understand-equals-symbol-big
  a oakcurric:Misconception ;
  oakcurric:statement """Often, pupils understand the equals symbol to be a big reveal or a 'ta-da!' rather than a symbol denoting equivalence. This can make the idea of a balanced equation tricky."""@en ;
  oakcurric:correction """Explore pupils' understanding of the equal sign at the start of the lesson. For children who still find it a tricky concept, make use of bucket scales and plasticine to explore equivalence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692825Z"^^xsd:dateTime .

oak:misconception-children-add-zero-multiplying-vice
  a oakcurric:Misconception ;
  oakcurric:statement """Children may 'add' a zero when multiplying or vice versa when dividing. Children may place a zero at the end of the decimal fraction when multiplying, or vice versa when dividing."""@en ;
  oakcurric:correction """When we 'add' zero, the value of the number does not change. When we multiply or divide by a power of 10, we need to move all the digits the appropriate spaces to the left/right even if this means bridging one and moving into the decimal places."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692966Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-estimation-especially-thinking
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle with estimation, especially with thinking of numbers that are quick and easy to calculate with."""@en ;
  oakcurric:correction """Pupils will probably have little or no experience of rounding but they will be able to think about the place value of numbers and give tens or hundreds numbers that are close. Number lines may be helpful for some children."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692971Z"^^xsd:dateTime .

oak:misconception-children-rush-subtract-numerator-denominator
  a oakcurric:Misconception ;
  oakcurric:statement """Children will rush to subtract both the numerator and the denominator when performing a subtraction of fractions with either structure in the lesson."""@en ;
  oakcurric:correction """Reinforce the concept of the unit being the fraction which is denoted by the denominator. Get children to perform subtractions using real life objects before moving them onto using fractions instead, perhaps using unit fractions to begin with."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692975Z"^^xsd:dateTime .

oak:misconception-area-perimeter-easily-confused-lesson
  a oakcurric:Misconception ;
  oakcurric:statement """Area and perimeter are easily confused. In this lesson, both concepts are explored, often at the same time."""@en ;
  oakcurric:correction """Use your knowledge of the pupils' attainment (including using the Starter Quiz) to see which pupils are confusing the terms. All pupils will benefit from access to a working wall which gives a clear reminder of which is which."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692982Z"^^xsd:dateTime .

oak:misconception-larger-objects-greater-mass-taller
  a oakcurric:Misconception ;
  oakcurric:statement """Larger objects have a greater mass. Taller containers have a greater capacity and/or volume."""@en ;
  oakcurric:correction """The size of something does not determine how much mass an object has; taller containers may be narrower and so may not hold as much liquid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692987Z"^^xsd:dateTime .

oak:misconception-pupils-believe-pair-10-exists
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils believe a pair to 10 only exists if the addends are next to one another in an equation."""@en ;
  oakcurric:correction """Addition is commutative. Model the use of tens frames to show efficient addition of calculations containing number pairs to 10."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692993Z"^^xsd:dateTime .

oak:misconception-two-shapes-cannot-same-area
  a oakcurric:Misconception ;
  oakcurric:statement "Two shapes cannot have the same area if they look different."@en ;
  oakcurric:correction """Use square sticky notes. Pupils can then move the shapes around to prove that two shapes can have the same area but look different."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693000Z"^^xsd:dateTime .

oak:misconception-pupils-believe-perpendicular-height-parallelogram
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might believe the perpendicular height of any parallelogram to be one of its side lengths. This is only true of a rectangle."""@en ;
  oakcurric:correction """Take time to exemplify perpendicular height with a focus on the right angle created. Make use of examples within the lesson and include additional unusual parallelograms to secure understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693247Z"^^xsd:dateTime .

oak:misconception-partitioning-subtract-children-partition-correctly
  a oakcurric:Misconception ;
  oakcurric:statement """When partitioning to subtract, children may partition correctly but then may subtract incorrectly by swapping the order of the fractional parts being subtracted."""@en ;
  oakcurric:correction """Is partitioning efficient for this subtraction where the fractional part of the subtrahend is greater than that of the minuend? It may be more efficient to 'find the difference' by counting on."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693256Z"^^xsd:dateTime .

oak:misconception-pupils-procedurally-multiply-numerators-together
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils procedurally multiply the numerators together and then multiply the denominators together to find the product."""@en ;
  oakcurric:correction """It's important pupils understand the magnitude of the fraction in relation to one another. Encourage pupils to draw images to represent each equation and notice that the magnitude of the product is decreasing in size each time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693261Z"^^xsd:dateTime .

oak:misconception-children-struggle-identify-dividends-confuse
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to identify the dividends and confuse these with the divisor."""@en ;
  oakcurric:correction """For each problem, ask the children what each number represents and help them to describe this. For example,  'the number of sweets before they were shared and the number they are sharing between' alongside the terms dividend and divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693265Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-cross-100s-boundaries
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to cross 100s boundaries when adding 10s."@en ;
  oakcurric:correction """Base ten blocks can help with this concept. It also helps if children's attention is drawn towards the patterns in the number system."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693270Z"^^xsd:dateTime .

oak:misconception-pupils-refer-size-numbers-manipulating
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not refer to the size of the numbers when manipulating the digit cards."""@en ;
  oakcurric:correction """Encourage them to talk about the size of the numbers and whether the digit cards represent ones, tens or hundreds."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693362Z"^^xsd:dateTime .

oak:misconception-pupils-automatically-want-compare-fractions
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils automatically want to compare fractions using common denominators, following a procedure to convert fractions to an equivalent with the same denominator."""@en ;
  oakcurric:correction """Spend time looking at a variety of examples that can be reasoned about without the need to convert to common denominators. It can be helpful to represent these examples using bar model help discuss the relationships between the whole and its parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693367Z"^^xsd:dateTime .

oak:misconception-pupils-forget-include-regrouped-values
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils forget to include regrouped values when multiplying."@en ;
  oakcurric:correction """Decide on a place and structure for regrouped values - they are included at the top of the algorithm in these lessons to avoid confusion with addition regrouping when partial products are summed. Ensure this is clearly modelled."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693375Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-see-unit-fraction
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to see that a unit fraction with a larger denominator is smaller than a unit fraction with a smaller denominator."""@en ;
  oakcurric:correction """Pupils should be supported to visualise each fraction before moving on to interpreting abstract fraction notation. Encourage them to see the connection between the number of equal parts and the relative size of the fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693380Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-present-regrouping-column
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to present regrouping in column addition."@en ;
  oakcurric:correction """Encourage pupils to talk about the process as they work through the problems. Model this in the lesson e.g. '5 tens add 7 tens is equal to 12 tens. 10 tens are regrouped as 1 hundred and written in the hundreds column.'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693385Z"^^xsd:dateTime .

oak:misconception-pupils-trouble-recognising-right-angles
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may have trouble recognising right angles or lines of symmetry when shapes have been rotated."""@en ;
  oakcurric:correction """Encourage pupils to check every angle using a simple right-angle measurer, which can be hand made or even cut from the corner of a piece of paper. Ask them to physically manipulate the shapes so that they can identify properties more easily."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693389Z"^^xsd:dateTime .

oak:misconception-pupils-believe-multiples-10-compose
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may believe only multiples of 10 can compose 100 and therefore do not see four groups of 25."""@en ;
  oakcurric:correction """Focus on practical representations e.g. bead strings and base 10 blocks where 100 can be composed and decomposed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693394Z"^^xsd:dateTime .

oak:misconception-because-representation-numbers-1-3
  a oakcurric:Misconception ;
  oakcurric:statement """Because the representation of numbers 1 to 3 bear a resemblance to tallies, pupils may be tempted to continue in this fashion, for example writing 4 in Roman numerals as IIII"""@en ;
  oakcurric:correction """Discuss with pupils the idea of Roman numerals being based around a small number of 'rules', which are never broken. One such rule is that the same letter is never used more than three times in a row. Spend time really focusing on IV and IX."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693401Z"^^xsd:dateTime .

oak:misconception-children-struggle-construct-whole-given
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to construct the whole from a given part. They may misunderstand the total number of parts needed as this includes the original part."""@en ;
  oakcurric:correction """Emphasise the denominator as the number of equal parts and ensure the learner sees the part they have as one of ___ equal parts. Take time to construct and deconstruct wholes from and into equal parts so learners know what to include in the count."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693530Z"^^xsd:dateTime .

oak:misconception-children-struggle-visualise-remainder-relates
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to visualise how the remainder relates to the question asked in the problem, or may solve the equation without relating back to the question asked."""@en ;
  oakcurric:correction """Encourage them to write the division equation for the problem and say what each part represents, focusing particularly on the role of the remainder and how it relates to the question asked."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693534Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-adding-near-double
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle when adding near double multiples of ten and when crossing 100s boundaries."""@en ;
  oakcurric:correction """Encourage pupils to use their known facts to support thinking and combine this with the use of base ten blocks, especially for crossing 100"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693543Z"^^xsd:dateTime .

oak:misconception-pupils-confident-representing-addition-problems
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not be confident in representing addition problems using bar models."@en ;
  oakcurric:correction """Make connections between bar models, tens frames and 'first...then...then...now' representations. Take time to model examples."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693548Z"^^xsd:dateTime .

oak:misconception-lack-fluency-number-facts-20
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency with number facts to 20 can hinder progress in applying them to multiples of ten."""@en ;
  oakcurric:correction """Ensure that fluency with number facts to 20 is secure or supported so that pupils can apply them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693553Z"^^xsd:dateTime .

oak:misconception-pupils-identify-ten-tens-equal
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not identify that ten tens are equal to 100 and cannot decompose 100 in this way."""@en ;
  oakcurric:correction """Base ten blocks or a bead string are useful tools to allow pupils to compose and decompose 100 into equal groups of ten."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693561Z"^^xsd:dateTime .

oak:misconception-pupils-less-efficient-fluent-bonds
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may be less efficient if they are not fluent with bonds within 10 e.g. 3 + 6 = 9"""@en ;
  oakcurric:correction """Provide additional scaffolding as appropriate including examples of pairs that total 9 and 10"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693566Z"^^xsd:dateTime .

oak:misconception-recording-multiple-0-1-number
  a oakcurric:Misconception ;
  oakcurric:statement """When recording which multiple of 0.1 a number is nearest to, pupils may forget to include the ones."""@en ;
  oakcurric:correction """Make sure pupils have plenty of opportunities to continue counting and rounding with multiples of 0.1 beyond one whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693571Z"^^xsd:dateTime .

oak:misconception-pupils-write-example-3-cm
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may write for example 3 cm as 0.3 m."@en ;
  oakcurric:correction """Make connections between the headings in the place value chart and images that represent metres, tenths of metres and centimetres."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693575Z"^^xsd:dateTime .

oak:misconception-pupils-miscalculate-measures-questions-involving
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may miscalculate measures questions involving unit conversions if they are not secure with the key conversions of 1 m = 1,000 mm, 1 km = 1,000 m, 1 kg = 1,000 g and 1 l = 1,000 ml."""@en ;
  oakcurric:correction """Spend time discussing the etymology of the words so pupils are not necessarily relying on memory and can figure out the equivalences if they cannot recall them. 'Milli' means 'thousandth' and 'kilo' means 'thousand': both relate to a thousand parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693703Z"^^xsd:dateTime .

oak:misconception-children-mistake-unit-measure-struggle
  a oakcurric:Misconception ;
  oakcurric:statement "Children may mistake which unit to measure in or may struggle to estimate."@en ;
  oakcurric:correction """This is one 1 m/1 cm length.  How many of these do you think would be the same as the length/height of the object being measured?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693707Z"^^xsd:dateTime .

oak:misconception-pupils-think-money-amount-made
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that if money amount is made up of more coins it must have a higher value."""@en ;
  oakcurric:correction """Encourage pupils to group their coins and set them out in order. Focus on the highest value digit first."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693712Z"^^xsd:dateTime .

oak:misconception-pupils-see-rectangle-perimeter-given
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may see a rectangle with the perimeter given and only one of the side lengths and think that there is insufficient information as there are three missing side lengths."""@en ;
  oakcurric:correction """Remind pupils that because it is a rectangle, the side length opposite the given side length is in fact known. A counter can be added on and then removed again to show that they actually know two of the missing side lengths, not just one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693719Z"^^xsd:dateTime .

oak:misconception-comparing-same-corresponding-sides-related
  a oakcurric:Misconception ;
  oakcurric:statement "Not comparing the same or corresponding sides of related shapes."@en ;
  oakcurric:correction """Label the sides of shapes clearly and refer to them with consistent language of height and width."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693723Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-represent-numbers-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to represent numbers where tens or ones are missing (e.g. 307 or 680)."""@en ;
  oakcurric:correction """Use place value grids to represent numbers, showing that there are 'no tens' or 'no ones'. Use alongside base ten block representations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693728Z"^^xsd:dateTime .

oak:misconception-children-identify-lines-symmetry-neither
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not identify lines of symmetry that are neither horizontal nor vertical."""@en ;
  oakcurric:correction """Allow opportunities for children to handle and manipulate cut outs of shapes so that they can try to find lines of symmetry in different orientations. Encourage them to describe the position of the line of symmetry to support their understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693732Z"^^xsd:dateTime .

oak:misconception-pupils-think-whole-divided-x
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that when a whole is divided into x parts, they need to have x interval markers."""@en ;
  oakcurric:correction """Encourage pupils to make connections between the bar model and the number line, drawing attention to where each whole has been divided."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693737Z"^^xsd:dateTime .

oak:misconception-adding-subtracting-fractions-different-denominators
  a oakcurric:Misconception ;
  oakcurric:statement """When adding or subtracting fractions with different denominators, you just add or subtract the denominators from each other."""@en ;
  oakcurric:correction """Encourage the children to use prior generalisations such as when the numerators are the same, the fraction with the largest denominator is the smallest, to help them reason about the above misconception."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693952Z"^^xsd:dateTime .

oak:misconception-objects-rotate-either-less-full
  a oakcurric:Misconception ;
  oakcurric:statement "Objects rotate only either less than a full turn or more than a full turn."@en ;
  oakcurric:correction """Take time to discuss the purpose of the object in question and clarify the difference between what an object should do and could do."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693957Z"^^xsd:dateTime .

oak:misconception-children-want-use-inequality-symbols
  a oakcurric:Misconception ;
  oakcurric:statement """Children might want to use inequality symbols between representations showing different wholes."""@en ;
  oakcurric:correction """Explain that inequalities can only be used when the whole is the same. Provide them with examples they may be familiar with such as offering half of a large and small apple and identifying that these are not the same because the wholes differ."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693961Z"^^xsd:dateTime .

oak:misconception-zero-tricky-concept-pupils-comes
  a oakcurric:Misconception ;
  oakcurric:statement """Zero is a tricky concept for some pupils when it comes to place value. For example, pupils might struggle to read and understand the number 2,087, or struggle to express in numbers a representation."""@en ;
  oakcurric:correction """Blank place value grids are an excellent scaffold. Give pupils ample opportunities to explore using them both with concrete resources such as counters and with numerals, practising reading and writing the number."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693968Z"^^xsd:dateTime .

oak:misconception-pupils-choose-short-division-solve
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may always choose short division to solve division equations."@en ;
  oakcurric:correction """Encourage pupils to think about other strategies that they know. Ask questions such as 'Is this the most efficient method?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.693973Z"^^xsd:dateTime .

oak:misconception-highly-common-pupils-mix-area
  a oakcurric:Misconception ;
  oakcurric:statement """It is highly common for pupils to mix up area and perimeter or to confuse the notations for the two."""@en ;
  oakcurric:correction """Allow children plenty of opportunity to identify perimeter and area for the same shapes and discuss why the unit of measure is different. You may also wish to build in deliberate errors when modelling or into tasks for children to identify and check."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693977Z"^^xsd:dateTime .

oak:misconception-children-read-scale-incorrectly-confusion
  a oakcurric:Misconception ;
  oakcurric:statement """Children may read the scale incorrectly - confusion between equal parts and marks on the scale."""@en ;
  oakcurric:correction """The scale is a number line. Remember to look at the number of equal parts between the marked numbers not the marks themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693982Z"^^xsd:dateTime .

oak:misconception-pupils-count-side-twice-miss
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may count a side twice, or miss a side, if they do not remember where their starting point was on the shape when counting the perimeter."""@en ;
  oakcurric:correction """Encourage pupils to mark a starting point, or use dots to mark the units they have counted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693986Z"^^xsd:dateTime .

oak:misconception-pupils-overgeneralise-assume-perimeters-calculated
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may overgeneralise and assume all perimeters can be calculated by multiplying one side length by the number of sides in the polygon."""@en ;
  oakcurric:correction """'Noticing' is a key mathematical skill. Encourage pupils to take their time to notice whether the shape is regular or irregular, if that information is not already explicitly given."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693993Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-use-estimation-help
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to use estimation to help them with checking addition equations."""@en ;
  oakcurric:correction """Encourage pupils to find the nearest multiple of 10 or 100 to the numbers they are adding. They will not yet be familiar with ‘rounding’. Estimated answers do not need to be really accurate, then are just an approximation and help when checking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693998Z"^^xsd:dateTime .

oak:misconception-counters-used-unitisation-lesson-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """Counters are being used for unitisation in this lesson but sometimes pupils can struggle to understand that counters can be worth different amounts without a proportional change in size."""@en ;
  oakcurric:correction """Count up and down in different amounts using the counters so that children understand they represent a unit that can have different values in different examples."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694009Z"^^xsd:dateTime .

oak:misconception-pupils-convert-percentages-fractions-denominators
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not convert percentages into fractions with denominators of 100 before attempting other conversions."""@en ;
  oakcurric:correction """Encourage pupils to always write percentages as fractions with denominators of 100 before trying to find other fraction equivalents. Show them how missing this key step can lead to errors."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694013Z"^^xsd:dateTime .

oak:misconception-pupils-default-trying-use-same
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may default to trying to use the same strategy for every shape, for example, the 'partition and add' can be applied to most shapes although it might not be the most efficient."""@en ;
  oakcurric:correction """Spend time exploring each strategy with basic dimensions for compound shapes at first. Explore different strategies for the same shape and encourage children to reason which strategy might be most efficient to use."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694018Z"^^xsd:dateTime .

oak:misconception-pupils-cut-parallelogram-vertex-opposite
  a oakcurric:Misconception ;
  oakcurric:statement """If pupils do not cut a parallelogram from vertex to opposite vertex, they will end up with either two non-congruent shapes or two congruent quadrilaterals."""@en ;
  oakcurric:correction """Modelling is key and this is a useful time to revisit the concept of a shape's diagonal, that is, a line connecting vertex to a non-adjacent vertex."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694129Z"^^xsd:dateTime .

oak:misconception-using-place-value-counters-children
  a oakcurric:Misconception ;
  oakcurric:statement """When using place value counters, children may misread a number if one of the digits is a zero and hence not represented with a counter."""@en ;
  oakcurric:correction """Remember that the digits in numbers are organised into groups of three with ones, tens and hundreds in each group."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694133Z"^^xsd:dateTime .

oak:misconception-scaling-values-done-using-addition
  a oakcurric:Misconception ;
  oakcurric:statement "Scaling values can be done using addition and subtraction."@en ;
  oakcurric:correction """The ratio relationship between the values when they are scaled must remain the same."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694138Z"^^xsd:dateTime .

oak:misconception-showing-times-clocks-example-drawing
  a oakcurric:Misconception ;
  oakcurric:statement """When showing times on clocks (for example drawing hands onto blank clock faces or manipulating mini-clocks with movable hands) pupils may not consider the position of the hour hand."""@en ;
  oakcurric:correction """Frequent exposure to both examples and non-examples (such as those in the slide deck) will help pupils to see that the hour hand will not be in an 'o'clock' position if it is ___ minutes to ___."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694142Z"^^xsd:dateTime .

oak:misconception-pupils-generalise-rule-assume-dividing
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may generalise the rule and assume that when dividing by 4 is the last digit is even, then the number is divisible by 4"""@en ;
  oakcurric:correction """Show children the relationship between 2s and 4s using the multiplication chart. Make clear that identifying the last digit as even is the first step - the last 2 digits should be a multiple of 4. Encourage discussions to highlight the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694257Z"^^xsd:dateTime .

oak:misconception-pupils-see-values-like-0
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils see values like 0.25 l and convert it to 25 ml."@en ;
  oakcurric:correction """The lesson presents fractions and decimals as parts of whole circles. As long as pupils know that 1 l = 1,000 ml, they should see from the representation that 0.25 l = 250 ml as 250 + 250 + 250 + 250 = 1,000"""@en ;
  dcterms:modified "2026-02-12T08:59:18.694261Z"^^xsd:dateTime .

oak:misconception-children-believe-smaller-mixed-number
  a oakcurric:Misconception ;
  oakcurric:statement """Children may believe that a smaller mixed number cannot be subtracted from a greater one if its fractional part is greater. E.g. five and three-quarters cannot be subtracted from six and one-quarter."""@en ;
  oakcurric:correction """If the mixed numbers are close to each other, try to ‘find the difference’ by counting forwards on a number line from the part to the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694268Z"^^xsd:dateTime .

oak:misconception-pupils-incorrectly-multiply-divide-100
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils incorrectly multiply and divide by 100 when converting, or multiply and divide by 10 instead."""@en ;
  oakcurric:correction """Continue to emphasise the relationship between one pound and 100 pence and encourage pupils to spot patterns e.g. £2 = 200 p, £3 = 300 p"""@en ;
  dcterms:modified "2026-02-12T08:59:18.694273Z"^^xsd:dateTime .

oak:misconception-pupils-automatically-convert-division-equation
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils automatically convert the division equation to multiply by a unit fraction regardless of the calculation."""@en ;
  oakcurric:correction """Many calculations can be managed through developing a sense of fractions. Where pupils have a sense of fractional magnitude, it is often easier to solve these calculations mentally. Continue to encourage representing these equations using model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694277Z"^^xsd:dateTime .

oak:misconception-finding-perimeter-shape-pupils-count
  a oakcurric:Misconception ;
  oakcurric:statement """When finding the perimeter of a shape, pupils may count one side twice, or not count one of the sides."""@en ;
  oakcurric:correction """Examples and non-examples of perimeter are given but encourage pupils to mark a 'start point' when they find the perimeter of a shape, so that they know where to end."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694286Z"^^xsd:dateTime .

oak:misconception-regular-polygons-include-familiar-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """That regular polygons include all familiar shapes even if they don't meet the definition."""@en ;
  oakcurric:correction """Reinforce the definition and apply to the regular shapes which appear in this lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694291Z"^^xsd:dateTime .

oak:misconception-lack-fluency-6-times-tables
  a oakcurric:Misconception ;
  oakcurric:statement """Lack of fluency in 6 times tables and not understanding the divisibility rules or the problems."""@en ;
  oakcurric:correction """To clearly model highlighting key words of worded problems to understand the problem and the operation required for the calculation. Continue to use language stems such as 'If I know...' 'Then I know...,' to support mathematical thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694295Z"^^xsd:dateTime .

oak:misconception-pupils-find-difficult-connect-calculating
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it difficult to connect calculating with hundreds with known facts."""@en ;
  oakcurric:correction """Pupils need to be encouraged to 'unitise' hundreds to make calculation easier, seeing 500 as 5 lots of one hundred."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694300Z"^^xsd:dateTime .

oak:misconception-pupils-see-other-shapes-collections
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may see other shapes and collections of lines as triangles when they are not (e.g. shapes with rounded corners, three lines that do not all meet)."""@en ;
  oakcurric:correction """Provide pupils with shapes, and explore shapes in the environment, classifying them as 'triangles' and 'not triangles'. Ask children, 'Does this shape have three straight sides? Does it have clearly defined, sharp vertices?'"""@en ;
  dcterms:modified "2026-02-12T08:59:18.694306Z"^^xsd:dateTime .

oak:misconception-representing-time-pupils-remember-minute
  a oakcurric:Misconception ;
  oakcurric:statement """When representing the time, pupils do not always remember that both the minute and the hour hand have a role to play when showing any given time - often leaving the hour hand in the o'clock position."""@en ;
  oakcurric:correction """Lots of examples and non-examples are shown in Cycle 2 of the slide deck to tackle this misconception. However, practice makes perfect. Give frequent quickfire opportunities outside of the Maths lesson for pupils to show times on mini clocks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694311Z"^^xsd:dateTime .

oak:misconception-pupils-find-challenging-use-equations
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it more challenging to use equations starting with the difference, or may make mistakes writing these."""@en ;
  oakcurric:correction """Emphasise the need for balance in equations. Both sides of the equation must be equal. Equations can start with the minuend or the difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694315Z"^^xsd:dateTime .

oak:misconception-children-inaccurately-describe-factor-partitioned
  a oakcurric:Misconception ;
  oakcurric:statement """Children may inaccurately describe which factor has been partitioned to solve a multiplication problem."""@en ;
  oakcurric:correction """Present children with lots of opportunities to create arrays, split them using a partitioning line and describe what they see before going on to use this to calculate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694320Z"^^xsd:dateTime .

oak:misconception-pupils-mistake-numbers-digits-decimal
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils mistake numbers with more digits after the decimal point to be the larger number."""@en ;
  oakcurric:correction """Provide opportunities for pupils to build numbers with base 10 blocks, enabling them to see the magnitude of the numbers they compare."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694326Z"^^xsd:dateTime .

oak:misconception-pupils-rely-heavily-rote-memorisation
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may rely too heavily on rote memorisation and struggle to apply their knowledge in different contexts."""@en ;
  oakcurric:correction """Highlight keywords in the problem to identify the equation needed. Continue to promote understanding by having pupils solve word problems and real-life scenarios involving the 7 times table."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694486Z"^^xsd:dateTime .

oak:misconception-trying-subtract-3-2-example
  a oakcurric:Misconception ;
  oakcurric:statement """Trying to subtract 3 from 2 for example without regrouping and seeing the difference as 1"""@en ;
  oakcurric:correction """Continually acknowledge the whole and the parts in each 'column' so that children know what we have and what is being subtracted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694493Z"^^xsd:dateTime .

oak:misconception-pupils-understand-column-subtraction-use
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand column subtraction. They may use regrouping without grasping the reasoning behind the algorithm."""@en ;
  oakcurric:correction """Ensure that pupils understand the purpose of regrouping and the value of the numbers when they are using column subtraction. Spend more time using base ten blocks with regrouping if pupils are not ready to progress onto the formal algorithm."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694498Z"^^xsd:dateTime .

oak:misconception-e-g-30-mm-equivalent
  a oakcurric:Misconception ;
  oakcurric:statement "E.g. 30 mm is not equivalent to 3 cm because 30 is a larger number."@en ;
  oakcurric:correction """10 mm are equivalent to 1 cm. Millimetres are smaller than centimetres and 10 mm are needed to make an equivalent length to 1 cm."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694502Z"^^xsd:dateTime .

oak:misconception-children-misalign-digits-arranging-short
  a oakcurric:Misconception ;
  oakcurric:statement """Children may misalign digits when arranging into the short multiplication layout."""@en ;
  oakcurric:correction """Children should use unitising language to help them understand and apply this to formal written methods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694513Z"^^xsd:dateTime .

oak:misconception-pupils-look-digits-once-ordering
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may look at all the digits at once when ordering numbers and this may lead to mistakes."""@en ;
  oakcurric:correction """When ordering 3-digit numbers, encourage pupils to compare the 100s digits first and then the 10s digits (and the 1s) afterwards."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694520Z"^^xsd:dateTime .

oak:misconception-pupils-need-able-count-steps
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will need to be able to count in steps of 6 to succeed in this lesson and have a good recall of the 6 times table. Calculation errors will occur frequently if there in insecurity in this area."""@en ;
  oakcurric:correction """Consider pre-teaching pupils still insecure with this, and / or providing scaffolding such as a times tables grid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694525Z"^^xsd:dateTime .

oak:misconception-many-pupils-believe-adding-zero
  a oakcurric:Misconception ;
  oakcurric:statement """Many pupils believe that 'adding zero' is multiplying by 10 which can lead to difficulties later on when they are introduced to decimal numbers."""@en ;
  oakcurric:correction """Don't dismiss it. It's a pattern that has been spotted and generalised. Do encourage the children to work with physical resources that don't involve the numbers themselves so they can understand that it isn't adding zero but changing place value."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694529Z"^^xsd:dateTime .

oak:misconception-pupils-fluency-properties-2d-shapes
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not have fluency in properties of 2D shapes and may therefore not notice properties of angles within quadrilaterals such as trapeziums."""@en ;
  oakcurric:correction """Pre-teaching or providing a scaffold containing shape names and properties will allow pupils to see the properties and support them in making connections."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694647Z"^^xsd:dateTime .

oak:misconception-pupils-significantly-estimate-size-angles
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils significantly over or under-estimate the size of angles, particularly when the initial line of the angle is not vertical or horizontal."""@en ;
  oakcurric:correction """Encourage pupils to rotate the angle so that one of the lines is vertical or horizontal, or if possible, look at the angle from a different point of view which may help to view a line of the angle from a vertical or horizontal position."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694651Z"^^xsd:dateTime .

oak:misconception-pupils-learned-parallelograms-fixed-idea
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils who have learned about parallelograms often have a fixed idea of what they look like and do not realise that squares and other kinds of rectangles are also parallelograms."""@en ;
  oakcurric:correction """The lesson defines parallelograms, giving three criteria, including parallel sides and equal pairs of opposite angles. Reinforce with pupils that these match the set criteria."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694656Z"^^xsd:dateTime .

oak:misconception-children-think-parts-whole-create
  a oakcurric:Misconception ;
  oakcurric:statement """Children might think that the parts of the whole they create in Task B have to be able to fit together to make the same shape as the whole."""@en ;
  oakcurric:correction """Reinforce the concept that the whole is about quantity and not necessarily about shape. Plasticine is a good way to demonstrate this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694661Z"^^xsd:dateTime .

oak:misconception-shape-split-smaller-shapes-order
  a oakcurric:Misconception ;
  oakcurric:statement """That a shape always has to be split into smaller shapes in order to calculate the area."""@en ;
  oakcurric:correction """Show different ways to calculate area using the same shape. It can be split in different ways, completed and an area subtracted or a part cut and fitted into a gap."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694667Z"^^xsd:dateTime .

oak:misconception-need-look-carefully-set-data
  a oakcurric:Misconception ;
  oakcurric:statement """You need to look carefully at a set of data to make sure that the values are reasonable and that calculation of the mean average will give a value that is useful when describing the set and comparing."""@en ;
  oakcurric:correction """Encourage pupils to look carefully at a set of data, identifying values that look unusual and thinking about the impact that they will have if the mean average is calculated. An outlying value in one set of data may be reasonable in another set."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694672Z"^^xsd:dateTime .

oak:misconception-pupils-understand-regrouping-works-column
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not understand how regrouping works with column subtraction."@en ;
  oakcurric:correction """Emphasise with pupils the size of the digits, referring to the tens and the ones. Model using Base 10 blocks so that pupils understand how regrouping works with column subtraction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694679Z"^^xsd:dateTime .

oak:misconception-pupils-find-hard-recognise-right
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find it hard to recognise right angles presented in unusual orientations."""@en ;
  oakcurric:correction """Encourage pupils to continue to check angles with a right angle measurer. Teach them to recognise where vertices are clearly not right angles and differentiate these from ones that could be right angles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694683Z"^^xsd:dateTime .

oak:misconception-pupils-opt-trial-improvement-approach
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils opt for a trial and improvement approach, without working systematically either."""@en ;
  oakcurric:correction """Encourage pupils to identify the structure of the problem and represent the maths in a way that makes sense for them. You can then take their representations of the maths and refine them so they are more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694688Z"^^xsd:dateTime .

oak:misconception-pupils-find-simplifying-fractions-difficult
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may find simplifying fractions difficult and understanding that they first need to identify the highest common factor."""@en ;
  oakcurric:correction """Model writing out fraction pairs and finding the highest common factor. Have worked examples displayed for pupils to reference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694692Z"^^xsd:dateTime .

oak:misconception-children-write-four-quarters-instead
  a oakcurric:Misconception ;
  oakcurric:statement """Children may write 'four-quarters' instead of 'one' or 'one and eight-eighths' instead of '2'. Children may also confuse 'part' and 'marks' when determining the unit that we are working with."""@en ;
  oakcurric:correction """One is composed of four-quarters, but we write '1'. Two is composed of one and eight-eighths but we write '2'. We need to count the equal parts in between the intervals, not the marks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694783Z"^^xsd:dateTime .

oak:misconception-pupils-miscount-squares-moving-shape
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may miscount the squares when moving the shape, leading to inaccurate placement."""@en ;
  oakcurric:correction """Encourage students to carefully count squares from the current position of each vertex and ensure consistency in their counting across the entire shape. Practice counting out loud as a class or in pairs. Relate it to counting on using a number line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694790Z"^^xsd:dateTime .

oak:misconception-unit-fraction-represented-quantity-greater
  a oakcurric:Misconception ;
  oakcurric:statement """When a unit fraction is represented as a quantity greater than one, pupils may think each part of the unit fractions quantity is itself the unit fraction of the whole."""@en ;
  oakcurric:correction """Draw a circle around the quantity each time to encourage pupils to recognise that each set of objects is representative of a quantity that is one part of the whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694795Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-set-long-division
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to set out the long division algorithm correctly."@en ;
  oakcurric:correction """Use the modelling from the lesson to focus on this, especially when writing multiples of the divisor (e.g. 3 tens × 17 = 51 tens) and subtracting this from the dividend."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694808Z"^^xsd:dateTime .

oak:misconception-pupil-automatically-assume-largest-3
  a oakcurric:Misconception ;
  oakcurric:statement """Pupil automatically assume that the largest 3-digit factor will lead to the largest product."""@en ;
  oakcurric:correction """Encourage pupils to think about the multiplicative structure of 'groups' of and consider e.g. whether 30 groups of 52 or 20 groups of 53 will be greater or smaller."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694814Z"^^xsd:dateTime .

oak:misconception-pupils-correctly-identify-right-angles
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not correctly identify right angles within a shape to join them."@en ;
  oakcurric:correction """Make sure that pupils have opportunities to identify right angles within a range of shapes prior to the lesson. If possible, encourage them to mark the right angles to help them. They should only be joining these right angles around a point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694819Z"^^xsd:dateTime .

oak:misconception-pupils-think-removal-multiplication-symbol
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the removal of the multiplication symbol can result in the number becoming a two-digit number rather than two, single digits being multiplied together."""@en ;
  oakcurric:correction """Using the language of 'lots of' may support pupils to see that an algebraic equation with coefficients represents multiplication. For example: 40 can be read as 'four lots of 0'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694824Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-parts-whole-equation
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may confuse the parts and the whole in an equation, especially when there is a missing number."""@en ;
  oakcurric:correction """Bar models are helpful for representing and understanding the parts and the whole. Ensure that pupils understand that minuend and sum both represent a whole. Allow lots of opportunities for pupils to sketch bar models."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694828Z"^^xsd:dateTime .

oak:misconception-pupils-think-one-possible-answer
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that there is only one possible answer to some problems or only one way to solve a problem."""@en ;
  oakcurric:correction """Discuss whether there is only one possible answer to a problem or if there are many solutions. Ensure that more than one approach to solving a problem is modelled where appropriate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694860Z"^^xsd:dateTime .

oak:misconception-pupils-forget-use-zero-place
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils forget the use of zero as a place holder when there are for example, 0 ten thousands in a number, e.g. 503,000"""@en ;
  oakcurric:correction """Encourage children to transfer the represented number into a place value chart prior to reading the number. However, it is important for pupils to be able to read numbers without a place value chart so ensure time is taken to reduce the scaffold too."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694869Z"^^xsd:dateTime .

oak:misconception-pupil-multiply-numerator-denominator-integer
  a oakcurric:Misconception ;
  oakcurric:statement """Pupil may multiply both the numerator and the denominator by the integer therefore finding an equivalent fraction."""@en ;
  oakcurric:correction """Encourage pupils to represent the maths using unitised counters as this will support them to recognise the multiplicand and the multiplier."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694874Z"^^xsd:dateTime .

oak:misconception-children-solve-equation-working-left
  a oakcurric:Misconception ;
  oakcurric:statement """Children will solve an equation by working from left to right and forget that multiplication needs to be completed before addition or subtraction."""@en ;
  oakcurric:correction """Allow plenty of opportunities for children to practise solving equations that cannot be solved working from left to right. You could highlight the operation symbols to draw children's attention to these before they begin to solve them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694878Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-find-missing-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to find missing numbers where they are given the start and end numbers only."""@en ;
  oakcurric:correction """Draw attention to the patterns in the counts (e.g. 5 and 0 of counting in 5s and 50s) so that pupils recognise multiples of numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694885Z"^^xsd:dateTime .

oak:misconception-regroupings-required-pupils-concise-their
  a oakcurric:Misconception ;
  oakcurric:statement "Where regroupings are required, pupils may not be concise in their jottings."@en ;
  oakcurric:correction """Encourage pupils to articulate what each number represents in each calculation, demonstrating the calculations with place value counters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694889Z"^^xsd:dateTime .

oak:misconception-pupils-realise-use-simpler-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not realise they can use simpler multiplication facts to build up to the 7 times table or may not know their times tables facts."""@en ;
  oakcurric:correction """You can provide multiplication charts. Continue to encourage pupils to break down problems involving 7 into smaller, known facts (e.g., 7 × 6 = 5 × 6 + 2 × 6)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695003Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-x-axis-y
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might confuse the x-axis and y-axis, leading them to count along the wrong axis."""@en ;
  oakcurric:correction """Reiterate that the x-axis runs horizontally (left to right) and the y-axis runs vertically (up and down). Use visual aids, like arrows or labels, to clearly mark the axes on the grid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695008Z"^^xsd:dateTime .

oak:misconception-pupils-know-one-method-such
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will often know one method, such as partitioning, and stick to it without trying any others. Sometimes, some  pupils will be very reluctant to move away from written methods such as columns."""@en ;
  oakcurric:correction """Reinforce the idea of bravery and courage to try new methods. Remind them that efficiency is partly about speed and they might find that other methods only become quick with practice!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.695046Z"^^xsd:dateTime .

oak:misconception-pupils-believe-area-one-square
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may believe that an area of one square metre has to be in the shape of a square."""@en ;
  oakcurric:correction """Take two large pieces of paper, each one square metre, and fold them in half in different ways. Bring them together to form a square metre."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695052Z"^^xsd:dateTime .

oak:misconception-pupils-see-larger-numbers-composed
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not see that larger numbers can be composed in different ways."@en ;
  oakcurric:correction """Use place value charts to show pupils how numbers can be composed in different ways (e.g. 1700 = 17 hundreds, 170 tens or 1700 ones). Make clear links to how we can read the number and how this helps us to describe what it is composed of."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695057Z"^^xsd:dateTime .

oak:misconception-pupils-draw-bar-models-inaccurate
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may draw bar models which are inaccurate and do not represent the problem effectively."""@en ;
  oakcurric:correction """These types of problems lend themselves to be drawn using bar models that are lined up one on top of the other. Model creating these bar models with the pupils and explaining how you know where the numbers sit within them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695061Z"^^xsd:dateTime .

oak:misconception-incorrectly-aligning-3-digit-4
  a oakcurric:Misconception ;
  oakcurric:statement "Incorrectly aligning 3-digit and 4-digit numbers resulting in an incorrect sum."@en ;
  oakcurric:correction """Practise partitioning 3 and 4-digit numbers into thousands, hundreds, tens and ones to support when placing in columns. This will also support in understanding the relationship between the columns when regrouping."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695263Z"^^xsd:dateTime .

oak:misconception-pupils-write-y-coordinate-vertical
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might write the y-coordinate (vertical distance) first instead of the x-coordinate (horizontal distance)."""@en ;
  oakcurric:correction """Reinforce the correct order by teaching "x comes before y" just like in the alphabet. Practice with examples and  devices like "along the x-axis, then up the y-axis" to solidify this concept."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695274Z"^^xsd:dateTime .

oak:misconception-theres-one-subtrahend-order-cannot
  a oakcurric:Misconception ;
  oakcurric:statement "When there's more than one subtrahend, the order cannot be changed."@en ;
  oakcurric:correction """Subtrahends can be subtracted from the minuend in any order. They can also be added together before being subtracted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695281Z"^^xsd:dateTime .

oak:misconception-two-shapes-share-dimension-such
  a oakcurric:Misconception ;
  oakcurric:statement """If two shapes share a dimension such as length, they must automatically have the same area."""@en ;
  oakcurric:correction """Print out and enlarge the tasks so the shapes may be cut out and one laid on top of the other so that the difference can be seen."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695286Z"^^xsd:dateTime .

oak:misconception-pupils-record-different-volumes-objects
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may record different volumes for objects if they measure with inconsistent units (for example: different sized cubes)."""@en ;
  oakcurric:correction """Encourage pupils to compare the volume of the same object measured with two different units. Discuss what you notice and draw out the importance for a consistent unit of measure."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695290Z"^^xsd:dateTime .

oak:misconception-children-think-denominator-many-parts
  a oakcurric:Misconception ;
  oakcurric:statement """Children will often think that the denominator is just how many parts a whole has been divided into and forget that the parts must be equal."""@en ;
  oakcurric:correction """If some children are struggling with this then get them to spot examples and non-examples drawn quickly on whiteboards. You can also make connections with sharing food with siblings/friends fairly. Some might endure 'one cuts, one chooses' at home."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695328Z"^^xsd:dateTime .

oak:misconception-pupils-remember-whether-certain-larger
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not remember whether a certain larger unit is comprised of 10, 100 or 1,000 smaller units - all of these are explored at some point in this sequence of lessons."""@en ;
  oakcurric:correction """Spend time discussing the etymology of the words, and have these displayed in your environment. The prefix 'kilo' means 'one thousand' while the prefix 'milli' means 'one thousandth'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695457Z"^^xsd:dateTime .

oak:misconception-pupils-able-identify-key-words
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may not be able to identify the key words leading to the operation."@en ;
  oakcurric:correction """Highlight the keyword and read back the question highlighting the context of the word problem. Words such as 'of' will need exemplifying."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695462Z"^^xsd:dateTime .

oak:misconception-applying-known-facts-strategies-solve
  a oakcurric:Misconception ;
  oakcurric:statement """Applying known facts and strategies to solve problems involving division. Being able to break down a problem into steps when it comes to compound shapes."""@en ;
  oakcurric:correction """Provide opportunities to discuss approaches and highlight the efficient strategies and approaches. Acknowledge that there is more than one way to solve a problem whilst focusing on efficient and effective strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695466Z"^^xsd:dateTime .

oak:misconception-pupils-understand-keyword-adjacent-difficult
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand the keyword adjacent and have difficult understanding the word problems."""@en ;
  oakcurric:correction """Model correct usage in a range of contexts including labelling abstract equations and using the term to identify the known elements in worded problems. Take time to show adjacent on number lines connecting to addition and subtraction of equal groups."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695479Z"^^xsd:dateTime .

oak:misconception-pupils-try-represent-numbers-array
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils try to represent numbers as an array with an unequal amount in rows and columns."""@en ;
  oakcurric:correction """Ensure pupils are given time to explore representing numbers as arrays and identifying where the numbers in a multiplication equation come from within their array."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695488Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-numbers-given-percentages
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may confuse the numbers given and the percentages of them when calculating."""@en ;
  oakcurric:correction """In the lesson, calculating with the numbers given (from 3 to 90) and the percentages of them (e.g. 1% to 30%) is often dealt with separately, looking at individual columns in a table. Columns can be covered when calculating to help focus attention."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695495Z"^^xsd:dateTime .

oak:misconception-looking-expression-such-9-3
  a oakcurric:Misconception ;
  oakcurric:statement """When looking at an expression such as 9 × 3 + 9 × 6 children might be tempted to add first leading to an expression like this: 9 × 12 × 6"""@en ;
  oakcurric:correction """Ensure that you support the equation with the arrays so that pupils understand where the multiplication expressions come from and they can match the partial products to the arrays."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695545Z"^^xsd:dateTime .

oak:misconception-tricky-part-comes-rounding-digit
  a oakcurric:Misconception ;
  oakcurric:statement """The tricky part when it comes to rounding is the digit 5: as the number lines in the lesson illustrate, a 4-digit number ending in 500 is equidistant to the previous and next multiples of 1,000"""@en ;
  oakcurric:correction """Take time to recognise the convention that when the number is equidistant to the previous and next multiple we round to the next multiple. Use examples and non-examples to show this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695549Z"^^xsd:dateTime .

oak:misconception-children-still-try-add-subtract
  a oakcurric:Misconception ;
  oakcurric:statement """Children might still try to add or subtract the denominators as well due to a misunderstanding about the denominator showing what unit-fraction is being used for calculation."""@en ;
  oakcurric:correction """By this stage, buddy checking can be useful. Get the children to check each other periodically but ensure that children can also explain why this is incorrect."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695557Z"^^xsd:dateTime .

oak:misconception-pupils-underestimate-product-example-fractional
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may underestimate the product for example where the fractional part, when multiplied by an integer bridges over a whole."""@en ;
  oakcurric:correction """Encourage pupils to look at the size of the fraction each time and ask whether it will bridge a whole or not and add that onto the estimate of the whole number multiplied by the integer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695562Z"^^xsd:dateTime .

oak:misconception-pupils-think-regrouping-needed-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not think regrouping is needed if the tens are the same digit, but regrouping in the ones can mean regrouping in the tens."""@en ;
  oakcurric:correction """Share examples where regrouping 1 ten as 10 tens means that regrouping is also needed in the tens (e.g. 345 - 148)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695567Z"^^xsd:dateTime .

oak:misconception-questions-lesson-one-possible-answer
  a oakcurric:Misconception ;
  oakcurric:statement """For some questions in this lesson, there is more than one possible answer, but all may not provide the solution to the problem posed. Pupils may give the first (incorrect) answer that they find."""@en ;
  oakcurric:correction """For the second task, encourage pupils to distinguish between questions that only have one solution and those that have multiple solutions. Modelling your thinking throughout the second learning cycle is key to supporting pupils to access the task."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695577Z"^^xsd:dateTime .

oak:misconception-pupils-record-two-digit-hundredth
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may record two-digit hundredth values incorrectly. For example 12 hundredths as 0.012"""@en ;
  oakcurric:correction """Use place value counters to represent the number and demonstrate the regrouping of ten hundredths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695588Z"^^xsd:dateTime .

oak:misconception-children-struggle-describe-changes-accurately
  a oakcurric:Misconception ;
  oakcurric:statement """Children might struggle to describe the changes accurately using mathematical language."""@en ;
  oakcurric:correction """Make good use of your learning walls here to display the key vocabulary and stem sentences for the children to use for the description of the changes in the equations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695613Z"^^xsd:dateTime .

oak:misconception-children-still-building-understanding-same
  a oakcurric:Misconception ;
  oakcurric:statement """Children may still be building understanding that the same fraction can be represented and recorded in different ways. They may still think that the larger the denominator, the larger the fraction."""@en ;
  oakcurric:correction """Make use of the stem sentences to support understanding of how the recording of the fraction relates to the images and contexts used. Model the use of the keywords numerator and denominator and encourage children to use them in explanations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695781Z"^^xsd:dateTime .

oak:misconception-pupils-understand-equals-sign-answer
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils understand the equals sign as 'where the answer is' rather than equality between expressions."""@en ;
  oakcurric:correction """Spend time moving addition and subtraction expressions to either side of the equals sign using numbers within 10 before moving to tenths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695785Z"^^xsd:dateTime .

oak:misconception-pupils-divide-denominator-multiply-numerator
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils divide by the denominator and then multiply by the numerator without any conceptual understanding for why this works."""@en ;
  oakcurric:correction """Ensure pupils spend time exploring how dividing and multiplying by either the numerator or denominator works in relation to a scaling or repeated addition strategy. Encourage pupils to reason when they would use one strategy over the other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695791Z"^^xsd:dateTime .

oak:misconception-children-think-10-mm-larger
  a oakcurric:Misconception ;
  oakcurric:statement "Children may think that 10 mm are larger than 1 cm."@en ;
  oakcurric:correction """There are 10 mm in 1 cm.  1 cm is made up of 10 mm.  10 mm and 1 cm are equivalent in length."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695796Z"^^xsd:dateTime .

oak:misconception-pupils-continue-work-left-right
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils continue to work only from left to right in calculations, therefore making calculations more time-consuming."""@en ;
  oakcurric:correction """Support pupils to find pairs of factors that are easy to multiply with. For example, finding factors that make a power of ten often make calculations easier as they can multiply by 10, 100 or 1000 for example at the end."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695801Z"^^xsd:dateTime .

oak:misconception-pupils-realise-even-one-long
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not realise that, even when one of the long side and short side lengths is missing in a rectangle, they still have enough information as these are the same as the given lengths."""@en ;
  oakcurric:correction """Counters are encouraged in this unit. It may be that some pupils still need the missing side lengths written on counters, but as with all scaffolding, this should only be temporary. Ask them - do you need this counter? Do you already know the number?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.695807Z"^^xsd:dateTime .

oak:misconception-knowing-create-table-bar-model
  a oakcurric:Misconception ;
  oakcurric:statement """Knowing how to create a table or bar model to represent a context presented in words."""@en ;
  oakcurric:correction """Discuss the context to identify the parts and the wholes in order to build an appropriate representation of the context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695812Z"^^xsd:dateTime .

oak:misconception-representing-problems-two-unknowns-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """When representing problems with more than two unknowns, pupils draw bar models all starting from the same end point and with the variables in any order."""@en ;
  oakcurric:correction """Encourage pupils to draw their bar models with the variables lined up underneath one another wherever possible. The bar model may not line up form the left, but this can help to identify the differences between each model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695816Z"^^xsd:dateTime .

oak:misconception-pupils-record-number-factors-square
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils record the number of factors for a square number as even as they record the same number twice when writing down the factors of the square arrangement."""@en ;
  oakcurric:correction """Highlight the need to only record each number as a factor once. You may like to record this on the tail of the factor bug to help emphasise this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695823Z"^^xsd:dateTime .

oak:misconception-pupils-write-subtraction-equations-incorrectly
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils write subtraction equations incorrectly for example: 7.42 = 7 − 0.4 − 0.02"""@en ;
  oakcurric:correction """Create the number using place value counters and subtract parts whilst drawing a part-whole model and writing the equation alongside."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695828Z"^^xsd:dateTime .

oak:misconception-children-struggle-make-connections-division
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to make connections between division and the value of a part."""@en ;
  oakcurric:correction """Support children to understand and describe what they know from the information given, for example, the whole, the size of a part, or the number of parts. Also, what it is that they are trying to find. Encourage representation as a bar model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695938Z"^^xsd:dateTime .

oak:misconception-pupils-get-confused-shapes-almost
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might get confused by shapes which are almost polygons - for example, one of the lines is slightly curved - or almost regular - for example, one side is slightly longer than the others."""@en ;
  oakcurric:correction """These are either not polygons or are irregular polygons. Ensure pupils are clear about that. Examples and non-examples are given, including 'almost' examples. You may wish to include more and display these in your Maths environment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696023Z"^^xsd:dateTime .

oak:misconception-pupils-think-divide-shape-denominator
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that they have to divide the shape by the denominator to create the unit fraction."""@en ;
  oakcurric:correction """This is an example of where a lack of conceptual understanding can lead to procedural errors. Ensure pupils represent the maths using equal parts and label each of these parts as the fractional value they have."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696029Z"^^xsd:dateTime .

oak:misconception-good-multiplication-skills-required-lesson
  a oakcurric:Misconception ;
  oakcurric:statement """Good multiplication skills are required for this lesson, including TO x O and HTO x O."""@en ;
  oakcurric:correction """Pupils who are insecure with short multiplication will need pre-teaching. Consider giving them a scaffold such as a times tables grid."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696033Z"^^xsd:dateTime .

oak:misconception-pupils-understand-addition-commutative-unable
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils do not understand that addition is commutative and are unable to 'swap' addends around."""@en ;
  oakcurric:correction """Use practical equipment and small numbers to show pupils that a sum is still the same even if values are added in different orders."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696038Z"^^xsd:dateTime .

oak:misconception-pupils-think-although-parts-look
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that although parts look different, they cannot represent the same fraction of the whole."""@en ;
  oakcurric:correction """Ensure multiple examples are provided where the fractional parts of the whole look different but instead are equivalent in value. You may like to create a concrete example of each shape and show how it can be manipulated so the parts are equivalent."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696208Z"^^xsd:dateTime .

oak:misconception-one-common-mistakes-pupils-make
  a oakcurric:Misconception ;
  oakcurric:statement """One of the most common mistakes pupils make when reflecting is to flip the shape. Essentially, they translate the shape rather than reflecting it."""@en ;
  oakcurric:correction """Attention is given at the start of the lesson to examples and non-examples of reflections, including the above misconception. Use real mirrors and ask pupils to reflect objects in them, noticing the direction in which the reflection is facing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696212Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-horizontal-calculations-present
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle when horizontal calculations do not present the minuend at the beginning of the equation (e.g. 23 = 44 - 21)."""@en ;
  oakcurric:correction """Discuss with pupils the minuend as the whole. It is the number being subtracted from. In a column subtraction, we always write the minuend first but it does not always appear first in horizontal calculations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696217Z"^^xsd:dateTime .

oak:misconception-pupils-see-number-like-9
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils might see a number like 9.2 m and incorrectly partition it into 9 m and 2 cm."""@en ;
  oakcurric:correction """It is essential that pupils are exposed to lots of examples of visual models, such as parts of circles and number lines, so that they have a secure understanding of why, in this case, the 0.2 m is equal to 20 cm."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696223Z"^^xsd:dateTime .

oak:misconception-pupils-able-regroup-dividing
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils not being able to regroup when dividing."@en ;
  oakcurric:correction """Use concrete resources to highlight regrouping of tens. Ask children 'What is the highest multiple you know?' to support with partitioning."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696230Z"^^xsd:dateTime .

oak:misconception-pupils-think-factor-become-product
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the factor that must become the product of two factors is always the largest factor."""@en ;
  oakcurric:correction """Ensure pupils are provided with a range of opportunities to break down factors, identifying where it does make a calculation easier, and also where it doesn't make the calculation easier."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696234Z"^^xsd:dateTime .

oak:misconception-counting-children-think-1-comes
  a oakcurric:Misconception ;
  oakcurric:statement """When counting, children might think that 1 comes one step after the numerator and denominator are the same. For example, "...five-sevenths, six-sevenths, seven-sevenths, 1"."""@en ;
  oakcurric:correction """As the teacher, count in a given unit fraction and ask the children to stand up, wave or respond in some way when you get to the unit fraction that's equivalent to 1 (when the numerator and denominator are the same)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696802Z"^^xsd:dateTime .

oak:misconception-using-addition-subtraction-connect-parts
  a oakcurric:Misconception ;
  oakcurric:statement """Using addition and subtraction to connect the parts and whole in a ratio context."""@en ;
  oakcurric:correction """Model all relationships at this stage using the language and notation of multiplication and division."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696813Z"^^xsd:dateTime .

oak:misconception-pupils-partition-numbers-incorrectly-adding
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may partition numbers incorrectly when adding or subtracting across a 100s boundary."""@en ;
  oakcurric:correction """Encourage pupils to add or subtract to first the 100s number, using number pairs that total 10 or 100."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696818Z"^^xsd:dateTime .

oak:misconception-children-find-harder-recognise-type
  a oakcurric:Misconception ;
  oakcurric:statement """Some children may find it harder to recognise the type of triangle when they are drawn in different positions and orientations."""@en ;
  oakcurric:correction """Allow time for children to manipulate the triangles so that they can see them in different orientations and build their understanding of the properties of each type of triangle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696824Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-determining-percentage
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes when determining the percentage of different wholes that are not equal in size or value."""@en ;
  oakcurric:correction """Talk about the differences between the different wholes explored. Describe percentage as a proportion of that specific whole. Compare two different wholes where the percentages of them are the same and where the percentages of them are different."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696829Z"^^xsd:dateTime .

oak:misconception-inaccuracy-drawing-mean-pupils-fail
  a oakcurric:Misconception ;
  oakcurric:statement """Inaccuracy when drawing can mean pupils fail to correctly answer questions relating to drawing area."""@en ;
  oakcurric:correction """Access to tools such as visualisers allows the teacher to model drawing lines with great accuracy, using the gridlines to guide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696835Z"^^xsd:dateTime .

oak:misconception-pupils-draw-straight-line-begin
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils draw a straight line to begin to create their angle and then place the centre of the protractor in the middle of the straight line."""@en ;
  oakcurric:correction """Encourage pupils to place the middle spot of the protractor on one end of the straight line as this will make it easier to mark on the second line to create the vertex once the protractor has been removed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696950Z"^^xsd:dateTime .

oak:misconception-pupils-generalise-word-base-recognise
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils often over-generalise the word 'base' and do not recognise that the base is not always horizontal or the 'bottom' part of the shape."""@en ;
  oakcurric:correction """Take time to identify that the base is related to the perpendicular height and show that one triangle can have a different base dependent on where the measurement is taken from. Pupils should consider efficiency when selecting a base."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696954Z"^^xsd:dateTime .

oak:misconception-pupils-see-relationship-numerator-denominator
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not see the relationship between the numerator and denominator in a fraction as an indication of equivalence. They may only see that they can keep doubling the numerator and denominator."""@en ;
  oakcurric:correction """When working with unit fractions, ensure that pupils explain that the denominator is always e.g. 3 times the value of the numerator when fractions are equivalent to e.g. one third. This will focus them on the equivalence and that key relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696968Z"^^xsd:dateTime .

oak:misconception-pupils-mistakenly-plot-y-coordinate
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may mistakenly plot the y-coordinate (vertical distance) first, then the x-coordinate (horizontal distance), leading to incorrect point placement."""@en ;
  oakcurric:correction """Reinforce that the x-coordinate comes first by using mnemonics such as "X before Y, along the ground before you fly." Practice plotting a few points together as a class to build this habit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696972Z"^^xsd:dateTime .

oak:misconception-pupils-able-arrange-digits-within
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not be able to arrange digits within the division frame correctly and work procedurally."""@en ;
  oakcurric:correction """Clear teacher modelling of arrangement of digits using the division frame. Continue to use stem sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696977Z"^^xsd:dateTime .

oak:misconception-mean-average-used-compare-different
  a oakcurric:Misconception ;
  oakcurric:statement """The mean average is used to compare different sets of data. Much of the data we see in the media uses mean average values so it is important to know how these figures are calculated."""@en ;
  oakcurric:correction """Discuss what the mean average of a set of data represents and perhaps look at current news stories or local papers for examples of the mean average used in the media."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696981Z"^^xsd:dateTime .

oak:misconception-pupils-think-product-fraction-shaded
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think the product is only the fraction of the shaded part and not the fraction of the original whole."""@en ;
  oakcurric:correction """Ensure precision in wording when clarifying what the question is asking of each pupil. It is important they recognise how the shaded parts relates back to the original whole each time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696986Z"^^xsd:dateTime .

oak:misconception-pupils-make-connection-10-hundreds
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not make the connection between 10 hundreds, 100 tens and 1 thousand as they may find it difficult to visualise 1,000"""@en ;
  oakcurric:correction """Secure understanding of 1,000 using a range of representations: counting up on number lines divided differently, showing Base 10 blocks that are equivalent to a one thousand block and even exploring within the context of money."""@en ;
  dcterms:modified "2026-02-12T08:59:18.696997Z"^^xsd:dateTime .

oak:misconception-children-difficulty-identifying-number-parts
  a oakcurric:Misconception ;
  oakcurric:statement """Children may have difficulty identifying the number of parts when dealing with cardinality and quantity. For example, dividing a class up into equal groups."""@en ;
  oakcurric:correction """Use a bar model to show a number of children being divided into equal parts. The bar model will then link to the paper strips in the slides."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697001Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-represent-problem-repeated
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to represent the problem as a repeated subtraction equation."@en ;
  oakcurric:correction """Simplify problems by using numbers within 10 at first to reveal the structure of the problem. By doing this, you can show how both the subtraction and addition equations relate, which can help you to find the value of the missing parts or whole."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697010Z"^^xsd:dateTime .

oak:misconception-pupils-add-subtract-numerators-denominators
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils add or subtract the numerators and denominators from eachother to find the solution."""@en ;
  oakcurric:correction """Ensure pupils don't move to abstract equations straight away until they are secure with how addition and subtraction of non-unit fractions can be represented pictorially. You can use unitised language: ___ fifths plus ___ fifths = ___ fifths."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697149Z"^^xsd:dateTime .

oak:misconception-angles-formed-one-horizontal-line
  a oakcurric:Misconception ;
  oakcurric:statement """Angles must always be formed with one horizontal line. Angles must also have two straight lines that are exactly the same length."""@en ;
  oakcurric:correction """Provide pupils with examples where acute, obtuse and reflex angles are shown in a wide range of orientations and where the length of the lines leading into the angles differ in size to support generalising the features of each angle type."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697154Z"^^xsd:dateTime .

oak:misconception-difference-represent-rise-fall-values
  a oakcurric:Misconception ;
  oakcurric:statement """Difference can represent a rise or fall in values so the calculation can have a positive or negative answer. Difference as change is always expressed as a positive value."""@en ;
  oakcurric:correction """Focus on finding equivalent changes in the data presented and ensure that pupils see that the change is a positive value that can be qualified with describing it as a rise or a fall, depending on the situation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697160Z"^^xsd:dateTime .

oak:misconception-composition-1-000-year-4
  a oakcurric:Misconception ;
  oakcurric:statement """Composition of 1,000 is Year 4 content so children may make mistakes when giving masses in kg and g."""@en ;
  oakcurric:correction "Use of stem sentences to help: 1,000 is composed of __ equal parts of __."@en ;
  dcterms:modified "2026-02-12T08:59:18.697167Z"^^xsd:dateTime .

oak:misconception-children-add-subtract-common-factors
  a oakcurric:Misconception ;
  oakcurric:statement """Children may add or subtract the common factors together rather than the uncommon factors."""@en ;
  oakcurric:correction """Use unitising counters or other physical resources to represent each problem and manipulate these to demonstrate the distributive law before showing children the equation that represents it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697171Z"^^xsd:dateTime .

oak:misconception-pupils-recognise-same-type-shape
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not recognise that the same type of shape, such as a pentagon, can have different properties such as parallel or perpendicular lines."""@en ;
  oakcurric:correction """Make use of geoboards if possible to create a pentagon and physically move one vertex. Focus on the fact that the shape still has 5 vertices and discuss what is similar and different."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697176Z"^^xsd:dateTime .

oak:misconception-pupils-resort-trial-improvement-time
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils resort to trial and improvement each time to solve every problem."@en ;
  oakcurric:correction """Pupils should look to apply what they know from previous learning and explore the structure of each problem to help them identify how best to solve it. You could come up with a checklist as a class for how best to explore a new problem each time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697180Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-writing-single
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may make mistakes when writing single-digit percentages as a decimal number (e.g. 3%)."""@en ;
  oakcurric:correction """Remind pupils that percentages are recorded as hundredths. Where is the hundredths column in a decimal number? Writing measurements where one unit is a hundredth of another (e.g. number of pence as a percentage of a pound) may help reinforce this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697185Z"^^xsd:dateTime .

oak:misconception-lots-children-want-make-use
  a oakcurric:Misconception ;
  oakcurric:statement """Lots of children will want to make use of a written method such as column addition straight away without considering the use of mental methods with jottings."""@en ;
  oakcurric:correction """Encourage the children out of their comfort zone by praising efforts  and allowing them to feel motivated by any small successes in the method. Explain to them that this understanding will help them to be better mathematicians in the long run!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.697191Z"^^xsd:dateTime .

oak:misconception-children-think-total-number-within
  a oakcurric:Misconception ;
  oakcurric:statement """Children will often think that the total number within a set is always the denominator as shown in the plates and cupcakes example on the slides."""@en ;
  oakcurric:correction """Put a set of 12 counters (or any countable objects) onto a mini-whiteboard. Children should practise dividing the set into equal groups, drawing rings around them. Repeat, 'The set has been divided into _  equal groups so the denominator is _'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697241Z"^^xsd:dateTime .

oak:misconception-children-estimate-incorrectly-confuse-record
  a oakcurric:Misconception ;
  oakcurric:statement """Children may estimate incorrectly or confuse where to record their measurements in the table."""@en ;
  oakcurric:correction """When estimating, hold an item of known mass in one hand and the unknown in the other - compare them. Take care when reading table headings."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697246Z"^^xsd:dateTime .

oak:misconception-pupils-draw-bar-models-larger
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils draw bar models with larger numbers within them, making them particularly time consuming."""@en ;
  oakcurric:correction """Where larger numbers are used, encourage children to unitise numbers into units of thousands or millions. Equally, if children are secure with what each number represents, they can label each part of the bar with a label from the context itself."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697250Z"^^xsd:dateTime .

oak:misconception-pupils-put-digit-ones-column
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils put a digit in the ones column instead of the tenths column to represent a number of tenths."""@en ;
  oakcurric:correction """Continue to ask what each digit that has been recorded represents, linking back to the place value chart and the role of the decimal point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697358Z"^^xsd:dateTime .

oak:misconception-failing-spot-change-unit-measure
  a oakcurric:Misconception ;
  oakcurric:statement "Failing to spot the change in unit of measure between the scale and real life."@en ;
  oakcurric:correction """Describe the scale and identify the unit of measure used on the map or plan and the unit of measure used in real life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697369Z"^^xsd:dateTime .

oak:misconception-pupils-find-division-trickier-concept
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils often find division a trickier concept than multiplication and do not connect this to their known multiplication facts."""@en ;
  oakcurric:correction """Establish the inverse relationship with multiplication and show how the division equations can be re-written as a multiplication equation with a missing factor. Support pupils in making this connection to allow them to use known facts to calculate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697376Z"^^xsd:dateTime .

oak:misconception-children-further-learn-composition-1
  a oakcurric:Misconception ;
  oakcurric:statement """Children further learn about the composition of 1,000 in Y4, so may make mistakes in reading scales."""@en ;
  oakcurric:correction """Rehearse 1,000 is composed of two equal parts of 500 ml, four equal parts of 250 ml, five equal parts of 200 ml, 10 equal parts of 100 ml."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697381Z"^^xsd:dateTime .

oak:misconception-rather-using-largest-multiple-less
  a oakcurric:Misconception ;
  oakcurric:statement """Rather than using the largest multiple less than or equal to the dividend, children may identify the closest multiple (one that is too high) or one that is less than the dividend but is too low."""@en ;
  oakcurric:correction """Add further examples using counters to explore patterns where one more is added to draw attention to the size of the remainder compared to the divisor. Draw number lines alongside these so children begin to also visualise in a more abstract way."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697390Z"^^xsd:dateTime .

oak:misconception-children-add-subtract-denominator-well
  a oakcurric:Misconception ;
  oakcurric:statement "Children might add or subtract the denominator as well."@en ;
  oakcurric:correction """Reinforce to children that the denominator denotes the unit fraction being used in calculation so does not need changing. Count aloud with physical objects to start with before moving onto counting in unit fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697395Z"^^xsd:dateTime .

oak:misconception-numbers-decimal-rewritten-fraction-one
  a oakcurric:Misconception ;
  oakcurric:statement """The numbers in a decimal can be rewritten as a fraction so one-fifth becomes 1.5 as a decimal and that fractions and decimals do not represent equivalent values."""@en ;
  oakcurric:correction """Read decimals as a number of tenths and hundredths to make the link to fractions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697401Z"^^xsd:dateTime .

oak:misconception-pupils-think-column-subtraction-efficient
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may think that column subtraction is  always the most efficient strategy where regrouping is needed."""@en ;
  oakcurric:correction """Emphasise calculations where adjustment is the most efficient strategy (e.g. 456 - 199). Regrouping is needed in both the tens and hundreds, but is is not the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697406Z"^^xsd:dateTime .

oak:misconception-pupils-mix-directions-example-moving
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may mix up directions, for example, moving left instead of right, or up instead of down. Pupils might start their movement from an incorrect position, leading to an inaccurate final location."""@en ;
  oakcurric:correction """Use clear and consistent language when teaching directions. Reinforce understanding by having students physically point or move in the indicated direction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697509Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-see-relationship-different
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to see the relationship between the different number rods."@en ;
  oakcurric:correction """Take time with pupils for them to explore the use of number rods if they have not done so before. You might ask pupils to find rods that are half the size of different coloured rods, so they can estimate sizes and draw attention to the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697517Z"^^xsd:dateTime .

oak:misconception-errors-column-addition-occur-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """Errors in column addition can occur when pupils fail to align their digits properly."""@en ;
  oakcurric:correction """Encourage pupils to align their decimal points before setting out the rest of the calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697522Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-represent-problems-bar
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils struggle to represent problems as a bar model."@en ;
  oakcurric:correction """Encourage pupils to draw their own image of what the maths represents. Make connections between their own image and a bar model, linking them both to where the numbers are represented in each image."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697527Z"^^xsd:dateTime .

oak:misconception-difference-found-subtracting-subtrahend-minuend
  a oakcurric:Misconception ;
  oakcurric:statement "Difference can only be found by subtracting the subtrahend from the minuend."@en ;
  oakcurric:correction """Subtract the subtrahend from the minuend when they are far apart. When close together, find the difference counting up from the subtrahend."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697531Z"^^xsd:dateTime .

oak:misconception-children-misinterpret-word-problem-especially
  a oakcurric:Misconception ;
  oakcurric:statement """Children may misinterpret a word problem especially where they are insecure on the key words such as 'difference' or 'how much more'."""@en ;
  oakcurric:correction """Teacher should model own thoughts when problem solving and encourage children to represent the word problems in a bar model. Construct bar models alongside a retelling of the problem so children can see where the mathematics is found."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697601Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-starting-equations-sum
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle starting equations with the sum. They may think = means 'the answer is..'"""@en ;
  oakcurric:correction """Ensure that children understand that 'equals' means that the equation balances (i.e. both sides have the same value.) This could be achieved through using balance scales and attaching the idea of equals with balance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697608Z"^^xsd:dateTime .

oak:misconception-children-lack-fluency-recall-multiplication
  a oakcurric:Misconception ;
  oakcurric:statement """Children lack fluency and recall in multiplication tables and therefore lose the thread of longer multiplication strategies."""@en ;
  oakcurric:correction """Providing multiplication grids and / or adapting questions to focus on known multiplication tables can support learners to focus on the steps of an algorithm."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697613Z"^^xsd:dateTime .

oak:misconception-pupils-partition-numbers-incorrectly-arrange
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may partition numbers incorrectly and arrange grid model incorrectly."@en ;
  oakcurric:correction "Clear teacher modelling, ask pupils 'what does this digit represent?'"@en ;
  dcterms:modified "2026-02-12T08:59:18.697619Z"^^xsd:dateTime .

oak:misconception-children-find-difficult-understand-idea
  a oakcurric:Misconception ;
  oakcurric:statement """Children often find it difficult to understand the idea that any whole can be represented by a fraction with the same numerator and denominator."""@en ;
  oakcurric:correction """You might want to list down some different real life examples such as slices of pizza or pie, complete sets of sticker pages, full packs of pens/pencils. Label each example with fraction notation so the children get a firmer understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697633Z"^^xsd:dateTime .

oak:misconception-looking-fraction-notation-children-still
  a oakcurric:Misconception ;
  oakcurric:statement """When looking at fraction notation, children might still be prone to considering the greater denominator to signify a greater fraction."""@en ;
  oakcurric:correction """Get the whole class on board with reminding one another that the greater the denominator, the smaller the fraction. You can model this by making this mistake as you teach and the children can call you out on it - they will enjoy that!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.697640Z"^^xsd:dateTime .

oak:misconception-pupils-think-angles-straight-line
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the angles on a straight line only applied to lines that are horizontal."""@en ;
  oakcurric:correction """Ensure pupils are exposed to straight lines in a range of orientations, encouraging them to draw on the 180 degree angle and how this can apply to both sides of the straight line."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697646Z"^^xsd:dateTime .

oak:misconception-pupils-think-whole-360-degrees
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the whole 360 degrees must be composed of different sized angles."""@en ;
  oakcurric:correction """Ensure pupils are exposed to examples where two or more of the angles summing to 360 degrees are the same."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697652Z"^^xsd:dateTime .

oak:misconception-pupils-think-largest-denominator-related
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that the largest denominator of the related fraction should only be used as the common denominator."""@en ;
  oakcurric:correction """Provide examples where fractions can be scaled up or scaled down to find an appropriate common denominator and encourage pupils to discuss which strategy they prefer and why."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697734Z"^^xsd:dateTime .

oak:misconception-because-area-perimeter-discussed-alongside
  a oakcurric:Misconception ;
  oakcurric:statement """Because area and perimeter are so often discussed alongside each other - as is the case with this lesson - pupils often get the two confused."""@en ;
  oakcurric:correction """By now pupils should be very familiar with area and perimeter, so that they can apply the knowledge to problem solving. However, spend time going over the definitions at the start and ensure pupils have access to visual reminders."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697741Z"^^xsd:dateTime .

oak:misconception-children-see-link-numerator-denominator
  a oakcurric:Misconception ;
  oakcurric:statement """Children do not always see the link between the numerator and the denominator in equivalent fractions. This lesson highlights that link and the fact that the proportion of the whole is the same."""@en ;
  oakcurric:correction """Use the stem sentences and generalisations in the lesson to describe the fractions and to relate them to the representations used."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697745Z"^^xsd:dateTime .

oak:misconception-pupils-record-missing-part-equations
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils record missing part equations incorrectly."@en ;
  oakcurric:correction """Encourage children to match the equation to a representation identifying which number represents the wholes and which represent parts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697750Z"^^xsd:dateTime .

oak:misconception-pupils-make-mistakes-converting-km
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may make mistakes converting from km into m or kg in g."@en ;
  oakcurric:correction """Pupils may need supporting converting units and multiplying by one thousand. Place value charts may be needed here."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697771Z"^^xsd:dateTime .

oak:misconception-relating-elements-multiplication-equation-values
  a oakcurric:Misconception ;
  oakcurric:statement """Relating the elements of the multiplication and equation to the values in the bar models."""@en ;
  oakcurric:correction """Ensure that pupils can explain what the values in the equation represent and where they are in the bar models."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697776Z"^^xsd:dateTime .

oak:misconception-pupils-think-ever-one-right
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may think there is only ever one right angle in an object or shape."@en ;
  oakcurric:correction """Provide opportunities for pupils to explore objects and shapes that have more than one right angle and show that these are not always rectangular e.g. some trapeziums can have more than one right angle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697780Z"^^xsd:dateTime .

oak:misconception-difference-grouping-sharing-distinction-find
  a oakcurric:Misconception ;
  oakcurric:statement """The difference between grouping and sharing is a distinction that some may find tricky to grasp."""@en ;
  oakcurric:correction """Remind children about the importance of understanding the different structures of division when interpreting a story. You could stress the difference, dividing the class into teams using grouping, then sharing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697785Z"^^xsd:dateTime .

oak:misconception-pupils-start-talking-adding-2
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may start talking of 'adding 2 zeros' to multiply by 100"@en ;
  oakcurric:correction """Don't dismiss this as it is disguising an understanding of a pattern but reassure the pupils that this will be explained later through place value discussions in the coming lessons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697789Z"^^xsd:dateTime .

oak:misconception-times-tables-recall-crucial-lessons
  a oakcurric:Misconception ;
  oakcurric:statement """Times tables recall is crucial in these lessons. It provides the platform for children to extend their understanding in combination with what they know about place value."""@en ;
  oakcurric:correction """For children who struggle with times table recall, give them a times table grid to refer to. This lesson is teaching the concept of scaling, not testing their knowledge of times tables."""@en ;
  dcterms:modified "2026-02-12T08:59:18.697794Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-finding-10-1
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle when finding 10% or 1% of numbers that include zero."@en ;
  oakcurric:correction """Draw attention to zero being a placeholder within specific numbers. Some pupils may still need to use resources such as number cards and place value charts to physically move the digits to develop their confidence in dividing by 10 and 100"""@en ;
  dcterms:modified "2026-02-12T08:59:18.697997Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-identify-much-rod
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to identify how much the rod has been scaled by as they cannot visualise the fractional size of the new whole."""@en ;
  oakcurric:correction """Encourage pupils to visualise how much the whole has shrunk by. Avoid pupils using the rods to immediately  find out what size of the new whole, encourage pupils to visualise and estimate prior to checking with the rods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698002Z"^^xsd:dateTime .

oak:misconception-pupils-procedurally-divide-denominator-multiply
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils procedurally divide by the denominator and multiply by the numerator without an understanding for why they do this."""@en ;
  oakcurric:correction """Take time to ensure pupils link how the fraction relates to the bar model. Using the sentence stem 'The whole has been divided into ___ equal parts, and we need ___ of them,' can help to make sense of the fraction in relation to the bar model."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698011Z"^^xsd:dateTime .

oak:misconception-pupils-forget-refer-size-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may forget to refer to the size of the numbers when adding and when regrouping."""@en ;
  oakcurric:correction """Encourage pupils to talk about the place value of the digits. Ten ones can be regrouped as a ten; ten tens can be regrouped as a hundred."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698027Z"^^xsd:dateTime .

oak:misconception-children-struggle-make-connection-unit
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to make the connection between the unit fraction and the division required."""@en ;
  oakcurric:correction """The stem sentence, 'The whole is divided into ___ equal parts. Each equal part is __________ of the whole.'  supports children to grasp this. Support children to make connections between the number of equal parts and the denominator of the fraction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698032Z"^^xsd:dateTime .

oak:misconception-pupils-connect-square-numbers-their
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not connect square numbers to their practical applications in problem-solving."""@en ;
  oakcurric:correction """Highlight key words in the question to help children identify that they can use knowledge of square numbers to find the product."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698037Z"^^xsd:dateTime .

oak:misconception-pupils-try-add-numerators-denominators
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils try to add both the numerators and both the denominators in order to find the sum."""@en ;
  oakcurric:correction """Spend time converting related fractions so that the denominators are common. Use analogies such as adding cats and dogs and needing to rename them as animals or pets to help highlight the need for a common counting unit (or common denominator)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698284Z"^^xsd:dateTime .

oak:misconception-pupils-get-mixed-comes-first
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can get mixed up with which comes first, the x or y axis, when reading/plotting coordinates."""@en ;
  oakcurric:correction """There are lots of aide-mémoires to remember the order. However, regular practice using a stem sentence like the one in the lesson will help."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700404Z"^^xsd:dateTime .

oak:misconception-pupils-still-automaticity-times-tables
  a oakcurric:Misconception ;
  oakcurric:statement """Some pupils may still not have the automaticity of times tables facts useful for this lesson."""@en ;
  oakcurric:correction """Pre-teaching some tricky times tables facts by using counters for arrays will be useful. Consider allowing scaffolds within the lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700696Z"^^xsd:dateTime .

oak:misconception-children-struggle-make-connection-multiplying
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to make the connection between multiplying by 0.1 and dividing by ten."""@en ;
  oakcurric:correction """When we multiply by 0.1, it is the same as multiplying by one-tenth. When we multiply by a unit fraction, we can divide by the denominator - in this case, 10."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700817Z"^^xsd:dateTime .

oak:misconception-pupils-default-using-column-subtraction
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will often default to using the column subtraction method even when it is inefficient."""@en ;
  oakcurric:correction """The slide deck gives examples of when column subtraction can be replaced by quicker, more efficient methods, such as 'counting on'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700837Z"^^xsd:dateTime .

oak:misconception-mistakes-made-identifying-previous-multiple
  a oakcurric:Misconception ;
  oakcurric:statement """Mistakes may be made when identifying the previous multiple of the power of 10 or when giving the rounded answer (missing off any digits that have a larger value)."""@en ;
  oakcurric:correction """Use numbers lines, the stem sentences and learning about the critical digit to support children to identify previous multiples and when giving their answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700957Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-articulate-larger-numbers
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils struggle to articulate larger numbers, confusing when to give the place value unit within the number."""@en ;
  oakcurric:correction """Provide a sentence stem like this: _ _ _ thousand and _ _ _ , encouraging the children to notice the groupings of thousands and ones."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701812Z"^^xsd:dateTime .

oak:misconception-children-automatically-use-formal-written
  a oakcurric:Misconception ;
  oakcurric:statement """Children may automatically use a formal written algorithm. Children may not see the difference between, 'How much more?' and 'How many times more?'"""@en ;
  oakcurric:correction """What do you notice about the numbers? Is there a more efficient way? Can you represent this in a bar model or form an equation. What do you notice about the language?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.702104Z"^^xsd:dateTime .

oak:misconception-children-appreciate-size-one-million
  a oakcurric:Misconception ;
  oakcurric:statement """Children may not appreciate the size of one million or that it is composed of 1,000 thousands. Children may find grasping the concept of 'power of 10' tricky."""@en ;
  oakcurric:correction """Use the place value chart and place value counters to represent the composition of one million. Use the stem sentences: 'One million is composed of 1,000 thousands' and 'Each column is ten times the value to that on its right'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702159Z"^^xsd:dateTime .

oak:misconception-children-understand-concept-nearest-multiple
  a oakcurric:Misconception ;
  oakcurric:statement "Children may not understand the concept of 'nearest multiple of 1,000,000'"@en ;
  oakcurric:correction """The nearest multiple of 1,000,000 is the multiple of 1,000,000 that a given letter or number is closest to. If a number is before than the midpoint, this will be the previous multiple and if it is after, this will be the next multiple."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702218Z"^^xsd:dateTime .

oak:misconception-children-think-greater-value-number
  a oakcurric:Misconception ;
  oakcurric:statement """Children may think that the greater value number is the one that starts with the greater value digit even if the number has fewer digits overall."""@en ;
  oakcurric:correction """When comparing numbers, compare the value of the digits not the digits themselves. If both numbers have the same amount of digits, so we need to compare the largest place value digit that is different."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702287Z"^^xsd:dateTime .

oak:misconception-children-automatically-resort-use-formal
  a oakcurric:Misconception ;
  oakcurric:statement """Children may automatically resort to the use of the formal column algorithms. These are not always the most efficient methods."""@en ;
  oakcurric:correction """What do you notice about the numbers? Is there a mental strategy that you could use?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.702340Z"^^xsd:dateTime .

oak:misconception-many-pupils-come-lesson-believing
  a oakcurric:Misconception ;
  oakcurric:statement "Many pupils will come into the lesson believing that the value of 3 ÷ 0 is 0"@en ;
  oakcurric:correction """Make sure that you use other examples of related multiplication and division equations to show how they can help to disprove the idea that the divisor can be used as zero. Keep them clearly displayed on the learning wall."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703316Z"^^xsd:dateTime .

oak:misconception-pupils-confuse-terminology-factors-multiples
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils confuse the terminology of factors and multiples and mistake them for one another."""@en ;
  oakcurric:correction """Spend time encouraging pupils to identify the factors in an array and within both multiplication and division equations. Make explicit that the product and dividend represent the multiple in each equation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703320Z"^^xsd:dateTime .

oak:misconception-pupils-look-convert-fractions-common
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils look to convert all fractions so that they have a common denominator in order to compare them."""@en ;
  oakcurric:correction """The vast majority of fractions can be compared without common denominators. To support this, pupils need to have a strong sense of the magnitude of the fractions they are comparing. Do not feel you need to move away from bar models too quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703401Z"^^xsd:dateTime .

oak:misconception-lots-pupils-want-calculate-value
  a oakcurric:Misconception ;
  oakcurric:statement """Lots of pupils will want to calculate the value of the expression with the known parts in order to calculate the unknown part without considering a more efficient approach."""@en ;
  oakcurric:correction """Calculating the value of one expression is efficient with simple numbers but encourage the children to try and compare the parts instead. As the numbers get harder, calculating the expression becomes much less efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703408Z"^^xsd:dateTime .

oak:misconception-known-facts-lesson-include-complements
  a oakcurric:Misconception ;
  oakcurric:statement """Known facts in this lesson include complements and two-digit subtractions which some children may find challenging to recall fluently."""@en ;
  oakcurric:correction """It's a good idea, if possible, to do some pre-teaching here to develop the confidence of the children who might find the known facts aspect provides extra cognitive load. Supplying scaffolds such as key bonds to 20 and 100 may also benefit."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703917Z"^^xsd:dateTime .

oak:misconception-pupils-try-make-fraction-simpler
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils try to make a fraction in a simpler form by finding separate factors for the numerator and denominator to simplify."""@en ;
  oakcurric:correction """Share examples for why this cannot be true with images to highlight the difference in the size of the fractions. Draw attention to the fact that it is both the numerator and denominator that needs to be scaled by a common factor."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704340Z"^^xsd:dateTime .

oak:misconception-thinking-change-values-subtraction-addition
  a oakcurric:Misconception ;
  oakcurric:statement """Thinking that you can change the values of subtraction and addition expressions by making the same changes."""@en ;
  oakcurric:correction """Go back and explore what happens when you change different elements of addition and subtraction equations. Use stem sentences from earlier learning to highlight what happens to the sum and difference when values are changed in equations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704345Z"^^xsd:dateTime .

oak:misconception-pupils-rely-same-strategies-solve
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may rely on the same strategies to solve all problems and may find it hard to remember when to add to find the missing part and when to subtract."""@en ;
  oakcurric:correction """Emphasise the use of bar models, especially for pupils who are struggling. This will help them identify whether a part is missing or if the whole is missing, and whether they should add the parts or subtract a part from the whole to get the answer."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704350Z"^^xsd:dateTime .

oak:misconception-children-struggle-language-unitising
  a oakcurric:Misconception ;
  oakcurric:statement "Children may struggle with the language of unitising."@en ;
  oakcurric:correction """Encourage children to read aloud and spot what they notice - which known fact can they see - what is the same/different?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.704718Z"^^xsd:dateTime .

oak:misconception-10-000-anything-same-size
  a oakcurric:Misconception ;
  oakcurric:statement "10,000 of anything is the same in size."@en ;
  oakcurric:correction """Provide a range of contexts which allow pupils to see that 10,000 can be large or small, it is dependent on the context. For example, comparing 10,000 mm with 10,000 miles on a map is a good way to emphasise the difference in distances."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705177Z"^^xsd:dateTime .

oak:misconception-pupils-need-support-identify-operation
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may need support to identify the operation(s) involved in solving a problem and when a problem is presented with mixed units and it is necessary to convert one of them."""@en ;
  oakcurric:correction """Read the problems aloud. Ensure that children identify the operation(s) involved and see this as a clear step in solving the problem. Emphasise the units of measure so that attention is drawn to them and they identify whether conversion is needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705181Z"^^xsd:dateTime .

oak:misconception-children-struggle-make-connection-division
  a oakcurric:Misconception ;
  oakcurric:statement """Children may struggle to make the connection between division and finding a fraction of a quantity."""@en ;
  oakcurric:correction """Support children to see that the denominator of a unit fraction tells us how many equal parts the whole has been divided into and that that is the same as the divisor."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705383Z"^^xsd:dateTime .

oak:misconception-pupils-convert-common-denominators-order
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils convert to common denominators to order fractions rather then use their sense of magnitude for each fraction they are comparing."""@en ;
  oakcurric:correction """Encourage pupils to step back at first from procedure and ask themselves what they notice about the fractions. Can they spot fractions that are equivalent to a quarter or a half?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.705930Z"^^xsd:dateTime .

oak:misconception-lack-fluency-9-times-tables
  a oakcurric:Misconception ;
  oakcurric:statement "Lack of fluency in 9 times tables and not understanding the problems."@en ;
  oakcurric:correction """To clearly model highlighting key words of worded problems to understand the problem and the operation required for the calculation. Continue to use language stems such as 'If I know...' 'Then I know...,' to support mathematical thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706146Z"^^xsd:dateTime .

oak:misconception-children-confuse-multiply-divide-converting
  a oakcurric:Misconception ;
  oakcurric:statement """Children may confuse when to multiply or when to divide when converting between units of measure."""@en ;
  oakcurric:correction """Encourage children to think about which unit of measure is greater e.g. kg are greater than g. In a given amount, there will be fewer of the greater unit so we need to divide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706390Z"^^xsd:dateTime .

oak:misconception-children-get-confused-vocabulary-say
  a oakcurric:Misconception ;
  oakcurric:statement """Children may get confused with the vocabulary when we say, for example, zero point one two rather than zero point twelve. They may also confuse how we write, for example, 32 hundredths."""@en ;
  oakcurric:correction """We say zero point one two to show that there is one tenth and two hundredths. 32 hundredths is composed of 30 hundredths - this is the same as 3 tenths and we have 2 more hundredths so 32 hundredths is written 0.32"""@en ;
  dcterms:modified "2026-02-12T08:59:18.706395Z"^^xsd:dateTime .

oak:misconception-children-get-confused-converting-units
  a oakcurric:Misconception ;
  oakcurric:statement """Children may get confused when converting between units of measure and be unsure when they need to multiply or divide."""@en ;
  oakcurric:correction """___ are smaller than ___, so there must be more of them in the same measure so we need to multiply (and vice versa)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706480Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-understand-purpose-transforming
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle to understand the purpose of transforming calculations using constant difference, especially if they are less confident in calculating using mental strategies."""@en ;
  oakcurric:correction """Show pupils sequences of calculations with a constant difference and get them to spot which of them is easiest to complete. Start as simply as you need to here. Constant difference is a helpful tool not a new method designed to lower confidence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706487Z"^^xsd:dateTime .

oak:misconception-pupils-start-talking-adding-zero
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may start talking of 'adding a zero' to multiply by 10"@en ;
  oakcurric:correction """Don't dismiss this as it is disguising an understanding of a pattern but reassure the pupils that this will be explained later through place value discussions in the coming lessons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706806Z"^^xsd:dateTime .

oak:misconception-pupils-reorder-numbers-forget-reorder
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may reorder the numbers but forget to reorder the operations too."@en ;
  oakcurric:correction """Model the problems using tens frames and number lines, ensuring that pupils understand that both the numbers and operations need to be reordered."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706920Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-apply-multiple-divisibility
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may struggle to apply multiple divisibility rules simultaneously."@en ;
  oakcurric:correction """Have the rules visible, practise applying multiple rules step-by-step to ensure understanding and accuracy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707088Z"^^xsd:dateTime .

oak:misconception-pupils-use-inefficient-calculation-strategies
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils use inefficient calculation strategies such as always using columnar methods."""@en ;
  oakcurric:correction """Promote efficient mental strategies and model clear examples of the use of these."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707096Z"^^xsd:dateTime .

oak:misconception-children-incorrectly-write-amount-tenths
  a oakcurric:Misconception ;
  oakcurric:statement """Children may incorrectly write the amount of tenths e.g. 49 tenths may be written as 0.49"""@en ;
  oakcurric:correction """There are ten tenths in one whole. So e.g. 49 tenths is composed of 4 ones and 9 more tenths. We write this as 4.9"""@en ;
  dcterms:modified "2026-02-12T08:59:18.707323Z"^^xsd:dateTime .

oak:misconception-using-column-addition-regrouping-pupils
  a oakcurric:Misconception ;
  oakcurric:statement """When using column addition with regrouping, pupils put the regrouped digits in the wrong order."""@en ;
  oakcurric:correction """Part of the first lesson cycle includes an example of a pupil getting it wrong, as well as the correct way to show the calculation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707559Z"^^xsd:dateTime .

oak:misconception-pupils-understand-use-patterns-odd
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may not understand how to use patterns of odd and even numbers to make problem-solving easier."""@en ;
  oakcurric:correction """Show that recognising these patterns can help predict results and verify answers (e.g., an even × odd = even)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707639Z"^^xsd:dateTime .

oak:misconception-pupils-think-numerator-denominator-divided
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that any numerator and denominator can be divided by 2 even when the numerator or denominator is odd."""@en ;
  oakcurric:correction """Highlight to children that although it can sometimes be helpful to think of the magnitude of a fraction when the fraction is simplified with a decimal as the numerator or denominator, fractions can only be written with whole numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707643Z"^^xsd:dateTime .

oak:misconception-children-struggle-reading-writing-teen
  a oakcurric:Misconception ;
  oakcurric:statement """Children who struggle reading/writing teen numbers may struggle to read or write larger numbers. Children may group in threes from the left, rather than the right."""@en ;
  oakcurric:correction """Use a place value chart to support the reading of the numbers. Remember to identify the hundreds, tens and ones first, then group in threes to the right of those."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707650Z"^^xsd:dateTime .

oak:misconception-children-believe-one-digit-change
  a oakcurric:Misconception ;
  oakcurric:statement """Children may believe that only one digit will change when adding two numbers where one addend has only one non-zero digit."""@en ;
  oakcurric:correction """This is usually correct but what would happen if the digit changed to a value of 10 or greater? Then we would need to regroup (another lesson)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707705Z"^^xsd:dateTime .

oak:misconception-pupils-think-converting-fraction-its
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils think that converting a fraction to its simplest form is the same as making the fraction smaller or making the numerator have a value of one."""@en ;
  oakcurric:correction """Ensure pupils realise that the numerator and denominator are both scaled to find a different representation of the same sized fraction. Provide examples of fractions where the simplest form does not have a numerator of one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708286Z"^^xsd:dateTime .

oak:misconception-pupils-use-wrong-operation-find
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may use the wrong operation to find missing numbers, adding when they should be subtracting or vice versa."""@en ;
  oakcurric:correction """Encourage pupils to draw bar models, focusing on the whole in the problem. They should also write problems, understanding where the missing number is and rearranging equations so that they can calculate the answers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708293Z"^^xsd:dateTime .

oak:misconception-pupils-default-using-written-algorithm
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils can 'default' to using a written algorithm when learned regardless of the values of the calculation."""@en ;
  oakcurric:correction """Consider using confident mathematicians in a race to show efficiency of different methods. Encourage pupils to 'interrogate' the values of the calculation in order to identify more efficient approaches."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708679Z"^^xsd:dateTime .

oak:misconception-children-think-multiplication-makes-things
  a oakcurric:Misconception ;
  oakcurric:statement """Children may think that multiplication always makes things larger. Children may scale incorrectly."""@en ;
  oakcurric:correction """When a number is multiplied by a value less than 1, the product is smaller than the original number - multiplication doesn't always make things larger. Compare numbers: if one factor is made ___ times the size, the product will be ___ times the size."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708916Z"^^xsd:dateTime .

oak:misconception-pupils-give-incorrect-number-bond
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils will sometimes give incorrect number bond examples such as as 63 + 47 = 100"""@en ;
  oakcurric:correction "Model adding together the tens first."@en ;
  dcterms:modified "2026-02-12T08:59:18.709467Z"^^xsd:dateTime .

oak:misconception-pupils-struggle-reordering-equations-addends
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may struggle when reordering equations where the addends and subtrahends are calculated first (e.g. 455 + 39 - 38)"""@en ;
  oakcurric:correction """Give pupils opportunities to explore the relationship between the addend and subtrahend. They could calculate the answers to problems where the subtrahend is one less than the addend (e.g. 45 + 10 - 9). Can they see a pattern in their answers?"""@en ;
  dcterms:modified "2026-02-12T08:59:18.709609Z"^^xsd:dateTime .

oak:misconception-children-confuse-multiply-divide
  a oakcurric:Misconception ;
  oakcurric:statement "Children may confuse when to multiply or when to divide."@en ;
  oakcurric:correction """Encourage children to think about which unit of measure is larger e.g. km are larger than m. In a given amount, there will be fewer of the larger unit so we need to divide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709644Z"^^xsd:dateTime .

oak:misconception-pupils-try-solve-problems-without
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may try to solve problems without thinking about the numbers involved."@en ;
  oakcurric:correction """Encourage pupils to look at the calculations and think about the numbers involved. Pupils may not get the most efficient method first time so encourage them to think about their responses and learn from what other children have done."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710119Z"^^xsd:dateTime .

oak:misconception-pupils-attempt-learn-many-tens
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils attempt to learn how many tens, hundreds and thousands there are in 100,000 as a set rule rather than develop a sense for this."""@en ;
  oakcurric:correction """Building and breaking 100,000 in different ways can be a really effective way to develop a sense of the number. You could use base 10 blocks to build up to 100,000 where a one cube could be redefined as 100 and then use plasticine to create 10 and 1."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710311Z"^^xsd:dateTime .

oak:misconception-pupils-eager-use-columnar-written
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may be eager to use columnar written methods for larger integers and decimals instead of considering the values and using an efficient strategy."""@en ;
  oakcurric:correction """Emphasise the importance of trying different mental methods so that pupils aren't reliant on written methods that prevent them from fully grasping the underlying structure of additive problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710440Z"^^xsd:dateTime .
