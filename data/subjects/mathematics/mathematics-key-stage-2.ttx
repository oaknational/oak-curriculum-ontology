oak:keylearningpoint-lesson-3757-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you add 9 to a multiple of nine you get the next multiple of nine."@en ;
  dcterms:modified "2026-02-12T08:59:21.744868Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3757-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you subtract 9 from a multiple of nine you get the previous multiple of nine."@en ;
  dcterms:modified "2026-02-12T08:59:21.744873Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3758-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Adjacent multiples of nine have a difference of 9 and alternate between odd and even numbers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744995Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3758-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you add 9 to a multiple of nine you get the next multiple of nine."@en ;
  dcterms:modified "2026-02-12T08:59:21.744999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3758-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If you subtract 9 from a multiple of nine you get the previous multiple of nine."@en ;
  dcterms:modified "2026-02-12T08:59:21.745005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3898-1
  a oakcurric:KeyLearningPoint ;
