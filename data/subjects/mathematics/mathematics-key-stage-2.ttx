  dcterms:modified "2026-02-12T08:59:21.656057Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4135-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A protractor is used to draw and measure angles accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.656082Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4135-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Read the scale from zero on a protractor to draw and measure angles accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.656087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4135-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Read the scale from zero on a ruler to draw and measure accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.656091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3595-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By looking carefully at the numbers involved, you can choose the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656096Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3595-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When numbers are close together, finding the difference is the most efficient strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656100Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3595-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sometimes, we can use known addition facts to make finding the difference even more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656105Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4240-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The mean value of a set of data is the total of the numbers divided by how many numbers there are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656109Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4240-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If a value in the set is zero it is still included in the calculation of the mean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656116Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7145-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Long division records the subtraction as a calculation underneath the dividend."@en ;
  dcterms:modified "2026-02-12T08:59:21.656121Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7145-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Long division records the regrouping alongside the subtraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.656125Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7145-3
