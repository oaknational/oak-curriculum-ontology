  dcterms:modified "2026-02-12T08:59:21.658078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3925-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "If the dividend is not a multiple of the divisor, there will be a remainder."@en ;
  dcterms:modified "2026-02-12T08:59:21.658083Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3925-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the remainder is a number of tens, you can exchange the tens for ones and continue to divide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658090Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3925-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the number of ones is not a multiple of the divisor, there will be a remainder as part of the quotient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658097Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3928-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the tens number is not a multiple of the divisor then the remainder is recorded next to the ones digit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658102Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3928-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If there is a remainder after dividing the tens digit the tens are exchanged and the ones digit becomes a 2-digit number"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658107Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3928-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If the number of ones, including any exchanged tens, is not a multiple of the divisor, there will be a remainder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658112Z"^^xsd:dateTime .

