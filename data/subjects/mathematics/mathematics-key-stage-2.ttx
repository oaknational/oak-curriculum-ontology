oak:keylearningpoint-lesson-3886-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """If 7 + 3 is equal to 10 then 7 hundredths + 3 hundredths is equal to 10 hundredths which is equal to one tenth 0.1"""@en ;
  dcterms:modified "2026-02-12T08:59:21.610616Z"^^xsd:dateTime .

