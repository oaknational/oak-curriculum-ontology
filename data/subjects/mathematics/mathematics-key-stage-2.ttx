  dcterms:modified "2026-02-12T08:59:21.612369Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3849-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A line of symmetry does not have to be vertical or horizontal. You can reflect shapes in a diagonal line of symmetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3849-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You can reflect a shape by counting the position of each vertex and making a mark, and then joining the marks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612384Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-3849-3
  a oakcurric:KeyLearningPoint ;
