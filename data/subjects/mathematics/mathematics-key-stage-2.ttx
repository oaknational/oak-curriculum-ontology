  schema:description """An interval is what is between two values. On a scale, intervals are shown using a small mark or line to show the space between."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799068Z"^^xsd:dateTime .

oak:keyword-proper-fraction
  a oakcurric:Keyword ;
  schema:name "Proper fraction"@en ;
  schema:description """A proper fraction is a fraction where the numerator (the top number) is less than the denominator (the bottom number)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.799085Z"^^xsd:dateTime .

oak:keyword-doubling
  a oakcurric:Keyword ;
  schema:name "doubling"@en ;
