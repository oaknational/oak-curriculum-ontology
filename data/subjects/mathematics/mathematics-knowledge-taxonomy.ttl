  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise mixed numbers and improper fractions and convert from one form to the other and write mathematical statements > 1 as a mixed number [for example, [Fraction:2/5]+[Fraction:4/5] = [Fraction:6/5] = 1 [Fraction:1/5] ]"@en ;
  curric:displayOrder "20"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
