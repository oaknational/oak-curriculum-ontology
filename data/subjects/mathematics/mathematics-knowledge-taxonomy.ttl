  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Add and subtract fractions with different denominators and mixed numbers, using the concept of equivalent fractions"@en ;
  curric:displayOrder "26"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
