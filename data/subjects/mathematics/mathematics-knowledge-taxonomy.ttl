  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Select appropriate concepts, methods and techniques to apply to unfamiliar and non-routine problems; interpret their solution in the context of the given problem"@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
