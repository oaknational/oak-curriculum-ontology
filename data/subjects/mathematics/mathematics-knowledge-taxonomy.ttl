  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-multiplication-commutative-property
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Show that multiplication of 2 numbers can be done in any order (commutative) and division of 1 number by another cannot"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-multiplication-and-division ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-solve-multiplication-division-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve problems involving multiplication and division, using materials, arrays, repeated addition, mental methods, and multiplication and division facts, including problems in contexts"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-multiplication-and-division ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-multiplication-tables-3-4-8
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recall and use multiplication and division facts for the 3, 4 and 8 multiplication tables"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-multiplication-and-division ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-calculate-multiplication-division-statements-2-digit
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Write and calculate mathematical statements for multiplication and division using the multiplication tables that they know, including for two-digit numbers times one-digit numbers, using mental and progressing to formal written methods"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-multiplication-and-division ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

