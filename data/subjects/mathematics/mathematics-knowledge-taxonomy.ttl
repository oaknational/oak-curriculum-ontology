natcurric:contentdescriptor-algebraic-notation
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use and interpret algebraic notation, including: ab in place of a × b; 3y in place of y + y + y and 3 × y; a² in place of a × a, a³ in place of a × a × a; a²b in place of a × a × b; [Fraction:a/b] in place of a ÷ b; coefficients written as fractions rather than as decimals; brackets."@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-substitute-formulae-expressions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Substitute numerical values into formulae and expressions, including scientific formulae"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

