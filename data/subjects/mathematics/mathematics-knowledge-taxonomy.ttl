  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Describe simple mathematical relationships between 2 variables (bivariate data) in observational and experimental contexts and illustrate using scatter graphs"@en ;
  curric:displayOrder "14"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-infer-populations-sampling-limitations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Infer properties of populations or distributions from a sample, whilst knowing the limitations of sampling"@en ;
  curric:displayOrder "15"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-time-series-tables-graphs
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret and construct tables and line graphs for time series data"@en ;
  curric:displayOrder "16"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-histograms-cumulative-frequency-graphs
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{construct and interpret diagrams for grouped discrete data and continuous data, ie, histograms with equal and unequal class intervals and cumulative frequency graphs, and know their appropriate use}"@en ;
  curric:displayOrder "17"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-discrete-continuous-grouped-data
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret, analyse and compare the distributions of data sets from univariate empirical distributions through appropriate graphical representation involving discrete, continuous and grouped data, {including box plots}"@en ;
  curric:displayOrder "18"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-central-tendency-spread
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret, analyse and compare the distributions of data sets from univariate empirical distributions through appropriate measures of central tendency (including modal class) and spread {including quartiles and inter-quartile range}"@en ;
  curric:displayOrder "19"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-apply-statistics-describe-population
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Apply statistics to describe a population"@en ;
  curric:displayOrder "20"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-scatter-graphs-correlation-predictions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use and interpret scatter graphs of bivariate data; recognise correlation and know that it does not indicate causation; draw estimated lines of best fit; make predictions; interpolate and extrapolate apparent trends whilst knowing the dangers of so doing."@en ;
  curric:displayOrder "21"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

