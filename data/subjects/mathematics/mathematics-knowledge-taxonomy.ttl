  skos:prefLabel "Working Mathematically"@en ;
  skos:definition "Description of strand..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-mathematics ;
  skos:narrower 
    natcurric:substrand-develop-fluency ,
    natcurric:substrand-reason-mathematically ,
    natcurric:substrand-solve-problems ;
