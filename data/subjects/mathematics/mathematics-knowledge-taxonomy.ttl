# ======================================================================
# National Curriculum for England - Mathematics Knowledge Taxonomy 
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/mathematics-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Mathematics Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Mathematics Knowledge Taxonomy"@en ;
  rdfs:comment """Mathematics knowledge taxonomy for the National Curriculum in England, 
  organizing content through strands, sub-strands, content descriptors, and sub-content 
  descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/mathematics-knowledge-taxonomy/0.1.0> ;
  
  dcterms:description """Mathematics knowledge taxonomy for the National Curriculum in England, 
  organizing content through strands, sub-strands, content descriptors, and sub-content 
  descriptors."""@en ;
  dcterms:created "2025-11-24T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  
  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/core/> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/mathematics-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-mathematics ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .
  
# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-mathematics
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "Mathematics"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower 
    natcurric:strand-working-mathematically,
    natcurric:strand-number ,
    natcurric:strand-algebra ,
    natcurric:strand-multiplicative-reasoning ,
    natcurric:strand-geometry-measurement-spacial-reasoning ,
    natcurric:strand-data-literacy ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-working-mathematically
