  skos:narrower natcurric:subcontentdescriptor-generate-theoretical-sample-spaces-single ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

natcurric:contentdescriptor-describe-interpret-compare-observed-distributions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Describe, interpret and compare observed distributions of a single variable
  through: appropriate graphical representation involving discrete, continuous and grouped
  data; and appropriate measures of central tendency (mean, mode, median) and spread (range,
  consideration of outliers)."""@en ;
  skos:broader natcurric:substrand-mathematics-statistics ;
  skos:narrower natcurric:subcontentdescriptor-describe-interpret-compare-observed-distributions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

natcurric:contentdescriptor-construct-interpret-appropriate-tables-charts
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Construct and interpret appropriate tables, charts, and diagrams, including
  frequency tables, bar charts, pie charts, and pictograms for categorical data, and
  vertical line (or bar) charts for ungrouped and grouped numerical data."""@en ;
  skos:broader natcurric:substrand-mathematics-statistics ;
  skos:narrower natcurric:subcontentdescriptor-construct-interpret-appropriate-tables-charts ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

natcurric:contentdescriptor-describe-simple-mathematical-relationships
  a skos:Concept, curric:ContentDescriptor ;
