  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Derive and apply formulae to calculate and solve problems involving: perimeter and area of triangles, parallelograms, trapezia, volume of cuboids (including cubes) and other prisms (including cylinders)"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geometry-and-measures ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-perimeters-areas-circles-composite
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Calculate and solve problems involving: perimeters of 2-D shapes (including circles), areas of circles and composite shapes"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geometry-and-measures ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

