  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve one-step and two-step questions [for example ‘How many more?’ and ‘How many fewer?’] using information presented in scaled bar charts and pictograms and tables"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-present-graphical-data
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret and present discrete and continuous data using appropriate graphical methods, including bar charts and time graphs"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-comparison-sum-difference-graphs-tables
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve comparison, sum and difference problems using information presented in bar charts, pictograms, tables and other graphs"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-comparison-sum-difference-line-graph
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve comparison, sum and difference problems using information presented in a line graph"@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-tables-timetables
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Complete, read and interpret information in tables, including timetables"@en ;
  curric:displayOrder "9"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-pie-charts-line-graphs
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret and construct pie charts and line graphs and use these to solve problems"@en ;
  curric:displayOrder "10"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-calculate-mean-average
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Calculate and interpret the mean as an average"@en ;
  curric:displayOrder "11"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-distributions-central-tendency-spread
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Describe, interpret and compare observed distributions of a single variable through: appropriate graphical representation involving discrete, continuous and grouped data; and appropriate measures of central tendency (mean, mode, median) and spread (range, consideration of outliers)"@en ;
  curric:displayOrder "12"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-construct-interpret-tables-charts
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Construct and interpret appropriate tables, charts, and diagrams, including frequency tables, bar charts, pie charts, and pictograms for categorical data, and vertical line (or bar) charts for ungrouped and grouped numerical data"@en ;
  curric:displayOrder "13"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

