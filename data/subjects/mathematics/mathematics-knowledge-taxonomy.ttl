  skos:prefLabel """Record, describe and analyse the frequency of outcomes of simple probability
  experiments involving randomness, fairness, equally and unequally likely outcomes, using
  appropriate language and the 0-1 probability scale."""@en ;
  skos:broader natcurric:substrand-probability ;
  skos:narrower natcurric:subcontentdescriptor-record-describe-analyse-frequency-outcomes ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

natcurric:contentdescriptor-probabilities-possible-outcomes-sum-1
  a skos:Concept, curric:ContentDescriptor ;
