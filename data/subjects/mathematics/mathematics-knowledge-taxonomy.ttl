  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-equations-identities-arguments-proofs
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Know the difference between an equation and an identity; argue mathematically to show algebraic expressions are equivalent, and use algebra to support and construct arguments {and proofs}"@en ;
  curric:displayOrder "25"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-functions-inverse-composite
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Where appropriate, interpret simple expressions as functions with inputs and outputs; {interpret the reverse process as the ‘inverse function’; interpret the succession of 2 functions as a ‘composite function’}"@en ;
  curric:displayOrder "26"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-parallel-perpendicular-lines-equations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use the form y = mx + c to identify parallel {and perpendicular} lines; find the equation of the line through 2 given points, or through 1 point with a given gradient"@en ;
  curric:displayOrder "27"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-quadratic-roots-turning-points-completing-square
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Identify and interpret roots, intercepts and turning points of quadratic functions graphically; deduce roots algebraically {and turning points by completing the square}"@en ;
  curric:displayOrder "28"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-graphs-all-function-types
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise, sketch and interpret graphs of linear functions, quadratic functions, simple cubic functions, the reciprocal function y = [Fraction:1/x] with x ≠ 0, {the exponential function y = kx for positive values of k, and the trigonometric functions (with arguments in degrees) y = sin x, y = cos x and y = tan x for angles of any size}"@en ;
  curric:displayOrder "29"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-sketch-transformations-functions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{sketch translations and reflections of the graph of a given function}"@en ;
  curric:displayOrder "30"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-graphs-real-contexts
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Plot and interpret graphs (including reciprocal graphs {and exponential graphs}) and graphs of non-standard functions in real contexts, to find approximate solutions to problems such as simple kinematic problems involving distance, speed and acceleration"@en ;
  curric:displayOrder "31"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-gradients-areas-graphs-interpret
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{calculate or estimate gradients of graphs and areas under graphs (including quadratic and other non-linear graphs), and interpret results in cases such as distance-time graphs, velocity-time graphs and graphs in financial contexts}"@en ;
  curric:displayOrder "32"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-circle-equations-tangents
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{recognise and use the equation of a circle with centre at the origin; find the equation of a tangent to a circle at a given point}"@en ;
  curric:displayOrder "33"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-solve-quadratics-all-methods
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve quadratic equations {including those that require rearrangement} algebraically by factorising, {by completing the square and by using the quadratic formula}; find approximate solutions using a graph"@en ;
  curric:displayOrder "34"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-simultaneous-equations-linear-quadratic
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve 2 simultaneous equations in 2 variables (linear/linear {or linear/quadratic}) algebraically; find approximate solutions using a graph"@en ;
  curric:displayOrder "35"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-numerical-iteration-solutions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{find approximate solutions to equations numerically using iteration}"@en ;
  curric:displayOrder "36"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-translate-derive-interpret-equations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Translate simple situations or procedures into algebraic expressions or formulae; derive an equation (or 2 simultaneous equations), solve the equation(s) and interpret the solution"@en ;
  curric:displayOrder "37"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-solve-all-inequalities
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve linear inequalities in 1 {or 2} variable {s}, {and quadratic inequalities in 1 variable}; represent the solution set on a number line, {using set notation and on a graph}"@en ;
  curric:displayOrder "38"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-recognise-all-sequence-types
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise and use sequences of triangular, square and cube numbers, simple arithmetic progressions, Fibonacci type sequences, quadratic sequences, and simple geometric progressions (rn where n is an integer, and r is a positive rational number {or a surd}) {and other sequences}"@en ;
  curric:displayOrder "39"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-nth-term-linear-quadratic
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Deduce expressions to calculate the nth term of linear {and quadratic} sequences."@en ;
  curric:displayOrder "40"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-algebra ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-probability-experiments-frequency-outcomes
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Record, describe and analyse the frequency of outcomes of simple probability experiments involving randomness, fairness, equally and unequally likely outcomes, using appropriate language and the 0-1 probability scale"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-probabilities-sum-to-one
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Understand that the probabilities of all possible outcomes sum to 1"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-enumerate-sets-venn-diagrams
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Enumerate sets and unions/intersections of sets systematically, using tables, grids and Venn diagrams"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-theoretical-sample-spaces-probabilities
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Generate theoretical sample spaces for single and combined events with equally likely, mutually exclusive outcomes and use these to calculate theoretical probabilities"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-exhaustive-mutually-exclusive-events
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Apply the property that the probabilities of an exhaustive set of mutually exclusive events sum to 1"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-probability-model-empirical-theoretical
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use a probability model to predict the outcomes of future experiments; understand that empirical unbiased samples tend towards theoretical probability distributions, with increasing sample size"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-independent-dependent-combined-events
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Calculate the probability of independent and dependent combined events, including using tree diagrams and other representations, and know the underlying assumptions"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-conditional-probabilities
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "{calculate and interpret conditional probabilities through representation using expected frequencies with two-way tables, tree diagrams and Venn diagrams}"@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-probability ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-construct-data-representations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret and construct simple pictograms, tally charts, block diagrams and tables"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-ask-answer-counting-questions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Ask and answer simple questions by counting the number of objects in each category and sorting the categories by quantity"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-questions-comparing-categorical-data
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Ask-and-answer questions about totalling and comparing categorical data"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-present-data
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret and present data using bar charts, pictograms and tables"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-statistics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

