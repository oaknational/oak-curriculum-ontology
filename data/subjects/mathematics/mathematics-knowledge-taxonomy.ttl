  skos:broader natcurric:substrand-probability ;
  skos:narrower natcurric:subcontentdescriptor-probabilities-possible-outcomes-sum-1 ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-06T15:20:11Z"^^xsd:dateTime .

natcurric:contentdescriptor-enumerate-sets-unions-intersections-sets
  a skos:Concept, curric:ContentDescriptor ;
