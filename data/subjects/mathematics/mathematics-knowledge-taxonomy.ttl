  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Compare and order fractions, including fractions >1"@en ;
  curric:displayOrder "25"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
