natcurric:contentdescriptor-recognise-percent-symbol
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise the per cent symbol (%) and understand that per cent relates to ‘number of parts per 100’, and write percentages as a fraction with denominator 100, and as a decimal fraction"@en ;
  curric:displayOrder "9"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-percentage-decimal-equivalents
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve problems which require knowing percentage and decimal equivalents of [Fraction:1/2], [Fraction:1/4], [Fraction:1/5], [Fraction:2/5], [Fraction:4/5] and those fractions with a denominator of a multiple of 10 or 25"@en ;
  curric:displayOrder "10"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-decimal-places-multiply-divide
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Identify the value of each digit in numbers given to 3 decimal places and multiply and divide numbers by 10, 100 and 1,000 giving answers up to 3 decimal places"@en ;
  curric:displayOrder "11"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-multiply-decimals-whole-numbers
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Multiply one-digit numbers with up to 2 decimal places by whole numbers"@en ;
  curric:displayOrder "12"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-written-division-decimal-answers
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use written division methods in cases where the answer has up to 2 decimal places"@en ;
  curric:displayOrder "13"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-round-specified-accuracy
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve problems which require answers to be rounded to specified degrees of accuracy"@en ;
  curric:displayOrder "14"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-fractions-decimals-percentages-equivalences
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recall and use equivalences between simple fractions, decimals and percentages, including in different contexts"@en ;
  curric:displayOrder "15"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-decimals-and-percentages ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-recognise-half
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise, find and name a half as 1 of 2 equal parts of an object, shape or quantity"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-recognise-quarter
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise, find and name a quarter as 1 of 4 equal parts of an object, shape or quantity"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-recognise-fractions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise, find, name and write fractions [Fraction:1/3], [Fraction:1/4], [Fraction:2/4] and [Fraction:3/4] of a length, shape, set of objects or quantity"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-write-simple-fractions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Write simple fractions, for example [Fraction:1/2] of 6 = 3 and recognise the equivalence of [Fraction:2/4] and [Fraction:1/2]"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-count-recognise-tenths
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Count up and down in tenths; recognise that tenths arise from dividing an object into 10 equal parts and in dividing one-digit numbers or quantities by 10"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
