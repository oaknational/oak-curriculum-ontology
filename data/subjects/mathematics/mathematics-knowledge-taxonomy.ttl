  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-fractions-discrete-sets
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise, find and write fractions of a discrete set of objects: unit fractions and non-unit fractions with small denominators"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-fractions-as-numbers
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Recognise and use fractions as numbers: unit fractions and non-unit fractions with small denominators"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-fractions ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

