natcurric:contentdescriptor-multiply-formal-written-layout
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Multiply two-digit and three-digit numbers by a one-digit number using formal written layout"@en ;
  curric:displayOrder "12"^^xsd:positiveInteger ;
