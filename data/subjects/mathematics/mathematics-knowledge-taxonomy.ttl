  skos:prefLabel "Read Roman numerals to 100 (I to C) and know that over time, the numeral system changed to include the concept of 0 and place value"@en ;
  curric:displayOrder "24"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-read-write-compare-to-1000000
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Read, write, order and compare numbers to at least 1,000,000 and determine the value of each digit"@en ;
  curric:displayOrder "25"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-count-powers-of-10
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Count forwards or backwards in steps of powers of 10 for any given number up to 1,000,000"@en ;
  curric:displayOrder "26"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-negative-numbers
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret negative numbers in context, count forwards and backwards with positive and negative whole numbers, including through 0"@en ;
  curric:displayOrder "27"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-round-to-1000000
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Round any number up to 1,000,000 to the nearest 10, 100, 1,000, 10,000 and 100,000"@en ;
  curric:displayOrder "28"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-solve-number-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Solve number and practical problems that involve all of the above"@en ;
  curric:displayOrder "29"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-roman-numerals-to-1000
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Read Roman numerals to 1,000 (M) and recognise years written in Roman numerals"@en ;
  curric:displayOrder "30"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-read-write-to-10000000
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Read, write, order and compare numbers up to 10,000,000 and determine the value of each digit"@en ;
  curric:displayOrder "31"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-round-required-accuracy
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Round any whole number to a required degree of accuracy"@en ;
  curric:displayOrder "32"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-negative-numbers-intervals
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use negative numbers in context, and calculate intervals across 0"@en ;
  curric:displayOrder "33"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-place-value ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-extend-number-system-place-value
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Consolidate their numerical and mathematical capability from key stage 2 and extend their understanding of the number system and place value to include decimals, fractions, powers and roots"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-calculation-strategies-complex-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Select and use appropriate calculation strategies to solve increasingly complex problems"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-algebra-generalise-arithmetic
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use algebra to generalise the structure of arithmetic, including to formulate mathematical relationships"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-substitute-rearrange-solve-equations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Substitute values in expressions, rearrange and simplify expressions, and solve equations"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-representations-fractions-decimals-equations-graphs
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Move freely between different numerical, algebraic, graphical and diagrammatic representations [for example, equivalent fractions, fractions and decimals, and equations and graphs]"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-algebraic-graphical-fluency
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Develop algebraic and graphical fluency, including understanding linear and simple quadratic functions"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-analyse-mathematical-properties
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use language and properties precisely to analyse numbers, algebraic expressions, 2-D and 3-D shapes, probability and statistics"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-extend-number-system-powers-roots
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Consolidate their numerical and mathematical capability from key stage 3 and extend their understanding of the number system to include powers, roots {and fractional indices}"@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-calculation-strategies-complex-problems-exact
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Select and use appropriate calculation strategies to solve increasingly complex problems, including exact calculations involving multiples of π {and surds}, use of standard form and application and interpretation of limits of accuracy"@en ;
  curric:displayOrder "9"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-algebraic-simplification-quadratic-expressions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Consolidate their algebraic capability from key stage 3 and extend their understanding of algebraic simplification and manipulation to include quadratic expressions, {and expressions involving surds and algebraic fractions}"@en ;
  curric:displayOrder "10"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-quadratic-simultaneous-equations-inequalities
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Extend fluency with expressions and equations from key stage 3, to include quadratic equations, simultaneous equations and inequalities"@en ;
  curric:displayOrder "11"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-representations-linear-quadratic-reciprocal-functions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Move freely between different numerical, algebraic, graphical and diagrammatic representations, including of linear, quadratic, reciprocal, {exponential and trigonometric} functions"@en ;
  curric:displayOrder "12"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-mathematical-language-properties-precisely
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use mathematical language and properties precisely"@en ;
  curric:displayOrder "13"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-develop-fluency ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-extend-number-system-connections
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Extend their understanding of the number system; make connections between number relationships, and their algebraic and graphical representations"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-ratio-proportion-algebraic-relations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Extend and formalise their knowledge of ratio and proportion in working with measures and geometry, and in formulating proportional relations algebraically"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-identify-variables-express-relations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Identify variables and express relations between variables algebraically and graphically"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-conjectures-patterns-relationships
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Make and test conjectures about patterns and relationships; look for proofs or counter-examples"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-deductive-reasoning-geometrical-constructions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Begin to reason deductively in geometry, number and algebra, including using geometrical constructions"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-interpret-reasoning-problem-structure
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Interpret when the structure of a numerical problem requires additive, multiplicative or proportional reasoning"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-statistical-probabilistic-inference
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Explore what can and cannot be inferred in statistical and probabilistic settings, and express their arguments formally"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-ratio-proportion-trigonometric-ratios
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Extend and formalise their knowledge of ratio and proportion, including trigonometric ratios, in working with measures and geometry, and in working with proportional relations algebraically and graphically"@en ;
  curric:displayOrder "8"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-extend-identify-variables-express-relations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Extend their ability to identify variables and express relations between variables algebraically and graphically"@en ;
  curric:displayOrder "9"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-conjectures-proofs-arguments
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Make and test conjectures about the generalisations that underlie patterns and relationships; look for proofs or counter-examples; begin to use algebra to support and construct arguments {and proofs}"@en ;
  curric:displayOrder "10"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-deductive-reasoning-constructions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Reason deductively in geometry, number and algebra, including using geometrical constructions"@en ;
  curric:displayOrder "11"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-assess-validity-accuracy-arguments
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Assess the validity of an argument and the accuracy of a given way of presenting information"@en ;
  curric:displayOrder "12"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-reason-mathematically ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-develop-knowledge-solving-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Develop their mathematical knowledge, in part through solving problems and evaluating the outcomes, including multi-step problems"@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-formal-knowledge-financial-mathematics
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Develop their use of formal mathematical knowledge to interpret and solve problems, including in financial mathematics"@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-model-situations-mathematical-representations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Begin to model situations mathematically and express the results using a range of formal mathematical representations"@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-methods-unfamiliar-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Select appropriate concepts, methods and techniques to apply to unfamiliar and non-routine problems"@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-formal-knowledge-financial-contexts
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Develop their use of formal mathematical knowledge to interpret and solve problems, including in financial contexts"@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-connections-between-mathematics
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Make and use connections between different parts of mathematics to solve problems"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-solve-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

