  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Associate a fraction with division and calculate decimal fraction equivalents [for example, 0.375] for a simple fraction [for example, [Fraction:3/8]]"@en ;
  curric:displayOrder "29"^^xsd:positiveInteger ;
