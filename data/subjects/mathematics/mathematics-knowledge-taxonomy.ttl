  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use the standard conventions for labelling the sides and angles of triangle ABC, and know and use the criteria for congruence of triangles"@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-geometry-and-measures ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-derive-properties-plane-figures
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Derive and illustrate properties of triangles, quadrilaterals, circles, and other plane figures [for example, equal lengths and angles] using appropriate language and technologies"@en ;
  curric:displayOrder "7"^^xsd:positiveInteger ;
