<https://w3id.org/uk/oak/curriculum/oakcurriculum/music-key-stage-4>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Music Key Stage 4 Instance Data"@en ;
  dc:title "Oak Curriculum Data - Music Key Stage 4 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for Music Key Stage 4."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/music-key-stage-4/0.1.1> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Music Key Stage 4, including exam board-specific unit variants and lesson sequences."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2026-05-25T00:00:00Z"^^xsd:dateTime ;
  dcterms:modified "2026-06-07T15:30:50.473941Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-25T00:00:00Z"^^xsd:dateTime ;

