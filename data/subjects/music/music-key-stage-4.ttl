oakcurric:keyword-gat
  a curric:Keyword ;
  schema:name "Gat"@en ;
  schema:description """The second section, where the tabla joins in is called gat. It has a more
  fixed melody."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397810Z"^^xsd:dateTime .

oakcurric:keyword-jhala
  a curric:Keyword ;
  schema:name "Jhala"@en ;
  schema:description "The final section, where the tempo and energy builds, is called jhala."@en ;
  dcterms:modified "2026-06-07T15:30:02.397817Z"^^xsd:dateTime .

oakcurric:keyword-raga
  a curric:Keyword ;
  schema:name "Raga"@en ;
  schema:description """A raga is a set of notes used to create a composition. Each raga has a
  specific mood associated with it."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397823Z"^^xsd:dateTime .

oakcurric:keyword-tala
  a curric:Keyword ;
  schema:name "Tala"@en ;
  schema:description """A tala is a repeating rhythmic pattern in North Indian classical music. They
  are taught by ear, using the sounds 'da', 'din' and 'ta'."""@en ;
  dcterms:modified "2026-06-07T15:30:02.397981Z"^^xsd:dateTime .

oakcurric:keyword-teental
  a curric:Keyword ;
  schema:name "Teental"@en ;
  schema:description "Teental is a 16-beat tala often used in North Indian classical music."@en ;
  dcterms:modified "2026-06-07T15:30:02.397986Z"^^xsd:dateTime .

oakcurric:keyword-trill
  a curric:Keyword ;
  schema:name "trill"@en ;
  schema:description "a type of ornamentation based on alternating rapidly between two notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.398261Z"^^xsd:dateTime .

oakcurric:keyword-mordent
  a curric:Keyword ;
  schema:name "mordent"@en ;
  schema:description "a type of ornamentation that creates the effect of a short trill"@en ;
  dcterms:modified "2026-06-07T15:30:02.398266Z"^^xsd:dateTime .

oakcurric:keyword-grace-note
  a curric:Keyword ;
  schema:name "grace note"@en ;
  schema:description """a very fast note that plays just before a main melodic note: it is sometimes
  referred to as an acciaccatura"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398271Z"^^xsd:dateTime .

oakcurric:keyword-imitation
  a curric:Keyword ;
  schema:name "imitation"@en ;
  schema:description """a melodic device in which part of the melody is copied immediately in
  another part"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398276Z"^^xsd:dateTime .

oakcurric:keyword-ritardando
  a curric:Keyword ;
  schema:name "ritardando"@en ;
  schema:description "a gradual slowing down of tempo; rallentando creates a similar effect"@en ;
  dcterms:modified "2026-06-07T15:30:02.398315Z"^^xsd:dateTime .

oakcurric:keyword-swing-quavers
  a curric:Keyword ;
  schema:name "swing quavers"@en ;
  schema:description """the first quaver in each pair has a slightly longer duration than the second
  quaver"""@en ;
  dcterms:modified "2026-06-07T15:30:02.398320Z"^^xsd:dateTime .

oakcurric:keyword-linear-loop
  a curric:Keyword ;
  schema:name "linear loop"@en ;
  schema:description "a repeating musical idea in a video game that can be looped indefinitely"@en ;
  dcterms:modified "2026-06-07T15:30:02.399570Z"^^xsd:dateTime .

oakcurric:keyword-adaptive-music
  a curric:Keyword ;
  schema:name "adaptive music"@en ;
  schema:description """music that can change by reacting to a stimulus; video game music reacts to
  the player's actions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399575Z"^^xsd:dateTime .

oakcurric:keyword-vertical-layering
  a curric:Keyword ;
  schema:name "vertical layering"@en ;
  schema:description """where layers of music are 'stacked' on top of each other and change in
  response to the player’s actions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399581Z"^^xsd:dateTime .

oakcurric:keyword-tremolo
  a curric:Keyword ;
  schema:name "tremolo"@en ;
  schema:description "alternating between two notes rapidly; sounds like a trembling effect"@en ;
  dcterms:modified "2026-06-07T15:30:02.400983Z"^^xsd:dateTime .

oakcurric:keyword-minor
  a curric:Keyword ;
  schema:name "minor"@en ;
  schema:description "the minor scale is organised around the note la and can feel dark"@en ;
  dcterms:modified "2026-06-07T15:30:02.408440Z"^^xsd:dateTime .

oakcurric:keyword-coherence
  a curric:Keyword ;
  schema:name "coherence"@en ;
  schema:description "the quality of forming a unified whole"@en ;
  dcterms:modified "2026-06-07T15:30:02.409915Z"^^xsd:dateTime .

oakcurric:keyword-motivic-transformation
  a curric:Keyword ;
  schema:name "motivic transformation"@en ;
  schema:description "when a motif is changed to represent a change in a story or character"@en ;
  dcterms:modified "2026-06-07T15:30:02.411491Z"^^xsd:dateTime .

oakcurric:keyword-theme-song
  a curric:Keyword ;
  schema:name "theme song"@en ;
  schema:description """a piece of music that introduces a film or game and captures its overall
  atmosphere"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411591Z"^^xsd:dateTime .

oakcurric:keyword-horizontal-resequencing
  a curric:Keyword ;
  schema:name "horizontal resequencing"@en ;
  schema:description "where a new section of music begins in response to a player's action"@en ;
  dcterms:modified "2026-06-07T15:30:02.411688Z"^^xsd:dateTime .

oakcurric:keyword-musical-clich
  a curric:Keyword ;
  schema:name "musical cliché"@en ;
  schema:description "a commonly used musical idea or association"@en ;
  dcterms:modified "2026-06-07T15:30:02.411720Z"^^xsd:dateTime .

oakcurric:keyword-choir-chorus
  a curric:Keyword ;
  schema:name "choir / chorus"@en ;
  schema:description """a group of singers, often including soprano, alto, tenor and bass voices
  (SATB)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411886Z"^^xsd:dateTime .

oakcurric:keyword-lied
  a curric:Keyword ;
  schema:name "lied"@en ;
  schema:description """a solo song, most common in the Romantic period, usually with piano
  accompaniment (plural 'lieder')"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411893Z"^^xsd:dateTime .

oakcurric:keyword-recitative
  a curric:Keyword ;
  schema:name "recitative"@en ;
  schema:description "a vocal style that sounds semi-spoken, often used for dialogue in opera"@en ;
  dcterms:modified "2026-06-07T15:30:02.411899Z"^^xsd:dateTime .

oakcurric:keyword-word-painting
  a curric:Keyword ;
  schema:name "word-painting"@en ;
  schema:description """where a vocal melody reflects the meaning of the words (e.g. a descending
  melody on the word ‘falls’)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411905Z"^^xsd:dateTime .

oakcurric:keyword-melisma
  a curric:Keyword ;
  schema:name "melisma"@en ;
  schema:description "where multiple notes are sung during one syllable of a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.411913Z"^^xsd:dateTime .

oakcurric:keyword-musical-element
  a curric:Keyword ;
  schema:name "Musical element"@en ;
  schema:description """the building blocks of music, which include rhythm, melody, harmony,
  structure and others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413092Z"^^xsd:dateTime .

oakcurric:keyword-musical-purpose
  a curric:Keyword ;
  schema:name "Musical purpose"@en ;
  schema:description """what the piece of music is trying to achieve; this could be to represent
  something, encourage an action or create a mood or emotion"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413098Z"^^xsd:dateTime .

oakcurric:keyword-synthesiser
  a curric:Keyword ;
  schema:name "synthesiser"@en ;
  schema:description "an electronic musical instrument"@en ;
  dcterms:modified "2026-06-07T15:30:02.413332Z"^^xsd:dateTime .

oakcurric:keyword-rhythm-section
  a curric:Keyword ;
  schema:name "rhythm section"@en ;
  schema:description """the group of instruments supporting the singer in a band and includes the
  guitar/piano, bass and drum kit"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413522Z"^^xsd:dateTime .

oakcurric:keyword-phrases
  a curric:Keyword ;
  schema:name "phrases"@en ;
  schema:description "a short section of a melody, often lasting 1, 2 or 4 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.414060Z"^^xsd:dateTime .

oakcurric:keyword-passing-notes
  a curric:Keyword ;
  schema:name "passing notes"@en ;
  schema:description "a non-chord tone that links two chord tones by step"@en ;
  dcterms:modified "2026-06-07T15:30:02.414065Z"^^xsd:dateTime .

oakcurric:keyword-primary-chord
  a curric:Keyword ;
  schema:name "Primary chord"@en ;
  schema:description "the most useful chords in a key - chord I (1), IV (4) and V (5)"@en ;
  dcterms:modified "2026-06-07T15:30:02.414152Z"^^xsd:dateTime .

oakcurric:keyword-secondary-chord
  a curric:Keyword ;
  schema:name "Secondary chord"@en ;
  schema:description "chords ii (2), iii (3) and vi (6) in a key"@en ;
  dcterms:modified "2026-06-07T15:30:02.414158Z"^^xsd:dateTime .

oakcurric:keyword-salsa
  a curric:Keyword ;
  schema:name "Salsa"@en ;
  schema:description "Salsa is a style of music and dance that developed from Cuban son music."@en ;
  dcterms:modified "2026-06-07T15:30:02.414250Z"^^xsd:dateTime .

oakcurric:keyword-montuno
  a curric:Keyword ;
  schema:name "Montuno"@en ;
  schema:description """A montuno is a syncopated, repeating piano pattern that is typical
  of salsa."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414256Z"^^xsd:dateTime .

oakcurric:keyword-merengue
  a curric:Keyword ;
  schema:name "Merengue"@en ;
  schema:description """Merengue is a style of music and dance from the Dominican Republic that
  often uses traditional Dominican instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414266Z"^^xsd:dateTime .

oakcurric:keyword-quintillo
  a curric:Keyword ;
  schema:name "Quintillo"@en ;
  schema:description """A quintillo is a rhythmic pattern of five fast notes that is a typical
  feature of merengue."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414272Z"^^xsd:dateTime .

oakcurric:keyword-distortion
  a curric:Keyword ;
  schema:name "Distortion"@en ;
  schema:description "Distortion is a fuzzy effect often added to guitar sounds."@en ;
  dcterms:modified "2026-06-07T15:30:02.414283Z"^^xsd:dateTime .

oakcurric:keyword-ska
  a curric:Keyword ;
  schema:name "ska"@en ;
  schema:description """Ska is an upbeat style of music that emerged in the late 1960s in Jamaica.
  It later developed into a style called rocksteady."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414304Z"^^xsd:dateTime .

oakcurric:keyword-reggae
  a curric:Keyword ;
  schema:name "reggae"@en ;
  schema:description """Reggae is a style that emergend in the late 1960s and became an important
  global style."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414312Z"^^xsd:dateTime .

oakcurric:keyword-skank
  a curric:Keyword ;
  schema:name "skank"@en ;
  schema:description """The skank rhythm is a defining feature of reggae that emphasises offbeat
  quavers."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414318Z"^^xsd:dateTime .

oakcurric:keyword-reggae-bubble
  a curric:Keyword ;
  schema:name "reggae bubble"@en ;
  schema:description "The reggae bubble is a typical organ pattern that emphasises offbeats."@en ;
  dcterms:modified "2026-06-07T15:30:02.414323Z"^^xsd:dateTime .

oakcurric:keyword-one-drop
  a curric:Keyword ;
  schema:name "one-drop"@en ;
  schema:description """The one-drop beat is a typical reggae drum beat, which removes the usual
  emphasis on beat one."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414328Z"^^xsd:dateTime .

oakcurric:keyword-power-chord
  a curric:Keyword ;
  schema:name "Power chord"@en ;
  schema:description """A power chord is a two-note chord often used on guitars, which uses the root
  note and the fifth of a triad chord."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414710Z"^^xsd:dateTime .

oakcurric:keyword-verse-chorus-form
  a curric:Keyword ;
  schema:name "verse-chorus form"@en ;
  schema:description """a common structure in popular music styles that is based around alternating
  verses and choruses"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414750Z"^^xsd:dateTime .

oakcurric:keyword-rhythm-guitar
  a curric:Keyword ;
  schema:name "rhythm guitar"@en ;
  schema:description "the rhythm guitar plays accompanying parts - usually riffs and chords"@en ;
  dcterms:modified "2026-06-07T15:30:02.415033Z"^^xsd:dateTime .

oakcurric:keyword-lead-guitar
  a curric:Keyword ;
  schema:name "lead guitar"@en ;
  schema:description "the lead guitar plays riffs, melodies and solos in a rock band"@en ;
  dcterms:modified "2026-06-07T15:30:02.415039Z"^^xsd:dateTime .

oakcurric:keyword-pop-ballad
  a curric:Keyword ;
  schema:name "pop ballad"@en ;
  schema:description """a pop ballad is an important genre of pop music - typically a slow song with
  romantic or sentimental lyrics"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415044Z"^^xsd:dateTime .

oakcurric:keyword-melismatic-melisma
  a curric:Keyword ;
  schema:name "melismatic / melisma"@en ;
  schema:description """melismatic singing is when a singer sings more than one note (often many
  notes) during a syllable of a word; it is also called melisma"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415049Z"^^xsd:dateTime .

oakcurric:keyword-transposition
  a curric:Keyword ;
  schema:name "transposition"@en ;
  schema:description """Transposition is a group of notes up or down in pitch so the intervals
  between the notes are the same but the pitch is different."""@en ;
  dcterms:modified "2026-06-07T15:30:02.415054Z"^^xsd:dateTime .

oakcurric:keyword-block-chord
  a curric:Keyword ;
  schema:name "block chord"@en ;
  schema:description """A block chord is a chord in which the notes are played together, at the same
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.415068Z"^^xsd:dateTime .

oakcurric:keyword-hammer-on
  a curric:Keyword ;
  schema:name "hammer-on"@en ;
  schema:description """a hammer-on is a technique where the guitarist presses their finger into a
  fret to play a note, rather than plucking the string"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415122Z"^^xsd:dateTime .

oakcurric:keyword-tapping
  a curric:Keyword ;
  schema:name "tapping"@en ;
  schema:description """tapping is a guitar technique in which both hands 'tap' the frets, allowing
  very fast patterns to be played"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415130Z"^^xsd:dateTime .

oakcurric:keyword-harmonic
  a curric:Keyword ;
  schema:name "harmonic"@en ;
  schema:description """a harmonic is a very high-pitched sound that guitarists often play to add
  excitement to solos"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415135Z"^^xsd:dateTime .

oakcurric:keyword-classical-period
  a curric:Keyword ;
  schema:name "Classical period"@en ;
  schema:description "the period of Western classical music between 1750 and 1820"@en ;
  dcterms:modified "2026-06-07T15:30:02.419882Z"^^xsd:dateTime .

oakcurric:keyword-symphony
  a curric:Keyword ;
  schema:name "symphony"@en ;
  schema:description """a long composition for orchestra, usually consisting of four shorter pieces
  (movements)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.419890Z"^^xsd:dateTime .

oakcurric:keyword-sonata
  a curric:Keyword ;
  schema:name "sonata"@en ;
  schema:description """a three-movement solo composition, and a structure with exposition,
  development and recapitulation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.419896Z"^^xsd:dateTime .

oakcurric:keyword-musical-effect
  a curric:Keyword ;
  schema:name "Musical effect"@en ;
  schema:description """the impact that a certain musical idea or device has, for example this could
  be creating a certain mood or feeling"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421234Z"^^xsd:dateTime .

oakcurric:keyword-arpeggiated
  a curric:Keyword ;
  schema:name "Arpeggiated"@en ;
  schema:description """a pattern that uses the notes of an arpeggio (an ascending or descending
  broken chord)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421774Z"^^xsd:dateTime .

oakcurric:keyword-melodic-device
  a curric:Keyword ;
  schema:name "Melodic device"@en ;
  schema:description """specific techniques used in melodies, including ornamentation and
  sequences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421780Z"^^xsd:dateTime .

oakcurric:keyword-harmonic-device
  a curric:Keyword ;
  schema:name "Harmonic device"@en ;
  schema:description """composition techniques that affect the harmony, including pedals and
  modulations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421785Z"^^xsd:dateTime .

oakcurric:keyword-rhythmic-dictation
  a curric:Keyword ;
  schema:name "rhythmic dictation"@en ;
  schema:description "the process of listening to a rhythm and writing it down"@en ;
  dcterms:modified "2026-06-07T15:30:02.422873Z"^^xsd:dateTime .

oakcurric:keyword-verbalise
  a curric:Keyword ;
  schema:name "verbalise"@en ;
  schema:description """to express with words (for example, verbalising a rhythm is turning a rhythm
  into words)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.422878Z"^^xsd:dateTime .

oakcurric:keyword-note-value
  a curric:Keyword ;
  schema:name "note value"@en ;
  schema:description """how long a note lasts for (for example, a crotchet has a note value of one
  beat)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.422884Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-3rds-5ths-octaves-work-disjunct
  a curric:Misconception ;
  curric:statement "Only 3rds, 5ths and octaves work as disjunct intervals in a melody."@en ;
  curric:correction """This is not true: all intervals (except sevenths) can work effectively, as
  long as they jump between chord tones. If intervals jump to or from non-chord tones, the
  melody will sound ineffective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083798Z"^^xsd:dateTime .

oakcurric:misconception-long-chord-tones-chord-played
  a curric:Misconception ;
  curric:statement """As long as the chord tones in the chord are played, it doesn't matter how
  these notes are split between the 2nd violin and viola."""@en ;
  curric:correction """This does matter. The voicing of the chord makes a big difference to how it
  sounds. Avoiding large intervals between those instruments, and making sure that the
  chords aren't very low or high pitched makes them sound effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083821Z"^^xsd:dateTime .

oakcurric:misconception-use-root-position-chords-sparingly
  a curric:Misconception ;
  curric:statement """You should use root position chords sparingly because they sound
  uninteresting."""@en ;
  curric:correction """Not necessarily. Root position chords are important because they anchor the
  music in the key. Most chords in a chord sequence should be root position, with some
  inversions used to add interst and variety."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083833Z"^^xsd:dateTime .

oakcurric:misconception-rules-writing-chord-sequence
  a curric:Misconception ;
  curric:statement "There are no 'rules' for writing a chord sequence."@en ;
  curric:correction """While to some extent this is true, in Western classical music there are very
  typical patterns that are used very regularly. These include the position of perfect and
  imperfect cadences, and what the chords do throughout the 16 bars."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084034Z"^^xsd:dateTime .

oakcurric:misconception-using-new-ideas-bar-best
  a curric:Misconception ;
  curric:statement "Using new ideas in every bar is the best way to compose a melody"@en ;
  curric:correction """Finding a balance of repetition and variety is usually more successful as it
  helps the melody become memorable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084039Z"^^xsd:dateTime .

oakcurric:misconception-baroque-music-contrapuntal-polyphonic
  a curric:Misconception ;
  curric:statement "All Baroque music is contrapuntal / polyphonic."@en ;
  curric:correction """Textures are varied in the Baroque period, but use of contrapuntal/polyphonic
  textures was very common and contrasts with the later Classical period. This is a typical
  texture of the period, but not the only one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084399Z"^^xsd:dateTime .

oakcurric:misconception-music-romantic-period-love-romance
  a curric:Misconception ;
  curric:statement "Music from the Romantic period is all about love and romance."@en ;
  curric:correction """The word Romantic in the musical sense has nothing to do with love or
  romance, this was just the name given to the period. The music was often intense, emotive
  and dramatic, and might sometimes link to ideas of love, but it was very varied."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084432Z"^^xsd:dateTime .

oakcurric:misconception-harmony-tonality-same-thing
  a curric:Misconception ;
  curric:statement "Harmony and tonality are the same thing."@en ;
  curric:correction """Tonality is to the type of notes and chords that are used (e.g. major).
  Harmony is the way the notes and chords are used within that key. Think of tonality as a
  language (e.g. English) and harmony as the word choice and order in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084724Z"^^xsd:dateTime .

oakcurric:misconception-music-baroque-classical-romantic-periods
  a curric:Misconception ;
  curric:statement """Most music in the Baroque, Classical and Romantic periods was written for an
  orchestra."""@en ;
  curric:correction """Although a lot of the most famous music now is orchestral, it was much more
  diverse than this - composers wrote for many different ensembles, large and small. These
  included solo compositions, duets, trios, quartets, quintets and many others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085565Z"^^xsd:dateTime .

oakcurric:misconception-non-functional-harmony-sounds-same
  a curric:Misconception ;
  curric:statement "Non-functional harmony sounds the same as functional harmony."@en ;
  curric:correction """While some of the chords might be the same, the difference is in the role. In
  functional harmony, chords have specific roles (e.g. V coming before I to create
  resolution). In non-functional harmony, any chord can be used whenever the composer wants."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085752Z"^^xsd:dateTime .

oakcurric:misconception-romantic-music-related-love-romance
  a curric:Misconception ;
  curric:statement "Romantic music is related to love and romance."@en ;
  curric:correction """This is not the case - the name is not related to that. Romantic composers
  focused on creating expression, emotion and evocative moods in their music. Sometimes this
  would have links with love, but not always."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085998Z"^^xsd:dateTime .

oakcurric:misconception-period-single-defining-texture-e
  a curric:Misconception ;
  curric:statement "Each period had a single defining texture (e.g. Baroque = polyphonic)."@en ;
  curric:correction """There were typical uses of texture for each period. For example, Baroque
  composers often used polyphonic textures, much more than Classical composers. However,
  within each period, there were examples of all textures being used and lots of variety."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086004Z"^^xsd:dateTime .

oakcurric:misconception-use-same-verbalisation-compound-time
  a curric:Misconception ;
  curric:statement """You can use the same verbalisation in compound time as simple time
  signatures."""@en ;
  curric:correction """This will create problems, because there are 3 quavers in each beat in
  compound time. The counting method in compound time avoids confusion by ensuring there are
  three quavers in each beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086894Z"^^xsd:dateTime .

oakcurric:misconception-orchestra-grown-adding-same-instruments
  a curric:Misconception ;
  curric:statement """The orchestra has only grown through the adding of more of the same
  instruments."""@en ;
  curric:correction """The number of players has increased, but the variety of instruments has also
  increased. Many different instruments have been added to the orchestra since the 1600s,
  including brass, woodwind, percussion and keyboard instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086955Z"^^xsd:dateTime .

oakcurric:misconception-singing-useful-singers
  a curric:Misconception ;
  curric:statement "Singing is only useful for singers."@en ;
  curric:correction """When identifying intervals, singing is incredibly useful, even for those who
  aren't confident singers. Hearing the intervals back through singing or humming allows us
  to compare them to the reference melodies. Without this, it is much harder."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089651Z"^^xsd:dateTime .

oakcurric:misconception-advanced-musicians-work-set-notes
  a curric:Misconception ;
  curric:statement "Only advanced musicians can work out a set of notes by listening to them."@en ;
  curric:correction """Anyone can work out notes by ear, if they practise the correct strategies.
  Identifying the melodic shape, representing it with a line, then carefully converting it
  into notes is an effective first step in melodic dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089663Z"^^xsd:dateTime .

oakcurric:misconception-notes-melody-changed-makes-new
  a curric:Misconception ;
  curric:statement "If the notes of a melody are changed, that just makes it a new melody."@en ;
  curric:correction """Changing the notes of a melody does create a new melody, but if it is still
  recognisable as related to the original, we can consider it a developed version of the
  melody. If it is unrecognisable, then it is not a development but a totally new melody."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089699Z"^^xsd:dateTime .

oakcurric:misconception-chord-iv-v-sound-same
  a curric:Misconception ;
  curric:statement """Chord IV and V sound the same, so plagal and perfect cadences sound
  the same."""@en ;
  curric:correction """They sound similar, but not identical. Picking out the bass note is the key -
  if you can hear that note, you can work out how it relates to the tonic, so can work out
  which chord (and cadence) you are listening to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089839Z"^^xsd:dateTime .

oakcurric:misconception-compound-time-signatures-create-complex
  a curric:Misconception ;
  curric:statement """Compound time signatures create more complex sounding music and aren't used
  often."""@en ;
  curric:correction """This isn't strictly true. Compound time signatures are extremely common,
  including in popular music styles. While the theory of them is slightly more complex than
  simple time signatures, to compose or play using them is not particularly difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089945Z"^^xsd:dateTime .

oakcurric:misconception-homophonic-melody-accompaniment-textures-same
  a curric:Misconception ;
  curric:statement "Homophonic and melody and accompaniment textures are the same thing."@en ;
  curric:correction """Melody and accompaniment is a specific type of homophonic texture, often
  called melody-dominated homophony. This is different to a chordal homophonic texture. To
  avoid confusion, it is easiest to treat melody and accompaniment as a separate texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090015Z"^^xsd:dateTime .

oakcurric:misconception-instrumental-timbres-families-identified-pitch
  a curric:Misconception ;
  curric:statement "Instrumental timbres in families can be identified with pitch."@en ;
  curric:correction """This isn't always the case. Instruments such as the trombone and French horn
  have a similiar pitch and the oboe and cor anglais pitch ranges cross over, so it's
  important that pupils think about the timbres to identify instruments correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090031Z"^^xsd:dateTime .

oakcurric:misconception-female-voices-higher-pitched-male
  a curric:Misconception ;
  curric:statement "Female voices are always higher pitched than male voices."@en ;
  curric:correction """While this is mostly true, alto and tenor ranges overlap. A low alto voice
  can be as low as a tenor. Alongside this, men can use the falsetto technique to sing much
  higher than their normal range, in some cases higher than female voices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090064Z"^^xsd:dateTime .

oakcurric:misconception-idiomatic-rhythms-rhythms-used-specific
  a curric:Misconception ;
  curric:statement "Idiomatic rhythms are rhythms that are only used in a specific style."@en ;
  curric:correction """Idiomatic rhythms are rhythms that are typically associated with that style,
  but can also be heard in different styles. For example, while the skank rhythm is very
  idiomatic in reggae, there are many other styles that also repeat off-beat quavers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090399Z"^^xsd:dateTime .

oakcurric:misconception-cadenzas-composed
  a curric:Misconception ;
  curric:statement "Cadenzas are always composed."@en ;
  curric:correction """Many cadenzas are composed, but it is common for soloists to improvise (or
  slightly change) cadenzas to make them more unique and to further show off their own
  skill."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090680Z"^^xsd:dateTime .

oakcurric:misconception-hand-drum-technique-same-across
  a curric:Misconception ;
  curric:statement "Hand drum technique is the same across the world."@en ;
  curric:correction """Techniques are very different on different hand drums around the world.
  Tabla, doumbek and djembe all use very different techniques, for example, the doumbek
  technique uses fingertips in a way that djembe does not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090982Z"^^xsd:dateTime .

oakcurric:misconception-working-notes-whole-melody-ear
  a curric:Misconception ;
  curric:statement """Working out the notes of a whole melody by ear is a very difficult musical
  skill."""@en ;
  curric:correction """While it seems challenging, if you break it down into small steps -
  individual intervals - it is no more difficult than working out one interval. Take it one
  step at a time in small chunks and it is completely achievable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091006Z"^^xsd:dateTime .

oakcurric:misconception-music-technology-consists-solely-daws
  a curric:Misconception ;
  curric:statement "Music technology consists solely of DAWs and computer-based technology."@en ;
  curric:correction """For modern musicians, computer-based tools such as DAWs are a brilliant way
  of using technology. However, music technology is much broader than this - synthesisers,
  amplification, turntables and drum machines are just a few examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091177Z"^^xsd:dateTime .

oakcurric:misconception-using-disjunct-intervals-melody-means
  a curric:Misconception ;
  curric:statement """Using disjunct intervals in a melody means the notes can be placed
  anywhere."""@en ;
  curric:correction """Disjunct intervals need a sense of order to the music and should be used in
  some sort of pattern in the same way that conjunct intervals should."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092419Z"^^xsd:dateTime .

oakcurric:misconception-instrument-one-timbre
  a curric:Misconception ;
  curric:statement "An instrument only has one timbre."@en ;
  curric:correction """An instrument can have a few different timbres. Give examples of how
  instruments can change the sound they make."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094055Z"^^xsd:dateTime .

oakcurric:misconception-blues-old-style-music-isnt
  a curric:Misconception ;
  curric:statement "Blues is an old style of music that isn't relevant anymore."@en ;
  curric:correction """While it's true that blues first developed more than a century ago, it
  continued to be an important style all through the 20th century and up to the present day.
  It shaped many different styles (including rock) that came to be incredibly important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094703Z"^^xsd:dateTime .

oakcurric:misconception-because-rock-n-roll-uses
  a curric:Misconception ;
  curric:statement """Because rock 'n' roll often uses the 12-bar blues, this means it is just a
  type of blues."""@en ;
  curric:correction """Many styles use the 12-bar blues, including pop, rock, jazz and other styles.
  While rock 'n' roll is closely related to blues, its defining features are quite
  different, and its role as a commerical pop style is far from the origins of blues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096825Z"^^xsd:dateTime .

oakcurric:misconception-melody-accompaniment-homophonic-texture
  a curric:Misconception ;
  curric:statement "Melody and accompaniment is not a homophonic texture."@en ;
  curric:correction """There are different kinds of homophonic texture. A chordal homophonic texture
  is one in which all parts play the same rhythm. Melody and accompaniment is also called
  melody-dominated homophony, where there is a homophonic texture with a melody above."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097692Z"^^xsd:dateTime .

oakcurric:misconception-one-type-accent
  a curric:Misconception ;
  curric:statement "There is only one type of accent."@en ;
  curric:correction """The regular accent is the most common, but composers often indicate more
  specific articulation by using other accents such as marcato and sforzando. These can be
  difficult to distinguish by ear, but as a performer you should be familiar with them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106181Z"^^xsd:dateTime .

oakcurric:misconception-chord-sequences-follow-fixed-rules
  a curric:Misconception ;
  curric:statement "Chord sequences have to follow fixed rules exactly."@en ;
  curric:correction """We use parameters as a guide to give a musical starting point for composing,
  but sometimes you might find other chords work. Always encourage pupils to try out a few
  ideas and perform their ideas so they can hear what they sound like."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108212Z"^^xsd:dateTime .

oakcurric:misconception-musical-ideas-such-riff-melody
  a curric:Misconception ;
  curric:statement """For musical ideas, such as a riff or melody to contrast, they have to be
  totally different."""@en ;
  curric:correction """Songs should have to have some continuity between the different sections.
  Highlight ways in which two melodically different ideas might still have some similarities
  ie. same rhythm, same shape, same number of notes, same initial motif."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109356Z"^^xsd:dateTime .

oakcurric:misconception-hooks-riffs-same-thing
  a curric:Misconception ;
  curric:statement "Hooks and riffs are the same thing."@en ;
  curric:correction """A riff is the more important feature in how the song fits together and tends
  to underpin some of the main sections in the music. It is also a more suitable musical
  starting point for a pop song composition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112974Z"^^xsd:dateTime .

oakcurric:misconception-piece-music-fixed-texture-way
  a curric:Misconception ;
  curric:statement "A piece of music has a fixed texture all the way through"@en ;
  curric:correction """Although we can describe some pieces of music as particular textures overall
  there are often sections within pieces where the texture changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113792Z"^^xsd:dateTime .

oakcurric:misconception-compose-rhythm-need-consider-notation
  a curric:Misconception ;
  curric:statement "To compose a rhythm we need to consider notation first."@en ;
  curric:correction """It is important to encourage pupils not to be restricted by only rhythms they
  can notate and for them to experiment with rhythmic patterns that they like musically.
  Highlight that individual note durations such as a crotchet are not rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113803Z"^^xsd:dateTime .

oakcurric:misconception-romantic-music-romantic-e-love
  a curric:Misconception ;
  curric:statement "Romantic music is romantic (i.e. about love)."@en ;
  curric:correction """Romantic music is generally expressive and emotional, but is not necessarily
  linked to the emotion of love. The emotions can be anything from dramatic and terrifying
  to dark and mournful. The name comes from a broader artistic movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113842Z"^^xsd:dateTime .

oakcurric:misconception-harmony-chords-same-thing
  a curric:Misconception ;
  curric:statement "Harmony and chords are the same thing."@en ;
  curric:correction """Although the harmony is created by the different notes of the chord
  progression, harmony also includes all parts in the music including the melodic line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113847Z"^^xsd:dateTime .

oakcurric:misconception-bhangra-style-music-south-asia
  a curric:Misconception ;
  curric:statement "Bhangra is a style of music from South Asia."@en ;
  curric:correction """Bhangra in its modern form is an example of musical fusion, between Punjabi
  traditional bhangra and Western popular styles of music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114703Z"^^xsd:dateTime .

oakcurric:misconception-punjab-part-india
  a curric:Misconception ;
  curric:statement "The Punjab is part of India."@en ;
  curric:correction """The Punjab is an area split between modern-day India and Pakistan. It has a
  distinct history, culture and traditions as a region, one of which is bhangra."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114711Z"^^xsd:dateTime .

oakcurric:misconception-calypso-mento-soca-different-versions
  a curric:Misconception ;
  curric:statement "Calypso, mento and soca are different versions of the same musical style."@en ;
  curric:correction """Although they have superficial similarities, these are all distinct styles
  with different features and histories. Soca is strongly linked to calypso and can be seen
  as an offshoot of that style, but mento is a completely separate tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115117Z"^^xsd:dateTime .

oakcurric:misconception-changes-moods-scene-sudden
  a curric:Misconception ;
  curric:statement "Changes between moods in a scene should always be sudden."@en ;
  curric:correction """This is not always the case. Sometimes it is more appropriate to create a
  gradual change so that the shift isn't dramatically obvious. This might be where there is
  a gradual change of mood or action in a scene."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115615Z"^^xsd:dateTime .

oakcurric:misconception-bhangra-traditional-style-music-doesnt
  a curric:Misconception ;
  curric:statement """Bhangra is a traditional style of music that doesn't use music technology
  extensively."""@en ;
  curric:correction """Modern bhangra uses many of the tools that are available to musicians now,
  including different applications of music technology. It uses these to enhance the music,
  while still having its roots embedded in the traditional features of Punjabi bhangra."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116294Z"^^xsd:dateTime .

oakcurric:misconception-chromatic-atonal-same-thing
  a curric:Misconception ;
  curric:statement "Chromatic and atonal are the same thing."@en ;
  curric:correction """Atonal music sounds chromatic, because there is no clear tonal centre.
  However, chromatic music isn't necessarily atonal - a piece can be in a key, but use
  chromatic notes from outside of it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116678Z"^^xsd:dateTime .

oakcurric:misconception-repetitive-film-music-interesting-cant
  a curric:Misconception ;
  curric:statement "Repetitive film music is not very interesting and can't build excitement."@en ;
  curric:correction """Music that repeats ideas can build excitement if the composer develops
  aspects of it. By adding layers, changing rhythms and developing the texture, a simple
  repeated idea can be developed into an exciting musical soundworld."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116709Z"^^xsd:dateTime .

oakcurric:misconception-12-possible-notes
  a curric:Misconception ;
  curric:statement "There are only 12 possible notes."@en ;
  curric:correction """There is an infinite possible number of notes. Imagine that an octave is a
  cake. We can divide it into 12 equal slices (12 Western notes) or 24 smaller slices (the
  Arabic system). In theory, we could divide it into any number of slices/notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117406Z"^^xsd:dateTime .

oakcurric:misconception-countermelody-type-accompaniment
  a curric:Misconception ;
  curric:statement "A countermelody is just a type of accompaniment."@en ;
  curric:correction """It is actually quite different from an accompaniment, because it should be
  equally as prominent as the main melody, whereas an accompaniment is not. An accompaniment
  is usually also based on repeating patterns, whereas a melody does not have to be."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120373Z"^^xsd:dateTime .

oakcurric:misconception-concerto-grosso-exactly-same-concerto
  a curric:Misconception ;
  curric:statement """A concerto grosso is exactly the same as a concerto, just with more than one
  soloist."""@en ;
  curric:correction """Because there is more than one soloist, composers can play around with
  texture and interaction more in a concerto grosso. This means that often there is more
  variety of interaction between parts in a concerto grosso than a solo concerto."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123576Z"^^xsd:dateTime .

oakcurric:misconception-impossible-memorise-timbre-different-instruments
  a curric:Misconception ;
  curric:statement """It is impossible to memorise the timbre of all of the different instruments
  around the world."""@en ;
  curric:correction """Yes, it would be impossible. However, learning to identify some of the key
  instruments is valuable - these are often heard in styles across different cultures, so
  learning the sound of the most common is important as a well-rounded musician."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123731Z"^^xsd:dateTime .

oakcurric:misconception-polyrhythm-cross-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Polyrhythm and cross rhythm are the same thing."@en ;
  curric:correction """They are related, but not the same. A polyrhythm doesn't necessarily have to
  create different senses of pulse - it can just have different rhythms playing together. A
  cross rhythm has to create different senses of pulse at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123759Z"^^xsd:dateTime .

oakcurric:misconception-afrobeat-afrobeats-same-thing
  a curric:Misconception ;
  curric:statement "Afrobeat and Afrobeats are the same thing."@en ;
  curric:correction """Afrobeat is a specific genre from the 1960s/1970s based on a fusion of West
  African music with funk and soul. Afrobeats is a broad term for many modern genres that
  are different fusions from across the continent, but have a few common features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123773Z"^^xsd:dateTime .

oakcurric:misconception-israeli-music-similar-other-middle
  a curric:Misconception ;
  curric:statement """Israeli music is very similar to other Middle Eastern music because Israel is
  in the Middle East."""@en ;
  curric:correction """Israeli folk music has a very different history to other music from the
  region, as it was influenced by Jewish migrants from other parts of the world. Jewish folk
  music uses many European instruments and has similarities with European folk music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124047Z"^^xsd:dateTime .

oakcurric:misconception-2-3-clave-starts-same
  a curric:Misconception ;
  curric:statement "The 2:3 clave starts on the same beat as the 3:2 clave."@en ;
  curric:correction """The 2:3 clave starts with a crotchet rest. Make sure when performing or
  recording this that you count 'rest, 1, 2' for the '2' section of the rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124967Z"^^xsd:dateTime .

oakcurric:misconception-augmentation-diminution-same-augmented-diminished
  a curric:Misconception ;
  curric:statement "Augmentation and diminution are not the same as augmented and diminished."@en ;
  curric:correction """Augmentation and diminution are devices that affect the rhythm of music.
  Augmented and diminished are types of chords and refer to the harmony of music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125439Z"^^xsd:dateTime .

oakcurric:misconception-contrasting-sections-totally-different-other
  a curric:Misconception ;
  curric:statement """Contrasting sections should be totally different to other sections in a
  composition."""@en ;
  curric:correction """Contrasting sections of music can be derived from some of the same ideas but
  should have their own recognisable melodic and harmonic ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125464Z"^^xsd:dateTime .

oakcurric:misconception-south-asian-indian-music-genre
  a curric:Misconception ;
  curric:statement "South Asian (or Indian) music is a genre itself."@en ;
  curric:correction """South Asian music is as diverse as European music. There are many different
  styles linked to different groups of people, places and traditions. What we are looking at
  here are a few ways that South Asian genres have been fused with Western genres."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125700Z"^^xsd:dateTime .

oakcurric:misconception-broken-chords-triad-position-root
  a curric:Misconception ;
  curric:statement """Broken chords have to be in the triad position where the root is the lowest
  note."""@en ;
  curric:correction """Broken chords like block chords can be played in different inversions and
  this can make them more interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126506Z"^^xsd:dateTime .

oakcurric:misconception-cross-rhythm-two-players-play
  a curric:Misconception ;
  curric:statement "A cross rhythm is when two players play in different time signatures."@en ;
  curric:correction """A cross rhythm only sounds like there are different time signatures at the
  same time, but in reality they both use the same time signature (but sound otherwise)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126516Z"^^xsd:dateTime .

oakcurric:misconception-pedal-note-long-low-note
  a curric:Misconception ;
  curric:statement "A pedal note is just a long, low note."@en ;
  curric:correction """A pedal note is a consistent pitch usually in the bass whilst the chords
  change. Encourage pupils to listen to and experiment with the pitch they choose for a
  pedal to hear the effect it has on the harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126555Z"^^xsd:dateTime .

oakcurric:misconception-sequence-retrograde-inversion-way-develop
  a curric:Misconception ;
  curric:statement """Sequence, retrograde and inversion are they only way to develop ideas and they
  have to be used perfectly."""@en ;
  curric:correction """Sequences, retrograde and inversion provide a concrete way for pupils to show
  development in their melodic ideas, but providing there is some similarity or recognisable
  quality in repeated ideas, any subtle changes within melodic ideas can work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126701Z"^^xsd:dateTime .

oakcurric:misconception-dance-music-usually-4-4
  a curric:Misconception ;
  curric:statement "Dance music is usually in 4/4."@en ;
  curric:correction """While the majority of modern Western dance music is in 4/4, dance music
  around the world (and throughout history) often uses different time signatures, including
  3/.4, 6/8 and 12/8, as well as others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126715Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-bossa-nova-clave
  a curric:Misconception ;
  curric:statement "Pupils may confuse the bossa nova clave and rumba clave with each other."@en ;
  curric:correction """Break the bossa nova clave into its group of 3 and group of 2. Practise the
  '3' on its own, identically to the son clave. Then practise the '2' with the second note
  delayed by a quaver. Only once the two parts are separately learnt then combine them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126918Z"^^xsd:dateTime .

oakcurric:misconception-music-dance-regular-pulse-2
  a curric:Misconception ;
  curric:statement "Music for dance must have a regular pulse (in 2, 3 or 4)."@en ;
  curric:correction """While most Western dance music has a regular time signature, in other parts
  of the world it is common to dance to music with irregular time signatures, such as 5/8
  and 7/8."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127015Z"^^xsd:dateTime .

oakcurric:misconception-alap-gat-jhala-structure-changes
  a curric:Misconception ;
  curric:statement """The alap - gat - jhala structure is just about changes in tempo from slow, to
  medium to fast."""@en ;
  curric:correction """While the tempo does change, the bigger changes are around melody. The alap
  explores the raga freely, the gat is more structured and the jhala is heavily improvised
  and virtuosic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127066Z"^^xsd:dateTime .

oakcurric:misconception-raga-scale
  a curric:Misconception ;
  curric:statement "A raga is just a scale."@en ;
  curric:correction """A raga is a bit more complex than being just a scale. It has specific times
  of day, moods and emotions associated with it, as well as rules about how it should be
  played."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127071Z"^^xsd:dateTime .

oakcurric:misconception-teental-4-4
  a curric:Misconception ;
  curric:statement "Teental is in 4/4."@en ;
  curric:correction """Teental sounds to us like it could be in 4/4, but this is just a coincidence.
  North Indian classical musicians don't think of time signature in the same way that we do
  - the tala is what structures the time and they can be many different lengths."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127336Z"^^xsd:dateTime .

oakcurric:misconception-music-key-diatonic
  a curric:Misconception ;
  curric:statement "If music has a key, it must be diatonic."@en ;
  curric:correction """Not necessarily. A piece of music can have a key, but use notes from outside
  of it. This would be chromatic. It could also have a key, but use some microtones as well,
  meaning it is microtonal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128008Z"^^xsd:dateTime .

oakcurric:misconception-modulation-chords-dont-use-tonic
  a curric:Misconception ;
  curric:statement "A modulation is when the chords don't use the tonic."@en ;
  curric:correction """A modulation is actually when the tonic changes. Sometimes music can sound
  like it will modulate, but then it stays in the same key. For a true modulation, it must
  feel like the tonic itself has changed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128016Z"^^xsd:dateTime .

oakcurric:misconception-imitation-countermelody-same-thing
  a curric:Misconception ;
  curric:statement "Imitation and a countermelody are the same thing."@en ;
  curric:correction """They are related, but not the same. Imitation has to include copying part of
  the melody, normally immediately. A countermelody usually tries to contrast with the main
  melody so that it can be heard clearly separately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128374Z"^^xsd:dateTime .

oakcurric:misconception-tempo-markings-precise-indication-speed
  a curric:Misconception ;
  curric:statement "Tempo markings are a precise indication of speed."@en ;
  curric:correction """Most tempo markings (like allegro) are a rough indication of the speed, but
  not an exact measurement. Composers usually leave it up to the performers to determine the
  exact speed. Often in modern music they will indicate a specific speed using BPM."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128451Z"^^xsd:dateTime .

oakcurric:misconception-description-timbre-describe-sound-qualities
  a curric:Misconception ;
  curric:statement "A description of timbre should only describe the sound qualities heard."@en ;
  curric:correction """While this should be included, it is also important to remember to describe
  the instruments that have been used, and if they from a particular ensemble. Remember that
  one instrument can also create multiple timbres."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129003Z"^^xsd:dateTime .

oakcurric:misconception-reharmonising-melody-simple-playing-third
  a curric:Misconception ;
  curric:statement "Reharmonising a melody is as simple as playing it a third higher."@en ;
  curric:correction """While this can be effective, for certain melodies this won't work
  effectively. Instead, experimenting with the harmonised melody both above and below the
  main melody is key, as well as experimenting with 3rds and 6ths."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131121Z"^^xsd:dateTime .

oakcurric:misconception-create-contrasting-version-leitmotif-change
  a curric:Misconception ;
  curric:statement """To create a contrasting version of a leitmotif, you should change lots of
  features of it."""@en ;
  curric:correction """You must be careful to not change it too much. If you do, it becomes
  unrecognisable and will just sound like a different leitmotif. A leitmotif represents a
  character, place, or idea, so we need to be able to recognise it to link it to that thing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151295Z"^^xsd:dateTime .

oakcurric:misconception-using-chords-within-minor-key
  a curric:Misconception ;
  curric:statement "Using chords from within a minor key creates a dark mood."@en ;
  curric:correction """It's more complex than that - it is important to carefully choose which
  chords within the key you emphasise to create a dark mood. Emphasising chord i and other
  minor chords helps to make it feel dark and ominous, rather than any chords from the key."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151317Z"^^xsd:dateTime .

oakcurric:misconception-one-feature-its-own-make
  a curric:Misconception ;
  curric:statement "One feature on its own will make a leitmotif have a particular mood."@en ;
  curric:correction """The mood of a leitmotif comes from a combination of different musical
  elements, including melodic features. Changing one feature might slightly change the mood,
  but to create a strong mood you need to consider all different aspects of the leitmotif."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151343Z"^^xsd:dateTime .

oakcurric:misconception-complex-music-sounds-exciting-energetic
  a curric:Misconception ;
  curric:statement "Complex music sounds most exciting and energetic."@en ;
  curric:correction """Not necessarily - sometimes the most energetic music is that which emphasises
  the pulse and uses driving rhythms. Sometimes if music is too complex, with many busy
  layers of sound, it can sound chaotic and messy rather than energetic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151369Z"^^xsd:dateTime .

oakcurric:misconception-leimotif-musical-theme
  a curric:Misconception ;
  curric:statement "A leimotif is just a musical theme."@en ;
  curric:correction """Not quite. A leitmotif is a musical idea that must represent something else.
  This is usually a character, place or idea. A musical theme can exist without representing
  anything at all."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151412Z"^^xsd:dateTime .

oakcurric:misconception-horizontal-resequencing-new-musical-sections
  a curric:Misconception ;
  curric:statement """In horizontal resequencing, new musical sections should completely contrast
  with the preceeding section."""@en ;
  curric:correction """There should be contrast, but there also needs to be a feeling of continuity.
  Using some consistent features (like tempo, key, timbre) can help to create a feeling of
  some continuity, while still creating a large contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151463Z"^^xsd:dateTime .

oakcurric:misconception-video-games-composers-compose-different
  a curric:Misconception ;
  curric:statement """Video games composers just have to compose different music for different
  scenes, like a film composer."""@en ;
  curric:correction """To be really effective, it is more complex than this. The music they compose
  must be able to repeat indefinitely, while sounding musically interesting. It also has to
  seamlessly transition into different moods, reacting to changes in the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151471Z"^^xsd:dateTime .

oakcurric:misconception-sudden-tempo-changes-work-horizontal
  a curric:Misconception ;
  curric:statement "Sudden tempo changes do not work in horizontal resequencing."@en ;
  curric:correction """Sometimes tempo changes can sound jarring and unnatural, but sometimes video
  game composers want to create a sudden change of pace. If done carefully, tempo changes
  can work effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151479Z"^^xsd:dateTime .

oakcurric:misconception-film-music-precise-second-fit
  a curric:Misconception ;
  curric:statement """All film music has to be precise to the second to fit the action
  perfectly."""@en ;
  curric:correction """Some film scenes do have to be exact where the music mirrors precisely what
  is happening on screen, but much film music is about creating the correct atmosphere and
  feel and this can be just as important when composing programmatic music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151506Z"^^xsd:dateTime .

oakcurric:misconception-genre-music-tells-us-exactly
  a curric:Misconception ;
  curric:statement "The genre of the music tells us exactly what kind of film it is."@en ;
  curric:correction """This is not always true. Sometimes composers deliberately use genres that go
  against expectations. This might be for humour, or to create a strange clash. A good
  example would be A Knight's Tale, which uses modern genres in a medieval film."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151518Z"^^xsd:dateTime .

oakcurric:misconception-oratorios-anthems-essentially-same-religious
  a curric:Misconception ;
  curric:statement """Oratorios and anthems are essentially the same - they are both religious, with
  similar musical features."""@en ;
  curric:correction """Anthems often are a capella, whereas oratorios always have orchestral
  accompaniment. Oratorios are long pieces of music, consisting of numerous songs that tell
  a biblical story. Anthems are shorter songs that are used as part of a Christian service."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151753Z"^^xsd:dateTime .

oakcurric:misconception-describing-music-describing-element-enough
  a curric:Misconception ;
  curric:statement "When describing music, just describing each element is enough."@en ;
  curric:correction """For some questions, it may be appropriate just to describe each element.
  However, often we should give a more sophisticated response that links each element to the
  compositional purpose - why did the composer use that and why is it suitable?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.153271Z"^^xsd:dateTime .

oakcurric:misconception-synthesiser-vs-synthesised-sound
  a curric:Misconception ;
  curric:statement "Synthesiser vs synthesised sound"@en ;
  curric:correction """You can use a synthesiser if you have one or show a youtube clip of one in
  action. Use keyboard and different sounds to explain synthesised"""@en ;
  dcterms:modified "2026-06-07T15:30:15.153777Z"^^xsd:dateTime .

oakcurric:misconception-piano-concertos-same-other-concertos
  a curric:Misconception ;
  curric:statement "Piano concertos are just the same as other concertos."@en ;
  curric:correction """Not quite. Because of the unique abilities of the piano - including its range
  and ability to play multiple lines at once - composers use it slightly differently to
  other instruments. This includes using it to accompany itself, or the orchestra."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153917Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-section-plays-rhythm-rhythm
  a curric:Misconception ;
  curric:statement """The rhythm section 'plays the rhythm'. Rhythm sections are a fixed group of
  instruments."""@en ;
  curric:correction """Highlight the roles of the band and how they 'support' the singer and don't
  just provide rhythm for the song. There is some flexibility in the rhythm section. Not all
  the instruments have to be present in the music all of the time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153986Z"^^xsd:dateTime .

oakcurric:misconception-melody-feature-motif
  a curric:Misconception ;
  curric:statement "A melody must feature a motif."@en ;
  curric:correction """This is not necessarily true - great melodies do not have to use motifs.
  However, they are a useful feature to understand when learning to write melodies, because
  they encourage composers to balance repetition anc contrast effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154527Z"^^xsd:dateTime .

oakcurric:misconception-melody-completely-conjunct
  a curric:Misconception ;
  curric:statement "A melody must be completely conjunct."@en ;
  curric:correction """This is not true - great melodies often use disjunct movement. However, when
  learning to compose melodies, sticking to mostly conjunct movement and small intervals
  helps them to sound melodic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154544Z"^^xsd:dateTime .

oakcurric:misconception-secondary-chords-shouldnt-used
  a curric:Misconception ;
  curric:statement "Secondary chords shouldn't be used."@en ;
  curric:correction """Secondary chords are important for interesting harmony and using them is a
  good idea. As you become a more experienced composer, you'll learn how to effectively use
  them. For now, a good rule of thumb is to use them sparingly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154646Z"^^xsd:dateTime .

oakcurric:misconception-latin-dance-music-sounds-same
  a curric:Misconception ;
  curric:statement "Latin dance music all sounds the same."@en ;
  curric:correction """Many of the styles of music from this region include similar features, such
  as syncopated rhythms, Latin percussion, Spanish lyrics etc. However, they all have
  distinct differences that allow us to tell the different traditions apart."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154785Z"^^xsd:dateTime .

oakcurric:misconception-drum-beats-emphasise-start-bar
  a curric:Misconception ;
  curric:statement "Drum beats should emphasise the start of each bar."@en ;
  curric:correction """Most pop and rock drum beats do this, but many other musical styles do not
  emphasise beat one. The one-drop beat starts with a rest on beat one, and emphasises beat
  two and four."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154822Z"^^xsd:dateTime .

oakcurric:misconception-bouzouki-sounds-same-guitar
  a curric:Misconception ;
  curric:statement "The bouzouki sounds the same as a guitar."@en ;
  curric:correction """The bouzouki has very specific techniques that give it its characteristic
  sound. These include use of tremolo, slides and thirds. Although these can be used on the
  guitar, they are not as common as on the bouzouki."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155334Z"^^xsd:dateTime .

oakcurric:misconception-bass-stays-same-note-pedal
  a curric:Misconception ;
  curric:statement "If the bass stays on the same note, this is a pedal."@en ;
  curric:correction """This is not quite true. It is only a pedal if the bass note stays the same
  while the chords change above it. If the chords do not change, it cannot be a pedal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155448Z"^^xsd:dateTime .

oakcurric:misconception-chord-inversions-inserted-randomly-composers
  a curric:Misconception ;
  curric:statement "Chord inversions are inserted randomly by composers."@en ;
  curric:correction """Chord inversions are used to add interest by bringing subtle amounts of
  tension to a chord and to create smoother transitions from one chord to another. They are
  not chosen randomly and are used sparingly to create a particular effect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155454Z"^^xsd:dateTime .

oakcurric:misconception-using-chord-inversions-chord-make
  a curric:Misconception ;
  curric:statement """Using chord inversions for every chord will make the chord sequence more
  interesting."""@en ;
  curric:correction """Using some inversions can make the chord sequence more interesting, but too
  many can sound unusual. Starting and finishing with a root position chord can help to
  reinforce the key."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155463Z"^^xsd:dateTime .

oakcurric:misconception-writing-vocal-melody-same-writing
  a curric:Misconception ;
  curric:statement "Writing a vocal melody is the same as writing an instrumental melody."@en ;
  curric:correction """Many of the same principles apply, such as phrase structure and using notes
  from the chords and the key. However, a vocal melody has to fit the natural rhythms and
  mood of the words well - we don't have to consider this with instrumental melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155493Z"^^xsd:dateTime .

oakcurric:misconception-unison-homophonic-textures-same-thing
  a curric:Misconception ;
  curric:statement """Unison and homophonic textures are the same thing and unison parts have to be
  played in the same octave."""@en ;
  curric:correction """In a unison texture, both the pitch and rhythm of the part must be the same.
  In a homophonic texture, only the rhythm needs to be the same - the parts can play
  different notes or chords. Parts played in octaves are also classed as a unison texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155509Z"^^xsd:dateTime .

oakcurric:misconception-changing-voicing-chord-same-changing
  a curric:Misconception ;
  curric:statement """Changing the voicing of a chord is the same as changing the chord
  inversion."""@en ;
  curric:correction """They are not the same thing. The inversion of the chord is determined by
  which note is at the bottom (the root or a different note). The voicing is how the notes
  are spread above this - whether they are close together or far apart."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155532Z"^^xsd:dateTime .

oakcurric:misconception-solo-use-many-fast-notes
  a curric:Misconception ;
  curric:statement "A solo should just use as many fast notes as possible."@en ;
  curric:correction """To be really effective, a solo should gradually build up in intensity. If it
  is extremely virtuosic from the beginning, it loses its impact. Building up to a very
  flashy, virtuosic climax is most effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155558Z"^^xsd:dateTime .

oakcurric:misconception-create-good-countermelody-need-two
  a curric:Misconception ;
  curric:statement """To create a good countermelody, you just need two melodies playing at the same
  time."""@en ;
  curric:correction """It's a bit more complicated than that. An effective countermelody has to
  contrast with the main melody, so that it can be heard. This is done by choosing an
  appropriate timbre and octave, and using the 'space' in the main melody."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155699Z"^^xsd:dateTime .

oakcurric:misconception-black-notes-same-thing-chromatic
  a curric:Misconception ;
  curric:statement "Black notes are the same thing as chromatic notes."@en ;
  curric:correction """This is not always true. Chromatic notes are any notes that are from outside
  of the key. If you are in C major, which only uses white notes, the black notes will be
  chromatic. However, in other keys the black notes might not be chromatic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155706Z"^^xsd:dateTime .

oakcurric:misconception-main-difference-verse-chorus-lyrics
  a curric:Misconception ;
  curric:statement "The main difference between the verse and chorus is the lyrics."@en ;
  curric:correction """Although that is an important difference, the verse and chorus usually have
  contrasting moods. This is achieved by creating contrasting chord sequences, textures,
  rhythms and melodies, not just using different lyrics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155773Z"^^xsd:dateTime .

oakcurric:misconception-sonata-form-sonata-same-thing
  a curric:Misconception ;
  curric:statement "Sonata form and a sonata are the same thing."@en ;
  curric:correction """This is a common misconception. Sonata form is a structure in a piece that
  has a exposition, development and recapitulation. A sonata is a three-movement composition
  for solo instrument. The first movement of a sonata is normally in sonata form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160109Z"^^xsd:dateTime .

oakcurric:misconception-choosing-elements-discuss-case-thinking
  a curric:Misconception ;
  curric:statement """Choosing elements to discuss is just a case of thinking of the easiest ones to
  talk about."""@en ;
  curric:correction """While this might seem like the best option, it is more important that you
  choose elements that are relevant to the question. Remember, always link your points back
  to the purpose of the music, or to the style that they are part of."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161020Z"^^xsd:dateTime .

oakcurric:misconception-main-thing-need-remember-long
  a curric:Misconception ;
  curric:statement """The main thing I need to remember for long-form answers is the elements
  acronym (e.g. MAD T SHIRTT)."""@en ;
  curric:correction """These acronyms do help us to remember what the elements are, but it is much
  more important in these longer descriptions to ensure answers are clearly structured,
  thorough and concise, and that correct technical vocabulary is used for each element."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161699Z"^^xsd:dateTime .

oakcurric:misconception-longer-note-values-like-minims
  a curric:Misconception ;
  curric:statement """Longer note values (like minims) are impossible to verbalise, because the
  words sound the same as a crotchet."""@en ;
  curric:correction """Longer note values are tricky to verbalise. A minim uses one syllable, just
  like a crotchet. The key is to make sure you count how many beats they last for - that
  will help you tell the difference between crotchets, minims and longer notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163287Z"^^xsd:dateTime .
