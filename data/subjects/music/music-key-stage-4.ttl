  dcterms:modified "2026-06-07T15:30:41.109502Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20105
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify key musical features of the Classical period."@en ;
  dcterms:modified "2026-06-07T15:30:41.112574Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8803
  a curric:PupilLessonOutcome ;
  rdfs:label """I can choose which elements to focus on in a musical description and can write an
