# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-broken-chord
  a curric:Keyword ;
  schema:name "broken chord"@en ;
  schema:description "when the notes of a chord are sounded one at a time"@en ;
  dcterms:modified "2026-06-07T15:30:02.347153Z"^^xsd:dateTime .

oakcurric:keyword-root-note
  a curric:Keyword ;
  schema:name "root note"@en ;
  schema:description "the main note of a chord, and what the chord is named after"@en ;
  dcterms:modified "2026-06-07T15:30:02.347189Z"^^xsd:dateTime .

oakcurric:keyword-octave
  a curric:Keyword ;
  schema:name "octave"@en ;
  schema:description """an interval of eight notes; octaves in music have the same name i.e. C to C
  on the keyboard"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347199Z"^^xsd:dateTime .

oakcurric:keyword-downbeat
  a curric:Keyword ;
  schema:name "downbeat"@en ;
  schema:description "the first and strongest beat of the bar"@en ;
  dcterms:modified "2026-06-07T15:30:02.347217Z"^^xsd:dateTime .

oakcurric:keyword-interval
  a curric:Keyword ;
  schema:name "interval"@en ;
  schema:description "the distance in pitch between two notes (e.g. a fifth)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347285Z"^^xsd:dateTime .

oakcurric:keyword-chord-tone
  a curric:Keyword ;
  schema:name "chord tone"@en ;
  schema:description "a note that is included within a chord"@en ;
  dcterms:modified "2026-06-07T15:30:02.347290Z"^^xsd:dateTime .

oakcurric:keyword-disjunct
  a curric:Keyword ;
  schema:name "disjunct"@en ;
  schema:description """movement between notes that involves intervals larger than two semitones
  (moving by leap)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347295Z"^^xsd:dateTime .

oakcurric:keyword-balanced-phrasing
  a curric:Keyword ;
  schema:name "balanced phrasing"@en ;
  schema:description """where melodic phrases are equal length and complementary melodic shape (also
  called 'question and answer' form)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347299Z"^^xsd:dateTime .

oakcurric:keyword-melodic-shape
  a curric:Keyword ;
  schema:name "melodic shape"@en ;
  schema:description """the overall shape of a melody or part of a melody, including where it
  ascends or descends and where it is conjunct or disjunct"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347307Z"^^xsd:dateTime .

oakcurric:keyword-string-quartet
  a curric:Keyword ;
  schema:name "string quartet"@en ;
  schema:description """a common western classical ensemble consisting of two violins, a viola and a
  cello"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347353Z"^^xsd:dateTime .

oakcurric:keyword-harmony
  a curric:Keyword ;
  schema:name "harmony"@en ;
  schema:description "how different notes and chords work together"@en ;
  dcterms:modified "2026-06-07T15:30:02.347358Z"^^xsd:dateTime .

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "range"@en ;
  schema:description "the range of pitches that an instrument is capable of playing"@en ;
  dcterms:modified "2026-06-07T15:30:02.347362Z"^^xsd:dateTime .

oakcurric:keyword-voicing
  a curric:Keyword ;
  schema:name "voicing"@en ;
  schema:description """how the notes in a chord are spread out on an instrument or between
  instruments"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347370Z"^^xsd:dateTime .

oakcurric:keyword-pizzicato
  a curric:Keyword ;
  schema:name "pizzicato"@en ;
  schema:description """a string technique in which the performer plucks the string with a
  finger"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347375Z"^^xsd:dateTime .

oakcurric:keyword-relative-minor
  a curric:Keyword ;
  schema:name "relative minor"@en ;
  schema:description """the minor chord or key that has the same key signature as a major key (e.g.
  A minor compared to C major)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347409Z"^^xsd:dateTime .

oakcurric:keyword-tonic
  a curric:Keyword ;
  schema:name "tonic"@en ;
  schema:description """chord I - the 'home' note and chord of a key and the note that the key is
  named after"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347414Z"^^xsd:dateTime .

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the fifth note in a scale, or the chord based on that note (chord V)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347419Z"^^xsd:dateTime .

oakcurric:keyword-root-position
  a curric:Keyword ;
  schema:name "root position"@en ;
  schema:description "a chord in which the root note is the lowest note"@en ;
  dcterms:modified "2026-06-07T15:30:02.347423Z"^^xsd:dateTime .

oakcurric:keyword-chord-inversion
  a curric:Keyword ;
  schema:name "chord inversion"@en ;
  schema:description """when the notes of a chord are reordered so that the root is not the lowest
  note"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347431Z"^^xsd:dateTime .

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-rubato
  a curric:Keyword ;
  schema:name "rubato"@en ;
  schema:description "a slight speeding up and slowing down of the tempo to show expression"@en ;
  dcterms:modified "2026-06-07T15:30:02.347516Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-time-signature
  a curric:Keyword ;
  schema:name "time signature"@en ;
  schema:description "the number of beats in a bar of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347693Z"^^xsd:dateTime .

oakcurric:keyword-imperfect-cadence
  a curric:Keyword ;
  schema:name "imperfect cadence"@en ;
  schema:description """where part of a chord sequence finishes on the dominant chord (V), which
  feels unfinished"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348117Z"^^xsd:dateTime .

oakcurric:keyword-anacrusis
  a curric:Keyword ;
  schema:name "anacrusis"@en ;
  schema:description "when a melody starts before the downbeat (beat 1)"@en ;
  dcterms:modified "2026-06-07T15:30:02.348121Z"^^xsd:dateTime .

oakcurric:keyword-melody
  a curric:Keyword ;
  schema:name "Melody"@en ;
  schema:description "the tune, usually the most memorable feature in a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.348126Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-conjunct
  a curric:Keyword ;
  schema:name "Conjunct"@en ;
  schema:description "movement between notes based on small intervals (steps)"@en ;
  dcterms:modified "2026-06-07T15:30:02.348137Z"^^xsd:dateTime .

oakcurric:keyword-phrase
  a curric:Keyword ;
  schema:name "Phrase"@en ;
  schema:description "a short section of a melody, often lasting 1, 2 or 4 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.348142Z"^^xsd:dateTime .

oakcurric:keyword-development
  a curric:Keyword ;
  schema:name "development"@en ;
  schema:description "improving and building on design ideas to make them better"@en ;
  dcterms:modified "2026-06-07T15:30:02.348273Z"^^xsd:dateTime .

oakcurric:keyword-chromatic
  a curric:Keyword ;
  schema:name "chromatic"@en ;
  schema:description "a note that is not part of the key or scale"@en ;
  dcterms:modified "2026-06-07T15:30:02.348649Z"^^xsd:dateTime .

oakcurric:keyword-genre
  a curric:Keyword ;
  schema:name "genre"@en ;
  schema:description "A genre is a category used to group different types of literature."@en ;
  dcterms:modified "2026-06-07T15:30:02.348775Z"^^xsd:dateTime .

oakcurric:keyword-accent
  a curric:Keyword ;
  schema:name "accent"@en ;
  schema:description "an emphasis on a note"@en ;
  dcterms:modified "2026-06-07T15:30:02.348784Z"^^xsd:dateTime .

oakcurric:keyword-crescendo
  a curric:Keyword ;
  schema:name "crescendo"@en ;
  schema:description "gradually getting louder"@en ;
  dcterms:modified "2026-06-07T15:30:02.348797Z"^^xsd:dateTime .

oakcurric:keyword-pentatonic-scale
  a curric:Keyword ;
  schema:name "pentatonic scale"@en ;
  schema:description "a common scale in folk music, consisting of five different notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348841Z"^^xsd:dateTime .

oakcurric:keyword-accompaniment
  a curric:Keyword ;
  schema:name "accompaniment"@en ;
  schema:description "a part in the music that supports the melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.348848Z"^^xsd:dateTime .

oakcurric:keyword-baroque-period
  a curric:Keyword ;
  schema:name "Baroque period"@en ;
  schema:description "the period of Western classical music between 1600 and 1750"@en ;
  dcterms:modified "2026-06-07T15:30:02.349006Z"^^xsd:dateTime .

oakcurric:keyword-continuo
  a curric:Keyword ;
  schema:name "continuo"@en ;
  schema:description """the accompaniment section of the Baroque orchestra, normally including
  harpsichord and a bass stringed instrument (e.g. cello)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349013Z"^^xsd:dateTime .

oakcurric:keyword-ornamentation
  a curric:Keyword ;
  schema:name "ornamentation"@en ;
  schema:description """when a performer decorates a melody with extra notes (e.g. trills,
  turns)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349020Z"^^xsd:dateTime .

oakcurric:keyword-terraced-dynamics
  a curric:Keyword ;
  schema:name "terraced dynamics"@en ;
  schema:description "where dynamics change suddenly, rather than gradually"@en ;
  dcterms:modified "2026-06-07T15:30:02.349024Z"^^xsd:dateTime .

oakcurric:keyword-contrapuntal
  a curric:Keyword ;
  schema:name "contrapuntal"@en ;
  schema:description """a type of polyphonic texture that includes two or more interweaving melodic
  lines"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349028Z"^^xsd:dateTime .

oakcurric:keyword-western-classical-tradition
  a curric:Keyword ;
  schema:name "Western Classical Tradition"@en ;
  schema:description """formal, notated European art music from the Medieval period to the 21st
  century"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349091Z"^^xsd:dateTime .

oakcurric:keyword-baroque
  a curric:Keyword ;
  schema:name "Baroque"@en ;
  schema:description "a period of music history between 1600 and 1750"@en ;
  dcterms:modified "2026-06-07T15:30:02.349100Z"^^xsd:dateTime .

oakcurric:keyword-classical
  a curric:Keyword ;
  schema:name "Classical"@en ;
  schema:description "a period of music history between 1750 and 1820"@en ;
  dcterms:modified "2026-06-07T15:30:02.349105Z"^^xsd:dateTime .

oakcurric:keyword-romantic
  a curric:Keyword ;
  schema:name "Romantic"@en ;
  schema:description "a period of music history between 1820 and 1910"@en ;
  dcterms:modified "2026-06-07T15:30:02.349110Z"^^xsd:dateTime .

oakcurric:keyword-tonality
  a curric:Keyword ;
  schema:name "tonality"@en ;
  schema:description """the type of notes and chords that a piece of music is based on (e.g. minor,
  major, atonal)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349998Z"^^xsd:dateTime .

oakcurric:keyword-key
  a curric:Keyword ;
  schema:name "key"@en ;
  schema:description "the specific set of notes that a piece is based on (e.g. C minor)"@en ;
  dcterms:modified "2026-06-07T15:30:02.350003Z"^^xsd:dateTime .

oakcurric:keyword-key-signature
  a curric:Keyword ;
  schema:name "key signature"@en ;
  schema:description """which sharps or flats should be used in a particular key, written at the
  start of each stave"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350009Z"^^xsd:dateTime .

oakcurric:keyword-cadence
  a curric:Keyword ;
  schema:name "cadence"@en ;
  schema:description "a combination of two chords at the end of a phrase or section"@en ;
  dcterms:modified "2026-06-07T15:30:02.350014Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-inversion
  a curric:Keyword ;
  schema:name "inversion"@en ;
  schema:description "when the subject pronoun and the verb switch place to form a question"@en ;
  dcterms:modified "2026-06-07T15:30:02.351177Z"^^xsd:dateTime .

oakcurric:keyword-chamber-music
  a curric:Keyword ;
  schema:name "chamber music"@en ;
  schema:description "music composed for a small ensemble, such as a string quartet"@en ;
  dcterms:modified "2026-06-07T15:30:02.351487Z"^^xsd:dateTime .

oakcurric:keyword-piano-trio
  a curric:Keyword ;
  schema:name "piano trio"@en ;
  schema:description """another common small ensemble, typically consisting of a piano, violin and
  cello"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351491Z"^^xsd:dateTime .

oakcurric:keyword-trio-sonata
  a curric:Keyword ;
  schema:name "trio sonata"@en ;
  schema:description """a common Baroque style of chamber music, with two melodic instruments and
  continuo"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351498Z"^^xsd:dateTime .

oakcurric:keyword-solo
  a curric:Keyword ;
  schema:name "solo"@en ;
  schema:description """a performance by one instrument; sometimes compositions for an instrument
  with a piano accompaniment are also called a solo"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351505Z"^^xsd:dateTime .

oakcurric:keyword-atonal
  a curric:Keyword ;
  schema:name "atonal"@en ;
  schema:description "music which has no key or tonic note"@en ;
  dcterms:modified "2026-06-07T15:30:02.351808Z"^^xsd:dateTime .

oakcurric:keyword-minimalist-music-minimalism
  a curric:Keyword ;
  schema:name "minimalist music (minimalism)"@en ;
  schema:description """a style of music that emerged in the 1960s in the USA, defined by its
  repetition of minimal musical ideas"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351815Z"^^xsd:dateTime .

oakcurric:keyword-non-functional-harmony
  a curric:Keyword ;
  schema:name "non-functional harmony"@en ;
  schema:description """where chords don’t have their traditional roles (e.g. chord V resolving to
  I, using mostly primary chords)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351819Z"^^xsd:dateTime .

oakcurric:keyword-experimental-music
  a curric:Keyword ;
  schema:name "experimental music"@en ;
  schema:description "music that radically challenges what we think of as 'normal' music"@en ;
  dcterms:modified "2026-06-07T15:30:02.351826Z"^^xsd:dateTime .

oakcurric:keyword-ostinato
  a curric:Keyword ;
  schema:name "ostinato"@en ;
  schema:description "a short, repeating musical idea (plural: ostinati)"@en ;
  dcterms:modified "2026-06-07T15:30:02.351831Z"^^xsd:dateTime .

oakcurric:keyword-chord-sequence
  a curric:Keyword ;
  schema:name "chord sequence"@en ;
  schema:description "a pattern of chords that usually lasts for 4, 8 or 16 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.352154Z"^^xsd:dateTime .

oakcurric:keyword-syncopation
  a curric:Keyword ;
  schema:name "syncopation"@en ;
  schema:description """a rhythm which emphasises (accents) notes in between the main beats, often
  referred to as off-beat rhythms"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352158Z"^^xsd:dateTime .

oakcurric:keyword-romantic-period
  a curric:Keyword ;
  schema:name "Romantic period"@en ;
  schema:description "the period of Western classical music between roughly 1820 and 1910"@en ;
  dcterms:modified "2026-06-07T15:30:02.352380Z"^^xsd:dateTime .

oakcurric:keyword-programme-music
  a curric:Keyword ;
  schema:name "programme music"@en ;
  schema:description "music that tells a story or creates an image of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.352387Z"^^xsd:dateTime .

oakcurric:keyword-leitmotif
  a curric:Keyword ;
  schema:name "leitmotif"@en ;
  schema:description "a short musical idea that represents a character, place or idea"@en ;
  dcterms:modified "2026-06-07T15:30:02.352392Z"^^xsd:dateTime .

oakcurric:keyword-virtuosic
  a curric:Keyword ;
  schema:name "virtuosic"@en ;
  schema:description "music that shows off a performer’s technical skill"@en ;
  dcterms:modified "2026-06-07T15:30:02.352396Z"^^xsd:dateTime .

oakcurric:keyword-polyphonic
  a curric:Keyword ;
  schema:name "polyphonic"@en ;
  schema:description "a texture with more than one equally important melodic line"@en ;
  dcterms:modified "2026-06-07T15:30:02.352401Z"^^xsd:dateTime .

oakcurric:keyword-melody-and-accompaniment
  a curric:Keyword ;
  schema:name "melody and accompaniment"@en ;
  schema:description "a texture consisting of a melody with a clearly separate accompaniment"@en ;
  dcterms:modified "2026-06-07T15:30:02.352405Z"^^xsd:dateTime .

oakcurric:keyword-diatonic
  a curric:Keyword ;
  schema:name "diatonic"@en ;
  schema:description """music which uses only notes that are based in the key (e.g. C major or F
  minor)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352412Z"^^xsd:dateTime .

oakcurric:keyword-modulation
  a curric:Keyword ;
  schema:name "modulation"@en ;
  schema:description "a change of key during a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.352416Z"^^xsd:dateTime .

oakcurric:keyword-dissonance
  a curric:Keyword ;
  schema:name "dissonance"@en ;
  schema:description "where notes in a chord clash, creating harmonic tension"@en ;
  dcterms:modified "2026-06-07T15:30:02.353260Z"^^xsd:dateTime .

oakcurric:keyword-consonance
  a curric:Keyword ;
  schema:name "consonance"@en ;
  schema:description "where notes in a chord sound pleasant together, without tension"@en ;
  dcterms:modified "2026-06-07T15:30:02.353264Z"^^xsd:dateTime .

oakcurric:keyword-unison
  a curric:Keyword ;
  schema:name "unison"@en ;
  schema:description "performing the same movement at exactly the same time as our partner"@en ;
  dcterms:modified "2026-06-07T15:30:02.353983Z"^^xsd:dateTime .

oakcurric:keyword-syncopated
  a curric:Keyword ;
  schema:name "Syncopated"@en ;
  schema:description """a rhythm that emphasises (accents) notes in between the main beats; this is
  often created by using half-beat rests on the beat or dotted rhythms"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354439Z"^^xsd:dateTime .

oakcurric:keyword-dotted-quaver
  a curric:Keyword ;
  schema:name "Dotted quaver"@en ;
  schema:description "a note that lasts for three quarters of a beat"@en ;
  dcterms:modified "2026-06-07T15:30:02.354444Z"^^xsd:dateTime .

oakcurric:keyword-compound-time
  a curric:Keyword ;
  schema:name "Compound time"@en ;
  schema:description """Compound time is when each beat is divided into three quavers, rather than
  two (e.g. a 12/8 time signature)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354451Z"^^xsd:dateTime .

oakcurric:keyword-orchestra
  a curric:Keyword ;
  schema:name "orchestra"@en ;
  schema:description """a large ensemble that is central to the Western Classical Tradition,
  consisting of strings, woodwind, brass and percussion instruments"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354567Z"^^xsd:dateTime .

oakcurric:keyword-strings
  a curric:Keyword ;
  schema:name "strings"@en ;
  schema:description """instruments with strings that are normally played with a bow, including the
  violin, viola, cello and double bass"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354574Z"^^xsd:dateTime .

oakcurric:keyword-woodwind
  a curric:Keyword ;
  schema:name "woodwind"@en ;
  schema:description """instruments that produce sound through blown air, including the flute,
  clarinet, oboe and bassoon"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354581Z"^^xsd:dateTime .

oakcurric:keyword-brass
  a curric:Keyword ;
  schema:name "brass"@en ;
  schema:description """metal instruments with valves or slides that produce sound with air,
  including the trumpet, trombone, French horn and tuba"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354585Z"^^xsd:dateTime .

oakcurric:keyword-percussion
  a curric:Keyword ;
  schema:name "percussion"@en ;
  schema:description """instruments that produce sound by being struck or hit, including drums,
  cymbals, xylophones and many others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354590Z"^^xsd:dateTime .

oakcurric:keyword-pedal
  a curric:Keyword ;
  schema:name "pedal"@en ;
  schema:description """a continuous pitch or note in the music which remains the same as the other
  harmonies change"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355112Z"^^xsd:dateTime .

oakcurric:keyword-tone
  a curric:Keyword ;
  schema:name "Tone"@en ;
  schema:description "The general mood or feeling of a text."@en ;
  dcterms:modified "2026-06-07T15:30:02.356590Z"^^xsd:dateTime .

oakcurric:keyword-rock
  a curric:Keyword ;
  schema:name "rock"@en ;
  schema:description """A rock is a solid substance, which is a mixture of minerals. It composes any
  solid portion of Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:02.356926Z"^^xsd:dateTime .

oakcurric:keyword-celtic
  a curric:Keyword ;
  schema:name "Celtic"@en ;
  schema:description """the Celtic people were the tribes who lived in Britain before the Ancient
  Romans arrived"""@en ;
  dcterms:modified "2026-06-07T15:30:02.357222Z"^^xsd:dateTime .

oakcurric:keyword-backbeat
  a curric:Keyword ;
  schema:name "backbeat"@en ;
  schema:description """a backbeat is the emphasis of beats 2 and 4, usually on the snare of the
  drum kit, providing the drive in a piece of pop music"""@en ;
  dcterms:modified "2026-06-07T15:30:02.357248Z"^^xsd:dateTime .

oakcurric:keyword-climax
  a curric:Keyword ;
  schema:name "climax"@en ;
  schema:description """the point in the narrative that describes the main action and takes the
  suspense to its highest point"""@en ;
  dcterms:modified "2026-06-07T15:30:02.357294Z"^^xsd:dateTime .

oakcurric:keyword-third
  a curric:Keyword ;
  schema:name "third"@en ;
  schema:description """an interval of three notes. When both notes are performed together, the
  harmony would be described as ‘3rds’"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358123Z"^^xsd:dateTime .

oakcurric:keyword-semitone
  a curric:Keyword ;
  schema:name "Semitone"@en ;
  schema:description """A semitone is the smallest interval in most Western music (e.g. C to
  C#)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.359091Z"^^xsd:dateTime .

oakcurric:keyword-melodic-dictation
  a curric:Keyword ;
  schema:name "Melodic dictation"@en ;
  schema:description "the process of listening to a melody and writing it down"@en ;
  dcterms:modified "2026-06-07T15:30:02.359098Z"^^xsd:dateTime .

oakcurric:keyword-augmentation
  a curric:Keyword ;
  schema:name "Augmentation"@en ;
  schema:description """the process of lengthening all of the notes in a melody by the same
  proportion"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359159Z"^^xsd:dateTime .

oakcurric:keyword-diminution
  a curric:Keyword ;
  schema:name "Diminution"@en ;
  schema:description """the process of shortening all of the notes in a melody by the same
  proportion"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359163Z"^^xsd:dateTime .

oakcurric:keyword-subdominant
  a curric:Keyword ;
  schema:name "Subdominant"@en ;
  schema:description "chord IV in a key"@en ;
  dcterms:modified "2026-06-07T15:30:02.359348Z"^^xsd:dateTime .

oakcurric:keyword-perfect-cadence
  a curric:Keyword ;
  schema:name "Perfect cadence"@en ;
  schema:description "a V-I progression at the end of a section of music; it feels resolved"@en ;
  dcterms:modified "2026-06-07T15:30:02.359353Z"^^xsd:dateTime .

oakcurric:keyword-simple-time
  a curric:Keyword ;
  schema:name "simple time"@en ;
  schema:description "each beat is divided into two quavers; 4/4 and 3/4 are examples of this"@en ;
  dcterms:modified "2026-06-07T15:30:02.359529Z"^^xsd:dateTime .

oakcurric:keyword-irregular-time-signature
  a curric:Keyword ;
  schema:name "irregular time signature"@en ;
  schema:description "the number of beats cannot be divided by 2 or 3 (e.g. 5, 7)"@en ;
  dcterms:modified "2026-06-07T15:30:02.359533Z"^^xsd:dateTime .

oakcurric:keyword-contrary-motion
  a curric:Keyword ;
  schema:name "contrary motion"@en ;
  schema:description """where two parts move in opposite directions (e.g. ascending and
  descending)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359664Z"^^xsd:dateTime .

oakcurric:keyword-harmonisation
  a curric:Keyword ;
  schema:name "harmonisation"@en ;
  schema:description """when one part plays at the same time as a melody, adding notes that create
  harmony with the melodic line"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359668Z"^^xsd:dateTime .

oakcurric:keyword-arco
  a curric:Keyword ;
  schema:name "arco"@en ;
  schema:description "when strings are played with a bow"@en ;
  dcterms:modified "2026-06-07T15:30:02.359677Z"^^xsd:dateTime .

oakcurric:keyword-mute
  a curric:Keyword ;
  schema:name "mute"@en ;
  schema:description "a device that dampens and reduces the sound produced by an instrument"@en ;
  dcterms:modified "2026-06-07T15:30:02.359682Z"^^xsd:dateTime .

oakcurric:keyword-synth-lead
  a curric:Keyword ;
  schema:name "synth lead"@en ;
  schema:description "a type of synthesised sound that is suited to playing melodies"@en ;
  dcterms:modified "2026-06-07T15:30:02.359688Z"^^xsd:dateTime .

oakcurric:keyword-synth-pad
  a curric:Keyword ;
  schema:name "synth pad"@en ;
  schema:description "a type of synthesised sound that is suited to playing sustained sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.359693Z"^^xsd:dateTime .

oakcurric:keyword-satb
  a curric:Keyword ;
  schema:name "SATB"@en ;
  schema:description "a type of choir consisting of soprano, alto, tenor and bass singers"@en ;
  dcterms:modified "2026-06-07T15:30:02.359742Z"^^xsd:dateTime .

oakcurric:keyword-vibrato
  a curric:Keyword ;
  schema:name "vibrato"@en ;
  schema:description "a vocal or instrumental technique in which the pitch ‘wobbles’ slightly"@en ;
  dcterms:modified "2026-06-07T15:30:02.359749Z"^^xsd:dateTime .

oakcurric:keyword-melismatic
  a curric:Keyword ;
  schema:name "melismatic"@en ;
  schema:description "when there are syllables with more than one note sung to them"@en ;
  dcterms:modified "2026-06-07T15:30:02.359754Z"^^xsd:dateTime .

oakcurric:keyword-beatboxing
  a curric:Keyword ;
  schema:name "beatboxing"@en ;
  schema:description "a vocal technique that imitates drum kit and percussion sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.359760Z"^^xsd:dateTime .

oakcurric:keyword-falsetto
  a curric:Keyword ;
  schema:name "falsetto"@en ;
  schema:description """a technique in which male voices can sing much higher than their normal
  range; it has a distinct, thin, airy timbre"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359765Z"^^xsd:dateTime .

oakcurric:keyword-driving-rhythms
  a curric:Keyword ;
  schema:name "driving rhythms"@en ;
  schema:description "fast, repeated rhythms that create a sense of energy"@en ;
  dcterms:modified "2026-06-07T15:30:02.360213Z"^^xsd:dateTime .

oakcurric:keyword-clave
  a curric:Keyword ;
  schema:name "clave"@en ;
  schema:description """a five-note syncopated rhythm with various forms; the most common form is
  the son clave"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360220Z"^^xsd:dateTime .

oakcurric:keyword-tresillo
  a curric:Keyword ;
  schema:name "tresillo"@en ;
  schema:description "a three-note rhythm that is the same as the ‘3’ of the son clave"@en ;
  dcterms:modified "2026-06-07T15:30:02.360225Z"^^xsd:dateTime .

oakcurric:keyword-chaal
  a curric:Keyword ;
  schema:name "chaal"@en ;
  schema:description """the name commonly given to a particular distinctive rhythm played on the
  dhol in bhangra"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360232Z"^^xsd:dateTime .

oakcurric:keyword-free-rhythms
  a curric:Keyword ;
  schema:name "free rhythms"@en ;
  schema:description "when free rhythms are played, they create no clear sense of pulse"@en ;
  dcterms:modified "2026-06-07T15:30:02.360237Z"^^xsd:dateTime .

oakcurric:keyword-cadenza
  a curric:Keyword ;
  schema:name "cadenza"@en ;
  schema:description """a solo section in a concerto in which the soloist plays in a virtuosic
  manner"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360745Z"^^xsd:dateTime .

oakcurric:keyword-sonata-form
  a curric:Keyword ;
  schema:name "sonata form"@en ;
  schema:description """a common structure for a piece, based on an exposition, development and
  recapitulation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360752Z"^^xsd:dateTime .

oakcurric:keyword-doumbek
  a curric:Keyword ;
  schema:name "doumbek"@en ;
  schema:description """a drum used in Arabic and Palestinian folk music; it is played with the
  hands and fingertips"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361195Z"^^xsd:dateTime .

oakcurric:keyword-oud
  a curric:Keyword ;
  schema:name "oud"@en ;
  schema:description """a stringed instrument with 11 strings used in Arabic and Palestinian music;
  it is an early predecessor to the guitar"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361200Z"^^xsd:dateTime .

oakcurric:keyword-wazn
  a curric:Keyword ;
  schema:name "wazn"@en ;
  schema:description """a repeating rhythmic cycle or pattern that forms the rhythmic basis of a
  composition"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361204Z"^^xsd:dateTime .

oakcurric:keyword-maqsum
  a curric:Keyword ;
  schema:name "maqsum"@en ;
  schema:description "a common wazn across the Middle East"@en ;
  dcterms:modified "2026-06-07T15:30:02.361211Z"^^xsd:dateTime .

oakcurric:keyword-saidi
  a curric:Keyword ;
  schema:name "saidi"@en ;
  schema:description "a specific upbeat wazn that uses fast rhythmic patterns"@en ;
  dcterms:modified "2026-06-07T15:30:02.361216Z"^^xsd:dateTime .

oakcurric:keyword-drum-machine
  a curric:Keyword ;
  schema:name "drum machine"@en ;
  schema:description "an instrument that synthesises drum sounds; the TR-808 is an example"@en ;
  dcterms:modified "2026-06-07T15:30:02.361575Z"^^xsd:dateTime .

oakcurric:keyword-reverb
  a curric:Keyword ;
  schema:name "reverb"@en ;
  schema:description """an effect that creates the impression of a sound being played in a more
  ‘echoey’ space"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361579Z"^^xsd:dateTime .

oakcurric:keyword-delay
  a curric:Keyword ;
  schema:name "delay"@en ;
  schema:description "an effect that ‘echoes’ sounds back after a specific time"@en ;
  dcterms:modified "2026-06-07T15:30:02.361586Z"^^xsd:dateTime .

oakcurric:keyword-overdubbing
  a curric:Keyword ;
  schema:name "overdubbing"@en ;
  schema:description """adding new recorded sound to a pre-existing recording to create a combined
  effect"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361591Z"^^xsd:dateTime .

oakcurric:keyword-scratching
  a curric:Keyword ;
  schema:name "scratching"@en ;
  schema:description """a DJing technique where the DJ creates a ‘wika wika’ sound by touching the
  record"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361596Z"^^xsd:dateTime .

oakcurric:keyword-sampling
  a curric:Keyword ;
  schema:name "sampling"@en ;
  schema:description "the process of creating and using a sample"@en ;
  dcterms:modified "2026-06-07T15:30:02.363377Z"^^xsd:dateTime .

oakcurric:keyword-articulation
  a curric:Keyword ;
  schema:name "articulation"@en ;
  schema:description "Articulation is how the note is played eg. legato, staccato or accented."@en ;
  dcterms:modified "2026-06-07T15:30:02.363479Z"^^xsd:dateTime .

oakcurric:keyword-timbre
  a curric:Keyword ;
  schema:name "timbre"@en ;
  schema:description "the description of the sound or tone of an instrument"@en ;
  dcterms:modified "2026-06-07T15:30:02.364140Z"^^xsd:dateTime .

oakcurric:keyword-idiomatic-writing
  a curric:Keyword ;
  schema:name "idiomatic writing"@en ;
  schema:description """Idiomatic writing is composing for an instrument (acoustic or electronic) or
  voice that makes the best use of the distinctive properties of that instrument or voice."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366056Z"^^xsd:dateTime .

oakcurric:keyword-retrograde
  a curric:Keyword ;
  schema:name "retrograde"@en ;
  schema:description "when a set of notes (like a tone row) is reversed"@en ;
  dcterms:modified "2026-06-07T15:30:02.366839Z"^^xsd:dateTime .

oakcurric:keyword-12-bar-blues
  a curric:Keyword ;
  schema:name "12-bar blues"@en ;
  schema:description """The 12-bar blues is the standard chord sequence in blues, based on chord I,
  IV and V."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367150Z"^^xsd:dateTime .

oakcurric:keyword-blues-scale
  a curric:Keyword ;
  schema:name "Blues scale"@en ;
  schema:description """A blues scale is a minor pentatonic scale with an added blue note between
  the 4th and 5th."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367154Z"^^xsd:dateTime .

oakcurric:keyword-blue-note
  a curric:Keyword ;
  schema:name "Blue note"@en ;
  schema:description """A blue note is a chromatic note that isn't in the key signature. It is
  usually the flattened 3rd, 5th or 7th."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367161Z"^^xsd:dateTime .

oakcurric:keyword-aab-structure
  a curric:Keyword ;
  schema:name "AAB structure"@en ;
  schema:description """An AAB structure is a melodic structure commonly used in blues and rock ‘n’
  roll where the A phrase is performed twice followed by a different (B) phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367166Z"^^xsd:dateTime .

oakcurric:keyword-fusion
  a curric:Keyword ;
  schema:name "fusion"@en ;
  schema:description """the process of blending two or more different musical styles, genres, or
  traditions to create a new, distinct sound"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367339Z"^^xsd:dateTime .

oakcurric:keyword-afrobeat
  a curric:Keyword ;
  schema:name "afrobeat"@en ;
  schema:description """a style of music that originated in Nigeria, often with chanted vocals over
  repeated riffs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368142Z"^^xsd:dateTime .

oakcurric:keyword-riff
  a curric:Keyword ;
  schema:name "riff"@en ;
  schema:description "a short, repeated musical phrase or pattern"@en ;
  dcterms:modified "2026-06-07T15:30:02.368147Z"^^xsd:dateTime .

oakcurric:keyword-bhangra
  a curric:Keyword ;
  schema:name "bhangra"@en ;
  schema:description """a lively form of music and dance that originated in the Punjab region in
  South-east Asia"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368595Z"^^xsd:dateTime .

oakcurric:keyword-hook
  a curric:Keyword ;
  schema:name "hook"@en ;
  schema:description "a memorable, repeated musical idea"@en ;
  dcterms:modified "2026-06-07T15:30:02.368646Z"^^xsd:dateTime .

oakcurric:keyword-rock-n-roll
  a curric:Keyword ;
  schema:name "Rock 'n' roll"@en ;
  schema:description """Rock 'n' roll was an energetic style that developed in the 1950s from blues
  and country music."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370031Z"^^xsd:dateTime .

oakcurric:keyword-walking-bass
  a curric:Keyword ;
  schema:name "Walking bass"@en ;
  schema:description """A walking bass is a moving bass line that 'walks' up and down the notes of a
  chord."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370035Z"^^xsd:dateTime .

oakcurric:keyword-shuffle
  a curric:Keyword ;
  schema:name "Shuffle"@en ;
  schema:description "A shuffle is a rhythmic pattern that uses swing quavers."@en ;
  dcterms:modified "2026-06-07T15:30:02.370040Z"^^xsd:dateTime .

oakcurric:keyword-driving-rhythm
  a curric:Keyword ;
  schema:name "Driving rhythm"@en ;
  schema:description """A driving rhythm is one that repeats fast notes to create a sense of
  energy."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370045Z"^^xsd:dateTime .

oakcurric:keyword-concerto
  a curric:Keyword ;
  schema:name "concerto"@en ;
  schema:description "a composition for a solo instrument with orchestral accompaniment"@en ;
  dcterms:modified "2026-06-07T15:30:02.371100Z"^^xsd:dateTime .

oakcurric:keyword-tutti
  a curric:Keyword ;
  schema:name "tutti"@en ;
  schema:description "In a tutti passage the whole ensemble plays"@en ;
  dcterms:modified "2026-06-07T15:30:02.371106Z"^^xsd:dateTime .

oakcurric:keyword-ritornello
  a curric:Keyword ;
  schema:name "ritornello"@en ;
  schema:description "a recurring passage in a piece of Baroque music"@en ;
  dcterms:modified "2026-06-07T15:30:02.371111Z"^^xsd:dateTime .

oakcurric:keyword-djembe
  a curric:Keyword ;
  schema:name "djembe"@en ;
  schema:description "a goblet-shaped hand drum originating in West Africa"@en ;
  dcterms:modified "2026-06-07T15:30:02.371581Z"^^xsd:dateTime .

oakcurric:keyword-instrumentation
  a curric:Keyword ;
  schema:name "instrumentation"@en ;
  schema:description "the combination of musical instruments used in a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.372637Z"^^xsd:dateTime .

oakcurric:keyword-major
  a curric:Keyword ;
  schema:name "major"@en ;
  schema:description """a specific musical tonality that might be described as joyous, bright or
  cheerful"""@en ;
  dcterms:modified "2026-06-07T15:30:02.372758Z"^^xsd:dateTime .

oakcurric:keyword-drone
  a curric:Keyword ;
  schema:name "drone"@en ;
  schema:description "a constant, pitched sound that continues throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.374156Z"^^xsd:dateTime .

oakcurric:keyword-tanpura
  a curric:Keyword ;
  schema:name "tanpura"@en ;
