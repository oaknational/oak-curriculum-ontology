    oakcurric:keylearningpoint-lesson-8809-3 ,
    oakcurric:keylearningpoint-lesson-8809-4 ;
  curric:hasKeyword
    oakcurric:keyword-rhythmic-dictation ,
    oakcurric:keyword-verbalise ,
    oakcurric:keyword-note-value ;
  curric:hasPupilLessonOutcome oakcurric:pupillessonoutcome-lesson-8809 ;
  curric:hasMisconception
    oakcurric:misconception-longer-note-values-like-minims ;
  dcterms:modified "2026-06-07T15:29:47.459638Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-20054-1
  a curric:KeyLearningPoint ;
  rdfs:label """Melodies that use disjunct movement can be very effective, if disjunct intervals are
  used carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20054-2
  a curric:KeyLearningPoint ;
  rdfs:label "In particular, 3rds, 5ths and octaves tend to be most effective."@en ;
  dcterms:modified "2026-06-07T15:30:28.998878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20054-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any disjunct movement should jump between chord tones."@en ;
  dcterms:modified "2026-06-07T15:30:28.998883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20054-4
  a curric:KeyLearningPoint ;
  rdfs:label "Balanced phrasing is a key feature of Western classical melodies."@en ;
  dcterms:modified "2026-06-07T15:30:28.998887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20054-5
  a curric:KeyLearningPoint ;
  rdfs:label """With this, phrases are an equal length and use a 'question' and 'answer' form with a
  similar rhythm and melodic shape."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20057-1
  a curric:KeyLearningPoint ;
  rdfs:label """When arranging a composition for an ensemble we must consider the strengths of the
  instruments in the ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20057-2
  a curric:KeyLearningPoint ;
  rdfs:label "This includes instrument ranges and possible techniques (such as pizzicato)."@en ;
  dcterms:modified "2026-06-07T15:30:28.998943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20057-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a string quartet, the first violin normally plays the melody and the cello plays
  the bass part."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20057-4
  a curric:KeyLearningPoint ;
  rdfs:label """The second violin and viola play harmony, splitting the remaining chord tones
  between them."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20057-5
  a curric:KeyLearningPoint ;
  rdfs:label """To arrange chords, consider voicing, move by small intervals, and make sure all
  chord tones are played in each chord."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20056-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chord vi is the relative minor chord in a major key."@en ;
  dcterms:modified "2026-06-07T15:30:28.998984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20056-2
  a curric:KeyLearningPoint ;
  rdfs:label """It can be used to briefly suggest minor tonality, adding complexity and interest to
  a chord sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20056-3
  a curric:KeyLearningPoint ;
  rdfs:label """The bass part is crucial to harmony, because it emphasises key notes in each chord
  and determines chord inversions."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20056-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is usually notated in bass clef."@en ;
  dcterms:modified "2026-06-07T15:30:28.998999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20056-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using the bass to emphasise root position chords helps to strengthen the
  harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20055-1
  a curric:KeyLearningPoint ;
  rdfs:label """A typical 16-bar classical melody has a contrasting section of harmony and melody in
  bars 9-12."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20055-2
  a curric:KeyLearningPoint ;
  rdfs:label "This usually ends with chord V, creating an imperfect cadence."@en ;
  dcterms:modified "2026-06-07T15:30:28.999579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20055-3
  a curric:KeyLearningPoint ;
  rdfs:label """The melody and harmony in bar 13-16 typically copy bar 5-8, ending with a perfect
  cadence."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20055-4
  a curric:KeyLearningPoint ;
  rdfs:label """An anacrusis is an interesting melodic feature that can help to make a melody sound
  more unique and interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8628-1
  a curric:KeyLearningPoint ;
  rdfs:label "Effective melodies balance repetition and contrast."@en ;
  dcterms:modified "2026-06-07T15:30:28.999592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8628-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are built using the notes of a particular scale and a variety of rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:28.999596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8628-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using 2-bar phrases and conjunct movement helps a melody to sound effective."@en ;
  dcterms:modified "2026-06-07T15:30:28.999600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8628-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melodies use the dominant (fifth) halfway through to sound unfinished, then the
  tonic at the end to sound finished."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8628-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to write effective melodies without all of these rules, but they are
  a good starting point for composing."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20104-1
  a curric:KeyLearningPoint ;
  rdfs:label "Baroque music has certain distinctive characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.001013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20104-2
  a curric:KeyLearningPoint ;
  rdfs:label "These include use of continuo, terraced dynamics and contrapuntal textures."@en ;
  dcterms:modified "2026-06-07T15:30:29.001040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20104-3
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies are often long and flowing and are decorated with ornamentation."@en ;
  dcterms:modified "2026-06-07T15:30:29.001051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Key genres include the trio sonata, suite, prelude and fugue, concerto and
  overture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20099-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Western Classical Tradition refers to European art music since the Medieval
  period."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20099-2
  a curric:KeyLearningPoint ;
  rdfs:label """The three key eras are the Baroque (1600-1750), Classical (1750-1820) and Romantic
  (1820-1910) periods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20099-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Baroque period used a small orchestra with harpsichord and ornamented melodies.
  Bach was a key composer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20099-4
  a curric:KeyLearningPoint ;
  rdfs:label """Classical composers (e.g. Mozart) began to use the piano and most music had a clear
  melody and accompaniment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20099-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the Romantic period music became much more complex, dramatic and emotive.
  Tchaikovsky was a famous composer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20102-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the Baroque, Classical and Romantic periods, tonality was almost always major or
  minor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20102-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every piece has a key signature, which explains which notes should be used in the
  given key."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Harmony in all three periods is based on primary chords (I, IV and V), with some use
  of secondary chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20102-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romantic composers experimented more with chord choice and chromatic notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.002216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20102-5
  a curric:KeyLearningPoint ;
  rdfs:label """Cadences are fundamental to all three periods with perfect and imperfect cadences
  being the most common."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chamber music is music in the Western Classical Tradition written for a small
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20101-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the Baroque period the trio sonata was the most common form, featuring two
  melodic instruments with basso continuo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20101-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the Classical period the string quartet was very popular, but many other
  combinations of instruments were also used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20101-4
  a curric:KeyLearningPoint ;
  rdfs:label "These included trios, duets, quintets and others."@en ;
  dcterms:modified "2026-06-07T15:30:29.005217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20101-5
  a curric:KeyLearningPoint ;
  rdfs:label """Compositions for solo instrument (with or without accompaniment) have also been
  popular throughout the periods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20108-1
  a curric:KeyLearningPoint ;
  rdfs:label "In the 20th century, classical music developed in various different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.251823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20108-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many composers used non-functional harmony, while some experimented with atonal and
  microtonal music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20108-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimental composers challenged core principles of the Western Classical Tradition
  (e.g. silent music, chance music)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20108-4
  a curric:KeyLearningPoint ;
  rdfs:label """Minimalist composers wrote mostly diatonic music based on repeating ostinati and
  gradual changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20106-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the Romantic period, composers often focused on creating dramatic, emotive and
  highly expressive music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20106-2
  a curric:KeyLearningPoint ;
  rdfs:label """It used complex chromatic harmony and varied textures, timbres and articulation to
  create vivid musical moods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20106-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many composers wrote programme music, using techniques like leitmotif to tell
  stories or evoke images through music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20106-4
  a curric:KeyLearningPoint ;
  rdfs:label """The orchestra became larger and more powerful and, as well as symphonies and
  concertos, tone poems became a key genre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20106-5
  a curric:KeyLearningPoint ;
  rdfs:label """The piano was important, with composers like Chopin exploiting its expressive and
  virtuosic qualities in various genres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20107-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texture and harmony had similarities and differences across the Baroque, Classical
  and Romantic eras."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20107-2
  a curric:KeyLearningPoint ;
  rdfs:label """A key Baroque texture is polyphony, while melody and accompaniment dominated the
  Classical period."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20107-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the Romantic period, music was mostly melody and accompaniment, but was more
  varied and often complex."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20107-4
  a curric:KeyLearningPoint ;
  rdfs:label """Baroque and Classical harmony was diatonic and emphasised modulation to
  closely-related keys."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20107-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romantic harmony was often chromatic and composers experimented with more complex
  modulations and chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8810-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythmic dictation is slightly more complex with syncopated and dotted rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.255829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8810-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying quaver rests (with ‘rest-di’) is useful for accurately notating
  syncopated rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8810-3
  a curric:KeyLearningPoint ;
  rdfs:label """In all time signatures we should make sure that the note values add up to the
  correct number of beats in a bar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8810-4
  a curric:KeyLearningPoint ;
  rdfs:label """In compound time, we must carefully count groups of 3 quavers (using ‘1 and a 2 and
  a’ etc.)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.255842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20100-1
  a curric:KeyLearningPoint ;
  rdfs:label """Between 1600 and 1910 the number of players and variety of instruments in the
  orchestra increased dramatically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20100-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Baroque orchestra was mostly strings with a few woodwind or brass instruments
  and a harpsichord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20100-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Classical orchestra was larger, with more woodwind, brass and percussion and no
  harpsichord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20100-4
  a curric:KeyLearningPoint ;
  rdfs:label """The huge Romantic orchestra had large woodwind, brass and percussion sections,
  giving composers many timbres to exploit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20100-5
  a curric:KeyLearningPoint ;
  rdfs:label """As the orchestra increased in size, woodwind, brass and percussion took on more
  important roles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8812-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying intervals is key to melodic dictation."@en ;
  dcterms:modified "2026-06-07T15:30:29.263042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8812-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use reference melodies to help us identify specific intervals by comparing
  the interval to the specific melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8812-3
  a curric:KeyLearningPoint ;
  rdfs:label "We also need to consider whether an interval is ascending or descending."@en ;
  dcterms:modified "2026-06-07T15:30:29.263052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8812-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have worked out the interval, we can notate it by drawing it on the stave
  next to the given starting note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying the shape of a melody is key to melodic dictation."@en ;
  dcterms:modified "2026-06-07T15:30:29.263074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8811-2
  a curric:KeyLearningPoint ;
  rdfs:label """The melodic shape has to account for ascending and descending pitch, as well as
  conjunct and disjunct movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8811-3
  a curric:KeyLearningPoint ;
  rdfs:label """With disjunct intervals, we have to listen carefully to notice whether they are
  large or small leaps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8811-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can represent melodic shape using a line."@en ;
  dcterms:modified "2026-06-07T15:30:29.263085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8811-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can then approximate the correct pitches by drawing notes in to fit the rough
  melodic shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26648-1
  a curric:KeyLearningPoint ;
  rdfs:label """Melodies can be analysed by looking at melodic shape, intervals, repetition and
  contrast, motifs and phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26648-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most composers develop melodies to create a balance between repetition and
  contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding notes and changing rhythms are simple ways to develop a melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.263234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Augmentation, diminution and sequences are also common methods for melodic
  development."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26651-1
  a curric:KeyLearningPoint ;
  rdfs:label """Major triads, minor triads and extended chords can be identified by listening
  carefully to the feeling of each chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26651-2
  a curric:KeyLearningPoint ;
  rdfs:label "The tonic chord (I) can be identified by the ‘finished’ feeling that it creates."@en ;
  dcterms:modified "2026-06-07T15:30:29.263661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26651-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dominant (V) and subdominant (IV) chords can be identified by listening for the
  bass notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26651-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify cadences by the feeling they create - perfect and plagal feel
  finished, imperfect and interrupted don’t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26651-5
  a curric:KeyLearningPoint ;
  rdfs:label """Listening for the bass notes helps to distinguish between perfect (V-I) and plagal
  (IV-I) cadences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29425-1
  a curric:KeyLearningPoint ;
  rdfs:label """Time signatures (or metre) can be grouped into simple, compound and irregular time
  signatures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29425-2
  a curric:KeyLearningPoint ;
  rdfs:label "Simple time signatures have two quavers in each beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.263973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29425-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compound time signatures have three quavers in each beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.263977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29425-4
  a curric:KeyLearningPoint ;
  rdfs:label """Simple and compound time signatures can also be described as duple (2), triple (3)
  or quadruple (4 beats)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29425-5
  a curric:KeyLearningPoint ;
  rdfs:label """Irregular time signatures cannot be counted with groups of only 2 or only 3 beats.
  Examples are 7/8 and 5/4."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29424-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texture refers to both the number of different musical lines and the way that they
  relate to each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29424-2
  a curric:KeyLearningPoint ;
  rdfs:label """Common textures include monophonic, homophonic, unison, melody and accompaniment and
  polyphonic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29424-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other specific relationships between parts include contrary motion, imitation and
  harmonisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29420-1
  a curric:KeyLearningPoint ;
  rdfs:label """The orchestra is home to a diverse range of instruments which use different effects
  to create different timbres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29420-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some common effects include: arco, pizzicato, muted, and double-stopping."@en ;
  dcterms:modified "2026-06-07T15:30:29.264732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29420-3
  a curric:KeyLearningPoint ;
  rdfs:label "Styles of popular music often use different timbres."@en ;
  dcterms:modified "2026-06-07T15:30:29.264737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29420-4
  a curric:KeyLearningPoint ;
  rdfs:label """The synthesiser creates a wide range of different sounds, including different synth
  leads, pads and basses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29422-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vocals are very diverse, with numerous voice types, styles and techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.264829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29422-2
  a curric:KeyLearningPoint ;
  rdfs:label """An SATB choir is made up of the following female and male vocal types: soprano,
  alto, tenor and bass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29422-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some common vocal techniques include melisma, vibrato and rapping."@en ;
  dcterms:modified "2026-06-07T15:30:29.264838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29422-4
  a curric:KeyLearningPoint ;
  rdfs:label """In some styles, microtonal singing, scat singing and beatboxing can also be
  heard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29429-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many styles around the world are defined by idiomatic rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.265834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29429-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of these are linked with specific styles, such as skank (reggae), chaal
  (bhangra) and scotch snap (Celtic folk)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29429-3
  a curric:KeyLearningPoint ;
  rdfs:label """Others have their roots in specific regions, but are used in many styles, such as
  the clave and tresillo rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29429-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some are not specific rhythms, but types of rhythms, such as swing, free rhythms and
  driving rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20129-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Classical concerto uses a larger orchestra than Baroque, with no continuo and a
  broader range of solo instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20129-2
  a curric:KeyLearningPoint ;
  rdfs:label """The first movement typically uses sonata form - exposition, development and
  recapitulation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20129-3
  a curric:KeyLearningPoint ;
  rdfs:label """The texture is usually melody and accompaniment, with a melody based on balanced
  phrasing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20129-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cadenzas are an opportunity for soloists to show off their technical skill, with
  virtuosic playing in a free tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8709-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arabic music has a long and complex history and is extremely varied."@en ;
  dcterms:modified "2026-06-07T15:30:29.267569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8709-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two key instruments in Palestinian folk music are the doumbek and oud."@en ;
  dcterms:modified "2026-06-07T15:30:29.267575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8709-3
  a curric:KeyLearningPoint ;
  rdfs:label """The doumbek uses three sounds - doum (middle of the drum), tek (edge of the drum)
  and ka (ring finger on edge of drum)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8709-4
  a curric:KeyLearningPoint ;
  rdfs:label """Palestinian folk music uses a wazn, a rhythmic cycle or pattern. Maqsum and saidi
  are two examples of this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notating a whole melody can be done by breaking it into a series of consecutive
  intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8813-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identify the melodic shape, then identify the first interval by singing it back and
  compare it to reference melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8813-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notate the first interval, then repeat for each consecutive interval."@en ;
  dcterms:modified "2026-06-07T15:30:29.267643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8813-4
  a curric:KeyLearningPoint ;
  rdfs:label """Check your answer by matching it to the melodic shape visually and singing
  it back."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8813-5
  a curric:KeyLearningPoint ;
  rdfs:label """When given the rhythm, we should be careful to accurately copy it in the notated
  pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29423-1
  a curric:KeyLearningPoint ;
  rdfs:label """Technology has hugely influenced the way that music is produced, edited and
  manipulated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29423-2
  a curric:KeyLearningPoint ;
  rdfs:label """Synth pads, leads, basses and drum machines are common tools for producing sounds
  electronically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29423-3
  a curric:KeyLearningPoint ;
  rdfs:label "Effects can be applied either live or after recording."@en ;
  dcterms:modified "2026-06-07T15:30:29.268159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29423-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some common effects are delay, reverb, chorus, auto-tune, distortion, panning and
  equalisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29423-5
  a curric:KeyLearningPoint ;
  rdfs:label """Overdubbing and DJing are two other important ways that technology has shaped modern
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Good melodies use some repetition and have a distinctive shape and can use conjunct
  and disjunct intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Melodies all have rhythm. There are a variety of rhythmic choices that can be used
  to reflect the character of a melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20064-3
  a curric:KeyLearningPoint ;
  rdfs:label "A melody can be expressive with appropriate tempo, dynamics and articulation."@en ;
  dcterms:modified "2026-06-07T15:30:29.271437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20068-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing for instruments music has to be playable and maximise the unique
  characteristics of the instrument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Range, intervals and how the instrument can be played is important in idiomatic
  writing for an instrument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20068-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some instruments can change timbre i.e. strings can play bowed or pizzicato."@en ;
  dcterms:modified "2026-06-07T15:30:29.275968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20068-4
  a curric:KeyLearningPoint ;
  rdfs:label "Timbre can also be changed for expressive purposes, including using vibrato."@en ;
  dcterms:modified "2026-06-07T15:30:29.275971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20068-5
  a curric:KeyLearningPoint ;
  rdfs:label "Creative use of timbre can add interest and variety to compositions."@en ;
  dcterms:modified "2026-06-07T15:30:29.275975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8663-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rock 'n' roll is an energetic style that developed in the 1950s."@en ;
  dcterms:modified "2026-06-07T15:30:29.278290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8663-2
  a curric:KeyLearningPoint ;
  rdfs:label "It was very popular with young people and became the first successful pop style."@en ;
  dcterms:modified "2026-06-07T15:30:29.278294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8663-3
  a curric:KeyLearningPoint ;
  rdfs:label "It incorporates key blues features, including the 12-bar blues."@en ;
  dcterms:modified "2026-06-07T15:30:29.278298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8663-4
  a curric:KeyLearningPoint ;
  rdfs:label "This is a repeating chord sequence which uses the primary chords I, IV and V."@en ;
  dcterms:modified "2026-06-07T15:30:29.278302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8663-5
  a curric:KeyLearningPoint ;
  rdfs:label """It also typically uses either a pentatonic or a blues scale (a minor pentatonic with
  a blue note added) in the melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rock 'n' roll is an energetic style that developed in the 1950s from blues and
  country music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8664-2
  a curric:KeyLearningPoint ;
  rdfs:label """It incorporates key blues features including the 12-bar blues, walking bass and
  swing/shuffle rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8664-3
  a curric:KeyLearningPoint ;
  rdfs:label """Driving rhythms and intense 'shouty' vocals help to give rock 'n' roll its
  distinctive style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8664-4
  a curric:KeyLearningPoint ;
  rdfs:label """Other key features include a fast tempo, vocal melodies with a small range of notes
  and a verse-chorus structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8664-5
  a curric:KeyLearningPoint ;
  rdfs:label """Typical instrumentation includes vocals, electric guitar, piano, drum kit and bass
  guitar or double bass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20127-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Baroque solo concerto features many typical features of Baroque music."@en ;
  dcterms:modified "2026-06-07T15:30:29.287469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20127-2
  a curric:KeyLearningPoint ;
  rdfs:label """These include a typical Baroque orchestra with continuo, and melodic features such
  as ornamentation and imitation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20127-3
  a curric:KeyLearningPoint ;
  rdfs:label """Baroque concertos create contrast through use of tutti and solo sections, terraced
  dynamics and contrasting textures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20127-4
  a curric:KeyLearningPoint ;
  rdfs:label """The three movements of a concerto contrast with each other, and often one or more
  use ritornello form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20127-5
  a curric:KeyLearningPoint ;
  rdfs:label "This features a ritornello section that returns throughout."@en ;
  dcterms:modified "2026-06-07T15:30:29.287489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29430-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dynamics and articulation have a big impact on musical mood and character."@en ;
  dcterms:modified "2026-06-07T15:30:29.308825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29430-2
  a curric:KeyLearningPoint ;
  rdfs:label "The most common dynamics are piano (p) and forte (f)."@en ;
  dcterms:modified "2026-06-07T15:30:29.308829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29430-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dynamic changes are indicated with crescendo, diminuendo and subito (sudden) and
  poco a poco (little by little)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29430-4
  a curric:KeyLearningPoint ;
  rdfs:label "Staccato and legato (slurred) are the most common types of articulation."@en ;
  dcterms:modified "2026-06-07T15:30:29.308837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29430-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different kinds of articulation include accents, tenuto, marcato and sforzando."@en ;
  dcterms:modified "2026-06-07T15:30:29.308841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8624-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chord sequences provide the harmony of a song. Chords I, IV, V and vi are the most
  common."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8624-2
  a curric:KeyLearningPoint ;
  rdfs:label """Roman numerals refer to degrees of the scale which allow musicians to work out chord
  patterns in different keys."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8624-3
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed the I - V - vi - IV chord sequence in the key of C, F and G and
  composed a 4- or 8-bar sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8624-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing chord sequences for a pop song, we also need to consider using common
  notes from the riff."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8627-1
  a curric:KeyLearningPoint ;
  rdfs:label """The drummer’s main role in the rhythm section is to establish the tempo and rhythmic
  groove."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8627-2
  a curric:KeyLearningPoint ;
  rdfs:label """They typically play a backbeat on the snare, beats 1 and 3 on the kick and quavers
  on the hi-hat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Combining a riff with chords, a bass line and a drum beat can create the
  accompanying parts of pop song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8627-4
  a curric:KeyLearningPoint ;
  rdfs:label "A pop song has two main sections, a verse and a chorus."@en ;
  dcterms:modified "2026-06-07T15:30:29.319449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8627-5
  a curric:KeyLearningPoint ;
  rdfs:label "It is important that they have both similarities and contrasting ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.319453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8625-1
  a curric:KeyLearningPoint ;
  rdfs:label """A hook is a musical idea designed to ‘catch’ the listener's ear and is usually the
  most memorable part of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8625-2
  a curric:KeyLearningPoint ;
  rdfs:label """A riff is a repeated musical phrase that is typically the defining melodic material
  of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8625-3
  a curric:KeyLearningPoint ;
  rdfs:label "A successful riff is short, simple, consonant and repeatable."@en ;
  dcterms:modified "2026-06-07T15:30:29.330279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8625-4
  a curric:KeyLearningPoint ;
  rdfs:label "When composing a pop song, it is common to start with a riff."@en ;
  dcterms:modified "2026-06-07T15:30:29.330283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8625-5
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a riff, we must ensure that it is short and simple. Less is more!"@en ;
  dcterms:modified "2026-06-07T15:30:29.330287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20067-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texture is an important element to consider when composing. Melody and accompaniment
  is the most common musical texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20067-2
  a curric:KeyLearningPoint ;
  rdfs:label "Composers also use homophonic, polyphonic and monophonic textures."@en ;
  dcterms:modified "2026-06-07T15:30:29.332637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20067-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a melody and accompaniment texture the lead line or melody should be clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.332641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20067-4
  a curric:KeyLearningPoint ;
  rdfs:label """Less important musical lines can contrast by using less interesting rhythms and
  melodic shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20066-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm and syllables of words can help us create rhythmic variety in our
  compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Variety is important as it creates interest for the listener, so we need to use both
  simple and complex rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20066-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can also use syncopation and polyrhythms to create interest."@en ;
  dcterms:modified "2026-06-07T15:30:29.332681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20066-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using repeated patterns or an ostinato allows the music to have a sense of
  unity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20130-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Romantic concerto mirrored many typical features of Romantic music."@en ;
  dcterms:modified "2026-06-07T15:30:29.332791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20130-2
  a curric:KeyLearningPoint ;
  rdfs:label """These include more complex textures, chromatic harmony, a larger orchestra and an
  emphasis on intense, expressive music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20130-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many Romantic concertos are extremely difficult for soloists and are highly
  virtuosic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20130-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bruch’s Violin Concerto reflects many of these typical features."@en ;
  dcterms:modified "2026-06-07T15:30:29.332803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20065-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers often create chord progressions to underpin their music."@en ;
  dcterms:modified "2026-06-07T15:30:29.332807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20065-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can start with a chord progression before you create a melody, or start with a
  melody then add chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20065-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding chords to a melody is called harmonisation."@en ;
  dcterms:modified "2026-06-07T15:30:29.332815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20065-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can create dissonance by using chords that are not triads and using occasional
  melody notes from outside the chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20065-5
  a curric:KeyLearningPoint ;
  rdfs:label "Broken chords and chord inversions can add interest to a chord progression."@en ;
  dcterms:modified "2026-06-07T15:30:29.332823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8682-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bhangra has continued to develop as a style, not only in the Punjab but also
  separately in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8682-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modern bhangra is a fusion of elements of traditional Punjabi music and Western
  popular music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8682-3
  a curric:KeyLearningPoint ;
  rdfs:label """A typical bhangra groove includes chaal on the dhol and a tumbi playing a simple,
  repeated pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8682-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vocals in bhangra are influenced by Punjabi traditions. They are often microtonal,
  melismatic and 'bend' between notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8681-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bhangra is a traditional Punjabi dance and form of music that has its roots in
  farming communities of the Punjab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8681-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the 20th century it evolved into a new style of music, which has distinct
  characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8681-3
  a curric:KeyLearningPoint ;
  rdfs:label """One distinct feature is a rhythm that is referred to as 'chaal' (meaning 'movement'
  in Punjabi)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8681-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chaal is a rhythm in 4/4, with each beat divided in three. It emphasises beat one
  and four."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8681-5
  a curric:KeyLearningPoint ;
  rdfs:label """Typically chaal is played on a two-headed drum called a dhol, or sometimes a smaller
  version called a dholak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20111-1
  a curric:KeyLearningPoint ;
  rdfs:label """Calypso and mento are important musical styles from the Caribbean that have their
  roots in colonial history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20111-2
  a curric:KeyLearningPoint ;
  rdfs:label """While they have some similar features, there are big differences in lyrics, origins
  and instrumentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20111-3
  a curric:KeyLearningPoint ;
  rdfs:label """Soca is a repetitive, catchy upbeat style that developed from calypso in the 1970s
  as a form of dance music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20111-4
  a curric:KeyLearningPoint ;
  rdfs:label "All three styles use some similar syncopated rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.336424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20111-5
  a curric:KeyLearningPoint ;
  rdfs:label """Steel pans are a key part of the culture of Trinidad and Tobago, and often perform
  calypso as well as other styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8708-1
  a curric:KeyLearningPoint ;
  rdfs:label """Film composers have to carefully match musical changes to precise cues and
  timestamps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8708-2
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating the tempo is one method that helps to fit sections of music to specific
  timings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8708-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes transitions between sections are deliberately sudden to match sudden
  changes in the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8708-4
  a curric:KeyLearningPoint ;
  rdfs:label """Composers can also make more musical transitions by ‘blending’ features of the two
  sections to create a seamless change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8683-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bhangra uses music technology extensively, in common with other modern dance
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sampling and looping are common in bhangra, as well as the use of effects including
  echo, delay and filters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8683-3
  a curric:KeyLearningPoint ;
  rdfs:label "Modern bhangra also commonly uses synthesisers."@en ;
  dcterms:modified "2026-06-07T15:30:29.340114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8683-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a simple bhangra groove with chaal, a riff and a chord sequence with a
  simple bass line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8704-1
  a curric:KeyLearningPoint ;
  rdfs:label "Harmony and tonality have a significant impact on the mood of film music."@en ;
  dcterms:modified "2026-06-07T15:30:29.341235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8704-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use atonal, diatonic (major or minor) or modal tonality to create
  different moods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8704-3
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of chords and use of chromatic harmony are also important for creating
  the correct emotions for the scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8704-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reharmonising a melody, by changing the harmony, is an effective way to develop a
  melodic idea in a film."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8706-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm and texture are crucial elements to develop when creating music for action
  scenes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8706-2
  a curric:KeyLearningPoint ;
  rdfs:label """Repeating ostinati, driving rhythms and accents can create a sense of energy and
  excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8706-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thickening the texture also builds energy and excitement."@en ;
  dcterms:modified "2026-06-07T15:30:29.341346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8706-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using these strategies, a simple melodic idea can be developed into exciting music
  for an action scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Palestinian folk music has many popular forms, many of which are performed for
  dance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8710-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ataaba is a popular song form in Palestine, and dabke is an important traditional
  form of dance across the region."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8710-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional Palestinian and Arabic music is based on a maqam, which is a set of
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8710-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each maqam is microtonal and includes seven notes. They are usually taught by ear.
  Bayati is a common maqam."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8710-5
  a curric:KeyLearningPoint ;
  rdfs:label """Performers improvise using the maqam, including in taqsim at the start of a
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20058-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding countermelodies and developing texture are effective ways to develop an
  ensemble composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20058-2
  a curric:KeyLearningPoint ;
  rdfs:label """A countermelody is a second and equally prominent melody that plays at the same time
  as the main melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20058-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a string quartet, the second violin or viola normally play countermelodies,
  although sometimes the cello does."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20058-4
  a curric:KeyLearningPoint ;
  rdfs:label """When adding countermelodies or developing texture it is crucial to make sure that
  every part can still be heard well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20058-5
  a curric:KeyLearningPoint ;
  rdfs:label """The chord tones of each chord should still be played across all parts to ensure the
  harmony is still effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20128-1
  a curric:KeyLearningPoint ;
  rdfs:label """The concerto grosso is a type of Baroque concerto that includes more than one
  soloist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20128-2
  a curric:KeyLearningPoint ;
  rdfs:label """The group of soloists is called the concertino. It usually has two or three
  performers, most commonly violin and cello."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20128-3
  a curric:KeyLearningPoint ;
  rdfs:label """The accompanying group is called the ripieno, normally based around strings and
  continuo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20128-4
  a curric:KeyLearningPoint ;
  rdfs:label "The concertino and ripieno interact in different ways, creating contrast."@en ;
  dcterms:modified "2026-06-07T15:30:29.359101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29421-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a huge diversity of instruments around the world. Some have crossed between
  musical genres and traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29421-2
  a curric:KeyLearningPoint ;
  rdfs:label "Common non-Western drums include tabla, timbales, conga, djembe and dhol."@en ;
  dcterms:modified "2026-06-07T15:30:29.359894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29421-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many other important percussion instruments, including both tuned and
  untuned percussion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29421-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is also a diverse range of stringed instruments that can be heard."@en ;
  dcterms:modified "2026-06-07T15:30:29.359902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29421-5
  a curric:KeyLearningPoint ;
  rdfs:label """These include guitar-like instruments like banjo, mandolin and bouzouki, and other
  instruments like tanpura and sarangi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29428-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many melodies use an anacrusis to start before beat one (the downbeat)."@en ;
  dcterms:modified "2026-06-07T15:30:29.360001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29428-2
  a curric:KeyLearningPoint ;
  rdfs:label """Polyrhythms include multiple rhythms that aren’t closely related playing together,
  creating a complex rhythmic texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29428-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cross rhythms create the feeling of different pulses playing simultaneously."@en ;
  dcterms:modified "2026-06-07T15:30:29.360031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29428-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hemiola is used to create a brief effect of the pulse changing (by playing three
  notes over two beats or vice versa)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29428-5
  a curric:KeyLearningPoint ;
  rdfs:label """Diminution and augmentation develop rhythmic ideas by proportionally shortening or
  lengthening notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8679-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most musical styles are some form of fusion of different musical influences."@en ;
  dcterms:modified "2026-06-07T15:30:29.360101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8679-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many key Latin-American musical styles are a fusion of African and European
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8679-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many of these Latin styles have also created fusions with other styles, such as jazz
  and rock."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8679-4
  a curric:KeyLearningPoint ;
  rdfs:label """Afrobeat is a style from the 1960s and 1970s that fuses aspects of West African
  music with jazz, funk and soul."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8679-5
  a curric:KeyLearningPoint ;
  rdfs:label """Afrobeats is a term used to describe a wide range of different modern fusion styles
  from Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8711-1
  a curric:KeyLearningPoint ;
  rdfs:label """Israeli folk music is influenced by various global regions and has strong ties with
  Jewish folk music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8711-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is often used to accompany dance, in particular at celebrations and festive
  occasions in Israel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8711-3
  a curric:KeyLearningPoint ;
  rdfs:label "The music is energetic, upbeat and has a strong rhythmic pulse for dancing to."@en ;
  dcterms:modified "2026-06-07T15:30:29.361249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8711-4
  a curric:KeyLearningPoint ;
  rdfs:label """Its distinct sound comes from its use of off-beat chords, accelerando and
  ornamentation, including note bends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8711-5
  a curric:KeyLearningPoint ;
  rdfs:label "Typical instruments include violin, clarinet and accordion."@en ;
  dcterms:modified "2026-06-07T15:30:29.361261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20109-1
  a curric:KeyLearningPoint ;
  rdfs:label "The music of Latin America is extremely varied."@en ;
  dcterms:modified "2026-06-07T15:30:29.364109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20109-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many styles are influenced by colonial history, drawing on European, Asian, African
  and indigenous American music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many styles use Latin percussion instruments, including woodblock, claves, guiro,
  congas, bongos and maracas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20109-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are often complex syncopated rhythms, including the son clave and rumba clave
  rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20109-5
  a curric:KeyLearningPoint ;
  rdfs:label "A clave rhythm can be arranged as a 3-2 clave or a 2-3 clave."@en ;
  dcterms:modified "2026-06-07T15:30:29.364129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20071-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers should carefully consider how to use rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.365733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers can use augmentation and diminution to develop musical ideas, such as new
  melodic ideas or countermelodies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20071-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our composing skills develop through making the most of small musical ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.365741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20071-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using rhythmic devices creates interest and variety for the listener."@en ;
  dcterms:modified "2026-06-07T15:30:29.365747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20073-1
  a curric:KeyLearningPoint ;
  rdfs:label "When musical material returns, composers often make subtle changes to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.365822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20073-2
  a curric:KeyLearningPoint ;
  rdfs:label """Keeping the melody and harmony recognisable is important when developing repeated
  sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20073-3
  a curric:KeyLearningPoint ;
  rdfs:label """In new sections, like a B section in ternary form, new melodic and harmonic ideas
  can be derived from earlier sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20073-4
  a curric:KeyLearningPoint ;
  rdfs:label """This maintains the coherence of the music and shows understanding of how musical
  elements can be explored creatively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8680-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many examples of musical fusion between Western musical styles and music
  from the Indian subcontinent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8680-2
  a curric:KeyLearningPoint ;
  rdfs:label """These usually mix typical instruments (such as sitar, tanpura and tabla), rhythms
  and melodies from the styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8680-3
  a curric:KeyLearningPoint ;
  rdfs:label "The same is the case with the traditional Celtic music of Scotland and Ireland."@en ;
  dcterms:modified "2026-06-07T15:30:29.366525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8680-4
  a curric:KeyLearningPoint ;
  rdfs:label """Celtic melodies and instruments including the fiddle, tin whistle and accordion are
  used in fusion with other styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8680-5
  a curric:KeyLearningPoint ;
  rdfs:label """Jazz, rock and electronic are some of the more common Western styles that are fused
  with Celtic and South Asian styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20072-1
  a curric:KeyLearningPoint ;
  rdfs:label """To create contrast in a composition it is important to vary the texture and
  timbre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20072-2
  a curric:KeyLearningPoint ;
  rdfs:label """This might include changing which part plays the melody and which parts are
  accompanying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20072-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use a range of accompaniment patterns to create the mood and character in
  the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20072-4
  a curric:KeyLearningPoint ;
  rdfs:label "These include broken chords and Alberti bass patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.368760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20072-5
  a curric:KeyLearningPoint ;
  rdfs:label "They change these patterns to create variety and contrast between sections."@en ;
  dcterms:modified "2026-06-07T15:30:29.368764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20062-1
  a curric:KeyLearningPoint ;
  rdfs:label """West Africa has a long history of music and dance. Many Western styles can trace
  their roots back to this region."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20062-2
  a curric:KeyLearningPoint ;
  rdfs:label """While the music is extremely varied, many traditional styles have similar features
  and instrumentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20062-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most traditional styles in the region use percussion instruments, including djembe,
  agogo bell, dunun and shekere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20062-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polyrhythm and cross rhythms are common features across various traditions."@en ;
  dcterms:modified "2026-06-07T15:30:29.368801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20062-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most of these traditions combine music and dance together."@en ;
  dcterms:modified "2026-06-07T15:30:29.368805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20070-1
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the harmonic rhythm can add interest to a composition. It can dramatically
  alter the mood in a piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20070-2
  a curric:KeyLearningPoint ;
  rdfs:label """Harmonic devices such as pedal notes and drones are useful for building harmonic
  tension and adding colour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20070-3
  a curric:KeyLearningPoint ;
  rdfs:label """By adding extensions to chords, composers can enhance the expressive qualities of
  chord sequences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers develop their musical ideas by exploring different ways of transforming
  the material."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20069-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sequence, retrograde and inversion are compositional devices that we can use to
  transform melodic ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20069-3
  a curric:KeyLearningPoint ;
  rdfs:label """A balance of repetition and contrast is important in making your music interesting
  but memorable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20069-4
  a curric:KeyLearningPoint ;
  rdfs:label """New ideas can be derived from already established ones by developing a few
  interesting, distinctive ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20063-1
  a curric:KeyLearningPoint ;
  rdfs:label "West African percussive music is often rhythmically complex."@en ;
  dcterms:modified "2026-06-07T15:30:29.369292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20063-2
  a curric:KeyLearningPoint ;
  rdfs:label """West African musicians traditionally don't use notation, but instead learn rhythms
  by ear and through movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20063-3
  a curric:KeyLearningPoint ;
  rdfs:label """A compound time signature has each beat divided into three quavers. 6/8 is a common
  example of this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20063-4
  a curric:KeyLearningPoint ;
  rdfs:label "In a simple time signature each beat is divided into two quavers."@en ;
  dcterms:modified "2026-06-07T15:30:29.369308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20063-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some West African music has a feel of compound time, including akom and dununba."@en ;
  dcterms:modified "2026-06-07T15:30:29.369313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20112-1
  a curric:KeyLearningPoint ;
  rdfs:label """Samba is a form of Brazilian dance and music which comes in many forms, one of which
  is batucada."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20112-2
  a curric:KeyLearningPoint ;
  rdfs:label """Batucada is often played at celebrations and carnival, and is performed by a
  percussion ensemble called a bateria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20112-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bossa nova adapts many of the features of samba to create a more relaxed style."@en ;
  dcterms:modified "2026-06-07T15:30:29.369798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20112-4
  a curric:KeyLearningPoint ;
  rdfs:label "It often uses a version of the clave called the bossa nova clave."@en ;
  dcterms:modified "2026-06-07T15:30:29.369802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20112-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many other styles exist in the region, including habanera, tango, danzón,
  cha-cha-chá and rumba."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8712-1
  a curric:KeyLearningPoint ;
  rdfs:label "Greek folk music includes both folk songs and music for dance."@en ;
  dcterms:modified "2026-06-07T15:30:29.370012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8712-2
  a curric:KeyLearningPoint ;
  rdfs:label """It uses a mix of common Western instruments and traditional Greek instruments,
  including the bouzouki and defi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8712-3
  a curric:KeyLearningPoint ;
  rdfs:label "Much Greek folk music uses irregular time signatures such as 5/8 and 7/8."@en ;
  dcterms:modified "2026-06-07T15:30:29.370020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8712-4
  a curric:KeyLearningPoint ;
  rdfs:label "Kalamatianó is a type of Greek folk dance which is based in 7/8."@en ;
  dcterms:modified "2026-06-07T15:30:29.370026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8712-5
  a curric:KeyLearningPoint ;
  rdfs:label "Usually 7/8 is counted as a 3-2-2. 5/8 is counted as 3-2."@en ;
  dcterms:modified "2026-06-07T15:30:29.370030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20061-1
  a curric:KeyLearningPoint ;
  rdfs:label """North Indian classical music has a typical structure consisting of alap, gat and
  jhala."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20061-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alap is the introduction, with a free tempo and the sitar player improvising on the
  raga."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20061-3
  a curric:KeyLearningPoint ;
  rdfs:label """In gat, there is a clear pulse on the tabla, and a more structured melody on the
  sitar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20061-4
  a curric:KeyLearningPoint ;
  rdfs:label """In jhala, it speeds up and the performers play more complex music in a virtuosic
  style, building to a frantic finale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20059-1
  a curric:KeyLearningPoint ;
  rdfs:label """North Indian classical music typically involves three features - rhythm, melody and
  drone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20059-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sitar typically plays the melody, accompanied by rhythms on the tabla and a
  sustained drone on the tanpura."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20059-3
  a curric:KeyLearningPoint ;
  rdfs:label """North Indian classical music is based on raga. Each raga is a set of notes that has
  a specific mood associated with it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20059-4
  a curric:KeyLearningPoint ;
  rdfs:label "Performers improvise using a raga to create the alap section."@en ;
  dcterms:modified "2026-06-07T15:30:29.370204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20059-5
  a curric:KeyLearningPoint ;
  rdfs:label """This is the first section in a piece of North Indian classical music, in which there
  is no clear pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20060-1
  a curric:KeyLearningPoint ;
  rdfs:label """Singing in North Indian classical music can be in many languages, most commonly
  Hindi and Urdu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20060-2
  a curric:KeyLearningPoint ;
  rdfs:label "Singers use the raga, and the style is melismatic and microtonal."@en ;
  dcterms:modified "2026-06-07T15:30:29.370675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20060-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tala are repeating rhythmic patterns. They are taught by ear, using the sounds da,
  dhin, tin, ti, na and ta."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20060-4
  a curric:KeyLearningPoint ;
  rdfs:label """Teental is a popular tala in North Indian classical music. It is sixteen
  beats long."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26650-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tonality determines the notes that are used in a piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.371911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26650-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lots of Western music is diatonic or chromatic, while many traditional styles around
  the world are modal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26650-3
  a curric:KeyLearningPoint ;
  rdfs:label """Atonal music has no key and microtonal music uses notes from in between the
  semitones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26650-4
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying intervals allows musicians to work out musical ideas by ear."@en ;
  dcterms:modified "2026-06-07T15:30:29.371923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26650-5
  a curric:KeyLearningPoint ;
  rdfs:label "The simplest way to do this is by comparing intervals to reference songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.371927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26652-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use various common harmonic devices to enhance harmony and create certain
  musical effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Drones, pedals and ground bass are all determined by the bass parts and how they
  relate to the chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26652-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modulations are changes in key that can radically alter the mood of a piece of
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26652-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suspensions are a specific type of dissonance that is used to create harmonic
  tension and resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26649-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers use different melodic devices to develop and enhance their melodies."@en ;
  dcterms:modified "2026-06-07T15:30:29.372220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ornamentation is a common melodic device in many styles."@en ;
  dcterms:modified "2026-06-07T15:30:29.372225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26649-3
  a curric:KeyLearningPoint ;
  rdfs:label "Common ornaments are trills, grace notes, turns and mordents."@en ;
  dcterms:modified "2026-06-07T15:30:29.372229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26649-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imitation is a device where a part of a melody is copied in another part immediately
  or shortly afterwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26649-5
  a curric:KeyLearningPoint ;
  rdfs:label """A countermelody is a contrasting second melody. It plays at the same time as the
  main melody and has equal prominence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29427-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different Italian terms to describe tempo, including largo, allegro
  and presto."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29427-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tempo can also be measured in beats per minute (BPM)."@en ;
  dcterms:modified "2026-06-07T15:30:29.372368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29427-3
  a curric:KeyLearningPoint ;
  rdfs:label "Accelerando, ritardando and rubato change the tempo during a composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.372372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29427-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the most common rhythmic features include syncopation, rhythmic motifs and
  cells and rhythmic repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8800-1
  a curric:KeyLearningPoint ;
  rdfs:label """A description of rhythm should mention specific note lengths or patterns, as well as
  any idiomatic rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8800-2
  a curric:KeyLearningPoint ;
  rdfs:label """A description of metre and tempo should use technical terms (e.g. presto) and
  identify tempo changes (e.g. rubato)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8800-3
  a curric:KeyLearningPoint ;
  rdfs:label """Timbre encompasses both the instruments that are used and the specific sounds or
  techniques used on them (e.g. muted)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8800-4
  a curric:KeyLearningPoint ;
  rdfs:label """Describing articulation and dynamics refers to how the note is played and how loud
  or soft the music is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Video game composers make music adaptive by using linear loops and vertical
  layering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8745-2
  a curric:KeyLearningPoint ;
  rdfs:label """This allows music to quickly and seamlessly respond to changes caused by a player’s
  actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8745-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding (or removing) layers to develop the texture is one way to do vertical
  layering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a harmonised melody is another common tool used by composers for this
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8678-1
  a curric:KeyLearningPoint ;
  rdfs:label """Developing a leitmotif to reflect changes in the story is called motivic
  transformation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8678-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers do this in many different ways, including extending or combining
  leitmotifs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reharmonising leitmotifs by changing the harmony but keeping the melody the same is
  an effective technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8678-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changing features of the leitmotif such as rhythm, dynamics, articulation and
  tonality is also common."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8678-5
  a curric:KeyLearningPoint ;
  rdfs:label """Key to motivic transformation is keeping the leitmotif recognisable and matching the
  mood of the moment in the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8674-1
  a curric:KeyLearningPoint ;
  rdfs:label "Film music is used in a variety of ways to support the action on screen."@en ;
  dcterms:modified "2026-06-07T15:30:29.428737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8674-2
  a curric:KeyLearningPoint ;
  rdfs:label """These include establishing the mood, setting the scene and creating tension and
  excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8674-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using leitmotif to represent particular characters or ideas is another effective
  technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8674-4
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use the musical elements to create appropriate atmospheres, including
  careful use of tonality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8674-5
  a curric:KeyLearningPoint ;
  rdfs:label "We have composed a short piece of film music using a repeated ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.428758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8677-1
  a curric:KeyLearningPoint ;
  rdfs:label "Leitmotifs must reflect the character or mood of what they represent."@en ;
  dcterms:modified "2026-06-07T15:30:29.428862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8677-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carefully planning how to use the musical elements such as tonality and rhythm is a
  key part of this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8677-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, we must also consider how melodic shape affects the character of a
  leitmotif."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8677-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using conjunct or disjunct intervals in a melody can also shape the mood or feeling
  that it creates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8744-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important that a video game theme song captures the atmosphere of the
  game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8744-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a high-energy racing game, the theme song should create a feeling of excitement
  and energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8744-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use fast, rhythmic percussion layers to add excitement."@en ;
  dcterms:modified "2026-06-07T15:30:29.428955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8744-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also create an energetic driving bass line to add to this energy, including
  using chord notes and passing notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8676-1
  a curric:KeyLearningPoint ;
  rdfs:label """Leitmotif is a technique that developed from opera and programme music in the 19th
  century."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8676-2
  a curric:KeyLearningPoint ;
  rdfs:label "Leitmotifs are used to represent characters, places or ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.429122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8676-3
  a curric:KeyLearningPoint ;
  rdfs:label "They often change to match changes in the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.429126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8676-4
  a curric:KeyLearningPoint ;
  rdfs:label """We must carefully consider the musical elements to make sure that the leitmotif
  suits the character or idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8676-5
  a curric:KeyLearningPoint ;
  rdfs:label """This includes harmony, tonality (major and minor), rhythm, timbre, articulation and
  dynamics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8746-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptive music in video games uses two techniques to respond to a player’s
  actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8746-2
  a curric:KeyLearningPoint ;
  rdfs:label "These are vertical layering and horizontal resequencing."@en ;
  dcterms:modified "2026-06-07T15:30:29.429278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8746-3
  a curric:KeyLearningPoint ;
  rdfs:label """In horizontal resequencing, new sections of contrasting music are used to match big
  changes in the game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8746-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many different sections are created, so that the music can respond to any one of the
  possible changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8746-5
  a curric:KeyLearningPoint ;
  rdfs:label """A typical example is using different musical ideas to represent victory or loss in a
  racing game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Video game music has transformed as computer technology has developed over the last
  50 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modern video game music fulfils similar roles to film music - creating mood, energy
  and helping to ‘tell the story’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8743-3
  a curric:KeyLearningPoint ;
  rdfs:label """Video game music is based on repeating linear loops that need to be able to repeat
  indefinitely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8743-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is also adaptive, changing in response to the player’s actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.429307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8743-5
  a curric:KeyLearningPoint ;
  rdfs:label """Video game theme songs should capture the overall mood and atmosphere of the
  game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8747-1
  a curric:KeyLearningPoint ;
  rdfs:label """Video game composers must check that transitions between sections work musically, in
  all possible sequences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8747-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dovetailing of melodies is an effective way of linking sections."@en ;
  dcterms:modified "2026-06-07T15:30:29.429319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8747-3
  a curric:KeyLearningPoint ;
  rdfs:label "Key changes, in particular, can sound unnatural and jarring."@en ;
  dcterms:modified "2026-06-07T15:30:29.429323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8747-4
  a curric:KeyLearningPoint ;
  rdfs:label """When analysing unfamiliar music, we can analyse the use of vertical layering and
  horizontal resequencing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8747-5
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the type of loops used and the mood created can suggest what type and
  era of video game it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8707-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing film music requires composers to precisely match their music to the timings
  of action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8707-2
  a curric:KeyLearningPoint ;
  rdfs:label """They use storyboards to represent the action of a scene and cues to help fit their
  music to exact moments in a scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8707-3
  a curric:KeyLearningPoint ;
  rdfs:label """They create the music to match each mood, by developing musical ideas in different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8707-4
  a curric:KeyLearningPoint ;
  rdfs:label "Developing an ostinato to create different moods."@en ;
  dcterms:modified "2026-06-07T15:30:29.429416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8675-1
  a curric:KeyLearningPoint ;
  rdfs:label """Film composers use different genres to help set the film in a time or place, and to
  create an appropriate mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8675-2
  a curric:KeyLearningPoint ;
  rdfs:label "They also use specific instrumental clichés to create effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.429445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8675-3
  a curric:KeyLearningPoint ;
  rdfs:label """These include using arco strings for emotional moments and brass to represent
  important or heroic characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8675-4
  a curric:KeyLearningPoint ;
  rdfs:label """Developing the texture allows film composers to balance variety and repetition, and
  to build energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20103-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers have used voices in many different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.430030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20103-2
  a curric:KeyLearningPoint ;
  rdfs:label """Solo songs, such as lieder, were particularly common from the Romantic period
  onwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20103-3
  a curric:KeyLearningPoint ;
  rdfs:label "They often used techniques such as word-painting and melisma."@en ;
  dcterms:modified "2026-06-07T15:30:29.430038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20103-4
  a curric:KeyLearningPoint ;
  rdfs:label """Opera used solo singers, a chorus and orchestra to tell epic stories, using arias
  and recitative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20103-5
  a curric:KeyLearningPoint ;
  rdfs:label "In the Baroque period, oratorios and anthems are two key genres of vocal music."@en ;
  dcterms:modified "2026-06-07T15:30:29.430047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8802-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most composers have a purpose in mind when they write music."@en ;
  dcterms:modified "2026-06-07T15:30:29.434615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8802-2
  a curric:KeyLearningPoint ;
  rdfs:label """This might be to tell a story (e.g. programme music), create a mood or encourage
  dancing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8802-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use the musical elements in specific ways to suit the purpose of their
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8802-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a sophisticated description of music if we link the elements to the
  purpose of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8802-5
  a curric:KeyLearningPoint ;
  rdfs:label """First we describe the element, then describe its effect, then analyse how that fits
  the purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8623-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pop music has been around since the 1950s and includes many different genres."@en ;
  dcterms:modified "2026-06-07T15:30:29.435973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8623-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pop music shares common features including instrumentation and structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.435977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8623-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instrumentation is which instruments and voices have been used."@en ;
  dcterms:modified "2026-06-07T15:30:29.435981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most pop songs have vocals, piano/guitar, bass guitar and drums, although more
  modern pop uses synthesized instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8623-5
  a curric:KeyLearningPoint ;
  rdfs:label """Metre is the organisation of bars and beats. Most pop songs have four beats in a bar
  or a 4/4 time signature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20131-1
  a curric:KeyLearningPoint ;
  rdfs:label """The piano became a very important instrument in Classical and Romantic
  concertos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20131-2
  a curric:KeyLearningPoint ;
  rdfs:label """Its dynamic range, pitch range, expressive abilities and ability to play multiple
  layers attracted composers to it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20131-3
  a curric:KeyLearningPoint ;
  rdfs:label """The piano concerto mirrored most of the trends of those periods, though there are
  some specific ways the piano is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20131-4
  a curric:KeyLearningPoint ;
  rdfs:label """These include accompanying orchestral melodies with chords and playing both melody
  and accompaniment together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8626-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm section is the name given to the group of accompanying instruments in a
  pop ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8626-2
  a curric:KeyLearningPoint ;
  rdfs:label "They support the singer with rhythm and harmony."@en ;
  dcterms:modified "2026-06-07T15:30:29.436758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8626-3
  a curric:KeyLearningPoint ;
  rdfs:label "The guitar/keyboard plays chords and the drummer plays a steady drum groove."@en ;
  dcterms:modified "2026-06-07T15:30:29.436763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8626-4
  a curric:KeyLearningPoint ;
  rdfs:label "The bass player supports the harmony by playing the root notes of each chord."@en ;
  dcterms:modified "2026-06-07T15:30:29.436767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interest is created in the bass line by using passing notes and octave leaps, and
  syncopated rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8629-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use motifs, short melodic ideas that are repeated, to give melodies a
  sense of coherence and unity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8629-2
  a curric:KeyLearningPoint ;
  rdfs:label """Motifs don’t need to be repeated exactly every time, but they need to sound familiar
  to the listener."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8629-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sequences are an effective melodic device for extending a melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.439128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8629-4
  a curric:KeyLearningPoint ;
  rdfs:label "They help to maintain a balance between familiarity and contrast."@en ;
  dcterms:modified "2026-06-07T15:30:29.439132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8632-1
  a curric:KeyLearningPoint ;
  rdfs:label "Melody and harmony must use some of the same notes to sound musically coherent."@en ;
  dcterms:modified "2026-06-07T15:30:29.439172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8632-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chord tones should form the basis of a melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.439176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8632-3
  a curric:KeyLearningPoint ;
  rdfs:label """Passing notes can make a melody interesting and more ‘melodic’ by creating conjunct
  movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8632-4
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies should still follow a recognisable or repeated phrase pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.439186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8631-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chord sequences are patterns of chords that form the harmony in a composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.584589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8631-2
  a curric:KeyLearningPoint ;
  rdfs:label """Starting on chord I (tonic) and using mostly primary chords (chords I, IV and V)
  helps to anchor the music in a key."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8631-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using some secondary chords (ii, iii and vi) adds further interest, but these should
  be used sparingly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8631-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ending with a perfect cadence (chord V to I) helps the music feel finished."@en ;
  dcterms:modified "2026-06-07T15:30:29.584604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8631-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using an imperfect cadence (any chord to V) in the middle of the sequence (bar 4)
  helps the music sound unfinished."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20110-1
  a curric:KeyLearningPoint ;
  rdfs:label """Salsa and merengue are popular forms of music and dance that both use Latin
  percussion and syncopated rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20110-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key features of salsa include the piano montuno, tresillo bass pattern and son clave
  rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20110-3
  a curric:KeyLearningPoint ;
  rdfs:label """Salsa often uses a large band, similar to a Western jazz ‘big band’ with saxophones,
  brass, and a rhythm section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20110-4
  a curric:KeyLearningPoint ;
  rdfs:label """Merengue typically has a smaller group, using traditional Dominican instruments such
  as the tambora."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20110-5
  a curric:KeyLearningPoint ;
  rdfs:label "The quintillo is a defining rhythmic pattern in merengue."@en ;
  dcterms:modified "2026-06-07T15:30:29.585075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20113-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reggae grew out of ska and rocksteady to become an important style of music in
  Jamaica and around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20113-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reggae often expresses political messages and addresses social issues."@en ;
  dcterms:modified "2026-06-07T15:30:29.585222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20113-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some of its defining characteristics are the skank rhythm on electric guitar,
  one-drop drum beat and reggae bubble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20113-4
  a curric:KeyLearningPoint ;
  rdfs:label """Those features all emphasise the offbeats, and avoid emphasising the usual strong
  beats (one and three)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20113-5
  a curric:KeyLearningPoint ;
  rdfs:label """The bass line often plays on the strong beats, sticking out from the other
  rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8713-1
  a curric:KeyLearningPoint ;
  rdfs:label "The bouzouki has a characteristic playing style that uses slides and tremolo."@en ;
  dcterms:modified "2026-06-07T15:30:29.587283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8713-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instrumental and vocal melodies are often harmonised with thirds."@en ;
  dcterms:modified "2026-06-07T15:30:29.587288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies in Greek folk music are mostly conjunct and use ornamentation."@en ;
  dcterms:modified "2026-06-07T15:30:29.587292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8713-4
  a curric:KeyLearningPoint ;
  rdfs:label "The vocal melodies are often conjunct and melismatic, like in Thalassaki Mou."@en ;
  dcterms:modified "2026-06-07T15:30:29.587300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8666-1
  a curric:KeyLearningPoint ;
  rdfs:label "By the 1970s, rock split into various different subgenres."@en ;
  dcterms:modified "2026-06-07T15:30:29.587692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8666-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heavy metal was a subgenre that used extreme distortion, aggressive vocals and
  powerful riffs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rock bands often vary texture by changing the role of the guitar and its interaction
  with the singer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8666-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many bands include both a lead guitar and a rhythm guitar which have different roles
  in the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8666-5
  a curric:KeyLearningPoint ;
  rdfs:label """Riffs which use power chords are common in rock music and pedal notes are often used
  to create harmonic interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8693-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pop ballads typically use a slow tempo, romantic lyrics, diatonic harmony, 4/4 metre
  and a verse-chorus structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8693-2
  a curric:KeyLearningPoint ;
  rdfs:label """A piano/keyboard is often prominent in pop ballads and strings or brass are commonly
  used to thicken the texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8693-3
  a curric:KeyLearningPoint ;
  rdfs:label "Typical artists include Whitney Houston and Elton John."@en ;
  dcterms:modified "2026-06-07T15:30:29.587727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8693-4
  a curric:KeyLearningPoint ;
  rdfs:label """A mix of root position and chord inversions can be used when composing chord
  sequences to create interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8693-5
  a curric:KeyLearningPoint ;
  rdfs:label """Chord inversions affect the bass line as it has to play the lowest note of each
  chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chord inversions and broken chords can add interest to a chord sequence without
  changing the harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chord inversions change the root position triad so the root note is no longer the
  lowest note in the chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8630-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using chord inversions can make chord sequences easier to play and sound more
  melodic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8630-4
  a curric:KeyLearningPoint ;
  rdfs:label "Broken chords can add rhythmic interest to a chord sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.587757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8695-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vocalists in pop ballads use many different techniques to add expression, including
  vibrato and rubato."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many singers use a mixture of syllabic and melismatic singing to develop melodies
  and add expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8695-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing a vocal melody, we need to consider the pattern of syllables and words,
  as well as the phrase structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8695-4
  a curric:KeyLearningPoint ;
  rdfs:label "This ensures that there is balance of repetition and contrast."@en ;
  dcterms:modified "2026-06-07T15:30:29.587814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8665-1
  a curric:KeyLearningPoint ;
  rdfs:label "1960s rock built on the foundations of rock 'n' roll and blues."@en ;
  dcterms:modified "2026-06-07T15:30:29.587844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8665-2
  a curric:KeyLearningPoint ;
  rdfs:label """British bands were key to the growth of 1960s rock, including The Beatles and
  Rolling Stones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key features include riffs and instrumentation featuring distorted electric guitars,
  vocals, bass guitar and drum kit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8665-4
  a curric:KeyLearningPoint ;
  rdfs:label """Riffs and melodies are often based around the blues scale and played in a unison
  texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8665-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can extend riffs by using transposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.587867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8694-1
  a curric:KeyLearningPoint ;
  rdfs:label """Songwriters use various techniques to develop their chord sequences, including
  voicings and broken chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8694-2
  a curric:KeyLearningPoint ;
  rdfs:label "The voicings of a chord can change how it sounds and create added interest."@en ;
  dcterms:modified "2026-06-07T15:30:29.587924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chords can also be made to sound more melodic through the addition of
  passing notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8694-4
  a curric:KeyLearningPoint ;
  rdfs:label """Songwriters develop the texture in pop ballads through the use of orchestral
  instruments, voices and synthesisers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8667-1
  a curric:KeyLearningPoint ;
  rdfs:label "In the 1980s rock continued to be hugely commercially successful."@en ;
  dcterms:modified "2026-06-07T15:30:29.588008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists drew influence from other styles and often used developing technology in
  their music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8667-3
  a curric:KeyLearningPoint ;
  rdfs:label "A common feature of many rock styles is the virtuosic guitar solo."@en ;
  dcterms:modified "2026-06-07T15:30:29.588018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8667-4
  a curric:KeyLearningPoint ;
  rdfs:label """These are normally based on the blues or pentatonic scale, and are played above the
  riff or chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8667-5
  a curric:KeyLearningPoint ;
  rdfs:label """Guitarists often used specific techniques such as note bending, hammer-ons, tapping,
  and harmonics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pop ballads typically build to an emotional climax in the final chorus."@en ;
  dcterms:modified "2026-06-07T15:30:29.588072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9199-2
  a curric:KeyLearningPoint ;
  rdfs:label """They do this through developing the texture, adding countermelodies and
  modulation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9199-3
  a curric:KeyLearningPoint ;
  rdfs:label """A countermelody should complement the main melody and both melodies should be easy
  to hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9199-4
  a curric:KeyLearningPoint ;
  rdfs:label "A typical modulation for a pop ballad is to modulate up a tone (two semitones)."@en ;
  dcterms:modified "2026-06-07T15:30:29.588088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8705-1
  a curric:KeyLearningPoint ;
  rdfs:label """Harmonic devices, such as pedals and dissonance are very useful tools for film
  composers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8705-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pedals (usually on the tonic note) create tension by creating clashes between the
  bass notes and chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8705-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dissonant chords, which often feature adjacent notes or chromatic notes, also create
  tension and excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8705-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can reharmonise a consonant melody with dissonant harmony to develop it and add
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8696-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pop ballads have continued to evolve through the use of music technology and by
  incorporating different musical styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8696-2
  a curric:KeyLearningPoint ;
  rdfs:label """In verse-chorus form, contrast between the sections is important to maximise the
  impact of the chorus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8696-3
  a curric:KeyLearningPoint ;
  rdfs:label """This happens through using different textures and contrasting chords and drum
  grooves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drum grooves in pop ballads often use reverb and are usually simple with a strong
  backbeat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8696-5
  a curric:KeyLearningPoint ;
  rdfs:label "They typically use drum fills to build energy at key moments."@en ;
  dcterms:modified "2026-06-07T15:30:29.588347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20105-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music from the Classical period (1750-1820) has certain defining
  characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20105-2
  a curric:KeyLearningPoint ;
  rdfs:label """These include melody and accompaniment texture, and simple melodies with limited
  ornamentation and balanced phrasing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20105-3
  a curric:KeyLearningPoint ;
  rdfs:label """The orchestra grew larger and, as well as the concerto, the symphony became a key
  genre. It has four movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20105-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first uses sonata form, with an exposition, development and recapitulation. The
  third is often a minuet and trio."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20105-5
  a curric:KeyLearningPoint ;
  rdfs:label """The sonata became a key genre (particularly for keyboard instruments), with three
  contrasting movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8803-1
  a curric:KeyLearningPoint ;
  rdfs:label "The way we structure a description is dependent on the question."@en ;
  dcterms:modified "2026-06-07T15:30:29.606846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8803-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the question is linked to a particular style or context, every point must link to
  that."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8803-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the question is linked to a musical purpose (e.g. depicting a specific scene)
  every point should link to that."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8803-4
  a curric:KeyLearningPoint ;
  rdfs:label """If it is a comparison, every feature that is described should be compared to the
  other clip."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8803-5
  a curric:KeyLearningPoint ;
  rdfs:label """Being concise, making only relevant points and using technical vocabulary are also
  key to effective responses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8801-1
  a curric:KeyLearningPoint ;
  rdfs:label """The musical elements are a useful starting point for a description of unfamiliar
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8801-2
  a curric:KeyLearningPoint ;
  rdfs:label """An effective description should encompass multiple different musical elements and
  should describe each in a concise way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8801-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the table method to help us structure our thoughts and arrange them into
  an effective paragraph."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8801-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can also analyse the musical effect of those elements in the table."@en ;
  dcterms:modified "2026-06-07T15:30:29.608150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8801-5
  a curric:KeyLearningPoint ;
  rdfs:label """Describing the effect of each feature gives a more thorough description of a piece
  of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8799-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the musical elements to help structure simple, clear descriptions of
  unfamiliar music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8799-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate description of a melody should include its shape and intervals as well as
  any melodic devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8799-3
  a curric:KeyLearningPoint ;
  rdfs:label """A description of tonality should identify whether the music is diatonic (major or
  minor), modal, atonal or microtonal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8799-4
  a curric:KeyLearningPoint ;
  rdfs:label """Harmony encompasses the types of chords used, harmonic rhythm, cadences and harmonic
  devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8799-5
  a curric:KeyLearningPoint ;
  rdfs:label """A description of texture should describe the specific texture (e.g. homophonic) and
  any changes that occur."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8809-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythmic dictation is the process of listening to a rhythm and writing it down using
  notation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8809-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbalisation, using words to represent different note values and patterns, is a
  useful strategy for rhythmic dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8809-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words like ‘ta’ (crotchet) and ‘ta di’ (pair of quavers) can help to identify
  different note values."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8809-4
  a curric:KeyLearningPoint ;
  rdfs:label "We then convert those words into their correct notation symbols."@en ;
  dcterms:modified "2026-06-07T15:30:29.614034Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-20054
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose a melody that uses both conjunct and disjunct movement effectively and
  creates balanced phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063065Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20057
  a curric:PupilLessonOutcome ;
  rdfs:label "I can arrange a melody, bass line and harmony effectively for a string quartet."@en ;
  dcterms:modified "2026-06-07T15:30:41.063078Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20056
  a curric:PupilLessonOutcome ;
  rdfs:label """I can develop an idiomatic bass line and modulate a chord sequence into the relative
  minor key."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063087Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20055
  a curric:PupilLessonOutcome ;
  rdfs:label "I can write an effectively structured 16-bar melody and chord sequence."@en ;
  dcterms:modified "2026-06-07T15:30:41.063230Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8628
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain features of effective melodies and use these to compose a simple
  melody."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063234Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20104
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify key features of Baroque music."@en ;
  dcterms:modified "2026-06-07T15:30:41.063471Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20099
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe key musical features of the three key periods within the Western
  Classical Tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063492Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20102
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain the fundamentals of harmony and tonality and how they are used in
  Western classical music."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063697Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20101
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify key small ensembles and describe key features of chamber and solo
