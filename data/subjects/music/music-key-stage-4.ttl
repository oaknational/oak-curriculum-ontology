  rdfs:label """I can develop a musical climax in my pop ballad through the use of a countermelody
  and modulation."""@en ;
  dcterms:modified "2026-06-07T15:30:41.109454Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8705
  a curric:PupilLessonOutcome ;
  rdfs:label "I can develop a film theme using pedals and dissonance."@en ;
  dcterms:modified "2026-06-07T15:30:41.109458Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8696
  a curric:PupilLessonOutcome ;
  rdfs:label """I understand how pop music has evolved since the 1990s, and can create a contrasting
