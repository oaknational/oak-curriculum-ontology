oakcurric:unit-1012
  a curric:Unit ;
  rdfs:label "Fundamentals of composition"@en ;
  curric:slug "fundamentals-of-composition" ;
  rdfs:comment """This unit explores fundamental components of composition. It embeds and develops
  pupils' understanding of writing melodies, including idiomatic features and making a
  melody sound 'melodic'. It also explores effective writing of chord sequences, and how
  these intertwine with melodic writing."""@en ;
  curric:whyThisWhyNow "[TO BE ADDED]" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-1012-1 ,
    oakcurric:priorknowledge-1012-2 ,
    oakcurric:priorknowledge-1012-3 ;
  curric:id "1012"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.261836Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-music-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-melody ,
    oakcurric:thread-composing-and-improvising .

oakcurric:unit-2592
  a curric:Unit ;
  rdfs:label "The Western Classical Tradition: extended"@en ;
  curric:slug "the-western-classical-tradition-extended" ;
  rdfs:comment """This unit builds on the Introduction to the WCT unit, exploring the Baroque,
  Classical and Romantic periods in greater depth, assessing the development of key musical
  trends, and finishing with a look at developments in the 20th century."""@en ;
  curric:whyThisWhyNow "[TO BE ADDED]" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2592-1 ,
    oakcurric:priorknowledge-2592-2 ,
    oakcurric:priorknowledge-2592-3 ,
    oakcurric:priorknowledge-2592-4 ,
    oakcurric:priorknowledge-2592-5 ;
  curric:id "2592"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.370711Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-music-key-stage-4 .

oakcurric:unit-2591
  a curric:Unit ;
  rdfs:label "The Western Classical Tradition (1600-1910)"@en ;
  curric:slug "the-western-classical-tradition-1600-1910" ;
  rdfs:comment """This unit introduces pupils to the Western Classical Tradition. It explores
  chamber, orchestral and vocal ensembles, musical features and key composers from the
  Baroque, Classical and Romantic periods, and takes a broad look at tonality and harmony
  across these periods."""@en ;
  curric:whyThisWhyNow "[TO BE ADDED]" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2591-1 ,
    oakcurric:priorknowledge-2591-2 ,
    oakcurric:priorknowledge-2591-3 ,
    oakcurric:priorknowledge-2591-4 ;
  curric:id "2591"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.380024Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-music-key-stage-4 .

