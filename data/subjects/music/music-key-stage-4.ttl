  dcterms:modified "2026-06-07T15:30:41.109249Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8666
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create a chordal guitar riff and use a pedal note to develop a bass line."@en ;
  dcterms:modified "2026-06-07T15:30:41.109337Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8693
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise key features of pop ballads and create a pop ballad chord
  sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:41.109341Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8630
  a curric:PupilLessonOutcome ;
  rdfs:label "I can develop a chord sequence using broken chords and chord inversions."@en ;
  dcterms:modified "2026-06-07T15:30:41.109345Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8695
  a curric:PupilLessonOutcome ;
  rdfs:label "I can compose and develop an idiomatic vocal melody for a pop ballad."@en ;
  dcterms:modified "2026-06-07T15:30:41.109358Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8665
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe the key features of rock and can create and develop a riff."@en ;
  dcterms:modified "2026-06-07T15:30:41.109367Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8694
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify and recreate some idiomatic ways to develop chordal textures."@en ;
  dcterms:modified "2026-06-07T15:30:41.109385Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8667
  a curric:PupilLessonOutcome ;
  rdfs:label """I have created a virtuosic guitar solo incorporating idiomatic guitar
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:41.109441Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9199
