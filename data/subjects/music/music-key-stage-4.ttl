  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose an effective 8-bar chord sequence using the typical conventions of
  Western classical music."""@en ;
  dcterms:modified "2026-06-07T15:30:41.108749Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20110
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the core features of salsa and merengue and can recreate a salsa
  groove."""@en ;
  dcterms:modified "2026-06-07T15:30:41.108840Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20113
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the key features of reggae and how it developed, and can create a
