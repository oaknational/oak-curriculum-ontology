  schema:description """an extended chord is a chord that includes more than three different
  notes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389885Z"^^xsd:dateTime .

oakcurric:keyword-7th-chord
  a curric:Keyword ;
  schema:name "7th chord"@en ;
  schema:description """a 7th chord includes a note that is the 7th note in the scale above the root
  note"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389890Z"^^xsd:dateTime .

oakcurric:keyword-6th-chord
  a curric:Keyword ;
  schema:name "6th chord"@en ;
  schema:description """a 6th chord includes a note that is the 6th note in the scale above the root
  note"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389895Z"^^xsd:dateTime .

oakcurric:keyword-synthesizer
  a curric:Keyword ;
  schema:name "Synthesizer"@en ;
  schema:description """A synthesizer is an electronic instrument that can create a wide variety of
  different timbres."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389920Z"^^xsd:dateTime .

oakcurric:keyword-flat
  a curric:Keyword ;
