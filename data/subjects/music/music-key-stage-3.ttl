  dcterms:modified "2026-06-07T15:30:02.414022Z"^^xsd:dateTime .

oakcurric:keyword-drum-roll
  a curric:Keyword ;
  schema:name "Drum roll"@en ;
  schema:description """A drum roll involves playing the snare drum rapidly, producing a continuous
