  dcterms:modified "2026-06-07T15:30:02.413409Z"^^xsd:dateTime .

oakcurric:keyword-stylistic-elements
  a curric:Keyword ;
  schema:name "stylistic elements"@en ;
  schema:description """the musical choices made by the composer to give the piece a sense
  of style"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413778Z"^^xsd:dateTime .

oakcurric:keyword-timbales
  a curric:Keyword ;
