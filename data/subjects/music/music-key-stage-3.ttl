  schema:description """The A minor scale is a set of notes starting on A, that uses only the white
  notes on the keyboard."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387209Z"^^xsd:dateTime .

oakcurric:keyword-triad-chord
  a curric:Keyword ;
  schema:name "triad chord"@en ;
  schema:description """a triad chord is a chord that includes three notes (the root note, 3rd and
  5th)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389878Z"^^xsd:dateTime .

oakcurric:keyword-extended-chord
  a curric:Keyword ;
