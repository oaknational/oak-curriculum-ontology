  dcterms:modified "2026-06-07T15:30:02.396023Z"^^xsd:dateTime .

oakcurric:keyword-ternary-form
  a curric:Keyword ;
  schema:name "Ternary form"@en ;
  schema:description """Ternary form is a musical structure in three sections, with the first
  section repeated at the end. It is also referred to as ABA."""@en ;
  dcterms:modified "2026-06-07T15:30:02.396401Z"^^xsd:dateTime .

oakcurric:keyword-improvised-solo
  a curric:Keyword ;
  schema:name "improvised solo"@en ;
  schema:description """a featured part of a composition played by one person, where the player
  makes up the rhythm on the spot"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396702Z"^^xsd:dateTime .

oakcurric:keyword-djembefola
  a curric:Keyword ;
  schema:name "djembefola"@en ;
  schema:description "the lead drummer"@en ;
  dcterms:modified "2026-06-07T15:30:02.396709Z"^^xsd:dateTime .

oakcurric:keyword-triplets
  a curric:Keyword ;
