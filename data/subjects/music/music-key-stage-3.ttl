  accenting the strong beats"""@en ;
  dcterms:modified "2026-06-07T15:30:02.412179Z"^^xsd:dateTime .

oakcurric:keyword-vamp
  a curric:Keyword ;
  schema:name "vamp"@en ;
  schema:description "a repeated musical pattern, often based on chords"@en ;
  dcterms:modified "2026-06-07T15:30:02.413275Z"^^xsd:dateTime .

oakcurric:keyword-d-minor
  a curric:Keyword ;
  schema:name "D minor"@en ;
  schema:description "a set of notes starting on D which includes Bb as the flattened sixth"@en ;
  dcterms:modified "2026-06-07T15:30:02.413281Z"^^xsd:dateTime .

oakcurric:keyword-bass-line
  a curric:Keyword ;
  schema:name "Bass line"@en ;
  schema:description "a low-pitched part that supports the harmony and melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.413291Z"^^xsd:dateTime .

oakcurric:keyword-hi-hat
  a curric:Keyword ;
  schema:name "hi-hat"@en ;
  schema:description "part of a drum kit made of two cymbals"@en ;
  dcterms:modified "2026-06-07T15:30:02.413398Z"^^xsd:dateTime .

oakcurric:keyword-cymbal
  a curric:Keyword ;
