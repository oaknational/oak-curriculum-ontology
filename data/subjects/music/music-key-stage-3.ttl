oakcurric:keyword-thin-texture
  a curric:Keyword ;
  schema:name "thin texture"@en ;
  schema:description """A piece of music has a thin texture if there are very few musical layers
  playing at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.386981Z"^^xsd:dateTime .

oakcurric:keyword-phrase-structure
  a curric:Keyword ;
