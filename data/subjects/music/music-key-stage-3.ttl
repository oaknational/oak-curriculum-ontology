  dcterms:modified "2026-06-07T15:30:02.386696Z"^^xsd:dateTime .

oakcurric:keyword-thick-texture
  a curric:Keyword ;
  schema:name "thick texture"@en ;
  schema:description """A piece of music has a thick texture if there are many different musical
