oakcurric:keyword-116th-note
  a curric:Keyword ;
  schema:name "1/16th note"@en ;
  schema:description "a note lasting a quarter of a beat; it is also called a semiquaver"@en ;
  dcterms:modified "2026-06-07T15:30:02.386571Z"^^xsd:dateTime .

oakcurric:keyword-ground-bass
  a curric:Keyword ;
  schema:name "ground bass"@en ;
  schema:description """a short, repeated bass line that repeats throughout a piece, forming the
  structure of the music"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386691Z"^^xsd:dateTime .

oakcurric:keyword-leading-note
  a curric:Keyword ;
