  schema:description """The dembow beat is the typical drum groove heard in reggaeton music, which
  uses the tresillo rhythm and has a strong beat on the kick drum."""@en ;
  dcterms:modified "2026-06-07T15:30:02.395327Z"^^xsd:dateTime .

oakcurric:keyword-dancehall
  a curric:Keyword ;
  schema:name "Dancehall"@en ;
  schema:description """A style of electronic music that evolved from reggae in Jamaica and
  influenced reggaeton."""@en ;
  dcterms:modified "2026-06-07T15:30:02.395335Z"^^xsd:dateTime .

oakcurric:keyword-title-theme
  a curric:Keyword ;
  schema:name "title theme"@en ;
  schema:description """the main musical theme of a film that is usually heard in the opening
  titles/credits"""@en ;
  dcterms:modified "2026-06-07T15:30:02.395514Z"^^xsd:dateTime .

oakcurric:keyword-elements-of-music
  a curric:Keyword ;
  schema:name "elements of music"@en ;
  schema:description """the building blocks or key ingredients needed to create a piece of music
