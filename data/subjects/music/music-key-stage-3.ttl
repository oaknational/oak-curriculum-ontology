  dcterms:modified "2026-06-07T15:30:02.399934Z"^^xsd:dateTime .

oakcurric:keyword-idiomatic
  a curric:Keyword ;
  schema:name "idiomatic"@en ;
  schema:description """if something is idiomatic it is appropriate to the style (e.g. blues music
  using blues features such as the blues scale and syncopation)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400500Z"^^xsd:dateTime .

oakcurric:keyword-aab
  a curric:Keyword ;
  schema:name "AAB"@en ;
  schema:description """a melodic phrase structure, common in blues music, where the first phrase
  (A) is repeated then followed by a contrasting phrase (B)"""@en ;
