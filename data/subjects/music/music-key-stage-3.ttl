oakcurric:pupillessonoutcome-lesson-8552
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play an extended phrase of a melody which uses the black notes and moves out
  of position."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063109Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8553
  a curric:PupilLessonOutcome ;
  rdfs:label """I understand the key features of Fur Elise that give the music its character and can
  use these as the basis of an improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063144Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8551
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play the opening of a piece using sharps on the keyboard and can recognise
  minor and major scales"""@en ;
  dcterms:modified "2026-06-07T15:30:41.063363Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29604
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform a piece with two independent parts demonstrating expressive
  elements."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063406Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29603
  a curric:PupilLessonOutcome ;
  rdfs:label "I can perform a piece which changes hand position in the middle of a phrase."@en ;
  dcterms:modified "2026-06-07T15:30:41.063410Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29413
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe some common features of European and Russian folk dance and can
  perform the melody of Korobeiniki."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063415Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29410
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain some key characteristics of folk music and can perform a simple
  pentatonic folk melody."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063419Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29414
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play Korobeiniki with a melody and accompaniment."@en ;
  dcterms:modified "2026-06-07T15:30:41.063423Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29412
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain what a mode is and have performed a modal sea shanty melody."@en ;
  dcterms:modified "2026-06-07T15:30:41.063427Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29411
  a curric:PupilLessonOutcome ;
  rdfs:label "I can compose a simple pentatonic melody with lyrics."@en ;
  dcterms:modified "2026-06-07T15:30:41.063431Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29463
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create an extended improvisation over the 12-bar blues chords."@en ;
  dcterms:modified "2026-06-07T15:30:41.063977Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29791
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing an ostinato pattern in a homophonic texture."@en ;
  dcterms:modified "2026-06-07T15:30:41.064471Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28158
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe some methods for composing for an SATB choir and have created a short
  contemporary choral composition."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064847Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29688
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create a drumming composition in the style of Kuku or Warabadon."@en ;
  dcterms:modified "2026-06-07T15:30:41.065399Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29794
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform a song with an understanding of musical shape, balance and clear
  diction."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065423Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29416
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing the melody of Gumama in a unison texture, focusing on producing clear,
  tall vowel sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065502Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29418
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing the melody of Follow Me in a unison texture, focusing on tone quality and
  accuracy of ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066176Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29419
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing the chorus for Follow Me in three-part harmony and perform the full song,
  considering expressive elements."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066283Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29792
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing a song with changing textures, showing an awareness of phrase endings and
  balance."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066435Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29417
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing Gumama as part of a three-part homophonic texture, focusing on producing
  clear, tall vowel sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066439Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29793
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing a song with three independent parts and use emphasis and dynamics to add
  musical shape."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066666Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28159
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify some extended vocal techniques and use them in a short vocal
  composition."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068188Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8563
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create an EDM drum beat and understand what its component parts are."@en ;
  dcterms:modified "2026-06-07T15:30:41.068327Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28160
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create a composition based on samples."@en ;
  dcterms:modified "2026-06-07T15:30:41.068841Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29645
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform a taiko ensemble performance with an ouchi using a variety of strikes,
  movements and kakegoe with an accompanying jiuchi."""@en ;
  dcterms:modified "2026-06-07T15:30:41.069681Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28162
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain the fundamentals of serialism and create a tone row."@en ;
  dcterms:modified "2026-06-07T15:30:41.070267Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29643
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform a short taiko structure using don and doko and can explain the origins
  of taiko."""@en ;
  dcterms:modified "2026-06-07T15:30:41.070296Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28163
  a curric:PupilLessonOutcome ;
  rdfs:label """I can develop a serialist composition by using typical techniques including
  retrograding."""@en ;
  dcterms:modified "2026-06-07T15:30:41.070312Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-28161
  a curric:PupilLessonOutcome ;
  rdfs:label "I can combine pitched and unpitched samples in a composition."@en ;
  dcterms:modified "2026-06-07T15:30:41.071235Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29646
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose a short composition using traditional taiko techniques and perform the
  ideas successfully within an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:41.071239Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9813
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose a musical idea in C major which appropriately complements the
  beginning of a story."""@en ;
  dcterms:modified "2026-06-07T15:30:41.071804Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29683
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the main techniques used on the djembe and dunduns, and their
  sonorities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.072732Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29644
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify strikes and kakegoe, applying these to the stance and movement to
  recreate key aspects of taiko."""@en ;
  dcterms:modified "2026-06-07T15:30:41.073356Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29537
  a curric:PupilLessonOutcome ;
  rdfs:label "I can apply triadic harmony to a ground bass."@en ;
  dcterms:modified "2026-06-07T15:30:41.079275Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29539
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use triadic harmony to add arpeggios and an alberti bass to a ground bass
  pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079474Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29540
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify different rhythmic values and am able to apply these to a ground
  bass."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079795Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29541
  a curric:PupilLessonOutcome ;
  rdfs:label """I can develop a melody line from triadic harmony using passing notes, and
  considering rhythmic, textural and structural elements."""@en ;
  dcterms:modified "2026-06-07T15:30:41.080163Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29534
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify pitches in the bass clef and perform and find the notes C - C on the
  keyboard."""@en ;
  dcterms:modified "2026-06-07T15:30:41.080807Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29686
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain the context of the Warabadon rhythm and can perform the rhythms in
  compound time using untuned percussion."""@en ;
  dcterms:modified "2026-06-07T15:30:41.080955Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8486
  a curric:PupilLessonOutcome ;
