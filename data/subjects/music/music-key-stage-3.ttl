  schema:description "a group of notes adjacent to each other, played at the same time"@en ;
  dcterms:modified "2026-06-07T15:30:02.411803Z"^^xsd:dateTime .

oakcurric:keyword-kenkeni
  a curric:Keyword ;
  schema:name "kenkeni"@en ;
  schema:description """the highest pitch dundun; this often keeps the pulse by playing on
  the beat"""@en ;
