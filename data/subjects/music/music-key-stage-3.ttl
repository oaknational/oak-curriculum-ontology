oakcurric:keyword-sangban
  a curric:Keyword ;
  schema:name "sangban"@en ;
  schema:description "the middle pitch dundun; this plays more complex rhythms"@en ;
  dcterms:modified "2026-06-07T15:30:02.412173Z"^^xsd:dateTime .

oakcurric:keyword-dundunba
  a curric:Keyword ;
  schema:name "dundunba"@en ;
