  sound frequencies within a track or project."""@en ;
  dcterms:modified "2026-06-07T15:30:02.408822Z"^^xsd:dateTime .

oakcurric:keyword-g-major-scale
  a curric:Keyword ;
  schema:name "G major scale"@en ;
