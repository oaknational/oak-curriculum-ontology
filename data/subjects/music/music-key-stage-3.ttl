  dcterms:modified "2026-06-07T15:30:02.398261Z"^^xsd:dateTime .

oakcurric:keyword-surdo
  a curric:Keyword ;
  schema:name "surdo"@en ;
  schema:description "a surdo is a type of bass drum used in batucada"@en ;
  dcterms:modified "2026-06-07T15:30:02.399324Z"^^xsd:dateTime .

oakcurric:keyword-caixa
  a curric:Keyword ;
  schema:name "caixa"@en ;
  schema:description "a caixa is a type of snare drum used in a batucada"@en ;
  dcterms:modified "2026-06-07T15:30:02.399332Z"^^xsd:dateTime .

oakcurric:keyword-blue-notes
  a curric:Keyword ;
  schema:name "blue notes"@en ;
  schema:description """the lowered or flattened notes in the blues scale, typically the 3rd, 5th
  and 7th"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399452Z"^^xsd:dateTime .

oakcurric:keyword-call
  a curric:Keyword ;
