  dcterms:modified "2026-06-07T15:30:02.414028Z"^^xsd:dateTime .

oakcurric:keyword-musical-fusion
  a curric:Keyword ;
  schema:name "Musical fusion"@en ;
  schema:description "When different musical styles are combined we call this musical fusion."@en ;
  dcterms:modified "2026-06-07T15:30:02.414033Z"^^xsd:dateTime .

oakcurric:keyword-musical-contrast
  a curric:Keyword ;
  schema:name "Musical contrast"@en ;
  schema:description """When there are differences between sections we would describe this as
  musical contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414133Z"^^xsd:dateTime .

oakcurric:keyword-low-pass-filter
  a curric:Keyword ;
