# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-8554-1
  a curric:KeyLearningPoint ;
  rdfs:label "Performing broken chords on the keyboard."@en ;
  dcterms:modified "2026-06-07T15:30:28.998742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8554-2
  a curric:KeyLearningPoint ;
  rdfs:label "Performing two independent parts at the same time on the keyboard."@en ;
  dcterms:modified "2026-06-07T15:30:28.998775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8554-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use expressive elements such as dynamics and rubato to add expression to a
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8554-4
  a curric:KeyLearningPoint ;
  rdfs:label "Emphasising the downbeat helps to show a sense of rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:28.998789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8552-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using carefully chosen dynamics, rubato and emphasising the first beat of the bar
  can add expression to a performance"""@en ;
  dcterms:modified "2026-06-07T15:30:28.999091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8552-2
  a curric:KeyLearningPoint ;
  rdfs:label "Finding patterns in music can help in learning it more quickly"@en ;
  dcterms:modified "2026-06-07T15:30:28.999099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8552-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Fur Elise melody is in an ABA structure and the middle section uses a descending
  sequence"""@en ;
  dcterms:modified "2026-06-07T15:30:28.999103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8552-4
  a curric:KeyLearningPoint ;
  rdfs:label "Playing the middle section of Fur Elise in a legato style"@en ;
  dcterms:modified "2026-06-07T15:30:28.999107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8553-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most music has its own distinctive features that make a piece enjoyable."@en ;
  dcterms:modified "2026-06-07T15:30:28.999247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8553-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fur Elise's distinctive features include the opening motif, the use of sequence and
  the constant quaver rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8553-3
  a curric:KeyLearningPoint ;
  rdfs:label """Musicians can use songs as inspiration for new music and adapt the original to make
  their own version."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8553-4
  a curric:KeyLearningPoint ;
  rdfs:label """The B section of Fur Elise changes key to the relative major key. This has an impact
  on the feel of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8553-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have created our own version of Fur Elise by changing the time signature, and
  adapting the melody and chords."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8551-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scales have their own distinctive sound and are defined by the order of the
  intervals from one note to the next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8551-2
  a curric:KeyLearningPoint ;
  rdfs:label "A minor scale pattern is tone, semitone, tone, tone, semitone, tone, tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.000298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8551-3
  a curric:KeyLearningPoint ;
  rdfs:label "The minor scale sounds more solemn than the major scale."@en ;
  dcterms:modified "2026-06-07T15:30:29.000302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8551-4
  a curric:KeyLearningPoint ;
  rdfs:label """When major and minor scales use notes outside the scale, these are called
  chromatic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8551-5
  a curric:KeyLearningPoint ;
  rdfs:label "Playing the opening phrase of Fur Elise, which uses both D sharp and D natural."@en ;
  dcterms:modified "2026-06-07T15:30:29.000310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29604-1
  a curric:KeyLearningPoint ;
  rdfs:label "The accompaniment part outlines the harmony of a piece."@en ;
  dcterms:modified "2026-06-07T15:30:29.000550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29604-2
  a curric:KeyLearningPoint ;
  rdfs:label """The accompaniment pattern in In the Hall of the Mountain King pattern plays the root
  and fith of the chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29604-3
  a curric:KeyLearningPoint ;
  rdfs:label "Performing appropriate accents in the melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.000559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refining our performance, considering expression, including dynamic changes from
  piano to forte with a crescendo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Developing fluency in hand position changes and performing two independent parts in
  the right and left hand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29603-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learning to play a melody which uses chromatic movement and is played in a staccato
  style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Developing fluency in changing hand positions when performing a piece on the
  keyboard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29603-3
  a curric:KeyLearningPoint ;
  rdfs:label """Developing dexterity in comfortably using fourth and fifth fingers to play a melody
  with accidentals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29603-4
  a curric:KeyLearningPoint ;
  rdfs:label """Learning how to navigate the difficult sections and spotting patterns in a piece to
  help learn it more efficiently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29413-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many folk music traditions use music for dance, including for celebrations like
  marriages and harvest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29413-2
  a curric:KeyLearningPoint ;
  rdfs:label """Like most dance music, folk dance needs a clear pulse, suitable tempo and repeated
  rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29413-3
  a curric:KeyLearningPoint ;
  rdfs:label """Korobeiniki is a Russian folk song often used for dancing, that was famously used
  for the video game Tetris."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29413-4
  a curric:KeyLearningPoint ;
  rdfs:label "It includes four-bar phrases, dotted crotchets and it is based on a minor scale."@en ;
  dcterms:modified "2026-06-07T15:30:29.000600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29413-5
  a curric:KeyLearningPoint ;
  rdfs:label "The music repeats and uses repeat marks in the notation to show this."@en ;
  dcterms:modified "2026-06-07T15:30:29.000605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29410-1
  a curric:KeyLearningPoint ;
  rdfs:label """Folk music encompasses many traditions from around the world that have been passed
  through generations orally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29410-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are varied, but have some common characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.000637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29410-3
  a curric:KeyLearningPoint ;
  rdfs:label """These include repetition of musical ideas and the use of simple, conjunct melodies
  with a small range."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29410-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many are based on the pentatonic scale, which includes five notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.000665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29410-5
  a curric:KeyLearningPoint ;
  rdfs:label "Xtoles is an ancient Maya song that is thought to have been sung by warriors."@en ;
  dcterms:modified "2026-06-07T15:30:29.000670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29414-1
  a curric:KeyLearningPoint ;
  rdfs:label """Folk dances often have highly rhythmic accompaniment parts which make them effective
  for dancing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29414-2
  a curric:KeyLearningPoint ;
  rdfs:label """These will often use repeated rhythms that create rhythmic drive, which is a feeling
  of energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29414-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Korobeiniki, we can create a simple accompaniment using the bass notes A, D and
  E."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29414-4
  a curric:KeyLearningPoint ;
  rdfs:label """By choosing a suitable rhythm, we can create the rhythmic drive typical of many folk
  dances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29412-1
  a curric:KeyLearningPoint ;
  rdfs:label "A mode is a type of scale, of which there are seven different types."@en ;
  dcterms:modified "2026-06-07T15:30:29.000691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29412-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dorian mode is commonly used in folk music, and it sounds similar to a minor
  scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29412-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sea shanty is a type of folk song that was traditionally sung by sailors to
  coordinate their movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29412-4
  a curric:KeyLearningPoint ;
  rdfs:label """What Shall We Do With A Drunken Sailor? is a famous example which uses the D dorian
  mode and a strophic structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29411-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many folk melodies are based on pentatonic scales such as the G major pentatonic
  scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29411-2
  a curric:KeyLearningPoint ;
  rdfs:label """The melodies usually have a small range and are conjunct, which makes them easier to
  sing and memorise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29411-3
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a melody, we should consider those features."@en ;
  dcterms:modified "2026-06-07T15:30:29.000719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29411-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can set lyrics to a melody, adjusting the rhythm to fit with the natural rhythm
  of the words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29463-1
  a curric:KeyLearningPoint ;
  rdfs:label """Blues is heavily improvised. Although improvisation is composing on the spot, it is
  not random."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29463-2
  a curric:KeyLearningPoint ;
  rdfs:label """Musicians use the blues scale, typical blues rhythms and the 12-bar blues chord
  sequence to structure an improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29463-3
  a curric:KeyLearningPoint ;
  rdfs:label "A successful improvisation often develops from an initial motif."@en ;
  dcterms:modified "2026-06-07T15:30:29.003613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29463-4
  a curric:KeyLearningPoint ;
  rdfs:label "We have performed an improvisation over the 12-bar blues chords on the keyboard."@en ;
  dcterms:modified "2026-06-07T15:30:29.003618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29791-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of warm ups to prepare the body for singing"@en ;
  dcterms:modified "2026-06-07T15:30:29.252329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29791-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pop songs often use a highly repetitive chord sequence and a verse chorus
  structure"""@en ;
  dcterms:modified "2026-06-07T15:30:29.252337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29791-3
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation can drive the music forward"@en ;
  dcterms:modified "2026-06-07T15:30:29.252358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29791-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adding dynamics and emphasis within the phrase can add shape to a melody"@en ;
  dcterms:modified "2026-06-07T15:30:29.252362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29791-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a syncopated melody"@en ;
  dcterms:modified "2026-06-07T15:30:29.252367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28158-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SATB choir is a very common vocal ensemble, consisting of soprano, alto, tenor
  and bass voices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28158-2
  a curric:KeyLearningPoint ;
  rdfs:label "Contemporary composers write both tonal and atonal music for choir."@en ;
  dcterms:modified "2026-06-07T15:30:29.254156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28158-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can create tension and release by creating dissonant chords that resolve to
  consonant chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28158-4
  a curric:KeyLearningPoint ;
  rdfs:label "When doing so, it is most effective to move by step."@en ;
  dcterms:modified "2026-06-07T15:30:29.254167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28158-5
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to consider the range of each voice type."@en ;
  dcterms:modified "2026-06-07T15:30:29.254172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29688-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composing a rhythmic piece in the style of either Kuku (in 4/4) or Warabadon (in
  12/8)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29688-2
  a curric:KeyLearningPoint ;
  rdfs:label """A successful Kuku or Warabadon structure includes a call, break, échauffement and
  solo sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29688-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composing and performing two contrasting ostinato patterns as the basis of our
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29688-4
  a curric:KeyLearningPoint ;
  rdfs:label """Developing these within the structure, creating a polyrhythmic section with an
  improvised solo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29794-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pedal notes create tension and excitement in music"@en ;
  dcterms:modified "2026-06-07T15:30:29.256967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29794-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate use of dynamics and emphasis within the phrase can add shape to
  a melody"""@en ;
  dcterms:modified "2026-06-07T15:30:29.256971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29794-3
  a curric:KeyLearningPoint ;
  rdfs:label "Correct balance in a vocal ensemble is important for creating a harmonious sound"@en ;
  dcterms:modified "2026-06-07T15:30:29.256975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29794-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a piece through changing textures"@en ;
  dcterms:modified "2026-06-07T15:30:29.256979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29794-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a melody with an extended range and more complex phrases for breathing"@en ;
  dcterms:modified "2026-06-07T15:30:29.256984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29416-1
  a curric:KeyLearningPoint ;
  rdfs:label "Warming up the body is important for singing"@en ;
  dcterms:modified "2026-06-07T15:30:29.257382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29416-2
  a curric:KeyLearningPoint ;
  rdfs:label "This includes warming-up our breathing, articulation, pitch and range"@en ;
  dcterms:modified "2026-06-07T15:30:29.257386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29416-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using tall vowels helps singers to produce a richer, clearer and more
  resonant tone"""@en ;
  dcterms:modified "2026-06-07T15:30:29.257390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29416-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singing Gumama in unison, focussing on tall vowels, and moving to a pulse to feel
  the rhythm"""@en ;
  dcterms:modified "2026-06-07T15:30:29.257394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29418-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humming can help warm up the vocal cords, develop voice resonance and reduce
  tension"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29418-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pop songs often have an overall texture of melody and accompaniment"@en ;
  dcterms:modified "2026-06-07T15:30:29.259236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29418-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tone quality in group singing relies on good breathing and listening to blend the
  sounds"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29418-4
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopated rhythms in slower music can help the music to have a laid-back feel"@en ;
  dcterms:modified "2026-06-07T15:30:29.259244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29418-5
  a curric:KeyLearningPoint ;
  rdfs:label """Singing Follow Me in unison, focussing on quality of tone and accuracy of
  ensemble"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29419-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humming can help warm up the vocal cords, develop voice resonance and reduce
  tension"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29419-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding dynamics and emphasis within the phrase can add shape to a melody"@en ;
  dcterms:modified "2026-06-07T15:30:29.259727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29419-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tone quality in group singing relies on good breathing and listening to blend the
  sounds"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29419-4
  a curric:KeyLearningPoint ;
  rdfs:label "Performing a backbeat can help drive the music"@en ;
  dcterms:modified "2026-06-07T15:30:29.259735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29419-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singing the chorus for Follow Me in three-part harmony"@en ;
  dcterms:modified "2026-06-07T15:30:29.259739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29792-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of warm ups to prepare the body for singing"@en ;
  dcterms:modified "2026-06-07T15:30:29.260414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29792-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pop songs use a typical verse and chorus structure and are often in melody and
  accompaniment texture"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29792-3
  a curric:KeyLearningPoint ;
  rdfs:label "The chorus is often louder than the verse to give a more uplifting quality"@en ;
  dcterms:modified "2026-06-07T15:30:29.260422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29792-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a song which has a range of different vocal textures"@en ;
  dcterms:modified "2026-06-07T15:30:29.260426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Singing Gumama in three-part homophonic harmony"@en ;
  dcterms:modified "2026-06-07T15:30:29.260429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29417-2
  a curric:KeyLearningPoint ;
  rdfs:label "Correct balance is important when signing in homophonic harmony"@en ;
  dcterms:modified "2026-06-07T15:30:29.260433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29417-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correct balance is where the parts are performed at the same volume to create a rich
  and warm tone in a vocal ensemble"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29417-4
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation adds energy and creates a groove in the music"@en ;
  dcterms:modified "2026-06-07T15:30:29.260440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29417-5
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation and triplets can create rhythmic interest"@en ;
  dcterms:modified "2026-06-07T15:30:29.260444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29793-1
  a curric:KeyLearningPoint ;
  rdfs:label "Singing in thirds is a common and effective way of harmonising a melodic line."@en ;
  dcterms:modified "2026-06-07T15:30:29.261372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29793-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate use of dynamics and emphasis within the phrase can add shape to a
  melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29793-3
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a piece through changing textures."@en ;
  dcterms:modified "2026-06-07T15:30:29.261379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29793-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing a melody with an extended range and more complex phrases for breathing."@en ;
  dcterms:modified "2026-06-07T15:30:29.261383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28159-1
  a curric:KeyLearningPoint ;
  rdfs:label """Extended vocal techniques are when a singer uses their voice in non-traditional ways
  to create unusual sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28159-2
  a curric:KeyLearningPoint ;
  rdfs:label """These are often explored by contemporary Western composers and some are common in
  music from different traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Techniques include clicking, popping, whispering and whistling, as well as more
  complex techniques like multiphonics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28159-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vocalise - singing without words - is another way to use the voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.268507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28159-5
  a curric:KeyLearningPoint ;
  rdfs:label """Creating an interesting, varied musical composition by exploring extended vocal
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8563-1
  a curric:KeyLearningPoint ;
  rdfs:label """EDM (electronic dance music) is a term used to describe a broad range of genres
  which all have similar musical features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8563-2
  a curric:KeyLearningPoint ;
  rdfs:label """EDM uses electronic instruments, has a strong beat, a fast tempo, 4 beats in a bar
  and uses repetitive musical ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Remixes, where a new version of a piece of music is created using music technology,
  are common in EDM."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8563-4
  a curric:KeyLearningPoint ;
  rdfs:label """An EDM drum beat typically includes four-on-the-floor kick drum, off-beat hi-hats
  and snare/clap on the backbeat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28160-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers have used recordings of sound in their music since recording technology
  was created."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28160-2
  a curric:KeyLearningPoint ;
  rdfs:label """This ranges from abstract-sounding musique concrète, to using samples of sound and
  music in popular music styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28160-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sampling is the process of creating samples - clips of pre-existing sound or music
  that are used in a new way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28160-4
  a curric:KeyLearningPoint ;
  rdfs:label "To create samples, we isolate individual sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.271275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28160-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can then combine them in a new way to create a musical pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.271278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29645-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main rhythmic part in a taiko performance is the ouchi. This is made up a
  variety of honji."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each honji can include a variety of different strikes, movements and kakegoe
  (shouts) and lasts for eight beats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29645-3
  a curric:KeyLearningPoint ;
  rdfs:label "It can also include ma, which is a rest."@en ;
  dcterms:modified "2026-06-07T15:30:29.274658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29645-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ouchi is accompanied by the jiuchi or ji, which plays consistent doko or dongo
  strikes softly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29645-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed an eight-honji ouchi, with an accompanying jiuchi, in time as an
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28162-1
  a curric:KeyLearningPoint ;
  rdfs:label """Serialism developed in the 20th century, with composers searching for a new approach
  to composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28162-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is atonal, meaning that it has no key or tonic note."@en ;
  dcterms:modified "2026-06-07T15:30:29.277542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28162-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything in a piece is based on a unique tone row - the 12 notes of the chromatic
  scale arranged in a specific order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28162-4
  a curric:KeyLearningPoint ;
  rdfs:label "A tone row must use all 12 notes and avoid repeating any."@en ;
  dcterms:modified "2026-06-07T15:30:29.277549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28162-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arnold Schoenberg and Elisabeth Lutyens are two well-known serialist composers."@en ;
  dcterms:modified "2026-06-07T15:30:29.277553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29643-1
  a curric:KeyLearningPoint ;
  rdfs:label """Taiko means ‘drum’ or ‘the art of drumming’. It is the global name for kumi daiko,
  which is Japanese ensemble drumming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29643-2
  a curric:KeyLearningPoint ;
  rdfs:label """Performers wear traditional outfits and use bachi to play the drums on the hara
  (head) or the fuchi (edge)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29643-3
  a curric:KeyLearningPoint ;
  rdfs:label """Taiko is learned aurally and can be understood by using the kuchi shoga phonetic
  method."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29643-4
  a curric:KeyLearningPoint ;
  rdfs:label "We have performed honji (eight-beat patterns) with don and doko sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.277672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28163-1
  a curric:KeyLearningPoint ;
  rdfs:label "Serialist composers use tone rows in many different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.277731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28163-2
  a curric:KeyLearningPoint ;
  rdfs:label """This includes varying the timbre, instrument, rhythm, dynamics, octave and
  articulation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28163-3
  a curric:KeyLearningPoint ;
  rdfs:label """As long as the order of the pitches doesn’t change, this is considered ‘within the
  rules’ of serialism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28163-4
  a curric:KeyLearningPoint ;
  rdfs:label "Another method is to create and use a retrograde of the tone row."@en ;
  dcterms:modified "2026-06-07T15:30:29.277744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28163-5
  a curric:KeyLearningPoint ;
  rdfs:label """This is when the order of pitches is carefully reversed, creating a ‘mirror image’
  of the tone row."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28161-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pitched sounds, such as musical notes, vocals or buzzing machines can be
  sampled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28161-2
  a curric:KeyLearningPoint ;
  rdfs:label """These can create unique timbres and textures, particularly when they are altered and
  recombined."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28161-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can alter them in many ways, including changing the pitch and adding effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.281671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28161-4
  a curric:KeyLearningPoint ;
  rdfs:label """By experimenting with different patterns of pitched samples, we can create unique
  hooks and riffs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29646-1
  a curric:KeyLearningPoint ;
  rdfs:label "We have composed an ouchi and performed this in an ensemble with the jiuchi."@en ;
  dcterms:modified "2026-06-07T15:30:29.281679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29646-2
  a curric:KeyLearningPoint ;
  rdfs:label """This included a variety of different strikes, kata (including kamae) and
  kakegoe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29646-3
  a curric:KeyLearningPoint ;
  rdfs:label """A successful taiko performance considers the key principles of kata, rei, waza and
  ki."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29646-4
  a curric:KeyLearningPoint ;
  rdfs:label "We have performed a complete taiko performance, demonstrating these principles."@en ;
  dcterms:modified "2026-06-07T15:30:29.281690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composing music using notes of the major scale can create music with a postive and
  cheerful feel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9813-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate use of other elements such as pitch, tempo and timbre can also help to
  create the desired mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9813-3
  a curric:KeyLearningPoint ;
  rdfs:label """When composing using a major scale, the home note is important in defining the feel
  of that scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9813-4
  a curric:KeyLearningPoint ;
  rdfs:label "Composin an ostinato in C major."@en ;
  dcterms:modified "2026-06-07T15:30:29.284519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29683-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sixteen countries that make up West Africa each have their own drumming
  traditions and styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Common instruments used are djembe, apitua and dunduns, which consist of the
  kenkeni, sangban and dundunba."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29683-3
  a curric:KeyLearningPoint ;
  rdfs:label "The djembe has three main sounds - bass, tone and slap."@en ;
  dcterms:modified "2026-06-07T15:30:29.288648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29683-4
  a curric:KeyLearningPoint ;
  rdfs:label "The call begins and ends a piece, brings in new parts and uses just tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.288652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29683-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have created a short rhythmic performance using typical techniques from the
  drumming traditions of West Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29644-1
  a curric:KeyLearningPoint ;
  rdfs:label "Taiko has four key principles which are fundamental to performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.291888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29644-2
  a curric:KeyLearningPoint ;
  rdfs:label """These are kata (movement), rei (attitude), waza (technique) and ki (energy and
  flow)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29644-3
  a curric:KeyLearningPoint ;
  rdfs:label "The correct kamae (stance) helps performers to keep in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.291896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29644-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are a variety of strikes and kakegoe, with some performed in synchronisation.
  These include sore, hup and sa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29644-5
  a curric:KeyLearningPoint ;
  rdfs:label """The common strikes are don and doko which are on the head of the drum (hara) and
  kara which is on the rim (fuchi)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29537-1
  a curric:KeyLearningPoint ;
  rdfs:label "Triadic harmony is using triad chords to add harmony to a piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.315083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29537-2
  a curric:KeyLearningPoint ;
  rdfs:label "The triad is the root, third and fifth of a chord."@en ;
  dcterms:modified "2026-06-07T15:30:29.315087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29537-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are seven chords in the scale. The most used chords are the primary chords I,
  IV, and V."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29537-4
  a curric:KeyLearningPoint ;
  rdfs:label """To add triadic harmony to a ground bass pattern, choose chords which have the bass
  note as part of the chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29539-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arpeggios and Alberti bass patterns are a variation on the triad chord."@en ;
  dcterms:modified "2026-06-07T15:30:29.316155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29539-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arpeggios and Alberti bass patterns can be used to add interest to an existing chord
  sequence and ground bass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29539-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Alberti bass has a distinctive, specific pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.316179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29539-4
  a curric:KeyLearningPoint ;
  rdfs:label """Playing arpeggios and an Alberti bass and added one or both to a ground bass
  pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29540-1
  a curric:KeyLearningPoint ;
  rdfs:label """The tresillo rhythm is a syncopated three-note pattern stretched across four beats
  (often called 3-3-2 pattern)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29540-2
  a curric:KeyLearningPoint ;
  rdfs:label """The habanera rhythm is a two beat rhythm that is similar to the tresillo in that the
  second note is syncopated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29540-3
  a curric:KeyLearningPoint ;
  rdfs:label """The tresillo and habanera contain dotted notes, which is a type of note worth 1.5
  times the value of the original note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29540-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adapting a ground bass by using either the tresillo or habanera to add rhythmic
  interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29541-1
  a curric:KeyLearningPoint ;
  rdfs:label """Triadic harmony can be used to build a melody by using one or two of the triad notes
  and the other in the bass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29541-2
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies are often higher in the scoring so we can play them up the octave."@en ;
  dcterms:modified "2026-06-07T15:30:29.319716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29541-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can develop the structure of a piece by adding in and taking out parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.319720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29541-4
  a curric:KeyLearningPoint ;
  rdfs:label """One way to do this is to start with a monophonic texture and build to a homophonic
  texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29541-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adding passing notes to a melody adds interest and creates a smooth melodic
  shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29534-1
  a curric:KeyLearningPoint ;
  rdfs:label """The bass clef shows lower pitched notes on the stave that are usually played by the
  left hand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29534-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the bass clef notes have their own symbol on the stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.322428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29534-3
  a curric:KeyLearningPoint ;
  rdfs:label "Playing pieces using the notes F - C, with the left hand."@en ;
  dcterms:modified "2026-06-07T15:30:29.322432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29534-4
  a curric:KeyLearningPoint ;
  rdfs:label "The left hand is in the F position when the little finger (5) is on F."@en ;
  dcterms:modified "2026-06-07T15:30:29.322436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Warabadon is a dance rhythm which originates in Burkina Faso."@en ;
  dcterms:modified "2026-06-07T15:30:29.323094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29686-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is in 12/8 so the rhythms have a shuffle feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.323098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29686-3
  a curric:KeyLearningPoint ;
  rdfs:label """12/8 is in compound time, where the beat is divided into groups of three quavers
  rather than two (like in simple time)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29686-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing the Warabadon rhythm, changing rhythms between the different
  sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8486-1
  a curric:KeyLearningPoint ;
  rdfs:label "The elements of music help us understand the music that we listen to and enjoy."@en ;
  dcterms:modified "2026-06-07T15:30:29.327105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8486-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pitch, tempo, dynamics and rhythm are four elements that are fundamental to how
  music is made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8486-3
  a curric:KeyLearningPoint ;
  rdfs:label "Performing is an example of making music."@en ;
  dcterms:modified "2026-06-07T15:30:29.327113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8486-4
  a curric:KeyLearningPoint ;
  rdfs:label "Keeping to a pulse is important when performing."@en ;
  dcterms:modified "2026-06-07T15:30:29.327117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8486-5
  a curric:KeyLearningPoint ;
  rdfs:label """Taking relaxed, deep and sustained singing breaths is important to help us sing
  well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8494-1
  a curric:KeyLearningPoint ;
  rdfs:label "A drum groove is the main rhythm or beat played by the drums in piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.327372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8494-2
  a curric:KeyLearningPoint ;
  rdfs:label "The kick and snare drums play an important role within the groove."@en ;
  dcterms:modified "2026-06-07T15:30:29.327376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8494-3
  a curric:KeyLearningPoint ;
  rdfs:label """In rock and most pop music, the snare usually plays a backbeat, which emphasizes the
  2nd and 4th beats of a bar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8494-4
  a curric:KeyLearningPoint ;
  rdfs:label "The kick drum often plays on the 1st and 3rd beats."@en ;
  dcterms:modified "2026-06-07T15:30:29.327384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8494-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can use a digital audio workstation (DAW) to play and create drum grooves."@en ;
  dcterms:modified "2026-06-07T15:30:29.327388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unison is a musical texture where everyone performs the same thing at the
  same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8487-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the texture by adding or taking away different layers of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.328240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Timbre refers to the sound of the instrument. Different timbres change the feeling
  and mood of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8487-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing posture and good vocal onset are important for singing well."@en ;
  dcterms:modified "2026-06-07T15:30:29.328249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8487-5
  a curric:KeyLearningPoint ;
  rdfs:label """The best posture for singing is with feet apart, knees slightly bent, arms by your
  sides and head lifted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8533-1
  a curric:KeyLearningPoint ;
  rdfs:label """The contrasting timbres in a drum kit provide the interest in the drum grooves you
  listen to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8533-2
  a curric:KeyLearningPoint ;
  rdfs:label """Toms typically have a less harsh timbre than the snare and cymbals, and a wide range
  of pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8533-3
  a curric:KeyLearningPoint ;
  rdfs:label "Toms are often used in drum fills."@en ;
  dcterms:modified "2026-06-07T15:30:29.330558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8533-4
  a curric:KeyLearningPoint ;
  rdfs:label """The snare usually plays the backbeat as it has a strong attack which helps to
  emphasise the pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8533-5
  a curric:KeyLearningPoint ;
  rdfs:label """Clicks and claps have a similar attack and can be used instead of the snare to play
  the backbeat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8531-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hi-hat can be played open, which produces longer vibrations, or closed, which
  produces a cleaner, short sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8531-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hi-hat quavers, with an open hi-hat on the last quaver of a bar, can provide a
  typical pattern for an R’n’B drum groove."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8531-3
  a curric:KeyLearningPoint ;
  rdfs:label """When recording different parts in to a DAW it can be helpful to solo the track so
  you can hear it clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8530-1
  a curric:KeyLearningPoint ;
  rdfs:label """R‘n’B (rhythm and blues) grooves in the late 20th century are built around the
  interaction of the kick and snare."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8530-2
  a curric:KeyLearningPoint ;
  rdfs:label """Two features of these grooves are the snare playing a backbeat and quaver and
  semiquaver upbeats on the kick"""@en ;
  dcterms:modified "2026-06-07T15:30:29.330759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8532-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pop music often uses four-bar phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.331368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8532-2
  a curric:KeyLearningPoint ;
  rdfs:label "These phrases may end with drum fills, which help listeners feel the phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.331372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8532-3
  a curric:KeyLearningPoint ;
  rdfs:label """Drum fills change the underlying groove of the music to create a contrasting break
  in the pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8532-4
  a curric:KeyLearningPoint ;
  rdfs:label """They can use all parts of a drum kit and we created fills using the kick and
  snare."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29535-1
  a curric:KeyLearningPoint ;
  rdfs:label """A ground bass is a short, repeated bass line that repeats throughout a piece,
  forming the structure of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29535-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ground bass was popular in baroque music but repeated chord sequences are still
  common in today's pop music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29535-3
  a curric:KeyLearningPoint ;
  rdfs:label "A ground bass tends to start on the tonic note to reinforce the key."@en ;
  dcterms:modified "2026-06-07T15:30:29.331860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29535-4
  a curric:KeyLearningPoint ;
  rdfs:label """A ground bass finishes on the dominant or leading note which naturally wants to
  return to the tonic note to start again."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29535-5
  a curric:KeyLearningPoint ;
  rdfs:label "Composing a ground bass"@en ;
  dcterms:modified "2026-06-07T15:30:29.331886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8565-1
  a curric:KeyLearningPoint ;
  rdfs:label """In EDM the texture can vary between thick and thin to create excitement and
  interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Texture in EDM is often described as thick or thin depending on the number of
  different layers in the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8565-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main layers in EDM music are the melody, the chords, the bass line and the drum
  groove."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8565-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can develop texture by adding, removing and changing instruments and tracks."@en ;
  dcterms:modified "2026-06-07T15:30:29.332742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8615-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing a melody, we need to use a phrase structure that balances repetition
  and contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8615-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the most popular phrase structures that achieve this balance are AABB, AABA,
  ABAB and ABAC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8615-3
  a curric:KeyLearningPoint ;
  rdfs:label "The A minor scale is a set of notes that uses only the white notes on the piano."@en ;
  dcterms:modified "2026-06-07T15:30:29.333304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8615-4
  a curric:KeyLearningPoint ;
  rdfs:label "This is one of the simplest minor keys to compose in."@en ;
  dcterms:modified "2026-06-07T15:30:29.333308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8580-1
  a curric:KeyLearningPoint ;
  rdfs:label """We have played melodies in the C position on the keyboard, identifying the notes C
  to G on the stave."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8580-2
  a curric:KeyLearningPoint ;
  rdfs:label """The melody of Going Home frequently uses a dotted crotchet rhythm. It also has
  quavers, crotchets, minims & semibreves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8580-3
  a curric:KeyLearningPoint ;
  rdfs:label """A phrase is a section of a melody. Each phrase in the Going Home melody is 4 bars
  long."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8580-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using all 5 fingers helps us play legato, which makes the movement between each note
  smooth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Minimalism is a style of music that developed in the 1960s in the USA."@en ;
  dcterms:modified "2026-06-07T15:30:29.337702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20139-2
  a curric:KeyLearningPoint ;
  rdfs:label "It uses minimal musical ideas and repeats them over and over again."@en ;
  dcterms:modified "2026-06-07T15:30:29.337706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20139-3
  a curric:KeyLearningPoint ;
  rdfs:label "The repeating musical ideas are called ostinati (one is called an ostinato)."@en ;
  dcterms:modified "2026-06-07T15:30:29.337711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20139-4
  a curric:KeyLearningPoint ;
  rdfs:label "Percussion instruments produce sound by being hit and can be tuned or untuned."@en ;
  dcterms:modified "2026-06-07T15:30:29.337715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8600-1
  a curric:KeyLearningPoint ;
  rdfs:label "An extended chord is a chord that includes more than three notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.340020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8600-2
  a curric:KeyLearningPoint ;
  rdfs:label """A 7th chord includes a note that is the 7th note in the scale above the root
  note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8600-3
  a curric:KeyLearningPoint ;
  rdfs:label """A 6th chord includes a note that is the 6th note in the scale above the root
  note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8600-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brazilian popular songs use extended chords to add colour and interest to the
  harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8490-1
  a curric:KeyLearningPoint ;
  rdfs:label "On the keyboard, the C is to the left of the two black keys."@en ;
  dcterms:modified "2026-06-07T15:30:29.345637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8490-2
  a curric:KeyLearningPoint ;
  rdfs:label """The C position is when you place your thumb on C and other fingers on the adjacent
  notes allowing for more control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8490-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recognising C, D, E, F and G on the stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.345647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8490-4
  a curric:KeyLearningPoint ;
  rdfs:label "C on the stave is distinctive as it sits under the stave and has its own line."@en ;
  dcterms:modified "2026-06-07T15:30:29.345651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8490-5
  a curric:KeyLearningPoint ;
  rdfs:label "Practising slowly at first allows time for more accuracy."@en ;
  dcterms:modified "2026-06-07T15:30:29.345655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9821-1
  a curric:KeyLearningPoint ;
  rdfs:label "The silent movie era was between the 1890s and 1920s."@en ;
  dcterms:modified "2026-06-07T15:30:29.345968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9821-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this period, film music was performed live by a solo performer (often improvised)
  or a group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9821-3
  a curric:KeyLearningPoint ;
  rdfs:label "The performers tried to capture and exaggerate the mood of scenes."@en ;
  dcterms:modified "2026-06-07T15:30:29.345976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9821-4
  a curric:KeyLearningPoint ;
  rdfs:label "Chase scenes were common in silent movies."@en ;
  dcterms:modified "2026-06-07T15:30:29.345980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9821-5
  a curric:KeyLearningPoint ;
  rdfs:label """The music often used a fast tempo, fast rhythms and scalic runs to create a sense of
  excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8581-1
  a curric:KeyLearningPoint ;
  rdfs:label """The brass family consist of four main instruments: the trumpet, French horn,
  trombone and tuba."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8581-2
  a curric:KeyLearningPoint ;
  rdfs:label """As the instruments get bigger, the pitch gets lower. The range of an instrument is
  how high and low it can play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8581-3
  a curric:KeyLearningPoint ;
  rdfs:label "The brass family are often used to play fanfares, which are triumphant melodies."@en ;
  dcterms:modified "2026-06-07T15:30:29.348292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8581-4
  a curric:KeyLearningPoint ;
  rdfs:label "The middle section of Going Home is played in F position."@en ;
  dcterms:modified "2026-06-07T15:30:29.348296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8581-5
  a curric:KeyLearningPoint ;
  rdfs:label "F position uses the notes F, G, A, B and C and the thumb should rest on F."@en ;
  dcterms:modified "2026-06-07T15:30:29.348300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8492-1
  a curric:KeyLearningPoint ;
  rdfs:label "A quaver is a half beat note. These often come in pairs."@en ;
  dcterms:modified "2026-06-07T15:30:29.355780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8492-2
  a curric:KeyLearningPoint ;
  rdfs:label "Playing the third phrase of Ode to Joy which uses paired quavers."@en ;
  dcterms:modified "2026-06-07T15:30:29.355785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8492-3
  a curric:KeyLearningPoint ;
  rdfs:label """Phrases give structure to the melody and often use repetition. Spotting the patterns
  can make the music easier to learn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8492-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pulse is the steady feel of the beats within the music. Feeling the pulse is
  fundamental to good music making."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8492-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dynamics (volume) and tempo (speed) can play an important role in expressive musical
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8491-1
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies are made up of phrases. The phrases in Ode to Joy are four bars long."@en ;
  dcterms:modified "2026-06-07T15:30:29.358420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8491-2
  a curric:KeyLearningPoint ;
  rdfs:label "A crotchet is a one beat note and a minim is a two beat note."@en ;
  dcterms:modified "2026-06-07T15:30:29.358424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8491-3
  a curric:KeyLearningPoint ;
  rdfs:label "Playing the first two phrases of Ode to Joy on the keyboard."@en ;
  dcterms:modified "2026-06-07T15:30:29.358428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8491-4
  a curric:KeyLearningPoint ;
  rdfs:label """An emphasis on the first beat of a bar and playing the last bar slighly quieter can
  help to create a well-shaped phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8491-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ode to Joy is a melody by German composer Ludwig van Beethoven."@en ;
  dcterms:modified "2026-06-07T15:30:29.358438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8575-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reggaeton is a style popularised in Puerto Rico in the 1990s."@en ;
  dcterms:modified "2026-06-07T15:30:29.362051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8575-2
  a curric:KeyLearningPoint ;
  rdfs:label "It draws on hip hop, reggae, dancehall and other Caribbean styles."@en ;
  dcterms:modified "2026-06-07T15:30:29.362054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8575-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is an energetic style, typically performed in Spanish that is usually
  danced to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8575-4
  a curric:KeyLearningPoint ;
  rdfs:label "It uses synthesised sounds combined with Latin American percussion sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.362062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8575-5
  a curric:KeyLearningPoint ;
  rdfs:label """The dembow beat is the defining rhythmic feature of reggaeton, which is based on the
  tresillo rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9820-1
  a curric:KeyLearningPoint ;
  rdfs:label "Film music can be used in a variety of ways to shape our experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.362533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9820-2
  a curric:KeyLearningPoint ;
  rdfs:label """These include setting the scene, creating tension, and use of leitmotif to represent
  a particular character or idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9820-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use the musical elements to create an appropriate atmosphere, including
  appropriate use of tonality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9820-4
  a curric:KeyLearningPoint ;
  rdfs:label """Title themes are often the first music in a film, so should set the tone for the
  whole film."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29687-1
  a curric:KeyLearningPoint ;
  rdfs:label "Warabadon has a structure consisting of different sections."@en ;
  dcterms:modified "2026-06-07T15:30:29.366658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29687-2
  a curric:KeyLearningPoint ;
  rdfs:label """Part 3 contains improvised solos which are performed by the djembefola and often
  include fast, complex triplet rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29687-3
  a curric:KeyLearningPoint ;
  rdfs:label "The solo section of the Warabadon includes polyrhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.366666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29687-4
  a curric:KeyLearningPoint ;
  rdfs:label """This is a key feature which creates excitement and a thicker texture in the
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29687-5
  a curric:KeyLearningPoint ;
  rdfs:label "Performing the full Warabadon structure including an improvised solo."@en ;
  dcterms:modified "2026-06-07T15:30:29.366673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20142-1
  a curric:KeyLearningPoint ;
  rdfs:label """Minimalist composers develop their compositions by varying different aspects,
  including dynamics and texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20142-2
  a curric:KeyLearningPoint ;
  rdfs:label """This allows them to create some contrast, keep the music engaging while still using
  their repeating ostinati."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20142-3
  a curric:KeyLearningPoint ;
  rdfs:label "We describe texture using the words thick or thin."@en ;
  dcterms:modified "2026-06-07T15:30:29.369068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20142-4
  a curric:KeyLearningPoint ;
  rdfs:label "Binary form (AB) and ternary form (ABA) are very common structures in music."@en ;
  dcterms:modified "2026-06-07T15:30:29.369073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Samba is a type of Brazilian dance and music which comes in many forms, one of which
  is batucada."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Batucada is often played at celebrations and carnival, and is performed by a
  percussion ensemble called a bateria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8599-3
  a curric:KeyLearningPoint ;
  rdfs:label """The instruments include surdo, caixa, agogo bells, repinique, tamborim and
  ganzá."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8599-4
  a curric:KeyLearningPoint ;
  rdfs:label """These instruments all play different rhythms, which combine to create a
  polyrhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8610-1
  a curric:KeyLearningPoint ;
  rdfs:label "The blues scale is a set of notes commonly used in blues music."@en ;
  dcterms:modified "2026-06-07T15:30:29.376716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8610-2
  a curric:KeyLearningPoint ;
  rdfs:label """It includes blue notes (flattened notes) which help to give blues music its
  distinctive sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8610-3
  a curric:KeyLearningPoint ;
  rdfs:label "The C blues scale includes the flats Eb, Gb and Bb."@en ;
  dcterms:modified "2026-06-07T15:30:29.376724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8610-4
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed the C blues scale on the keyboard and played a blues scale melody
  over the 12-bar blues chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Programme music is music that is written to depict a story through music."@en ;
  dcterms:modified "2026-06-07T15:30:29.378415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9814-2
  a curric:KeyLearningPoint ;
  rdfs:label """The elements of music can be used in a certain way to convey a specific correct
  mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9814-3
  a curric:KeyLearningPoint ;
  rdfs:label "The minor scale usually creates a more sombre mood to the major scale."@en ;
  dcterms:modified "2026-06-07T15:30:29.378423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9814-4
  a curric:KeyLearningPoint ;
  rdfs:label """Developing a motif from major to minor to change the feel of the music to suggest a
  sense of unrest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29464-1
  a curric:KeyLearningPoint ;
  rdfs:label """An idiomatic blues improvisation can be created by using a motif and typical blues
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29464-2
  a curric:KeyLearningPoint ;
  rdfs:label "These include blue notes, syncopation and an AAB phrase structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.380667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29464-3
  a curric:KeyLearningPoint ;
  rdfs:label """They also include piano techniques such as tremolos, playing in octaves and using
  chords in the melodic line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29464-4
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed an extended 12-bar blues performance using the blues scale,
  improvisation and a blues accompaniment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8609-1
  a curric:KeyLearningPoint ;
  rdfs:label """The boogie-woogie is an upbeat and energetic style of blues music that encourages
  people to dance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8609-2
  a curric:KeyLearningPoint ;
  rdfs:label "The piano is the key instrument in boogie-woogie."@en ;
  dcterms:modified "2026-06-07T15:30:29.383286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8609-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is also a blues piano accompaniment pattern, which is said to sound like
  a train."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8609-4
  a curric:KeyLearningPoint ;
  rdfs:label """This is due to the repetition, constant movement and tremolos that mimic train
  sounds. It is often staccato."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8609-5
  a curric:KeyLearningPoint ;
  rdfs:label "Learning to play the boogie-woogie pattern with the 12-bar blues chords."@en ;
  dcterms:modified "2026-06-07T15:30:29.383298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29685-1
  a curric:KeyLearningPoint ;
  rdfs:label "The structure of Kuku includes various different sections."@en ;
  dcterms:modified "2026-06-07T15:30:29.390745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29685-2
  a curric:KeyLearningPoint ;
  rdfs:label "The call arrives between every section."@en ;
  dcterms:modified "2026-06-07T15:30:29.390749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Part 3 contains solos which are performed by the djembefola. These can be prepared
  or improvised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29685-4
  a curric:KeyLearningPoint ;
  rdfs:label """The piece ends with an échauffement which is used to speed up or signal the end of
  the performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29685-5
  a curric:KeyLearningPoint ;
  rdfs:label """Preparing a performance of the full Kuku structure which includes a prepared or
  improvised solo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8608-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are four main instrumental roles in a blues ensemble: the melody, chords, bass
  and drum groove."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8608-2
  a curric:KeyLearningPoint ;
  rdfs:label """The melody is often performed by a singer. The piano, guitar, bass and drum kit play
  an accompanying role."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8608-3
  a curric:KeyLearningPoint ;
  rdfs:label """The piano, guitar and instruments such as the harmonica and brass can play melodic
  lines which are often improvised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8608-4
  a curric:KeyLearningPoint ;
  rdfs:label "We have learned to play a syncopated bass riff with the 12-bar blues chords."@en ;
  dcterms:modified "2026-06-07T15:30:29.390776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8608-5
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation in the music drives the music forward and helps create a blues feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.390780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8601-1
  a curric:KeyLearningPoint ;
  rdfs:label """A bass line can be created using just the root note, or by adding additional notes,
  including octaves and chord tones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8601-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chord tones are notes that are included in a chord."@en ;
  dcterms:modified "2026-06-07T15:30:29.407097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8601-3
  a curric:KeyLearningPoint ;
  rdfs:label "Octaves are different pitches of the same note (e.g. a low C and a higher C)."@en ;
  dcterms:modified "2026-06-07T15:30:29.407101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8601-4
  a curric:KeyLearningPoint ;
  rdfs:label """These are not essential in a bass line, but they make it more interesting and
  complex than just using root notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8564-1
  a curric:KeyLearningPoint ;
  rdfs:label """Syncopated rhythms are common in EDM music, creating excitement and music that is
  highly danceable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8564-2
  a curric:KeyLearningPoint ;
  rdfs:label "EDM bass lines are based around the root of the chord and often use syncopation."@en ;
  dcterms:modified "2026-06-07T15:30:29.410433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8564-3
  a curric:KeyLearningPoint ;
  rdfs:label "EDM bass lines are often played on a synth bass (low-pitched synthesizer)"@en ;
  dcterms:modified "2026-06-07T15:30:29.410437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8566-1
  a curric:KeyLearningPoint ;
  rdfs:label """Remixes (and EDM generally) use a variety of music technology tools to create
  effects and enhance the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8566-2
  a curric:KeyLearningPoint ;
  rdfs:label """Risers and volume automation are useful tools that help to create contrast and
  climax in EDM."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8566-3
  a curric:KeyLearningPoint ;
  rdfs:label """EQ (equalization) allows you to radically alter the timbre of your recorded tracks
  to create variety and contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8493-1
  a curric:KeyLearningPoint ;
  rdfs:label """A semibreve is a four beat note and the main note duration in the accompaniment of
  Ode to Joy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8493-2
  a curric:KeyLearningPoint ;
  rdfs:label """The accompaniment to Ode to Joy is played with the left hand using the notes C and
  G."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8493-3
  a curric:KeyLearningPoint ;
  rdfs:label "The melody and accompaniment are played together on the first beat of each bar."@en ;
  dcterms:modified "2026-06-07T15:30:29.417227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8493-4
  a curric:KeyLearningPoint ;
  rdfs:label """A final performance of the melody and accompaniment with attention to pulse,
  dynamics and tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8602-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our melody is an unusual length (14 bars), and has an anacrusis. The song is in the
  key of G major, which includes F#."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8602-2
  a curric:KeyLearningPoint ;
  rdfs:label """When improvising, we should use notes from the key of the music. In this song, we
  use the G major scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8602-3
  a curric:KeyLearningPoint ;
  rdfs:label "One strategy for improvisation is to use target notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.418492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8602-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we are improvising more freely, we can use other strategies to help us to
  structure our improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8582-1
  a curric:KeyLearningPoint ;
  rdfs:label "The percussion family has the most varied instruments in the orchestra."@en ;
  dcterms:modified "2026-06-07T15:30:29.422862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8582-2
  a curric:KeyLearningPoint ;
  rdfs:label """The instruments are either tuned, which can play pitched sounds, or untuned, which
  play notes without clear pitch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8582-3
  a curric:KeyLearningPoint ;
  rdfs:label """To perform the melody of Going Home, you have to move hand positions from C to F on
  the keyboard with your right hand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8582-4
  a curric:KeyLearningPoint ;
  rdfs:label "The piece is in an ABA structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.422874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8582-5
  a curric:KeyLearningPoint ;
  rdfs:label "It's important to play with a steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.422878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20141-1
  a curric:KeyLearningPoint ;
  rdfs:label """When creating melodic ideas, improvising using a scale is a useful technique to try
  out different ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20141-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can create variety by changing the pitch of our ostinati, though still using the
  notes of the Dm pentatonic scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20141-3
  a curric:KeyLearningPoint ;
  rdfs:label """Retrograding is reversing the order of notes. This is another technique that we can
  use to develop our melodic ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20690-1
  a curric:KeyLearningPoint ;
  rdfs:label """When performing Going Home with fluency, the pitches and rhythms are played
  correctly and in time with a pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20690-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can add musical expression by changing dynamics, playing legato, or stressing the
  first beat of the bar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20690-3
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed the melody and accompaniment of Going Home and refined the
  performance by adding expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20689-1
  a curric:KeyLearningPoint ;
  rdfs:label """The accompaniment part for Going Home is played by the left hand an octave lower
  than the melody part."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20689-2
  a curric:KeyLearningPoint ;
  rdfs:label """We have performed the accompaniment part separately and then the melody and
  accompaniment together for section A."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20689-3
  a curric:KeyLearningPoint ;
  rdfs:label "The accompaniment mainly uses semibreves."@en ;
  dcterms:modified "2026-06-07T15:30:29.423835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20689-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider expression in performance. This can include stressing
  certain notes and using dynamics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20140-1
  a curric:KeyLearningPoint ;
  rdfs:label """The texture can be developed by creating sections of thin (few layers) and thick
  (many layers) texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20140-2
  a curric:KeyLearningPoint ;
  rdfs:label """A pentatonic scale uses five notes. The Dm pentatonic scale uses D, F, G, A
  and C."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20140-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a melodic ostinato by improvising using a scale like the pentatonic
  scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8607-1
  a curric:KeyLearningPoint ;
  rdfs:label """Blues music is considered one of the most influential styles of the 20th
  Century."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8607-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main structure in blues is the 12-bar blues chord sequence which uses the chords
  C, F and G."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8607-3
  a curric:KeyLearningPoint ;
  rdfs:label """Main instruments include vocals, piano, guitar, double bass, drum kit and often
  harmonica, saxophone and brass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8607-4
  a curric:KeyLearningPoint ;
  rdfs:label "Slide/bottleneck guitar helps to give the music that ‘bluesy’ sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.428729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8607-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can perform the 12-bar blues chord sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.428733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29597-1
  a curric:KeyLearningPoint ;
  rdfs:label """Trill and glissando are two musical techniques which create a specific effect in
  music or help to create tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29597-2
  a curric:KeyLearningPoint ;
  rdfs:label """Silence can also be effective in adding tension when used at an appropriate
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29597-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of musical techniques and the elements to create an appropriate
  atmosphere for a scary story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mickey-mousing is a common technique in early movies."@en ;
  dcterms:modified "2026-06-07T15:30:29.428928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9822-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is where the music copies the movement of a character."@en ;
  dcterms:modified "2026-06-07T15:30:29.428934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9822-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many early movies also involve scenes in which music is key to creating
  suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9822-4
  a curric:KeyLearningPoint ;
  rdfs:label """Typical suspenseful music uses dissonant chords (such as diminished sevenths) and
  sudden changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9812-1
  a curric:KeyLearningPoint ;
  rdfs:label "Timbre can be used to help create atmosphere in music."@en ;
  dcterms:modified "2026-06-07T15:30:29.429092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9812-2
  a curric:KeyLearningPoint ;
  rdfs:label "Strings are effective as they have quite an intense sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.429097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9812-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tuned percussion (bell-like sounds) can also be effective in making music sound
  creepy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9812-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use different articulations, including staccato and legato for different
  effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9812-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use sequence to develop and extend our musical ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.429114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29521-1
  a curric:KeyLearningPoint ;
  rdfs:label "Leitmotifs are musical ideas that represent ideas, characters or places."@en ;
  dcterms:modified "2026-06-07T15:30:29.429336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29521-2
  a curric:KeyLearningPoint ;
  rdfs:label """They were used in opera and became popular in films after the end of silent movies
  in the 1920s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29521-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composers capture the important features of a character in a leitmotif to support
  the audience’s understanding of them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29521-4
  a curric:KeyLearningPoint ;
  rdfs:label """They do this by choosing suitable keys, pitch and rhythms, including the use of
  strong rhythms for powerful characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29521-5
  a curric:KeyLearningPoint ;
  rdfs:label """By changing a leitmotif, a composer can reflect changes in that character or in the
  plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be used to create an atmosphere and convey a scene."@en ;
  dcterms:modified "2026-06-07T15:30:29.429605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9811-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatic movement, note clusters and pedal notes create suspense and help to make
  the music sound scary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9811-3
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate use of pitch, tempo and dynamics can also be used to reflect actions,
  movement and mood in a scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9811-4
  a curric:KeyLearningPoint ;
  rdfs:label """A successful musical idea is often repetitive and simple, using only a few
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29522-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers use leitmotif to tell us about a character or idea, but also to show
  changes that occur."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29522-2
  a curric:KeyLearningPoint ;
  rdfs:label """This is done through motivic transformation - changing aspects of the leitmotif to
  represent changes in the character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29522-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can change most aspects of a leitmotif, but must keep the melodic shape similar
  so that it is still recognisable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29522-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changing articulation, rhythms, dynamics, tempo and harmony can transform a
  leitmotif to create very different emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8489-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can refine musical ideas by thinking about the melodic shape and choice
  of notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8489-2
  a curric:KeyLearningPoint ;
  rdfs:label """ABA is a common structure. It starts and finishes with the same idea (A) and uses a
  contrasting idea (B) in the middle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8489-3
  a curric:KeyLearningPoint ;
  rdfs:label """This gives music a balance of unity and variety, making it interesting and
  memorable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8489-4
  a curric:KeyLearningPoint ;
  rdfs:label """We have composed a piece of music in an ABA structure, using the elements of music
  appropriately to depict an image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29415-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sea shanties are a type of folk song that were traditionally sung by sailors to
  coordinate their movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29415-2
  a curric:KeyLearningPoint ;
  rdfs:label """They have a strong pulse to help this coordination, and a catchy, repeated
  melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29415-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing them in unison - when everyone sings the same melody - or in
  harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29415-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can emphasise the downbeat to help show the pulse when performing."@en ;
  dcterms:modified "2026-06-07T15:30:29.430455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29684-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Kuku rhythm is performed to celebrate the return of the women from fishing
  expeditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29684-2
  a curric:KeyLearningPoint ;
  rdfs:label """Kuku has many variations in performance but it is based around two djembe parts and
  three dundun parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29684-3
  a curric:KeyLearningPoint ;
  rdfs:label """The parts are highly syncopated and, when played together, create exciting
  polyrhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29684-4
  a curric:KeyLearningPoint ;
  rdfs:label """Grid notation can be used to help understand how the syncopated rhythms are
  counted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Performing a Kuku rhythm with syncopation."@en ;
  dcterms:modified "2026-06-07T15:30:29.430734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29625-1
  a curric:KeyLearningPoint ;
  rdfs:label """Drum beats can be recreated by ear by using similar techniques to working out a
  melodic line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29625-2
  a curric:KeyLearningPoint ;
  rdfs:label """Breaking it into small chunks and trying to pick out individual instruments or lines
  helps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29625-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blinding Lights has a typical pop drum groove, with a snare backbeat, repeated
  hi-hats and kick emphasising 1 and 3."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29625-4
  a curric:KeyLearningPoint ;
  rdfs:label "The hook uses a synth lead and has syncopated rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.434739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8579-1
  a curric:KeyLearningPoint ;
  rdfs:label """The orchestra is a large ensemble used often in classical music and film. It
  consists of four families of instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8579-2
  a curric:KeyLearningPoint ;
  rdfs:label """The strings consist of four main instruments: violin, viola, cello and double bass.
  They can be bowed or plucked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8579-3
  a curric:KeyLearningPoint ;
  rdfs:label """The woodwind family consists of five main instruments: flute, oboe, clarinet,
  bassoon and saxophone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8579-4
  a curric:KeyLearningPoint ;
  rdfs:label "The saxophone is not used often in the orchestra."@en ;
  dcterms:modified "2026-06-07T15:30:29.435182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8579-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each instrument in each family has a distinctive timbre."@en ;
  dcterms:modified "2026-06-07T15:30:29.435187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9823-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music in silent movies has to transition seamlessly between different scenes and
  moods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9823-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many performers played popular songs and used musical clichés in their musical
  performances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9823-3
  a curric:KeyLearningPoint ;
  rdfs:label "One famous example is the ‘misterioso’ musical cliché."@en ;
  dcterms:modified "2026-06-07T15:30:29.435497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9823-4
  a curric:KeyLearningPoint ;
  rdfs:label """To transition between scenes, performers often played a vamp, a repeated pattern
  based on chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9823-5
  a curric:KeyLearningPoint ;
  rdfs:label "Composing music using a D minor vamp."@en ;
  dcterms:modified "2026-06-07T15:30:29.435506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29624-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learning music by ear is an important musical skill that can be developed through
  practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29624-2
  a curric:KeyLearningPoint ;
  rdfs:label "Working out rhythm and pitch separately helps to simplify the process."@en ;
  dcterms:modified "2026-06-07T15:30:29.435530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29624-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can describe melody using the words ascending, descending, conjunct and
  disjunct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29624-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can then use this process, we can work out hooks, harmony lines and other musical
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29626-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying repeated phrases can make it easier to recreate melodic ideas
  quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29626-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hook in As It Was uses two repeated phrases that are only slightly different
  from each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29626-3
  a curric:KeyLearningPoint ;
  rdfs:label """Accompaniments often use synth pads, which are effective for sustained notes and
  chords."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29626-4
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the melodic shape of a pattern can help to accurately work out the
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29627-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bass guitarists in pop and rock styles often work out iconic bass riffs to help
  develop their skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29627-2
  a curric:KeyLearningPoint ;
  rdfs:label """The bass riff in Under Pressure is very famous and creates a pedal by repeating the
  same pitches as the chords change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29627-3
  a curric:KeyLearningPoint ;
  rdfs:label """The bass riff in Feel Good Inc. is more complex as it is syncopated and has more
  varied pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29627-4
  a curric:KeyLearningPoint ;
  rdfs:label """To work out a bass riff, the key is to hear it on its own, break it into small
  chunks and work out notes one-by-one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8495-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hi-hat is the third main part of a drum kit. It is higher and quieter than the
  kick and snare drum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8495-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hi-hat can make an open or closed sound depending on whether its two cymbals are
  touching or not."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8495-3
  a curric:KeyLearningPoint ;
  rdfs:label "A metronome helps keep time when recording in a DAW."@en ;
  dcterms:modified "2026-06-07T15:30:29.436379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8495-4
  a curric:KeyLearningPoint ;
  rdfs:label """After recording, the music can be pushed perfectly in time by using the quantise
  function."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using the elements of music appropriately can help us depict an image or tell a
  story with music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8488-2
  a curric:KeyLearningPoint ;
  rdfs:label """Structure is an important element of music that refers to how the sections within a
  piece of music are organised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8488-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composing a musical idea as a starting point for a composition which depicts a
  scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8488-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important that a musical idea recurs like a motif, or repeats like an
  ostinato, to ensure the piece is memorable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8577-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reggaeton often uses melodic hooks which are short, memorable musical ideas that
  normally repeat in a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8577-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is possible to create hooks by sampling, or by composing them from scratch."@en ;
  dcterms:modified "2026-06-07T15:30:29.437354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8577-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bass lines in reggaeton are usually simple and repeated."@en ;
  dcterms:modified "2026-06-07T15:30:29.437360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8577-4
  a curric:KeyLearningPoint ;
  rdfs:label "They are typically based on the tonic, which is the ‘home’ note in a key."@en ;
  dcterms:modified "2026-06-07T15:30:29.437365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29598-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using common features can help to create a sense of style in a composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.437609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a recurring motif or rhythm can help with the music having an identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.437613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Having a prominent instrument or other recurring musical feature is also
  suitable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering how to use common features and stylistic elements to give music a sense
  of style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29598-5
  a curric:KeyLearningPoint ;
  rdfs:label "Composing a complete soundtrack for a short scary story."@en ;
  dcterms:modified "2026-06-07T15:30:29.437625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8576-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reggaeton has evolved from being popular in Puerto Rico to being a globally
  successful genre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8576-2
  a curric:KeyLearningPoint ;
  rdfs:label """It has influenced many pop artists, including Ed Sheeran, Clean Bandit and
  Dua Lipa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8576-3
  a curric:KeyLearningPoint ;
  rdfs:label """When different musical styles are combined, such as using the dembow beat in pop
  music, it results in a musical fusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8576-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can create more complex variations on the dembow beat by adding timbales, extra
  percussion and drum rolls."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8578-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reggaeton usually repeats musical ideas extensively."@en ;
  dcterms:modified "2026-06-07T15:30:29.584551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8578-2
  a curric:KeyLearningPoint ;
  rdfs:label """It maintains interest by creating musical contrast. This includes varying the
  texture, dynamics and instrumentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8578-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composers build energy through the use of build-ups."@en ;
  dcterms:modified "2026-06-07T15:30:29.584562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8578-4
  a curric:KeyLearningPoint ;
  rdfs:label "One technique we can use to create a build-up is a low-pass filter sweep."@en ;
  dcterms:modified "2026-06-07T15:30:29.584566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22199-1
  a curric:KeyLearningPoint ;
  rdfs:label """The intro and outro are important parts of a structure - they provide the 'frame'
  for the main content of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22199-2
  a curric:KeyLearningPoint ;
  rdfs:label "The intro and outro are usually based on musical ideas from the verse or chorus."@en ;
  dcterms:modified "2026-06-07T15:30:29.585036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22199-3
  a curric:KeyLearningPoint ;
  rdfs:label """The intro is an opportunity to introduce some of the musical ideas and set the mood
  for the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22199-4
  a curric:KeyLearningPoint ;
  rdfs:label "The outro provides a neat ending to the song. It is not used in all songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.585045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22199-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can make an instrumental melody vocal by adapting it to fit the rhythms
  of words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8611-1
  a curric:KeyLearningPoint ;
  rdfs:label """Grunge is a style of of heavy rock music featuring distorted guitar sounds and angry
  lyrics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8611-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key musical features include the use of riffs, distorted guitars and simple
  instrumentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8611-3
  a curric:KeyLearningPoint ;
  rdfs:label "These are influences taken from punk rock and heavy metal."@en ;
  dcterms:modified "2026-06-07T15:30:29.585122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8611-4
  a curric:KeyLearningPoint ;
  rdfs:label "Drum beats in rock have a strong pulse and snare backbeat."@en ;
  dcterms:modified "2026-06-07T15:30:29.585127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8611-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grunge drum beats often contrast between sections, and use open hi-hats or crash
  cymbals to create powerful effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22198-1
  a curric:KeyLearningPoint ;
  rdfs:label """Songwriters create musical contrast by making sections or musical ideas sound
  different from each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22198-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is exaggerated in grunge, reflecting the emotional lyrics."@en ;
  dcterms:modified "2026-06-07T15:30:29.585855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22198-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can create contrast through considered use of dynamics, timbre, pitch, texture,
  rhythm and harmonic rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22198-4
  a curric:KeyLearningPoint ;
  rdfs:label """The middle 8 is a contrasting section, usually 8 bars long, heard in the second half
  of a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8613-1
  a curric:KeyLearningPoint ;
  rdfs:label "A key feature of grunge (and most rock styles) is the use of riffs."@en ;
  dcterms:modified "2026-06-07T15:30:29.586906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8613-2
  a curric:KeyLearningPoint ;
  rdfs:label "Grunge riffs often use power chords, consisting of the root note and fifth."@en ;
  dcterms:modified "2026-06-07T15:30:29.586951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8613-3
  a curric:KeyLearningPoint ;
  rdfs:label """To play a power chord on the piano, we remove the middle note from a triad chord, or
  find the fifth note in the scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8613-4
  a curric:KeyLearningPoint ;
  rdfs:label """Distortion is often added to electric guitar sounds, creating a fuzzy effect which
  distorts the sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8613-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bass lines in grunge are often based around the riff, using the root note of each
  chord."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8497-1
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition in drum grooves is important, but adding some contrast can create
  interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contrast works well at the end of a phrase and can be added in the following
  ways:"""@en ;
  dcterms:modified "2026-06-07T15:30:29.586979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8497-3
  a curric:KeyLearningPoint ;
  rdfs:label "adding new rhythms and sounds on a separate track"@en ;
  dcterms:modified "2026-06-07T15:30:29.586984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8497-4
  a curric:KeyLearningPoint ;
  rdfs:label "altering the fundamental groove"@en ;
  dcterms:modified "2026-06-07T15:30:29.586988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8497-5
  a curric:KeyLearningPoint ;
  rdfs:label """keeping the same pattern but using a different part of the drum kit (e.g. ride
  cymbal)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.586995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8612-1
  a curric:KeyLearningPoint ;
  rdfs:label """Drum fills are used at the end of sections and phrases to create variety and to
  highlight the change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8612-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are limitless possibilities for drum fills, but there are some patterns that
  are commonly used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8612-3
  a curric:KeyLearningPoint ;
  rdfs:label """A crash cymbal on beat one of the new section is an effective way to end a drum
  fill."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8612-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can add variation to our drum groove by using the ride cymbal, open hi-hats and
  varying the drum patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8612-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verse-chorus form is normally as follows: intro - verse - chorus - verse - chorus -
  middle 8 - chorus - outro"""@en ;
  dcterms:modified "2026-06-07T15:30:29.587073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8496-1
  a curric:KeyLearningPoint ;
  rdfs:label """The tempo and timbre that a songwriter chooses play an important role in the overall
  effect of a piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8496-2
  a curric:KeyLearningPoint ;
  rdfs:label "Timbre is a broad term which describes the sound quality of an instrument."@en ;
  dcterms:modified "2026-06-07T15:30:29.588540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8496-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a difference between acoustic and synthesized sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.588544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8496-4
  a curric:KeyLearningPoint ;
  rdfs:label """The groove used in this lesson has similarities with the simpler rock groove, but
  the overall effect contrasts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8496-5
  a curric:KeyLearningPoint ;
  rdfs:label """Learning to recreate a slightly more complex drum groove which is based on the
  features of a typical drum groove."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588553Z"^^xsd:dateTime .

