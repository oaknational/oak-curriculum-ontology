oakcurric:keyword-distortion
  a curric:Keyword ;
  schema:name "Distortion"@en ;
  schema:description "Distortion is a fuzzy effect often added to guitar sounds."@en ;
  dcterms:modified "2026-06-07T15:30:02.414283Z"^^xsd:dateTime .

oakcurric:keyword-middle-8
  a curric:Keyword ;
  schema:name "Middle 8"@en ;
  schema:description """The middle 8 is a section in a song that contrasts with the verse and the
  chorus. It is often 8 bars long."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414478Z"^^xsd:dateTime .

oakcurric:keyword-power-chord
  a curric:Keyword ;
  schema:name "Power chord"@en ;
  schema:description """A power chord is a two-note chord often used on guitars, which uses the root
  note and the fifth of a triad chord."""@en ;
  dcterms:modified "2026-06-07T15:30:02.414710Z"^^xsd:dateTime .

oakcurric:keyword-crash-cymbal
  a curric:Keyword ;
  schema:name "crash cymbal"@en ;
  schema:description "a medium to large size cymbal used for dramatic efffect on the drum kit"@en ;
  dcterms:modified "2026-06-07T15:30:02.414715Z"^^xsd:dateTime .

oakcurric:keyword-ride-cymbal
  a curric:Keyword ;
  schema:name "ride cymbal"@en ;
  schema:description """has a thin 'ringing' sound and is an alternative to the hi-hat in drum
  grooves"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414745Z"^^xsd:dateTime .

oakcurric:keyword-verse-chorus-form
  a curric:Keyword ;
  schema:name "verse-chorus form"@en ;
  schema:description """a common structure in popular music styles that is based around alternating
  verses and choruses"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414750Z"^^xsd:dateTime .

oakcurric:keyword-acoustic
  a curric:Keyword ;
  schema:name "acoustic"@en ;
  schema:description """an acoustic instrument produces sound naturally without any
  electronic input"""@en ;
  dcterms:modified "2026-06-07T15:30:02.415276Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-sense-pulse-sense-rhythm-same
  a curric:Misconception ;
  curric:statement "Sense of pulse and sense of rhythm are the same thing"@en ;
  curric:correction """A sense of pulse is understanding the underlying beat in the music. A sense
  of rhythm is understanding where the stress should be in a bar or rhythm. This is much
  more nuanced. At this point, encourage pupils to stress the downbeat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083724Z"^^xsd:dateTime .

oakcurric:misconception-rubato-use-expressive-performance
  a curric:Misconception ;
  curric:statement "The more rubato you use the more expressive the performance"@en ;
  curric:correction """Rubato affects the tempo and pulse of a piece so needs to be used with
  subtlety. Show various examples of how Fur Elise might be played by different performers
  so pupils can see the variety of ways rubato can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083867Z"^^xsd:dateTime .

oakcurric:misconception-related-keys-same-home-tonic
  a curric:Misconception ;
  curric:statement """Related keys are those with the same home (tonic) note such as C major and C
  minor."""@en ;
  curric:correction """Related keys are those with the same notes, but a different home (tonic
  note). Major and minor scales have different tone and semitone patterns, so they need to
  start three semitones apart for the notes to be the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083928Z"^^xsd:dateTime .

oakcurric:misconception-adjacent-white-notes-keyboard-tone
  a curric:Misconception ;
  curric:statement "Adjacent white notes on the keyboard are all a tone apart."@en ;
  curric:correction """Most of the adjacent white notes are a tone apart but because of the pattern
  of the black notes on the keyboard some of the adjacent white notes are also semitones.
  It's important for pupils to count the notes to work out an interval."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084239Z"^^xsd:dateTime .

oakcurric:misconception-accompaniment-patterns-section-section-b
  a curric:Misconception ;
  curric:statement """The accompaniment patterns for section A and section B are the same and the
  best way to practise is to play from the start to the end of the piece repeatedly."""@en ;
  curric:correction """The accompaniment pattern changes slightly in section B. Highlight the
  difference so pupils are sure of this when practising hands together. It's more efficient
  to identify and practise the difficult bars in isolation first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084301Z"^^xsd:dateTime .

oakcurric:misconception-refer-section-piece-music-relation
  a curric:Misconception ;
  curric:statement """When we refer to the A section of a piece of music (in relation to structure)
  they have to be exactly the same."""@en ;
  curric:correction """Letters are used to describe sections overall but quite often there are
  slight differences. Use some common examples of songs pupils will know of where sections
  might be labelled the same piece of music, but where there are small differences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084309Z"^^xsd:dateTime .

oakcurric:misconception-hand-positions-change-start-new
  a curric:Misconception ;
  curric:statement "Hand positions should only change at the start of new phrases."@en ;
  curric:correction """This depends entirely on what notes are used. Sometimes, like in Korobeiniki,
  it is more useful to change hand position during a phrase. When doing this, we should
  always practise making it seamless, so there is no obvious change in sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084315Z"^^xsd:dateTime .

oakcurric:misconception-folk-music-sounds-same
  a curric:Misconception ;
  curric:statement "Folk music all sounds the same."@en ;
  curric:correction """Many folk traditions have shared characteristics, primarily because of the
  way that the music was passed between generations, but folk music is incredibly diverse,
  and covers lots of different types of music from different cultures and times."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084321Z"^^xsd:dateTime .

oakcurric:misconception-folk-dances-folk-songs-different
  a curric:Misconception ;
  curric:statement "Folk dances and folk songs are different names for exactly the same thing."@en ;
  curric:correction """Not necessarily. Many folk songs are for storytelling or other purposes, not
  dancing. Some folk songs are designed for dancing, which often have different features,
  including an upbeat tempo, strong pulse and rhythmic drive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084327Z"^^xsd:dateTime .

oakcurric:misconception-dorian-mode-same-minor-scale
  a curric:Misconception ;
  curric:statement "The dorian mode is the same as a minor scale."@en ;
  curric:correction """There is a slight difference, with one different note. All of the modes are
  closely linked to major and minor scales, but have slightly different notes that help to
  create different moods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084333Z"^^xsd:dateTime .

oakcurric:misconception-fit-lyrics-melody
  a curric:Misconception ;
  curric:statement "You can fit any lyrics to a melody."@en ;
  curric:correction """Lyrics or melody often have to be adjusted to fit each other. This can be
  because there are too many or too few words to fit in a phrase, or there are too many or
  too few notes to fit with the words. Trial and error is the best way to address this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084341Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-means-notes-chosen-random
  a curric:Misconception ;
  curric:statement "Improvisation means the notes are chosen at random."@en ;
  curric:correction """Although improvising means making music up on the spot, it is based on a set
  of notes or scale and can use repetition. Improvisation often uses fixed stylistic
  characteristics such as particular rhythms, phrase structures and chord sequences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085018Z"^^xsd:dateTime .

oakcurric:misconception-balance-same-throughout-song
  a curric:Misconception ;
  curric:statement "The balance is the same throughout a song."@en ;
  curric:correction """The balance changes depending on the parts and texture. The melody line would
  usually be the most prominent part. In an accompaniment texture all parts are more likely
  to be equal. It's important to listen and be aware of the lead line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085902Z"^^xsd:dateTime .

oakcurric:misconception-different-voice-types-cannot-sing
  a curric:Misconception ;
  curric:statement "Different voice types cannot sing any of the same notes."@en ;
  curric:correction """The ranges of voices overlap, so there are some notes that can be sung by
  different voice types. For example, many notes that a bass can sing are also possible for
  tenor voices to sing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086383Z"^^xsd:dateTime .

oakcurric:misconception-composing-rhyhtm-means-creating-something
  a curric:Misconception ;
  curric:statement "Composing a rhyhtm means creating something totally original"@en ;
  curric:correction """Successful compositions often take some ideas from other pieces and do
  something new with it, so adapting rhythms from the drumming pieces you have already
  played is acceptable and can help in finding the right type of rhythms and the right
  style."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087292Z"^^xsd:dateTime .

oakcurric:misconception-diction-articulation-clear-pronunciation
  a curric:Misconception ;
  curric:statement "Diction (articulation) is just about clear pronunciation."@en ;
  curric:correction """Articulation is also connected to taking suitable singing breaths. If
  breathing is poorly controlled, consonants can sound weak or unclear, and vowels lose
  focus. Good breath support allows the voice to stay energised through quick or complex
  lyrics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087324Z"^^xsd:dateTime .

oakcurric:misconception-tall-vowels-mean-singing-louder
  a curric:Misconception ;
  curric:statement "Tall vowels mean singing louder or just opening the mouth really wide."@en ;
  curric:correction """Although they do help with projection, tall vowels are not about volume,
  they’re about the vertical space inside the mouth. If the mouth is too wide horizontally
  (grinning), this can tense the jaw, leading to a strained tone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087446Z"^^xsd:dateTime .

oakcurric:misconception-syncopation-makes-music-sound-energetic
  a curric:Misconception ;
  curric:statement "Syncopation always makes music sound more energetic and driving."@en ;
  curric:correction """Syncopation can make a piece feel laid back by relaxing the timing to give a
  'behind the beat' effect. Syncopated rhythms often leave gaps between sounds, which can
  make the groove feel more spacious and less rushed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088214Z"^^xsd:dateTime .

oakcurric:misconception-add-shape-melody-emphasis-first
  a curric:Misconception ;
  curric:statement """To add shape to a melody, the emphasis will always be on the first note of the
  phrase."""@en ;
  curric:correction """This is not always the case. Quite often, when the first note of the phrase
  lands on the downbeat this is naturally where the emphasis falls, however, this is more
  about where the main beats are rather than where the phrase starts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088373Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-listen-other-end-phrases
  a curric:Misconception ;
  curric:statement """Forgetting to listen to each other at the end of phrases and changing from one
  part to another."""@en ;
  curric:correction """Explain where pupils finish the longer notes together. They may pick a lot of
  this up from listening, but reinforce the importance of this in a powerful performance.
  Rehearse the changes from section to section to develop confidence in this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088620Z"^^xsd:dateTime .

oakcurric:misconception-good-balance-means-parts-same
  a curric:Misconception ;
  curric:statement "Good balance means the parts should be the same volume all the time."@en ;
  curric:correction """There is a nuance to balance and we always need to listen to other performers
  in the ensemble to check we can hear them and particularly hear the lead line. In Gumama
  all parts are of equal importance so the parts are a similar volume."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088628Z"^^xsd:dateTime .

oakcurric:misconception-pupils-take-big-breath-raise
  a curric:Misconception ;
  curric:statement "When pupils take a big breath, they raise their shoulders."@en ;
  curric:correction """A singing breath is from the diaphragm; the upper body and shoulders should
  remain relaxed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089035Z"^^xsd:dateTime .

oakcurric:misconception-human-voice-produce-one-note
  a curric:Misconception ;
  curric:statement "The human voice can only produce one note at a time."@en ;
  curric:correction """Every sound we make has multiple different notes, its just that the main note
  is much louder than the others. Think about when you have a croaky voice - it almost
  sounds like multiple notes, because it is! Multiphonics just amplify the quieter notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091298Z"^^xsd:dateTime .

oakcurric:misconception-backbeat-beat-same
  a curric:Misconception ;
  curric:statement "The backbeat and off-beat are the same."@en ;
  curric:correction """The backbeat is on beat 2 and 4 while the off-beat is on the second half of a
  beat (in between the beats)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091510Z"^^xsd:dateTime .

oakcurric:misconception-samples-non-musical-sounds
  a curric:Misconception ;
  curric:statement "Samples are always non-musical sounds."@en ;
  curric:correction """This is not true - a sample is any pre-existing sound that is used in a new
  way. This could be traditionally non-musical sounds like machinery or speech, or it could
  be clips of pieces of music or individual notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092360Z"^^xsd:dateTime .

oakcurric:misconception-mixing-dongo-doko-strikes-comfortably
  a curric:Misconception ;
  curric:statement """Mixing up the dongo and doko strikes and comfortably swapping from one to the
  other."""@en ;
  curric:correction """The dongo is a shuffle feel, whilst the doko and kara are even beats.
  Practise alternating from one to the other so pupils can recognise them easily and can
  comfortably swap from one to the other in a performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093629Z"^^xsd:dateTime .

oakcurric:misconception-tone-row-scale
  a curric:Misconception ;
  curric:statement "A tone row is just a scale."@en ;
  curric:correction """A tone row is different because it isn't just a set of notes to choose from,
  but a specific order. When you are composing something in C major, you can use the notes
  of the C major scale in any order. With a tone row, they have a specific order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094449Z"^^xsd:dateTime .

oakcurric:misconception-taiko-name-style
  a curric:Misconception ;
  curric:statement "Taiko is the name of the style."@en ;
  curric:correction """Taiko is Japanese for 'drum' and the drums make up kumi daiko which is
  ensemble drumming."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094493Z"^^xsd:dateTime .

oakcurric:misconception-retrograding-breaks-rules-serialism-because
  a curric:Misconception ;
  curric:statement """Retrograding breaks the rules of serialism because it changes the order of the
  notes."""@en ;
  curric:correction """Serialist composers don't consider retrograding breaking the rules. It does
  change the order, but the new order is still closely linked to the original tone row (by
  being reversed). It is therefore an acceptable and musically interesting technique."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094523Z"^^xsd:dateTime .

oakcurric:misconception-musical-instruments-voices-produce-pitched
  a curric:Misconception ;
  curric:statement "Only musical instruments (and voices) produce pitched sound."@en ;
  curric:correction """Pitched sounds are everywhere. In fact, most sounds have a pitch, it is often
  just hard to hear it. You can probably hear a pitched sound now if you listen closely -
  electrical buzzing, distant speech, weather or animals all produce subtle pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095872Z"^^xsd:dateTime .

oakcurric:misconception-elements-achieved-perfectly-order-produce
  a curric:Misconception ;
  curric:statement """All the elements have to be achieved perfectly in order to produce a
  successful taiko performance."""@en ;
  curric:correction """There is a lot to consider when putting the performance together. Focus on
  playing and moving together with repeated ideas to start with. Working as a team and
  getting the count in and stance right is important to support the rest of the performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095877Z"^^xsd:dateTime .

oakcurric:misconception-using-white-notes-c-major
  a curric:Misconception ;
  curric:statement "Using all the white notes is C major will sound cheerful"@en ;
  curric:correction """It's important that the home note (in this case C) is used appropriately to
  reinforce the notes sounding like they are in C major."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096800Z"^^xsd:dateTime .

oakcurric:misconception-use-given-rhythms
  a curric:Misconception ;
  curric:statement "You must use the given rhythms."@en ;
  curric:correction """The rhythms used are variations on traditional accompaniments that are passed
  down orally across generations. At this stage, any rhythm can be used as a starting point
  for getting pupils making music but this example covers the required techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098053Z"^^xsd:dateTime .

oakcurric:misconception-movements-shouts-related-pulse-rhythm
  a curric:Misconception ;
  curric:statement "The movements and shouts are not related to the pulse and rhythm."@en ;
  curric:correction """The movements and shouts, just like the drum strikes, are rhythmically
  important. Reinforce the pulse when teaching the movements, shouts and strikes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099079Z"^^xsd:dateTime .

oakcurric:misconception-adding-chords-bass-line-chord
  a curric:Misconception ;
  curric:statement """When adding chords to a bass line, the chord has to be the same as the note in
  the bass."""@en ;
  curric:correction """In most cases the bass note should be one of the notes in the chord, but
  doesn't always have to be the lowest note of the chord. For a balanced chord sequence most
  notes in the bass lines should be the root, but not all have to be."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108217Z"^^xsd:dateTime .

oakcurric:misconception-alberti-bass-notes-triad-played
  a curric:Misconception ;
  curric:statement "An Alberti bass is the notes of the triad played in any order."@en ;
  curric:correction """An Alberti bass has a specfic, distinctive pattern which uses the lowest
  note, highest note, middle note, highest note of the triad in that order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108469Z"^^xsd:dateTime .

oakcurric:misconception-one-iteration-tresillo-habanera-last
  a curric:Misconception ;
  curric:statement "One iteration of the tresillo and habanera has to last for two beats."@en ;
  curric:correction """The tresillo and habanera can be played in 2/4 or 4/4. The important thing is
  the relationship of the notes to each other. Practise clapping the rhythms twice as fast
  or slow to the same beat to help pupils grasp this concept."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108853Z"^^xsd:dateTime .

oakcurric:misconception-interval-3rd-three-tones-higher
  a curric:Misconception ;
  curric:statement "An interval of a 3rd is three tones higher or lower than the first note."@en ;
  curric:correction """In C major (where pupils are counting the white keys), they should count the
  starting note and final note, plus any in between. So an interval of a 3rd is actually two
  tones higher or lower than the first note. An octave would be seven notes higher."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109438Z"^^xsd:dateTime .

oakcurric:misconception-c-position-thumb-c-left
  a curric:Misconception ;
  curric:statement "C position is thumb on C in the left hand."@en ;
  curric:correction """The C position is when the hand is placed in a position to play C up to G.
  With the right hand, this would be the thumb on C, finger 2 on D etc. With the left hand,
  the C position is when the little finger is on C, finger 4 is on D etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110324Z"^^xsd:dateTime .

oakcurric:misconception-swapping-comfortably-accurately-one-rhythm
  a curric:Misconception ;
  curric:statement """Swapping comfortably and accurately from one rhythm to another with the
  overall structure."""@en ;
  curric:correction """This is quite tricky as the strucutre is complex. Break it down for pupils so
  they learn each section comfortably and encourage them to practise going from one rhythm
  to the next and think about strategies for remembering the rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110523Z"^^xsd:dateTime .

oakcurric:misconception-conductor-person-responsible-keeping-pulse
  a curric:Misconception ;
  curric:statement """The conductor is the only person responsible for keeping the pulse and pitch
  is only high and low."""@en ;
  curric:correction """The conductor can set the tempo but all performers are responsible for
  keeping the pulse in a performance. Pitch as high and low is slightly limiting. Help
  pupils make connections to other related words that they might know."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111773Z"^^xsd:dateTime .

oakcurric:misconception-pupils-start-playing-snare-because
  a curric:Misconception ;
  curric:statement """Pupils start playing on the snare because they are used to reading left to
  right."""@en ;
  curric:correction """Emphasise that the kick is the start because it is central within the drum
  kit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111839Z"^^xsd:dateTime .

oakcurric:misconception-description-thick-texture-relates-number
  a curric:Misconception ;
  curric:statement """The description thick texture relates to the number of people performing and
  loud dynamics."""@en ;
  curric:correction """Texture is more complex than thick/thin. Use good examples early on to show
  that texture is related to the different layers in the music and not neccesarily the
  number of performers. Show how lots of performers could be performing in a thin texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112077Z"^^xsd:dateTime .

oakcurric:misconception-toms-used-fills-use-snare
  a curric:Misconception ;
  curric:statement """Toms are only used in fills. Use of the snare/claps/clicks will automatically
  be a backbeat."""@en ;
  curric:correction """Toms can be used in the main groove just less commonly than the kick/snare.
  For a backbeat the snare/claps have to play on beats 2 and 4."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113071Z"^^xsd:dateTime .

oakcurric:misconception-play-open-hi-hat-way
  a curric:Misconception ;
  curric:statement """You can play an open hi-hat all the way through the bar or anywhere in the
  pattern."""@en ;
  curric:correction """The hi-hat can be played open at any point, but it shouldn't be overused, and
  stylistically it works well on the last quaver or off the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113196Z"^^xsd:dateTime .

oakcurric:misconception-note-precedes-strong-beat-upbeat
  a curric:Misconception ;
  curric:statement "Any note that precedes a strong beat is an upbeat."@en ;
  curric:correction """An upbeat sounds like it musically belongs to the strong beat. Find a good
  non-example in a melody or drum groove to show how an upbeat both precedes the strong beat
  and also creates emphasis, often due to following a rest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113223Z"^^xsd:dateTime .

oakcurric:misconception-drum-fills-complex-fundamental-groove
  a curric:Misconception ;
  curric:statement "Drum fills must be more complex than the fundamental groove."@en ;
  curric:correction """Show how absence of sound can be as powerful as added sound by giving an
  example of the groove briefly stopping."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113410Z"^^xsd:dateTime .

oakcurric:misconception-ground-bass-pattern-finish-tonic
  a curric:Misconception ;
  curric:statement "A ground bass pattern should finish on the tonic as it 'sounds' finished."@en ;
  curric:correction """The final bar of the piece should finish on the tonic note, but until that
  bar, the pattern wants to repeat. Finishing on the dominant or the leading note naturally
  helps the music return to the first note of the pattern, which should be the tonic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113525Z"^^xsd:dateTime .

oakcurric:misconception-lots-layers-music-playing-simultaneously
  a curric:Misconception ;
  curric:statement """Having lots of layers of music playing simultaneously is effective use of
  texture."""@en ;
  curric:correction """It is easy to create a texture that is too thick and too busy. Encourage
  students to experiment with both thin and thick textures and reiterate that adding too
  many layers simultaneously can make music sound ineffective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113825Z"^^xsd:dateTime .

oakcurric:misconception-everyone-write-good-melody
  a curric:Misconception ;
  curric:statement "Not everyone can write a good melody."@en ;
  curric:correction """Writing a melody is just like writing a paragraph. Break it into small chunks
  (phrases). If you are finding it difficult to create a phrase, keep it simple and start by
  just improvising using 2 or 3 notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113996Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-number-prompts-find
  a curric:Misconception ;
  curric:statement """Pupils may use the number prompts but not find the correct C position on the
  keyboard."""@en ;
  curric:correction """Reinforce the position of the note C on the keyboard and ensure the pupils
  are sitting to play comfortably in the C position."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114918Z"^^xsd:dateTime .

oakcurric:misconception-complicated-rhythms-sound-interesting
  a curric:Misconception ;
  curric:statement "Complicated rhythms will sound more interesting."@en ;
  curric:correction """Often creating simpler rhythms is more effective. In particular, rhythms that
  have rests (silence) in them can create a powerful contrast between sound and silence. Try
  using a mix of simple and complex rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115497Z"^^xsd:dateTime .

oakcurric:misconception-one-note-added-create-seventh
  a curric:Misconception ;
  curric:statement """There is only one note that can be added to create a seventh chord, and
  likewise for a sixth chord."""@en ;
  curric:correction """There are various different types of sixth and seventh chords, which have
  different rules about how to form them. Here we are just learning the general principle of
  forming extended chords."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116251Z"^^xsd:dateTime .

oakcurric:misconception-mistaking-f-another-note-c
  a curric:Misconception ;
  curric:statement """Mistaking F (or another note) for C and not understanding the impact this has
  on the finger prompts."""@en ;
  curric:correction """Reinforce 'C to the left of the two black keys', why F is a common mistake
  and the finger prompts only work if the C position is correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118058Z"^^xsd:dateTime .

oakcurric:misconception-music-films-recorded-played-speakers
  a curric:Misconception ;
  curric:statement "Music for films is always recorded and played through speakers."@en ;
  curric:correction """Before technology existed to do this, film music was played live by
  performers in the room. It would often be a solo piano/organ player, who would improvise
  along with the film. Sometimes, ensembles such as orchestras would play music live
  instead."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118154Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-another-note-f
  a curric:Misconception ;
  curric:statement """Pupils may mistake another note for F when changing position. Brass
  instruments can only be identified by pitch."""@en ;
  curric:correction """Reinforce that F is to the left of the three black keys; this has to be
  correct for the finger prompts to work. The ranges of the brass instruments overlap, so
  it's important to emphasise that the timbre of each instrument is slightly different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118857Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-pulse-music-same-thing
  a curric:Misconception ;
  curric:statement """Rhythm and pulse in music are the same thing (particularly as there are a lot
  of crotchets used)."""@en ;
  curric:correction """Pupils could clap/tap the beat with the audio examples to reinforce how it is
  different to the rhythm of the melody.."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122833Z"^^xsd:dateTime .

oakcurric:misconception-overdoing-emphasis-first-note-bar
  a curric:Misconception ;
  curric:statement """Overdoing the emphasis on the first note of the bar and the music becoming
  stilted."""@en ;
  curric:correction """Play the pupils a non-example where the first beat is so strong it becomes
  unmusical and follow this with a good example."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123420Z"^^xsd:dateTime .

oakcurric:misconception-tresillo-triplet-spanish-uses-three
  a curric:Misconception ;
  curric:statement "The tresillo ('triplet' in Spanish) uses three equally spaced notes."@en ;
  curric:correction """The notes in the tresillo rhythm are not equally spaced. The third note is a
  shorter duration. Counting the semiquavers in a 3-3-2 pattern can help us space the notes
  correctly (1-2-3, 1-2-3, 1-2)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124279Z"^^xsd:dateTime .

oakcurric:misconception-fixed-correct-finger-pattern-performing
  a curric:Misconception ;
  curric:statement """There is a fixed and correct finger pattern for performing keyboard
  pieces."""@en ;
  curric:correction """With pieces that require a dexterous hand postition change, there are often
  several options. Encourage pupils to find a comfortable solution. Show examples of good
  keyboard technique that allows them to perform more difficult melodies with control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124445Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-means-making-something-nothing
  a curric:Misconception ;
  curric:statement "Improvisation means making something up from nothing"@en ;
  curric:correction """You can use typical rhythms or features of the style as a basis oof any
  improvisation. This might mean using an establisehd idea such as a prepared triplet or
  syncopated rhtyhm and then extending the idea with something made up in the moment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125792Z"^^xsd:dateTime .

oakcurric:misconception-lots-automation-changes-make-dynamics
  a curric:Misconception ;
  curric:statement "Lots of automation changes make the dynamics effective."@en ;
  curric:correction """Doing lots of dynamic changes can sound chaotic and messy. Try to limit your
  use of automation so that changes are gradual and slowly change the dynamics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126600Z"^^xsd:dateTime .

oakcurric:misconception-parts-necessary-make-project-work
  a curric:Misconception ;
  curric:statement "All of the parts are necessary to make the project work."@en ;
  curric:correction """Ideally pupils will record in all of the parts of the batucada, but the
  project will still work successfully with the core ensemble of surdo, caixa and repinique."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130794Z"^^xsd:dateTime .

oakcurric:misconception-c-blues-scale-use-black
  a curric:Misconception ;
  curric:statement """The C blues scale can use any of the black notes (flattened notes) on the
  keyboard."""@en ;
  curric:correction """The blues scale uses specific flattened notes - 3rd, 5th and 7th. It's
  important for pupils to practise finding these notes and getting used to how the scale
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130996Z"^^xsd:dateTime .

oakcurric:misconception-change-3rd-6th-scale-change
  a curric:Misconception ;
  curric:statement """You can only change the 3rd or the 6th of the scale to change the mood of the
  music."""@en ;
  curric:correction """In the lesson task any suitable chromatic movement can be used to change the
  feel of the motif, so pupils don't explicitly have to change the 3rd and the 6th. Play a
  range of motifs in the major key and change different notes so pupils can see this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131841Z"^^xsd:dateTime .

oakcurric:misconception-notes-work-improvising
  a curric:Misconception ;
  curric:statement "Any notes will work for improvising"@en ;
  curric:correction """Find the balance between developing confidence in improvising and quality of
  musical ideas. Encourage pupils to think about the choice of notes, repetition, returning
  to a main note etc, as well as trying ideas and reflecting on what they sound like."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132793Z"^^xsd:dateTime .

oakcurric:misconception-note-boogie-woogie-pattern-rise
  a curric:Misconception ;
  curric:statement "Any note of the boogie-woogie pattern can rise and fall."@en ;
  curric:correction """Whilst there are different variations of boogie-woogie, it is important that
  pupils keep the root the same and the 5th of the chord rises and falls."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133695Z"^^xsd:dateTime .

oakcurric:misconception-solo-section-made-moment
  a curric:Misconception ;
  curric:statement "The solo section has to be made up in the moment."@en ;
  curric:correction """The solo section can use ideas that are already planned. This is a good
  starting point for adding solos to build confidence and then build up to doing improvised
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137088Z"^^xsd:dateTime .

oakcurric:misconception-instruments-fixed-role-drums-drive
  a curric:Misconception ;
  curric:statement """All instruments have a fixed role and only the drums drive the music
  forward."""@en ;
  curric:correction """The guitar and piano can be melodic as well as accompanying. Different
  instruments can drive the music forward, and all players in the ensemble are responsible
  for this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137096Z"^^xsd:dateTime .

oakcurric:misconception-bass-line-different-rhythm-chords
  a curric:Misconception ;
  curric:statement """The bass line must have a different rhythm from the chords and percussion
  parts."""@en ;
  curric:correction """It can be appropriate for the bass line to use the same rhythm as another
  part. If it sounds effective then it is fine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142757Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-includes-quavers-syncopated
  a curric:Misconception ;
  curric:statement "If a rhythm includes quavers it is syncopated."@en ;
  curric:correction """This is a common misconception when first learning syncopation. Reiterate
  that a rhythm is only syncopated if the emphasis is in between the main beats. In practice
  here, that means that there will be a quaver rest at the start of a beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143877Z"^^xsd:dateTime .

oakcurric:misconception-adjusting-eq-dynamics-musically-beneficial
  a curric:Misconception ;
  curric:statement "Adjusting EQ and/or dynamics is always musically beneficial."@en ;
  curric:correction """Encourage students to use the DAW tools sparingly and reinforce the point
  that these tools are effective but that it is possible to overuse them. The analogy of
  seasoning on a meal - too much can spoil the meal - can be an effective one to use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147535Z"^^xsd:dateTime .

oakcurric:misconception-pupils-misinterpret-score-think-accompaniment
  a curric:Misconception ;
  curric:statement """Pupils misinterpret the score and think the accompaniment is the second line
  of the melody."""@en ;
  curric:correction """Encourage pupils to follow the score through when listening to the music and
  reinforce that both lines are part of the same system."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147663Z"^^xsd:dateTime .

oakcurric:misconception-rights-wrongs-improvisation
  a curric:Misconception ;
  curric:statement "There are 'rights' or 'wrongs' in improvisation."@en ;
  curric:correction """While there are rules that help us improvise effectively, a big part of
  learning to improvise is experimenting and seeing what works and what doesn't. Be willing
  to make 'mistakes' and don't fixate on doing it perfectly first time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148015Z"^^xsd:dateTime .

oakcurric:misconception-mistaking-another-note-f-changing
  a curric:Misconception ;
  curric:statement """Mistaking another note for F when changing position quickly. The timpani are
  untuned percussion because they are drums."""@en ;
  curric:correction """Reinforce that F is to the left of the three black keys. Highlight that the
  timpani are tuned to specific pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149575Z"^^xsd:dateTime .

oakcurric:misconception-using-same-rhythm-different-ostinati
  a curric:Misconception ;
  curric:statement "Using the same rhythm in different ostinati creates effective contrast."@en ;
  curric:correction """Using different rhythms in your ostinati is important for creating contrast.
  If they use the same rhythm, they will inevitably sound very similar. Try coming up with
  some interesting rhythm by clapping, then play them using notes on the keyboard."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149704Z"^^xsd:dateTime .

oakcurric:misconception-hands-change-position-same-time
  a curric:Misconception ;
  curric:statement "Both hands change position at the same time"@en ;
  curric:correction """Highlight to pupils that the left hand remains in the C position even though
  the right hand moves to the F position and back again."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149710Z"^^xsd:dateTime .

oakcurric:misconception-accompaniment-part-semibreves-throughout
  a curric:Misconception ;
  curric:statement "The accompaniment part is semibreves throughout."@en ;
  curric:correction """Two bars of the accompaniment is in minims. Encourage pupils to practise this
  bar specifically on its own when putting both hands/parts together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149903Z"^^xsd:dateTime .

oakcurric:misconception-pentatonic-scale-limited-one-octave
  a curric:Misconception ;
  curric:statement "The pentatonic scale is limited to one octave on the instrument."@en ;
  curric:correction """The pentatonic scale is just the names of the notes that we can use. You can
  use them as high-pitched notes or low-pitched notes on your instrument. Experiment with
  playing the scale up high and down low."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150096Z"^^xsd:dateTime .

oakcurric:misconception-playing-sequence-incorrectly-particularly-missing
  a curric:Misconception ;
  curric:statement """Playing the sequence incorrectly, particularly missing the final F in the
  sequence."""@en ;
  curric:correction """Encourage pupils to learn the chord structure from memory and to think in
  4-bar phrases. Highlight the last phrase specifically which has two chord changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151310Z"^^xsd:dateTime .

oakcurric:misconception-soundtrack-music-way
  a curric:Misconception ;
  curric:statement "A soundtrack should have music all the way through."@en ;
  curric:correction """Careful use of silence can heighten the tension and help to emphasise the
  dialogue. There is a balance and silence can be used sparingly to elevate other parts of
  the music and the story, particularly after a musical build up."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151325Z"^^xsd:dateTime .

oakcurric:misconception-diminished-seventh-chord-like-other
  a curric:Misconception ;
  curric:statement """A diminished seventh chord is just like any other extended chord - a triad
  with added notes."""@en ;
  curric:correction """A diminished seventh chord is quite unique as every interval is the same size
  (three semitones). It is different from extended chords that add notes to a triad. It has
  been used for centuries as a tense, dramatic chord, including in silent movies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151363Z"^^xsd:dateTime .

oakcurric:misconception-certain-timbres-used-certain-effects
  a curric:Misconception ;
  curric:statement "Certain timbres can only be used for certain effects."@en ;
  curric:correction """Some timbres are particularly well suited to certain moods or effects but
  this doesn't mean that other timbres can't be used for different effects. It can also
  depend on the other musical features used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151407Z"^^xsd:dateTime .

oakcurric:misconception-leitmotif-film-theme-same-thing
  a curric:Misconception ;
  curric:statement "A leitmotif and a film theme are the same thing."@en ;
  curric:correction """Not quite. Many films have themes that represent the overall mood, and can be
  heard throughout the film. The difference with a leitmotif is that it explicitly
  represents one thing - a character, place or an idea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151488Z"^^xsd:dateTime .

oakcurric:misconception-pitch-notes-work-composition
  a curric:Misconception ;
  curric:statement "Any pitch and notes can work in a composition."@en ;
  curric:correction """Encourage pupils to think about the choice of notes in their musical ideas
  and listen to how it sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151559Z"^^xsd:dateTime .

oakcurric:misconception-simply-changing-instrument-makes-leitmotif
  a curric:Misconception ;
  curric:statement "Simply changing the instrument makes a leitmotif change mood."@en ;
  curric:correction """While it does have an impact, changing other elements can make this even
  greater. Harmony, rhythm, dynamics, articulation and tempo are particularly useful for
  motivic transformation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151671Z"^^xsd:dateTime .

oakcurric:misconception-sections-musical-structure-repeated-section
  a curric:Misconception ;
  curric:statement """The A sections in a musical structure which has a repeated A section have to
  be the same."""@en ;
  curric:correction """Strong musical ideas usually have a balance of unity and variety, so even
  when a section is repeated, providing the main melodic idea is recognisable there can be
  some small changes which then helps to find this balance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151738Z"^^xsd:dateTime .

oakcurric:misconception-sea-shanties-songs-pirates
  a curric:Misconception ;
  curric:statement "Sea shanties are songs for pirates."@en ;
  curric:correction """Many cultures based around the sea use songs to coordinate movement on boats.
  Sea shanties are one example of this, and were sung by many, including sailors and
  fishermen. Other traditional cultures had their own songs for this purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151855Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-definitive-version-kuku-rhythm
  a curric:Misconception ;
  curric:statement "The rhythm is the definitive version of the Kuku rhythm."@en ;
  curric:correction """There are different versions of this piece from both Guinea and the Ivory
  Coast. There are also local versions within each of these. This version is a guide and can
  be adapted to suit your local context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151934Z"^^xsd:dateTime .

oakcurric:misconception-drum-grooves-exactly-same-rhythms
  a curric:Misconception ;
  curric:statement """All drum grooves have exactly the same rhythms in the kick, snare and
  hi-hat."""@en ;
  curric:correction """Many typical drum grooves do have the same features or features very close to
  this, however encourage pupils to identify where there are subtle differences and how the
  kick, snare and hi-hat patterns can be varied within these features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153376Z"^^xsd:dateTime .

oakcurric:misconception-string-instruments-identified-pitch-woodwind
  a curric:Misconception ;
  curric:statement """The string instruments can only be identified by pitch. The woodwind
  instruments are made of wood."""@en ;
  curric:correction """The pitch of the instruments does overlap slightly, so it's important to
  emphasise that the timbre of each instrument is slightly different. Most woodwind
  instruments were originally made of wood but the flute and the saxophone are now made of
  metal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153551Z"^^xsd:dateTime .

oakcurric:misconception-piano-player-plays-music-silent
  a curric:Misconception ;
  curric:statement """When a piano player plays music with a silent movie it is always completely
  improvised."""@en ;
  curric:correction """While they improvise many aspects, they often use specific musical ideas to
  create specific effects. This includes vamps, certain chords (e.g. diminished 7th for
  tension) and musical clichés like the misterioso that create certain effects."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153652Z"^^xsd:dateTime .

oakcurric:misconception-highly-skilled-naturally-gifted-musicians
  a curric:Misconception ;
  curric:statement """Only highly skilled and naturally gifted musicians can work out music
  by ear."""@en ;
  curric:correction """Anyone can work out music by ear. It just takes practice and is made easier
  through use of effective strategies, including working out rhythm and pitch separately,
  and identifying individual pitches through trial and error."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153664Z"^^xsd:dateTime .

oakcurric:misconception-synthesisers-effective-melodic-lines
  a curric:Misconception ;
  curric:statement "Synthesisers are most effective for melodic lines."@en ;
  curric:correction """Different types of synthesiser suit different musical roles. While synth
  leads are very effective for melodic lines, synth pads are well-suited to playing
  accompaniments, particularly sustained notes and chords."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153851Z"^^xsd:dateTime .

oakcurric:misconception-bass-parts-normally-simple-play
  a curric:Misconception ;
  curric:statement """Bass parts are normally simple and just play the lowest notes from the
  chords."""@en ;
  curric:correction """In some cases this is true, but in many cases bass lines are interesting
  patterns and can often be defining features of songs. This is true for both Under Pressure
  and Feel Good Inc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153885Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-metronome-matches-rhythms
  a curric:Misconception ;
  curric:statement """Pupils think the metronome matches the rhythms they play, since they
  previously played crotchets."""@en ;
  curric:correction """Pupils should play a metronome beat while the class claps quavers to
  highlight the metronome shows the pulse by clicking on the beats of the bar."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153905Z"^^xsd:dateTime .

oakcurric:misconception-develop-composition-around-element-music
  a curric:Misconception ;
  curric:statement "We can develop a composition around any element of music."@en ;
  curric:correction """Using the elements of music, particularly individually, is not always helpful
  for pupils to make a start on a composition. Finding a musical starting point such as a
  set of notes or rhythm allows pupils to then explore the elements through that idea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154140Z"^^xsd:dateTime .

oakcurric:misconception-melodic-idea-repeats-hook
  a curric:Misconception ;
  curric:statement "Any melodic idea that repeats is a hook."@en ;
  curric:correction """It's a bit more complex than that. In some cases, whether something is a hook
  or not could be a matter of opinion, not necessarily true or false. A hook must be short,
  memorable, and repeated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154154Z"^^xsd:dateTime .

oakcurric:misconception-sense-style-music-refers-genre
  a curric:Misconception ;
  curric:statement "A sense of style in music refers only to the genre."@en ;
  curric:correction """Style can mean genre-specific features but also can refer to compositional
  style and the composer using common features throughout a particular piece."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154239Z"^^xsd:dateTime .

oakcurric:misconception-interesting-developed-dembow-beat-complex
  a curric:Misconception ;
  curric:statement "An interesting, developed dembow beat should be complex."@en ;
  curric:correction """Often keeping things simple is more effective than complexity. Choose one or
  two of the suggested ways of developing your drum beat, rather than trying to add
  everything in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154515Z"^^xsd:dateTime .

oakcurric:misconception-important-constantly-create-variety-change
  a curric:Misconception ;
  curric:statement "It is important to constantly create variety and change in a composition."@en ;
  curric:correction """We have to balance variety and repetition. Too much variety makes a piece
  sound messy and incoherent, too much repetition and it becomes boring. Try to find a happy
  medium between repeating ideas and varying things (e.g. the texture)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154634Z"^^xsd:dateTime .

oakcurric:misconception-singing-melody-possible-strong-singer
  a curric:Misconception ;
  curric:statement "Singing a melody is only possible if you are a very strong singer."@en ;
  curric:correction """Everyone can sing, but keeping to a small range of notes can help when
  building confidence with singing. Singing helps us to internalise the notes and really
  'feel' the melody. Melodies can sound much more natural when sung."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154778Z"^^xsd:dateTime .

oakcurric:misconception-rock-specific-narrow-genre-itself
  a curric:Misconception ;
  curric:statement "Rock is a specific, narrow genre in itself."@en ;
  curric:correction """Rock is a very broad term for lots of different musical genres, spanning a
  wide range of influences and using very different musical features. There are many
  sub-genres of rock, including grunge, punk rock and heavy metal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154797Z"^^xsd:dateTime .

oakcurric:misconception-harmonic-rhythm-means-rhythm-chord
  a curric:Misconception ;
  curric:statement "Harmonic rhythm means the rhythm that each chord plays."@en ;
  curric:correction """Harmonic rhythm means how often the chords change, not the actual rhythm that
  the chords play. Show examples of the same harmonic rhythm different rhythms in the
  chords. Changing the harmonic rhythm is a useful tool to alter the feel of music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154971Z"^^xsd:dateTime .

oakcurric:misconception-power-chords-two-notes-chord
  a curric:Misconception ;
  curric:statement "Power chords are any two notes of the chord triad."@en ;
  curric:correction """For a chord to be a power chord it has to be the root and the fifth, not the
  root and the third. It also needs to be a perfect fifth. If pupils are working out their
  own power chords on the keyboard, some chords would use the black notes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155268Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-record-their-new
  a curric:Misconception ;
  curric:statement """Pupils try to record their new ideas into one of the pitched instrument
  tracks."""@en ;
  curric:correction "Demonstrate this error before they have time to improvise new ideas."@en ;
  dcterms:modified "2026-06-07T15:30:15.155274Z"^^xsd:dateTime .

oakcurric:misconception-drum-fills-complex-use-lots
  a curric:Misconception ;
  curric:statement """Drum fills have to be complex and use lots of different parts of the drum kit.
  The tom-toms can be played in any order."""@en ;
  curric:correction """Drum fills can be effective using only one or two parts of the kit, such as
  the snare and kick. The key is that they have a distinct rhythm that separates them from
  the main drum groove. When using the toms, they should be played from high to low."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155294Z"^^xsd:dateTime .

oakcurric:misconception-misunderstanding-meaning-acoustic-because-lesson
  a curric:Misconception ;
  curric:statement """Misunderstanding the meaning of acoustic because the lesson examples are
  played on an iPad/computer."""@en ;
  curric:correction "Make it clear that the iPad/computer is imitating acoustic sound."@en ;
  dcterms:modified "2026-06-07T15:30:15.155826Z"^^xsd:dateTime .
