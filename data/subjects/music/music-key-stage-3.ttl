  dcterms:modified "2026-06-07T15:30:02.402427Z"^^xsd:dateTime .

oakcurric:keyword-synth-bass
  a curric:Keyword ;
  schema:name "synth bass"@en ;
  schema:description "A synth bass is a low-pitched synthesizer."@en ;
  dcterms:modified "2026-06-07T15:30:02.407785Z"^^xsd:dateTime .

oakcurric:keyword-riser
  a curric:Keyword ;
