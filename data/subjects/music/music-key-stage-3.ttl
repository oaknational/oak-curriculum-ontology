oakcurric:priorknowledge-995-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience changing hand position fluently"@en ;
  dcterms:modified "2026-06-07T15:29:23.050174Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to find natural and sharp notes on the treble clef and play them on
  the keyboard"""@en ;
  dcterms:modified "2026-06-07T15:29:23.050221Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience play a melody with hand position changes kept in time"@en ;
  dcterms:modified "2026-06-07T15:29:23.050232Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the term chord and can play triads"@en ;
  dcterms:modified "2026-06-07T15:29:23.050238Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the rhythmic values minims, crotchets and quavers and that they can be
  dotted"""@en ;
  dcterms:modified "2026-06-07T15:29:23.050244Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that melodies can be major or minor and how this sounds"@en ;
  dcterms:modified "2026-06-07T15:29:23.050258Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the music is built in phrases"@en ;
  dcterms:modified "2026-06-07T15:29:23.050263Z"^^xsd:dateTime .

oakcurric:priorknowledge-995-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience keeping time and shaping phrases"@en ;
  dcterms:modified "2026-06-07T15:29:23.050268Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have been introduced to the notation C to C and crotchets, minims, semibreves
  and dotted rhythms"""@en ;
  dcterms:modified "2026-06-07T15:29:23.356489Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand of the concepts tempo, dynamics, pitch and rhythm"@en ;
  dcterms:modified "2026-06-07T15:29:23.356500Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can find the C position on the keyboard"@en ;
  dcterms:modified "2026-06-07T15:29:23.356506Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of finding patterns in music to help them learn a piece"@en ;
  dcterms:modified "2026-06-07T15:29:23.356511Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils may have experience of putting a melody and accompaniment together in pairs
  or with two hands"""@en ;
  dcterms:modified "2026-06-07T15:29:23.356515Z"^^xsd:dateTime .

oakcurric:priorknowledge-3802-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of singing in unison and in simple harmony"@en ;
  dcterms:modified "2026-06-07T15:29:23.356520Z"^^xsd:dateTime .

oakcurric:priorknowledge-1008-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can play a melody on the keyboard in the C and F position"@en ;
  dcterms:modified "2026-06-07T15:29:23.613143Z"^^xsd:dateTime .

oakcurric:priorknowledge-1008-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can play a melody with a simple left hand part"@en ;
  dcterms:modified "2026-06-07T15:29:23.613166Z"^^xsd:dateTime .

oakcurric:priorknowledge-1008-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that music is built with scales including the pentatonic scale"@en ;
  dcterms:modified "2026-06-07T15:29:23.613176Z"^^xsd:dateTime .

oakcurric:priorknowledge-1008-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience improvising around the pentatonic scale"@en ;
  dcterms:modified "2026-06-07T15:29:23.613185Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of singing in unison textures"@en ;
  dcterms:modified "2026-06-07T15:29:23.844059Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of singing in homophonic textures"@en ;
  dcterms:modified "2026-06-07T15:29:23.844072Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand why and how to prepare and warm up the body for singing including
  taking a good singing breath"""@en ;
  dcterms:modified "2026-06-07T15:29:23.844078Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have been encouraged to use tall vowels and vocal onset"@en ;
  dcterms:modified "2026-06-07T15:29:23.844084Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experience of performing in an extended structure such as a pop song
  with three different sections"""@en ;
  dcterms:modified "2026-06-07T15:29:23.844089Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have performed songs which use syncopation and understand that this
  emphasises notes between the main beats"""@en ;
  dcterms:modified "2026-06-07T15:29:23.844094Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have performed songs using dynamics and emphasis within the phrase to add
  expression"""@en ;
  dcterms:modified "2026-06-07T15:29:23.844099Z"^^xsd:dateTime .

oakcurric:priorknowledge-3867-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are aware that balance involves listening to all the parts in the ensemble
