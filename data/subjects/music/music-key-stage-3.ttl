  dcterms:modified "2026-06-07T15:30:02.410127Z"^^xsd:dateTime .

oakcurric:keyword-untuned
  a curric:Keyword ;
  schema:name "untuned"@en ;
  schema:description "instruments that only play sounds without clear pitch"@en ;
  dcterms:modified "2026-06-07T15:30:02.410133Z"^^xsd:dateTime .

oakcurric:keyword-dm-pentatonic-scale
  a curric:Keyword ;
  schema:name "Dm pentatonic scale"@en ;
  schema:description "The Dm (D minor) pentatonic scale includes the notes D, F, G, A and C."@en ;
  dcterms:modified "2026-06-07T15:30:02.410520Z"^^xsd:dateTime .

oakcurric:keyword-opera
