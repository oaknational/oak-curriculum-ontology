  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-conjunct
  a curric:Keyword ;
  schema:name "Conjunct"@en ;
  schema:description "movement between notes based on small intervals (steps)"@en ;
  dcterms:modified "2026-06-07T15:30:02.348137Z"^^xsd:dateTime .

oakcurric:keyword-phrase
  a curric:Keyword ;
  schema:name "Phrase"@en ;
  schema:description "a short section of a melody, often lasting 1, 2 or 4 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.348142Z"^^xsd:dateTime .

oakcurric:keyword-diction
  a curric:Keyword ;
  schema:name "diction"@en ;
  schema:description "pronouncing words clearly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348214Z"^^xsd:dateTime .

oakcurric:keyword-minor-scale
  a curric:Keyword ;
  schema:name "minor scale"@en ;
  schema:description """a set of notes where the 3rd and 6th notes in the scale are flattened, and
  that sound sad or more solemn than a major scale"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348633Z"^^xsd:dateTime .

oakcurric:keyword-sharp
  a curric:Keyword ;
  schema:name "sharp"@en ;
  schema:description """the sharp symbol (#) is used to show that a note has been raised by a
  semitone"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348638Z"^^xsd:dateTime .

oakcurric:keyword-natural
  a curric:Keyword ;
  schema:name "natural"@en ;
  schema:description """the natural symbol is used to show a note in the bar has returned to the
  normal pitch"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348642Z"^^xsd:dateTime .

oakcurric:keyword-chromatic
  a curric:Keyword ;
  schema:name "chromatic"@en ;
  schema:description "a note that is not part of the key or scale"@en ;
  dcterms:modified "2026-06-07T15:30:02.348649Z"^^xsd:dateTime .

oakcurric:keyword-build-up
  a curric:Keyword ;
  schema:name "build-up"@en ;
  schema:description "the part of a narrative where problems are introduced and tension rises"@en ;
  dcterms:modified "2026-06-07T15:30:02.348708Z"^^xsd:dateTime .

oakcurric:keyword-accent
  a curric:Keyword ;
  schema:name "accent"@en ;
  schema:description "an emphasis on a note"@en ;
  dcterms:modified "2026-06-07T15:30:02.348784Z"^^xsd:dateTime .

oakcurric:keyword-piano
  a curric:Keyword ;
  schema:name "piano"@en ;
  schema:description "a dynamic instruction meaning to play quietly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348788Z"^^xsd:dateTime .

oakcurric:keyword-forte
  a curric:Keyword ;
  schema:name "forte"@en ;
  schema:description "a dynamic instruction meaning to play loudly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348793Z"^^xsd:dateTime .

oakcurric:keyword-crescendo
  a curric:Keyword ;
  schema:name "crescendo"@en ;
  schema:description "gradually getting louder"@en ;
  dcterms:modified "2026-06-07T15:30:02.348797Z"^^xsd:dateTime .

oakcurric:keyword-fifth
  a curric:Keyword ;
  schema:name "fifth"@en ;
  schema:description "the fifth note of the scale and the top note in a chord triad"@en ;
  dcterms:modified "2026-06-07T15:30:02.348802Z"^^xsd:dateTime .

oakcurric:keyword-chromatic-movement
  a curric:Keyword ;
  schema:name "chromatic movement"@en ;
  schema:description "using notes outside of the normal (major or minor) key"@en ;
  dcterms:modified "2026-06-07T15:30:02.348811Z"^^xsd:dateTime .

oakcurric:keyword-staccato
  a curric:Keyword ;
  schema:name "staccato"@en ;
  schema:description "when the notes are played in a detached manner"@en ;
  dcterms:modified "2026-06-07T15:30:02.348816Z"^^xsd:dateTime .

oakcurric:keyword-accidental
  a curric:Keyword ;
  schema:name "accidental"@en ;
  schema:description """a sign in music notation which shows that the note is sharp, flat or
  natural."""@en ;
  dcterms:modified "2026-06-07T15:30:02.348821Z"^^xsd:dateTime .

oakcurric:keyword-dotted-crotchet
  a curric:Keyword ;
  schema:name "dotted crotchet"@en ;
  schema:description "a note that lasts for one and half beats"@en ;
  dcterms:modified "2026-06-07T15:30:02.348825Z"^^xsd:dateTime .

oakcurric:keyword-repeat-mark
  a curric:Keyword ;
  schema:name "repeat mark"@en ;
  schema:description """a symbol at the end (and also often start) of a section that tells the
  performer to repeat it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348830Z"^^xsd:dateTime .

oakcurric:keyword-folk-music
  a curric:Keyword ;
  schema:name "folk music"@en ;
  schema:description """the traditional music of a culture that is passed down through
  generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348834Z"^^xsd:dateTime .

oakcurric:keyword-pentatonic-scale
  a curric:Keyword ;
  schema:name "pentatonic scale"@en ;
  schema:description "a common scale in folk music, consisting of five different notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348841Z"^^xsd:dateTime .

oakcurric:keyword-accompaniment
  a curric:Keyword ;
  schema:name "accompaniment"@en ;
  schema:description "a part in the music that supports the melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.348848Z"^^xsd:dateTime .

oakcurric:keyword-semibreve
  a curric:Keyword ;
  schema:name "semibreve"@en ;
  schema:description "a note that lasts for four beats"@en ;
  dcterms:modified "2026-06-07T15:30:02.348858Z"^^xsd:dateTime .

oakcurric:keyword-crotchet
  a curric:Keyword ;
  schema:name "crotchet"@en ;
  schema:description "a note that lasts for one beat"@en ;
  dcterms:modified "2026-06-07T15:30:02.348863Z"^^xsd:dateTime .

oakcurric:keyword-rhythmic-drive
  a curric:Keyword ;
  schema:name "rhythmic drive"@en ;
  schema:description "a feeling of energy created by rhythms"@en ;
  dcterms:modified "2026-06-07T15:30:02.348867Z"^^xsd:dateTime .

oakcurric:keyword-mode
  a curric:Keyword ;
  schema:name "mode"@en ;
  schema:description "a type of scale, of which there are seven main types"@en ;
  dcterms:modified "2026-06-07T15:30:02.348872Z"^^xsd:dateTime .

oakcurric:keyword-dorian-mode
  a curric:Keyword ;
  schema:name "dorian mode"@en ;
  schema:description """a mode that sounds similar to a minor scale; the D dorian mode uses the
  white notes starting on D"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348877Z"^^xsd:dateTime .

oakcurric:keyword-strophic
  a curric:Keyword ;
  schema:name "strophic"@en ;
  schema:description "a structure based on repeating verses, with variation in the lyrics"@en ;
  dcterms:modified "2026-06-07T15:30:02.348881Z"^^xsd:dateTime .

oakcurric:keyword-sea-shanty
  a curric:Keyword ;
  schema:name "sea shanty"@en ;
  schema:description """a folk song traditionally sung by sailors to help them coordinate their
  movements"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348886Z"^^xsd:dateTime .

oakcurric:keyword-g-major-pentatonic-scale
  a curric:Keyword ;
  schema:name "G major pentatonic scale"@en ;
  schema:description "a pentatonic scale consisting of the notes G, A, B, D and E"@en ;
  dcterms:modified "2026-06-07T15:30:02.348893Z"^^xsd:dateTime .

oakcurric:keyword-abac-structure
  a curric:Keyword ;
  schema:name "ABAC structure"@en ;
  schema:description """structure in music is how the different phrases or sections of music are
  organised; ABAC is three different sections of music (A B and C), with the first section
  (A) repeated after the B section"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348898Z"^^xsd:dateTime .

oakcurric:keyword-fluency
  a curric:Keyword ;
  schema:name "fluency"@en ;
  schema:description "how smooth and natural speech your speech sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.349047Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-baroque
  a curric:Keyword ;
  schema:name "Baroque"@en ;
  schema:description "a period of music history between 1600 and 1750"@en ;
  dcterms:modified "2026-06-07T15:30:02.349100Z"^^xsd:dateTime .

oakcurric:keyword-tonality
  a curric:Keyword ;
  schema:name "tonality"@en ;
  schema:description """the type of notes and chords that a piece of music is based on (e.g. minor,
  major, atonal)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349998Z"^^xsd:dateTime .

oakcurric:keyword-improvisation
  a curric:Keyword ;
  schema:name "improvisation"@en ;
  schema:description "a section of music where the melodic ideas are made up on the spot"@en ;
  dcterms:modified "2026-06-07T15:30:02.350779Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
  flow of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351040Z"^^xsd:dateTime .

oakcurric:keyword-expression
  a curric:Keyword ;
  schema:name "expression"@en ;
  schema:description "reading with feelings and emotion to bring the poem to life"@en ;
  dcterms:modified "2026-06-07T15:30:02.351044Z"^^xsd:dateTime .

oakcurric:keyword-solo
  a curric:Keyword ;
  schema:name "solo"@en ;
  schema:description """a performance by one instrument; sometimes compositions for an instrument
  with a piano accompaniment are also called a solo"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351505Z"^^xsd:dateTime .

oakcurric:keyword-atonal
  a curric:Keyword ;
  schema:name "atonal"@en ;
  schema:description "music which has no key or tonic note"@en ;
  dcterms:modified "2026-06-07T15:30:02.351808Z"^^xsd:dateTime .

oakcurric:keyword-ostinato
  a curric:Keyword ;
  schema:name "ostinato"@en ;
  schema:description "a short, repeating musical idea (plural: ostinati)"@en ;
  dcterms:modified "2026-06-07T15:30:02.351831Z"^^xsd:dateTime .

oakcurric:keyword-chord-sequence
  a curric:Keyword ;
  schema:name "chord sequence"@en ;
  schema:description "a pattern of chords that usually lasts for 4, 8 or 16 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.352154Z"^^xsd:dateTime .

oakcurric:keyword-syncopation
  a curric:Keyword ;
  schema:name "syncopation"@en ;
  schema:description """a rhythm which emphasises (accents) notes in between the main beats, often
  referred to as off-beat rhythms"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352158Z"^^xsd:dateTime .

oakcurric:keyword-programme-music
  a curric:Keyword ;
  schema:name "programme music"@en ;
  schema:description "music that tells a story or creates an image of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.352387Z"^^xsd:dateTime .

oakcurric:keyword-leitmotif
  a curric:Keyword ;
  schema:name "leitmotif"@en ;
  schema:description "a short musical idea that represents a character, place or idea"@en ;
  dcterms:modified "2026-06-07T15:30:02.352392Z"^^xsd:dateTime .

oakcurric:keyword-melody-and-accompaniment
  a curric:Keyword ;
  schema:name "melody and accompaniment"@en ;
  schema:description "a texture consisting of a melody with a clearly separate accompaniment"@en ;
  dcterms:modified "2026-06-07T15:30:02.352405Z"^^xsd:dateTime .

oakcurric:keyword-balance
  a curric:Keyword ;
  schema:name "balance"@en ;
  schema:description "keeping a steady and stable body position"@en ;
  dcterms:modified "2026-06-07T15:30:02.352576Z"^^xsd:dateTime .

oakcurric:keyword-dynamics
  a curric:Keyword ;
  schema:name "dynamics"@en ;
  schema:description "the speed and force of an action"@en ;
  dcterms:modified "2026-06-07T15:30:02.352729Z"^^xsd:dateTime .

oakcurric:keyword-dissonance
  a curric:Keyword ;
  schema:name "dissonance"@en ;
  schema:description "where notes in a chord clash, creating harmonic tension"@en ;
  dcterms:modified "2026-06-07T15:30:02.353260Z"^^xsd:dateTime .

oakcurric:keyword-consonance
  a curric:Keyword ;
  schema:name "consonance"@en ;
  schema:description "where notes in a chord sound pleasant together, without tension"@en ;
  dcterms:modified "2026-06-07T15:30:02.353264Z"^^xsd:dateTime .

oakcurric:keyword-satb-choir
  a curric:Keyword ;
  schema:name "SATB choir"@en ;
  schema:description """a vocal ensemble consisting of four voice types - soprano, alto, tenor and
  bass"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353269Z"^^xsd:dateTime .

oakcurric:keyword-tonal
  a curric:Keyword ;
  schema:name "tonal"@en ;
  schema:description "music that has a tonic note (the opposite of atonal)"@en ;
  dcterms:modified "2026-06-07T15:30:02.353275Z"^^xsd:dateTime .

oakcurric:keyword-unison
  a curric:Keyword ;
  schema:name "unison"@en ;
  schema:description "performing the same movement at exactly the same time as our partner"@en ;
  dcterms:modified "2026-06-07T15:30:02.353983Z"^^xsd:dateTime .

oakcurric:keyword-syncopated
  a curric:Keyword ;
  schema:name "Syncopated"@en ;
  schema:description """a rhythm that emphasises (accents) notes in between the main beats; this is
  often created by using half-beat rests on the beat or dotted rhythms"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354439Z"^^xsd:dateTime .

oakcurric:keyword-compound-time
  a curric:Keyword ;
  schema:name "Compound time"@en ;
  schema:description """Compound time is when each beat is divided into three quavers, rather than
  two (e.g. a 12/8 time signature)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354451Z"^^xsd:dateTime .

oakcurric:keyword-orchestra
  a curric:Keyword ;
  schema:name "orchestra"@en ;
  schema:description """a large ensemble that is central to the Western Classical Tradition,
  consisting of strings, woodwind, brass and percussion instruments"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354567Z"^^xsd:dateTime .

oakcurric:keyword-strings
  a curric:Keyword ;
  schema:name "strings"@en ;
  schema:description """instruments with strings that are normally played with a bow, including the
  violin, viola, cello and double bass"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354574Z"^^xsd:dateTime .

oakcurric:keyword-woodwind
  a curric:Keyword ;
  schema:name "woodwind"@en ;
  schema:description """instruments that produce sound through blown air, including the flute,
  clarinet, oboe and bassoon"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354581Z"^^xsd:dateTime .

oakcurric:keyword-brass
  a curric:Keyword ;
  schema:name "brass"@en ;
  schema:description """metal instruments with valves or slides that produce sound with air,
  including the trumpet, trombone, French horn and tuba"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354585Z"^^xsd:dateTime .

oakcurric:keyword-percussion
  a curric:Keyword ;
  schema:name "percussion"@en ;
  schema:description """instruments that produce sound by being struck or hit, including drums,
  cymbals, xylophones and many others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354590Z"^^xsd:dateTime .

oakcurric:keyword-ensemble
  a curric:Keyword ;
  schema:name "ensemble"@en ;
  schema:description "a group of people who perform together"@en ;
  dcterms:modified "2026-06-07T15:30:02.354860Z"^^xsd:dateTime .

oakcurric:keyword-44
  a curric:Keyword ;
  schema:name "4/4"@en ;
  schema:description "a time signature with four beats in a bar"@en ;
  dcterms:modified "2026-06-07T15:30:02.355035Z"^^xsd:dateTime .

oakcurric:keyword-128
  a curric:Keyword ;
  schema:name "12/8"@en ;
  schema:description """a time signature with twelve quavers in a bar; these are in four groups of
  three"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355040Z"^^xsd:dateTime .

oakcurric:keyword-pedal
  a curric:Keyword ;
  schema:name "pedal"@en ;
  schema:description """a continuous pitch or note in the music which remains the same as the other
  harmonies change"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355112Z"^^xsd:dateTime .

oakcurric:keyword-musical-shape
  a curric:Keyword ;
  schema:name "musical shape"@en ;
  schema:description """how we use dynamics and stresses within the phrase to give a sense of
  direction to a performance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355116Z"^^xsd:dateTime .

oakcurric:keyword-kick
  a curric:Keyword ;
  schema:name "kick"@en ;
  schema:description "striking or propelling a ball or another object with the foot"@en ;
  dcterms:modified "2026-06-07T15:30:02.355174Z"^^xsd:dateTime .

oakcurric:keyword-tall-vowels
  a curric:Keyword ;
  schema:name "tall vowels"@en ;
  schema:description "vowels that are sung with an open, vertical mouth shape"@en ;
  dcterms:modified "2026-06-07T15:30:02.355251Z"^^xsd:dateTime .

oakcurric:keyword-pulse
  a curric:Keyword ;
  schema:name "pulse"@en ;
  schema:description "the steady feel of the beat"@en ;
  dcterms:modified "2026-06-07T15:30:02.355256Z"^^xsd:dateTime .

oakcurric:keyword-score
  a curric:Keyword ;
  schema:name "score"@en ;
  schema:description "the points gained in a game or an activity"@en ;
  dcterms:modified "2026-06-07T15:30:02.355407Z"^^xsd:dateTime .

oakcurric:keyword-pitch
  a curric:Keyword ;
  schema:name "pitch"@en ;
  schema:description "how high or low a note is"@en ;
  dcterms:modified "2026-06-07T15:30:02.356597Z"^^xsd:dateTime .

oakcurric:keyword-stave
  a curric:Keyword ;
  schema:name "stave"@en ;
  schema:description "lines on which notes can be placed"@en ;
  dcterms:modified "2026-06-07T15:30:02.356608Z"^^xsd:dateTime .

oakcurric:keyword-homophony
  a curric:Keyword ;
  schema:name "homophony"@en ;
  schema:description "two or more different layers which move at the same time (in harmony)"@en ;
  dcterms:modified "2026-06-07T15:30:02.357236Z"^^xsd:dateTime .

oakcurric:keyword-verse-chorus-structure
  a curric:Keyword ;
  schema:name "verse chorus structure"@en ;
  schema:description "a structure used in pop music with two main sections (verse and chorus)"@en ;
  dcterms:modified "2026-06-07T15:30:02.357241Z"^^xsd:dateTime .

oakcurric:keyword-backbeat
  a curric:Keyword ;
  schema:name "backbeat"@en ;
  schema:description """a backbeat is the emphasis of beats 2 and 4, usually on the snare of the
  drum kit, providing the drive in a piece of pop music"""@en ;
  dcterms:modified "2026-06-07T15:30:02.357248Z"^^xsd:dateTime .

oakcurric:keyword-triplet
  a curric:Keyword ;
  schema:name "triplet"@en ;
  schema:description "three notes performed in a beat where normally two would be played"@en ;
  dcterms:modified "2026-06-07T15:30:02.357656Z"^^xsd:dateTime .

oakcurric:keyword-third
  a curric:Keyword ;
  schema:name "third"@en ;
  schema:description """an interval of three notes. When both notes are performed together, the
  harmony would be described as ‘3rds’"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358123Z"^^xsd:dateTime .

oakcurric:keyword-breath-control
  a curric:Keyword ;
  schema:name "breath control"@en ;
  schema:description """managing airflow to sustain the phrases. This starts with taking a good
  singing breath"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358128Z"^^xsd:dateTime .

oakcurric:keyword-tempo
  a curric:Keyword ;
  schema:name "tempo"@en ;
  schema:description "how fast or slow the music is played"@en ;
  dcterms:modified "2026-06-07T15:30:02.358536Z"^^xsd:dateTime .

oakcurric:keyword-synth-lead
  a curric:Keyword ;
  schema:name "synth lead"@en ;
  schema:description "a type of synthesised sound that is suited to playing melodies"@en ;
  dcterms:modified "2026-06-07T15:30:02.359688Z"^^xsd:dateTime .

oakcurric:keyword-synth-pad
  a curric:Keyword ;
  schema:name "synth pad"@en ;
  schema:description "a type of synthesised sound that is suited to playing sustained sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.359693Z"^^xsd:dateTime .

oakcurric:keyword-tresillo
  a curric:Keyword ;
  schema:name "tresillo"@en ;
