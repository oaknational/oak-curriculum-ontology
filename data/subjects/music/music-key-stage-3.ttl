  schema:description """an upbeat style of blues music and the name of the piano accompaniment
  pattern used in boogie-woogie"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400978Z"^^xsd:dateTime .

oakcurric:keyword-tremolo
  a curric:Keyword ;
  schema:name "tremolo"@en ;
  schema:description "alternating between two notes rapidly; sounds like a trembling effect"@en ;
  dcterms:modified "2026-06-07T15:30:02.400983Z"^^xsd:dateTime .

oakcurric:keyword-chauffement
  a curric:Keyword ;
  schema:name "échauffement"@en ;
  schema:description "a phrase that is used to build to the climax of a piece"@en ;
