  dcterms:modified "2026-06-07T15:30:41.102284Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20545
  a curric:PupilLessonOutcome ;
  rdfs:label """I can name some different places where children may sing together and can
