oakcurric:keyword-soliloquy-musical-theatre
  a curric:Keyword ;
  schema:name "soliloquy (musical theatre)"@en ;
  schema:description "a character sharing their thoughts and feelings with the audience"@en ;
  dcterms:modified "2026-06-07T15:30:02.411446Z"^^xsd:dateTime .

oakcurric:keyword-civil-rights
  a curric:Keyword ;
  schema:name "civil rights"@en ;
  schema:description """rules that make sure everyone in society is treated fairly, no matter who
  they are"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411782Z"^^xsd:dateTime .

oakcurric:keyword-chanting
  a curric:Keyword ;
  schema:name "chanting"@en ;
  schema:description """speaking in time to a pulse - in this case saying or singing the same words
  over and over, often to show support or share a message"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411787Z"^^xsd:dateTime .

oakcurric:keyword-rap
  a curric:Keyword ;
  schema:name "rap"@en ;
  schema:description "rhythmical speech, often over a musical accompaniment"@en ;
  dcterms:modified "2026-06-07T15:30:02.412144Z"^^xsd:dateTime .

oakcurric:keyword-beat-poetry
  a curric:Keyword ;
  schema:name "beat poetry"@en ;
  schema:description """an artistic movement that started in the 1950s influenced by the free
  improvisation styles in jazz"""@en ;
  dcterms:modified "2026-06-07T15:30:02.412149Z"^^xsd:dateTime .

oakcurric:keyword-saptak
  a curric:Keyword ;
  schema:name "saptak"@en ;
  schema:description "the seven notes in Indian classical music - Sa, Re, Ga, ma, Pa, Dha, Ni"@en ;
  dcterms:modified "2026-06-07T15:30:02.413047Z"^^xsd:dateTime .

oakcurric:keyword-3-time
  a curric:Keyword ;
  schema:name "3-time"@en ;
  schema:description "the organisation and feel of the beats as strong-weak-weak"@en ;
  dcterms:modified "2026-06-07T15:30:02.413551Z"^^xsd:dateTime .

oakcurric:keyword-rounds
  a curric:Keyword ;
  schema:name "rounds"@en ;
  schema:description """a singing structure in which a melody is sung in groups, with each group
  starting at regular intervals, to create texture"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413767Z"^^xsd:dateTime .

oakcurric:keyword-thinking-voice
  a curric:Keyword ;
  schema:name "thinking voice"@en ;
  schema:description "singing music inside your head, rather than out loud"@en ;
  dcterms:modified "2026-06-07T15:30:02.414581Z"^^xsd:dateTime .

oakcurric:keyword-bar-lines
  a curric:Keyword ;
  schema:name "bar lines"@en ;
  schema:description """vertical lines on a stave that show how the music is organised into groups
  of strong and weak beats"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414704Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-playing-piece-music-numerous-times
  a curric:Misconception ;
  curric:statement "Playing a piece of music numerous times will improve the performance."@en ;
  curric:correction """Playing sections of a piece multiple times will only improve a performance if
  a small part is focused on and improvements are considered and rehearsed effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087172Z"^^xsd:dateTime .

oakcurric:misconception-beat-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Beat and rhythm are the same thing."@en ;
  curric:correction """The beat is the playing or showing of the steady pulse, while the the rhythm
  is a pattern of sounds we play or sing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089657Z"^^xsd:dateTime .

oakcurric:misconception-performing-parts-children-try-block
  a curric:Misconception ;
  curric:statement """When performing in parts children often try to block out listening to the
  other parts and focus only on their own."""@en ;
  curric:correction """Children will gain in confidence when they listen to all the parts and will
  improve their performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092905Z"^^xsd:dateTime .

oakcurric:misconception-beatboxing-really-difficult
  a curric:Misconception ;
  curric:statement "Beatboxing is really difficult."@en ;
  curric:correction """Beatboxing is just using your voice and sense of rhythm to mimic sounds.
  Humans mimic sounds all the time and this is just an extension of that."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093022Z"^^xsd:dateTime .

oakcurric:misconception-once-play-rhythms-melodies-correctly
  a curric:Misconception ;
  curric:statement """Once we can play the rhythms and melodies correctly, there is nothing else we
  need to do to prepare for a performance."""@en ;
  curric:correction """We can think about a range of ways to make the music more expressive, for
  example, adding dynamics to make our music have more impact for an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094796Z"^^xsd:dateTime .

oakcurric:misconception-dont-read-music-fluently-theres
  a curric:Misconception ;
  curric:statement """If we don't read music fluently, there's no point in looking at the written
  music of a song. We should just use the lyrics."""@en ;
  curric:correction """We can build on our understanding of pitch by identifying 'melodic shapes' or
  'melodic contours' in the music. We can also find clues in the music to help us know how
  to sing each part of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095117Z"^^xsd:dateTime .

oakcurric:misconception-musical-fusion-refers-one-type
  a curric:Misconception ;
  curric:statement """Musical fusion only refers to one type of blending of musical styles for
  example jazz and rock."""@en ;
  curric:correction """Fusion is a broad genre of music characterized by the creative integration of
  any two or more distinct styles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095244Z"^^xsd:dateTime .

oakcurric:misconception-fusion-refers-blending-two-contemporary
  a curric:Misconception ;
  curric:statement "Fusion only refers to the blending of two contemporary styles of music."@en ;
  curric:correction "Fusion is the blending of any two or more styles of music."@en ;
  dcterms:modified "2026-06-07T15:30:15.095407Z"^^xsd:dateTime .

oakcurric:misconception-fusion-music-less-authentic-valuable
  a curric:Misconception ;
  curric:statement "Fusion music is less authentic or valuable than traditional genres."@en ;
  curric:correction """Fusion music is in itself innovative and musically complex and is recognised
  as a genre in its own right."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095413Z"^^xsd:dateTime .

oakcurric:misconception-fusion-music-requires-specific-identifiable
  a curric:Misconception ;
  curric:statement """Fusion music always requires specific, identifiable elements from each
  original style."""@en ;
  curric:correction """The fusion of styles can be so integrated that the original influences become
  indistinguishable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095621Z"^^xsd:dateTime .

oakcurric:misconception-music-other-parts-world-traditional
  a curric:Misconception ;
  curric:statement """Music from other parts of the world is 'traditional' and remains
  unchanged."""@en ;
  curric:correction """All music changes over time as different musicians shape it with their own
  creativity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095809Z"^^xsd:dateTime .

oakcurric:misconception-make-mistake-performance-start-again
  a curric:Misconception ;
  curric:statement "If we make a mistake in a performance we should start again."@en ;
  curric:correction """When performing in front of an audience it's best to carry on if we make a
  mistake. Most of the time the audience won't notice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095825Z"^^xsd:dateTime .

oakcurric:misconception-playing-layers-ostinati-ignore-other
  a curric:Misconception ;
  curric:statement """When playing layers of ostinati we have to ignore the other parts in order to
  focus on playing our own layer accurately."""@en ;
  curric:correction """When performing layers of ostinati, it is important that each group is aware
  of how their part fits into the whole. Layers should work together, ensuring they are
  keeping a steady pulse and that the start of their musical sentences align."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096746Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-grid-notation-shows-one
  a curric:Misconception ;
  curric:statement "Rhythm grid notation only shows one instruction - play and rest."@en ;
  curric:correction """Rhythm grid notation can give many instructions, including which instrument
  to play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097821Z"^^xsd:dateTime .

oakcurric:misconception-warming-fun-dont-need-warm
  a curric:Misconception ;
  curric:statement """Warming up is fun, but we don’t need to warm up every time we practise our
  singing."""@en ;
  curric:correction """Warming-up is really important to prevent our voice from injury. It also
  helps to improve many of our music skills."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097852Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-pulse-same
  a curric:Misconception ;
  curric:statement "Rhythm and pulse are the same."@en ;
  curric:correction """Pulse is the regular, steady heartbeat of the music as opposed to rhythm
  which is the pattern of sounds that we play and sing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097872Z"^^xsd:dateTime .

oakcurric:misconception-make-mistake-performing-stop-start
  a curric:Misconception ;
  curric:statement """If we make a mistake when performing we should always stop and start
  again."""@en ;
  curric:correction """While you might sometimes need to start again, it's good practice to try and
  find your place and carry on if you make a mistake when performing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097880Z"^^xsd:dateTime .

oakcurric:misconception-composing-choosing-wide-variety-complicated
  a curric:Misconception ;
  curric:statement """When composing, choosing a wide variety of complicated rhythms is more
  exciting than using simpler ones."""@en ;
  curric:correction """When starting composing it's often good to use mostly simpler rhythms, and to
  make use of repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097953Z"^^xsd:dateTime .

oakcurric:misconception-ta-di-ta-mi-same
  a curric:Misconception ;
  curric:statement "Ta-di and Ta-mi are the same because they both have two notes in one beat."@en ;
  curric:correction """With the Ta-di rhythm both notes divide the beat equally in half. With Ta-mi,
  the notes are not distributed equally - the first is longer (¾ of a beat) and the second
  is shorter (¼ of a beat)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097959Z"^^xsd:dateTime .

oakcurric:misconception-composing-make-melody-interesting-complicated
  a curric:Misconception ;
  curric:statement """When composing, to make a melody interesting, it should be complicated with
  lots of different notes."""@en ;
  curric:correction """A simple melody with lots of repetition and stepwise movement often makes a
  more memorable melody."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098003Z"^^xsd:dateTime .

oakcurric:misconception-singing-two-songs-together-same
  a curric:Misconception ;
  curric:statement """Singing two songs together or the same song at different times will clash and
  not sound harmonious."""@en ;
  curric:correction """Partner songs and rounds have melodies that fit together harmoniously, and
  the parts are sung following the same steady beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098026Z"^^xsd:dateTime .

oakcurric:misconception-need-worry-my-own-part
  a curric:Misconception ;
  curric:statement "I only need to worry about my own part in an ensemble."@en ;
  curric:correction """It is important to be able to play your own part confidently in an ensemble
  but it is also important to understand how your part fits in with the rest of the
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098076Z"^^xsd:dateTime .

oakcurric:misconception-embellishing-theme-create-variation-makes
  a curric:Misconception ;
  curric:statement "Embellishing a theme to create a variation makes a totally new composition"@en ;
  curric:correction """Although each variation is different, each is based on the initial theme, and
  pupils will be able to recognise aspects of the original theme."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098087Z"^^xsd:dateTime .

oakcurric:misconception-warm-singing
  a curric:Misconception ;
  curric:statement "We only warm up for singing."@en ;
  curric:correction """Warming up can also help us prepare for playing instruments, using our bodies
  and working together in an ensemble. This helps us to focus, develops our sense of pulse
  and improves our coordination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098093Z"^^xsd:dateTime .

oakcurric:misconception-rhythmic-ostinato-same-rhythm-words
  a curric:Misconception ;
  curric:statement "A rhythmic ostinato is the same as the rhythm of the words."@en ;
  curric:correction """We can make an ostinato using the rhythms of the words but often the ostinato
  has a different rhythm. It can be tricky to play an ostinato and sing a different rhythm!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.098098Z"^^xsd:dateTime .

oakcurric:misconception-improvising-music-created-solely-spot
  a curric:Misconception ;
  curric:statement "Improvising is music created solely on the spot."@en ;
  curric:correction """Musicians might not know exactly what they are going to do, but they are
  building on and working from a bank of known ideas and motifs that they can draw upon, use
  and adapt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098281Z"^^xsd:dateTime .

oakcurric:misconception-reading-notation-effective-way-learning
  a curric:Misconception ;
  curric:statement "Reading notation is the most effective way of learning a melody."@en ;
  curric:correction """If the song has been well established, pupils may not even need notation.
  They will have learnt through singing, pitch actions, chanting rhythms and hand signs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098302Z"^^xsd:dateTime .

oakcurric:misconception-cells-minimalist-music-new-ideas
  a curric:Misconception ;
  curric:statement "Cells in minimalist music are all new ideas and are not connected."@en ;
  curric:correction """Even music that can feel 'random' is often born from a single idea. For an
  effective minimalist piece, use cells that relate in rhythm or melody."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098350Z"^^xsd:dateTime .

oakcurric:misconception-notes-stave-written-like-dots
  a curric:Misconception ;
  curric:statement """The notes on the stave can be written like dots on the line or inbetween the
  lines."""@en ;
  curric:correction """It is important that the size of the notes matches the size of the stave.
  This makes the notation easier to read."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098430Z"^^xsd:dateTime .

oakcurric:misconception-major-pentatonic-scale-comes-simplified
  a curric:Misconception ;
  curric:statement """The major pentatonic scale comes from a simplified version of the major
  (heptatonic) scale."""@en ;
  curric:correction """The major pentatonic scale comes from ancient civilisations and is not a
  simplified form of the heptatonic scale. Pentatonic music, in its various forms, is found
  in folk music from all around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098482Z"^^xsd:dateTime .

oakcurric:misconception-notes-short-duration-means-music
  a curric:Misconception ;
  curric:statement "Notes of short duration means the music is a really fast tempo."@en ;
  curric:correction """The pulse and beat sets the tempo. It doesn't matter how many sounds fit into
  the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098488Z"^^xsd:dateTime .

oakcurric:misconception-play-one-ostinato-time
  a curric:Misconception ;
  curric:statement "We can only play one ostinato at a time."@en ;
  curric:correction """We can have two or more groups playing two or more ostinati that can fit
  together when played to a steady pulse. By playing rhythms on instruments with different
  timbres, and adding tuned percussion, we change the sound and thickness of the texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098504Z"^^xsd:dateTime .

oakcurric:misconception-sound-rhythm-beat
  a curric:Misconception ;
  curric:statement "Each sound in a rhythm is a beat."@en ;
  curric:correction """Rhythm is the pattern of sounds and silences of differing durations. Rhythmic
  notes can have a duration of one beat, more than one beat, or less than one beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098518Z"^^xsd:dateTime .

oakcurric:misconception-takadi-ta-dimi-same-thing
  a curric:Misconception ;
  curric:statement "Takadi and Ta-dimi are the same thing."@en ;
  curric:correction "Takadi is quick-quick-slow. Ta-dimi is slow-quick-quick."@en ;
  dcterms:modified "2026-06-07T15:30:15.098600Z"^^xsd:dateTime .

oakcurric:misconception-minimalism-structure
  a curric:Misconception ;
  curric:statement "Minimalism has no structure."@en ;
  curric:correction """Minimalist music does have structure, but this might be on a micro level. It
  employs repetition of cells - a cyclical structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098689Z"^^xsd:dateTime .

oakcurric:misconception-using-one-note-harmony-sound
  a curric:Misconception ;
  curric:statement "Using just one note as a harmony would sound boring"@en ;
  curric:correction """Using a drone as part of a Hindustani classical performance adds an
  effective, meaningful and symbolic layer to the music"""@en ;
  dcterms:modified "2026-06-07T15:30:15.099579Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-complicated-hard
  a curric:Misconception ;
  curric:statement "Improvisation is complicated and hard to do."@en ;
  curric:correction """Using fewer notes and focusing on creating short improvisations can be very
  effective and help us to introduce the idea of conveying emotion through our music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101200Z"^^xsd:dateTime .

oakcurric:misconception-raag-played-sitar
  a curric:Misconception ;
  curric:statement "A raag can only be played on a sitar."@en ;
  curric:correction """Raags can be sung too. They can also be played on other instruments. Common
  instruments used in Hindustani classical music include harmonium, flute, bansuri and
  sarod. In the classroom, a largely accessible instrument is a glockenspiel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101222Z"^^xsd:dateTime .

oakcurric:misconception-taal-raag-begin-end-same
  a curric:Misconception ;
  curric:statement "The taal and raag begin and end at the same time."@en ;
  curric:correction "A raag can start and end at any point in the rhythm cycle."@en ;
  dcterms:modified "2026-06-07T15:30:15.101509Z"^^xsd:dateTime .

oakcurric:misconception-practising-rehearsing-same-thing
  a curric:Misconception ;
  curric:statement "Practising and rehearsing are the same thing."@en ;
  curric:correction """Practising is taking the time to learn your own part, focusing on the parts
  you need to improve. Rehearsing is the bringing together of parts, to prepare for a
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102151Z"^^xsd:dateTime .

oakcurric:misconception-ensemble-performance-one-part-usually
  a curric:Misconception ;
  curric:statement """In an ensemble performance, one part, usually the melody, is the most
  important part."""@en ;
  curric:correction """In an ensemble performance each part is crucial. Each part adds something
  different to the final performance such as harmony, melody or rhythmic foundation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103521Z"^^xsd:dateTime .

oakcurric:misconception-complicated-rhythms-use-compose-better
  a curric:Misconception ;
  curric:statement """The more complicated rhythms we use when we compose, the better our music will
  sound."""@en ;
  curric:correction "Successful music is repetitive, playable and memorable!"@en ;
  dcterms:modified "2026-06-07T15:30:15.103582Z"^^xsd:dateTime .

oakcurric:misconception-changing-tonality-major-minor-automatically
  a curric:Misconception ;
  curric:statement """Changing the tonality from major to minor will automatically make the music
  sound sad."""@en ;
  curric:correction """This is an oversimplification. All of the musical elements work together to
  create the character or mood of a piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103988Z"^^xsd:dateTime .

oakcurric:misconception-theme-variations-same-theme-music
  a curric:Misconception ;
  curric:statement "Theme and variations is the same as theme music."@en ;
  curric:correction """Theme music is a musical composition which is often written specifically for
  video games, or films and is usually played at the beginning, end and at some point during
  the course of the game or film."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104024Z"^^xsd:dateTime .

oakcurric:misconception-rhythms-shorter-duration-notes-means
  a curric:Misconception ;
  curric:statement "Rhythms with shorter duration notes means the music is faster."@en ;
  curric:correction """The speed of music is determined by the tempo. A complicated rhythm with
  shorter notes can be played at a fast or slow tempo"""@en ;
  dcterms:modified "2026-06-07T15:30:15.104061Z"^^xsd:dateTime .

oakcurric:misconception-theme-variation-structure-applies-orchestral
  a curric:Misconception ;
  curric:statement "Theme and variation structure only applies to orchestral music."@en ;
  curric:correction "A musical structure can apply to any style of music."@en ;
  dcterms:modified "2026-06-07T15:30:15.104088Z"^^xsd:dateTime .

oakcurric:misconception-major-songs-happy-minor-songs
  a curric:Misconception ;
  curric:statement "All major songs are happy. All minor songs are sad."@en ;
  curric:correction """This is an oversimplification. All of the musical elements work together to
  create the character or mood of a piece of music. The context in which a piece is heard
  will also impact our emotional response to it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104181Z"^^xsd:dateTime .

oakcurric:misconception-playground-singing-games-such-clapping
  a curric:Misconception ;
  curric:statement """Playground singing games (such as clapping games) are only played in my
  school/schools in the UK."""@en ;
  curric:correction """Playground singing games (including clapping games) are shared in playground
  communities from all over the world. For example, this unit includes playground singing
  games from the UK, Ghana, Finland, Japan and USA."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104357Z"^^xsd:dateTime .

oakcurric:misconception-common-try-play-songs-quickly
  a curric:Misconception ;
  curric:statement """It is common to try and play songs too quickly when learning them on an
  instrument."""@en ;
  curric:correction """It's always better to start slowly and at a steady tempo, then gradually
  build up speed when feeling confident."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104603Z"^^xsd:dateTime .

oakcurric:misconception-singing-football-matches-simply-entertainment
  a curric:Misconception ;
  curric:statement """Singing at football matches is simply for entertainment at the games. It
  doesn't have any real significance or importance."""@en ;
  curric:correction """The earliest football chants recorded date back to the 1920s. Singing
  together has always been an important part of the human experience. Singing helps us to
  celebrate, express belief in our team and connect with each other. It is very important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104747Z"^^xsd:dateTime .

oakcurric:misconception-blocking-sound-other-song-help
  a curric:Misconception ;
  curric:statement """Blocking out the sound of the other song will help you concentrate on your own
  part better."""@en ;
  curric:correction """By singing more softly, we can hear the other parts and hear how partner
  songs fit together. This is because they share similar musical characteristics such as the
  key, the rhythm, the tempo and chord progression."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104763Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-music-completely-made-spot
  a curric:Misconception ;
  curric:statement "Improvisation is music completely made up on the spot."@en ;
  curric:correction """Improvised music is not completely made up on the spot. Preparation and the
  practising of musical ideas is important. It is more a form of spontaneous reconstruction
  of musical ideas built upon knowledge and practice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104769Z"^^xsd:dateTime .

oakcurric:misconception-syncopated-rhythms-really-difficult
  a curric:Misconception ;
  curric:statement "Syncopated rhythms are really difficult."@en ;
  curric:correction """Syncopated rhythms can be simple rhythms, but the emphasis on the offbeat can
  create an interesting, but not necessarily difficult, sound to recreate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104833Z"^^xsd:dateTime .

oakcurric:misconception-improvised-music-structure
  a curric:Misconception ;
  curric:statement "Improvised music has no structure."@en ;
  curric:correction """Jazz pieces are heavily structured around chord sequences, the head and order
  of improvisatons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104953Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-music-done-instruments-voice
  a curric:Misconception ;
  curric:statement "Improvisation in music is only done on instruments and not the voice."@en ;
  curric:correction """Scat singing, from jazz music is one type of vocal improvisation. Other types
  include the sargams of Hindustani and Carnatic music from India, freestyle rap, even
  yodelling!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.105122Z"^^xsd:dateTime .

oakcurric:misconception-syncopation-means-playing-emphasising-weak
  a curric:Misconception ;
  curric:statement """Syncopation means only playing on (or emphasising) the ‘weak beats’ as in
  emphasising the 2nd and 4th beat of a 4-beat bar, instead of the 1st and 3rd."""@en ;
  curric:correction """Whilst emphasising the ‘2’ and the ‘4’ is common in pop music (often called
  backbeat) we can also create syncopation by holding notes, missing beats, and playing what
  is called ‘offbeat syncopation’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105128Z"^^xsd:dateTime .

oakcurric:misconception-musical-piece-performance-unchangeable
  a curric:Misconception ;
  curric:statement "A musical piece or performance is unchangeable."@en ;
  curric:correction """There can be many interpretations of a piece of music, even if certain
  directions are suggested by the composer. As the composers of your own minimalist piece,
  anything is changeable and each performance may also be different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105134Z"^^xsd:dateTime .

oakcurric:misconception-singing-two-songs-together-clash
  a curric:Misconception ;
  curric:statement "Singing two songs together will clash and not sound harmonious."@en ;
  curric:correction """Partner songs are made of notes that sound good together. The songs are
  partnered up because they fit harmoniously and can be sung following the same steady beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105167Z"^^xsd:dateTime .

oakcurric:misconception-musical-genres-rules-follow-styles
  a curric:Misconception ;
  curric:statement """Musical genres have rules to follow, and styles never mix or borrow ideas from
  each other."""@en ;
  curric:correction """Like the rainbow, music is a continuing spectrum of ideas, with genres of
  blending and merging into each other, borrowing, sharing and adapting key features and
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105201Z"^^xsd:dateTime .

oakcurric:misconception-weve-rehearsed-our-songs-dont
  a curric:Misconception ;
  curric:statement "If we've rehearsed our songs, we don't need to warm up for a performance."@en ;
  curric:correction """Warming up for a performance encourages everyone to feel engaged, connected
  and alert as well as supporting a good quality of vocal sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105218Z"^^xsd:dateTime .

oakcurric:misconception-count-four-music
  a curric:Misconception ;
  curric:statement "We always count to four in music."@en ;
  curric:correction """Music can be organised into any number of beats. The first beat is always the
  strongest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105223Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-complicated-scary
  a curric:Misconception ;
  curric:statement "Improvisation is complicated and scary!"@en ;
  curric:correction """Improvisation can be as simple as changing one note. Try to play what you
  might already be able to hear in your head. Are you planning your improvisations well?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.105229Z"^^xsd:dateTime .

oakcurric:misconception-rehearsing-isnt-important-time
  a curric:Misconception ;
  curric:statement "Rehearsing isn't important. We can just do it if we have time."@en ;
  curric:correction """Rehearsing helps us to practise and prepare, so our performance can be
  successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105319Z"^^xsd:dateTime .

oakcurric:misconception-preparing-performance-focus-playing-our
  a curric:Misconception ;
  curric:statement """When preparing for a performance, we should just focus on playing our own part
  accurately."""@en ;
  curric:correction """When playing and singing in an ensemble, the overall sound is important, we
  need to make the ensemble as cohesive and synchronised as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105324Z"^^xsd:dateTime .

oakcurric:misconception-once-weve-performed-dont-need
  a curric:Misconception ;
  curric:statement "Once we've performed, we don't need to keep thinking about the learning."@en ;
  curric:correction """Reflecting on our performance is a valuable tool not only to feel a sense of
  pride in the skills we've developed, but also to see which areas of our musical learning
  need more focus."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105425Z"^^xsd:dateTime .

oakcurric:misconception-commonly-misused-generalised-term-african
  a curric:Misconception ;
  curric:statement "A commonly misused, generalised term is ‘African drumming’."@en ;
  curric:correction """A popular drum from West Africa is the djembe, which is frequently referred
  to as ‘African drumming’. By looking specifically at Guinea, in West Africa, we can see
  there are many types of drum in one country within the continent of Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105431Z"^^xsd:dateTime .

oakcurric:misconception-hierarchy-notation-stave-notation-best
  a curric:Misconception ;
  curric:statement "There is a hierarchy in notation - stave notation is always best."@en ;
  curric:correction """Notation is only effective when it can be read easily. We can notate in many
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105467Z"^^xsd:dateTime .

oakcurric:misconception-particular-piece-folk-music-played
  a curric:Misconception ;
  curric:statement "A particular piece of Folk music is always played in eactly the same way."@en ;
  curric:correction """Folk music is passed down via an oral tradition and is often interpreted
  differently. Melodies, harmonies and instrumentation may change over time and when played
  in different places."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105658Z"^^xsd:dateTime .

oakcurric:misconception-singing-opera-like-our-everyday
  a curric:Misconception ;
  curric:statement "Singing in opera is just like our everyday singing."@en ;
  curric:correction """Singing in opera is all about telling a story. We can adapt the quality of
  our voice by using a different vocal timbre, using diction in a more percussive way or by
  singing with different articulation to bring our character to life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105908Z"^^xsd:dateTime .

oakcurric:misconception-live-performance-exactly-same
  a curric:Misconception ;
  curric:statement "A live performance will always be exactly the same."@en ;
  curric:correction """Live performances, especially of an improvisation will alter very slightly
  between each concert."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105946Z"^^xsd:dateTime .

oakcurric:misconception-theres-difference-listening-live-music
  a curric:Misconception ;
  curric:statement "There's no difference between listening to live music and recorded music."@en ;
  curric:correction """Many studies have shown that live music has a greater emotional impact on the
  listener compared to recorded music. The shared experience brings people together and
  increases the emotional impact of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105952Z"^^xsd:dateTime .

oakcurric:misconception-warm-performance
  a curric:Misconception ;
  curric:statement "We only warm up for a performance."@en ;
  curric:correction """No, it is important to warm up whenever we are making music. Warming up will
  help us to focus, it will stretch and relax our vocal muscles ready for using them and
  will help us to listen and work as a group of musicians."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105963Z"^^xsd:dateTime .

oakcurric:misconception-singing-harmony-need-ignore-other
  a curric:Misconception ;
  curric:statement """When singing in harmony, we need to ignore the other parts to concentrate on
  our own part."""@en ;
  curric:correction """When singing in harmony, we need to listen carefully to the other parts to
  ensure our part blends with the other voices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105974Z"^^xsd:dateTime .

oakcurric:misconception-ostinato-simple-way-add-texture
  a curric:Misconception ;
  curric:statement "An ostinato is a simple way to add texture. It is not complex or exciting."@en ;
  curric:correction """While ostinatos are repetitive, they can be quite complex and add lots of
  excitement to music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106170Z"^^xsd:dateTime .

oakcurric:misconception-singing-rehearsed-performed-order-successful
  a curric:Misconception ;
  curric:statement "Singing has to be rehearsed and performed in order to be successful."@en ;
  curric:correction """Singing is one of the most powerful tools we can use socially to create bonds
  between people. This is very often unrehearsed; particularly in sports arenas such as
  football stadiums."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106212Z"^^xsd:dateTime .

oakcurric:misconception-sing-harmony-successfully-need-focus
  a curric:Misconception ;
  curric:statement """To sing in harmony successfully, we need to focus on our part and block out
  the other parts."""@en ;
  curric:correction """To develop tuning, balance and accuracy, we need to listen to all the parts
  being sung around us."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106281Z"^^xsd:dateTime .

oakcurric:misconception-rehearsing-something-again-again
  a curric:Misconception ;
  curric:statement "Rehearsing is just about doing something again and again."@en ;
  curric:correction """In order to rehearse effectively, pupils need to discuss and question what is
  good or needs developing in their performance. Repeating without analysing a performance
  will not improve the outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106287Z"^^xsd:dateTime .

oakcurric:misconception-once-stage-common-focus-singing
  a curric:Misconception ;
  curric:statement """Once on stage, it is common to focus more on the singing and drop some of the
  physicality."""@en ;
  curric:correction """We can avoid this by melding the two. How we move and how we sing can be
  described in similar ways. For example, legato, or smooth singing, may happen whilst we
  are moving in a smooth manner."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106312Z"^^xsd:dateTime .

oakcurric:misconception-ostinato-exciting-accompaniment
  a curric:Misconception ;
  curric:statement "An ostinato is not a very exciting accompaniment."@en ;
  curric:correction """An ostinato can make a singing performance more interesting and memorable.
  Ostinatos are used to great effect in many pieces of music in different styles and genres."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106362Z"^^xsd:dateTime .

oakcurric:misconception-hear-pulse-music
  a curric:Misconception ;
  curric:statement "We can always hear the pulse in music."@en ;
  curric:correction """Sometimes the pulse is sounded (beat), but not always. The pulse is something
  we can feel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106401Z"^^xsd:dateTime .

oakcurric:misconception-same-note
  a curric:Misconception ;
  curric:statement "Do is always the same note."@en ;
  curric:correction """This is the case in 'fixed do'. However, at Oak we use 'moveable do'. This
  means, do can be any note and then all other notes fall into place around it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106615Z"^^xsd:dateTime .

oakcurric:misconception-rhythmic-ostinato-matches-syllables-song
  a curric:Misconception ;
  curric:statement "The rhythmic ostinato matches the syllables of the song words."@en ;
  curric:correction """We have composed ostinatos using the syllables of the words, but rhythmic
  ostinatos can be made with any rhythm pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106681Z"^^xsd:dateTime .

oakcurric:misconception-ta-di-two-beats
  a curric:Misconception ;
  curric:statement "Ta-di is two beats."@en ;
  curric:correction """Every time we chant 'Ta' it is the beginning of a new beat. Ta-di is two
  sounds in one beat, each sound is half a beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106686Z"^^xsd:dateTime .

oakcurric:misconception-singing-harmony-parts-sing-loudly
  a curric:Misconception ;
  curric:statement """When singing harmony parts, we should sing loudly to block out the other parts
  so that we can sing our own part correctly."""@en ;
  curric:correction """When singing together, it's important to listen to the other parts so that we
  hear how they fit together. We need to balance the sound, so that the audience can hear
  both parts clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106780Z"^^xsd:dateTime .

oakcurric:misconception-once-performance-done-our-learning
  a curric:Misconception ;
  curric:statement "Once the performance is done, our learning is done too."@en ;
  curric:correction """Watching a performance back and/or getting feedback from an audience/
  director/teacher is hugely valuable in cementing our learning. We can see and hear how we
  used our voices and bodies to tell a story and how we applied the techniques we learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106810Z"^^xsd:dateTime .

oakcurric:misconception-music-songs-written-audiences-enjoyment
  a curric:Misconception ;
  curric:statement "Music and songs are only written for an audience's enjoyment."@en ;
  curric:correction """Songs and music can be written to help people understand a feeling or an
  important message."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106818Z"^^xsd:dateTime .

oakcurric:misconception-rehearsal-going-songs-until-know
  a curric:Misconception ;
  curric:statement "Rehearsal is going over the songs until we know them."@en ;
  curric:correction """Rehearsal is used to develop a character - physically, vocally, and by
  understanding intentions and mood. Rehearsal is also for exploring using the space to tell
  the story clearly as well as neatening key parts of the songs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106850Z"^^xsd:dateTime .

oakcurric:misconception-beatboxing-artists-use-rhythmic-patterns
  a curric:Misconception ;
  curric:statement "Beatboxing artists use only rhythmic patterns in their music."@en ;
  curric:correction """Beatboxing is not always just about drum machine mimicry. Artists like Jason
  Singh, combine other sounds in his recordings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107367Z"^^xsd:dateTime .

oakcurric:misconception-singing-makes-us-feel-good
  a curric:Misconception ;
  curric:statement "Singing only makes us feel good in the moment."@en ;
  curric:correction """Singing, and breathing for singing, are powerful tools to reduce stress
  levels and improve overall well being. Singing releases endorphins in the brain which
  contribute to improved mood. This positive effect is noticeably magnified in larger
  groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107475Z"^^xsd:dateTime .

oakcurric:misconception-accompaniments-use-beat-rhythm-patterns
  a curric:Misconception ;
  curric:statement "Accompaniments only use on-beat rhythm patterns to help keep us in time."@en ;
  curric:correction """Accompaniments can use any rhythms! Syncopated rhythms and polyrhythms can
  still keep us in time as we feel the offbeat and still feel the steady pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109325Z"^^xsd:dateTime .

oakcurric:misconception-create-polyrhythms-rhythms-complicated
  a curric:Misconception ;
  curric:statement "To create polyrhythms, all rhythms must be complicated."@en ;
  curric:correction """The layered rhythms don't need to be complex, they just need to give a
  contrasting feel of the beat or metre. It's the layering that makes things more
  complicated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113520Z"^^xsd:dateTime .

oakcurric:misconception-need-rehearse-find-our-part
  a curric:Misconception ;
  curric:statement "We only need to rehearse if we find our part difficult."@en ;
  curric:correction """Rehearsing can warm you up for a performance and make sure you feel alert and
  ready to perform. It also makes sure you know when and how to play and not just what to
  play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113530Z"^^xsd:dateTime .

oakcurric:misconception-polyrhythms-created-syncopated-rhythm-patterns
  a curric:Misconception ;
  curric:statement "Polyrhythms are only created with syncopated rhythm patterns."@en ;
  curric:correction """Polyrhythms are built from a combination of on and offbeat rhythms and
  rhythms that give a feeling of a different metre (beats per bar)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113556Z"^^xsd:dateTime .

oakcurric:misconception-music-four-beats-bar-finish
  a curric:Misconception ;
  curric:statement """Music has four beats in a bar and we always finish at the last beat in the
  bar."""@en ;
  curric:correction """Rhythm cycles in Hindustani classical music can have anything from 3 beats to
  128 beats. The rhythm is cyclical and ends on the first beat of the rhythm cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115560Z"^^xsd:dateTime .

oakcurric:misconception-syncopated-rhythms-really-complicated
  a curric:Misconception ;
  curric:statement "Syncopated rhythms are really complicated."@en ;
  curric:correction """In its simplest form, syncopation is just rhythmic patterns that emphasise
  the offbeat. They can be simple rhythms, but the emphasis on the offbeat can create an
  interesting, but not necessarily difficult, sound to recreate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117290Z"^^xsd:dateTime .

oakcurric:misconception-need-warm-performance
  a curric:Misconception ;
  curric:statement "We only need to warm up before a performance."@en ;
  curric:correction """It is important to warm up before we sing, whether that is when we rehearse,
  in a lesson, or before a performance. Warming up develops our vocal skills and protects
  our voice from injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120258Z"^^xsd:dateTime .

oakcurric:misconception-once-play-notes-correctly-theres
  a curric:Misconception ;
  curric:statement """Once we can play the notes correctly, there's nothing we need to do to improve
  a performance."""@en ;
  curric:correction """Listening and watching the overall performance and getting feedback from
  others can help us to identify how to refine the performance such as adding dynamics,
  playing sensitively within the ensemble and playing precisely in time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120270Z"^^xsd:dateTime .

oakcurric:misconception-musicians-trying-tell-story-music
  a curric:Misconception ;
  curric:statement "Musicians are always trying to tell a story with music."@en ;
  curric:correction """Sometimes music is created for music's sake and may not have any deeper
  meaning than what the listener creates for themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124829Z"^^xsd:dateTime .

oakcurric:misconception-symphonic-work-uses-instruments
  a curric:Misconception ;
  curric:statement "A symphonic work only uses instruments."@en ;
  curric:correction """Whilst a symphony traditionally only used instruments of the orchestra,
  composers over time have diversified and introduced voices into symphonic works."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124882Z"^^xsd:dateTime .

oakcurric:misconception-texture-structure-same-thing
  a curric:Misconception ;
  curric:statement "Texture and structure are the same thing."@en ;
  curric:correction """Texture and structure are easily confused. Think of texture as vertical and
  structure as horizontal. Texture is what is happening at the same time - the layers of
  sound. Structure is what happens in order - what happens first, then what happens next."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125060Z"^^xsd:dateTime .

oakcurric:misconception-golden-ratio-golden-brick-connected
  a curric:Misconception ;
  curric:statement "The golden ratio and the golden brick are connected or the same thing."@en ;
  curric:correction """Here, the word golden is used to suggest beauty, balance or perfection, or
  its importance. However, these two concepts are not connected. Be sure the pupils
  understand that Whitacre uses the term 'golden brick' just to mean his small musical idea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125106Z"^^xsd:dateTime .

oakcurric:misconception-musical-maps-graphic-scores-same
  a curric:Misconception ;
  curric:statement "Musical maps and graphic scores are the same."@en ;
  curric:correction """A musical map is not the same as a graphic score, although it may look very
  similar. A graphic score is created by a composer to notate their musical ideas. A musical
  map is created by the listener to make sense of what they are hearing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125128Z"^^xsd:dateTime .

oakcurric:misconception-respond-same-way-piece-music
  a curric:Misconception ;
  curric:statement "We all respond in the same way to a piece of music."@en ;
  curric:correction """Our response to music is personal. We may agree or disagree with others on
  the feelings and atmosphere we sense in a piece of music. We can have interesting
  discussions around our personal responses to music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125160Z"^^xsd:dateTime .

oakcurric:misconception-film-scores-programme-music-same
  a curric:Misconception ;
  curric:statement "Film scores and programme music are the same thing."@en ;
  curric:correction """A film score is synchronised to the film. It supports the visual, enhancing
  the story as it happens. Programme music tells a narrative, but is a standalone piece of
  music and is not bound to the storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125201Z"^^xsd:dateTime .

oakcurric:misconception-scale-starts-note
  a curric:Misconception ;
  curric:statement "A scale always starts on the note do."@en ;
  curric:correction """We are used to using the Solfège note names in the order - do, re, mi, fa,
  so, la, ti, do. This is only correct for major scales. A minor scale starts on the note
  la."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126384Z"^^xsd:dateTime .

oakcurric:misconception-play-melody-quickly-learning
  a curric:Misconception ;
  curric:statement "We can play a melody quickly when we are learning it."@en ;
  curric:correction "It's always better to start slow, then speed up when confidence is built."@en ;
  dcterms:modified "2026-06-07T15:30:15.126403Z"^^xsd:dateTime .

oakcurric:misconception-writing-music-notation-exact-position
  a curric:Misconception ;
  curric:statement """When writing out music notation, the exact position of the notes doesn't
  really matter."""@en ;
  curric:correction """The part that matters the most is the note head - the circle at the bottom of
  the stick. Where that sits (on a line or space) tells us what pitch to play, so accuracy
  in where it is placed is important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126409Z"^^xsd:dateTime .

oakcurric:misconception-layering-instrumental-melody-different-song
  a curric:Misconception ;
  curric:statement """Layering an instrumental melody with a different song will not create pleasing
  harmonies."""@en ;
  curric:correction """Partner songs are selected to work together because their notes fit together
  harmoniously. It doesn't matter if we play or sing the melody, it will work equally well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126415Z"^^xsd:dateTime .

oakcurric:misconception-parts-ensemble-piece-important-others
  a curric:Misconception ;
  curric:statement "Some parts in an ensemble piece are more important than others."@en ;
  curric:correction """Through learning all the parts you will come to see the importance and
  difficulty and unique qualities of each. Often the hardest part is just holding the beat!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.126470Z"^^xsd:dateTime .

oakcurric:misconception-rehearsing-simply-means-playing-piece
  a curric:Misconception ;
  curric:statement "Rehearsing simply means playing a piece again and again."@en ;
  curric:correction """To rehearse effectively, we need to work on sepcific areas for improvement to
  help us to play and sing together and create a balanced sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144384Z"^^xsd:dateTime .

oakcurric:misconception-playing-loudly-shows-playing-confidently
  a curric:Misconception ;
  curric:statement "Playing loudly shows we are playing confidently."@en ;
  curric:correction """We want to encourage pupils to understand the importance of balancing their
  sound and that playing or singing loudly does not mean it is more confident or more
  correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144500Z"^^xsd:dateTime .

oakcurric:misconception-creating-performance-same-singing-together
  a curric:Misconception ;
  curric:statement """Creating a performance is the same as singing together in our normal music
  lessons/there is no difference between singing together and creating a performance."""@en ;
  curric:correction """When we perform we are sharing our work with an audience. We need to use our
  performing skills such as standing like a singer and capturing a song's character using
  our voices to communicate the meaning of the song to the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144600Z"^^xsd:dateTime .

oakcurric:misconception-singing-two-parts-cover-my
  a curric:Misconception ;
  curric:statement """When singing in two parts, I should cover my ears/try not to listen to the
  other part. This will help me to hold my own part."""@en ;
  curric:correction """When we sing in two parts, it is important to have \"open ears\" so we can
  hear how both parts fit together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146423Z"^^xsd:dateTime .

oakcurric:misconception-best-way-learn-play-piece
  a curric:Misconception ;
  curric:statement "The best way to learn to play a piece is to start at the beginning."@en ;
  curric:correction """We can be clever when learning pieces, looking for patterns and easy parts to
  fit together first whilst internalising the sounds of trickier parts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146843Z"^^xsd:dateTime .

oakcurric:misconception-singing-parts-need-stand-other
  a curric:Misconception ;
  curric:statement """When singing in parts we need to stand away from other parts, so that we can
  concentrate on our part."""@en ;
  curric:correction """Understanding how parts fit together, hearing texture, structure and harmony,
  and feeling the steady pulse together are all important elements of learning to sing in
  parts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146849Z"^^xsd:dateTime .

oakcurric:misconception-songs-minor-tonality-sad
  a curric:Misconception ;
  curric:statement "Songs with a minor tonality are always sad."@en ;
  curric:correction """Tonality is one of the elements that gives a melody its character. While
  minor tonalites often feel dark, it is the combination of how all the elements of music
  are used that will make a song sound sad."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147016Z"^^xsd:dateTime .

oakcurric:misconception-practising-ensemble-need-practise-our
  a curric:Misconception ;
  curric:statement """When practising in an ensemble we need to practise at our own speed so we can
  play our part accurately."""@en ;
  curric:correction """When practising as an ensemble, we all need to play at the same tempo, we
  should start off slowly and speed up as we feel more confident."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147079Z"^^xsd:dateTime .

oakcurric:misconception-scale-uses-notes-step-leaps
  a curric:Misconception ;
  curric:statement "A scale uses all the notes in step with no leaps."@en ;
  curric:correction """A scale is a series of notes arranged in an ascending or descending order.
  Each scale has a unique pattern of intervals (the distance between notes) that defines its
  character and the intervals are not always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147970Z"^^xsd:dateTime .

oakcurric:misconception-practise-need-repeat-music-times
  a curric:Misconception ;
  curric:statement "When we practise, we just need to repeat the music a few times."@en ;
  curric:correction """Thinking about what we want to improve and choosing the best stragtegy to
  help us is the best way to practise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148026Z"^^xsd:dateTime .

oakcurric:misconception-singing-forte-means-singing-shouting
  a curric:Misconception ;
  curric:statement "Singing forte means singing (or shouting) as loudly as I can."@en ;
  curric:correction """It is important when we are singing forte to use our singing, not our
  shouting, voices. To do this, think about singing 'strongly' not 'loudly.' Can you make
  your voice sound confident? Energetic? Powerful?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.148271Z"^^xsd:dateTime .

oakcurric:misconception-songs-major-tonality-happy
  a curric:Misconception ;
  curric:statement "Songs with a major tonality are always happy."@en ;
  curric:correction """Tonality is one of the elements that gives a melody it's character. While
  major tonalites often feel bright, it is the combination of how all the elements of music
  are used that will make a song sound happy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148518Z"^^xsd:dateTime .

oakcurric:misconception-music-worked-beforehand-cant-made
  a curric:Misconception ;
  curric:statement "All music is worked out beforehand and can’t be made up on the spot."@en ;
  curric:correction """Improvisation is the spontaneous creation of musical melodies and rhythms
  during a live performance. These musical ideas are made up on the spot and not written
  down so it is very hard to exactly recreate them a second time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148536Z"^^xsd:dateTime .

oakcurric:misconception-rehearsal-singing-song-make-sure
  a curric:Misconception ;
  curric:statement "Rehearsal is just singing the song over to make sure we know it."@en ;
  curric:correction """Rehearsal helps us develop our relationships with other characters on stage,
  work out what we're trying to acheive (eg 'get my brother to dance with me'/'make my
  sister laugh') and work out how to show that with our posture, expression and movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151010Z"^^xsd:dateTime .

oakcurric:misconception-once-weve-performed-weve-finished
  a curric:Misconception ;
  curric:statement """Once we've performed, then we've finished and don't need to carry on
  reflecting on our work."""@en ;
  curric:correction """Watching a performance back, and/or reflecting on our performance is useful
  because it gives us an opportunity to realise and appreciate the various skills we've been
  learning, using and building on. We can also see what we'd do better next tiime."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151148Z"^^xsd:dateTime .

oakcurric:misconception-opera-boring-older-wealthier-people
  a curric:Misconception ;
  curric:statement """Opera is boring and only for older, wealthier people. It's mainly people
  singing in high voices in languages we might not understand."""@en ;
  curric:correction """Opera can be performed anywhere, for anyone, and in many different languages.
  There are operas suitable for all age groups and they combine drama, comedy, singing,
  dance, music and design. Opera can be a great genre for exciting storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151160Z"^^xsd:dateTime .

oakcurric:misconception-ostinato-rhythm-pattern
  a curric:Misconception ;
  curric:statement "An ostinato is a rhythm pattern only."@en ;
  curric:correction """An ostinato can be melodic as well as rhythmic. In pop music they’re often
  called a ‘riff’ and in electronic music, a ‘loop’. A repeated pattern can add to the
  texture of a piece of music and help drive it forward."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151169Z"^^xsd:dateTime .

oakcurric:misconception-play-same-tune-singing
  a curric:Misconception ;
  curric:statement "We play the same tune as what we're singing."@en ;
  curric:correction """A melodic ostinato can add more interest to the overall sound and, with
  practice, we can play a different tune to the one we're singing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151189Z"^^xsd:dateTime .

oakcurric:misconception-play-our-own-tempo-without
  a curric:Misconception ;
  curric:statement "We can play at our own tempo without listening to the other groups."@en ;
  curric:correction """The songs we are layering are all played at different tempi. Feeling the
  steady pulse and following a conductor, as well as listening to the playing of all groups
  will help the class to play to the same steady pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151207Z"^^xsd:dateTime .

oakcurric:misconception-songs-written-based-beliefs-experiences
  a curric:Misconception ;
  curric:statement """Songs are written based on the beliefs and experiences of the person writing
  or singing."""@en ;
  curric:correction """Songs have been used for so many purposes from preserving history, sharing
  family history, entertaining people, to protesting, sharing political messages and to tell
  a huge range of stories both factual and fiction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151224Z"^^xsd:dateTime .

oakcurric:misconception-musical-theatre-solely-light-entertainment
  a curric:Misconception ;
  curric:statement "Musical theatre is solely for light entertainment."@en ;
  curric:correction """Songs in musical theatre can explore a range of emotions and experiences that
  an audience might relate to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151237Z"^^xsd:dateTime .

oakcurric:misconception-singing-song-enough-help-audience
  a curric:Misconception ;
  curric:statement """Singing the song is enough to help the audience follow a story because the
  story is in the lyrics."""@en ;
  curric:correction """Singing in character by understanding your character's motivation and how
  that might influence their actions helps bring the lyrics to life by singing and
  performing with our whole body, thinking about our posture and expression."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151263Z"^^xsd:dateTime .

oakcurric:misconception-repetition-music-boring-simplistic
  a curric:Misconception ;
  curric:statement "Repetition in music is boring and simplistic."@en ;
  curric:correction """Repetition is a powerful tool that allows musicians and songwriters to make a
  point clearly and be very specific."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151545Z"^^xsd:dateTime .

oakcurric:misconception-lyrics-fit-time-music
  a curric:Misconception ;
  curric:statement "Lyrics should always fit in time with the music."@en ;
  curric:correction """Beat poetry is an example of when speech can ‘float above’ the music without
  having to keep to a strict rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151883Z"^^xsd:dateTime .

oakcurric:misconception-wont-able-hear-instruments-playing
  a curric:Misconception ;
  curric:statement """We won't be able to hear what instruments are playing when they're playing at
  the same time."""@en ;
  curric:correction """We can identify the instruments playing by their unique timbre and tune our
  ears to recognise each sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152741Z"^^xsd:dateTime .

oakcurric:misconception-music-songs-written-long-time
  a curric:Misconception ;
  curric:statement "Music and songs written a long time ago aren’t relevant to us now."@en ;
  curric:correction """Music and songs from the past can help us to connect with, and better
  understand many people, both at home and abroad."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152819Z"^^xsd:dateTime .

oakcurric:misconception-drones-boring-because-single-note
  a curric:Misconception ;
  curric:statement "Drones are boring because they are just a single note."@en ;
  curric:correction """Drones can add depth and a focus point to a piece of music. They can
  sometimes even be soothing for the listener. A piece of music can be built around a drone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152857Z"^^xsd:dateTime .

oakcurric:misconception-one-set-names-use-notes
  a curric:Misconception ;
  curric:statement "There are only one set of names we use for notes in a scale"@en ;
  curric:correction """We can use pitch names of C, D, E, F, G, A, B. We can use the solfège of do,
  re, mi, fa, so la, ti, and in Hindustani classical we use the sargam of sa, re, ga, ma,
  pa, dha ni. These are not fixed - meaning 'do' or 'Sa' don't have to be 'C'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153102Z"^^xsd:dateTime .

oakcurric:misconception-music-notated-using-stave-notation
  a curric:Misconception ;
  curric:statement "All music is notated using stave notation."@en ;
  curric:correction """Music should be notated in the most effective way for it to be decoded. This
  is often stave notation, but can be any way of sharing the musical intention successfully,
  for example rhythm grids or graphic scores."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153432Z"^^xsd:dateTime .

oakcurric:misconception-music-major-minor-tonality
  a curric:Misconception ;
  curric:statement "Music can only be major or minor in tonality."@en ;
  curric:correction """Music can be tonal - major, minor or other using modes. Music can also be
  atonal or go beyond tonality, not having a traditional sense of key or tonal note."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153825Z"^^xsd:dateTime .

oakcurric:misconception-warm-singing-performance
  a curric:Misconception ;
  curric:statement "We only warm up before a singing performance."@en ;
  curric:correction """Warming up protects and strengthens our voice, prepares our mind and develops
  our musical skills. It is beneficial and advisable to warm up for every music lesson and
  every singing practice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153937Z"^^xsd:dateTime .

oakcurric:misconception-round-sing-song-once-everyone
  a curric:Misconception ;
  curric:statement """A round is where you sing a song once through but everyone starts at different
  times."""@en ;
  curric:correction """A round is a shorter song that repeats on a loop. The start times are
  staggered in half, in quarters, or sometimes in thirds. Feeling the steady pulse, and
  counting the correct number of beats helps us know when to start singing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154062Z"^^xsd:dateTime .

oakcurric:misconception-rehearsing-singing-songs
  a curric:Misconception ;
  curric:statement "Rehearsing is just singing the songs through."@en ;
  curric:correction """Rehearsing helps us to work out what needs further practice. It helps us know
  when to start and stop singing, to feel the steady beat and is a regular reminder to
  follow the conductor. Feeling more confident will enable a more accurate performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154225Z"^^xsd:dateTime .

oakcurric:misconception-conductors-needed-lead-orchestras
  a curric:Misconception ;
  curric:statement "Conductors are only needed to lead orchestras."@en ;
  curric:correction """Conductors can direct any group of musicians - singers or instrumentalists.
  They can help each voice enter a round at the correct time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154264Z"^^xsd:dateTime .

oakcurric:misconception-music-sound-pleasing-ear
  a curric:Misconception ;
  curric:statement "Music should always sound pleasing to the ear."@en ;
  curric:correction """Music doesn’t have to sound ‘nice’ to be effective. There are styles of music
  that explore more difficult messages and use dissonance to create a particular effect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154672Z"^^xsd:dateTime .

oakcurric:misconception-pitch-same-melodic-shape
  a curric:Misconception ;
  curric:statement "Pitch is the same as melodic shape."@en ;
  curric:correction """Pitch refers to how high or low an individual note is. Melodic shape refers
  to the up and down contour pattern created by a series of pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155077Z"^^xsd:dateTime .

oakcurric:misconception-singing-parts-its-better-sing
  a curric:Misconception ;
  curric:statement """When singing in parts it's better to sing loudly so that you are not
  distracted by the other parts."""@en ;
  curric:correction """If everyone sings more gently, they can hear themselves, and others,
  properly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155260Z"^^xsd:dateTime .
