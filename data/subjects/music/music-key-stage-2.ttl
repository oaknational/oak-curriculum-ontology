  dcterms:modified "2026-06-07T15:30:41.078812Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20649
  a curric:PupilLessonOutcome ;
  rdfs:label "I can combine rhythms to create a polyrhythm that can accompany a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.080082Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20647
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play two contrasting rhythms as part of an ensemble to create a
  polyrhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:41.082766Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20650
  a curric:PupilLessonOutcome ;
  rdfs:label "I can rehearse songs with many layers effectively to prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:41.082774Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20648
  a curric:PupilLessonOutcome ;
  rdfs:label "I can layer multiple rhythms to create a polyrhythm as part of an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:41.082790Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20646
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play a syncopated rhythmic ostinato using body percussion."@en ;
  dcterms:modified "2026-06-07T15:30:41.082798Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20585
  a curric:PupilLessonOutcome ;
  rdfs:label "I can speak and clap a rhythm cycle (taal) in time."@en ;
  dcterms:modified "2026-06-07T15:30:41.084055Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20645
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing songs that include syncopated rhythms while keeping a steady beat."@en ;
  dcterms:modified "2026-06-07T15:30:41.085232Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20609
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing new rounds and partner songs in unison and understand the structure of
  these."""@en ;
  dcterms:modified "2026-06-07T15:30:41.087228Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20596
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use feedback to refine an ensemble performance and can review the success of
  rehearsal strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:41.087241Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29932
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create a short piece of programme music as an ensemble and know that programme
  music aims to represent something non-musical, such as telling a story."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089579Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29935
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create and combine small vocal musical ideas (golden bricks) based around
  themes to structure a vocal piece."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089617Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29974
  a curric:PupilLessonOutcome ;
  rdfs:label "I can develop a motif for a film score that represents a character and setting."@en ;
  dcterms:modified "2026-06-07T15:30:41.089739Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29976
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create drama in my film score, considering effective ways to build on my motif
  to create a sense of danger and disaster."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089743Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29934
  a curric:PupilLessonOutcome ;
  rdfs:label """I can structure a short musical piece by including the climatic point at the golden
  ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089774Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29933
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a small musical idea, called a golden brick, to inspire and structure a
  short piece of programme music."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089790Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29975
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create atmosphere in my film score, considering effective ways to build on my
  motif to create feelings of tension and danger."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089853Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29973
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose a motif and use this to begin scoring a nature inspired film score,
  considering firstly the habitat in my narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089881Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20634
  a curric:PupilLessonOutcome ;
  rdfs:label """I can read, sing and play the minor pentachord and know it uses the first five notes
