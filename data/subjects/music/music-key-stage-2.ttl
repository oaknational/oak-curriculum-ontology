  dcterms:modified "2026-06-07T15:30:41.102910Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20544
  a curric:PupilLessonOutcome ;
  rdfs:label """I can participate in playground singing games and know that these can be used to
