  dcterms:modified "2026-06-07T15:30:41.090670Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20636
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read and play minor melodies on tuned percussion."@en ;
  dcterms:modified "2026-06-07T15:30:41.090683Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20635
  a curric:PupilLessonOutcome ;
  rdfs:label """I can read and notate the ascending and descending minor pentachord on a simplified
  stave."""@en ;
  dcterms:modified "2026-06-07T15:30:41.090687Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20613
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play a three note melody, partnering this with a different song."@en ;
  dcterms:modified "2026-06-07T15:30:41.090691Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20614
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play my part in an ensemble piece with accuracy and an understanding of
  balance."""@en ;
  dcterms:modified "2026-06-07T15:30:41.090724Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20595
  a curric:PupilLessonOutcome ;
  rdfs:label """I can work in a small ensemble using effective rehearsal strategies to prepare for a
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:41.102123Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20576
  a curric:PupilLessonOutcome ;
  rdfs:label "I can accompany a major tonality song with a melodic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:41.102204Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20548
  a curric:PupilLessonOutcome ;
  rdfs:label """I can choose appropriate dynamics and use my voice in different ways to create a
