  dcterms:modified "2026-06-07T15:30:41.103564Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20547
  a curric:PupilLessonOutcome ;
  rdfs:label """I understand how changing dynamics and using my voice in different ways can help
