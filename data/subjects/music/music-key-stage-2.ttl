  dcterms:modified "2026-06-07T15:30:41.104422Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20583
  a curric:PupilLessonOutcome ;
  rdfs:label """I can demonstrate my understanding of opera by performing a song in character and
