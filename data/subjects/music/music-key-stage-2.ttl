    oakcurric:priorknowledge-2668-5 ,
    oakcurric:priorknowledge-2668-6 ;
  curric:id "2668"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.928989Z"^^xsd:dateTime ;
