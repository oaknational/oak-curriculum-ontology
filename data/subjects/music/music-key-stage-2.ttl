  dcterms:modified "2026-06-07T15:30:41.106497Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20656
  a curric:PupilLessonOutcome ;
  rdfs:label "I can convey emotion through song and know how songs can be powerful for change."@en ;
  dcterms:modified "2026-06-07T15:30:41.106616Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20655
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand how rap and beat poetry can inspire hope and positive action."@en ;
  dcterms:modified "2026-06-07T15:30:41.106716Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20555
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify different layers of sound under songs and in music."@en ;
  dcterms:modified "2026-06-07T15:30:41.107396Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20654
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand how music can connect us emotionally to others and to the past."@en ;
  dcterms:modified "2026-06-07T15:30:41.107461Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20556
  a curric:PupilLessonOutcome ;
  rdfs:label "I can add to the texture of a song by playing a drone."@en ;
  dcterms:modified "2026-06-07T15:30:41.107492Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20586
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing and play notes from a raag."@en ;
  dcterms:modified "2026-06-07T15:30:41.107662Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20625
  a curric:PupilLessonOutcome ;
  rdfs:label """I can structure and notate a minimalist composition considering the most effective
  way to do this."""@en ;
  dcterms:modified "2026-06-07T15:30:41.107791Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20575
  a curric:PupilLessonOutcome ;
  rdfs:label """I can follow the melodic shape of minor tonality folk songs, singing and signing the
  minor pentachord and framing this with a drone accompaniment."""@en ;
  dcterms:modified "2026-06-07T15:30:41.108056Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20573
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing new major and minor tonality folk songs with a sense of character."@en ;
  dcterms:modified "2026-06-07T15:30:41.108140Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20577
  a curric:PupilLessonOutcome ;
  rdfs:label "I can accompany a minor tonality song with a melodic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:41.108223Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20567
  a curric:PupilLessonOutcome ;
  rdfs:label """I can follow the structure of a round and know that everybody sings the same melody
