# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-20674-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use good practice techniques to prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.256542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20674-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding how to rehearse effectively improves our ensemble skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.256546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20674-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ongoing refinement is an important part of improving a composition and
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20674-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can create a successful composition using a theme and variations structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.256556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20629-1
  a curric:KeyLearningPoint ;
  rdfs:label """Beatboxing sounds can be layered with vocal parts to make a texture of two or more
  parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20629-2
  a curric:KeyLearningPoint ;
  rdfs:label """To hold a part in a texture it is important to rehearse together as a musical
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20629-3
  a curric:KeyLearningPoint ;
  rdfs:label "A loop station allows musicians to record, playback, and layer musical phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.272817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20629-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different beatboxing sounds create different timbres when they imitate
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20628-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our voices to mimic different percussion instruments in a beatboxing
  style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20628-2
  a curric:KeyLearningPoint ;
  rdfs:label "Beatboxing sounds are created using different mouth shapes and letter sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.273129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20628-3
  a curric:KeyLearningPoint ;
  rdfs:label """Every percussion instrument has a unique timbre. We mimic this unique timbre when
  beatboxing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20628-4
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more musical lines layered together create a musical texture. The more lines,
  the thicker the texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20668-1
  a curric:KeyLearningPoint ;
  rdfs:label "Effective rehearsal will likely lead to a more successful performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.278532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20668-2
  a curric:KeyLearningPoint ;
  rdfs:label """Taking time to consider how we can improve, and what next to work on is an important
  part of the refining process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20668-3
  a curric:KeyLearningPoint ;
  rdfs:label "Receiving feedback can help us to reflect on our own performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.278544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20668-4
  a curric:KeyLearningPoint ;
  rdfs:label """Asking questions about musicians' choices is a powerful way of gaining a greater
  understanding of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers carefully use dynamics, texture, and articulation to create the mood and
  feeling of a piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27380-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quiet, legato playing and singing can give music a sense of peace and calm."@en ;
  dcterms:modified "2026-06-07T15:30:29.279316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27380-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can control our breathing so that we have enough air for singing long sustained
  lines of a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27380-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can look at the melodic shape and the phrasing of written music to help us to
  sing a legato melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fusion music is a genre that deliberately combines two or more existing musical
  styles to create a new sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20664-2
  a curric:KeyLearningPoint ;
  rdfs:label """The clave is a rhythmic pattern found in Cuban, Latin and other African-influenced
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20664-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layered syncopated rhythms is a feature of Latin music."@en ;
  dcterms:modified "2026-06-07T15:30:29.279764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20664-4
  a curric:KeyLearningPoint ;
  rdfs:label """The soca rhythm is a fast-paced, highly syncopated beat that forms the foundation of
  soca music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20664-5
  a curric:KeyLearningPoint ;
  rdfs:label """Soca is a dance-focused music genre that is a fusion of calypso, Indian folk and
  West African musical traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20665-1
  a curric:KeyLearningPoint ;
  rdfs:label """Musical fusions have been created by blending music originally composed for the
  orchestra with other musical styles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Classical music was composed between 1750-1820, characterised by formal structure,
  technical skill, and emotional depth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fusion music forms a deliberate and new synthesis of styles, combining musical
  elements from the original music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20666-1
  a curric:KeyLearningPoint ;
  rdfs:label """Repeated motifs are like small building blocks that composers use to create
  continuity, momentum, and structure"""@en ;
  dcterms:modified "2026-06-07T15:30:29.280271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20666-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can layer rhythmic cells to create an accompaniment texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.280275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20666-3
  a curric:KeyLearningPoint ;
  rdfs:label """A melodic riff is a short, repeated musical phrase or pattern that forms a core part
  of a musical piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20667-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different people might have different ideas of what works well in a fusion
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20667-2
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone responds to music in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.280856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20667-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fusion music forms a deliberate and new synthesis of styles."@en ;
  dcterms:modified "2026-06-07T15:30:29.280862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20667-4
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting, developing and rejecting ideas is a crucial part of the artistic
  journey of creating a piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fusion music is when two or more different styles of music are combined together to
  create something new."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fusion music often blends different cultural elements or genres from
  different eras."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20663-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to recognise the stylistic features of the different musical
  influences in fusion music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20541-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use ostinato patterns to accompany a musical performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.284309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20541-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can combine different layers of sound to add texture to an accompaniment."@en ;
  dcterms:modified "2026-06-07T15:30:29.284312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20541-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can play multiple layers of sound simultaneously as an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.284318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20541-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adding more layers of sound creates a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.284322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20552-1
  a curric:KeyLearningPoint ;
  rdfs:label """The beat can be subdivided into smaller parts and can be notated on a rhythm grid as
  symbols such as dots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20552-2
  a curric:KeyLearningPoint ;
  rdfs:label """A rhythm grid can help you to read and perform layers of music at the same time,
  creating a thick texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple different symbols can represent different sounds on the same rhythm
  grid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20604-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm names like ta and ta-di can be worked out using beat fingers, listening for
  how many sounds are on each beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20604-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch actions can help us recognise melodic shape"@en ;
  dcterms:modified "2026-06-07T15:30:29.288014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20604-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use solfège like so, mi and do to identify specific pitches."@en ;
  dcterms:modified "2026-06-07T15:30:29.288018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20561-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to warm up before singing to protect our voice from injury and to
  develop our vocal strength."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20561-2
  a curric:KeyLearningPoint ;
  rdfs:label """Folk songs come from all around the world, originating from a particular country,
  area or people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20561-3
  a curric:KeyLearningPoint ;
  rdfs:label "Folk songs are usually simple songs passed down by oral tradition."@en ;
  dcterms:modified "2026-06-07T15:30:29.288087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20561-4
  a curric:KeyLearningPoint ;
  rdfs:label "Developing a sound sense of pulse helps us to sing and play together."@en ;
  dcterms:modified "2026-06-07T15:30:29.288090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20561-5
  a curric:KeyLearningPoint ;
  rdfs:label "Body percussion can help us to identify and perform rhythm patterns accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.288094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20550-1
  a curric:KeyLearningPoint ;
  rdfs:label """A rhythm grid is a visual grid system to represent and perform rhythmic
  patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20550-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm grids can be displayed in many ways, you just need to know the code in order
  to be able to play them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20550-3
  a curric:KeyLearningPoint ;
  rdfs:label """Visual symbols such as colours, shapes or numbers can represent musical
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20550-4
  a curric:KeyLearningPoint ;
  rdfs:label """To play together in an ensemble, you need to have a good sense of pulse, to know
  when it is your turn to play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20638-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use an AABA structure to shape a melody"@en ;
  dcterms:modified "2026-06-07T15:30:29.288173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20638-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing music helps us improve."@en ;
  dcterms:modified "2026-06-07T15:30:29.288177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20638-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we perform we should pick a steady tempo, and if we make a mistake we should
  try and find our place and continue."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20602-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can compose and improvise using the pitches of the major pentachord."@en ;
  dcterms:modified "2026-06-07T15:30:29.288265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20602-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective melodies move mostly by step, with some leaps."@en ;
  dcterms:modified "2026-06-07T15:30:29.288268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20602-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rondo form is a type of composition with a returning theme."@en ;
  dcterms:modified "2026-06-07T15:30:29.288272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20602-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps us get ready to perform."@en ;
  dcterms:modified "2026-06-07T15:30:29.288275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20602-5
  a curric:KeyLearningPoint ;
  rdfs:label """When we perform we should pick a steady tempo and if we make a mistake we should try
  and find our place and continue."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20637-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can compose rhythms by selecting and arranging takadimi patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.288377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20637-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can compose melodies by selecting pitches from the minor scale and assigning
  these to our composed rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20637-3
  a curric:KeyLearningPoint ;
  rdfs:label "Effective melodies move mostly by step, with some leaps."@en ;
  dcterms:modified "2026-06-07T15:30:29.288387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20637-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use question and answer phrases to structure our melodies."@en ;
  dcterms:modified "2026-06-07T15:30:29.288391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20564-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hand signs can help us hear, feel and understand the melodic shape of a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.288395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20564-2
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be notated to be shared and remembered for another day"@en ;
  dcterms:modified "2026-06-07T15:30:29.288401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20564-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stick notation is one way that music can be notated. There are many more
  ways still."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20564-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can decode the major pentatonic folk songs we learn and write these using stick
  notation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20564-5
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation can help us to read rhythms and melodies quickly and easily."@en ;
  dcterms:modified "2026-06-07T15:30:29.288415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20601-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stave notation can tell us the rhythm and pitch of a melody, which we can use to
  help us perform it accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20601-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can compose by selecting pitches from the major pentachord for an existing
  rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective melodies start and end on ‘do’ and move mostly by step, with some
  leaps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20601-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use repeating patterns to make our melody and rhythm compositions sound
  organised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Partner songs are a type of harmony where two songs are performed at the
  same time"""@en ;
  dcterms:modified "2026-06-07T15:30:29.288568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rounds are another type of harmony; singing the same song, but starting at different
  times"""@en ;
  dcterms:modified "2026-06-07T15:30:29.288572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20605-3
  a curric:KeyLearningPoint ;
  rdfs:label "A beat of silence is called a rest"@en ;
  dcterms:modified "2026-06-07T15:30:29.288576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20542-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can accompany a song by combining different layers of sound to add texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.288689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20542-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can combine multiple ostinato patterns to create a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.288695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20542-3
  a curric:KeyLearningPoint ;
  rdfs:label "An ensemble needs to rehearse together to play successfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.288699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20542-4
  a curric:KeyLearningPoint ;
  rdfs:label """In an ensemble, each part needs to play confidently while also understanding how the
  parts fit together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20672-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many composers borrow the theme from other composers when they compose their
  variations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20672-2
  a curric:KeyLearningPoint ;
  rdfs:label "A composer can change the theme in different ways to create a variation."@en ;
  dcterms:modified "2026-06-07T15:30:29.288753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20672-3
  a curric:KeyLearningPoint ;
  rdfs:label """A melodic variation is when the melody is changed; however, you can still recognise
  aspects of the original theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20672-4
  a curric:KeyLearningPoint ;
  rdfs:label """The melody is often changed by adding extra notes, sometimes notes adjacent to the
  original or just a step away."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20549-1
  a curric:KeyLearningPoint ;
  rdfs:label """A rhythm grid is a visual grid system to represent and perform rhythmic
  patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20549-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm grids are a useful way of notating music for percussionists."@en ;
  dcterms:modified "2026-06-07T15:30:29.288770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20549-3
  a curric:KeyLearningPoint ;
  rdfs:label "A steady pulse is important when playing a rhythm grid as it helps keep in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.288774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20549-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can create an ostinato by repeating rhythm grid patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.288780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stave notation can tell us the rhythms and pitches used in a melody, which we can
  use to help us perform it accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20600-2
  a curric:KeyLearningPoint ;
  rdfs:label """A rhythmic ostinato is a repeating pattern of sounds that can be clapped or played
  on a percussion instrument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20600-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can select different rhythms to compose a rhythmic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.288794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20600-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythmic ostinati can be played as an accompaniment to a sung melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.288798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20565-1
  a curric:KeyLearningPoint ;
  rdfs:label "Improvising is creating music in the moment, alone or with others."@en ;
  dcterms:modified "2026-06-07T15:30:29.288965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20565-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can improvise actions to songs, new lyrics and responses, rhythms and
  melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Improvising allows us to freely explore and try out musical ideas, and to respond to
  these in the moment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20565-4
  a curric:KeyLearningPoint ;
  rdfs:label "The notes of the major pentatonic scale are do, re, mi, so, la."@en ;
  dcterms:modified "2026-06-07T15:30:29.288976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20565-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ta-mi is a one-beat dotted pattern that consisting of a longer duration note
  followed by a shorter duration note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20611-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sound sense of pulse is essential when singing rounds and partner songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.289001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20611-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body percussion and actions can help us feel the pulse and stay in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.289005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20611-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pitch actions and hand signs help us learn melodies, before playing them on
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20611-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch notation can be read on a stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.289012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20624-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can create melodic cells that compliment each other with a similar melodic shape
  but different rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20624-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using notes of a longer duration creates a slower feeling rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.289112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20624-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using notes of a shorter duration creates a faster feeling rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.289116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20624-4
  a curric:KeyLearningPoint ;
  rdfs:label """As composers, we can select instruments for their timbre when deciding the
  instrumentation for a new piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20599-1
  a curric:KeyLearningPoint ;
  rdfs:label "Musical notes are written on a stave, which tells us the pitch of the notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.289365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20599-2
  a curric:KeyLearningPoint ;
  rdfs:label "Higher notes are higher up on the stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.289369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Improvising means creating music in the moment using the voice or instruments, alone
  or with others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20599-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can add pitches to a rhythmic composition using improvisation."@en ;
  dcterms:modified "2026-06-07T15:30:29.289376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20562-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pentatonic scales are found in many ancient civilisations."@en ;
  dcterms:modified "2026-06-07T15:30:29.289509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20562-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many folk songs around the world use the notes of the major pentatonic scale."@en ;
  dcterms:modified "2026-06-07T15:30:29.289513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20562-3
  a curric:KeyLearningPoint ;
  rdfs:label "The major pentatonic scale uses five notes. We call these do, re, mi, so, la."@en ;
  dcterms:modified "2026-06-07T15:30:29.289517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20562-4
  a curric:KeyLearningPoint ;
  rdfs:label """The sound of the major pentatonic scale might be described as bright, happy, light
  or joyous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20562-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hand signs can be used to show different notes in a melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.289524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20551-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes can have shorter or longer durations. When we combine these we create
  rhythms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20551-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can subdivide the beat on a rhythm grid to help us decode, play and notate
  rhythms successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20551-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chanting Takadimi can help us work out how to read and play rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.289536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20551-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we layer different rhythm patterns, we create a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.289539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20557-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can hear the texture become thicker as each layer of sound is added one at a
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20557-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding instruments with different timbres can make the texture more interesting."@en ;
  dcterms:modified "2026-06-07T15:30:29.289572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20557-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can layer riffs or ostinati to make the texture thicker as an accompaniment to
  our songs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20557-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the steady pulse helps us to play different layers of sound in time
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20538-1
  a curric:KeyLearningPoint ;
  rdfs:label "The rhythm is the pattern of the lyrics we sing or chant."@en ;
  dcterms:modified "2026-06-07T15:30:29.289601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20538-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can work out the rhythm of a word using syllables."@en ;
  dcterms:modified "2026-06-07T15:30:29.289605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20538-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation can be used to notate rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.289608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20538-4
  a curric:KeyLearningPoint ;
  rdfs:label "Takadimi is a rhythm where there are four equal sounds within one beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.289612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20538-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unpitched percussion instruments can be used to highlight rhythms in a song or
  chant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20563-1
  a curric:KeyLearningPoint ;
  rdfs:label """The notes of the major pentatonic scale can be used to form melodies in folk
  songs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20563-2
  a curric:KeyLearningPoint ;
  rdfs:label "The notes of the major pentatonic scale are do, re, mi, so, la."@en ;
  dcterms:modified "2026-06-07T15:30:29.290309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ta-mi is a one-beat rhythm pattern consisting of a longer duration note followed by
  a shorter duration note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20563-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Ta-mi rhythm pattern has a slight galloping feel to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.290317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20612-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a rhythmic ostinato under a song creates another layer of texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.290377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20612-2
  a curric:KeyLearningPoint ;
  rdfs:label "Playing a rhythmic ostinato can help us keep in time to the steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.290381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20612-3
  a curric:KeyLearningPoint ;
  rdfs:label "A rhythmic ostinato can be inspired by rhythms from a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.290388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20612-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhythmic ostinato can be layered under partner songs to create a thicker
  texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20612-5
  a curric:KeyLearningPoint ;
  rdfs:label "Takadimi notation helps us read rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.290398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20622-1
  a curric:KeyLearningPoint ;
  rdfs:label "A repeating cell can form the structure of a minimalist composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.290676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20622-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ostinato is an Italian word meaning obstinate and describes a musical phrase or
  rhythm that is repeated persistently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20622-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a piece of minimalist music to inspire a new composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.290684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20622-4
  a curric:KeyLearningPoint ;
  rdfs:label "Taka-mi is a new rhythm to us, with a one beat short-long-short rhythm pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.290690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20590-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nada Brahma, in Indian philosophy, means God is sound or the universe is sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.293366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20590-2
  a curric:KeyLearningPoint ;
  rdfs:label "The drone is the constant sound that runs through Hindustani classical music."@en ;
  dcterms:modified "2026-06-07T15:30:29.293370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20590-3
  a curric:KeyLearningPoint ;
  rdfs:label "The drone symbolises the idea of Nada Brahma - the fundamental constant sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.293374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20590-4
  a curric:KeyLearningPoint ;
  rdfs:label """The three main components of Hindustani classical music are taal, raag, and
  drone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20590-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can clap and tap the taal, play a melody and improvise in the raag, and sing and
  hold a drone note."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Improvising is creating music in the moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.294377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20588-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Hindustani classical music, we can only improvise using the notes in the
  raag."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Improvisation does not need to be complicated and using fewer notes can effectively
  convey a feeling or emotion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20588-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we play a raag, we can add an emotion we want the listener to hear and feel.
  This is called ras or rasa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20588-5
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the tempo and the dynamics of our playing can give the music a different
  feel or emotion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20587-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a raag, aaroh is the name the ascending notes and avroh is the name for the
  descending notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20587-2
  a curric:KeyLearningPoint ;
  rdfs:label "Raags can be played and sung - or both."@en ;
  dcterms:modified "2026-06-07T15:30:29.294474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20587-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing the notes in a raag using the sargam. The notes are Sa, Re, Ga, ma, Pa,
  Dha, Ni."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sa, Re, Ga, ma, Pa, Dha, Ni can be played on C, D, E, F, G, A, B on our
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20589-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can develop the texture of our piece by layering the taal and the raag."@en ;
  dcterms:modified "2026-06-07T15:30:29.295312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20589-2
  a curric:KeyLearningPoint ;
  rdfs:label "The bols and the claps of the taal are a steady pulse we can layer a raag over."@en ;
  dcterms:modified "2026-06-07T15:30:29.295316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20589-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can add the raag by singing a melody and playing improvisations that use the
  notes of the raag."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The taal and raag don’t have to start at the same time. A raag can start halfway
  through the rhythm cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20578-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing together helps us prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.297274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20578-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can learn strategies that help us work together as an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.297278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20578-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can add multiple layers of sound to build a more complex accompaniment for a
  song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20578-4
  a curric:KeyLearningPoint ;
  rdfs:label """We need to consider the dynamic balance to make sure the accompaniment does not take
  over the main melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20594-1
  a curric:KeyLearningPoint ;
  rdfs:label """Playing in an ensemble requires a shared sense of pulse, confident part playing and
  an awareness of the whole sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practising in parts first can help us to perform our part accurately and confidently
  as part of an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20594-3
  a curric:KeyLearningPoint ;
  rdfs:label """Successful rehearsal strategies include ‘chunking’, practising the start and
  thinking about appropriate dynamics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20554-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation is one way of representing different rhythms on a rhythm grid."@en ;
  dcterms:modified "2026-06-07T15:30:29.301706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20554-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective compositions make use of simple, memorable ideas and repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.301710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20554-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythms are built up of notes of differing durations."@en ;
  dcterms:modified "2026-06-07T15:30:29.301714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20673-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers use the elements of music to vary the theme in lots of different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.302849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20673-2
  a curric:KeyLearningPoint ;
  rdfs:label """A composer might alter the pitch, rhythm, tonality, timbre, dynamics or tempo in a
  variation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20673-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tonality is the organisation of notes around a central note, the tonic, which helps
  to shape the music’s sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20673-4
  a curric:KeyLearningPoint ;
  rdfs:label "These changes affect the sound, mood and feel of the music in each variation."@en ;
  dcterms:modified "2026-06-07T15:30:29.302861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20669-1
  a curric:KeyLearningPoint ;
  rdfs:label "Theme and variations is a type of musical structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.302951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20669-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a short, recognisable melody that is the main musical idea for a
  composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each variation is based on the original theme but changed slightly in one or more
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20669-4
  a curric:KeyLearningPoint ;
  rdfs:label """The orchestra is made up of four main sections: strings, woodwind, brass and
  percussion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20671-1
  a curric:KeyLearningPoint ;
  rdfs:label "Theme and variations is a type of musical structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.303050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers can use different instrumentation to alter the timbre and character of the
  theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20671-3
  a curric:KeyLearningPoint ;
  rdfs:label "A rhythmic variation is when the rhythm of the original theme is altered."@en ;
  dcterms:modified "2026-06-07T15:30:29.303060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20671-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can still recognise the theme in a rhythmic variation as the melody is
  the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20670-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can usually recognise aspects of the original theme when you listen to a
  variation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20670-2
  a curric:KeyLearningPoint ;
  rdfs:label """When composing variations, composers might change the rhythm, the melody or the
  tonality of the theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20670-3
  a curric:KeyLearningPoint ;
  rdfs:label """A glockenspiel is played with mallets and the best sound is achieved when striking
  the centre of the bar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20670-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can play a theme accurately using pitch and rhythm notation."@en ;
  dcterms:modified "2026-06-07T15:30:29.303694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20574-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we sing, we string together a series of high and low notes to create a
  melody."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20574-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hand signs help us identify the shape of a melody, if it is ascending or descending,
  moving in step or in leaps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20574-3
  a curric:KeyLearningPoint ;
  rdfs:label """The major pentachord is the first five notes of the major scale: do, re, mi,
  fa, so."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20574-4
  a curric:KeyLearningPoint ;
  rdfs:label "Songs with a major tonality are organised around the central note, do."@en ;
  dcterms:modified "2026-06-07T15:30:29.303955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20574-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can add a drone to accompany folk songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.303960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20543-1
  a curric:KeyLearningPoint ;
  rdfs:label """Playground singing games are often short, memorable folk songs that are passed down
  orally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20543-2
  a curric:KeyLearningPoint ;
  rdfs:label """Playground singing games are often unaccompanied so that they can be played
  anywhere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20543-3
  a curric:KeyLearningPoint ;
  rdfs:label """Playground games can help us connect with one another and can help to build a happy
  community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A major scale is a group of notes centered around the note do, which often sound
  bright when used to create melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20598-2
  a curric:KeyLearningPoint ;
  rdfs:label """The major pentachord is the first five notes of the major scale: do, re, mi, fa and
  so."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solfège is a system of naming pitches so we can recognise musical patterns
  by ear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20598-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can play songs using the major pentachord with a pitched percussion instrument,
  like the xylophone or glockenspiel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20598-5
  a curric:KeyLearningPoint ;
  rdfs:label """When we are learning to play a melody, we should play slowly and at a steady
  tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20546-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we sing together, we can feel a sense of connectedness and belonging in our
  communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20546-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singing in unison is an important part of sports fans celebrating victories and
  creating a shared identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20546-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singing in a crowd can feel powerful and emotional for the listener and the
  participant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20546-4
  a curric:KeyLearningPoint ;
  rdfs:label "People use singing to express joy and to feel joy."@en ;
  dcterms:modified "2026-06-07T15:30:29.304816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20546-5
  a curric:KeyLearningPoint ;
  rdfs:label """Singing releases feel-good chemicals in the brain and can help us feel calm and
  happy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20570-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can add more partner songs to a piece to thicken the texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.304848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each partner song must be sung to the same steady beat in order for them to fit
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20570-3
  a curric:KeyLearningPoint ;
  rdfs:label "Following the conductor shows us a visual pulse to follow."@en ;
  dcterms:modified "2026-06-07T15:30:29.304858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singing confidently but not loudly helps us to keep focused on our partner song and
  not be distracted by the other tunes"""@en ;
  dcterms:modified "2026-06-07T15:30:29.304864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20660-1
  a curric:KeyLearningPoint ;
  rdfs:label "In jazz, the head is followed by a series of improvisations."@en ;
  dcterms:modified "2026-06-07T15:30:29.304871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20660-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although improvising is making music in-the-moment, considering the elements can
  help create a stylistic improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Practising is skill and there are many strategies you can use to improve your time
  spent practising."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20640-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can identfy offbeats in a bar whilst counting and clapping."@en ;
  dcterms:modified "2026-06-07T15:30:29.305032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Syncopated music can give us a sense of movement, grab our attention, or add an
  interesting groove to a piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation can be played on any instrument including the voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.305039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20640-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can play and sing different syncopated rhythms layered over each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.305043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20662-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jazz music is often structured like a musical sandwich."@en ;
  dcterms:modified "2026-06-07T15:30:29.305159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20662-2
  a curric:KeyLearningPoint ;
  rdfs:label "The head opens and closes the piece, with improvisations in the middle."@en ;
  dcterms:modified "2026-06-07T15:30:29.305162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20662-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bars in 4-time can be counted as 1 2 3 4, 2 2 3 4, 3 2 3 4, 4 2 3 4 ..."@en ;
  dcterms:modified "2026-06-07T15:30:29.305166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Improvisation is creative, in-the-moment musical composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.305173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20662-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, there are many parts to an improvised performance that can be
  rehearsed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jazz grew from the music and experiences of enslaved Africans and their
  descendants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jazz blends African music traditions with European instruments and newer American
  influences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Syncopation can be used to make the same melody sound and feel very different."@en ;
  dcterms:modified "2026-06-07T15:30:29.305649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20642-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can take inspiration from jazz to create short syncopated rhythms using scat
  singing and improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20639-1
  a curric:KeyLearningPoint ;
  rdfs:label """Each bar of music has ‘strong’ and ‘weak’ beats. Syncopated rhythms emphasise beats
  that are usually weaker."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20639-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are many ways to create syncopation."@en ;
  dcterms:modified "2026-06-07T15:30:29.305697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20639-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can demonstrate ‘backbeat’ syncopation by clapping on beats 2 and 4 of a
  four-beat bar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20639-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can clap and play syncopated rhythms which place emphasis on offbeats as well as
  the weak beats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20626-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effective practice and rehearsal will likely lead to a more successful
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20626-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we rehearse together, it is helpful to think about our rehearsal techniques and
  how we work effectively together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful ensemble players will fully understand their role in an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.305717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Receiving feedback can be a helpful way to try new things and make improvements."@en ;
  dcterms:modified "2026-06-07T15:30:29.305721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Performing can help you realise where your strengths and weaknesses in a
  piece lie."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20568-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two or more songs can fit together musically.  We call these partner songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.305824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20568-2
  a curric:KeyLearningPoint ;
  rdfs:label "For partner songs to fit together, they should be sung to the same steady beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.305829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20568-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the pulse helps each group stay together and enables the two songs to sound
  good together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20568-4
  a curric:KeyLearningPoint ;
  rdfs:label "Layering up partner songs together is a way of building texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.305837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music can often be identified as fitting within a certain genre by its key
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20621-2
  a curric:KeyLearningPoint ;
  rdfs:label "Minimalism consists of short, repetitive musical cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.305901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20621-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ostinato is a musical phrase or rhythm that is repeated persistently."@en ;
  dcterms:modified "2026-06-07T15:30:29.305905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20621-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are the building blocks (structure) of a minimalist piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.305909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20621-5
  a curric:KeyLearningPoint ;
  rdfs:label "The use of repetition in music is an effective musical tool."@en ;
  dcterms:modified "2026-06-07T15:30:29.305913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20572-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to warm up before a performance as it helps us to feel like we’re
  performing as an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20572-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing helps us feel confident and prepared, so we are ready to perform our
  best."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20572-3
  a curric:KeyLearningPoint ;
  rdfs:label """Watching the conductor is important because they help us follow the steady pulse and
  keep us together in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20572-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performances should be engaging and accurate because we want the audience to see the
  best work we can do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20553-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music is organised into the feeling of beats, giving it, for example, a
  strong-weak-weak feel if in 3-time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20553-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation can be used on rhythm grids to notate rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.305977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20553-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes of different durations are combined to create rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.305981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20553-4
  a curric:KeyLearningPoint ;
  rdfs:label "Takadi and Ta-dimi both have three sounds, but in different duration orders."@en ;
  dcterms:modified "2026-06-07T15:30:29.305985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20661-1
  a curric:KeyLearningPoint ;
  rdfs:label """A jazz piece begins with a head played by all instruments. Improvisations then
  follow this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20661-2
  a curric:KeyLearningPoint ;
  rdfs:label """A new arrangement of a piece can be created by changing or adding to the
  instrumentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Improvising with a call and response structure in mind can help to organise an
  improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20661-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is helpful to perform in front of an audience to receive effective feedback."@en ;
  dcterms:modified "2026-06-07T15:30:29.306003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20643-1
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the pulse helps us to play the syncopated rhythms accurately and
  precisely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20643-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can prepare for a performance by thinking about how we will present our music to
  an audience and being organised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20643-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve our ensemble skills by rehearsing together focusing accuracy,
  synchronisation and balance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up our voice, minds and bodies helps us deliver a focused, safe, and
  engaging performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20644-2
  a curric:KeyLearningPoint ;
  rdfs:label "Feeling the pulse is key to neat ensemble performing."@en ;
  dcterms:modified "2026-06-07T15:30:29.306619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20644-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we evaluate and reflect on our performance, we become more aware of the skills
  we've developed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20641-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many drums played in West Africa, inclduing the dundunba, sangban, and
  kenkeni forming the mande drum enemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Kuku is a rhythm from Guinea that can be played on two or more drums."@en ;
  dcterms:modified "2026-06-07T15:30:29.306632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20641-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use rhythm grids to decode syncopated rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.306638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20641-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing to a syncopated accmpaniment."@en ;
  dcterms:modified "2026-06-07T15:30:29.306642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20623-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music can be notated in many ways. The best form of notation is the most effective
  for reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20623-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cells can be rhythmic or melodic."@en ;
  dcterms:modified "2026-06-07T15:30:29.306818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20623-3
  a curric:KeyLearningPoint ;
  rdfs:label "A drone is a type of ostinato or cell."@en ;
  dcterms:modified "2026-06-07T15:30:29.306822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the order of cells entries and exits creates a structure for your
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20623-5
  a curric:KeyLearningPoint ;
  rdfs:label """When cells are layered, they create a thicker texture and a more complex piece of
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20591-1
  a curric:KeyLearningPoint ;
  rdfs:label """Folk music is music that originates from a particular country, culture or people and
  is usually passed down orally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20591-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of techniques to help us to practise effectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.307346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20591-3
  a curric:KeyLearningPoint ;
  rdfs:label "A song can be internalised more easily by learning it in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.307350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20591-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can speak the lyrics, tap the rhythm and perform sections in different styles
  such as using staccato or legato."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27383-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can explore characters by thinking which body part they lead from when
  they move."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27383-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use different singing techniques to change the vocal timbre to suit a
  different character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27383-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the articulation, for example, from legato to staccato, can change the mood
  and atmosphere of the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27383-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding body percussion can add another level of characterisation and can be
  performed 'in character' too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20631-1
  a curric:KeyLearningPoint ;
  rdfs:label "A film score is original music written specifically to accompany a film."@en ;
  dcterms:modified "2026-06-07T15:30:29.308298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing is an important part of preparing for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.308302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20631-3
  a curric:KeyLearningPoint ;
  rdfs:label "A film score creates the atmosphere and brings to life the images in the film."@en ;
  dcterms:modified "2026-06-07T15:30:29.308306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20631-4
  a curric:KeyLearningPoint ;
  rdfs:label """Music that includes improvisation is performed in the moment and will alter slightly
  each time it is performed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a countermelody is a way of creating harmony and building texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.308314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20620-2
  a curric:KeyLearningPoint ;
  rdfs:label "Do, mi, so work really well together when building harmonies."@en ;
  dcterms:modified "2026-06-07T15:30:29.308318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Live performances engage an audience and connect with their emotions more readily
  than recorded music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20620-4
  a curric:KeyLearningPoint ;
  rdfs:label "Live performances can help audiences feel a sense of wellbeing and belonging."@en ;
  dcterms:modified "2026-06-07T15:30:29.308326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20627-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before music so that our bodies, minds and voices are ready to
  learn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20627-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beatboxing is a form of vocal percussion that uses the mouth, lips, tongue and
  voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20627-3
  a curric:KeyLearningPoint ;
  rdfs:label """The art of beatboxing involves mimicry of sounds, including that of a drum
  machine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of sounds that are often imitated by beatboxers include kick drum, hi-hat
  and snare drum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20608-1
  a curric:KeyLearningPoint ;
  rdfs:label "So, mi and do create pleasing harmony when sung at the same time."@en ;
  dcterms:modified "2026-06-07T15:30:29.308379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20608-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can layer a harmony part and a rhythmic ostinato to add a thicker texture to our
  to our songs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20608-3
  a curric:KeyLearningPoint ;
  rdfs:label "Singing partner songs together can create harmony."@en ;
  dcterms:modified "2026-06-07T15:30:29.308387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20539-1
  a curric:KeyLearningPoint ;
  rdfs:label """An ostinato is a short, repeating pattern in music. It can be rhythmic or
  melodic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20539-2
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato is memorable and can add interest to a piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.308757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20539-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we perform an ostinato with a chant, we create musical texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.308761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20539-4
  a curric:KeyLearningPoint ;
  rdfs:label """Musical texture describes the different layers that are happening at the same time
  in a piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20539-5
  a curric:KeyLearningPoint ;
  rdfs:label """Takadi is a rhythm where there are three sounds within one beat and the first two
  sounds are shorter than the third."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up together is a form of social bonding as well as protecting our voice and
  developing our choral skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20615-2
  a curric:KeyLearningPoint ;
  rdfs:label """Social bonding is about making positive connections with others and can be achieved
  through singing in unison together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20615-3
  a curric:KeyLearningPoint ;
  rdfs:label """Listening carefully to those singing around us as we sing can help us create a
  blended and balanced choral sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20617-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are choirs to suit nearly every style and they are a brilliant way of bringing
  communities together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20617-2
  a curric:KeyLearningPoint ;
  rdfs:label "Singing in harmony can help us create a rich choral sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.309132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20617-3
  a curric:KeyLearningPoint ;
  rdfs:label "Do, mi and so sound great when combined to form harmony."@en ;
  dcterms:modified "2026-06-07T15:30:29.309136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20617-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can add shape to a song by altering the dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:29.309140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20617-5
  a curric:KeyLearningPoint ;
  rdfs:label "To sound like a choir, we need to work together to blend and balance our sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.309144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20632-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a variety of vocal percussion timbres to mimic sounds in nature."@en ;
  dcterms:modified "2026-06-07T15:30:29.309148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20632-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use different dynamics, timbres and textures to create an effective score for
  a film."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20632-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can evaluate what is good about our performance and improve on some aspects that
  could be even better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20632-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can rehearse effectively to refine our performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.309162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27382-1
  a curric:KeyLearningPoint ;
  rdfs:label """By breaking a song’s structure into sections, we can better understand its story and
  decide how to stage each part."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27382-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can follow the rise and fall of pitch by reading a musical score."@en ;
  dcterms:modified "2026-06-07T15:30:29.309226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27382-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using gestures can help us to sing legato."@en ;
  dcterms:modified "2026-06-07T15:30:29.309230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27382-4
  a curric:KeyLearningPoint ;
  rdfs:label "How we move and how we sing can combine for effective storytelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.309234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27382-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can reflect on our performance to assess how clearly we've conveyed a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.309238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20540-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple way to create an ostinato is to use rhythms from a song or chant."@en ;
  dcterms:modified "2026-06-07T15:30:29.309373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20540-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using stick notation is one way of notating an ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.309380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20540-3
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato can make an effective accompaniment to our singing."@en ;
  dcterms:modified "2026-06-07T15:30:29.309384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20540-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a rhythmic ostinato as we sing a song adds texture and interest to our
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20537-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we sing, play, or listen to music, we can feel the steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.309482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20537-2
  a curric:KeyLearningPoint ;
  rdfs:label """A steady pulse is important in music because it helps keep us in time as we sing or
  play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20537-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we show or sound the pulse, it is called the beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.309492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20537-4
  a curric:KeyLearningPoint ;
  rdfs:label """The beat can be sounded using instruments or body percussion, or shown with actions
  and movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20618-1
  a curric:KeyLearningPoint ;
  rdfs:label "Do is moveable - it can be on any note."@en ;
  dcterms:modified "2026-06-07T15:30:29.310133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20618-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singing can sometimes make us nervous, but it is also brilliant at boosting our
  confidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20618-3
  a curric:KeyLearningPoint ;
  rdfs:label "Singing gives us an opportunity to express ourselves and be creative."@en ;
  dcterms:modified "2026-06-07T15:30:29.310143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20618-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different combinations of notes creates different kinds of harmony."@en ;
  dcterms:modified "2026-06-07T15:30:29.310147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20606-1
  a curric:KeyLearningPoint ;
  rdfs:label "A rhythmic ostinato is a repeating musical idea created from a rhythmic pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.310370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20606-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can create and perform a rhythm ostinato using ta and ta-di while singing
  a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20606-3
  a curric:KeyLearningPoint ;
  rdfs:label """A round is a song structure where multiple groups sing the same melody but start at
  different times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20606-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rounds can be sung in two or more parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.310382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20619-1
  a curric:KeyLearningPoint ;
  rdfs:label """Melodies do not need to be complicated. They can use simple rhythms and just a few
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20619-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective song melodies will use repetition of ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.310390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20619-3
  a curric:KeyLearningPoint ;
  rdfs:label "Do, mi and so work really well together to create pleasing melodies."@en ;
  dcterms:modified "2026-06-07T15:30:29.310394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20619-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notation needs to be written carefully and spaced out thoughtfully in order for it
  to be read easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27381-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can read music notation by following the melodic shape of the melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.310788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27381-2
  a curric:KeyLearningPoint ;
  rdfs:label """When two or more harmony parts have distinct melodies that move at different times,
  this creates a polyphonic texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27381-3
  a curric:KeyLearningPoint ;
  rdfs:label """Listening carefully to the other part when singing in harmony helps us to balance
  our parts together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27381-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can apply the character building blocks to help us to stage a scene."@en ;
  dcterms:modified "2026-06-07T15:30:29.310803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27385-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsal requires patience, creativity and repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.310919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27385-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use our bodies and the space in different ways, and with different energy,
  depending on the feel of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27385-3
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up our bodies and voices can boost our performance because we’re focused and
  physically prepared to perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27385-4
  a curric:KeyLearningPoint ;
  rdfs:label """If we are focused and enjoying our performance, it helps an audience feel relaxed
  watching it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27385-5
  a curric:KeyLearningPoint ;
  rdfs:label """Receiving feedback can help us see what we’re doing well and where we can make
  improvements to our performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20652-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music has been used to express how people feel about migration and leaving loved
  ones behind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lyrics and music can convey powerful emotions and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.310948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20652-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use different vocal and expressive techniques to communicate the emotion of
  the lyrics to an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27384-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our bodies and our voice to convey a character and their mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.311060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocal timbre and diction can be used to create a singing quality to suit the
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27384-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use lip trills, sirening, open vowel sounds and movement to access our higher
  singing voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27384-4
  a curric:KeyLearningPoint ;
  rdfs:label "Teamwork and compromise are key elements to a successful rehearsal."@en ;
  dcterms:modified "2026-06-07T15:30:29.311078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27384-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a scene by applying the building blocks to tell the story of our
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20630-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sounds in nature can be mimicked using the voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.312735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sound effects, such as altering the direction of sound, can be used to create
  interest and contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20630-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can create music in the moment, using the voice or instruments, alone or with
  others. This is called improvisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Building up a performance of different textures requires rehearsal, evaluation and
  improvement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20616-1
  a curric:KeyLearningPoint ;
  rdfs:label "Singing releases ‘happy’ hormones in our body that help to make us feel good."@en ;
  dcterms:modified "2026-06-07T15:30:29.313029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20616-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singing is good for our health. It improves our lung capacity and helps improve our
  memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hand signs and pitch actions can help us understand the shape of a melody and sing
  in tune."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Do, mi, so are all copycats; they are either all on lines or all in the spaces when
  written on stave notation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20649-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ensembles need to rehearse together to be able to perform together successfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.319336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Playing in an ensemble is an excellent way to develop our musical skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.319340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20649-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polyrhythms can be used to accompany a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.319346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20649-4
  a curric:KeyLearningPoint ;
  rdfs:label "We need to balance our sound when performing in an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.319351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different rhythms can be layered and played at the same time, this creates
  polyrhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20647-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Poly’ is Greek for ‘many’, so polyrhythms means ‘many rhythms.’"@en ;
  dcterms:modified "2026-06-07T15:30:29.331816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20647-3
  a curric:KeyLearningPoint ;
  rdfs:label """Combining on-beat and off-beat rhythm patterns creates an interesting
  polyrhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20647-4
  a curric:KeyLearningPoint ;
  rdfs:label "One way to notate polyrhythms is on a rhythm grid."@en ;
  dcterms:modified "2026-06-07T15:30:29.331826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20650-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing together makes sure that everybody knows their part in the ensemble and
  when to play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20650-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing together is a skill that can be developed."@en ;
  dcterms:modified "2026-06-07T15:30:29.331894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20650-3
  a curric:KeyLearningPoint ;
  rdfs:label """Performing to a small audience gives you the opportunity to develop your performance
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20648-1
  a curric:KeyLearningPoint ;
  rdfs:label "The lyrics and phrases of a song can be used to create a rhythmic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.331949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20648-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple rhythmic ostinati can be layered to create a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.331976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layering 'on-beat; and offbeat rhythms creates a polyrhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.331981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Having a strong feeling of the pulse helps us to perform syncopated rhythms more
  successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20646-2
  a curric:KeyLearningPoint ;
  rdfs:label "A syncopated phrase can become a rhythmic ostinato to create interest."@en ;
  dcterms:modified "2026-06-07T15:30:29.332026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20646-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a rhythmic ostinato creates another layer of sound and a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.332030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20585-1
  a curric:KeyLearningPoint ;
  rdfs:label """The three key components of Hindustani classical music are taal, raag, and
  drone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20585-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main instruments used are the tabla, the sitar, and the tanpura."@en ;
  dcterms:modified "2026-06-07T15:30:29.337891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20585-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can speak the rhythm cycles of the taals by using the bols, which sound like the
  drum sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20585-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can clap and wave the rhythm cycles which can help keep us in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.337899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20645-1
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up for music lessons protects and strengthens our voice as well as helps to
  develop other music skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20645-2
  a curric:KeyLearningPoint ;
  rdfs:label "Clapping on the offbeat or weak beats is a form of syncopation."@en ;
  dcterms:modified "2026-06-07T15:30:29.343074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20645-3
  a curric:KeyLearningPoint ;
  rdfs:label """Having a strong feeling of the pulse helps us to perform syncopated rhythms more
  successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20645-4
  a curric:KeyLearningPoint ;
  rdfs:label "Songs can contain syncopated phrases to help emphasise the lyrics."@en ;
  dcterms:modified "2026-06-07T15:30:29.343082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20609-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to warm up the voice and body to prepare for singing and to help
  keep the voice strong and healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20609-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we sing the same thing at the same time, we are singing in unison."@en ;
  dcterms:modified "2026-06-07T15:30:29.352536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rounds help develop part-singing in a simple way. The same melody fits together at
  different times to create harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20609-4
  a curric:KeyLearningPoint ;
  rdfs:label """Partner songs help develop part-singing in a simple way. The two songs work together
  to create a pleasing harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20609-5
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the structure of a song helps us sing together successfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.352548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20596-1
  a curric:KeyLearningPoint ;
  rdfs:label """The most effective rehearsals are when many different rehearsal strategies are used
  to improve a final performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20596-2
  a curric:KeyLearningPoint ;
  rdfs:label """Feedback from others and evaluating our own performance is a key element to refining
  a performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20596-3
  a curric:KeyLearningPoint ;
  rdfs:label """I can reflect on the practice and rehearsal strategies that have helped me perform
  successfully in an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29932-1
  a curric:KeyLearningPoint ;
  rdfs:label """Programme music is music that has been inspired by something non-musical. For
  example, a story or a piece of artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29932-2
  a curric:KeyLearningPoint ;
  rdfs:label """Absolute music is music that is not inspired by anything else. It focuses just on
  the notes the composer wishes to use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29932-3
  a curric:KeyLearningPoint ;
  rdfs:label """A movement is a self-contained section of a large-scale musical composition, like a
  chapter in a book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29932-4
  a curric:KeyLearningPoint ;
  rdfs:label """A symphonic work is a large-scale musical composition with distinct movements
  (usually four)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29932-5
  a curric:KeyLearningPoint ;
  rdfs:label """Deep Field composed by Eric Whitacre is a symphonic work in four movements that is
  an example of programme music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29935-1
  a curric:KeyLearningPoint ;
  rdfs:label """Programme music is music that has been inspired by something non-musical. For
  example, a story or a piece of artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29935-2
  a curric:KeyLearningPoint ;
  rdfs:label """Deep Field composed by Eric Whitacre is a symphonic work in four movements that is
  an example of programme music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29935-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of music can be inspired and built from one small musical idea. Eric
  Whitacre calls this a ‘golden brick'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Music can be mapped as we listen to help us make sense of the musical journey and
  its structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29974-1
  a curric:KeyLearningPoint ;
  rdfs:label """An effective film score will help us understand and deepen connections with a
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29974-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a motif in a film score helps to strengthen the understanding of the narrative
  through the music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29974-3
  a curric:KeyLearningPoint ;
  rdfs:label """The motifs in film scores from the Planet Earth series help bring the characters in
  the documentaries to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29974-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motif can be developed and built on to create a bigger piece."@en ;
  dcterms:modified "2026-06-07T15:30:29.364470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29976-1
  a curric:KeyLearningPoint ;
  rdfs:label """A film score is an effective tool for adding emotion, tension and drama to a visual
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29976-2
  a curric:KeyLearningPoint ;
  rdfs:label """A motif can be used to represent an idea or emotion and can be developed and built
  on to create a bigger piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29976-3
  a curric:KeyLearningPoint ;
  rdfs:label """We need to think about the structure when scoring so that the film score clearly
  enhances the visual narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29976-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making changes to the elements of music, for example changing tempo, can help to add
  drama and tension to a film score."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29934-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Fibonacci sequence can be shown in a spiral shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.364585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29934-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can find this sequence or its related Fibonacci spiral in nature and art."@en ;
  dcterms:modified "2026-06-07T15:30:29.364589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29934-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence and spiral create a ratio that is approximately ⅔ to ⅓. This is called
  the golden ratio."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29934-4
  a curric:KeyLearningPoint ;
  rdfs:label """The golden ratio can often be heard in music, with the climax of the music at the
  golden ratio point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29934-5
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of music can be inspired and built from one small musical idea. Eric
  Whitacre calls this a ‘golden brick’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29933-1
  a curric:KeyLearningPoint ;
  rdfs:label """Programme music is music that has been inspired by something non-musical. For
  example, a story or a piece of artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Deep Field composed by Eric Whitacre is a symphonic work in four movements that is
  an example of programme music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be mapped as we listen to help us make sense of the musical journey."@en ;
  dcterms:modified "2026-06-07T15:30:29.364663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29933-4
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of music can be inspired and built from one small musical idea. Eric
  Whitacre calls this a ‘golden brick'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music can effectively create a sense of atmosphere, for example, creating feelings
  of tension, danger or drama."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Repeating and adapting a motif throughout a film score can help us to follow a
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29975-3
  a curric:KeyLearningPoint ;
  rdfs:label """We need to think about the structure of the music when scoring so that the music
  clearly enhances the visual narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29973-1
  a curric:KeyLearningPoint ;
  rdfs:label """A film score is an effective tool for adding emotion, tension and drama to a visual
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29973-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Planet Earth series is an award winning documentary that highlights the
  impactfulness of powerful film scores."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29973-3
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a motif that represents something in the narrative helps us associate the
  sound with the visuals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20634-1
  a curric:KeyLearningPoint ;
  rdfs:label "The minor pentachord uses the notes la, ti, do, re and mi."@en ;
  dcterms:modified "2026-06-07T15:30:29.368405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many folk songs are based around the minor pentachord. We can sing and play them on
  a pitched percussion instrument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20634-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing and pay a new rhythm: Taa-di."@en ;
  dcterms:modified "2026-06-07T15:30:29.368413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20634-4
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies can ascend and descend, and use leaps and steps."@en ;
  dcterms:modified "2026-06-07T15:30:29.368417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stave notation can tell us the rhythm and pitch of a melody, which we can use to
  help us perform it accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20636-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can work out the rhythms and pitches using takadimi and solfège note names."@en ;
  dcterms:modified "2026-06-07T15:30:29.368461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20636-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can add to the texture of our music by using a drone as an accompaniment."@en ;
  dcterms:modified "2026-06-07T15:30:29.368465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20635-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stave notation can tell us the rhythm and pitch of a melody, which we can use to
  help us perform it accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20635-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm of notes is the pattern of long and short sounds, and can be represented
  using ‘Takadimi’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20635-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can add pitches to a rhythmic composition using improvisation"@en ;
  dcterms:modified "2026-06-07T15:30:29.368477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20613-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising well prepares us for singing three-part rounds and three partner
  songs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20613-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instrumental melodies can be layered under songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.368484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20613-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sound sense of pulse is essential when combining instrument melodies and singing
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20614-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising is essential to develop musical skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.368612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20614-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding an instrumental melody and rhythmic ostinato to partner songs creates a thick
  texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20614-3
  a curric:KeyLearningPoint ;
  rdfs:label "Every part in an ensemble has an important role."@en ;
  dcterms:modified "2026-06-07T15:30:29.368620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20614-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising skills and rehearsal techniques can be developed."@en ;
  dcterms:modified "2026-06-07T15:30:29.368624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20614-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing together is essential to ensure we are playing in time together and with
  balanced dynamics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20595-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can play and sing our part accurately and confidently as part of a small
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20595-2
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing an ensemble leader can help us to play in time together and begin and end
  at the same moment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20595-3
  a curric:KeyLearningPoint ;
  rdfs:label """In an ensemble, it is important to listen carefully to the overall sound to balance
  and blend each part."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20595-4
  a curric:KeyLearningPoint ;
  rdfs:label """Part of playing in an ensemble is adjusting our own part when needed to help the
  group stay together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20595-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of rehearsal strategies to help us prepare for a performance as
  an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20576-1
  a curric:KeyLearningPoint ;
  rdfs:label "Folk songs can be accompanied or unaccompanied."@en ;
  dcterms:modified "2026-06-07T15:30:29.412773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20576-2
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato can be rhythmic or melodic."@en ;
  dcterms:modified "2026-06-07T15:30:29.412777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20576-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding an ostinato underneath a song adds another layer of sound to the texture of
  the piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20576-4
  a curric:KeyLearningPoint ;
  rdfs:label "We need to consider the dynamic balance when adding accompaniments to songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.412785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20548-1
  a curric:KeyLearningPoint ;
  rdfs:label """Singing together can make both the performers and the audience feel joyful and
  connected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20548-2
  a curric:KeyLearningPoint ;
  rdfs:label "To create a powerful performance, we should stand and breathe like a singer."@en ;
  dcterms:modified "2026-06-07T15:30:29.413077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20548-3
  a curric:KeyLearningPoint ;
  rdfs:label """All music starts and ends with silence. Stand silent and still at the beginning and
  end of a performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20548-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can capture a song’s character by using our voices in different ways and choosing
  dynamics carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20545-1
  a curric:KeyLearningPoint ;
  rdfs:label "People sing together in lots of different communities."@en ;
  dcterms:modified "2026-06-07T15:30:29.413647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20545-2
  a curric:KeyLearningPoint ;
  rdfs:label "Singing as a group can help us connect to our communities."@en ;
  dcterms:modified "2026-06-07T15:30:29.413651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20545-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple folk songs and campfire songs are an important, traditional part of Guiding
  and Scouting communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20545-4
  a curric:KeyLearningPoint ;
  rdfs:label """Songs sung in Guiding and Scouting groups are often folk songs that have been sung
  for generations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20545-5
  a curric:KeyLearningPoint ;
  rdfs:label """A round is a song structure where multiple groups sing the same thing but start at
  different times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20659-1
  a curric:KeyLearningPoint ;
  rdfs:label "The head is a term used when referring to the main theme in jazz music."@en ;
  dcterms:modified "2026-06-07T15:30:29.414768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20659-2
  a curric:KeyLearningPoint ;
  rdfs:label """The head is played by the whole ensemble then followed by individual
  improvisations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20659-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chunking up a melody can help make it easier to learn."@en ;
  dcterms:modified "2026-06-07T15:30:29.414776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20659-4
  a curric:KeyLearningPoint ;
  rdfs:label """A song that uses the D minor pentatonic scale will have phrases that revolve around
  the note D."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20659-5
  a curric:KeyLearningPoint ;
  rdfs:label """When playing barred instruments, focus on how you play the instrument; for example
  striking the bar right in the centre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we sing in parts, we need to balance our dymamics so both parts can be
  heard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20610-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important not to ‘block out’ the sound of harmony parts as you need to hear
  how the music fits together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20610-3
  a curric:KeyLearningPoint ;
  rdfs:label "A sound sense of pulse is essential when singing part-songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.414796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20633-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is essential to warm up the voice before singing to keep it strong and healthy
  and to prevent injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20633-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many songs have a tonal centre, or tonality. Often, this can be described as major
  or minor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20633-3
  a curric:KeyLearningPoint ;
  rdfs:label "Minor tonalities are organised around the note 'la' and are often dark sounding."@en ;
  dcterms:modified "2026-06-07T15:30:29.415241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20593-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the structure of the music can help us to practise the piece in
  sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20593-2
  a curric:KeyLearningPoint ;
  rdfs:label """Binary form is a musical structure that has two sections, usually labeled A and B,
  that are often repeated (as AABB)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20593-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use practice techniques such as exploring different ways to learn to help us
  to play an accompaniment part."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20593-4
  a curric:KeyLearningPoint ;
  rdfs:label """When practising in an ensemble, working together at a slower tempo at first is a
  good strategy to help us to improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20544-1
  a curric:KeyLearningPoint ;
  rdfs:label """Playground singing games are unaccompanied songs that are often inspired by folk
  songs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20544-2
  a curric:KeyLearningPoint ;
  rdfs:label """Playground singing games are shared orally by friends teaching one another in the
  playground."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20544-3
  a curric:KeyLearningPoint ;
  rdfs:label """Children teach one another playground songs in playground communities all over the
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20544-4
  a curric:KeyLearningPoint ;
  rdfs:label "A group of people performing together is called an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.417944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20544-5
  a curric:KeyLearningPoint ;
  rdfs:label """To be a successful ensemble, it is important to look at one another and listen to
  one another and to work as a team."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20658-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jazz music often uses syncopated and swung rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.418300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20658-2
  a curric:KeyLearningPoint ;
  rdfs:label "The D minor pentatonic scale is made up of the five notes D, F, G, A, C."@en ;
  dcterms:modified "2026-06-07T15:30:29.418304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20658-3
  a curric:KeyLearningPoint ;
  rdfs:label "Improvisation means created new musical ideas in-the-moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.418308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20658-4
  a curric:KeyLearningPoint ;
  rdfs:label """Improvising can mean choosing small changes, such as changing from playing on the
  beat to playing on the offbeat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20592-1
  a curric:KeyLearningPoint ;
  rdfs:label """When practising, isolating the tricky parts to practise with purpose is a useful
  strategy to help us improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20592-2
  a curric:KeyLearningPoint ;
  rdfs:label """Slowing the tempo whilst practising is a useful strategy to help achieve rhythmic
  accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20592-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythmic accompaniment plays an important role in an ensemble as it helps to
  keep everyone in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20592-4
  a curric:KeyLearningPoint ;
  rdfs:label "Counting-in will help set a steady tempo and help us maintain a steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.418566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20547-1
  a curric:KeyLearningPoint ;
  rdfs:label """Singing together as a school community can help everyone to feel a sense of
  belonging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20547-2
  a curric:KeyLearningPoint ;
  rdfs:label """To create an effective performance, it is important to think carefully about the
  character of a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20547-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can choose dynamics such as piano (soft) and forte (loud) to reflect the
  character of a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20566-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compositions can be changed and improved with the music being created over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.419423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20566-2
  a curric:KeyLearningPoint ;
  rdfs:label """Music can be shared by the oral tradition. It can also be notated to be shared and
  remembered for another day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20566-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation is one way to notate our compositions."@en ;
  dcterms:modified "2026-06-07T15:30:29.419435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20566-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing is essential to help us prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.419439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20566-5
  a curric:KeyLearningPoint ;
  rdfs:label """Playing slowly and keeping to the steady pulse is one way to help us to rehearse and
  perform effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20597-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is essential to warm up the voice before singing to keep it strong and healthy
  and to prevent injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20597-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many songs have a tonal centre, or tonality. Often, this can be described as major
  or minor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20597-3
  a curric:KeyLearningPoint ;
  rdfs:label """Major tonalities are organised around the note 'do' and are often bright
  sounding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20597-4
  a curric:KeyLearningPoint ;
  rdfs:label """When describing the character of a melody, I could mention the tonality, its melodic
  shape and other musical elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20657-1
  a curric:KeyLearningPoint ;
  rdfs:label """The minor pentatonic scale is a scale often used in musical genres such as jazz and
  Blues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20657-2
  a curric:KeyLearningPoint ;
  rdfs:label """The minor pentatonic scale is made up of five notes and has a different tonality to
  the major pentatonic scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20657-3
  a curric:KeyLearningPoint ;
  rdfs:label """The minor pentatonic scale uses la, do, re, mi, so. In the D minor pentatonic scale
  this is D, F, G, A, C."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20657-4
  a curric:KeyLearningPoint ;
  rdfs:label "Improvisation is creative, in-the-moment musical composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.419701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20583-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the structure helps us remember a song for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.427716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20583-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can stage a song by considering what the characters want in the song and how to
  make that clear to the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20583-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing helps us make sure that the story we are telling is clear and that we
  feel confident in our parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20583-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on our performance helps us to understand what we've learnt and how we
  can improve for our next performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20584-1
  a curric:KeyLearningPoint ;
  rdfs:label "Performing is sharing our best work with an audience to entertain them."@en ;
  dcterms:modified "2026-06-07T15:30:29.428198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20584-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can convey stories and meanings of songs by the way we sing and perform them."@en ;
  dcterms:modified "2026-06-07T15:30:29.428202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20584-3
  a curric:KeyLearningPoint ;
  rdfs:label "Warming up effectively helps us to be ready to perform"@en ;
  dcterms:modified "2026-06-07T15:30:29.428206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20584-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can put our song in context by using a script"@en ;
  dcterms:modified "2026-06-07T15:30:29.428210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20584-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on our performance help us see how we are developing as musicians and
  performers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20581-1
  a curric:KeyLearningPoint ;
  rdfs:label "Opera is a way of telling stories through singing."@en ;
  dcterms:modified "2026-06-07T15:30:29.428246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20581-2
  a curric:KeyLearningPoint ;
  rdfs:label """Opera brings together dramatic singing, acting, dance, & art to create a
  multi-sensory live experience of storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20581-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our singing voices to convey how our character is feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.428257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20581-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing the words clearly help the audience to understand the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.428261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20581-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can show the relationship between two characters by the way they respond to each
  other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20558-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato can make a tune more memorable."@en ;
  dcterms:modified "2026-06-07T15:30:29.428272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20558-2
  a curric:KeyLearningPoint ;
  rdfs:label "A small number of notes can make an effective ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.428276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20558-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding an ostinato layer to a piece makes the texture thicker."@en ;
  dcterms:modified "2026-06-07T15:30:29.428280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20558-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the steady pulse helps us play our ostinato at the right tempo, and sing and
  play together as an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20559-1
  a curric:KeyLearningPoint ;
  rdfs:label "An effective ostinato can be played on two or three notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.428332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20559-2
  a curric:KeyLearningPoint ;
  rdfs:label "Feeling the steady pulse helps us to play and sing in time together."@en ;
  dcterms:modified "2026-06-07T15:30:29.428337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20559-3
  a curric:KeyLearningPoint ;
  rdfs:label "knowing each part really well helps us to play and sing them simultaneously."@en ;
  dcterms:modified "2026-06-07T15:30:29.428341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20559-4
  a curric:KeyLearningPoint ;
  rdfs:label "With practice, we can sing a different tune to what we’re playing."@en ;
  dcterms:modified "2026-06-07T15:30:29.428345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20560-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can layer a drone, rhythmic ostinati, melodic ostinati, and vocal parts and work
  together as an ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20560-2
  a curric:KeyLearningPoint ;
  rdfs:label "Following a conductor can help keep us in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.428422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20560-3
  a curric:KeyLearningPoint ;
  rdfs:label "The more layers of sound we add, the thicker the texture becomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.428428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20560-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsal helps us to improve by focusing on listening, pulse, following a
  conductor, and our playing technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20560-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accompaniments to songs support the main melody and therefore are played a bit
  quieter to allow the lyrics to be heard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20579-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans have told stories through song for thousands of years."@en ;
  dcterms:modified "2026-06-07T15:30:29.428458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20579-2
  a curric:KeyLearningPoint ;
  rdfs:label """A griot shares family history, stories and knowledge through song and poetry via the
  oral tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20579-3
  a curric:KeyLearningPoint ;
  rdfs:label """The oral tradition is a means of sharing songs by passing them down through singing
  rather than being written down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20579-4
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional ballads tell stories nd have been passed through generations via the
  oral tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20579-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about the meaning of the words when we are singing helps us to communicate
  the story to the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Actors can tell a story or share a character's emotional journey through song"@en ;
  dcterms:modified "2026-06-07T15:30:29.428500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20580-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solo songs often give us information about how a character is feeling"@en ;
  dcterms:modified "2026-06-07T15:30:29.428507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20580-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ensemble songs often tell the story or give us clues about the mood of the story"@en ;
  dcterms:modified "2026-06-07T15:30:29.428514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20580-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can share stories with an audience by understanding the lyrics we're singing"@en ;
  dcterms:modified "2026-06-07T15:30:29.428518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20582-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can develop our characters by showing our moods, feelings and ideas through our
  bodies and our voices"""@en ;
  dcterms:modified "2026-06-07T15:30:29.428576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20582-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can create a thicker texture by singing in a round"@en ;
  dcterms:modified "2026-06-07T15:30:29.428581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20582-3
  a curric:KeyLearningPoint ;
  rdfs:label """A round can be used to show two characters working well together and
  connecting more"""@en ;
  dcterms:modified "2026-06-07T15:30:29.428585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20582-4
  a curric:KeyLearningPoint ;
  rdfs:label """Where and how we stand and sing on stage can make the story more engaging and
  clearer for an audience"""@en ;
  dcterms:modified "2026-06-07T15:30:29.428591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20651-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music has been used as a platform to talk about many different civil rights all
  around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20651-2
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition can be an important tool in creating music so that music and messages can
  be remembered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20651-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition and chanting allow many people to join in, developing a sense of
  connectivity and unity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singing songs that comment on social justice can be more powerful in groups than
  singing alone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20656-1
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition is a powerful tool in creating music so that music and messages can be
  remembered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20656-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can combine different layers of sound to create textures that help our piece to
  have impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20656-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can structure our music to make the message in the music more powerful."@en ;
  dcterms:modified "2026-06-07T15:30:29.430059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20656-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can add dynamics and musical expression to connect and communicate with our
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20655-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use words in different ways. Beat poets composed poems that are often
  spoken over music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20655-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rap artists rhyme in a rhythmical way in time to the music."@en ;
  dcterms:modified "2026-06-07T15:30:29.430551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20655-3
  a curric:KeyLearningPoint ;
  rdfs:label "Music and lyrics can bring hope and inspire."@en ;
  dcterms:modified "2026-06-07T15:30:29.430555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20655-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can be inspired by music and lyrics even when they weren’t written specifically
  for a community we are a part of."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20555-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instruments can be identified by their timbre."@en ;
  dcterms:modified "2026-06-07T15:30:29.433251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20555-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more instruments or layers of sound we add, the thicker the texture becomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.433255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20555-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can add ostinatos and drones to songs to thicken the texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.433259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20555-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feeling the steady pulse helps us to play and sing in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.433263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20654-1
  a curric:KeyLearningPoint ;
  rdfs:label """Singing songs about the past can help us connect emotionally with others and keep
  cultural traditions alive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20654-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers manipulate the elements of music such as timbre and texture, to achieve
  particular effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20654-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can add different layers of music to our piece to create different textures."@en ;
  dcterms:modified "2026-06-07T15:30:29.433558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20556-1
  a curric:KeyLearningPoint ;
  rdfs:label """A drone is a continuous or repeated sound that can be played throughout a piece of
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20556-2
  a curric:KeyLearningPoint ;
  rdfs:label """Drones can be played by many instruments including bagpipes, tanpura, and
  didgeridoos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20556-3
  a curric:KeyLearningPoint ;
  rdfs:label "A drone can accompany a melody to add depth and texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.433669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20556-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can play drones using instruments available to us, including our voices."@en ;
  dcterms:modified "2026-06-07T15:30:29.433675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20586-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Hindustani classical music, a raag is the melodic part of the music."@en ;
  dcterms:modified "2026-06-07T15:30:29.434284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20586-2
  a curric:KeyLearningPoint ;
  rdfs:label """When playing Hindustani classical music, you can only play the notes that belong to
  the raag you are playing in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20586-3
  a curric:KeyLearningPoint ;
  rdfs:label """Raag Bhupali has 5 notes. Different raags have different numbers and combinations of
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20586-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a raag, aaroh is the name of the ascending scale and avaro is the name of the
  descending scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20625-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can experiment with structure, tempo and dynamics to create an effective
  minimalist composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20625-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notation helps us to share music and remember it for another day."@en ;
  dcterms:modified "2026-06-07T15:30:29.434958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Minimalist music can be notated in a variety of ways for effective decoding."@en ;
  dcterms:modified "2026-06-07T15:30:29.434963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20625-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possible notation examples include stave notation, rhythm grids, graphic scores or
  written instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20575-1
  a curric:KeyLearningPoint ;
  rdfs:label """The minor pentachord is the first five notes of the minor scale: la, ti, do,
  re, mi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20575-2
  a curric:KeyLearningPoint ;
  rdfs:label "Folk songs can be accompanied or unaccompanied."@en ;
  dcterms:modified "2026-06-07T15:30:29.436130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a drone underneath a song adds another layer of sound to the texture of the
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20575-4
  a curric:KeyLearningPoint ;
  rdfs:label """To be able to accompany songs effectively, we need to be able to play with a sound
  sense of pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20575-5
  a curric:KeyLearningPoint ;
  rdfs:label "We need to consider the dynamic balance when adding accompaniments to songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.436142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20573-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is essential to warm up the voice before singing to keep it strong and healthy
  and to prevent injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20573-2
  a curric:KeyLearningPoint ;
  rdfs:label "Performing with a sense of character and emotion brings a song to life."@en ;
  dcterms:modified "2026-06-07T15:30:29.436482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20573-3
  a curric:KeyLearningPoint ;
  rdfs:label "The same song can be sung with different character and feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.436487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20573-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singing with different dynamics can change the character of a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.436491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many songs have a tonal centre, or tonality. Often, this can be described as major
  or minor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20577-1
  a curric:KeyLearningPoint ;
  rdfs:label "Folk songs can be accompanied or unaccompanied."@en ;
  dcterms:modified "2026-06-07T15:30:29.436895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20577-2
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato can be rhythmic or melodic."@en ;
  dcterms:modified "2026-06-07T15:30:29.436899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20577-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding an ostinato underneath a song adds another layer of sound to the texture of
  the piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20577-4
  a curric:KeyLearningPoint ;
  rdfs:label "We need to consider the dynamic balance when adding accompaniments to songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.436907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20577-5
  a curric:KeyLearningPoint ;
  rdfs:label "Beats are organised into groups. Rise Up O Flame is in 3-time."@en ;
  dcterms:modified "2026-06-07T15:30:29.436912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20567-1
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up can help develop our sense of pulse as well as protect our voice from
  injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20567-2
  a curric:KeyLearningPoint ;
  rdfs:label """A round is a song structure where the same melody is sung in groups with each group
  beginning at regular intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20567-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are usually two to four groups singing in a round. The more parts there are,
  the thicker the texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20567-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the pulse helps us to sing at the same tempo so that the round is
  successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20571-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing helps us to improve by identifying which parts of our performance needs
  working on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20571-2
  a curric:KeyLearningPoint ;
  rdfs:label """A round is a song structure where the same melody is sung in groups with each group
  beginning at regular intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20571-3
  a curric:KeyLearningPoint ;
  rdfs:label """Partner songs are made up of notes that sound good together. They sound pleasing
  together when sung to a steady beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20571-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to watch the conductor because they show us when to begin singing
  and help us keep in time together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20569-1
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor uses clear hand signals to keep us in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.437668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20569-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen and feel the pulse so our part of the round stays
  in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20569-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can thicken the texture of a song by dividing a round into more parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.437676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20569-4
  a curric:KeyLearningPoint ;
  rdfs:label "We usually sing a round at least the same number of times as there are parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.437680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20653-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instrumental music can be a powerful tool in communicating a powerful message."@en ;
  dcterms:modified "2026-06-07T15:30:29.584719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20653-2
  a curric:KeyLearningPoint ;
  rdfs:label """Music doesn't always have to sound 'nice' to be effective. Dissonance can create
  tension to help tell a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20653-3
  a curric:KeyLearningPoint ;
  rdfs:label "Afrobeat music is a fusion of many different styles and influences."@en ;
  dcterms:modified "2026-06-07T15:30:29.584730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20653-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated riffs can create an effective accompaniment texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.584735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20603-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before we sing in parts, it is important we can keep a steady beat to stay in time
  wth others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20603-2
  a curric:KeyLearningPoint ;
  rdfs:label "In 4-time, the beat pattern feels: strong - weak - medium - weak."@en ;
  dcterms:modified "2026-06-07T15:30:29.586088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20603-3
  a curric:KeyLearningPoint ;
  rdfs:label "Melodic shape describes the up and down movement of pitches in music."@en ;
  dcterms:modified "2026-06-07T15:30:29.586093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20603-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can show melodic shape using actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.586100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20607-1
  a curric:KeyLearningPoint ;
  rdfs:label """A melodic ostinato is a short, repeating melody that usually accompanies a song or
  piece of music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20607-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bar lines show where strong beats are and keep the music organised."@en ;
  dcterms:modified "2026-06-07T15:30:29.586892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20607-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use the finger stave to read and sing a melodic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:29.586897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20607-4
  a curric:KeyLearningPoint ;
  rdfs:label "The beat pattern in 3-time feels: strong - weak - weak."@en ;
  dcterms:modified "2026-06-07T15:30:29.586901Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-20674
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use effective strategies to prepare for a performance of my variations on a
  given theme."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065320Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20629
  a curric:PupilLessonOutcome ;
  rdfs:label "I can hold my part as we build a texture in a beatboxing vocal ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:41.069244Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20628
  a curric:PupilLessonOutcome ;
  rdfs:label "I can begin to layer beatboxing vocal sounds."@en ;
  dcterms:modified "2026-06-07T15:30:41.069324Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20668
  a curric:PupilLessonOutcome ;
  rdfs:label """I can rehearse effectively for a performance and reflect on the musical decisions we
  made."""@en ;
  dcterms:modified "2026-06-07T15:30:41.070493Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-27380
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify the musical choices a composer has made and control my singing voice
  to convey the intended mood."""@en ;
  dcterms:modified "2026-06-07T15:30:41.070676Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20664
  a curric:PupilLessonOutcome ;
  rdfs:label """I can learn and combine syncopated rhythms derived from different musical
  styles."""@en ;
  dcterms:modified "2026-06-07T15:30:41.070783Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20665
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play a melody as part of a fusion performance."@en ;
