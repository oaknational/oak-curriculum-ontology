  dcterms:modified "2026-06-07T15:30:41.108420Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20569
  a curric:PupilLessonOutcome ;
  rdfs:label "I can follow a conductor when singing a round to know when it's my turn to sing."@en ;
