  dcterms:modified "2026-06-07T15:30:41.109026Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20607
  a curric:PupilLessonOutcome ;
  rdfs:label "I can perform and read a melodic ostinato."@en ;
