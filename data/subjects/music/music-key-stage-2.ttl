  dcterms:modified "2026-06-07T15:30:41.102424Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20659
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play the main melody (head) of a jazz piece with accuracy and a steady
  pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:41.102751Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20610
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing two-part rounds and partner songs with improving accuracy and a clear
