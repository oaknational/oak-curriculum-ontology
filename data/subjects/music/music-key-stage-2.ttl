  dcterms:modified "2026-06-07T15:30:41.104292Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20566
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose, notate and perform a major pentatonic melody that uses dotted rhythms
