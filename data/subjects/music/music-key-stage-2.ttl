  dcterms:modified "2026-06-07T15:30:41.108260Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20571
  a curric:PupilLessonOutcome ;
  rdfs:label """I can rehearse effectively using the structures of both rounds and partner
