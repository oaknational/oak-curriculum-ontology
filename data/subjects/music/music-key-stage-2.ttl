  dcterms:modified "2026-06-07T15:30:41.102755Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20633
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing and identify songs in the major or minor key."@en ;
  dcterms:modified "2026-06-07T15:30:41.102869Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20593
  a curric:PupilLessonOutcome ;
  rdfs:label """I can practise a new melodic accompaniment and recognise strategies I can use to
