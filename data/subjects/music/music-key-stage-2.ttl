  dcterms:modified "2026-06-07T15:30:41.104374Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20597
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify a major melody and describe its character."@en ;
  dcterms:modified "2026-06-07T15:30:41.104410Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20657
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play the minor pentatonic scale and know this scale can be used as the basis
