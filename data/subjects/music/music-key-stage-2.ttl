# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-melodic-shape
  a curric:Keyword ;
  schema:name "melodic shape"@en ;
  schema:description """the overall shape of a melody or part of a melody, including where it
  ascends or descends and where it is conjunct or disjunct"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347307Z"^^xsd:dateTime .

oakcurric:keyword-harmony
  a curric:Keyword ;
  schema:name "harmony"@en ;
  schema:description "how different notes and chords work together"@en ;
  dcterms:modified "2026-06-07T15:30:02.347358Z"^^xsd:dateTime .

oakcurric:keyword-legato
  a curric:Keyword ;
  schema:name "legato"@en ;
  schema:description "when the movement between each note is smooth"@en ;
  dcterms:modified "2026-06-07T15:30:02.347500Z"^^xsd:dateTime .

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-melody
  a curric:Keyword ;
  schema:name "Melody"@en ;
  schema:description "the tune, usually the most memorable feature in a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.348126Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-phrase
  a curric:Keyword ;
  schema:name "Phrase"@en ;
  schema:description "a short section of a melody, often lasting 1, 2 or 4 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.348142Z"^^xsd:dateTime .

oakcurric:keyword-diction
  a curric:Keyword ;
  schema:name "diction"@en ;
  schema:description "pronouncing words clearly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348214Z"^^xsd:dateTime .

oakcurric:keyword-atmosphere
  a curric:Keyword ;
  schema:name "atmosphere"@en ;
  schema:description "the mood created in a section or whole of a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348363Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description "a main idea that the writer wants to focus on"@en ;
  dcterms:modified "2026-06-07T15:30:02.348497Z"^^xsd:dateTime .

oakcurric:keyword-genre
  a curric:Keyword ;
  schema:name "genre"@en ;
  schema:description "A genre is a category used to group different types of literature."@en ;
  dcterms:modified "2026-06-07T15:30:02.348775Z"^^xsd:dateTime .

oakcurric:keyword-piano
  a curric:Keyword ;
  schema:name "piano"@en ;
  schema:description "a dynamic instruction meaning to play quietly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348788Z"^^xsd:dateTime .

oakcurric:keyword-forte
  a curric:Keyword ;
  schema:name "forte"@en ;
  schema:description "a dynamic instruction meaning to play loudly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348793Z"^^xsd:dateTime .

oakcurric:keyword-crescendo
  a curric:Keyword ;
  schema:name "crescendo"@en ;
  schema:description "gradually getting louder"@en ;
  dcterms:modified "2026-06-07T15:30:02.348797Z"^^xsd:dateTime .

oakcurric:keyword-staccato
  a curric:Keyword ;
  schema:name "staccato"@en ;
  schema:description "when the notes are played in a detached manner"@en ;
  dcterms:modified "2026-06-07T15:30:02.348816Z"^^xsd:dateTime .

oakcurric:keyword-folk-music
  a curric:Keyword ;
  schema:name "folk music"@en ;
  schema:description """the traditional music of a culture that is passed down through
  generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348834Z"^^xsd:dateTime .

oakcurric:keyword-accompaniment
  a curric:Keyword ;
  schema:name "accompaniment"@en ;
  schema:description "a part in the music that supports the melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.348848Z"^^xsd:dateTime .

oakcurric:keyword-syllable
  a curric:Keyword ;
  schema:name "syllable"@en ;
  schema:description "a single sound or beat in a word that contains a vowel sound"@en ;
  dcterms:modified "2026-06-07T15:30:02.348919Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
