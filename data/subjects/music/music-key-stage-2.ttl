  dcterms:modified "2026-06-07T15:30:41.103430Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20658
  a curric:PupilLessonOutcome ;
  rdfs:label """I can play the ascending and descending minor pentatonic scale and know this scale
