  dcterms:modified "2026-06-07T15:30:41.106175Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20581
  a curric:PupilLessonOutcome ;
  rdfs:label "I can talk about what opera is and how it is used to tell a story"@en ;
  dcterms:modified "2026-06-07T15:30:41.106220Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20558
  a curric:PupilLessonOutcome ;
  rdfs:label "I can add to the texture of a song by playing a simple melodic ostinato."@en ;
  dcterms:modified "2026-06-07T15:30:41.106224Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20559
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play a melodic ostinato whilst singing at the same time."@en ;
  dcterms:modified "2026-06-07T15:30:41.106237Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20560
  a curric:PupilLessonOutcome ;
  rdfs:label "I can rehearse, sing and play as part of an ensemble performance."@en ;
  dcterms:modified "2026-06-07T15:30:41.106257Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20579
  a curric:PupilLessonOutcome ;
  rdfs:label "I can hear and understand part of a story told through song."@en ;
  dcterms:modified "2026-06-07T15:30:41.106266Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20580
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand how different songs are used to tell us about stories and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:41.106274Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20582
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use my voice and body to share how a character is feeling in a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.106291Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20651
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify music that talks about civil rights and sing using the power of
