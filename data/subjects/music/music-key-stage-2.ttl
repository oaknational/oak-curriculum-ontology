  dcterms:modified "2026-06-07T15:30:41.103516Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20592
  a curric:PupilLessonOutcome ;
  rdfs:label """I can practise a new rhythmic accompaniment and recognise strategies I can use to
