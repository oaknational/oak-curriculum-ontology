oakcurric:keylearningpoint-lesson-20469-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify both echo and call and response song structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.380213Z"^^xsd:dateTime .

