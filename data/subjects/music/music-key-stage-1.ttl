# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-20519-1
  a curric:KeyLearningPoint ;
  rdfs:label "The melodies we sing, are made up of high and low pitched notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.258981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20519-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a musical stave to read songs containing do, mi, so, and la."@en ;
  dcterms:modified "2026-06-07T15:30:29.258985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20519-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can find do, mi, so, and la on a pitched percussion instrument."@en ;
  dcterms:modified "2026-06-07T15:30:29.258989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20519-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use pitched percussion to play simple melodies and patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.258993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20491-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing slowly and quickly and know that we are thinking about the tempo of the
  music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20491-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can describe the tempo of the music, for example, the song has a fast tempo."@en ;
  dcterms:modified "2026-06-07T15:30:29.262181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20491-3
  a curric:KeyLearningPoint ;
  rdfs:label """The same piece of music can be performed at different speeds. It can be played or
  sung at a slow tempo or a fast tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20504-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we sing a song, our voices go higher and lower."@en ;
  dcterms:modified "2026-06-07T15:30:29.262856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20504-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch is the musical word to describe how high or low a sound is."@en ;
  dcterms:modified "2026-06-07T15:30:29.262860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20504-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a song, the pitch follows a pattern called the melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.262864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20504-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing movements or actions as we sing is one way to feel the pitch going higher
  or lower."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20505-1
  a curric:KeyLearningPoint ;
  rdfs:label "Singing questions and answers is a form of call and response musical structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.262900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20505-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sung question has a melody. When we sing it, our voice moves up and down as we
  sing different pitches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20505-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using pitch actions can help us feel how the pitch moves in the melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.262908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20505-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singing questions and answers with the same melody is a good way of practising
  matching pitch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20501-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to warm up our bodies and voices before every music lesson."@en ;
  dcterms:modified "2026-06-07T15:30:29.262934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20501-2
  a curric:KeyLearningPoint ;
  rdfs:label "Warming up helps prevent us from injuring our voices."@en ;
  dcterms:modified "2026-06-07T15:30:29.262937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20501-3
  a curric:KeyLearningPoint ;
  rdfs:label """Having a steady sense of pulse helps to keep us in time when we sing and move
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20501-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can show the pulse in different ways, and this is called the beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.262945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20506-1
  a curric:KeyLearningPoint ;
  rdfs:label """Moving and singing together when we play singing games helps us to feel the
  beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20506-2
  a curric:KeyLearningPoint ;
  rdfs:label """As we repeat songs, we become more familiar with the rhythm of the words, and the
  way the pitch moves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20506-3
  a curric:KeyLearningPoint ;
  rdfs:label """The beat of a song stays steady, like a ticking clock, while the rhythm follows the
  pattern of the words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20506-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we know a song very well, it is easier to clap or play the rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.263070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20503-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most music has a steady beat. The beat can be fast or slow."@en ;
  dcterms:modified "2026-06-07T15:30:29.263115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20503-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the beat is fast, we say it has a fast tempo. When the beat is slow we say it
  has a slow tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20503-3
  a curric:KeyLearningPoint ;
  rdfs:label "The rhythm matches the pattern of the words or syllables in a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.263122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20503-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using stick notation is one way of writing down the rhythm of a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.263126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20502-1
  a curric:KeyLearningPoint ;
  rdfs:label "Having a steady sense of pulse is important when we sing and move together."@en ;
  dcterms:modified "2026-06-07T15:30:29.263145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20502-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we show the pulse through actions, body percussion, or by playing instruments,
  we call it the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20502-3
  a curric:KeyLearningPoint ;
  rdfs:label """Playing the beat on a percussion instrument can help us keep in time as we sing
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20502-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using hearts is one way to visualise the beat in a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.263156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20500-1
  a curric:KeyLearningPoint ;
  rdfs:label """Music is a form of storytelling. We can tell the story by singing with character and
  feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20500-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing with character and feeling by thinking about the use of dynamics, tempo,
  facial expressions and actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20500-3
  a curric:KeyLearningPoint ;
  rdfs:label "We rehearse before a performance to make sure we know the songs well."@en ;
  dcterms:modified "2026-06-07T15:30:29.281534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20500-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we perform to an audience we should try and sing with character and feeling,
  and carry on if we make a mistake."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20489-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20489-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our voices to chant or sing in time to the pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.281815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20489-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use movements or body percussion to help us feel and show this pulse so we
  can see and hear the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20489-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can keep a steady beat so we are able to sing our responses and join in with
  musical games at the correct moment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20514-1
  a curric:KeyLearningPoint ;
  rdfs:label "Melodies are made up of high and low notes and these notes have names"@en ;
  dcterms:modified "2026-06-07T15:30:29.282924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20514-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use the word pitch to describe how high or low a note is"@en ;
  dcterms:modified "2026-06-07T15:30:29.282928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20514-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can show high and low notes on a musical stave"@en ;
  dcterms:modified "2026-06-07T15:30:29.282932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20514-4
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be written down, or notated, to be remembered for another day"@en ;
  dcterms:modified "2026-06-07T15:30:29.282935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20529-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising helps to improve musical skill and prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.287989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20529-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing with different characters or feeling of a mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.287993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20529-3
  a curric:KeyLearningPoint ;
  rdfs:label "Controlling dynamics helps different parts in music be heard clearly."@en ;
  dcterms:modified "2026-06-07T15:30:29.287996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20529-4
  a curric:KeyLearningPoint ;
  rdfs:label "An accompaniment should support the melody, not overpower it."@en ;
  dcterms:modified "2026-06-07T15:30:29.288002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20529-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singing musically means thinking about the whole sound, not just our own voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.288007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20521-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can tap the beat and rhythm of a song or rhyme."@en ;
  dcterms:modified "2026-06-07T15:30:29.288139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20521-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use stick notation to read rhythms using rhythm language."@en ;
  dcterms:modified "2026-06-07T15:30:29.288143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20521-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can feel the pitch going higher and lower as we sing a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.288147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20521-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a musical stave to see the pitch of the notes ewe are gioing to play."@en ;
  dcterms:modified "2026-06-07T15:30:29.288151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20521-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can play the melody of a song on pitched percussion instruments using do, mi, so,
  and la."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20507-1
  a curric:KeyLearningPoint ;
  rdfs:label "We warm up our body and mind before singing so that we are focused and ready."@en ;
  dcterms:modified "2026-06-07T15:30:29.288245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20507-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sea shanties were sung by sailors all around the world to help them to achieve a
  task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20507-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sea shanties often have a steady pulse that is sounded as a strong beat. This helps
  sailors work together in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20507-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can feel the pulse and hear the beat in sea shanties and can use this to help us
  move together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20530-1
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up prepares us for rehearsing and performing safely and helps us do our
  best."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20530-2
  a curric:KeyLearningPoint ;
  rdfs:label """A rehearsal helps us prepare for a performance and can help us feel less
  nervous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20530-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor give us musical signals, to help us perform well."@en ;
  dcterms:modified "2026-06-07T15:30:29.288309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20530-4
  a curric:KeyLearningPoint ;
  rdfs:label "An audience wants to enjoy a successful musical performance with us."@en ;
  dcterms:modified "2026-06-07T15:30:29.288312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20528-1
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling the pulse and practising playing the beat helps get us ready for making
  harder music together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20528-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body percussion can help us control the steady beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.288893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20528-3
  a curric:KeyLearningPoint ;
  rdfs:label "A song can have more than one ostinato layered to create a thicker texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.288896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20528-4
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato can be chanted, sung or played."@en ;
  dcterms:modified "2026-06-07T15:30:29.288900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20523-1
  a curric:KeyLearningPoint ;
  rdfs:label "Music is organised in different ways. This is called structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.288984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20523-2
  a curric:KeyLearningPoint ;
  rdfs:label "Call and response and ABA are examples of musical structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.288988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20523-3
  a curric:KeyLearningPoint ;
  rdfs:label "Musical structure can help make music more interesting and memorable."@en ;
  dcterms:modified "2026-06-07T15:30:29.288993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20523-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we perform within an ABA structure, there is a B section which is different
  than the A section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20522-1
  a curric:KeyLearningPoint ;
  rdfs:label """Keeping a steady beat as we sing or play music helps us keep in time when we perform
  with others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20522-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can create rhythms using our understanding of syllables."@en ;
  dcterms:modified "2026-06-07T15:30:29.289295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20522-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stick notation helps us to read and play rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:29.289299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20522-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can read and play melodies using stick notation with note names."@en ;
  dcterms:modified "2026-06-07T15:30:29.289302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20525-1
  a curric:KeyLearningPoint ;
  rdfs:label "We keep a steady pulse while we sing so that we can stay in time with others."@en ;
  dcterms:modified "2026-06-07T15:30:29.289327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20525-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can move to the pulse so that we can feel the steady beat of the music in our
  bodies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20525-3
  a curric:KeyLearningPoint ;
  rdfs:label "2-time has a beat pattern of strong-weak."@en ;
  dcterms:modified "2026-06-07T15:30:29.289334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20525-4
  a curric:KeyLearningPoint ;
  rdfs:label "A fast tempo has a fast pulse. A slow tempo has a slow pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.289338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20527-1
  a curric:KeyLearningPoint ;
  rdfs:label """Short rhythmic patterns can be repeated to create an ostinato accompaniment for a
  chant or song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20527-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more layers of sound in a piece of music, the thicker the texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.289472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20527-3
  a curric:KeyLearningPoint ;
  rdfs:label "Beats are organised into patterns of strong beats and weak beats."@en ;
  dcterms:modified "2026-06-07T15:30:29.289476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20527-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the tempo gets faster, we need to chant and sing faster."@en ;
  dcterms:modified "2026-06-07T15:30:29.289480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20527-5
  a curric:KeyLearningPoint ;
  rdfs:label "When the tempo gets slower we need to chant and sing slower."@en ;
  dcterms:modified "2026-06-07T15:30:29.289483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20524-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can improvise alone, with a partner, or in an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.289489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20524-2
  a curric:KeyLearningPoint ;
  rdfs:label """To improvise thoughtfully, we can think about which notes we might use or which
  rhythm we might play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20524-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we play and improvise in a group ensemble, it is important to listen to each
  other and keep a steady pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20524-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can structure our musical performance to make it more interesting."@en ;
  dcterms:modified "2026-06-07T15:30:29.289503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20526-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we sing the same melody together, we are singing in unison."@en ;
  dcterms:modified "2026-06-07T15:30:29.289586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20526-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use body percussion to accompany a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.289590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20526-3
  a curric:KeyLearningPoint ;
  rdfs:label "Music in 4-time has a beat pattern of strong-weak-medium-weak."@en ;
  dcterms:modified "2026-06-07T15:30:29.289594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20526-4
  a curric:KeyLearningPoint ;
  rdfs:label """Body percussion can be played on the beat to help us hear the pattern of beats in
  4-time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20520-1
  a curric:KeyLearningPoint ;
  rdfs:label "Improvising is a way to create new musical ideas in the moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.295945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20520-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can improvise new words, new rhythms, or new melodies using our voices or
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20520-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can improvise alone, in a group, or with a partner using call and response."@en ;
  dcterms:modified "2026-06-07T15:30:29.295952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20520-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improvise new melodies using do, mi, so, and la."@en ;
  dcterms:modified "2026-06-07T15:30:29.295956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20534-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we chant an animal description we are chanting in a rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.301113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20534-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can rehearse rhythms to improve and prepare for performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.301117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20534-3
  a curric:KeyLearningPoint ;
  rdfs:label "An instrument might be chosen to represent an animal based on its timbre."@en ;
  dcterms:modified "2026-06-07T15:30:29.301121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20534-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is no right and wrong when choosing instruments to represent an animal."@en ;
  dcterms:modified "2026-06-07T15:30:29.301125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20531-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before playing so that we can focus our mind and bodies and be ready to
  play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20531-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composers can choose instruments because their timbre helps to tell a story or to
  represent something, like an animal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20531-3
  a curric:KeyLearningPoint ;
  rdfs:label "An instrument’s materials affect the unique sounds it makes."@en ;
  dcterms:modified "2026-06-07T15:30:29.301807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20531-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can listen to instruments and identify them by their timbre."@en ;
  dcterms:modified "2026-06-07T15:30:29.301811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20531-5
  a curric:KeyLearningPoint ;
  rdfs:label "Timbre is the unique tone an instrument can make."@en ;
  dcterms:modified "2026-06-07T15:30:29.301815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20533-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composers can create music that helps us imagine animals, characters or stories."@en ;
  dcterms:modified "2026-06-07T15:30:29.302467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20533-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving to music can help us imagine the stories the composer is trying to tell."@en ;
  dcterms:modified "2026-06-07T15:30:29.302471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20533-3
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be notated to share and remember for another day."@en ;
  dcterms:modified "2026-06-07T15:30:29.302475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20533-4
  a curric:KeyLearningPoint ;
  rdfs:label "A graphic score is one way of reading notation."@en ;
  dcterms:modified "2026-06-07T15:30:29.302479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20533-5
  a curric:KeyLearningPoint ;
  rdfs:label """Percussion instruments can be played in many different ways to create the imagery of
  an animal or environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20484-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the songs and games we play have a call and response structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.304978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20484-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we chant and clap to a steady pulse, we are chanting a rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.304982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20484-3
  a curric:KeyLearningPoint ;
  rdfs:label "We clap on each syllable of the chant to create a rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.304986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20484-4
  a curric:KeyLearningPoint ;
  rdfs:label """For these fruit chants, our one syllable words can be written as Ta and our two
  syllable words as Ta-di."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20536-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to rehearse as an ensemble in order to perform together
  successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20536-2
  a curric:KeyLearningPoint ;
  rdfs:label "Structure is the way the music is organised."@en ;
  dcterms:modified "2026-06-07T15:30:29.305423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20536-3
  a curric:KeyLearningPoint ;
  rdfs:label "ABA is a musical sandwich structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.305427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20536-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our composition and a chant we know, Do as I Do, have an ABA structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.305431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20532-1
  a curric:KeyLearningPoint ;
  rdfs:label """Composers can create music that helps us imagine animals, characters or
  stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20532-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving to music can help us imagine the stories the composer is trying to tell."@en ;
  dcterms:modified "2026-06-07T15:30:29.305733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20532-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instruments are chosen because of their timbre but all the musical elements need to
  work together to create the animal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20532-4
  a curric:KeyLearningPoint ;
  rdfs:label """Percussion instruments can be played in many different ways to create the imagery of
  an animal or environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20485-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch is how high or low a note sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.305800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20485-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use actions with our bodies to help us hear the high and low notes in
  a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20485-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unpitched percussion instruments do not play higher or lower pitches."@en ;
  dcterms:modified "2026-06-07T15:30:29.305810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20485-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythms can be played on unpitched instruments."@en ;
  dcterms:modified "2026-06-07T15:30:29.305815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20485-5
  a curric:KeyLearningPoint ;
  rdfs:label "When we chant as we play rhythms, it helps us stay in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.305819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20483-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20483-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the songs and games we play have a call and response structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.306092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20483-3
  a curric:KeyLearningPoint ;
  rdfs:label "Call and response chants and songs are found all around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.306096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20483-4
  a curric:KeyLearningPoint ;
  rdfs:label "Instrumental music can have a call and response structure too."@en ;
  dcterms:modified "2026-06-07T15:30:29.306100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20483-5
  a curric:KeyLearningPoint ;
  rdfs:label "Call and response is a question and answer musical structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.306103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20488-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we perform we are sharing our musical work with others."@en ;
  dcterms:modified "2026-06-07T15:30:29.306288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20488-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps us to feel prepared for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.306292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20488-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the structure of music helps us know when to sing and play."@en ;
  dcterms:modified "2026-06-07T15:30:29.306296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20488-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to keep a steady pulse as we sing and play."@en ;
  dcterms:modified "2026-06-07T15:30:29.306300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20488-5
  a curric:KeyLearningPoint ;
  rdfs:label """Performing gives us an opportunity to share and celebrate our learning with
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20535-1
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be notated to share and remember for another day."@en ;
  dcterms:modified "2026-06-07T15:30:29.306366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20535-2
  a curric:KeyLearningPoint ;
  rdfs:label "A graphic score is one way of reading and writing notation."@en ;
  dcterms:modified "2026-06-07T15:30:29.306370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20535-3
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic scores need to be clear and simple symbols, not pictures."@en ;
  dcterms:modified "2026-06-07T15:30:29.306374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20535-4
  a curric:KeyLearningPoint ;
  rdfs:label "An instrument might be chosen to represent an animal based on its timbre."@en ;
  dcterms:modified "2026-06-07T15:30:29.306378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20535-5
  a curric:KeyLearningPoint ;
  rdfs:label """Percussion instruments can be played in many different ways to create the imagery of
  an animal or environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20486-1
  a curric:KeyLearningPoint ;
  rdfs:label """Beat and rhythm are not the same thing. We can play rhythms successfully when we are
  able to hold a steady beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20486-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ta is one beat. Ta-di is also one beat long."@en ;
  dcterms:modified "2026-06-07T15:30:29.306441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20486-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we create new music we are composers. We can choose the sounds we like."@en ;
  dcterms:modified "2026-06-07T15:30:29.306445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pitch is how high or low the note sounds. We can show different pitches with actions
  as we sing and play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20487-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bigger pitched percussion instruments usually make a lower pitched sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.306650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20487-3
  a curric:KeyLearningPoint ;
  rdfs:label "Smaller pitched percussion instruments usually make a higher pitched sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.306654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20487-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we choose rhythms and notes we are composing a melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.306658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20497-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our voices, facial expressions and body movements to give a song
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20497-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dynamics means how loudly or quietly the music is played or sung."@en ;
  dcterms:modified "2026-06-07T15:30:29.308190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20497-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing with contrasting dynamics to change the character of our singing."@en ;
  dcterms:modified "2026-06-07T15:30:29.308196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20508-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before every music lesson to make sure that our minds, bodies and voices
  are ready."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20508-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sea shanties have a steady pulse that is sounded as a strong beat. This helped
  sailors to work together in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20508-3
  a curric:KeyLearningPoint ;
  rdfs:label """This strong beat stays the same. It does not get slower or faster. This helped
  sailors to all move together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20508-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm is the pattern of notes that we play and sing and follows the syllables of
  the words. It is different to pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20496-1
  a curric:KeyLearningPoint ;
  rdfs:label "Music can make us feel different emotions and we can show this in our singing."@en ;
  dcterms:modified "2026-06-07T15:30:29.308422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20496-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can change the character and feeling of our voice to create different moods in a
  song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20496-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our faces and bodies to emhpasise the mood or character of a song when
  singing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20510-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we feel the pulse, we can want to move or clap in time. When we do this, we are
  sounding the pulse as a beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20510-2
  a curric:KeyLearningPoint ;
  rdfs:label "Playing the pulse as a strong beat can help us to sing in time together."@en ;
  dcterms:modified "2026-06-07T15:30:29.308512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20510-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can play the pulse using instruments or body percussion to help us to sing in
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20510-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many sea shanties and working songs have a steady pulse that is sounded as a strong
  beat to help workers sing in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20482-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20482-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can can hear, feel and perform the rhythm and the beat in our songs and
  chants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20482-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify known rhythm patterns in our chants."@en ;
  dcterms:modified "2026-06-07T15:30:29.308817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20482-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use pictures and words to help us play rhythm compositions accurately,
  keeping a steady pulse as we play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20471-1
  a curric:KeyLearningPoint ;
  rdfs:label "Warming up our voice helps us to sing safely."@en ;
  dcterms:modified "2026-06-07T15:30:29.308883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20471-2
  a curric:KeyLearningPoint ;
  rdfs:label "Singing loudly doesn't mean shouting."@en ;
  dcterms:modified "2026-06-07T15:30:29.308887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20471-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use many different dynamics when we sing."@en ;
  dcterms:modified "2026-06-07T15:30:29.308891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20471-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different songs can suit different dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:29.308895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20480-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20480-2
  a curric:KeyLearningPoint ;
  rdfs:label "We play instruments on the beat and to the rhythm as we sing."@en ;
  dcterms:modified "2026-06-07T15:30:29.309116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20480-3
  a curric:KeyLearningPoint ;
  rdfs:label "We know music can be shared by listening or by writing it down."@en ;
  dcterms:modified "2026-06-07T15:30:29.309120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20480-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use pictures and words to help us play rhythms accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.309124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20475-1
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor can help us know when to change dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:29.309206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20475-2
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor can show clear hand gestures to change the dynamics of our singing."@en ;
  dcterms:modified "2026-06-07T15:30:29.309210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20475-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we follow a conductor, we all change dynamics at the same time."@en ;
  dcterms:modified "2026-06-07T15:30:29.309214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20475-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changing dynamics can help a song to feel more interesting and exciting."@en ;
  dcterms:modified "2026-06-07T15:30:29.309218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20498-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use changing dynamics along with facial expressions and actions to give a
  song character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20498-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tempo is the speed of the music, it means how fast or slow it is played or sung."@en ;
  dcterms:modified "2026-06-07T15:30:29.309280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20498-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the tempo to change how a song feels."@en ;
  dcterms:modified "2026-06-07T15:30:29.309284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20476-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps us remember when to change dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:29.309706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20476-2
  a curric:KeyLearningPoint ;
  rdfs:label "Watching the conductor helps us all keep together and sing at the same volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.309710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20476-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can share the feeling of a song by how we sing it."@en ;
  dcterms:modified "2026-06-07T15:30:29.309716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20476-4
  a curric:KeyLearningPoint ;
  rdfs:label "We warm up before we perform so our minds and voices are ready."@en ;
  dcterms:modified "2026-06-07T15:30:29.309721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20473-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our louder singing voice safely and without shouting."@en ;
  dcterms:modified "2026-06-07T15:30:29.309725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20473-2
  a curric:KeyLearningPoint ;
  rdfs:label "Singing strongly suits some songs more than others."@en ;
  dcterms:modified "2026-06-07T15:30:29.309729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20473-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can choose our dynamics based on how the song makes us feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.309735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20473-4
  a curric:KeyLearningPoint ;
  rdfs:label "Loud singing can make us feel joyful and energetic."@en ;
  dcterms:modified "2026-06-07T15:30:29.309741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20473-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can feel energised by adding actions to our songs."@en ;
  dcterms:modified "2026-06-07T15:30:29.309745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20512-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato is a repeated musical pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.311458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20512-2
  a curric:KeyLearningPoint ;
  rdfs:label """Playing an ostinato to a strong beat can help us to sing and play in time
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20512-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can create our own rhythmic ostinato to help us to keep in time together."@en ;
  dcterms:modified "2026-06-07T15:30:29.311466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20512-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can combine different layers of sound to create texture, such as playing
  different ostinati at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20472-1
  a curric:KeyLearningPoint ;
  rdfs:label "Singing softly can help the listener to feel relaxed."@en ;
  dcterms:modified "2026-06-07T15:30:29.312793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20472-2
  a curric:KeyLearningPoint ;
  rdfs:label "Soft singing can be useful at times like bedtime, or when we want to feel calm."@en ;
  dcterms:modified "2026-06-07T15:30:29.312797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20472-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some songs suit a soft dynamic more than others."@en ;
  dcterms:modified "2026-06-07T15:30:29.312801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20472-4
  a curric:KeyLearningPoint ;
  rdfs:label "We still need plenty of breath when singing softly."@en ;
  dcterms:modified "2026-06-07T15:30:29.312805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20499-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing with character and feeling by considering the use of tempo and dynamics
  in our performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20499-2
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor is a person who directs musicians and singers."@en ;
  dcterms:modified "2026-06-07T15:30:29.312958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20499-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conductor can show a group of musicians that they want the tempo or dynamics to
  change using gestures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20511-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sea shanties and working songs have a steady pulse and a rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.313372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20511-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm is the pattern of notes that we play and sing. A steady beat can help us to
  play and sing rhythms in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20511-3
  a curric:KeyLearningPoint ;
  rdfs:label "An ostinato is a repeated musical pattern that is played to a strong beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.313380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20511-4
  a curric:KeyLearningPoint ;
  rdfs:label """laying and listening to an ostinato can help us to play and sing in time
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20479-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20479-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can sing and move in time to a steady pulse and find the rhythm in our songs and
  chants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20479-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can control changes on our percussion instruments, starting, playing and stopping
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20479-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can echo rhythmic phrases when playing our percussion instruments."@en ;
  dcterms:modified "2026-06-07T15:30:29.313970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20474-1
  a curric:KeyLearningPoint ;
  rdfs:label "Changing dynamics can help tell the story in a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.331765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20474-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing loudly and quietly in the same song."@en ;
  dcterms:modified "2026-06-07T15:30:29.331769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20474-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changing dynamics can help share the feeling of the song."@en ;
  dcterms:modified "2026-06-07T15:30:29.331773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20474-4
  a curric:KeyLearningPoint ;
  rdfs:label "A conductor can lead us by showing gestures to change the dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:29.331777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20515-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use the word pitch to describe how high or low a note is."@en ;
  dcterms:modified "2026-06-07T15:30:29.356258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20515-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can show the pitch with actions as we sing to help us hear when the notes are
  high or low."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20515-3
  a curric:KeyLearningPoint ;
  rdfs:label """Music can be notated to be remembered for another day and we can use a musical stave
  to do this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20515-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can show so, mi, and la on a musical stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.356274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29875-1
  a curric:KeyLearningPoint ;
  rdfs:label "Music can be used in films to help tell the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.363575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29875-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumentation and the musical elements, such as dynamic changes, all help to tell
  the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29875-3
  a curric:KeyLearningPoint ;
  rdfs:label """We think about instrumentation and the musical elements when creating
  soundscapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29875-4
  a curric:KeyLearningPoint ;
  rdfs:label "A soundscape can be captured using a graphic score."@en ;
  dcterms:modified "2026-06-07T15:30:29.363589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29874-1
  a curric:KeyLearningPoint ;
  rdfs:label """The material that an instrument is made from will affect the instrument’s
  timbre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29874-2
  a curric:KeyLearningPoint ;
  rdfs:label """Music can create images in our minds, like Le Onde creates images of seaside and
  waves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29874-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use percussion instruments to create soundscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.363666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29874-4
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic scores are one way of capturing our musical ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.363670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29874-5
  a curric:KeyLearningPoint ;
  rdfs:label "When we make music together, we are an ensemble."@en ;
  dcterms:modified "2026-06-07T15:30:29.363676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29877-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composed music can also include space for improvising."@en ;
  dcterms:modified "2026-06-07T15:30:29.364489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dynamics, tempo and texture are three musical elements that we can think about when
  creating stormy music."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29877-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a concerto, the soloist is accompanied by an ensemble. In 'Storm', the fiddle and
  the harp are the soloists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29877-4
  a curric:KeyLearningPoint ;
  rdfs:label "The fiddle is another name for the violin."@en ;
  dcterms:modified "2026-06-07T15:30:29.364503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29876-1
  a curric:KeyLearningPoint ;
  rdfs:label "A soundscape can be created using just vocalisations and body percussion."@en ;
  dcterms:modified "2026-06-07T15:30:29.364768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29876-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we structure a soundscape, we think about how to organise the sounds - what
  comes first, then what comes next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29876-3
  a curric:KeyLearningPoint ;
  rdfs:label """A cell is a short musical idea that can be used in a soundscape to help build the
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20481-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368099Z"^^xsd:dateTime .

