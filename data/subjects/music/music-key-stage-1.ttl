  a curric:PupilLessonOutcome ;
  rdfs:label "I can compose a high-low melody and perform this on pitched percussion."@en ;
  dcterms:modified "2026-06-07T15:30:41.076758Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20497
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing songs with changing dynamics and can explain how this makes the song
