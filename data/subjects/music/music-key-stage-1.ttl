  dcterms:modified "2026-06-07T15:30:41.072651Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20528
  a curric:PupilLessonOutcome ;
  rdfs:label "I can keep a sung ostinato going under a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.072789Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20523
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use the do, mi, so and la to play within an ABA structure."@en ;
  dcterms:modified "2026-06-07T15:30:41.072810Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20522
  a curric:PupilLessonOutcome ;
  rdfs:label """I can read and play rhythms and melodies using simplified notation, keeping a steady
