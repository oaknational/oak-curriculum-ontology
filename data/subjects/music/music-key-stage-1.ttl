  dcterms:modified "2026-06-07T15:30:41.076545Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20485
  a curric:PupilLessonOutcome ;
  rdfs:label "I can hear the difference between high and low notes in our songs."@en ;
  dcterms:modified "2026-06-07T15:30:41.076562Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20483
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing and identify call and response structures in chants and songs."@en ;
  dcterms:modified "2026-06-07T15:30:41.076627Z"^^xsd:dateTime .

