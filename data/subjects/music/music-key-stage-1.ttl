oakcurric:pupillessonoutcome-lesson-20491
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe the tempo of the music as fast, slow or steady."@en ;
  dcterms:modified "2026-06-07T15:30:41.066858Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20504
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify high and low pitch in the songs I sing."@en ;
  dcterms:modified "2026-06-07T15:30:41.067058Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20505
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing high and low pitches, matching a leader."@en ;
  dcterms:modified "2026-06-07T15:30:41.067070Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20501
  a curric:PupilLessonOutcome ;
