  dcterms:modified "2026-06-07T15:30:41.075849Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20484
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read and chant four beat rhythms."@en ;
  dcterms:modified "2026-06-07T15:30:41.076378Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20536
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read my graphic score and play my part in an ABA composition."@en ;
  dcterms:modified "2026-06-07T15:30:41.076480Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20532
  a curric:PupilLessonOutcome ;
  rdfs:label """I can respond to music through movement and understand that timbre can help to
