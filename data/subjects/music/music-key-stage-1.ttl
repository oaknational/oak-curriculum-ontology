oakcurric:keylearningpoint-lesson-20470-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can play a steady beat on percussion instruments as we sing and chant."@en ;
  dcterms:modified "2026-06-07T15:30:29.388239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20490-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use movements, body percussion and instruments to help us feel the pulse and
  hear the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20490-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we keep a steady beat we are able to sing our responses and join in with
  musical games at the correct moment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20490-3
  a curric:KeyLearningPoint ;
  rdfs:label """We understand the structure of our songs and know when it is our turn to sing and
  play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20493-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tempo can change within a piece of music."@en ;
  dcterms:modified "2026-06-07T15:30:29.414748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20493-2
  a curric:KeyLearningPoint ;
  rdfs:label "Movement can help us to feel, show and hear the changing tempo."@en ;
  dcterms:modified "2026-06-07T15:30:29.414753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20493-3
  a curric:KeyLearningPoint ;
  rdfs:label "We know a piece of music can speed up (accelerando) or slow down (rallentando)."@en ;
  dcterms:modified "2026-06-07T15:30:29.414759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20493-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the tempo changes within a piece of music, it changes how the music feels and
  helps us create stories in our mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20517-1
  a curric:KeyLearningPoint ;
  rdfs:label "The notes we sing can be high pitch or low pitch."@en ;
  dcterms:modified "2026-06-07T15:30:29.415639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20517-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can show the pitch with actions as we sing to help us hear when the notes are
  high or low."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20517-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can show how high or low a note is on a musical stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.415647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20517-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can place do on a musical stave, and we know that it has a lower pitch
  than mi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20516-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can show the pitch with actions as we sing to help us hear when the notes are
  high or low."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20516-2
  a curric:KeyLearningPoint ;
  rdfs:label """Music can be written down to be remembered for another day, and this is called
  notation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20516-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can notate songs with the Solfège syllables mi, so, and la on a musical
  stave."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20494-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to sing and play at different tempi to practise feeling the pulse and
  following the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20494-2
  a curric:KeyLearningPoint ;
  rdfs:label "We know a piece of music can speed up (accelerando) or slow down (rallentando)."@en ;
  dcterms:modified "2026-06-07T15:30:29.419248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20494-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different tempi and tempo changes can help to tell a musical story."@en ;
  dcterms:modified "2026-06-07T15:30:29.419252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20513-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we sing a song, our voices go higher or lower to form the melody."@en ;
  dcterms:modified "2026-06-07T15:30:29.419335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20513-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can follow the shape of the melody with movements or actions to show higher or
  lower."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20513-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we talk about high and low in music, we use the word pitch."@en ;
  dcterms:modified "2026-06-07T15:30:29.419343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20477-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20477-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing new songs together, keeping a steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.419378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20477-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify when an instrument is a percussion instrument."@en ;
  dcterms:modified "2026-06-07T15:30:29.419382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20477-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can play percussion instruments, starting and stopping together."@en ;
  dcterms:modified "2026-06-07T15:30:29.419386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20492-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can describe the tempo of the music. For example, the song has a steady
  tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20492-2
  a curric:KeyLearningPoint ;
  rdfs:label """The same piece of music can be performed at different speeds. It can be played or
  sung at a slow, steady or fast tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20492-3
  a curric:KeyLearningPoint ;
  rdfs:label """The tempo of a piece of music changes the mood of the music and how we respond to
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20518-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using pitch actions as we sing can help us hear the patterns of high and low
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20518-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can show how high or low a note is on a musical stave."@en ;
  dcterms:modified "2026-06-07T15:30:29.419825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20518-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can place do, mi, so, and la on the stave to notate a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.419829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20509-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to warm up before every music lesson to make sure that our minds,
  bodies and voices are ready."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20509-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many sea shanties have a call and response structure that features a call and then a
  response sung in unison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20509-3
  a curric:KeyLearningPoint ;
  rdfs:label "Working songs of the sea are sung on different types of boats."@en ;
  dcterms:modified "2026-06-07T15:30:29.421018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20509-4
  a curric:KeyLearningPoint ;
  rdfs:label """An echo song is a special type of call and response song where the call and the
  response are exactly the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20465-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20465-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our voices to chant and sing together."@en ;
  dcterms:modified "2026-06-07T15:30:29.432805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20465-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing together or sing on our own."@en ;
  dcterms:modified "2026-06-07T15:30:29.432809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20465-4
  a curric:KeyLearningPoint ;
  rdfs:label "We know when it is our turn to sing."@en ;
  dcterms:modified "2026-06-07T15:30:29.432813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20495-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20495-2
  a curric:KeyLearningPoint ;
  rdfs:label "Music can make us feel different emotions like happy, sad, sleepy or excited."@en ;
  dcterms:modified "2026-06-07T15:30:29.586209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20495-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can show different feelings in our singing with our voice, face and body."@en ;
  dcterms:modified "2026-06-07T15:30:29.586213Z"^^xsd:dateTime .

