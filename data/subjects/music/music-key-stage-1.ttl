  dcterms:modified "2026-06-07T15:30:41.074312Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20534
  a curric:PupilLessonOutcome ;
  rdfs:label """I can rehearse a rhythm and can choose an instrument, based on its timbre, to
