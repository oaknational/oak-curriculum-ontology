  dcterms:modified "2026-06-07T15:30:41.071269Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20514
  a curric:PupilLessonOutcome ;
  rdfs:label "I can recognise high and low notes and place these on a simplified stave."@en ;
  dcterms:modified "2026-06-07T15:30:41.071464Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20529
  a curric:PupilLessonOutcome ;
  rdfs:label "I can practise a song to prepare for a performance."@en ;
  dcterms:modified "2026-06-07T15:30:41.072577Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20521
  a curric:PupilLessonOutcome ;
  rdfs:label """I can begin to play a song that uses do, mi, so and la on pitched percussion
