  dcterms:modified "2026-06-07T15:30:41.067123Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20502
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify the beat in songs I sing."@en ;
  dcterms:modified "2026-06-07T15:30:41.067131Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20500
  a curric:PupilLessonOutcome ;
