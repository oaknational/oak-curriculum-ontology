  a curric:KeyLearningPoint ;
  rdfs:label "We can feel the pulse of the music as we sing, play and move on the beat."@en ;
  dcterms:modified "2026-06-07T15:30:29.368103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20481-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use pictures and words to help us play rhythms accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.368107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20481-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can be composers, creating new rhythms and using pictures to help us."@en ;
  dcterms:modified "2026-06-07T15:30:29.368111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20478-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
