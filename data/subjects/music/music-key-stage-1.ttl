oakcurric:keylearningpoint-lesson-20468-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can create musical responses as part of play in a singing game."@en ;
  dcterms:modified "2026-06-07T15:30:29.383250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20470-1
  a curric:KeyLearningPoint ;
  rdfs:label """We warm up before singing so that our bodies, minds and voices are ready to
  sing."""@en ;
