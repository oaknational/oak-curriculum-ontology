  a curric:KeyLearningPoint ;
  rdfs:label "We can use our voices to chant and sing together."@en ;
  dcterms:modified "2026-06-07T15:30:29.382364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20467-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing together or on our own and know when it is our turn to sing."@en ;
  dcterms:modified "2026-06-07T15:30:29.382367Z"^^xsd:dateTime .

