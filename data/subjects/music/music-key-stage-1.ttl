  dcterms:modified "2026-06-07T15:30:29.368730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20478-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing and move in time to a steady pulse."@en ;
  dcterms:modified "2026-06-07T15:30:29.368733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20478-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can describe the timbre of percussion instruments."@en ;
  dcterms:modified "2026-06-07T15:30:29.368740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20478-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can recognise the sound of a selection of percussion instruments."@en ;
  dcterms:modified "2026-06-07T15:30:29.368744Z"^^xsd:dateTime .

