  dcterms:modified "2026-06-07T15:29:25.899577Z"^^xsd:dateTime .

oakcurric:priorknowledge-2635-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Teachers have established some classroom routines that would be beneficial to the
  unit, such as sitting in a circle, echoing and moving around the room."""@en ;
  dcterms:modified "2026-06-07T15:29:25.901405Z"^^xsd:dateTime .

oakcurric:priorknowledge-2635-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experience of singing as part of a group and have some experience of
  starting and stopping singing together."""@en ;
  dcterms:modified "2026-06-07T15:29:25.901416Z"^^xsd:dateTime .

oakcurric:priorknowledge-2635-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have heard songs and music used in film, lullabies and games."@en ;
  dcterms:modified "2026-06-07T15:29:25.901422Z"^^xsd:dateTime .

oakcurric:priorknowledge-2635-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had some practice of coming in together, guided by a count-in such as
  ‘ready, steady, off we go’."""@en ;
  dcterms:modified "2026-06-07T15:29:25.901426Z"^^xsd:dateTime .

oakcurric:priorknowledge-3882-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experienced playing a range of pitched and unpitched classroom
  percussion."""@en ;
  dcterms:modified "2026-06-07T15:29:26.326119Z"^^xsd:dateTime .

oakcurric:priorknowledge-3882-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a percussion instrument makes a sound when it is struck, shaken or
  scraped."""@en ;
  dcterms:modified "2026-06-07T15:29:26.326129Z"^^xsd:dateTime .

oakcurric:priorknowledge-3882-3
  a curric:PriorKnowledgeRequirement ;
