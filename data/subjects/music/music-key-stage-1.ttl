oakcurric:pupillessonoutcome-lesson-20496
  a curric:PupilLessonOutcome ;
  rdfs:label "I can respond to and sing songs that have different feelings or moods."@en ;
  dcterms:modified "2026-06-07T15:30:41.077236Z"^^xsd:dateTime .

