  dcterms:modified "2026-06-07T15:30:41.067078Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20506
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play singing games with awareness of beat, rhythm, and pitch."@en ;
  dcterms:modified "2026-06-07T15:30:41.067110Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20503
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify the rhythm in songs I sing, and I know the difference between beat
