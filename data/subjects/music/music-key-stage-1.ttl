  dcterms:modified "2026-06-07T15:30:41.072876Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20525
  a curric:PupilLessonOutcome ;
  rdfs:label "I can move in time to the pulse whilst singing."@en ;
  dcterms:modified "2026-06-07T15:30:41.072884Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20527
  a curric:PupilLessonOutcome ;
  rdfs:label "I can keep a rhythmic, chanted ostinato going under a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.072916Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20524
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform an ABA piece, keeping a steady pulse and improvising thoughtfully on
