  dcterms:modified "2026-06-07T15:30:29.378023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20466-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our voices to chant and sing together."@en ;
  dcterms:modified "2026-06-07T15:30:29.378027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20466-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can sing together or on our own and know when it is our turn to sing."@en ;
  dcterms:modified "2026-06-07T15:30:29.378031Z"^^xsd:dateTime .

