  dcterms:modified "2026-06-07T15:30:02.380093Z"^^xsd:dateTime .

oakcurric:keyword-lullaby
  a curric:Keyword ;
  schema:name "lullaby"@en ;
  schema:description "a gentle, soothing song to help us sleep"@en ;
  dcterms:modified "2026-06-07T15:30:02.381054Z"^^xsd:dateTime .

oakcurric:keyword-accelerando
  a curric:Keyword ;
  schema:name "accelerando"@en ;
  schema:description "when the tempo gradually speeds up"@en ;
  dcterms:modified "2026-06-07T15:30:02.395039Z"^^xsd:dateTime .

oakcurric:keyword-soundscape
  a curric:Keyword ;
  schema:name "soundscape"@en ;
  schema:description """using sounds to create a feeling, place or story, making you feel like you
  are really there, for example in the ocean"""@en ;
  dcterms:modified "2026-06-07T15:30:02.395741Z"^^xsd:dateTime .

oakcurric:keyword-improvising
  a curric:Keyword ;
  schema:name "improvising"@en ;
  schema:description """creating music in the moment, using the voice or instruments, alone or with
  others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396041Z"^^xsd:dateTime .

oakcurric:keyword-soloist
  a curric:Keyword ;
  schema:name "soloist"@en ;
  schema:description """a musician who performs alone or performs the main melodic line with an
  accompaniment underneath"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396046Z"^^xsd:dateTime .

oakcurric:keyword-accompany
  a curric:Keyword ;
  schema:name "accompany"@en ;
  schema:description "to play a supporting part underneath the main melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.396053Z"^^xsd:dateTime .

oakcurric:keyword-vocalisation
  a curric:Keyword ;
  schema:name "vocalisation"@en ;
  schema:description "a sound made by the voice, but does not need to be a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.396122Z"^^xsd:dateTime .

oakcurric:keyword-instrument
  a curric:Keyword ;
  schema:name "instrument"@en ;
  schema:description "a device used to make a musical sound"@en ;
  dcterms:modified "2026-06-07T15:30:02.401999Z"^^xsd:dateTime .

oakcurric:keyword-rallentando
  a curric:Keyword ;
  schema:name "rallentando"@en ;
  schema:description "gradually getting slower"@en ;
  dcterms:modified "2026-06-07T15:30:02.408371Z"^^xsd:dateTime .

oakcurric:keyword-speaking-voice
  a curric:Keyword ;
  schema:name "speaking voice"@en ;
  schema:description "the voice we use when we talk to each other"@en ;
  dcterms:modified "2026-06-07T15:30:02.412664Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-longer-taller-bars-pitched-percussion
  a curric:Misconception ;
  curric:statement """The longer (taller) bars on a pitched percussion instrument make a higher
  pitch."""@en ;
  curric:correction """On a pitched percussion instrument, the bars with a longer length make a
  lower pitch and the bars with a shorter length make a higher pitch."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087980Z"^^xsd:dateTime .

oakcurric:misconception-pulse-beat-same-thing
  a curric:Misconception ;
  curric:statement "Pulse and beat are the same thing."@en ;
  curric:correction """Pulse is the underlying feeling of uniformed beats - it is the heartbeat of
  the music. When organised into metres, we then feel it as beats e.g. counting 1,2,3 1,2,3."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089332Z"^^xsd:dateTime .

oakcurric:misconception-high-low-refer-volume-loud
  a curric:Misconception ;
  curric:statement "High and low refer to volume (loud/quiet)."@en ;
  curric:correction """High and low in music refers to pitch. Not to be confused with high and low
  volume (like on a T.V.)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089576Z"^^xsd:dateTime .

oakcurric:misconception-cant-match-pitch-means-am
  a curric:Misconception ;
  curric:statement "If I can't match the pitch, it means I am a bad singer!"@en ;
  curric:correction """Matching pitch takes practice. Using pitch actions can help students feel the
  pitch as they sing and learn to match pitch more accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089592Z"^^xsd:dateTime .

oakcurric:misconception-warming-important-perfomance-isnt-necessary
  a curric:Misconception ;
  curric:statement """Warming up is only important before a perfomance. It isn't necessary to warm
  up for every music lesson."""@en ;
  curric:correction """Warming up is necessary before undertaking any type of singing. It is an
  important part of a regular music lesson routine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089604Z"^^xsd:dateTime .

oakcurric:misconception-beat-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Beat and rhythm are the same thing."@en ;
  curric:correction """The beat is the playing or showing of the steady pulse, while the the rhythm
  is a pattern of sounds we play or sing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089657Z"^^xsd:dateTime .

oakcurric:misconception-beat-pulse-same-thing
  a curric:Misconception ;
  curric:statement "The beat and the pulse are the same thing."@en ;
  curric:correction """The pulse is something we can feel in the music, while the beat is the
  showing or sounding of the pulse."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089682Z"^^xsd:dateTime .

oakcurric:misconception-make-mistake-performance-start-again
  a curric:Misconception ;
  curric:statement "If we make a mistake in a performance we should start again."@en ;
  curric:correction """When performing in front of an audience it's best to carry on if we make a
  mistake. Most of the time the audience won't notice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095825Z"^^xsd:dateTime .

oakcurric:misconception-high-low-refers-volume-loud
  a curric:Misconception ;
  curric:statement "High and low refers to volume (loud and quiet)."@en ;
  curric:correction "High and low refers to pitch."@en ;
  dcterms:modified "2026-06-07T15:30:15.096203Z"^^xsd:dateTime .

oakcurric:misconception-sing-louder-my-part-heard
  a curric:Misconception ;
  curric:statement "I should sing louder so my part can be heard over the others."@en ;
  curric:correction """When we all sing louder, the music becomes unbalanced. If we listen and
  balance each layer, our music sounds clear and beautiful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097826Z"^^xsd:dateTime .

oakcurric:misconception-pulse-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Pulse and rhythm are the same thing."@en ;
  curric:correction """Pulse is the regular, steady heartbeat of the music. Rhythm is the pattern of
  notes that we play and sing. It will follow the syllables of the words we sing. Pulse is
  the underlying feeling of uniformed beats."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097911Z"^^xsd:dateTime .

oakcurric:misconception-know-our-songs-well-need
  a curric:Misconception ;
  curric:statement """If we know our songs well, we do not need to rehearse before a
  performance."""@en ;
  curric:correction """A rehearsal can really help to settle the nerves, helping us know what will
  happen and how things will feel different during the performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097925Z"^^xsd:dateTime .

oakcurric:misconception-sing-change-pitch
  a curric:Misconception ;
  curric:statement "When we sing, we have to change pitch"@en ;
  curric:correction "We can sing a phrase all on one note."@en ;
  dcterms:modified "2026-06-07T15:30:15.098206Z"^^xsd:dateTime .

oakcurric:misconception-compose-music-notate-using-stave
  a curric:Misconception ;
  curric:statement "When we compose music we always notate it using a stave."@en ;
  curric:correction """Using stick notation with the notes written underneath is a quick way to
  notate simple melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098295Z"^^xsd:dateTime .

oakcurric:misconception-music-notated-musical-stave
  a curric:Misconception ;
  curric:statement "Music is always notated on a musical stave."@en ;
  curric:correction """There are many different ways to notate music. Stick notation, for example,
  is a quick way to notate simple rhythms and melodies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098405Z"^^xsd:dateTime .

oakcurric:misconception-beat-same-rhythm-words
  a curric:Misconception ;
  curric:statement "The beat is the same as the rhythm of the words."@en ;
  curric:correction """The pulse is like a steady beat that stays the same, even when the rhythm of
  the words changes. Clap the beat whilst saying words to show how they are different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098417Z"^^xsd:dateTime .

oakcurric:misconception-pulse-steady-beat-stays-same
  a curric:Misconception ;
  curric:statement "The pulse and steady beat always stays the same."@en ;
  curric:correction "If the tempo changes, the pulse will change too!"@en ;
  dcterms:modified "2026-06-07T15:30:15.098471Z"^^xsd:dateTime .

oakcurric:misconception-improvising-doesnt-require-thought
  a curric:Misconception ;
  curric:statement "Improvising doesn't require any thought."@en ;
  curric:correction """Before we improvise, we think about what notes or rhythms we might play and
  how we will structure our playing, but the final product is played in the moment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098477Z"^^xsd:dateTime .

oakcurric:misconception-one-instrument-make-one-type
  a curric:Misconception ;
  curric:statement "One instrument can only make one type of sound."@en ;
  curric:correction """Our body is an instrument and we can create many different sounds, all with
  different timbre."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098510Z"^^xsd:dateTime .

oakcurric:misconception-improvisation-difficult-professional-musicians-well
  a curric:Misconception ;
  curric:statement "Improvisation is difficult and only professional musicians can do it well."@en ;
  curric:correction """Improvisation is about exploring new musical ideas. Even young pupils can
  improvise in a fun and playful way using familiar material as a starting point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101718Z"^^xsd:dateTime .

oakcurric:misconception-instruments-create-one-sound-represent
  a curric:Misconception ;
  curric:statement "Instruments can only create one sound or represent one animal."@en ;
  curric:correction "There is no right or wrong when choosing instruments for their timbre."@en ;
  dcterms:modified "2026-06-07T15:30:15.103379Z"^^xsd:dateTime .

oakcurric:misconception-timbre-alone-creates-musical-story
  a curric:Misconception ;
  curric:statement "Timbre alone creates a musical story."@en ;
  curric:correction """All the musical elements need to work together to create a musical story. A
  glockenspiel can be many things depending on how it is played - not just a polar bear."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103613Z"^^xsd:dateTime .

oakcurric:misconception-music-notated-score
  a curric:Misconception ;
  curric:statement "Music is always notated on a score."@en ;
  curric:correction """Some music is never notated, it is shared by singing and playing. Some
  notation uses graphic scores, or rhythm grids. Any way of sharing how the music is
  expected to be played is a form of notation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103831Z"^^xsd:dateTime .

oakcurric:misconception-responses-same-call-response-songs
  a curric:Misconception ;
  curric:statement "Responses are always the same in call and response songs."@en ;
  curric:correction """The response can be different every time. The call can also be different.
  Call and response can be any kind of back and forth musical conversation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104813Z"^^xsd:dateTime .

oakcurric:misconception-practise-your-own-play-together
  a curric:Misconception ;
  curric:statement """You can practise on your own and then you will play together successfully as
  an ensemble."""@en ;
  curric:correction """It is important to rehearse as an ensemble in order to perform
  successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105040Z"^^xsd:dateTime .

oakcurric:misconception-instruments-play-different-notes
  a curric:Misconception ;
  curric:statement "All instruments can play different notes."@en ;
  curric:correction """Some instruments are unpitched. This means they do not create different high
  and low sounds when played."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105158Z"^^xsd:dateTime .

oakcurric:misconception-call-response-singing-structure
  a curric:Misconception ;
  curric:statement "Call and response is a singing structure."@en ;
  curric:correction """The call and response structure can be found in songs, chants and
  instrumental music in musical styles all around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105254Z"^^xsd:dateTime .

oakcurric:misconception-rehearsing-isnt-important-time
  a curric:Misconception ;
  curric:statement "Rehearsing isn't important. We can just do it if we have time."@en ;
  curric:correction """Rehearsing helps us to practise and prepare, so our performance can be
  successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105319Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-beat-same-thing
  a curric:Misconception ;
  curric:statement "Rhythm and beat are the same thing."@en ;
  curric:correction """The beat is the playing or showing of the steady pulse, like the ticking of a
  clock. The rhythm is the pattern of sounds we play and sing over the steady beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105357Z"^^xsd:dateTime .

oakcurric:misconception-bigger-longer-instruments-usually-create
  a curric:Misconception ;
  curric:statement """Bigger or longer instruments usually create a higher pitched sound. Shorter or
  smaller instruments usually create a lower pitched sound."""@en ;
  curric:correction "Usually, the bigger the instrument, the lower the sound."@en ;
  dcterms:modified "2026-06-07T15:30:15.105436Z"^^xsd:dateTime .

oakcurric:misconception-everyone-responds-music-same-way
  a curric:Misconception ;
  curric:statement "Everyone responds to music in the same way."@en ;
  curric:correction "Loud music might be exciting, but it might also be a bit scary."@en ;
  dcterms:modified "2026-06-07T15:30:15.105919Z"^^xsd:dateTime .

oakcurric:misconception-warm-performance
  a curric:Misconception ;
  curric:statement "We only warm up for a performance."@en ;
  curric:correction """No, it is important to warm up whenever we are making music. Warming up will
  help us to focus, it will stretch and relax our vocal muscles ready for using them and
  will help us to listen and work as a group of musicians."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105963Z"^^xsd:dateTime .

oakcurric:misconception-singing-loud-cross-tone-involves
  a curric:Misconception ;
  curric:statement "Singing in a loud or cross tone involves shouting."@en ;
  curric:correction """You can sing loudly and sound cross without shouting. Think of singing
  strongly, rather than loud to help you to do this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105996Z"^^xsd:dateTime .

oakcurric:misconception-pulse-beat-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Pulse, beat and rhythm are the same thing."@en ;
  curric:correction """Beat is the playing of the steady pulse. Rhythm is the pattern of sounds and
  silences of differing durations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106176Z"^^xsd:dateTime .

oakcurric:misconception-need-sing-loudly-heard-good
  a curric:Misconception ;
  curric:statement "We need to sing loudly for it to be heard or for it to be 'good'."@en ;
  curric:correction """Learning to sing using a range of dynamics is a key aspect of conveying the
  mood of a song. Pupils can explore what quality singing feels like, and the effect it can
  have, using a range of dynamics to suit the song."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106198Z"^^xsd:dateTime .

oakcurric:misconception-conductors-orchestras-singing-class
  a curric:Misconception ;
  curric:statement "Conductors are for orchestras and not for singing in class."@en ;
  curric:correction """Following a conductor can help us to stay together and change our dynamics
  together. This adds focus to our singing as well as making the song more effective for an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106306Z"^^xsd:dateTime .

oakcurric:misconception-exaggerate-tempo-changes-interpreting-singing
  a curric:Misconception ;
  curric:statement """Sometimes we exaggerate tempo changes, interpreting singing fast as singing
  'as fast as we can'."""@en ;
  curric:correction """Subtle tempo changes can affect the character of the music as well as big
  ones."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106323Z"^^xsd:dateTime .

oakcurric:misconception-perform-loudly-confidently-audience-hear
  a curric:Misconception ;
  curric:statement "We should perform loudly and confidently so that the audience can hear us."@en ;
  curric:correction """Changing dynamics can actually help an audience to feel more engaged in the
  singing because their ears are given more variation, and they can interpret the feeling of
  a song more easily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106490Z"^^xsd:dateTime .

oakcurric:misconception-singing-loudly-means-using-our
  a curric:Misconception ;
  curric:statement "Singing loudly means using our shouting voice."@en ;
  curric:correction """Singing loudly should be a controlled, projected sound that avoids
  shouting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106496Z"^^xsd:dateTime .

oakcurric:misconception-ostinato-like-rhythm-song-changes
  a curric:Misconception ;
  curric:statement """An ostinato, like the rhythm of a song, changes throughout a piece of
  music."""@en ;
  curric:correction """An ostinato does have a rhythm, but this rhythm is repeated over and over
  again throughout a piece of music. The rhythm stays exactly the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106975Z"^^xsd:dateTime .

oakcurric:misconception-singing-softly-easier-requires-less
  a curric:Misconception ;
  curric:statement "Singing softly is easier and requires less effort."@en ;
  curric:correction """Soft singing requires the same breath control as louder singing. The warm-ups
  and the breathing exercise help prepare for this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107387Z"^^xsd:dateTime .

oakcurric:misconception-performance-piece-same
  a curric:Misconception ;
  curric:statement "Every performance of a piece is the same."@en ;
  curric:correction """We can use dynamics and tempo to tell the story of the words, different
  conductors and performers might do this differently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107446Z"^^xsd:dateTime .

oakcurric:misconception-ostinato-rhythm-matches-syllabic-rhythm
  a curric:Misconception ;
  curric:statement """The ostinato rhythm matches the syllabic rhythm of the words all the way
  through the song."""@en ;
  curric:correction """Ostinatos are short repeated musical patterns, and so the rhythmic ostinato
  (taken from a small part of the words) stays the same all the way through."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107620Z"^^xsd:dateTime .

oakcurric:misconception-sing-song-same-dynamics-way
  a curric:Misconception ;
  curric:statement "We sing a song at the same dynamics all the way through."@en ;
  curric:correction """We can help to convey the meaning of a song by varying the dynamics within a
  song. Singing with a range of dynamics also provides the listener with a broader range of
  sound to feel engaged with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113502Z"^^xsd:dateTime .

oakcurric:misconception-notes-placed-lines-stave
  a curric:Misconception ;
  curric:statement "Notes are always placed on the lines of a stave"@en ;
  curric:correction "Notes can be placed on, above, or below the lines on a stave"@en ;
  dcterms:modified "2026-06-07T15:30:15.122991Z"^^xsd:dateTime .

oakcurric:misconception-timbre-instrument-creates-mood-piece
  a curric:Misconception ;
  curric:statement "The timbre of an instrument creates the mood of the piece."@en ;
  curric:correction """The instrumentation helps, but it is the combination of all the musical
  elements that creates the mood of a piece. For example, dynamic changes can build drama."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124793Z"^^xsd:dateTime .

oakcurric:misconception-piano-percussion-instrument
  a curric:Misconception ;
  curric:statement "The piano is not a percussion instrument."@en ;
  curric:correction """The piano is a percussion instrument because the hammers inside strike the
  strings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124818Z"^^xsd:dateTime .

oakcurric:misconception-soloist-one-musician-performing-their
  a curric:Misconception ;
  curric:statement "A soloist is only one musician performing on their own."@en ;
  curric:correction """A soloist can be accompanied. They can also be performing alongside another
  soloist."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125066Z"^^xsd:dateTime .

oakcurric:misconception-structure-texture-same-thing
  a curric:Misconception ;
  curric:statement "Structure and texture are the same thing."@en ;
  curric:correction """Here, the structuring of the piece does involve a buiding of texture, but it
  is helpful to think of structure as horizontal - what is happening now and next, and
  texture as vertical - how many layers are there."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125165Z"^^xsd:dateTime .

oakcurric:misconception-describing-instruments-timbre-say-high
  a curric:Misconception ;
  curric:statement """When describing an instrument’s timbre, we can say it is high or low, loud or
  quiet, fast or slow."""@en ;
  curric:correction """Timbre describes the unique sound of an instrument, not its pitch, dynamics
  or tempo."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126500Z"^^xsd:dateTime .

oakcurric:misconception-echo-call-response-same
  a curric:Misconception ;
  curric:statement "Echo and call and response are the same."@en ;
  curric:correction """An echo is an exact match of a phrase. A call and response is a question and
  answer structure in which the response can be different from the call."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131683Z"^^xsd:dateTime .

oakcurric:misconception-echo-call-response-same-thing
  a curric:Misconception ;
  curric:statement "Echo and call and response are the same thing."@en ;
  curric:correction """An echo is an exact match of a phrase. A call and response is a question and
  answer structure in which the response can be different from the call."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133673Z"^^xsd:dateTime .

oakcurric:misconception-beat-rhythm-interchangeable-terminology
  a curric:Misconception ;
  curric:statement "Beat and rhythm are interchangeable terminology."@en ;
  curric:correction """The beat is the consistent audible sound of the underlying pulse. Rhythm is
  the pattern of sounds and silences which can be a combination of sounds of any duration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144403Z"^^xsd:dateTime .

oakcurric:misconception-tempo-stays-same-throughout-piece
  a curric:Misconception ;
  curric:statement "The tempo always stays the same throughout a piece of music."@en ;
  curric:correction """Although we learn to feel the pulse and follow the steady beat, music can get
  gradually faster or gradually slower."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146837Z"^^xsd:dateTime .

oakcurric:misconception-word-low-associated-quiet
  a curric:Misconception ;
  curric:statement "The word low is sometimes associated with quiet."@en ;
  curric:correction "The word low refers to low pitch."@en ;
  dcterms:modified "2026-06-07T15:30:15.147155Z"^^xsd:dateTime .

oakcurric:misconception-note-la-placed-anywhere-high
  a curric:Misconception ;
  curric:statement "The note la is placed anywhere above the high line on the stave."@en ;
  curric:correction "The note la sits on top of and touches the high line of the stave."@en ;
  dcterms:modified "2026-06-07T15:30:15.147651Z"^^xsd:dateTime .

oakcurric:misconception-feeling-beat-doesnt-need-practising
  a curric:Misconception ;
  curric:statement "Feeling the beat doesn't need practising."@en ;
  curric:correction """Singing games are really useful to help us practise the beat, especially when
  it is very slow or very fast. We need to practise the beat at lots of different tempi."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148411Z"^^xsd:dateTime .

oakcurric:misconception-tempo-alone-set-musical-mood
  a curric:Misconception ;
  curric:statement "Tempo alone can set the musical mood."@en ;
  curric:correction "All the musical elements work together to help set the musical mood."@en ;
  dcterms:modified "2026-06-07T15:30:15.148503Z"^^xsd:dateTime .

oakcurric:misconception-sea-shanties-sung-board-ships
  a curric:Misconception ;
  curric:statement "Sea shanties were only sung on-board ships."@en ;
  curric:correction """This unit features working songs of the sea that were sung on different types
  of boats, not just ships. For example, Tongo is a canoe song. It was sung to keep
  fisherfolk in time as they rowed in their canoes along rivers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149032Z"^^xsd:dateTime .

oakcurric:misconception-singing-louder-means-children-engaged
  a curric:Misconception ;
  curric:statement "Singing louder means the children are more engaged and singing better."@en ;
  curric:correction """For children to develop sound intonation and accuracy, they need to sing
  gently and not be encouraged to always sing loudly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152590Z"^^xsd:dateTime .

oakcurric:misconception-everybody-responds-music-same-way
  a curric:Misconception ;
  curric:statement "Everybody responds to music in the same way"@en ;
  curric:correction """While there are common musical features that makes a song sound happy, sad or
  scary, these are not always experienced in the same way. One person may find a song calm,
  wheras another may find it sad."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155085Z"^^xsd:dateTime .
