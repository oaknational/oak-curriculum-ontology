  dcterms:modified "2026-06-07T15:30:41.072920Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20526
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use body percussion to keep a steady beat whilst singing."@en ;
  dcterms:modified "2026-06-07T15:30:41.072945Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20520
  a curric:PupilLessonOutcome ;
  rdfs:label """I can improvise with a partner using do, mi, so and la, within a call and response
