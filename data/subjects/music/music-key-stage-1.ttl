  dcterms:modified "2026-06-07T15:30:41.077175Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20508
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing songs with a steady pulse and know that this can help us to work together
