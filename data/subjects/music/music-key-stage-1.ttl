  dcterms:modified "2026-06-07T15:29:26.326135Z"^^xsd:dateTime .

oakcurric:priorknowledge-3882-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experience of making music together and working in small groups to
  prepare for a performance."""@en ;
  dcterms:modified "2026-06-07T15:29:26.326140Z"^^xsd:dateTime .

oakcurric:priorknowledge-3882-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experience of manipulating the musical elements to create music, for
  example creating a rhythm or changing the tempo."""@en ;
  dcterms:modified "2026-06-07T15:29:26.326144Z"^^xsd:dateTime .

oakcurric:priorknowledge-2634-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced song, rhyme and pulse in their early years setting."@en ;
  dcterms:modified "2026-06-07T15:29:26.597177Z"^^xsd:dateTime .

oakcurric:priorknowledge-2634-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Teachers have established some classroom routines that would be beneficial to the
