  dcterms:modified "2026-06-07T15:30:41.072610Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20507
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand that singing can be used to help achieve a task."@en ;
  dcterms:modified "2026-06-07T15:30:41.072638Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20530
  a curric:PupilLessonOutcome ;
  rdfs:label """I can perform songs with two or more layers, singing my part accurately and keeping
