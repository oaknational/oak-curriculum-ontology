# ----------------------------------------------------------------------
# Prior Knowledge Requirements
# ----------------------------------------------------------------------

oakcurric:priorknowledge-2645-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have sung songs using the toneset do, mi, so, la."@en ;
  dcterms:modified "2026-06-07T15:29:24.229672Z"^^xsd:dateTime .

oakcurric:priorknowledge-2645-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have used different ways to notate and record music."@en ;
  dcterms:modified "2026-06-07T15:29:24.229686Z"^^xsd:dateTime .

oakcurric:priorknowledge-2645-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can read four note notation on a simplified stave and can represent this
  using movement and singing."""@en ;
  dcterms:modified "2026-06-07T15:29:24.229692Z"^^xsd:dateTime .

oakcurric:priorknowledge-2645-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can identify the direction of pitch in an ascending or descending four note
  toneset."""@en ;
  dcterms:modified "2026-06-07T15:29:24.229698Z"^^xsd:dateTime .

oakcurric:priorknowledge-2645-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have played three note melodies (mi, so, la) on pitched percussion."@en ;
  dcterms:modified "2026-06-07T15:29:24.229703Z"^^xsd:dateTime .

oakcurric:priorknowledge-2645-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had previous opportunities to compose and improvise music on tuned
  percussion."""@en ;
  dcterms:modified "2026-06-07T15:29:24.229714Z"^^xsd:dateTime .

oakcurric:priorknowledge-2638-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can sing with a developing sense of pulse."@en ;
  dcterms:modified "2026-06-07T15:29:24.401748Z"^^xsd:dateTime .

oakcurric:priorknowledge-2638-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have rehearsed coming in together guided by a count-in such as ‘ready,
  steady, off we go’."""@en ;
  dcterms:modified "2026-06-07T15:29:24.401764Z"^^xsd:dateTime .

oakcurric:priorknowledge-2638-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experienced feeling the pulse through clapping, marching or other gross
  motor movements."""@en ;
  dcterms:modified "2026-06-07T15:29:24.401771Z"^^xsd:dateTime .

oakcurric:priorknowledge-2638-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the structure of call and response songs and games."@en ;
  dcterms:modified "2026-06-07T15:29:24.401776Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced singing together as a class."@en ;
  dcterms:modified "2026-06-07T15:29:24.431090Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had time to practise classroom routines such as sitting or standing in a
  circle and moving around the room safely."""@en ;
  dcterms:modified "2026-06-07T15:29:24.431105Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had opportunities to feel the pulse through clapping, marching or using
  other movements in time to the beat."""@en ;
  dcterms:modified "2026-06-07T15:29:24.431111Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that feeling the pulse helps to keep us in time."@en ;
  dcterms:modified "2026-06-07T15:29:24.431117Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand pitch as how high or low the sound is."@en ;
  dcterms:modified "2026-06-07T15:29:24.431122Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of chanting and clapping rhythms in time."@en ;
  dcterms:modified "2026-06-07T15:29:24.431127Z"^^xsd:dateTime .

oakcurric:priorknowledge-2641-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have sung songs using the toneset mi, so."@en ;
  dcterms:modified "2026-06-07T15:29:24.431132Z"^^xsd:dateTime .

oakcurric:priorknowledge-2639-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced singing together as a class."@en ;
  dcterms:modified "2026-06-07T15:29:25.259559Z"^^xsd:dateTime .

oakcurric:priorknowledge-2639-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are developing their ability to match the pitch in simple melodies."@en ;
  dcterms:modified "2026-06-07T15:29:25.259570Z"^^xsd:dateTime .

oakcurric:priorknowledge-2639-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are starting to change the way they sing a song for effect. For example,
  singing more quietly or more strongly."""@en ;
  dcterms:modified "2026-06-07T15:29:25.259575Z"^^xsd:dateTime .

oakcurric:priorknowledge-2639-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have used their voice in a variety of ways such as in chants and in call and
  response games."""@en ;
  dcterms:modified "2026-06-07T15:29:25.259580Z"^^xsd:dateTime .

oakcurric:priorknowledge-2639-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have played games that have supported their development of feeling
  the pulse."""@en ;
  dcterms:modified "2026-06-07T15:29:25.259585Z"^^xsd:dateTime .

oakcurric:priorknowledge-2644-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Classroom routines are established for singing games. For example, sitting in a
  circle, passing in time to the beat and singing tunefully as they play."""@en ;
  dcterms:modified "2026-06-07T15:29:25.292119Z"^^xsd:dateTime .

oakcurric:priorknowledge-2644-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had plenty of opportunities to feel the pulse through clapping, marching
  or using other movements in time to the beat."""@en ;
  dcterms:modified "2026-06-07T15:29:25.292131Z"^^xsd:dateTime .

oakcurric:priorknowledge-2644-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that music can be ‘notated’ and have previously used
  manipulatives, flashcards, images, graphic scores and/or stick notation to compose."""@en ;
  dcterms:modified "2026-06-07T15:29:25.292137Z"^^xsd:dateTime .

oakcurric:priorknowledge-2644-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand pitch as how high or low the sound is."@en ;
  dcterms:modified "2026-06-07T15:29:25.292142Z"^^xsd:dateTime .

oakcurric:priorknowledge-2644-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have explored representing a high/low pitch with a high/low action or placing
  a manipulative up high/low on paper or the interactive white board."""@en ;
  dcterms:modified "2026-06-07T15:29:25.292152Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Through singing a range of simple songs and chants including call and response
  pupils have learnt to perform together with a steady pulse."""@en ;
  dcterms:modified "2026-06-07T15:29:25.451235Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can pitch match songs with a small range of notes."@en ;
  dcterms:modified "2026-06-07T15:29:25.451252Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can match the pitch in age-appropriate songs."@en ;
  dcterms:modified "2026-06-07T15:29:25.451258Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can start and stop singing using a given signal."@en ;
  dcterms:modified "2026-06-07T15:29:25.451263Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can change how they sing to alter a performance, such as singing more quietly
  or faster."""@en ;
  dcterms:modified "2026-06-07T15:29:25.451269Z"^^xsd:dateTime .

oakcurric:priorknowledge-2646-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that they need to warm-up their voices for singing."@en ;
  dcterms:modified "2026-06-07T15:29:25.451274Z"^^xsd:dateTime .

oakcurric:priorknowledge-2642-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced singing together as a class."@en ;
  dcterms:modified "2026-06-07T15:29:25.460281Z"^^xsd:dateTime .

oakcurric:priorknowledge-2642-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are developing their ability to match the pitch in age-appropriate songs."@en ;
  dcterms:modified "2026-06-07T15:29:25.460294Z"^^xsd:dateTime .

oakcurric:priorknowledge-2642-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have had plenty of opportunities to feel the pulse through clapping, marching
  or using other movements in time to the beat."""@en ;
  dcterms:modified "2026-06-07T15:29:25.460301Z"^^xsd:dateTime .

oakcurric:priorknowledge-2642-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the structure of call and response songs and know when it is their
  turn to sing."""@en ;
  dcterms:modified "2026-06-07T15:29:25.460306Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experience of chanting and clapping rhythms in time."@en ;
  dcterms:modified "2026-06-07T15:29:25.737055Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experienced creating and clapping their own simple rhythms using text to
  support."""@en ;
  dcterms:modified "2026-06-07T15:29:25.737069Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have explored a range of tuned and untuned classroom percussion."@en ;
  dcterms:modified "2026-06-07T15:29:25.737076Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand pitch as how high or low the sound is."@en ;
  dcterms:modified "2026-06-07T15:29:25.737082Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have some experience of identifying and using larger instruments for lower
  sounds and smaller instruments for higher sounds."""@en ;
  dcterms:modified "2026-06-07T15:29:25.737087Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have experience of using appropriate words to describe sounds or the timbre
  of an instrument."""@en ;
  dcterms:modified "2026-06-07T15:29:25.737103Z"^^xsd:dateTime .

oakcurric:priorknowledge-2647-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that music can be ‘notated’ and have previously used
  manipulatives, flashcards, images and/or stick notation to compose."""@en ;
  dcterms:modified "2026-06-07T15:29:25.737111Z"^^xsd:dateTime .

oakcurric:priorknowledge-2637-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the structure of call and response songs and games."@en ;
  dcterms:modified "2026-06-07T15:29:25.837466Z"^^xsd:dateTime .

oakcurric:priorknowledge-2637-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that feeling the pulse keeps us in time when playing and singing
  together."""@en ;
  dcterms:modified "2026-06-07T15:29:25.837477Z"^^xsd:dateTime .

oakcurric:priorknowledge-2637-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have had some experience of chanting and clapping rhythms in time."@en ;
  dcterms:modified "2026-06-07T15:29:25.837483Z"^^xsd:dateTime .

oakcurric:priorknowledge-2637-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced creating and clapping their own simple rhythms."@en ;
  dcterms:modified "2026-06-07T15:29:25.837487Z"^^xsd:dateTime .

oakcurric:priorknowledge-2637-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have sung high-low songs (so, mi)."@en ;
  dcterms:modified "2026-06-07T15:29:25.837492Z"^^xsd:dateTime .

oakcurric:priorknowledge-2636-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Teachers have established some classroom routines that would be beneficial to the
  unit, such as sitting in a circle, echoing and moving around the room."""@en ;
  dcterms:modified "2026-06-07T15:29:25.899551Z"^^xsd:dateTime .

oakcurric:priorknowledge-2636-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have experienced rhythm and pulse as part of simple chants and rhymes."@en ;
  dcterms:modified "2026-06-07T15:29:25.899562Z"^^xsd:dateTime .

oakcurric:priorknowledge-2636-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have rehearsed coming in together guided by a count-in such as ‘ready,
  steady, off we go’."""@en ;
  dcterms:modified "2026-06-07T15:29:25.899568Z"^^xsd:dateTime .

oakcurric:priorknowledge-2636-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils will have experienced turn-taking in song as a precursor to learning to echo
  rhythmic patterns."""@en ;
  dcterms:modified "2026-06-07T15:29:25.899573Z"^^xsd:dateTime .

oakcurric:priorknowledge-2636-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils will have used representational pictures or manipulatives in other
