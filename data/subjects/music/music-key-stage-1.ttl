  dcterms:modified "2026-06-07T15:30:29.380205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20469-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can move in time to the music and know that pulse is the regular, steady
