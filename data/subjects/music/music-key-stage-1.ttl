oakcurric:pupillessonoutcome-lesson-20473
  a curric:PupilLessonOutcome ;
  rdfs:label "I can control my strong singing voice to suit a song without shouting."@en ;
  dcterms:modified "2026-06-07T15:30:41.077537Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20512
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create a rhythmic ostinato to help us keep in time together."@en ;
  dcterms:modified "2026-06-07T15:30:41.077873Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20472
  a curric:PupilLessonOutcome ;
  rdfs:label "I can control my soft singing voice to suit a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.078755Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20499
  a curric:PupilLessonOutcome ;
  rdfs:label "I can follow a conductor to change the mood of the song."@en ;
  dcterms:modified "2026-06-07T15:30:41.078792Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20511
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify and play the beat or rhythm of a song."@en ;
  dcterms:modified "2026-06-07T15:30:41.078882Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20479
  a curric:PupilLessonOutcome ;
  rdfs:label """I can echo a rhythm in time and know that rhythm is the pattern of sounds that we
  play and sing."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079023Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20474
  a curric:PupilLessonOutcome ;
  rdfs:label """I can change dynamics when singing and know that dynamics means how strong or soft I
  am singing."""@en ;
  dcterms:modified "2026-06-07T15:30:41.082753Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20515
  a curric:PupilLessonOutcome ;
  rdfs:label "I can hear the highest note of a song and can place this on a musical stave."@en ;
  dcterms:modified "2026-06-07T15:30:41.088025Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29875
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create an ocean soundscape and capture this using a graphic score."@en ;
  dcterms:modified "2026-06-07T15:30:41.089545Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29874
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create a seaside soundscape, thinking about timbre and dynamics."@en ;
  dcterms:modified "2026-06-07T15:30:41.089566Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29877
  a curric:PupilLessonOutcome ;
  rdfs:label """I can improvise a stormy seas soundscape and perform this as part of an
  ensemble."""@en ;
  dcterms:modified "2026-06-07T15:30:41.089748Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29876
  a curric:PupilLessonOutcome ;
  rdfs:label "I can layer vocal and body percussion cells to create a river soundscape."@en ;
  dcterms:modified "2026-06-07T15:30:41.089857Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20481
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use pictures to help me compose a rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:41.090584Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20478
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explore the sounds of our percussion instruments, starting and stopping with a
  leader."""@en ;
  dcterms:modified "2026-06-07T15:30:41.090745Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20466
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing an echo and know what an echo is."@en ;
  dcterms:modified "2026-06-07T15:30:41.093551Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20469
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing my part in our songs and know the difference between echo and call and
  response."""@en ;
  dcterms:modified "2026-06-07T15:30:41.094076Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20467
  a curric:PupilLessonOutcome ;
  rdfs:label "I can sing a response and know what a call and response song is."@en ;
  dcterms:modified "2026-06-07T15:30:41.094584Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20468
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create and sing a musical response as part of a call and response singing
  game."""@en ;
  dcterms:modified "2026-06-07T15:30:41.094795Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20470
  a curric:PupilLessonOutcome ;
  rdfs:label "I can play a steady beat on my instrument as we sing."@en ;
  dcterms:modified "2026-06-07T15:30:41.095941Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20490
  a curric:PupilLessonOutcome ;
  rdfs:label """I can move to the beat of the music and know when it is my turn to sing, move and
  respond in time."""@en ;
  dcterms:modified "2026-06-07T15:30:41.102136Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20493
  a curric:PupilLessonOutcome ;
  rdfs:label """I can hear tempo changes in a piece of music and can respond by moving in time to
  the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:41.102747Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20517
  a curric:PupilLessonOutcome ;
  rdfs:label "I can hear the lowest note of a song and can place this on a musical stave."@en ;
  dcterms:modified "2026-06-07T15:30:41.102962Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20516
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify the notes of a three note song and place these notes on a musical
  stave."""@en ;
  dcterms:modified "2026-06-07T15:30:41.103282Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20494
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use tempo changes to tell a musical story."@en ;
  dcterms:modified "2026-06-07T15:30:41.104325Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20513
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify high and low notes and know that melodies have different pitches."@en ;
  dcterms:modified "2026-06-07T15:30:41.104349Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20477
  a curric:PupilLessonOutcome ;
  rdfs:label "I can move, play and sing in time to the pulse."@en ;
  dcterms:modified "2026-06-07T15:30:41.104362Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20492
  a curric:PupilLessonOutcome ;
  rdfs:label """I can change the tempo of a song or musical game and can explain how this makes it
  feel different."""@en ;
  dcterms:modified "2026-06-07T15:30:41.104402Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20518
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify the notes of a four note song and place these notes on a musical
  stave."""@en ;
  dcterms:modified "2026-06-07T15:30:41.104451Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20509
  a curric:PupilLessonOutcome ;
  rdfs:label """I can sing my part in a call and response song and know that this structure is used
  in sea shanties and other songs of the sea."""@en ;
  dcterms:modified "2026-06-07T15:30:41.104685Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20465
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use my singing voice and sing songs with my friends."@en ;
  dcterms:modified "2026-06-07T15:30:41.107289Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20495
  a curric:PupilLessonOutcome ;
  rdfs:label "I can listen carefully and share ideas about how music makes me feel."@en ;
  dcterms:modified "2026-06-07T15:30:41.109048Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-melody
  a curric:Keyword ;
  schema:name "Melody"@en ;
  schema:description "the tune, usually the most memorable feature in a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.348126Z"^^xsd:dateTime .

oakcurric:keyword-accompaniment
  a curric:Keyword ;
  schema:name "accompaniment"@en ;
  schema:description "a part in the music that supports the melody"@en ;
  dcterms:modified "2026-06-07T15:30:02.348848Z"^^xsd:dateTime .

oakcurric:keyword-sea-shanty
  a curric:Keyword ;
  schema:name "sea shanty"@en ;
  schema:description """a folk song traditionally sung by sailors to help them coordinate their
  movements"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348886Z"^^xsd:dateTime .

oakcurric:keyword-syllable
  a curric:Keyword ;
  schema:name "syllable"@en ;
  schema:description "a single sound or beat in a word that contains a vowel sound"@en ;
  dcterms:modified "2026-06-07T15:30:02.348919Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-symbol
  a curric:Keyword ;
  schema:name "symbol"@en ;
  schema:description """a word, object, or image that represents a bigger idea or meaning beyond
  itself"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350718Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
  flow of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351040Z"^^xsd:dateTime .

oakcurric:keyword-ostinato
  a curric:Keyword ;
  schema:name "ostinato"@en ;
  schema:description "a short, repeating musical idea (plural: ostinati)"@en ;
  dcterms:modified "2026-06-07T15:30:02.351831Z"^^xsd:dateTime .

oakcurric:keyword-balance
  a curric:Keyword ;
  schema:name "balance"@en ;
  schema:description "keeping a steady and stable body position"@en ;
  dcterms:modified "2026-06-07T15:30:02.352576Z"^^xsd:dateTime .

oakcurric:keyword-actions
  a curric:Keyword ;
  schema:name "actions"@en ;
  schema:description "the movements we perform"@en ;
  dcterms:modified "2026-06-07T15:30:02.352724Z"^^xsd:dateTime .

oakcurric:keyword-dynamics
  a curric:Keyword ;
  schema:name "dynamics"@en ;
  schema:description "the speed and force of an action"@en ;
  dcterms:modified "2026-06-07T15:30:02.352729Z"^^xsd:dateTime .

oakcurric:keyword-unison
  a curric:Keyword ;
  schema:name "unison"@en ;
  schema:description "performing the same movement at exactly the same time as our partner"@en ;
  dcterms:modified "2026-06-07T15:30:02.353983Z"^^xsd:dateTime .

oakcurric:keyword-percussion
  a curric:Keyword ;
  schema:name "percussion"@en ;
  schema:description """instruments that produce sound by being struck or hit, including drums,
  cymbals, xylophones and many others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.354590Z"^^xsd:dateTime .

oakcurric:keyword-rehearse
  a curric:Keyword ;
  schema:name "rehearse"@en ;
  schema:description "to practise in order to improve and prepare for performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.354855Z"^^xsd:dateTime .

oakcurric:keyword-ensemble
  a curric:Keyword ;
  schema:name "ensemble"@en ;
  schema:description "a group of people who perform together"@en ;
  dcterms:modified "2026-06-07T15:30:02.354860Z"^^xsd:dateTime .

oakcurric:keyword-pulse
  a curric:Keyword ;
  schema:name "pulse"@en ;
  schema:description "the steady feel of the beat"@en ;
  dcterms:modified "2026-06-07T15:30:02.355256Z"^^xsd:dateTime .

oakcurric:keyword-performance
  a curric:Keyword ;
  schema:name "performance"@en ;
  schema:description """the act of executing the skill to the best of your ability, especially when
  it counts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355489Z"^^xsd:dateTime .

oakcurric:keyword-pitch
  a curric:Keyword ;
  schema:name "pitch"@en ;
  schema:description "how high or low a note is"@en ;
  dcterms:modified "2026-06-07T15:30:02.356597Z"^^xsd:dateTime .

oakcurric:keyword-note
  a curric:Keyword ;
  schema:name "note"@en ;
  schema:description "a single sound in music"@en ;
  dcterms:modified "2026-06-07T15:30:02.356604Z"^^xsd:dateTime .

oakcurric:keyword-stave
  a curric:Keyword ;
  schema:name "stave"@en ;
  schema:description "lines on which notes can be placed"@en ;
  dcterms:modified "2026-06-07T15:30:02.356608Z"^^xsd:dateTime .

oakcurric:keyword-pitched-percussion
  a curric:Keyword ;
  schema:name "pitched percussion"@en ;
  schema:description "an instrument that can play musical notes when we strike it"@en ;
  dcterms:modified "2026-06-07T15:30:02.356613Z"^^xsd:dateTime .

oakcurric:keyword-beat
  a curric:Keyword ;
  schema:name "beat"@en ;
  schema:description """the regular, repeated pulse or rhythm in music that dancers follow to stay
  in time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356782Z"^^xsd:dateTime .

oakcurric:keyword-composition
  a curric:Keyword ;
  schema:name "composition"@en ;
  schema:description "the arrangement of visual elements within an artwork"@en ;
  dcterms:modified "2026-06-07T15:30:02.357962Z"^^xsd:dateTime .

oakcurric:keyword-material
  a curric:Keyword ;
  schema:name "material"@en ;
  schema:description """A material is what an object is made from. An object can be made from more
  than one material."""@en ;
  dcterms:modified "2026-06-07T15:30:02.358135Z"^^xsd:dateTime .

oakcurric:keyword-tempo
  a curric:Keyword ;
  schema:name "tempo"@en ;
  schema:description "how fast or slow the music is played"@en ;
  dcterms:modified "2026-06-07T15:30:02.358536Z"^^xsd:dateTime .

oakcurric:keyword-singing-voice
  a curric:Keyword ;
  schema:name "singing voice"@en ;
  schema:description """the voice we use to create musical sounds that can be a mixture of high
  sounds and low sounds"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358969Z"^^xsd:dateTime .

oakcurric:keyword-call-and-response
  a curric:Keyword ;
  schema:name "call and response"@en ;
  schema:description "a question and answer musical structure"@en ;
  dcterms:modified "2026-06-07T15:30:02.358976Z"^^xsd:dateTime .

oakcurric:keyword-warm-up
  a curric:Keyword ;
  schema:name "warm-up"@en ;
  schema:description """a sequence of exercises used to prepare the mind, body and voice for singing
  / playing instruments"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358995Z"^^xsd:dateTime .

oakcurric:keyword-stick-notation
  a curric:Keyword ;
  schema:name "stick notation"@en ;
  schema:description "a way of writing rhythms down"@en ;
  dcterms:modified "2026-06-07T15:30:02.359113Z"^^xsd:dateTime .

oakcurric:keyword-percussion-instrument
  a curric:Keyword ;
  schema:name "percussion instrument"@en ;
  schema:description """a device used to make a musical sound which is played by striking, scraping
  or shaking"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359129Z"^^xsd:dateTime .

oakcurric:keyword-timbre
  a curric:Keyword ;
  schema:name "timbre"@en ;
  schema:description "the description of the sound or tone of an instrument"@en ;
  dcterms:modified "2026-06-07T15:30:02.364140Z"^^xsd:dateTime .

oakcurric:keyword-cell
  a curric:Keyword ;
  schema:name "cell"@en ;
  schema:description "a rectangular box in a spreadsheet used to store data"@en ;
  dcterms:modified "2026-06-07T15:30:02.366326Z"^^xsd:dateTime .

oakcurric:keyword-perform
  a curric:Keyword ;
  schema:name "perform"@en ;
  schema:description "presenting our work in front of others"@en ;
  dcterms:modified "2026-06-07T15:30:02.367344Z"^^xsd:dateTime .

oakcurric:keyword-practise
  a curric:Keyword ;
  schema:name "practise"@en ;
  schema:description "to deliberately make an effort to improve musical skills"@en ;
  dcterms:modified "2026-06-07T15:30:02.368419Z"^^xsd:dateTime .

oakcurric:keyword-sing
  a curric:Keyword ;
  schema:name "sing"@en ;
  schema:description """create musical sounds with our voice that can be a mixture of high sounds
  and low sounds"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368706Z"^^xsd:dateTime .

oakcurric:keyword-chant
  a curric:Keyword ;
  schema:name "chant"@en ;
  schema:description "speaking in time to a pulse"@en ;
  dcterms:modified "2026-06-07T15:30:02.368711Z"^^xsd:dateTime .

oakcurric:keyword-notation
  a curric:Keyword ;
  schema:name "notation"@en ;
  schema:description "a way of writing music down"@en ;
  dcterms:modified "2026-06-07T15:30:02.369215Z"^^xsd:dateTime .

oakcurric:keyword-improvise
  a curric:Keyword ;
  schema:name "improvise"@en ;
  schema:description """to create music in the moment, using the voice or instruments, alone or with
  others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.371357Z"^^xsd:dateTime .

oakcurric:keyword-conductor
  a curric:Keyword ;
  schema:name "conductor"@en ;
  schema:description "a person who directs musicians or singers"@en ;
  dcterms:modified "2026-06-07T15:30:02.371373Z"^^xsd:dateTime .

oakcurric:keyword-compose
  a curric:Keyword ;
  schema:name "compose"@en ;
  schema:description "to create a piece of music over time"@en ;
  dcterms:modified "2026-06-07T15:30:02.371497Z"^^xsd:dateTime .

oakcurric:keyword-instrumentation
  a curric:Keyword ;
  schema:name "instrumentation"@en ;
  schema:description "the combination of musical instruments used in a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.372637Z"^^xsd:dateTime .

oakcurric:keyword-2-time
  a curric:Keyword ;
  schema:name "2-time"@en ;
  schema:description "the organisation and feel of the beats as strong-weak"@en ;
  dcterms:modified "2026-06-07T15:30:02.372705Z"^^xsd:dateTime .

oakcurric:keyword-body-percussion
  a curric:Keyword ;
  schema:name "body percussion"@en ;
  schema:description "to make a percussive musical sound with the body"@en ;
  dcterms:modified "2026-06-07T15:30:02.372769Z"^^xsd:dateTime .

oakcurric:keyword-4-time
  a curric:Keyword ;
  schema:name "4-time"@en ;
  schema:description "the organisation and feel of the beats as: strong-weak-medium-weak"@en ;
  dcterms:modified "2026-06-07T15:30:02.372774Z"^^xsd:dateTime .

oakcurric:keyword-echo
  a curric:Keyword ;
  schema:name "echo"@en ;
  schema:description """the repetition of a sound; to repeat what someone else has said or
  thought"""@en ;
  dcterms:modified "2026-06-07T15:30:02.374448Z"^^xsd:dateTime .

oakcurric:keyword-composer
  a curric:Keyword ;
  schema:name "composer"@en ;
  schema:description "a person who creates music"@en ;
  dcterms:modified "2026-06-07T15:30:02.377481Z"^^xsd:dateTime .

oakcurric:keyword-notate
  a curric:Keyword ;
  schema:name "notate"@en ;
  schema:description "to write music down"@en ;
  dcterms:modified "2026-06-07T15:30:02.377754Z"^^xsd:dateTime .

oakcurric:keyword-graphic-score
  a curric:Keyword ;
  schema:name "graphic score"@en ;
  schema:description "a way of notating music using symbols, shapes or images"@en ;
  dcterms:modified "2026-06-07T15:30:02.377759Z"^^xsd:dateTime .

oakcurric:keyword-lyrics
  a curric:Keyword ;
  schema:name "lyrics"@en ;
  schema:description "the words of a song"@en ;
  dcterms:modified "2026-06-07T15:30:02.378572Z"^^xsd:dateTime .

oakcurric:keyword-song
  a curric:Keyword ;
  schema:name "song"@en ;
  schema:description "a short poem or other set of words set to music or meant to be sung"@en ;
  dcterms:modified "2026-06-07T15:30:02.378863Z"^^xsd:dateTime .

oakcurric:keyword-singing
  a curric:Keyword ;
  schema:name "singing"@en ;
  schema:description """creating musical sounds with our voice that can be a mixture of high sounds
