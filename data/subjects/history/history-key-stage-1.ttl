oakcurric:pupillessonoutcome-lesson-9605
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe how the Romans allowed Prasutagus and Boudica to rule the east of
  England."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063738Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9309
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe how Elizabeth I reacted to the threat of the Spanish Armada."@en ;
  dcterms:modified "2026-06-07T15:30:41.063997Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9587
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the early life of Aethelflaed and her return to court following the
  Viking invasion of Wessex."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067074Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9513
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe some of the jobs Victorian children had to do and what this was like
  for them"""@en ;
  dcterms:modified "2026-06-07T15:30:41.067313Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9303
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe how Constantine II strengthened the kingdom of Alba."@en ;
  dcterms:modified "2026-06-07T15:30:41.067413Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9601
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain why Suleiman's rule has been described as a 'Golden Age'."@en ;
  dcterms:modified "2026-06-07T15:30:41.068261Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9741
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe Eleanor and Louis' relationship and how they went on a crusade."@en ;
  dcterms:modified "2026-06-07T15:30:41.068709Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9312
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain why Nūr Jahān became so powerful."@en ;
  dcterms:modified "2026-06-07T15:30:41.068717Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9341
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe some of Queen Victoria's experiences of being a mother."@en ;
  dcterms:modified "2026-06-07T15:30:41.069685Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9285
  a curric:PupilLessonOutcome ;
  rdfs:label "I can retell some of the popular stories told about St. Patrick."@en ;
  dcterms:modified "2026-06-07T15:30:41.070174Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9284
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe the early life of St. Patrick, the patron saint of Ireland."@en ;
  dcterms:modified "2026-06-07T15:30:41.070182Z"^^xsd:dateTime .

