oakcurric:keyword-tragedy
  a curric:Keyword ;
  schema:name "tragedy"@en ;
  schema:description "a play dealing with tragic events and often ends with a death"@en ;
  dcterms:modified "2026-06-07T15:30:02.347535Z"^^xsd:dateTime .

oakcurric:keyword-duty
  a curric:Keyword ;
  schema:name "Duty"@en ;
  schema:description "Duty is a moral or legal obligation or responsibility."@en ;
  dcterms:modified "2026-06-07T15:30:02.348086Z"^^xsd:dateTime .

oakcurric:keyword-india
  a curric:Keyword ;
  schema:name "India"@en ;
  schema:description """In this historical context, India refers to the British-controlled
  territories in South Asia during the period of British colonial rule, including Punjab,
  the Sikh Empire's homeland."""@en ;
  dcterms:modified "2026-06-07T15:30:02.348354Z"^^xsd:dateTime .

oakcurric:keyword-evidence
  a curric:Keyword ;
  schema:name "evidence"@en ;
  schema:description "the information from a text that can support or justify our reasoning"@en ;
  dcterms:modified "2026-06-07T15:30:02.348463Z"^^xsd:dateTime .

oakcurric:keyword-monastery
  a curric:Keyword ;
  schema:name "monastery"@en ;
  schema:description """a monastery is a building where monks live and work together dedicated to
  religious life"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349961Z"^^xsd:dateTime .

oakcurric:keyword-ancient-romans
  a curric:Keyword ;
  schema:name "Ancient Romans"@en ;
  schema:description """the Ancient Romans were a group of people from Italy that took over lots of
