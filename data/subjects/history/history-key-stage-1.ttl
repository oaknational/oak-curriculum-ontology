# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Boudica was the wife of an important British king, Prasutagus; they lived with their
  daughters in the east of England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-2
  a curric:KeyLearningPoint ;
  rdfs:label "At this time, Britain was ruled over by a group of people called the Romans."@en ;
  dcterms:modified "2026-06-07T15:30:29.002444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans had come to Britain and forced the people living there to do what they
  said."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans allowed some kings, like Prasutagus, to keep on ruling if they did what
  they were told."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-5
  a curric:KeyLearningPoint ;
  rdfs:label """When Prasutagus died, Boudica became queen, but the Romans wanted to take control of
  her lands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth I faced one of her greatest challenges in 1588 when mighty Spain went to
  war with England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spain wanted to invade England and take control of it, so they sent a huge armada to
  do so."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth sent her best sailors to fight the Spanish in the English Channel to stop
  them from invading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the same time, Elizabeth made a famous speech to her army at Tilbury, saying she
  was as brave as any king."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although the English had fewer ships, they were helped by the weather, which blew
  the Spanish ships away from England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed was the daughter of Alfred, a king of a place in Britain called
  Wessex."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed lived in Britain at a time when her people, the Anglo-Saxons, were under
  attack from the Vikings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings had travelled across the sea to settle in Britain, and they were willing
  to fight for their new lands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-4
  a curric:KeyLearningPoint ;
  rdfs:label """As Aethelflaed grew up, the Vikings took more and more land, almost capturing Alfred
  and his family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-5
  a curric:KeyLearningPoint ;
  rdfs:label """When Aethelflaed was around the age of 16, her father Alfred won a big victory
  against the Vikings and made peace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-1
  a curric:KeyLearningPoint ;
  rdfs:label "Victorian childhood was very different to childhood today."@en ;
  dcterms:modified "2026-06-07T15:30:29.264008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many Victorian children needed to work, both in towns and in the countryside."@en ;
  dcterms:modified "2026-06-07T15:30:29.264012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a Victorian illustration, a child can be seen fainting in the fields due to the
  hard work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-4
  a curric:KeyLearningPoint ;
  rdfs:label """Children worked in factories and mines, and as chimney sweeps; these jobs were often
  very dangerous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historical sources show many children died or were injured doing these dangerous
  jobs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-1
  a curric:KeyLearningPoint ;
  rdfs:label """With the Vikings defeated, Constantine now set about strenghtening his kingdom of
  Alba."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-2
  a curric:KeyLearningPoint ;
  rdfs:label """He changed the Church to make it more like the one he had experienced in
  Ireland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-3
  a curric:KeyLearningPoint ;
  rdfs:label """He created a system of mormaers, local leaders who could help him rule over his
  lands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eventually he came into conflict with a powerful king from England and they fought a
  big battle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although Constantine lost, it stopped the king from England from taking control of
  parts of Scotland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Suleiman loved art, poetry and literature, even composing poems himself."@en ;
  dcterms:modified "2026-06-07T15:30:29.268802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-2
  a curric:KeyLearningPoint ;
  rdfs:label "He spent huge amounts of money making his palace a centre for art and writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.268806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists, poets and writers from all over the Ottoman Empire were paid to paint and
  write for him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-4
  a curric:KeyLearningPoint ;
  rdfs:label """With all these beautiful paintings and wonderful pieces of writing, this time has
  been called a 'Golden Age'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the West, people have given Suleiman the nickname, 'the Magnificent' because of
  this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shortly after her father's death, Eleanor married a French prince, Louis."@en ;
  dcterms:modified "2026-06-07T15:30:29.270700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-2
  a curric:KeyLearningPoint ;
  rdfs:label """Even though Louis became the Duke of Aquitaine, Eleanor got to keep her land for
  herself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-3
  a curric:KeyLearningPoint ;
  rdfs:label """Louis became King of France shortly after their marriage, and Eleanor helped him to
  rule."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor went with Louis on a crusade, travelling to Constantinople and
  Jerusalem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-5
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor and Louis' marriage broke down and it was annulled, leaving her free to
  marry again."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr was quite a sick man and described how Nūr Jahān was better than any doctor
  at making him feel better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr also wrote about how Nūr Jahān was a skilful hunter, managing to shoot a
  lion whilst sitting on an elephant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr was not a strong ruler, and gave Nūr Jahān his imperial seal, making her
  the true ruler of Mughal India."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-4
  a curric:KeyLearningPoint ;
  rdfs:label """This made her very powerful and she even minted her own coins and issued royal
  orders that everyone had to follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-5
  a curric:KeyLearningPoint ;
  rdfs:label """During the last years of Jahāngīr's life she used her power to build a huge white
  marble tomb for her father."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria wrote about her pregnancies in her diaries: she didn't like being pregnant
  and wrote newborn babies were ugly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria and Albert's first child, a girl they named Victoria, was born in November
  1840."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria and Albert had nine children together; her first son, Albert Edward, became
  king when Queen Victoria died."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-4
  a curric:KeyLearningPoint ;
  rdfs:label """When her 8th and 9th babies were born, Queen Victoria used special new medical
  invention called chloroform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thanks to Victoria, chloroform became quite popular, which helped many other women
  when they were having babies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-1
  a curric:KeyLearningPoint ;
  rdfs:label """Having returned to Britain, St. Patrick had a vision which convinced him to return
  to Ireland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-2
  a curric:KeyLearningPoint ;
  rdfs:label "When he reached Ireland, he travelled around teaching people about Christianity."@en ;
  dcterms:modified "2026-06-07T15:30:29.276666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-3
  a curric:KeyLearningPoint ;
  rdfs:label """One popular story about St. Patrick is how he used the shamrock to explain some
  important things about Christianity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-4
  a curric:KeyLearningPoint ;
  rdfs:label "The shamrock has since become one of the symbols of Ireland."@en ;
  dcterms:modified "2026-06-07T15:30:29.276675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-5
  a curric:KeyLearningPoint ;
  rdfs:label """Another popular story about St. Patrick was that he drove all of the snakes out of
  Ireland, chasing them into the sea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-1
  a curric:KeyLearningPoint ;
  rdfs:label """St. Patrick was born in Britain when it was controlled by a group of people called
  the Romans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-2
  a curric:KeyLearningPoint ;
  rdfs:label "He grew up in a Christian family but did not believe in God as a child."@en ;
  dcterms:modified "2026-06-07T15:30:29.276704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aged 16, he was captured by Irish raiders and taken as an enslaved person to Ireland
  for 6 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-4
  a curric:KeyLearningPoint ;
  rdfs:label """During his captivity, he worked as a shepherd and during this time his belief in God
  got stronger."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-5
  a curric:KeyLearningPoint ;
  rdfs:label """One day, he had a dream telling him that he would soon go home, so he fled to the
  coast and sailed back to Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-1
  a curric:KeyLearningPoint ;
  rdfs:label "After Boudica attacked London, the Roman army came back from Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.278563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans managed to trap Boudica and her warriors in a valley and attacked
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-3
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica's army was destroyed, and nobody knows exactly how Boudica died."@en ;
  dcterms:modified "2026-06-07T15:30:29.278571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-4
  a curric:KeyLearningPoint ;
  rdfs:label "Even though Boudica's rebellion failed, she is still remembered."@en ;
  dcterms:modified "2026-06-07T15:30:29.278575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is a statue of Boudica in London to remind us how brave she was and that she
  refused to be ruled by someone else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-1
  a curric:KeyLearningPoint ;
  rdfs:label """One of the most famous legends told about Robert the Bruce is the story of him and a
  spider."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-2
  a curric:KeyLearningPoint ;
  rdfs:label """While Robert was hiding from the English, it was said that he sheltered from the
  Scottish winter in a cave."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this cave, Robert watched a spider again and again try to spin its web; every
  time it fell it tried again."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-4
  a curric:KeyLearningPoint ;
  rdfs:label "This made Robert realise that he had to keep trying against the English."@en ;
  dcterms:modified "2026-06-07T15:30:29.278697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inspired by the spider, Robert returned to Scotland and eventually forced the
  English out of his homeland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-1
  a curric:KeyLearningPoint ;
  rdfs:label "At the time of Robert the Bruce, England and Scotland were separate countries."@en ;
  dcterms:modified "2026-06-07T15:30:29.280454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-2
  a curric:KeyLearningPoint ;
  rdfs:label """The English king, Edward I, invaded Scotland because he wanted them to do what he
  said."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-3
  a curric:KeyLearningPoint ;
  rdfs:label """Robert the Bruce was a young Scottish noble who decided to stand up to the English
  King."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-4
  a curric:KeyLearningPoint ;
  rdfs:label "He became King of Scotland and this made Edward very angry."@en ;
  dcterms:modified "2026-06-07T15:30:29.280466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-5
  a curric:KeyLearningPoint ;
  rdfs:label "Robert was forced to run away; his family were captured and put in prison."@en ;
  dcterms:modified "2026-06-07T15:30:29.280469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had an empire which meant it controlled a lot of places across the world,
  including countries in Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-2
  a curric:KeyLearningPoint ;
  rdfs:label """Towards the end of Victoria's reign, a woman called Alice Kinloch travelled a long
  way to come to Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alice Kinloch was born in South Africa, and had come to Britain with an important
  mission."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-4
  a curric:KeyLearningPoint ;
  rdfs:label """She wanted to speak out about the poor conditions that African miners faced when
  they worked to find diamonds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alice helped to set up a group of people to speak up and help the miners in South
  Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing up in India, Mehr al-Nesā married a Mughal official and together they had a
  baby daughter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, her husband was killed after an argument with the local governor, and Mehr
  al-Nesā became a widow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-3
  a curric:KeyLearningPoint ;
  rdfs:label """At this time, widows were welcomed to the Mughal Emperor's court to keep his wives
  company."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-4
  a curric:KeyLearningPoint ;
  rdfs:label """The emperor, Jahāngīr, had nineteen wives; when he saw Mehr al-Nesā he fell in love
  with her straight away."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-5
  a curric:KeyLearningPoint ;
  rdfs:label """They married and she was given a new title, Nūr Jahān (Light of the World), and
  became his favourite wife."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gaining support from many people in Wales, Owain and his forces captured many
  castles including Conwy castle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-2
  a curric:KeyLearningPoint ;
  rdfs:label "After a few years, Owain and his army had gained control of most of Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.291178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owain pronounced himself the Prince of Wales, a title that English kings had given
  to their heirs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, the English fought back and, after a few years, most of Wales was back
  under its control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-5
  a curric:KeyLearningPoint ;
  rdfs:label """Owain refused to surrender, now and again ambushing English soldiers who never
  managed to capture him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-1
  a curric:KeyLearningPoint ;
  rdfs:label "When Victoria became queen, she ruled England, Scotland, Wales and Ireland."@en ;
  dcterms:modified "2026-06-07T15:30:29.292595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1842, she was meant to go on holiday in Europe, but became ill so her advisers
  arranged for her to visit Scotland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both she and Albert fell in love with Scotland, buying an estate at Balmoral and
  building their own castle there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-4
  a curric:KeyLearningPoint ;
  rdfs:label """When Albert died in 1861, Victoria was very sad. She was comforted by John Brown, a
  Scottish servant at Balmoral."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-1
  a curric:KeyLearningPoint ;
  rdfs:label """Owain Glyndwr was a Welshman who was born at a time when England controlled
  Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-2
  a curric:KeyLearningPoint ;
  rdfs:label "He was descended from the princes of a part of Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.292663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-3
  a curric:KeyLearningPoint ;
  rdfs:label """As a young man he travelled to London to study law and even fought in an English
  army."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-4
  a curric:KeyLearningPoint ;
  rdfs:label """When he returned to Wales, he found that many people were unhappy with
  English rule."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-5
  a curric:KeyLearningPoint ;
  rdfs:label "Owain Glyndwr decided to fight to try and make Wales free from English rule."@en ;
  dcterms:modified "2026-06-07T15:30:29.292679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman was born in a place called the Ottoman Empire, which controlled lots of
  land in Europe and the Middle East."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman's father was the Sultan of the Ottoman Empire, and when he died in 1520,
  Suleiman became the new Sultan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman wanted to make his empire stronger by fighting wars and conquering
  land."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-4
  a curric:KeyLearningPoint ;
  rdfs:label "He conquered places all over Europe, North Africa and the Middle East."@en ;
  dcterms:modified "2026-06-07T15:30:29.294028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-5
  a curric:KeyLearningPoint ;
  rdfs:label """He even reached as far as the grand city of Vienna, but had to turn back because his
  army ran out of supplies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1199, Richard died during a siege in France and John became the King of
  England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-2
  a curric:KeyLearningPoint ;
  rdfs:label "However, John was not a successful king."@en ;
  dcterms:modified "2026-06-07T15:30:29.294239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-3
  a curric:KeyLearningPoint ;
  rdfs:label """He lost control of lots of English land in France and made his barons pay very high
  taxes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-4
  a curric:KeyLearningPoint ;
  rdfs:label "He also argued with the leaders of the Church."@en ;
  dcterms:modified "2026-06-07T15:30:29.294248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-5
  a curric:KeyLearningPoint ;
  rdfs:label "His actions made his barons very angry with him."@en ;
  dcterms:modified "2026-06-07T15:30:29.294253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-1
  a curric:KeyLearningPoint ;
  rdfs:label """John was the youngest son of Henry II and Eleanor of Aquitaine, the King and Queen
  of England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-2
  a curric:KeyLearningPoint ;
  rdfs:label "When Henry II died, John's older brother Richard became the King of England."@en ;
  dcterms:modified "2026-06-07T15:30:29.294527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-3
  a curric:KeyLearningPoint ;
  rdfs:label """Richard I was called the 'Lionheart' because he was a brave warrior who was often
  away from England fighting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-4
  a curric:KeyLearningPoint ;
  rdfs:label """One time, when Richard I was fighting on a crusade, John began to rule the country
  as if he was the king."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-5
  a curric:KeyLearningPoint ;
  rdfs:label """This made Richard I angry, and John was exiled for two years; but returned to be
  named Richard's heir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victoria's reign there were very clear groups of people, called classes, in
  society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ford Madox Brown's 1865 painting called 'Work' shows some of these alongside many
  other aspects of Victorian life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the middle of the painting are a group of workers called 'navvies', who are
  digging up the road to build a tunnel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-4
  a curric:KeyLearningPoint ;
  rdfs:label """Around them are both rich and poor men and women, a group of orphaned children and
  some sleeping unemployed men."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the top of the painting are two wealthy figures on horseback whose progress has
  been stopped by the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some of John's barons were so angry with him that they started a rebellion."@en ;
  dcterms:modified "2026-06-07T15:30:29.295679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-2
  a curric:KeyLearningPoint ;
  rdfs:label "To stop the fighting, John was forced to accept an agreement called Magna Carta."@en ;
  dcterms:modified "2026-06-07T15:30:29.295683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this agreement, John promised not to tax his barons so heavily, and to behave
  better in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-4
  a curric:KeyLearningPoint ;
  rdfs:label "Magna Carta made John weaker and his barons stronger."@en ;
  dcterms:modified "2026-06-07T15:30:29.295691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-5
  a curric:KeyLearningPoint ;
  rdfs:label """Even after John died, kings and queens that followed him have followed the
  agreements set out in Magna Carta."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When Mansa Musa returned from the Hajj he spent time in one of the cities that his
  generals had conquered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-2
  a curric:KeyLearningPoint ;
  rdfs:label """This city was Timbuktu, and Mansa Musa ordered great mosques to be built there to
  spread Islam."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-3
  a curric:KeyLearningPoint ;
  rdfs:label """Under Mansa Musa's rule, Timbuktu became very important for trade, with desert
  caravans linking it to North Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-4
  a curric:KeyLearningPoint ;
  rdfs:label """It also became a place of learning and education with one of the mosques made into a
  place for teaching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scholars travelled from all over the Islamic world to learn about history, Islam and
  law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-1
  a curric:KeyLearningPoint ;
  rdfs:label "Musa Keita was an important man living in the large and powerful empire of Mali."@en ;
  dcterms:modified "2026-06-07T15:30:29.295738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mansa of Mali wanted to explore beyond the seas, and set off on a voyage into
  the Atlantic Ocean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-3
  a curric:KeyLearningPoint ;
  rdfs:label """He gave the instruction that if he did not return, Musa Keita should become the
  mansa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-4
  a curric:KeyLearningPoint ;
  rdfs:label "He never returned, and Musa became Mansa Musa, emperor of Mali."@en ;
  dcterms:modified "2026-06-07T15:30:29.295750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mansa Musa used Mali's army to conquer lands rich with gold, making Mali even more
  powerful and wealthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-1
  a curric:KeyLearningPoint ;
  rdfs:label "As queen, Elizabeth I had lots of problems."@en ;
  dcterms:modified "2026-06-07T15:30:29.296694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-2
  a curric:KeyLearningPoint ;
  rdfs:label """England had a powerful enemy, Spain, and arguments over religion had torn the
  country apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's advisors wanted her to have children quickly so that if she died, her
  children could take over from her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, Elizabeth was more concerned with solving England's problems, and never
  married or had children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-5
  a curric:KeyLearningPoint ;
  rdfs:label "This has led her to be remembered as a queen who put her country before herself."@en ;
  dcterms:modified "2026-06-07T15:30:29.296709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alfred needed other parts of Britain to be strong again, so he arranged for
  Aethelflaed to marry the leader of Mercia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-2
  a curric:KeyLearningPoint ;
  rdfs:label """The man Aethelflaed married was called Aethelred, and together they made Mercia
  strong again to resist the Vikings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelred was much older than Aethelflaed; as he got old and sick and eventually
  died, Aethelflaed ruled Mercia herself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed stood up to the Vikings; ordering a group of soldiers to go on a special
  mission into Viking lands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-5
  a curric:KeyLearningPoint ;
  rdfs:label """The soldiers brought back the bones of an important Anglo-Saxon saint, Oswald, which
  won Aethelflaed a lot of respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor of Aquitaine was the daughter of the Duke of Aquitaine, an important
  landholder in what is modern France."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her father made sure that she received a good education and she was taught about
  literature, languages and how to ride!"""@en ;
  dcterms:modified "2026-06-07T15:30:29.299311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-3
  a curric:KeyLearningPoint ;
  rdfs:label """Her father expected her to marry a duke, prince or king, and this education would be
  very useful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, before he could see her married, the Duke of Aquitaine died, leaving
  Eleanor all of his lands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-5
  a curric:KeyLearningPoint ;
  rdfs:label "Just 13 years old, Eleanor was now the rich and powerful Duchess of Aquitaine."@en ;
  dcterms:modified "2026-06-07T15:30:29.299324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman was not just a powerful general; he cared about the law and making sure his
  empire was run fairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-2
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman changed the laws in the Ottoman Empire so that everyone followed the same
  rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-3
  a curric:KeyLearningPoint ;
  rdfs:label "He also spent lots of money improving the cities of his empire."@en ;
  dcterms:modified "2026-06-07T15:30:29.300109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-4
  a curric:KeyLearningPoint ;
  rdfs:label """In major Islamic cities like Mecca, Damascus and Baghdad he built great mosques,
  bridges and even aqueducts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-5
  a curric:KeyLearningPoint ;
  rdfs:label """He spent huge sums of money building an impressive mosque in Istanbul that is named
  after him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victorian times, the British Empire controlled many countries around the
  world including India."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-2
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had gradually taken control of more and more territory of India before and
  during Victoria's reign."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-3
  a curric:KeyLearningPoint ;
  rdfs:label "In 1876, Victoria was given the special title 'Empress of India'."@en ;
  dcterms:modified "2026-06-07T15:30:29.300837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-4
  a curric:KeyLearningPoint ;
  rdfs:label """Later in Victoria's life, one of her most faithful servants was called Abdul Karim,
  who was from India."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some of Victoria's other household servants were angered by Abdul and did not want
  to treat him as an equal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mansa Musa was a Muslim and his faith was very strong."@en ;
  dcterms:modified "2026-06-07T15:30:29.306491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-2
  a curric:KeyLearningPoint ;
  rdfs:label """He knew that as a Muslim, he should travel to the holy city of Mecca on a pilgrimage
  called the Hajj."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-3
  a curric:KeyLearningPoint ;
  rdfs:label """He made the long journey to Mecca accompanied by many people and camels, carrying
  huge amounts of gold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-4
  a curric:KeyLearningPoint ;
  rdfs:label "During the journey Mansa Musa gave this gold away to the people that he met."@en ;
  dcterms:modified "2026-06-07T15:30:29.306504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-5
  a curric:KeyLearningPoint ;
  rdfs:label """His journey and the gold made Mansa Musa and Mali famous throughout the Islamic
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mehr al-Nesā was born in Kandahar, part of the mighty Mughal Empire in what is now
  Afghanistan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her name meant 'sun among women', but she would later have a new name, Nūr
  Jahān."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-3
  a curric:KeyLearningPoint ;
  rdfs:label """Her parents were running away from another country where they had been treated
  badly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-4
  a curric:KeyLearningPoint ;
  rdfs:label """A story is told about Mehr al-Nesā during this time; that on their journey her
  parents abandoned her in the desert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-5
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling awful about what they had done, they returned to find their daughter sitting
  calmly next to a dangerous snake."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the month after the boycott, Raghbir Singh became Bristol's first bus conductor
  who was a person of colour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, Paul Stephenson continued to fight against the way people of colour were
  being treated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-3
  a curric:KeyLearningPoint ;
  rdfs:label """This is why he went into The Bay Horse pub; he wanted to make people realise that
  the boycott was not enough."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-4
  a curric:KeyLearningPoint ;
  rdfs:label """The boycott and Paul Stephenson's other work influenced the government to make a
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1965 and 1968, new laws were passed that said people of colour could not be
  treated unfairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Suffragettes did lots of things to fight for women to be allowed to vote."@en ;
  dcterms:modified "2026-06-07T15:30:29.309547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-2
  a curric:KeyLearningPoint ;
  rdfs:label """They were militant: prepared to break the law and go to prison to accomplish
  this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emily Davison was arrested lots of times for the things she did."@en ;
  dcterms:modified "2026-06-07T15:30:29.309555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-4
  a curric:KeyLearningPoint ;
  rdfs:label """She broke windows, set fire to postboxes and even threw stones at an important
  politician."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-5
  a curric:KeyLearningPoint ;
  rdfs:label """In prison, Emily even stopped eating to try to show how important it was for women
  to be allowed to vote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-1
  a curric:KeyLearningPoint ;
  rdfs:label "Emily Davison was born in South East London in 1872."@en ;
  dcterms:modified "2026-06-07T15:30:29.311937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-2
  a curric:KeyLearningPoint ;
  rdfs:label """When she was eight years old, one of her sisters died from a deadly disease,
  diphtheria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emily loved reading so much that she went on to study literature at university."@en ;
  dcterms:modified "2026-06-07T15:30:29.311945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-4
  a curric:KeyLearningPoint ;
  rdfs:label """She did well in her studies and got such high marks that she should have received a
  degree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-5
  a curric:KeyLearningPoint ;
  rdfs:label "However, as a woman, Emily was not allowed to get a degree."@en ;
  dcterms:modified "2026-06-07T15:30:29.311953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-1
  a curric:KeyLearningPoint ;
  rdfs:label "Not getting her degree because she was a woman made Emily Davison very angry."@en ;
  dcterms:modified "2026-06-07T15:30:29.312127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-2
  a curric:KeyLearningPoint ;
  rdfs:label "Something else that women were not allowed to do was to vote."@en ;
  dcterms:modified "2026-06-07T15:30:29.312131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-3
  a curric:KeyLearningPoint ;
  rdfs:label "This made Emily very angry as well."@en ;
  dcterms:modified "2026-06-07T15:30:29.312135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-4
  a curric:KeyLearningPoint ;
  rdfs:label "Emily joined a group of women who were fighting for women to be allowed to vote."@en ;
  dcterms:modified "2026-06-07T15:30:29.312139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-5
  a curric:KeyLearningPoint ;
  rdfs:label "This group was called the Suffragettes."@en ;
  dcterms:modified "2026-06-07T15:30:29.312143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-1
  a curric:KeyLearningPoint ;
  rdfs:label "In 1837, Victoria became queen when she was 18 years old."@en ;
  dcterms:modified "2026-06-07T15:30:29.312338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria was very popular when she became queen; 400,000 people visited London for
  her coronation in 1838."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-3
  a curric:KeyLearningPoint ;
  rdfs:label """She had little experience of how to rule the country and relied on her prime
  minister, who led the government, for help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-1
  a curric:KeyLearningPoint ;
  rdfs:label "Despite living some time apart, both Emily and Paul's stories are similar."@en ;
  dcterms:modified "2026-06-07T15:30:29.313510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-2
  a curric:KeyLearningPoint ;
  rdfs:label """They were both angry about something that affected them and other people in
  Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-3
  a curric:KeyLearningPoint ;
  rdfs:label "They both fought for equality."@en ;
  dcterms:modified "2026-06-07T15:30:29.313518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-4
  a curric:KeyLearningPoint ;
  rdfs:label """They were both prepared to go to prison for what they believed and to try and get
  things changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-5
  a curric:KeyLearningPoint ;
  rdfs:label "They are both recognised today as brave people who helped to change Britain."@en ;
  dcterms:modified "2026-06-07T15:30:29.313526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paul Stephenson was born in 1937 and was evacuated when he was three years old
  because of the Second World War."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-2
  a curric:KeyLearningPoint ;
  rdfs:label """He lived in the countryside for the next seven years and enjoyed paddling in streams
  and hunting rabbits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, Paul was always treated differently because he was the only black
  child."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-4
  a curric:KeyLearningPoint ;
  rdfs:label "When he returned to London his classmates made fun of the colour of his skin."@en ;
  dcterms:modified "2026-06-07T15:30:29.314242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1964, 51 years after Emily Davison's death, a man called Paul Stephenson walked
  into the Bay Horse Pub in Bristol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-2
  a curric:KeyLearningPoint ;
  rdfs:label "He ordered a drink, but before he could drink it the manager told him to leave."@en ;
  dcterms:modified "2026-06-07T15:30:29.316191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stephenson refused, and eight police officers came to arrest him."@en ;
  dcterms:modified "2026-06-07T15:30:29.316195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-4
  a curric:KeyLearningPoint ;
  rdfs:label "He was held in a police cell until midnight."@en ;
  dcterms:modified "2026-06-07T15:30:29.316201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-5
  a curric:KeyLearningPoint ;
  rdfs:label "The manager had told Stephenson to leave because he was black."@en ;
  dcterms:modified "2026-06-07T15:30:29.316205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-1
  a curric:KeyLearningPoint ;
  rdfs:label """After school Paul joined the RAF and spent time in Germany working with young
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-2
  a curric:KeyLearningPoint ;
  rdfs:label "After the RAF he studied youth work and moved to Bristol in 1962."@en ;
  dcterms:modified "2026-06-07T15:30:29.319251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-3
  a curric:KeyLearningPoint ;
  rdfs:label "He was the first black youth worker in Bristol."@en ;
  dcterms:modified "2026-06-07T15:30:29.319255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-4
  a curric:KeyLearningPoint ;
  rdfs:label "At this time many black people had come from the Caribbean to live in Bristol."@en ;
  dcterms:modified "2026-06-07T15:30:29.319259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-5
  a curric:KeyLearningPoint ;
  rdfs:label """Even though they had travelled to Britain to help the country recover after the war,
  they were not treated well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-1
  a curric:KeyLearningPoint ;
  rdfs:label "On the 4th of June 1913, a tragedy occurred at Epsom Racecourse."@en ;
  dcterms:modified "2026-06-07T15:30:29.319269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-2
  a curric:KeyLearningPoint ;
  rdfs:label """A woman called Emily Davison ran out onto the course during a big horse race called
  the Epsom Derby."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emily ran out onto the course because she was fighting for a change to take place in
  Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-4
  a curric:KeyLearningPoint ;
  rdfs:label "She was knocked over by the King's horse and died from her injuries."@en ;
  dcterms:modified "2026-06-07T15:30:29.319282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-1
  a curric:KeyLearningPoint ;
  rdfs:label """The year after Emily Davison died, a large war broke out and men in Britain had to
  go and fight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-2
  a curric:KeyLearningPoint ;
  rdfs:label """With the men gone, women had to take on their jobs; they showed how strong and
  capable they were."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the war, people appreciated how much women had done while the men were
  away."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-4
  a curric:KeyLearningPoint ;
  rdfs:label "They also remembered how brave suffragettes like Emily Davison were."@en ;
  dcterms:modified "2026-06-07T15:30:29.324347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-5
  a curric:KeyLearningPoint ;
  rdfs:label "As a result, it was decided that some women should be allowed to vote."@en ;
  dcterms:modified "2026-06-07T15:30:29.324351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two months after her marriage to Louis was annulled, Eleanor married Henry, who was
  next in line to the English throne."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-2
  a curric:KeyLearningPoint ;
  rdfs:label """Henry became the King of England, and Eleanor was his queen; together they ruled
  over large parts of France and England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, their marriage was not always happy and eventually Eleanor moved back to
  Aquitaine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-4
  a curric:KeyLearningPoint ;
  rdfs:label """When her sons decided to revolt against Henry, she supported them and Henry had her
  confined as punishment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, after Henry's death she helped two of her sons, Richard and John, to rule
  when they were king of England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-1
  a curric:KeyLearningPoint ;
  rdfs:label """After he defeated his father's enemy, Constantine became King of Alba, but he had no
  time to relax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-2
  a curric:KeyLearningPoint ;
  rdfs:label """His kingdom was under attack by the Vikings, who had taken control of an important
  place called Dunkeld."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-3
  a curric:KeyLearningPoint ;
  rdfs:label """The bones of an important Scottish saint, Saint Columba, were held there, and the
  Vikings had taken them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-4
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine led his army against the Vikings, driving them out and recapturing
  Dunkeld and the relics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many people in Victorian Britain were proud of new inventions that were introduced
  at that time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prince Albert was one of these people; in 1851, he organised the Great Exhibition to
  celebrate new modern inventions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Crystal Palace, a huge steel and glass building, was built for the
  exhibition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-4
  a curric:KeyLearningPoint ;
  rdfs:label """Albert invited inventors from all over Britain and the world to show off their
  inventions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-5
  a curric:KeyLearningPoint ;
  rdfs:label """More than six million people, roughly a third of Britain's population, visited the
  exhibition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before Victoria became queen she had met her cousin Albert several times, and
  described him as 'handsome'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although she did not marry him straight away, once Victoria was queen she proposed
  to Albert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-3
  a curric:KeyLearningPoint ;
  rdfs:label "Victoria and Albert were in love from the early days of their marriage."@en ;
  dcterms:modified "2026-06-07T15:30:29.328522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-4
  a curric:KeyLearningPoint ;
  rdfs:label """On their wedding day in 1840, Victoria wrote in her diary that 'This was the
  happiest day of my life!'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.328526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the age of 21, a young woman called Elizabeth found herself imprisoned in the
  Tower of London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-2
  a curric:KeyLearningPoint ;
  rdfs:label """She had been accused of plotting to take the throne by her older half-sister Mary,
  who was queen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-3
  a curric:KeyLearningPoint ;
  rdfs:label """It was very likely that Mary might order her to be executed, so Elizabeth wrote her
  a letter saying she was innocent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although Mary refused to see Elizabeth, she eventually freed her and Elizabeth's
  life was spared."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-5
  a curric:KeyLearningPoint ;
  rdfs:label "Soon after, Mary died and Elizabeth became Queen of England."@en ;
  dcterms:modified "2026-06-07T15:30:29.328548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-1
  a curric:KeyLearningPoint ;
  rdfs:label """Queen Victoria died in 1901 having reigned for 63 years; only Elizabeth II reigned
  for longer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-2
  a curric:KeyLearningPoint ;
  rdfs:label "By the time of Victoria's death, Britain had changed a great deal."@en ;
  dcterms:modified "2026-06-07T15:30:29.328738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Britain's empire had continued to grow, with Britain controlling land across six of
  the world's continents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-4
  a curric:KeyLearningPoint ;
  rdfs:label """Laws now protected children from working at a young age, and gave them the right to
  free education."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Laws had been passed to clean up dirty cities and to build new sewers and water
  supplies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-1
  a curric:KeyLearningPoint ;
  rdfs:label "Constantine was the son of a king in a part of Scotland called Alba."@en ;
  dcterms:modified "2026-06-07T15:30:29.328931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-2
  a curric:KeyLearningPoint ;
  rdfs:label """When he was very young, his father was killed by someone who wanted to rule in his
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine had to flee to Ireland where he lived with his aunt who was married to
  an Irish king."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine was educated at a nearby monastery and as he grew older he planned his
  revenge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-5
  a curric:KeyLearningPoint ;
  rdfs:label """Eventually Constantine returned to Scotland and defeated his father's enemy at a
  huge hillfort called Dundurn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans came to the lands of the Iceni, Boudica's tribe, and were very cruel to
  her and her daughters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-2
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica decided to fight to take back her land."@en ;
  dcterms:modified "2026-06-07T15:30:29.329198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-3
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica was lucky because the Roman army was far away, fighting in Wales."@en ;
  dcterms:modified "2026-06-07T15:30:29.329202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-4
  a curric:KeyLearningPoint ;
  rdfs:label """Boudica was able to attack and destroy three large Roman towns: Colchester, London
  and St Albans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-5
  a curric:KeyLearningPoint ;
  rdfs:label "However, her luck would soon run out."@en ;
  dcterms:modified "2026-06-07T15:30:29.329210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-1
  a curric:KeyLearningPoint ;
  rdfs:label "By the time of John Franklin, navigation by sea had become more advanced."@en ;
  dcterms:modified "2026-06-07T15:30:29.334701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-2
  a curric:KeyLearningPoint ;
  rdfs:label """Seafarers used new inventions like sextants and chronometers to work out where they
  were."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Larger, stronger ships meant that longer voyages were undertaken by European
  explorers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-4
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin's expedition used a new type of ship, steamships, fitted with propellers
  and a heating system."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-5
  a curric:KeyLearningPoint ;
  rdfs:label "During their voyage, Franklin's sailors had to endure freezing temperatures."@en ;
  dcterms:modified "2026-06-07T15:30:29.334722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-1
  a curric:KeyLearningPoint ;
  rdfs:label """Just under 200 years ago, a race was underway to see which would be the first
  steamship to cross the Atlantic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A British engineer called Isambard Kingdom Brunel designed the SS Great Western to
  try and achieve this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-3
  a curric:KeyLearningPoint ;
  rdfs:label "It was a wooden hulled steamship with masts, sails and a paddle wheel."@en ;
  dcterms:modified "2026-06-07T15:30:29.335664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-4
  a curric:KeyLearningPoint ;
  rdfs:label """The SS Great Western was narrowly beaten by the SS Sirius, which became the first
  steamship to cross the Atlantic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-5
  a curric:KeyLearningPoint ;
  rdfs:label """Brunel then designed and built the SS Great Britain, the first iron steamship with a
  propeller to cross the Atlantic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shortly after Zheng He's voyages, an Italian navigator and explorer called John
  Cabot was living in Bristol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-2
  a curric:KeyLearningPoint ;
  rdfs:label """He was sent by the English king, Henry VII, to find a shorter route to Asia, and to
  claim new lands for England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-3
  a curric:KeyLearningPoint ;
  rdfs:label """He tried to sail across the Atlantic but bad weather, food shortages and arguments
  with his crew meant he failed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-4
  a curric:KeyLearningPoint ;
  rdfs:label """He tried again the next year with a small ship, 'The Matthew', and a crew of just
  18, reaching what is now Canada."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-5
  a curric:KeyLearningPoint ;
  rdfs:label """The next year, the king sent Cabot on another trip to try and reach even further;
  Cabot and his ships never returned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vikings used fast, narrow boats called longboats for trading and raiding."@en ;
  dcterms:modified "2026-06-07T15:30:29.339899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-2
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats had oars, sails, and were both strong and flexible, allowing them to
  withstand strong waves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-3
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats had flat bottoms, allowing them to sail through shallow water and rivers
  when the tide was high."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-4
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats were often used for raiding and the sailors on board would hang their
  shields over the sides of the boat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Viking boats were light and fast, they could even be carried short distances over
  land to other rivers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-1
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like John Cabot, had begun to use boats more similar to those of
  Zheng He."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boats were pointed at the front and square at the back, with a rudder to help
  them steer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-3
  a curric:KeyLearningPoint ;
  rdfs:label """The boats had many sails and used rigging to support and control the sails to help
  them catch as much wind as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-4
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors had also begun to use the compass to navigate, like the Chinese
  before them, and the astrolabe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-5
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like John Cabot, used lead lines to work out how deep the water
  they were sailing in was."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-1
  a curric:KeyLearningPoint ;
  rdfs:label "Explorers often travel to places that are unknown to them."@en ;
  dcterms:modified "2026-06-07T15:30:29.341822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humans have always moved around and explored new places."@en ;
  dcterms:modified "2026-06-07T15:30:29.341826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humans explored to find new places to live, new survival essentials, or to escape
  danger."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some early explorers used very early types of boats like the hollowed out Pesse
  Canoe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He and other Chinese sailors were able to navigate across large distances
  because of various things they used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Chinese used strong ships called junks with many large sails."@en ;
  dcterms:modified "2026-06-07T15:30:29.342968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-3
  a curric:KeyLearningPoint ;
  rdfs:label """These ships had a rudder, which allowed the Chinese to steer them without oars,
  which was easier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Chinese were the first seafarers to use a compass, which made navigation more
  simple and reliable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the earliest seaborne explorers were a group of people known as
  Polynesians."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-2
  a curric:KeyLearningPoint ;
  rdfs:label """A long time ago Polynesians spread across the Pacific Ocean using canoes that they
  built."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-3
  a curric:KeyLearningPoint ;
  rdfs:label "These canoes had to have a strong hull and sail to travel across the ocean."@en ;
  dcterms:modified "2026-06-07T15:30:29.342990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Polynesians navigated to new islands by watching the waves and the paths of sea
  creatures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-1
  a curric:KeyLearningPoint ;
  rdfs:label """While the Polynesians were exploring the Pacific Ocean, other humans were exploring
  the Mediterranean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ancient Minoans, Phoenecians and Greeks used galleys to transport people and
  goods around the Mediterranean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Galleys had sails and many oars."@en ;
  dcterms:modified "2026-06-07T15:30:29.345108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-4
  a curric:KeyLearningPoint ;
  rdfs:label "Galleys were also used for warfare and would sometimes ram into each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.345112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Adams was an English sailor who went on many long voyages about 200 years
  after Zheng He."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adams wanted to follow in the footsteps of other explorers and travel to Asia."@en ;
  dcterms:modified "2026-06-07T15:30:29.345158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adams sailed across the Atlantic to the Americas with five ships, before crossing
  the Pacific with only two."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the voyage a huge storm sunk one of Adam's boats and he arrived in Japan with
  just one boat and a very sickly crew."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adam's voyage took over two years and he chose to stay in Japan, working with a
  local leader to build ships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SS Great Britain was an iron-hulled steamship and was the world's largest ship
  at the time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her role was to carry passengers across the Atlantic, and then to carry passengers
  to Australia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-3
  a curric:KeyLearningPoint ;
  rdfs:label """The passengers were divided into first-class and steerage; first-class paid more and
  had more luxurious cabins."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fresh food was taken but would be eaten at the start of the journey."@en ;
  dcterms:modified "2026-06-07T15:30:29.349188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-5
  a curric:KeyLearningPoint ;
  rdfs:label """First-class passengers had four meals with a huge choice; steerage passengers had to
  make do with simpler food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Franklin was a British explorer and an admiral in the Navy."@en ;
  dcterms:modified "2026-06-07T15:30:29.351297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin wanted to find the Northwest Passage, something that no one else had
  managed to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-3
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin's ships, the 'Erebus' & the 'Terror', were last seen waiting for ice to
  clear; none of the 129 crew survived."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1859, a note was found that revealed the ships had been abandoned, stuck in ice,
  and that Franklin was dead."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-1
  a curric:KeyLearningPoint ;
  rdfs:label "150 years ago, steam power was replacing sail power for ships."@en ;
  dcterms:modified "2026-06-07T15:30:29.365763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wooden-hulled ships, which had been used for thousands of years, were being replaced
  by iron-hulled ones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-3
  a curric:KeyLearningPoint ;
  rdfs:label """JMW Turner's painting, The Fighting Temeraire, is symbolic of this process, showing
  the final journey of the Temeraire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Temeraire, an old ship used in important battles, is being towed by a steam boat
  on its way to be broken up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is unlikely that Turner witnessed this event, but he has imagined it to make the
  point that seafaring was changing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He was a Chinese admiral and explorer and made his final voyage of discovery
  in 1432, which would be his furthest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-2
  a curric:KeyLearningPoint ;
  rdfs:label """First stopping at Changle on the Chinese coast, he ordered the inscription of
  granite stele describing his journeys."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He had made six other voyages in the seas of South East Asia and across the
  Indian Ocean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-4
  a curric:KeyLearningPoint ;
  rdfs:label """These voyages, made in huge 'treasure ships', were to show off Chinese power and
  force foreign rulers to pay tribute."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Having travelled to East Africa, the expedition returned, but without Zheng He, who
  had died and was buried at sea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-1
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like William Adams, had begun to use boats more similar to those
  of Zheng He."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boats were pointed at the front and square at the back, with a rudder to help
  them steer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-3
  a curric:KeyLearningPoint ;
  rdfs:label """The boats had many sails and used rigging to support and control the sails to help
  them catch as much wind as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-4
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors had also begun to use the compass to navigate, like the Chinese
  before them, and the astrolabe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-5
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like William Adams, used lead lines to work out how deep the water
  they were sailing in was."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victorian times, Britain changed a lot as people left the countryside to work
  in new factories in towns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some people thought these changes were good; this can be seen in William Wyld's
  painting 'Manchester from Kersal Moor'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-3
  a curric:KeyLearningPoint ;
  rdfs:label """He makes the factory chimneys look pretty by putting them next to church spires, and
  painting golden sunlight on them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-4
  a curric:KeyLearningPoint ;
  rdfs:label """But these cities and towns were not nice places to live, with lots of crowding,
  pollution and poor health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-5
  a curric:KeyLearningPoint ;
  rdfs:label """These poor conditions can be seen in Gustave Doré's engraving 'Over London - By
  Rail'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-1
  a curric:KeyLearningPoint ;
  rdfs:label """Almost 200 years ago, a woman called Victoria became the Queen of the United
  Kingdom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-2
  a curric:KeyLearningPoint ;
  rdfs:label """She would go on to rule for longer than any other monarch before her and be
  remembered as very important."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, when she was very little her life was very sad, later Victoria would
  describe it as 'melancholy'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-4
  a curric:KeyLearningPoint ;
  rdfs:label """She was very lonely; her father died when she was just one year old and her mother
  was very protective of her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-5
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria did not meet many other children, spending her days learning or playing
  with her dolls and her dog, Dash."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings used the sun, moon and stars to navigate, and also followed the path of
  birds and other animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some archaeologists have found wooden 'sun-shadow' boards that might have been used
  by the Vikings to navigate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Vikings used these techniques to travel long distances."@en ;
  dcterms:modified "2026-06-07T15:30:29.415297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings sailed far down the rivers of Europe to trading ports and met with
  traders from the Middle East and Asia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-5
  a curric:KeyLearningPoint ;
  rdfs:label "They even travelled as far as Iceland, Greenland and North America."@en ;
  dcterms:modified "2026-06-07T15:30:29.415338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Copernicus studied the night sky carefully and noticed the planets did not move as
  people expected them to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29813-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most people believed Earth was at the centre, but Copernicus bravely imagined the
  Sun at the centre instead."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29813-3
  a curric:KeyLearningPoint ;
  rdfs:label """His new idea explained why planets moved in loops in the night sky and helped people
  understand the sky in a new way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29813-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many leaders were shocked by his discovery because it challenged old beliefs they
  thought were correct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29813-5
  a curric:KeyLearningPoint ;
  rdfs:label """Later scientists used new tools to test his ideas and proved he was right about
  Earth moving around the Sun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29816-1
  a curric:KeyLearningPoint ;
  rdfs:label "Marie Curie studied rocks to uncover the invisible energy hidden inside them."@en ;
  dcterms:modified "2026-06-07T15:30:29.586722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29816-2
  a curric:KeyLearningPoint ;
  rdfs:label """She discovered two new elements, polonium and radium, through careful scientific
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29816-3
  a curric:KeyLearningPoint ;
  rdfs:label """What Marie learned about radium's powerful energy helped scientists create
  radiotherapy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29816-4
  a curric:KeyLearningPoint ;
  rdfs:label "She worked with her husband and other scientists."@en ;
  dcterms:modified "2026-06-07T15:30:29.586736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29816-5
  a curric:KeyLearningPoint ;
  rdfs:label "Her work changed medicine and still helps people today."@en ;
  dcterms:modified "2026-06-07T15:30:29.586741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ada Lovelace loved maths and had a strong imagination."@en ;
  dcterms:modified "2026-06-07T15:30:29.586769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29814-2
  a curric:KeyLearningPoint ;
  rdfs:label "She worked with Charles Babbage on a new kind of machine."@en ;
  dcterms:modified "2026-06-07T15:30:29.586774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29814-3
  a curric:KeyLearningPoint ;
  rdfs:label "She wrote notes that became the first ideas about computers."@en ;
  dcterms:modified "2026-06-07T15:30:29.586779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29814-4
  a curric:KeyLearningPoint ;
  rdfs:label "Few women studied science then, but Ada did."@en ;
  dcterms:modified "2026-06-07T15:30:29.586784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29814-5
  a curric:KeyLearningPoint ;
  rdfs:label "Her ideas inspired the computers of today."@en ;
  dcterms:modified "2026-06-07T15:30:29.586788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29815-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia Duleep Singh was a princess who chose to stand up for fairness instead of
  living a quiet royal life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29815-2
  a curric:KeyLearningPoint ;
  rdfs:label """She joined the Suffragettes, a group of brave women fighting for women to have the
  right to vote in Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29815-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia helped the movement by marching, speaking out, and selling Suffragette
  newspapers across London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29815-4
  a curric:KeyLearningPoint ;
  rdfs:label """She took risks for fairness, even when some people disapproved, because she believed
  women deserved a voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29815-5
  a curric:KeyLearningPoint ;
  rdfs:label """Her actions helped change the law so that women could vote, leaving a legacy of
  courage that inspires people today."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29817-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mandela fought against unfair laws called apartheid."@en ;
  dcterms:modified "2026-06-07T15:30:29.586834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29817-2
  a curric:KeyLearningPoint ;
  rdfs:label "He worked with others and protested against the unfair laws."@en ;
  dcterms:modified "2026-06-07T15:30:29.586841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29817-3
  a curric:KeyLearningPoint ;
  rdfs:label "He was imprisoned for many years."@en ;
  dcterms:modified "2026-06-07T15:30:29.586846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29817-4
  a curric:KeyLearningPoint ;
  rdfs:label "He forgave his enemies and became president."@en ;
  dcterms:modified "2026-06-07T15:30:29.586851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29817-5
  a curric:KeyLearningPoint ;
  rdfs:label "His ideas inspired peace around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.586856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29812-1
  a curric:KeyLearningPoint ;
  rdfs:label """Al-Razi was a doctor who used careful observation to understand why people became
  sick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29812-2
  a curric:KeyLearningPoint ;
  rdfs:label "He tested medicines to find better treatments."@en ;
  dcterms:modified "2026-06-07T15:30:29.586868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29812-3
  a curric:KeyLearningPoint ;
  rdfs:label """He chose a hospital location by observing how slowly meat rotted in clean, healthy
  air."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29812-4
  a curric:KeyLearningPoint ;
  rdfs:label """He treated rich and poor people alike, listening and learning from each patient he
  helped."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29812-5
  a curric:KeyLearningPoint ;
  rdfs:label """He shared ideas, and his books spread worldwide, helping doctors for hundreds of
  years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at Victorian seaside photographs can tell us about things that have changed
  or stayed the same over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at a photograph of a steam train can tell us about how people travelled to
  the seaside and if this has changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of people on the beach can tell us about what they did at the
  seaside and if this has changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of piers and ice cream sellers can tell us about what people enjoyed at
  the seaside and if this has changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photography is the process of capturing an image using a camera."@en ;
  dcterms:modified "2026-06-07T15:30:29.588273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-2
  a curric:KeyLearningPoint ;
  rdfs:label """This process produces a photograph, a picture of whatever the camera was
  pointed at."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-3
  a curric:KeyLearningPoint ;
  rdfs:label """Photography is quite a recent invention, and has only been used for about
  200 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs are interesting to historians because they have captured ways of life
  that have now disappeared."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of Britain from the 1940s and 1950s can tell us a lot about
  that time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of bomb damage and new types of housing can tell us about the effects of
  the Second World War."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photographs of kitchens can show us what life at home was like in the 1950s."@en ;
  dcterms:modified "2026-06-07T15:30:29.588402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of busy streets in London and Leeds can tell us about the sorts of
  transport people used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-5
  a curric:KeyLearningPoint ;
  rdfs:label """All of these photographs can tell us about things that have changed or stayed the
  same since these times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early photography was not like photography today, which is quick, easy and available
  to everyone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-2
  a curric:KeyLearningPoint ;
  rdfs:label """Not everyone could afford a photographer to take their picture, but it was still
  cheaper than having someone paint you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-3
  a curric:KeyLearningPoint ;
  rdfs:label """Early cameras were complicated, big and bulky compared to today's cameras and
  smartphones that can take photographs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-4
  a curric:KeyLearningPoint ;
  rdfs:label """Early cameras took a long time to take a photo, meaning people sitting for
  photographs had to stay very still."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-5
  a curric:KeyLearningPoint ;
  rdfs:label """Early photographs had to be developed using very complex processes involving
  chemicals and equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of Britain from the 1960s and 1970s can tell us about things
  that have changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs can tell us a lot about what people wore and the fashion during the
  1960s and 1970s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-3
  a curric:KeyLearningPoint ;
  rdfs:label """A 1960s photograph of children playing outside their homes can tell us a lot about
  childhood in the 1960s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of protests can show us how some people were not treated fairly in the
  1960s and 1970s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at a family portrait from 140 years ago can tell us a lot about that
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-2
  a curric:KeyLearningPoint ;
  rdfs:label "The number of children can tell us about the size of families."@en ;
  dcterms:modified "2026-06-07T15:30:29.588520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-3
  a curric:KeyLearningPoint ;
  rdfs:label "The clothes they are wearing can tell us about what was fashionable at the time."@en ;
  dcterms:modified "2026-06-07T15:30:29.588526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-4
  a curric:KeyLearningPoint ;
  rdfs:label "The objects in the photograph can tell us about their interests and pastimes."@en ;
  dcterms:modified "2026-06-07T15:30:29.588531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29809-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth II wore different clothes for each of her duties."@en ;
  dcterms:modified "2026-06-07T15:30:29.595875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29809-2
  a curric:KeyLearningPoint ;
  rdfs:label "Her clothes showed respect for people and places she visited."@en ;
  dcterms:modified "2026-06-07T15:30:29.595880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29809-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wearing a uniform showed her role as head of the armed forces."@en ;
  dcterms:modified "2026-06-07T15:30:29.595884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29809-4
  a curric:KeyLearningPoint ;
  rdfs:label "On visits abroad, she chose colours linked to that country."@en ;
  dcterms:modified "2026-06-07T15:30:29.595888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29809-5
  a curric:KeyLearningPoint ;
  rdfs:label "Her clothing told a story of service to many nations."@en ;
  dcterms:modified "2026-06-07T15:30:29.595892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29807-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth first spoke on the radio in 1940."@en ;
  dcterms:modified "2026-06-07T15:30:29.598720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29807-2
  a curric:KeyLearningPoint ;
  rdfs:label "Her message comforted children away from home."@en ;
  dcterms:modified "2026-06-07T15:30:29.598724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29807-3
  a curric:KeyLearningPoint ;
  rdfs:label "People listened to the radio but could not see her."@en ;
  dcterms:modified "2026-06-07T15:30:29.598728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29807-4
  a curric:KeyLearningPoint ;
  rdfs:label "Her words and voice showed care for her future subjects."@en ;
  dcterms:modified "2026-06-07T15:30:29.598733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29807-5
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking like this was part of her duty."@en ;
  dcterms:modified "2026-06-07T15:30:29.598737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29808-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth became queen in 1952 and was crowned in 1953."@en ;
  dcterms:modified "2026-06-07T15:30:29.604339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29808-2
  a curric:KeyLearningPoint ;
  rdfs:label "People watched on TV."@en ;
  dcterms:modified "2026-06-07T15:30:29.604343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29808-3
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth's coronation crown and jewels had special meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.604347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29808-4
  a curric:KeyLearningPoint ;
  rdfs:label "The four nations joined in celebration."@en ;
  dcterms:modified "2026-06-07T15:30:29.604351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29808-5
  a curric:KeyLearningPoint ;
  rdfs:label "It was a proud day."@en ;
  dcterms:modified "2026-06-07T15:30:29.604355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29806-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth was a child when war began."@en ;
  dcterms:modified "2026-06-07T15:30:29.607727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29806-2
  a curric:KeyLearningPoint ;
  rdfs:label "London was dangerous."@en ;
  dcterms:modified "2026-06-07T15:30:29.607731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29806-3
  a curric:KeyLearningPoint ;
  rdfs:label "The royal family stayed to show courage."@en ;
  dcterms:modified "2026-06-07T15:30:29.607735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29806-4
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth learned about duty."@en ;
  dcterms:modified "2026-06-07T15:30:29.607739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29806-5
  a curric:KeyLearningPoint ;
  rdfs:label "This was long before our families were born."@en ;
  dcterms:modified "2026-06-07T15:30:29.607743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29810-1
  a curric:KeyLearningPoint ;
  rdfs:label """As queen, Elizabeth travelled frequently across England, Scotland, Wales and
  Northern Ireland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29810-2
  a curric:KeyLearningPoint ;
  rdfs:label "She also visited many Commonwealth countries."@en ;
  dcterms:modified "2026-06-07T15:30:29.609797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29810-3
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth II met people to help charities."@en ;
  dcterms:modified "2026-06-07T15:30:29.609801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29810-4
  a curric:KeyLearningPoint ;
  rdfs:label "Her actions showed she was a queen for everyone."@en ;
  dcterms:modified "2026-06-07T15:30:29.609805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some historians think Emily was trying to put a suffragette banner on a horse at the
  racecourse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-2
  a curric:KeyLearningPoint ;
  rdfs:label "Others think that she was prepared to die so that women could get the vote."@en ;
  dcterms:modified "2026-06-07T15:30:29.610437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-3
  a curric:KeyLearningPoint ;
  rdfs:label "Whatever her motives, Emily was recognised at the time for being very brave."@en ;
  dcterms:modified "2026-06-07T15:30:29.610441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Suffragettes organised a large funeral procession; 5,000 of them marched in the
  streets of London with her coffin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-5
  a curric:KeyLearningPoint ;
  rdfs:label """50,000 people came out to watch her coffin moving through London and to pay
  respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Queen Elizabeth II died in 2022 after a long life."@en ;
  dcterms:modified "2026-06-07T15:30:29.613466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29811-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many people watched or attended her state funeral."@en ;
  dcterms:modified "2026-06-07T15:30:29.613470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29811-3
  a curric:KeyLearningPoint ;
  rdfs:label "Her son Charles became King Charles III when she died."@en ;
  dcterms:modified "2026-06-07T15:30:29.613474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29811-4
  a curric:KeyLearningPoint ;
  rdfs:label "People remembered her duty and kindness."@en ;
  dcterms:modified "2026-06-07T15:30:29.613482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29811-5
  a curric:KeyLearningPoint ;
  rdfs:label "Britain had changed a lot since Elizabeth was a child."@en ;
  dcterms:modified "2026-06-07T15:30:29.613486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-1
  a curric:KeyLearningPoint ;
  rdfs:label "One big problem that black people faced in Bristol was finding good jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.618378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-2
  a curric:KeyLearningPoint ;
  rdfs:label """Even though there were not enough workers on the city's buses, people of colour were
  not allowed to work on them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-3
  a curric:KeyLearningPoint ;
  rdfs:label """This made Paul Stephenson very angry and so with four men from the Caribbean islands
  he decided to take action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-4
  a curric:KeyLearningPoint ;
  rdfs:label """They organised a boycott of the city's buses, supported by students, celebrities and
  politicians."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-5
  a curric:KeyLearningPoint ;
  rdfs:label """After several months, the bus company agreed to allow people of colour to work on
  the buses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618395Z"^^xsd:dateTime .

