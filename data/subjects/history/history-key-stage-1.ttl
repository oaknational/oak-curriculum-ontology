# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Boudica was the wife of an important British king, Prasutagus; they lived with their daughters in the east of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-2
  a curric:KeyLearningPoint ;
  rdfs:label "At this time, Britain was ruled over by a group of people called the Romans."@en ;
  dcterms:modified "2026-02-12T08:59:21.481780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans had come to Britain and forced the people living there to do what they said."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans allowed some kings, like Prasutagus, to keep on ruling if they did what they were told."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9605-5
  a curric:KeyLearningPoint ;
  rdfs:label """When Prasutagus died, Boudica became queen, but the Romans wanted to take control of her lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth I faced one of her greatest challenges in 1588 when mighty Spain went to war with England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spain wanted to invade England and take control of it, so they sent a huge armada to do so."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth sent her best sailors to fight the Spanish in the English Channel to stop them from invading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the same time, Elizabeth made a famous speech to her army at Tilbury, saying she was as brave as any king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9309-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although the English had fewer ships, they were helped by the weather, which blew the Spanish ships away from England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-1
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like William Adams, had begun to use boats more similar to those of Zheng He."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boats were pointed at the front and square at the back, with a rudder to help them steer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-3
  a curric:KeyLearningPoint ;
  rdfs:label """The boats had many sails and used rigging to support and control the sails to help them catch as much wind as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-4
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors had also begun to use the compass to navigate, like the Chinese before them, and the astrolabe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9737-5
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like William Adams, used lead lines to work out how deep the water they were sailing in was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Franklin was a British explorer and an admiral in the Navy."@en ;
  dcterms:modified "2026-02-12T08:59:21.483408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin wanted to find the Northwest Passage, something that no one else had managed to do."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-3
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin's ships, the 'Erebus' & the 'Terror', were last seen waiting for ice to clear; none of the 129 crew survived."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9489-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1859, a note was found that revealed the ships had been abandoned, stuck in ice, and that Franklin was dead."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed was the daughter of Alfred, a king of a place in Britain called Wessex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed lived in Britain at a time when her people, the Anglo-Saxons, were under attack from the Vikings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings had travelled across the sea to settle in Britain, and they were willing to fight for their new lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-4
  a curric:KeyLearningPoint ;
  rdfs:label """As Aethelflaed grew up, the Vikings took more and more land, almost capturing Alfred and his family."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9587-5
  a curric:KeyLearningPoint ;
  rdfs:label """When Aethelflaed was around the age of 16, her father Alfred won a big victory against the Vikings and made peace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SS Great Britain was an iron-hulled steamship and was the world's largest ship at the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her role was to carry passengers across the Atlantic, and then to carry passengers to Australia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-3
  a curric:KeyLearningPoint ;
  rdfs:label """The passengers were divided into first-class and steerage; first-class paid more and had more luxurious cabins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fresh food was taken but would be eaten at the start of the journey."@en ;
  dcterms:modified "2026-02-12T08:59:21.483518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9739-5
  a curric:KeyLearningPoint ;
  rdfs:label """First-class passengers had four meals with a huge choice; steerage passengers had to make do with simpler food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-1
  a curric:KeyLearningPoint ;
  rdfs:label "By the time of John Franklin, navigation by sea had become more advanced."@en ;
  dcterms:modified "2026-02-12T08:59:21.483621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-2
  a curric:KeyLearningPoint ;
  rdfs:label """Seafarers used new inventions like sextants and chronometers to work out where they were."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Larger, stronger ships meant that longer voyages were undertaken by European explorers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-4
  a curric:KeyLearningPoint ;
  rdfs:label """Franklin's expedition used a new type of ship, steamships, fitted with propellers and a heating system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9738-5
  a curric:KeyLearningPoint ;
  rdfs:label "During their voyage, Franklin's sailors had to endure freezing temperatures."@en ;
  dcterms:modified "2026-02-12T08:59:21.483637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-1
  a curric:KeyLearningPoint ;
  rdfs:label "Victorian childhood was very different to childhood today."@en ;
  dcterms:modified "2026-02-12T08:59:21.483678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many Victorian children needed to work, both in towns and in the countryside."@en ;
  dcterms:modified "2026-02-12T08:59:21.483682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a Victorian illustration, a child can be seen fainting in the fields due to the hard work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-4
  a curric:KeyLearningPoint ;
  rdfs:label """Children worked in factories and mines, and as chimney sweeps; these jobs were often very dangerous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9513-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historical sources show many children died or were injured doing these dangerous jobs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-1
  a curric:KeyLearningPoint ;
  rdfs:label """With the Vikings defeated, Constantine now set about strenghtening his kingdom of Alba."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-2
  a curric:KeyLearningPoint ;
  rdfs:label """He changed the Church to make it more like the one he had experienced in Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-3
  a curric:KeyLearningPoint ;
  rdfs:label """He created a system of mormaers, local leaders who could help him rule over his lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eventually he came into conflict with a powerful king from England and they fought a big battle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9303-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although Constantine lost, it stopped the king from England from taking control of parts of Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photography is the process of capturing an image using a camera."@en ;
  dcterms:modified "2026-02-12T08:59:21.484615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-2
  a curric:KeyLearningPoint ;
  rdfs:label """This process produces a photograph, a picture of whatever the camera was pointed at."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-3
  a curric:KeyLearningPoint ;
  rdfs:label """Photography is quite a recent invention, and has only been used for about 200 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9278-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs are interesting to historians because they have captured ways of life that have now disappeared."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Suleiman loved art, poetry and literature, even composing poems himself."@en ;
  dcterms:modified "2026-02-12T08:59:21.484633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-2
  a curric:KeyLearningPoint ;
  rdfs:label "He spent huge amounts of money making his palace a centre for art and writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.484637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists, poets and writers from all over the Ottoman Empire were paid to paint and write for him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-4
  a curric:KeyLearningPoint ;
  rdfs:label """With all these beautiful paintings and wonderful pieces of writing, this time has been called a 'Golden Age'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9601-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the West, people have given Suleiman the nickname, 'the Magnificent' because of this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-1
  a curric:KeyLearningPoint ;
  rdfs:label """While the Polynesians were exploring the Pacific Ocean, other humans were exploring the Mediterranean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ancient Minoans, Phoenecians and Greeks used galleys to transport people and goods around the Mediterranean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Galleys had sails and many oars."@en ;
  dcterms:modified "2026-02-12T08:59:21.484848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9292-4
  a curric:KeyLearningPoint ;
  rdfs:label "Galleys were also used for warfare and would sometimes ram into each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.484856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shortly after her father's death, Eleanor married a French prince, Louis."@en ;
  dcterms:modified "2026-02-12T08:59:21.485083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-2
  a curric:KeyLearningPoint ;
  rdfs:label """Even though Louis became the Duke of Aquitaine, Eleanor got to keep her land for herself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-3
  a curric:KeyLearningPoint ;
  rdfs:label """Louis became King of France shortly after their marriage, and Eleanor helped him to rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor went with Louis on a crusade, travelling to Constantinople and Jerusalem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9741-5
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor and Louis' marriage broke down and it was annulled, leaving her free to marry again."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr was quite a sick man and described how Nūr Jahān was better than any doctor at making him feel better."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr also wrote about how Nūr Jahān was a skilful hunter, managing to shoot a lion whilst sitting on an elephant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jahāngīr was not a strong ruler, and gave Nūr Jahān his imperial seal, making her the true ruler of Mughal India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-4
  a curric:KeyLearningPoint ;
  rdfs:label """This made her very powerful and she even minted her own coins and issued royal orders that everyone had to follow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9312-5
  a curric:KeyLearningPoint ;
  rdfs:label """During the last years of Jahāngīr's life she used her power to build a huge white marble tomb for her father."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-1
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like John Cabot, had begun to use boats more similar to those of Zheng He."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boats were pointed at the front and square at the back, with a rudder to help them steer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-3
  a curric:KeyLearningPoint ;
  rdfs:label """The boats had many sails and used rigging to support and control the sails to help them catch as much wind as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-4
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors had also begun to use the compass to navigate, like the Chinese before them, and the astrolabe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9735-5
  a curric:KeyLearningPoint ;
  rdfs:label """European sailors, like John Cabot, used lead lines to work out how deep the water they were sailing in was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of Britain from the 1940s and 1950s can tell us a lot about that time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of bomb damage and new types of housing can tell us about the effects of the Second World War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photographs of kitchens can show us what life at home was like in the 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.485774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of busy streets in London and Leeds can tell us about the sorts of transport people used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9282-5
  a curric:KeyLearningPoint ;
  rdfs:label """All of these photographs can tell us about things that have changed or stayed the same since these times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria wrote about her pregnancies in her diaries: she didn't like being pregnant and wrote newborn babies were ugly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria and Albert's first child, a girl they named Victoria, was born in November 1840."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria and Albert had nine children together; her first son, Albert Edward, became king when Queen Victoria died."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-4
  a curric:KeyLearningPoint ;
  rdfs:label """When her 8th and 9th babies were born, Queen Victoria used special new medical invention called chloroform."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9341-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thanks to Victoria, chloroform became quite popular, which helped many other women when they were having babies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-1
  a curric:KeyLearningPoint ;
  rdfs:label """Having returned to Britain, St. Patrick had a vision which convinced him to return to Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-2
  a curric:KeyLearningPoint ;
  rdfs:label "When he reached Ireland, he travelled around teaching people about Christianity."@en ;
  dcterms:modified "2026-02-12T08:59:21.486563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-3
  a curric:KeyLearningPoint ;
  rdfs:label """One popular story about St. Patrick is how he used the shamrock to explain some important things about Christianity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-4
  a curric:KeyLearningPoint ;
  rdfs:label "The shamrock has since become one of the symbols of Ireland."@en ;
  dcterms:modified "2026-02-12T08:59:21.486571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9285-5
  a curric:KeyLearningPoint ;
  rdfs:label """Another popular story about St. Patrick was that he drove all of the snakes out of Ireland, chasing them into the sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-1
  a curric:KeyLearningPoint ;
  rdfs:label """St. Patrick was born in Britain when it was controlled by a group of people called the Romans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-2
  a curric:KeyLearningPoint ;
  rdfs:label "He grew up in a Christian family but did not believe in God as a child."@en ;
  dcterms:modified "2026-02-12T08:59:21.486583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aged 16, he was captured by Irish raiders and taken as an enslaved person to Ireland for 6 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-4
  a curric:KeyLearningPoint ;
  rdfs:label """During his captivity, he worked as a shepherd and during this time his belief in God got stronger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9284-5
  a curric:KeyLearningPoint ;
  rdfs:label """One day, he had a dream telling him that he would soon go home, so he fled to the coast and sailed back to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-1
  a curric:KeyLearningPoint ;
  rdfs:label "After Boudica attacked London, the Roman army came back from Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.487152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans managed to trap Boudica and her warriors in a valley and attacked them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-3
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica's army was destroyed, and nobody knows exactly how Boudica died."@en ;
  dcterms:modified "2026-02-12T08:59:21.487160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-4
  a curric:KeyLearningPoint ;
  rdfs:label "Even though Boudica's rebellion failed, she is still remembered."@en ;
  dcterms:modified "2026-02-12T08:59:21.487164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9607-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is a statue of Boudica in London to remind us how brave she was and that she refused to be ruled by someone else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-1
  a curric:KeyLearningPoint ;
  rdfs:label """One of the most famous legends told about Robert the Bruce is the story of him and a spider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-2
  a curric:KeyLearningPoint ;
  rdfs:label """While Robert was hiding from the English, it was said that he sheltered from the Scottish winter in a cave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this cave, Robert watched a spider again and again try to spin its web; every time it fell it tried again."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-4
  a curric:KeyLearningPoint ;
  rdfs:label "This made Robert realise that he had to keep trying against the English."@en ;
  dcterms:modified "2026-02-12T08:59:21.487189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9289-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inspired by the spider, Robert returned to Scotland and eventually forced the English out of his homeland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-1
  a curric:KeyLearningPoint ;
  rdfs:label "At the time of Robert the Bruce, England and Scotland were separate countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.487782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-2
  a curric:KeyLearningPoint ;
  rdfs:label """The English king, Edward I, invaded Scotland because he wanted them to do what he said."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-3
  a curric:KeyLearningPoint ;
  rdfs:label """Robert the Bruce was a young Scottish noble who decided to stand up to the English King."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-4
  a curric:KeyLearningPoint ;
  rdfs:label "He became King of Scotland and this made Edward very angry."@en ;
  dcterms:modified "2026-02-12T08:59:21.487794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9288-5
  a curric:KeyLearningPoint ;
  rdfs:label "Robert was forced to run away; his family were captured and put in prison."@en ;
  dcterms:modified "2026-02-12T08:59:21.487798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had an empire which meant it controlled a lot of places across the world, including countries in Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-2
  a curric:KeyLearningPoint ;
  rdfs:label """Towards the end of Victoria's reign, a woman called Alice Kinloch travelled a long way to come to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alice Kinloch was born in South Africa, and had come to Britain with an important mission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-4
  a curric:KeyLearningPoint ;
  rdfs:label """She wanted to speak out about the poor conditions that African miners faced when they worked to find diamonds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9514-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alice helped to set up a group of people to speak up and help the miners in South Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing up in India, Mehr al-Nesā married a Mughal official and together they had a baby daughter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, her husband was killed after an argument with the local governor, and Mehr al-Nesā became a widow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-3
  a curric:KeyLearningPoint ;
  rdfs:label """At this time, widows were welcomed to the Mughal Emperor's court to keep his wives company."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-4
  a curric:KeyLearningPoint ;
  rdfs:label """The emperor, Jahāngīr, had nineteen wives; when he saw Mehr al-Nesā he fell in love with her straight away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9311-5
  a curric:KeyLearningPoint ;
  rdfs:label """They married and she was given a new title, Nūr Jahān (Light of the World), and became his favourite wife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gaining support from many people in Wales, Owain and his forces captured many castles including Conwy castle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-2
  a curric:KeyLearningPoint ;
  rdfs:label "After a few years, Owain and his army had gained control of most of Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.600095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owain pronounced himself the Prince of Wales, a title that English kings had given to their heirs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, the English fought back and, after a few years, most of Wales was back under its control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9590-5
  a curric:KeyLearningPoint ;
  rdfs:label """Owain refused to surrender, now and again ambushing English soldiers who never managed to capture him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early photography was not like photography today, which is quick, easy and available to everyone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-2
  a curric:KeyLearningPoint ;
  rdfs:label """Not everyone could afford a photographer to take their picture, but it was still cheaper than having someone paint you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-3
  a curric:KeyLearningPoint ;
  rdfs:label """Early cameras were complicated, big and bulky compared to today's cameras and smartphones that can take photographs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-4
  a curric:KeyLearningPoint ;
  rdfs:label """Early cameras took a long time to take a photo, meaning people sitting for photographs had to stay very still."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9279-5
  a curric:KeyLearningPoint ;
  rdfs:label """Early photographs had to be developed using very complex processes involving chemicals and equipment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-1
  a curric:KeyLearningPoint ;
  rdfs:label "When Victoria became queen, she ruled England, Scotland, Wales and Ireland."@en ;
  dcterms:modified "2026-02-12T08:59:21.600617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1842, she was meant to go on holiday in Europe, but became ill  so her advisers arranged for her to visit Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both she and Albert fell in love with Scotland, buying an estate at Balmoral and building their own castle there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9516-4
  a curric:KeyLearningPoint ;
  rdfs:label """When Albert died in 1861, Victoria was very sad. She was comforted by John Brown, a Scottish servant at Balmoral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-1
  a curric:KeyLearningPoint ;
  rdfs:label """Owain Glyndwr was a Welshman who was born at a time when England controlled Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-2
  a curric:KeyLearningPoint ;
  rdfs:label "He was descended from the princes of a part of Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.600664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-3
  a curric:KeyLearningPoint ;
  rdfs:label """As a young man he travelled to London to study law and even fought in an English army."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-4
  a curric:KeyLearningPoint ;
  rdfs:label """When he returned to Wales, he found that many people were unhappy with English rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9589-5
  a curric:KeyLearningPoint ;
  rdfs:label "Owain Glyndwr decided to fight to try and make Wales free from English rule."@en ;
  dcterms:modified "2026-02-12T08:59:21.600692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of Britain from the 1960s and 1970s can tell us about things that have changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs can tell us a lot about what people wore and the fashion during the 1960s and 1970s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-3
  a curric:KeyLearningPoint ;
  rdfs:label """A 1960s photograph of children playing outside their homes can tell us a lot about childhood in the 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9283-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of protests can show us how some people were not treated fairly in the 1960s and 1970s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman was born in a place called the Ottoman Empire, which controlled lots of land in Europe and the Middle East."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman's father was the Sultan of the Ottoman Empire, and when he died in 1520, Suleiman became the new Sultan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman wanted to make his empire stronger by fighting wars and conquering land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-4
  a curric:KeyLearningPoint ;
  rdfs:label "He conquered places all over Europe, North Africa and the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.601841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9599-5
  a curric:KeyLearningPoint ;
  rdfs:label """He even reached as far as the grand city of Vienna, but had to turn back because his army ran out of supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1199, Richard died during a siege in France and John became the King of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-2
  a curric:KeyLearningPoint ;
  rdfs:label "However, John was not a successful king."@en ;
  dcterms:modified "2026-02-12T08:59:21.602020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-3
  a curric:KeyLearningPoint ;
  rdfs:label """He lost control of lots of English land in France and made his barons pay very high taxes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-4
  a curric:KeyLearningPoint ;
  rdfs:label "He also argued with the leaders of the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.602035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9305-5
  a curric:KeyLearningPoint ;
  rdfs:label "His actions made his barons very angry with him."@en ;
  dcterms:modified "2026-02-12T08:59:21.602043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-1
  a curric:KeyLearningPoint ;
  rdfs:label """John was the youngest son of Henry II and Eleanor of Aquitaine, the King and Queen of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-2
  a curric:KeyLearningPoint ;
  rdfs:label "When Henry II died, John's older brother Richard became the King of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.602329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-3
  a curric:KeyLearningPoint ;
  rdfs:label """Richard I was called the 'Lionheart' because he was a brave warrior who was often away from England fighting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-4
  a curric:KeyLearningPoint ;
  rdfs:label """One time, when Richard I was fighting on a crusade, John began to rule the country as if he was the king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9304-5
  a curric:KeyLearningPoint ;
  rdfs:label """This made Richard I angry, and John was exiled for two years; but returned to be named Richard's heir."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at a family portrait from 140 years ago can tell us a lot about that time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-2
  a curric:KeyLearningPoint ;
  rdfs:label "The number of children can tell us about the size of families."@en ;
  dcterms:modified "2026-02-12T08:59:21.603134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-3
  a curric:KeyLearningPoint ;
  rdfs:label "The clothes they are wearing can tell us about what was fashionable at the time."@en ;
  dcterms:modified "2026-02-12T08:59:21.603146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9280-4
  a curric:KeyLearningPoint ;
  rdfs:label "The objects in the photograph can tell us about their interests and pastimes."@en ;
  dcterms:modified "2026-02-12T08:59:21.603154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victoria's reign there were very clear groups of people, called classes, in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ford Madox Brown's 1865 painting called 'Work' shows some of these alongside many other aspects of Victorian life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the middle of the painting are a group of workers called  'navvies', who are digging up the road to build a tunnel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-4
  a curric:KeyLearningPoint ;
  rdfs:label """Around them are both rich and poor men and women, a group of orphaned children and some sleeping unemployed men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9866-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the top of the painting are two wealthy figures on horseback whose progress has been stopped by the work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some of John's barons were so angry with him that they started a rebellion."@en ;
  dcterms:modified "2026-02-12T08:59:21.603729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-2
  a curric:KeyLearningPoint ;
  rdfs:label "To stop the fighting, John was forced to accept an agreement called Magna Carta."@en ;
  dcterms:modified "2026-02-12T08:59:21.603741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this agreement, John promised not to tax his barons so heavily, and to behave better in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-4
  a curric:KeyLearningPoint ;
  rdfs:label "Magna Carta made John weaker and his barons stronger."@en ;
  dcterms:modified "2026-02-12T08:59:21.603757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9306-5
  a curric:KeyLearningPoint ;
  rdfs:label """Even after John died, kings and queens that followed him have followed the agreements set out in Magna Carta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When Mansa Musa returned from the Hajj he spent time in one of the cities that his generals had conquered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-2
  a curric:KeyLearningPoint ;
  rdfs:label """This city was Timbuktu, and Mansa Musa ordered great mosques to be built there to spread Islam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-3
  a curric:KeyLearningPoint ;
  rdfs:label """Under Mansa Musa's rule, Timbuktu became very important for trade, with desert caravans linking it to North Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-4
  a curric:KeyLearningPoint ;
  rdfs:label """It also became a place of learning and education with one of the mosques made into a place for teaching."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9610-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scholars travelled from all over the Islamic world to learn about history, Islam and law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-1
  a curric:KeyLearningPoint ;
  rdfs:label "Musa Keita was an important man living in the large and powerful empire of Mali."@en ;
  dcterms:modified "2026-02-12T08:59:21.603823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mansa of Mali wanted to explore beyond the seas, and set off on a voyage into the Atlantic Ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-3
  a curric:KeyLearningPoint ;
  rdfs:label """He gave the instruction that if he did not return, Musa Keita should become the mansa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-4
  a curric:KeyLearningPoint ;
  rdfs:label "He never returned, and Musa became Mansa Musa, emperor of Mali."@en ;
  dcterms:modified "2026-02-12T08:59:21.603847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9608-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mansa Musa used Mali's army to conquer lands rich with gold, making Mali even more powerful and wealthy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-1
  a curric:KeyLearningPoint ;
  rdfs:label "As queen, Elizabeth I had lots of problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.605017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-2
  a curric:KeyLearningPoint ;
  rdfs:label """England had a powerful enemy, Spain, and arguments over religion had torn the country apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's advisors wanted her to have children quickly so that if she died, her children could take over from her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, Elizabeth was more concerned with solving England's problems, and never married or had children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9308-5
  a curric:KeyLearningPoint ;
  rdfs:label "This has led her to be remembered as a queen who put her country before herself."@en ;
  dcterms:modified "2026-02-12T08:59:21.605048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alfred needed other parts of Britain to be strong again, so he arranged for Aethelflaed to marry the leader of Mercia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-2
  a curric:KeyLearningPoint ;
  rdfs:label """The man Aethelflaed married was called Aethelred, and together they made Mercia strong again to resist the Vikings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelred was much older than Aethelflaed; as he got old and sick and eventually died, Aethelflaed ruled Mercia herself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aethelflaed stood up to the Vikings; ordering a group of soldiers to go on a special mission into Viking lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9588-5
  a curric:KeyLearningPoint ;
  rdfs:label """The soldiers brought back the bones of an important Anglo-Saxon saint, Oswald, which won Aethelflaed a lot of respect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eleanor of Aquitaine was the daughter of the Duke of Aquitaine, an important landholder in what is modern France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her father made sure that she received a good education and she was taught about literature, languages and how to ride!"""@en ;
  dcterms:modified "2026-02-12T08:59:21.607889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-3
  a curric:KeyLearningPoint ;
  rdfs:label """Her father expected her to marry a duke, prince or king, and this education would be very useful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, before he could see her married, the Duke of Aquitaine died, leaving Eleanor all of his lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9740-5
  a curric:KeyLearningPoint ;
  rdfs:label "Just 13 years old, Eleanor was now the rich and powerful Duchess of Aquitaine."@en ;
  dcterms:modified "2026-02-12T08:59:21.607912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman was not just a powerful general; he cared about the law and making sure his empire was run fairly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-2
  a curric:KeyLearningPoint ;
  rdfs:label """Suleiman changed the laws in the Ottoman Empire so that everyone followed the same rules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-3
  a curric:KeyLearningPoint ;
  rdfs:label "He also spent lots of money improving the cities of his empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.608787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-4
  a curric:KeyLearningPoint ;
  rdfs:label """In major Islamic cities like Mecca, Damascus and Baghdad he built great mosques, bridges and even aqueducts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9600-5
  a curric:KeyLearningPoint ;
  rdfs:label """He spent huge sums of money building an impressive mosque in Istanbul that is named after him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victorian times, the British Empire controlled many countries around the world including India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-2
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had gradually taken control of more and more territory of India before and during Victoria's reign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-3
  a curric:KeyLearningPoint ;
  rdfs:label "In 1876, Victoria was given the special title 'Empress of India'."@en ;
  dcterms:modified "2026-02-12T08:59:21.609260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-4
  a curric:KeyLearningPoint ;
  rdfs:label """Later in Victoria's life, one of her most faithful servants was called Abdul Karim, who was from India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9515-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some of Victoria's other household servants were angered by Abdul and did not want to treat him as an equal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mansa Musa was a Muslim and his faith was very strong."@en ;
  dcterms:modified "2026-02-12T08:59:21.613498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-2
  a curric:KeyLearningPoint ;
  rdfs:label """He knew that as a Muslim, he should travel to the holy city of Mecca on a pilgrimage called the Hajj."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-3
  a curric:KeyLearningPoint ;
  rdfs:label """He made the long journey to Mecca accompanied by many people and camels, carrying huge amounts of gold."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-4
  a curric:KeyLearningPoint ;
  rdfs:label "During the journey Mansa Musa gave this gold away to the people that he met."@en ;
  dcterms:modified "2026-02-12T08:59:21.613518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9609-5
  a curric:KeyLearningPoint ;
  rdfs:label """His journey and the gold made Mansa Musa and Mali famous throughout the Islamic world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mehr al-Nesā was born in Kandahar, part of the mighty Mughal Empire in what is now Afghanistan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-2
  a curric:KeyLearningPoint ;
  rdfs:label """Her name meant 'sun among women', but she would later have a new name, Nūr Jahān."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-3
  a curric:KeyLearningPoint ;
  rdfs:label """Her parents were running away from another country where they had been treated badly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-4
  a curric:KeyLearningPoint ;
  rdfs:label """A story is told about Mehr al-Nesā during this time; that on their journey her parents abandoned her in the desert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9310-5
  a curric:KeyLearningPoint ;
  rdfs:label """Feeling awful about what they had done, they returned to find their daughter sitting calmly next to a dangerous snake."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9266-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth was born in one of her family's houses in Mayfair, London on the 21st April 1926."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9266-2
  a curric:KeyLearningPoint ;
  rdfs:label """She was born into the royal family, her parents were the Duke and Duchess of York."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9266-3
  a curric:KeyLearningPoint ;
  rdfs:label """When she was still a baby, her parents had to go on an official visit to Australia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9266-4
  a curric:KeyLearningPoint ;
  rdfs:label """During this time she spent a lot of time with her grandparents, King George V and Queen Mary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9266-5
  a curric:KeyLearningPoint ;
  rdfs:label "They kept her parents informed of her development through telegram."@en ;
  dcterms:modified "2026-02-12T08:59:21.614564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9269-1
  a curric:KeyLearningPoint ;
  rdfs:label """Like many girls from wealthy families at this time, Elizabeth was educated at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9269-2
  a curric:KeyLearningPoint ;
  rdfs:label """She learnt French from her governesses, which she would later use when visiting Canada."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9269-3
  a curric:KeyLearningPoint ;
  rdfs:label "She also learnt to ride horses, and joined the Girl Guides and Sea Rangers."@en ;
  dcterms:modified "2026-02-12T08:59:21.615113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9269-4
  a curric:KeyLearningPoint ;
  rdfs:label """When she became first in line to the throne, her education changed to prepare her to be queen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9269-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth had to study law and the history of kings and queens; the Archbishop of Canterbury taught her about religion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the month after the boycott, Raghbir Singh became Bristol's first bus conductor who was a person of colour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, Paul Stephenson continued to fight against the way people of colour were being treated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-3
  a curric:KeyLearningPoint ;
  rdfs:label """This is why he went into The Bay Horse pub; he wanted to make people realise that the boycott was not enough."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-4
  a curric:KeyLearningPoint ;
  rdfs:label """The boycott and Paul Stephenson's other work influenced the government to make a change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9512-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1965 and 1968, new laws were passed that said people of colour could not be treated unfairly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Suffragettes did lots of things to fight for women to be allowed to vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.615765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-2
  a curric:KeyLearningPoint ;
  rdfs:label """They were militant: prepared to break the law and go to prison to accomplish this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emily Davison was arrested lots of times for the things she did."@en ;
  dcterms:modified "2026-02-12T08:59:21.615777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-4
  a curric:KeyLearningPoint ;
  rdfs:label """She broke windows, set fire to postboxes and even threw stones at an important politician."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9504-5
  a curric:KeyLearningPoint ;
  rdfs:label """In prison, Emily even stopped eating to try to show how important it was for women to be allowed to vote."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9267-1
  a curric:KeyLearningPoint ;
  rdfs:label """By the time her parents returned from Australia, Elizabeth had grown into a confident and cheeky child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9267-2
  a curric:KeyLearningPoint ;
  rdfs:label """Despite being a princess, like other children she had a nickname which was 'Lilibet'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9267-3
  a curric:KeyLearningPoint ;
  rdfs:label """During the family's Christmas party in 1927, she climbed onto the table and threw biscuits at the guests!"""@en ;
  dcterms:modified "2026-02-12T08:59:21.616227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9267-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once, the Archbishop of Canterbury visited George V and found Elizabeth leading him around like a horse by his beard!"""@en ;
  dcterms:modified "2026-02-12T08:59:21.616237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9267-5
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth was very fond of horses and dogs which continued into her adult life."@en ;
  dcterms:modified "2026-02-12T08:59:21.616244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-1
  a curric:KeyLearningPoint ;
  rdfs:label "Emily Davison was born in South East London in 1872."@en ;
  dcterms:modified "2026-02-12T08:59:21.617485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-2
  a curric:KeyLearningPoint ;
  rdfs:label """When she was eight years old, one of her sisters died from a deadly disease, diphtheria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emily loved reading so much that she went on to study literature at university."@en ;
  dcterms:modified "2026-02-12T08:59:21.617497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-4
  a curric:KeyLearningPoint ;
  rdfs:label """She did well in her studies and got such high marks that she should have received a degree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9502-5
  a curric:KeyLearningPoint ;
  rdfs:label "However, as a woman, Emily was not allowed to get a degree."@en ;
  dcterms:modified "2026-02-12T08:59:21.617514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9268-1
  a curric:KeyLearningPoint ;
  rdfs:label "In 1936 Elizabeth was 10 years old and her uncle was king: Edward VIII."@en ;
  dcterms:modified "2026-02-12T08:59:21.617588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9268-2
  a curric:KeyLearningPoint ;
  rdfs:label """Because Edward was king, his children, if he was to have any, would become the next king or queen after him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9268-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth and her family led a quiet family life, spending time at their country house in Windsor Great Park."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9268-4
  a curric:KeyLearningPoint ;
  rdfs:label "In 1936, Edward VIII abdicated, shocking Elizabeth and her family."@en ;
  dcterms:modified "2026-02-12T08:59:21.617606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9268-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's father was now the king, George VI, and Elizabeth would now become queen when he died."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-1
  a curric:KeyLearningPoint ;
  rdfs:label "Not getting her degree because she was a woman made Emily Davison very angry."@en ;
  dcterms:modified "2026-02-12T08:59:21.617622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-2
  a curric:KeyLearningPoint ;
  rdfs:label "Something else that women were not allowed to do was to vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.617631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-3
  a curric:KeyLearningPoint ;
  rdfs:label "This made Emily very angry as well."@en ;
  dcterms:modified "2026-02-12T08:59:21.617638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-4
  a curric:KeyLearningPoint ;
  rdfs:label "Emily joined a group of women who were fighting for women to be allowed to vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.617644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9503-5
  a curric:KeyLearningPoint ;
  rdfs:label "This group was called the Suffragettes."@en ;
  dcterms:modified "2026-02-12T08:59:21.617650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-1
  a curric:KeyLearningPoint ;
  rdfs:label "In 1837, Victoria became queen when she was 18 years old."@en ;
  dcterms:modified "2026-02-12T08:59:21.617795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria was very popular when she became queen; 400,000 people visited London for her coronation in 1838."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9339-3
  a curric:KeyLearningPoint ;
  rdfs:label """She had little experience of how to rule the country and relied on her prime minister, who led the government, for help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He was a Chinese admiral and explorer and made his final voyage of discovery in 1432, which would be his furthest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-2
  a curric:KeyLearningPoint ;
  rdfs:label """First stopping at Changle on the Chinese coast, he ordered the inscription of granite stele describing his journeys."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He had made six other voyages in the seas of South East Asia and across the Indian Ocean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-4
  a curric:KeyLearningPoint ;
  rdfs:label """These voyages, made in huge 'treasure ships', were to show off Chinese power and force foreign rulers to pay tribute."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Having travelled to East Africa, the expedition returned, but without Zheng He, who had died and was buried at sea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vikings used fast, narrow boats called longboats for trading and raiding."@en ;
  dcterms:modified "2026-02-12T08:59:21.618071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-2
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats had oars, sails, and were both strong and flexible, allowing them to withstand strong waves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-3
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats had flat bottoms, allowing them to sail through shallow water and rivers when the tide was high."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-4
  a curric:KeyLearningPoint ;
  rdfs:label """Longboats were often used for raiding and the sailors on board would hang their shields over the sides of the boat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Viking boats were light and fast, they could even be carried short distances over land to other rivers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Adams was an English sailor who went on many long voyages about 200 years after Zheng He."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adams wanted to follow in the footsteps of other explorers and travel to Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.618141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adams sailed across the Atlantic to the Americas with five ships, before crossing the Pacific with only two."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the voyage a huge storm sunk one of Adam's boats and he arrived in Japan with just one boat and a very sickly crew."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9736-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adam's voyage took over two years and he chose to stay in Japan, working with a local leader to build ships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings used the sun, moon and stars to navigate, and also followed the path of birds and other animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some archaeologists have found wooden 'sun-shadow' boards that might have been used by the Vikings to navigate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Vikings used these techniques to travel long distances."@en ;
  dcterms:modified "2026-02-12T08:59:21.618432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Vikings sailed far down the rivers of Europe to trading ports and met with traders from the Middle East and Asia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9294-5
  a curric:KeyLearningPoint ;
  rdfs:label "They even travelled as far as Iceland, Greenland and North America."@en ;
  dcterms:modified "2026-02-12T08:59:21.618444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-1
  a curric:KeyLearningPoint ;
  rdfs:label "Despite living some time apart, both Emily and Paul's stories are similar."@en ;
  dcterms:modified "2026-02-12T08:59:21.618634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-2
  a curric:KeyLearningPoint ;
  rdfs:label """They were both angry about something that affected them and other people in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-3
  a curric:KeyLearningPoint ;
  rdfs:label "They both fought for equality."@en ;
  dcterms:modified "2026-02-12T08:59:21.618646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-4
  a curric:KeyLearningPoint ;
  rdfs:label """They were both prepared to go to prison for what they believed and to try and get things changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9510-5
  a curric:KeyLearningPoint ;
  rdfs:label "They are both recognised today as brave people who helped to change Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.618659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paul Stephenson was born in 1937 and was evacuated when he was three years old because of the Second World War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-2
  a curric:KeyLearningPoint ;
  rdfs:label """He lived in the countryside for the next seven years and enjoyed paddling in streams and hunting rabbits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, Paul was always treated differently because he was the only black child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9508-4
  a curric:KeyLearningPoint ;
  rdfs:label "When he returned to London his classmates made fun of the colour of his skin."@en ;
  dcterms:modified "2026-02-12T08:59:21.619133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-1
  a curric:KeyLearningPoint ;
  rdfs:label """During Victorian times, Britain changed a lot as people left the countryside to work in new factories in towns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some people thought these changes were good; this can be seen in William Wyld's painting 'Manchester from Kersal Moor'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-3
  a curric:KeyLearningPoint ;
  rdfs:label """He makes the factory chimneys look pretty by putting them next to church spires, and painting golden sunlight on them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-4
  a curric:KeyLearningPoint ;
  rdfs:label """But these cities and towns were not nice places to live, with lots of crowding, pollution and poor health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9342-5
  a curric:KeyLearningPoint ;
  rdfs:label """These poor conditions can be seen in Gustave Doré's engraving 'Over London - By Rail'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1964, 51 years after Emily Davison's death, a man called Paul Stephenson walked into the Bay Horse Pub in Bristol."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-2
  a curric:KeyLearningPoint ;
  rdfs:label "He ordered a drink, but before he could drink it the manager told him to leave."@en ;
  dcterms:modified "2026-02-12T08:59:21.620921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stephenson refused, and eight police officers came to arrest him."@en ;
  dcterms:modified "2026-02-12T08:59:21.620927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-4
  a curric:KeyLearningPoint ;
  rdfs:label "He was held in a police cell until midnight."@en ;
  dcterms:modified "2026-02-12T08:59:21.620932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9507-5
  a curric:KeyLearningPoint ;
  rdfs:label "The manager had told Stephenson to leave because he was black."@en ;
  dcterms:modified "2026-02-12T08:59:21.620938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-1
  a curric:KeyLearningPoint ;
  rdfs:label """After school Paul joined the RAF and spent time in Germany working with young people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-2
  a curric:KeyLearningPoint ;
  rdfs:label "After the RAF he studied youth work and moved to Bristol in 1962."@en ;
  dcterms:modified "2026-02-12T08:59:21.622314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-3
  a curric:KeyLearningPoint ;
  rdfs:label "He was the first black youth worker in Bristol."@en ;
  dcterms:modified "2026-02-12T08:59:21.622319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-4
  a curric:KeyLearningPoint ;
  rdfs:label "At this time many black people had come from the Caribbean to live in Bristol."@en ;
  dcterms:modified "2026-02-12T08:59:21.622325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9509-5
  a curric:KeyLearningPoint ;
  rdfs:label """Even though they had travelled to Britain to help the country recover after the war, they were not treated well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-1
  a curric:KeyLearningPoint ;
  rdfs:label "On the 4th of June 1913, a tragedy occurred at Epsom Racecourse."@en ;
  dcterms:modified "2026-02-12T08:59:21.622337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-2
  a curric:KeyLearningPoint ;
  rdfs:label """A woman called Emily Davison ran out onto the course during a big horse race called the Epsom Derby."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emily ran out onto the course because she was fighting for a change to take place in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9501-4
  a curric:KeyLearningPoint ;
  rdfs:label "She was knocked over by the King's horse and died from her injuries."@en ;
  dcterms:modified "2026-02-12T08:59:21.622353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9270-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1939, England began fighting in the Second World War and much of the country was in danger of attack."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9270-2
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth and her family were moved out of London to keep them safe; many children were evacuated like this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9270-3
  a curric:KeyLearningPoint ;
  rdfs:label """Like the rest of the United Kingdom, Elizabeth and her family experienced air raid drills and rationing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9270-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth joined a special part of the army, that was created for women, by driving and repairing vehicles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth made her first radio broadcast during the war, speaking to other evacuated children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-1
  a curric:KeyLearningPoint ;
  rdfs:label """The year after Emily Davison died, a large war broke out and men in Britain had to go and fight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-2
  a curric:KeyLearningPoint ;
  rdfs:label """With the men gone, women had to take on their jobs; they showed how strong and capable they were."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the war, people appreciated how much women had done while the men were away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-4
  a curric:KeyLearningPoint ;
  rdfs:label "They also remembered how brave suffragettes like Emily Davison were."@en ;
  dcterms:modified "2026-02-12T08:59:21.625921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9506-5
  a curric:KeyLearningPoint ;
  rdfs:label "As a result, it was decided that some women should be allowed to vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.625926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two months after her marriage to Louis was annulled, Eleanor married Henry, who was next in line to the English throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-2
  a curric:KeyLearningPoint ;
  rdfs:label """Henry became the King of England, and Eleanor was his queen; together they ruled over large parts of France and England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, their marriage was not always happy and eventually Eleanor moved back to Aquitaine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-4
  a curric:KeyLearningPoint ;
  rdfs:label """When her sons decided to revolt against Henry, she supported them and Henry had her confined as punishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9742-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, after Henry's death she helped two of her sons, Richard and John, to rule when they were king of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-1
  a curric:KeyLearningPoint ;
  rdfs:label """After he defeated his father's enemy, Constantine became King of Alba, but he had no time to relax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-2
  a curric:KeyLearningPoint ;
  rdfs:label """His kingdom was under attack by the Vikings, who had taken control of an important place called Dunkeld."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-3
  a curric:KeyLearningPoint ;
  rdfs:label """The bones of an important Scottish saint, Saint Columba, were held there, and the Vikings had taken them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9302-4
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine led his army against the Vikings, driving them out and recapturing Dunkeld and the relics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at Victorian seaside photographs can tell us about things that have changed or stayed the same over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at a photograph of a steam train can tell us about how people travelled to the seaside and if this has changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at photographs of people on the beach can tell us about what they did at the seaside and if this has changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9281-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs of piers and ice cream sellers can tell us about what people enjoyed at the seaside and if this has changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many people in Victorian Britain were proud of new inventions that were introduced at that time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prince Albert was one of these people; in 1851, he organised the Great Exhibition to celebrate new modern inventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Crystal Palace, a huge steel and glass building, was built for the exhibition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-4
  a curric:KeyLearningPoint ;
  rdfs:label """Albert invited inventors from all over Britain and the world to show off their inventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9343-5
  a curric:KeyLearningPoint ;
  rdfs:label """More than six million people, roughly a third of Britain's population, visited the exhibition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before Victoria became queen she had met her cousin Albert several times, and described him as 'handsome'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although she did not marry him straight away, once Victoria was queen she proposed to Albert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-3
  a curric:KeyLearningPoint ;
  rdfs:label "Victoria and Albert were in love from the early days of their marriage."@en ;
  dcterms:modified "2026-02-12T08:59:21.628544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9340-4
  a curric:KeyLearningPoint ;
  rdfs:label """On their wedding day in 1840, Victoria wrote in her diary that 'This was the happiest day of my life!'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the age of 21, a young woman called Elizabeth found herself imprisoned in the Tower of London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-2
  a curric:KeyLearningPoint ;
  rdfs:label """She had been accused of plotting to take the throne by her older half-sister Mary, who was queen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-3
  a curric:KeyLearningPoint ;
  rdfs:label """It was very likely that Mary might order her to be executed, so Elizabeth wrote her a letter saying she was innocent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although Mary refused to see Elizabeth, she eventually freed her and Elizabeth's life was spared."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9307-5
  a curric:KeyLearningPoint ;
  rdfs:label "Soon after, Mary died and Elizabeth became Queen of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.628577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-1
  a curric:KeyLearningPoint ;
  rdfs:label """Queen Victoria died in 1901 having reigned for 63 years; only Elizabeth II reigned for longer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-2
  a curric:KeyLearningPoint ;
  rdfs:label "By the time of Victoria's death, Britain had changed a great deal."@en ;
  dcterms:modified "2026-02-12T08:59:21.628682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Britain's empire had continued to grow, with Britain controlling land across six of the world's continents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-4
  a curric:KeyLearningPoint ;
  rdfs:label """Laws now protected children from working at a young age, and gave them the right to free education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Laws had been passed to clean up dirty cities and to build new sewers and water supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-1
  a curric:KeyLearningPoint ;
  rdfs:label "Constantine was the son of a king in a part of Scotland called Alba."@en ;
  dcterms:modified "2026-02-12T08:59:21.628921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-2
  a curric:KeyLearningPoint ;
  rdfs:label """When he was very young, his father was killed by someone who wanted to rule in his place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine had to flee to Ireland where he lived with his aunt who was married to an Irish king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Constantine was educated at a nearby monastery and as he grew older he planned his revenge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9598-5
  a curric:KeyLearningPoint ;
  rdfs:label """Eventually Constantine returned to Scotland and defeated his father's enemy at a huge hillfort called Dundurn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Romans came to the lands of the Iceni, Boudica's tribe, and were very cruel to her and her daughters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-2
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica decided to fight to take back her land."@en ;
  dcterms:modified "2026-02-12T08:59:21.629083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-3
  a curric:KeyLearningPoint ;
  rdfs:label "Boudica was lucky because the Roman army was far away, fighting in Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.629088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-4
  a curric:KeyLearningPoint ;
  rdfs:label """Boudica was able to attack and destroy three large Roman towns: Colchester, London and St Albans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9606-5
  a curric:KeyLearningPoint ;
  rdfs:label "However, her luck would soon run out."@en ;
  dcterms:modified "2026-02-12T08:59:21.629098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the earliest seaborne explorers were a group of people known as Polynesians."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-2
  a curric:KeyLearningPoint ;
  rdfs:label """A long time ago Polynesians spread across the Pacific Ocean using canoes that they built."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-3
  a curric:KeyLearningPoint ;
  rdfs:label "These canoes had to have a strong hull and sail to travel across the ocean."@en ;
  dcterms:modified "2026-02-12T08:59:21.649567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9291-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Polynesians navigated to new islands by watching the waves and the paths of sea creatures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zheng He and other Chinese sailors were able to navigate across large distances because of various things they used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Chinese used strong ships called junks with many large sails."@en ;
  dcterms:modified "2026-02-12T08:59:21.651461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-3
  a curric:KeyLearningPoint ;
  rdfs:label """These ships had a rudder, which allowed the Chinese to steer them without oars, which was easier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9296-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Chinese were the first seafarers to use a compass, which made navigation more simple and reliable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-1
  a curric:KeyLearningPoint ;
  rdfs:label """Just under 200 years ago, a race was underway to see which would be the first steamship to cross the Atlantic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A British engineer called Isambard Kingdom Brunel designed the SS Great Western to try and achieve this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-3
  a curric:KeyLearningPoint ;
  rdfs:label "It was a wooden hulled steamship with masts, sails and a paddle wheel."@en ;
  dcterms:modified "2026-02-12T08:59:21.651976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-4
  a curric:KeyLearningPoint ;
  rdfs:label """The SS Great Western was narrowly beaten by the SS Sirius, which became the first steamship to cross the Atlantic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9732-5
  a curric:KeyLearningPoint ;
  rdfs:label """Brunel then designed and built the SS Great Britain, the first iron steamship with a propeller to cross the Atlantic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-1
  a curric:KeyLearningPoint ;
  rdfs:label "150 years ago, steam power was replacing sail power for ships."@en ;
  dcterms:modified "2026-02-12T08:59:21.652299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wooden-hulled ships, which had been used for thousands of years, were being replaced by iron-hulled ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-3
  a curric:KeyLearningPoint ;
  rdfs:label """JMW Turner's painting, The Fighting Temeraire, is symbolic of this process, showing the final journey of the Temeraire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Temeraire, an old ship used in important battles, is being towed by a steam boat on its way to be broken up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9490-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is unlikely that Turner witnessed this event, but he has imagined it to make the point that seafaring was changing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shortly after Zheng He's voyages, an Italian navigator and explorer called John Cabot was living in Bristol."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-2
  a curric:KeyLearningPoint ;
  rdfs:label """He was sent by the English king, Henry VII, to find a shorter route to Asia, and to claim new lands for England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-3
  a curric:KeyLearningPoint ;
  rdfs:label """He tried to sail across the Atlantic but bad weather, food shortages and arguments with his crew meant he failed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-4
  a curric:KeyLearningPoint ;
  rdfs:label """He tried again the next year with a small ship, 'The Matthew', and a crew of just 18, reaching what is now Canada."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9734-5
  a curric:KeyLearningPoint ;
  rdfs:label """The next year, the king sent Cabot on another trip to try and reach even further; Cabot and his ships never returned."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-1
  a curric:KeyLearningPoint ;
  rdfs:label "Explorers often travel to places that are unknown to them."@en ;
  dcterms:modified "2026-02-12T08:59:21.652716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humans have always moved around and explored new places."@en ;
  dcterms:modified "2026-02-12T08:59:21.652721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humans explored to find new places to live, new survival essentials, or to escape danger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9290-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some early explorers used very early types of boats like the hollowed out Pesse Canoe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9485-1
  a curric:KeyLearningPoint ;
  rdfs:label """At Elizabeth's coronation, various important objects were used that hold great symbolism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9485-2
  a curric:KeyLearningPoint ;
  rdfs:label """These were: the coronation spoon; the coronation chair with the Stone of Scone; the orb and sceptre; the Imperial Crown."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9485-3
  a curric:KeyLearningPoint ;
  rdfs:label """When Elizabeth was crowned at her coronation, she became Queen not just of England but of four nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth became Queen of the United Kingdom of England, Scotland, Wales and Northern Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9485-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Royal Coat of Arms contains symbols of England, Scotland and Northern Ireland; the male heir is the Prince of Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9483-1
  a curric:KeyLearningPoint ;
  rdfs:label """After their marriage, Elizabeth and Philip started a family with the birth of Charles in 1948, at Buckingham Palace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9483-2
  a curric:KeyLearningPoint ;
  rdfs:label "Princess Anne was born two years later at Clarence House in London."@en ;
  dcterms:modified "2026-02-12T08:59:21.688095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9483-3
  a curric:KeyLearningPoint ;
  rdfs:label """While Philip continued his career in the Royal Navy, Elizabeth remained in England caring for her young children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9483-4
  a curric:KeyLearningPoint ;
  rdfs:label "Between 1949-51 the young family moved to Malta when Philip was stationed there."@en ;
  dcterms:modified "2026-02-12T08:59:21.688104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9483-5
  a curric:KeyLearningPoint ;
  rdfs:label "Malta was a part of the British Empire, but is now part of the Commonwealth."@en ;
  dcterms:modified "2026-02-12T08:59:21.688108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-1
  a curric:KeyLearningPoint ;
  rdfs:label """Almost 200 years ago, a woman called Victoria became the Queen of the United Kingdom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-2
  a curric:KeyLearningPoint ;
  rdfs:label """She would go on to rule for longer than any other monarch before her and be remembered as very important."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, when she was very little her life was very sad, later Victoria would describe it as 'melancholy'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-4
  a curric:KeyLearningPoint ;
  rdfs:label """She was very lonely; her father died when she was just one year old and her mother was very protective of her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9338-5
  a curric:KeyLearningPoint ;
  rdfs:label """Victoria did not meet many other children, spending her days learning or playing with her dolls and her dog, Dash."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth II was not just Queen of the United Kingdom, but also Head of the Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9487-2
  a curric:KeyLearningPoint ;
  rdfs:label """When Elizabeth became Queen, Britain still ruled some countries around the world that were part of the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9487-3
  a curric:KeyLearningPoint ;
  rdfs:label """As these countries won the right to rule themselves and left the empire, they often joined the Commonwealth of Nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9487-4
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth spent a lot of time visiting these countries, going to 28 of them."@en ;
  dcterms:modified "2026-02-12T08:59:21.706488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's visits to Commonwealth nations were important occasions with lots of spectacular events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9488-1
  a curric:KeyLearningPoint ;
  rdfs:label """On 8 September 2022, Elizabeth II died peacefully at her favourite home, Balmoral Castle, in Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9488-2
  a curric:KeyLearningPoint ;
  rdfs:label """She was 96 and had reigned over 70 years; she is the longest reigning monarch that the United Kingdom has ever had."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9488-3
  a curric:KeyLearningPoint ;
  rdfs:label """People queued for hours to see her coffin as it lay in state in Westminster Hall at the Houses of Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9488-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth was given a state funeral so that the whole nation could show their respects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9488-5
  a curric:KeyLearningPoint ;
  rdfs:label """When she died, Elizabeth's eldest son, Charles, the Prince of Wales, became King Charles III."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some historians think Emily was trying to put a suffragette banner on a horse at the racecourse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-2
  a curric:KeyLearningPoint ;
  rdfs:label "Others think that she was prepared to die so that women could get the vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.722024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-3
  a curric:KeyLearningPoint ;
  rdfs:label "Whatever her motives, Emily was recognised at the time for being very brave."@en ;
  dcterms:modified "2026-02-12T08:59:21.722030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Suffragettes organised a large funeral procession; 5,000 of them marched in the streets of London with her coffin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9505-5
  a curric:KeyLearningPoint ;
  rdfs:label """50,000 people came out to watch her coffin moving through London and to pay respect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-1
  a curric:KeyLearningPoint ;
  rdfs:label "One big problem that black people faced in Bristol was finding good jobs."@en ;
  dcterms:modified "2026-02-12T08:59:21.725574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-2
  a curric:KeyLearningPoint ;
  rdfs:label """Even though there were not enough workers on the city's buses, people of colour were not allowed to work on them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-3
  a curric:KeyLearningPoint ;
  rdfs:label """This made Paul Stephenson very angry and so with four men from the Caribbean islands he decided to take action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-4
  a curric:KeyLearningPoint ;
  rdfs:label """They organised a boycott of the city's buses, supported by students, celebrities and politicians."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9511-5
  a curric:KeyLearningPoint ;
  rdfs:label """After several months, the bus company agreed to allow people of colour to work on the buses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9484-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1951, George VI's health began to fail, and Elizabeth and her family returned to England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9484-2
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth, helped by Philip, began to support her father and experience what it would be like to rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9484-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1952, Elizabeth was visiting Kenya, part of the British Empire, when she learnt George VI had died and she was queen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9484-4
  a curric:KeyLearningPoint ;
  rdfs:label """The night before coronation Elizabeth made a radio broadcast pledging her devotion to her people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9484-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth requested that her coronation was the first ever to be broadcast on both radio and television."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9486-1
  a curric:KeyLearningPoint ;
  rdfs:label """As queen, Elizabeth II had many public duties and responsibilities and performed many public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9486-2
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth II was a symbol of unity and national identity; she attended special events and gave national messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9486-3
  a curric:KeyLearningPoint ;
