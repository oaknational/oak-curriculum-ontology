oakcurric:keyword-sexism
  a curric:Keyword ;
  schema:name "sexism"@en ;
  schema:description """discrimination, prejudice, or bias based on someone's gender, typically favouring one gender over another"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791039Z"^^xsd:dateTime .

oakcurric:keyword-alliance
  a curric:Keyword ;
  schema:name "alliance"@en ;
  schema:description """an agreement between countries or political parties to work together to achieve something"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791082Z"^^xsd:dateTime .

oakcurric:keyword-act
  a curric:Keyword ;
  schema:name "act"@en ;
  schema:description "an act is a law passed by the government"@en ;
