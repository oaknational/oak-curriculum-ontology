# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-5238-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mansa Musa was a 14th century ruler of Mali and the wealthiest man who has ever lived."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5238-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mansa Musa was a devout Muslim and undertook the Hajj to Mecca."@en ;
  dcterms:modified "2026-02-12T08:59:21.482306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5238-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mansa Musa's wealth destabilised the economy of Egypt during his Hajj."@en ;
  dcterms:modified "2026-02-12T08:59:21.482310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5238-4
  a curric:KeyLearningPoint ;
  rdfs:label "There were positive and negative consequences of Mansa Musa's pilgrimage."@en ;
  dcterms:modified "2026-02-12T08:59:21.482318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5207-1
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda established her court in Gloucester."@en ;
  dcterms:modified "2026-02-12T08:59:21.483256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5207-2
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda defeated Stephen at the Battle of Lincoln."@en ;
  dcterms:modified "2026-02-12T08:59:21.483260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5207-3
  a curric:KeyLearningPoint ;
  rdfs:label "The citizens of London forced Matilda and her followers to flee London."@en ;
  dcterms:modified "2026-02-12T08:59:21.483264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5207-4
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda was defeated by Stephen at the Siege of Oxford."@en ;
  dcterms:modified "2026-02-12T08:59:21.483268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5207-5
  a curric:KeyLearningPoint ;
  rdfs:label """Matilda's actions during the Anarchy gives historians an insight into medieval women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5208-1
  a curric:KeyLearningPoint ;
  rdfs:label """Matilda’s son, Henry 'FitzEmpress', launched military campaigns in England after Matilda relocated to Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5208-2
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda and Stephen ended the Anarchy by agreement in the Treaty of Wallingford."@en ;
  dcterms:modified "2026-02-12T08:59:21.483530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5208-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stephen agreed Matilda's son Henry would inherit the throne after his death, which led to a peaceful succession."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5208-4
  a curric:KeyLearningPoint ;
  rdfs:label """Matilda retired to Normandy but continued to advise Henry II on matters of government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5208-5
  a curric:KeyLearningPoint ;
  rdfs:label """Matilda's later life can be studied by historians interested in the political role played by elite medieval women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5216-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many consider John to be the model of a bad king with a reputation for untrustworthiness and greed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5216-2
  a curric:KeyLearningPoint ;
  rdfs:label "King John raised unpopular taxes which caused anger amongst the English barons."@en ;
  dcterms:modified "2026-02-12T08:59:21.483745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5216-3
  a curric:KeyLearningPoint ;
  rdfs:label "King John had a reputation for avoiding battle and was known as 'Softsword'."@en ;
  dcterms:modified "2026-02-12T08:59:21.483750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5216-4
  a curric:KeyLearningPoint ;
  rdfs:label "King John was said to have killed his nephew."@en ;
  dcterms:modified "2026-02-12T08:59:21.483754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5216-5
  a curric:KeyLearningPoint ;
  rdfs:label "King John lost a third of his lands, including his family’s ancestral homelands."@en ;
  dcterms:modified "2026-02-12T08:59:21.483758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5218-1
  a curric:KeyLearningPoint ;
  rdfs:label "John had Magna Carta annulled."@en ;
  dcterms:modified "2026-02-12T08:59:21.483802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5218-2
  a curric:KeyLearningPoint ;
  rdfs:label "John's actions led to a civil war."@en ;
  dcterms:modified "2026-02-12T08:59:21.483805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5218-3
  a curric:KeyLearningPoint ;
  rdfs:label "In 1216 Henry III came to the throne as a child."@en ;
  dcterms:modified "2026-02-12T08:59:21.483809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5218-4
  a curric:KeyLearningPoint ;
  rdfs:label "Henry III reissued Magna Carta in 1216, without its most radical clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.483814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5218-5
  a curric:KeyLearningPoint ;
  rdfs:label """The king’s regent, William Marshal, hoped this Magna Carta would mean a better balance between king and barons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5224-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I believed he could unite England and Wales under his kingship."@en ;
  dcterms:modified "2026-02-12T08:59:21.483824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5224-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many Welsh revolted against English law and heavy-handed rule being forced upon them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5224-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edward I launched a war of conquest assisted by Llywelyn’s Welsh enemies and the Scottish Earl of Carrick."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5224-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Welsh revolt was defeated and Llywelyn and Dafydd ap Gruffuff were both killed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5224-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I built castles to enforce the English conquest of Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.483840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5220-1
  a curric:KeyLearningPoint ;
  rdfs:label """Since Magna Carta, a special meeting of barons and bishops had become known as parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5220-2
  a curric:KeyLearningPoint ;
  rdfs:label """Simon de Montfort confronted Henry in parliament because he was not keeping to the aims of Magna Carta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5220-3
  a curric:KeyLearningPoint ;
  rdfs:label "Simon de Montfort established the First Parliament."@en ;
  dcterms:modified "2026-02-12T08:59:21.483854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5220-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simon de Montfort was eventually defeated in the Battle of Evesham."@en ;
  dcterms:modified "2026-02-12T08:59:21.483858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5220-5
  a curric:KeyLearningPoint ;
  rdfs:label """Henry III was restored to power, he accepted some of the baronial demands and ruled more with parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5213-1
  a curric:KeyLearningPoint ;
  rdfs:label "Henry had his son crowned during Thomas Becket's absence from England."@en ;
  dcterms:modified "2026-02-12T08:59:21.483902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5213-2
  a curric:KeyLearningPoint ;
  rdfs:label "Becket returned and excommunicated the bishops involved in the coronation."@en ;
  dcterms:modified "2026-02-12T08:59:21.483907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5213-3
  a curric:KeyLearningPoint ;
  rdfs:label "Becket was murdered by four of Henry's knights."@en ;
  dcterms:modified "2026-02-12T08:59:21.483911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5213-4
  a curric:KeyLearningPoint ;
  rdfs:label """The king’s reaction to Becket's murder reveals the extent of power the Church held across Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5213-5
  a curric:KeyLearningPoint ;
  rdfs:label "Becket's murder ultimately strengthened the king's control over the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.483919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5221-1
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta started a process of struggle over how much power the monarch should have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5221-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the short term, Magna Carta had limited impact on the power of the monarchy and basic human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5221-3
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta survived through various ways and historians often disagree about this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5221-4
  a curric:KeyLearningPoint ;
  rdfs:label "Magna Carta survived through force."@en ;
  dcterms:modified "2026-02-12T08:59:21.483935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5221-5
  a curric:KeyLearningPoint ;
  rdfs:label "Magna Carta survived through compromise."@en ;
  dcterms:modified "2026-02-12T08:59:21.483939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5206-1
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda regarded Stephen as a usurper."@en ;
  dcterms:modified "2026-02-12T08:59:21.483943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5206-2
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda sought to secure the pope's backing for her claim."@en ;
  dcterms:modified "2026-02-12T08:59:21.483947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5206-3
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda raised an army in England to fight against Stephen."@en ;
  dcterms:modified "2026-02-12T08:59:21.483951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5206-4
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda gained the support of some leading English barons."@en ;
  dcterms:modified "2026-02-12T08:59:21.483955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5206-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historians can learn about the role of elite women in the Middle Ages from Matilda's campaign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5219-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1225 Magna Carta was a consensual agreement between the king, the Church, and the barons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5219-2
  a curric:KeyLearningPoint ;
  rdfs:label "Early in Henry’s reign, Henry tried to follow the promises of Magna Carta."@en ;
  dcterms:modified "2026-02-12T08:59:21.484187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5219-3
  a curric:KeyLearningPoint ;
  rdfs:label "Henry was a weak military leader and got into huge debts."@en ;
  dcterms:modified "2026-02-12T08:59:21.484191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5219-4
  a curric:KeyLearningPoint ;
  rdfs:label """Henry invited many foreign barons and gave them land and important positions in leadership."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5219-5
  a curric:KeyLearningPoint ;
  rdfs:label """The English barons were angered by the arrival of foreign-born nobles and their castle-building and tax collecting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5189-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Pope wanted the Anglo-Saxon Church to be reformed."@en ;
  dcterms:modified "2026-02-12T08:59:21.484222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5189-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Norman government replaced the leadership of the Anglo-Saxon Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.484226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lanfranc became Archbishop of Canterbury and conducted a programme of reform."@en ;
  dcterms:modified "2026-02-12T08:59:21.484230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Historians sometimes use material remains as sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.484236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5189-5
  a curric:KeyLearningPoint ;
  rdfs:label """Winchester Cathedral represents an important source for the study of the Anglo-Norman Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5214-1
  a curric:KeyLearningPoint ;
  rdfs:label """Henry announced how his empire would be divided upon his death in an attempt to secure peace and stability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5214-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry’s sons did not want to wait for future power; they wanted power now."@en ;
  dcterms:modified "2026-02-12T08:59:21.484280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5214-3
  a curric:KeyLearningPoint ;
  rdfs:label """Henry's wife, Eleanor of Aquitaine, conspired with their sons in revolt against Henry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5214-4
  a curric:KeyLearningPoint ;
  rdfs:label "Henry’s sons continued to rebel during the last years of his reign."@en ;
  dcterms:modified "2026-02-12T08:59:21.484290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5214-5
  a curric:KeyLearningPoint ;
  rdfs:label "Henry’s succession planning had been a disaster."@en ;
  dcterms:modified "2026-02-12T08:59:21.484294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5215-1
  a curric:KeyLearningPoint ;
  rdfs:label """A successful medieval king needed to have certain qualities to enable them to effectively rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5215-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry’s reign demonstrated success."@en ;
  dcterms:modified "2026-02-12T08:59:21.484365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5215-3
  a curric:KeyLearningPoint ;
  rdfs:label "Henry’s reign demonstrated failure."@en ;
  dcterms:modified "2026-02-12T08:59:21.484369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5215-4
  a curric:KeyLearningPoint ;
  rdfs:label "Historians often disagree whether a king can be seen as a successful ruler."@en ;
  dcterms:modified "2026-02-12T08:59:21.484373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5215-5
  a curric:KeyLearningPoint ;
  rdfs:label "Henry reasserted his royal authority in various ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.484377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5259-1
  a curric:KeyLearningPoint ;
  rdfs:label """The printing press allowed humanists to share rediscovered knowledge more easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5259-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humanism was promoted by the universities of Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.484396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5259-3
  a curric:KeyLearningPoint ;
  rdfs:label "New universities were founded in this period."@en ;
  dcterms:modified "2026-02-12T08:59:21.484400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5259-4
  a curric:KeyLearningPoint ;
  rdfs:label "Humanism represented a desire to study the classical world."@en ;
  dcterms:modified "2026-02-12T08:59:21.484403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5259-5
  a curric:KeyLearningPoint ;
  rdfs:label "Erasmus was an important humanist scholar."@en ;
  dcterms:modified "2026-02-12T08:59:21.484407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5212-1
  a curric:KeyLearningPoint ;
  rdfs:label """The power of the Church often brought it into conflict with the king’s authority  ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5212-2
  a curric:KeyLearningPoint ;
  rdfs:label """If they broke the law, the clergy were only required to attend the Church's own courts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5212-3
  a curric:KeyLearningPoint ;
  rdfs:label """Henry II appointed Thomas Becket, the Archbishop of Canterbury, to help reform the Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5212-4
  a curric:KeyLearningPoint ;
  rdfs:label """Henry wanted to use the Constitutions of Clarendon to increase his control over the Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5212-5
  a curric:KeyLearningPoint ;
  rdfs:label """Becket argued with Henry and believed the Church should be free from the king's interference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5211-1
  a curric:KeyLearningPoint ;
  rdfs:label "Legal matters were inconsistently dealt with by local courts and barons."@en ;
  dcterms:modified "2026-02-12T08:59:21.484692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5211-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry II established the Assizes to settle property disputes in local areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.484700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5211-3
  a curric:KeyLearningPoint ;
  rdfs:label """Henry’s reforms restored and increased his royal authority in legal matters across England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5211-4
  a curric:KeyLearningPoint ;
  rdfs:label "The judgements of the Assizes developed the English Common Law."@en ;
  dcterms:modified "2026-02-12T08:59:21.484708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5211-5
  a curric:KeyLearningPoint ;
  rdfs:label """Henry II's legal reforms represent an important change in the English legal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5217-1
  a curric:KeyLearningPoint ;
  rdfs:label "John’s disagreement with the Church angered the barons."@en ;
  dcterms:modified "2026-02-12T08:59:21.484798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5217-2
  a curric:KeyLearningPoint ;
  rdfs:label "The barons rose up against John, led by Robert Fitzwalter."@en ;
  dcterms:modified "2026-02-12T08:59:21.484802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5217-3
  a curric:KeyLearningPoint ;
  rdfs:label "John was forced to accept the barons’ demands set out in Magna Carta."@en ;
  dcterms:modified "2026-02-12T08:59:21.484806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5217-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 63 clauses of the Magna Carta included one which many consider the start of basic human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5217-5
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta included a radical clause which suggested power lay not with the king, but with the barons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5210-1
  a curric:KeyLearningPoint ;
  rdfs:label "Henry II attempted to restore his royal lands after the Anarchy"@en ;
  dcterms:modified "2026-02-12T08:59:21.484930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5210-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry ruled over an area of Western Europe known as the Angevin Empire"@en ;
  dcterms:modified "2026-02-12T08:59:21.484935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5210-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Angevin Empire was a collection of separate lands, each with their own local traditions and leadership"""@en ;
  dcterms:modified "2026-02-12T08:59:21.484939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5210-4
  a curric:KeyLearningPoint ;
  rdfs:label "Henry II oversaw an invasion of Ireland in 1169, with the support of the Pope"@en ;
  dcterms:modified "2026-02-12T08:59:21.484943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5210-5
  a curric:KeyLearningPoint ;
  rdfs:label "Kings of England subsequently claimed to be rightful rulers of Ireland"@en ;
  dcterms:modified "2026-02-12T08:59:21.484947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5191-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Normans changed landholding in England."@en ;
  dcterms:modified "2026-02-12T08:59:21.484981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5191-2
  a curric:KeyLearningPoint ;
  rdfs:label "The new system of landholding is often referred to as 'feudalism'."@en ;
  dcterms:modified "2026-02-12T08:59:21.484987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5191-3
  a curric:KeyLearningPoint ;
  rdfs:label "England was a hierarchical and tenurial society."@en ;
  dcterms:modified "2026-02-12T08:59:21.484991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5191-4
  a curric:KeyLearningPoint ;
  rdfs:label "Domesday Book is used by historians to study Norman changes to landholding."@en ;
  dcterms:modified "2026-02-12T08:59:21.484995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5190-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Normans faced many rebellions during William the Conqueror's reign."@en ;
  dcterms:modified "2026-02-12T08:59:21.485001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5190-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Normans built motte-and-bailey castles to deter these rebellions."@en ;
  dcterms:modified "2026-02-12T08:59:21.485005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5190-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Normans introduced new stone buildings to many towns."@en ;
  dcterms:modified "2026-02-12T08:59:21.485011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5190-4
  a curric:KeyLearningPoint ;
  rdfs:label "Historians use the material remains of castles to study the Norman period."@en ;
  dcterms:modified "2026-02-12T08:59:21.485016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5187-1
  a curric:KeyLearningPoint ;
  rdfs:label "King Edward the Confessor died without an heir in 1066."@en ;
  dcterms:modified "2026-02-12T08:59:21.485268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5187-2
  a curric:KeyLearningPoint ;
  rdfs:label "William of Normandy and Harold Godwinson claimed the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.485272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5187-3
  a curric:KeyLearningPoint ;
  rdfs:label "William of Poitiers tried to justify William's claim in his \"Gesta Guillelmi\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.485276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5187-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Gesta Guillelmi claims that William was promised the throne by Edward and that Godwinson betrayed William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5187-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historians have to remember Poitiers' motives for writing when using his work to investigate claims to the throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5209-1
  a curric:KeyLearningPoint ;
  rdfs:label "Historians can learn about medieval women by studying Matilda's early life."@en ;
  dcterms:modified "2026-02-12T08:59:21.485444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5209-2
  a curric:KeyLearningPoint ;
  rdfs:label """Historians can learn about medieval women by studying Matilda's role in the Anarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5209-3
  a curric:KeyLearningPoint ;
  rdfs:label "Historians can learn about medieval women by studying Matilda's court."@en ;
  dcterms:modified "2026-02-12T08:59:21.485452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5209-4
  a curric:KeyLearningPoint ;
  rdfs:label "Historians can learn about medieval women by studying Matilda's later life."@en ;
  dcterms:modified "2026-02-12T08:59:21.485456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5209-5
  a curric:KeyLearningPoint ;
  rdfs:label """Matilda's life is one particularly well documented way in which historians can learn about medieval women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5192-1
  a curric:KeyLearningPoint ;
  rdfs:label """Historians draw on a range of sources to study the impact of the Norman Conquest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5192-2
  a curric:KeyLearningPoint ;
  rdfs:label """These sources offer different evidence depending on the questions historians ask."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5192-3
  a curric:KeyLearningPoint ;
  rdfs:label "The sources sometimes corroborate one another."@en ;
  dcterms:modified "2026-02-12T08:59:21.485472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5192-4
  a curric:KeyLearningPoint ;
  rdfs:label "The sources sometimes contradict one another."@en ;
  dcterms:modified "2026-02-12T08:59:21.485476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8196-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Roman Catholic Church was led by the pope, who was based in Rome."@en ;
  dcterms:modified "2026-02-12T08:59:21.485636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8196-2
  a curric:KeyLearningPoint ;
  rdfs:label "There was a movement to reform the Church in the 11th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.485639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8196-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pope Leo IX was an important reforming pope."@en ;
  dcterms:modified "2026-02-12T08:59:21.485643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8196-4
  a curric:KeyLearningPoint ;
  rdfs:label "The reforms increased the authority and improved the perception of the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.485649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8196-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pope Leo IX's reforms were continued by later popes."@en ;
  dcterms:modified "2026-02-12T08:59:21.485653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pope Urban II led the Roman Church in the late 11th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.485693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5201-2
  a curric:KeyLearningPoint ;
  rdfs:label "Urban II faced a number of challenges whilst he was pope."@en ;
  dcterms:modified "2026-02-12T08:59:21.485697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Urban II called a Church council to Clermont in 1095, partly to discuss the Seljuk invasion into the Byzantine Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5201-4
  a curric:KeyLearningPoint ;
  rdfs:label """Urban II called upon Western European Christians to go on crusade against the Seljuk Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5201-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many people were eager to go on crusade."@en ;
  dcterms:modified "2026-02-12T08:59:21.485709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5203-1
  a curric:KeyLearningPoint ;
  rdfs:label "The invasion of Byzantium was one reason for the First Crusade."@en ;
  dcterms:modified "2026-02-12T08:59:21.485713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5203-2
  a curric:KeyLearningPoint ;
  rdfs:label "The actions of Urban II were one cause of the First Crusade."@en ;
  dcterms:modified "2026-02-12T08:59:21.485716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5203-3
  a curric:KeyLearningPoint ;
  rdfs:label "The desire to fight for their God and the Church motivated some crusaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.485720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5203-4
  a curric:KeyLearningPoint ;
  rdfs:label "The desire to go on a holy journey motivated some crusaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.485726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5203-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historians disagree about the relative importance of the reasons why the First Crusade occurred as and when it did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5200-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Western Church was headed by the pope."@en ;
  dcterms:modified "2026-02-12T08:59:21.485734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5200-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the early medieval period the pope and Church had little power compared to local kings, but gained more over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5200-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the medieval period there was a power struggle between local kings and the pope over control of religion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5200-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Church had gained significant control over the lives of Western Europeans by the 11th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5200-5
  a curric:KeyLearningPoint ;
  rdfs:label "Christianity was a fundamental aspect of life for medieval Europeans."@en ;
  dcterms:modified "2026-02-12T08:59:21.485750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8195-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the disputes resulted in the location and relative isolation of the two centres of Christianity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8195-2
  a curric:KeyLearningPoint ;
  rdfs:label "There were liturgical disputes between different members of the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.485789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8195-3
  a curric:KeyLearningPoint ;
  rdfs:label "One dispute concerned the nature of the Holy Spirit."@en ;
  dcterms:modified "2026-02-12T08:59:21.485793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8195-4
  a curric:KeyLearningPoint ;
  rdfs:label """These disputes resulted in the Church splitting into the Roman Catholic and Eastern Orthodox Churches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8195-5
  a curric:KeyLearningPoint ;
  rdfs:label "The 1054 Schism could be regarded as a transformational change."@en ;
  dcterms:modified "2026-02-12T08:59:21.485803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5198-1
  a curric:KeyLearningPoint ;
  rdfs:label "Byzantium considered itself to be the successor to the Roman Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.485859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5198-2
  a curric:KeyLearningPoint ;
  rdfs:label "Byzantium was a Christian empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.485863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5198-3
  a curric:KeyLearningPoint ;
  rdfs:label "The reign of Justinian I was a high point for the Byzantine Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.485867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5198-4
  a curric:KeyLearningPoint ;
  rdfs:label """By the 11th century, the Byzantine Empire had been weakened by a series of internal conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5198-5
  a curric:KeyLearningPoint ;
  rdfs:label """By the 11th century, Byzantium was facing external threats from the Seljuk Turks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5261-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inventors like da Vinci developed new scientific ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.485903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5261-2
  a curric:KeyLearningPoint ;
  rdfs:label "Da Vinci's notebooks contain examples of his new inventions."@en ;
  dcterms:modified "2026-02-12T08:59:21.485907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5261-3
  a curric:KeyLearningPoint ;
  rdfs:label "People began to study anatomy more scientifically."@en ;
  dcterms:modified "2026-02-12T08:59:21.485910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5261-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some developments were made in the understanding of the human body."@en ;
  dcterms:modified "2026-02-12T08:59:21.485914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5202-1
  a curric:KeyLearningPoint ;
  rdfs:label "The First Crusade took place in the later 1090s."@en ;
  dcterms:modified "2026-02-12T08:59:21.485918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5202-2
  a curric:KeyLearningPoint ;
  rdfs:label "The People's Crusade was a failure."@en ;
  dcterms:modified "2026-02-12T08:59:21.485922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5202-3
  a curric:KeyLearningPoint ;
  rdfs:label "The crusaders faced very harsh conditions during their crusade."@en ;
  dcterms:modified "2026-02-12T08:59:21.485926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5202-4
  a curric:KeyLearningPoint ;
  rdfs:label "The events of the First Crusade led to the establishment of the crusader states."@en ;
  dcterms:modified "2026-02-12T08:59:21.485930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5202-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Princes' Crusade successfully captured Jerusalem."@en ;
  dcterms:modified "2026-02-12T08:59:21.485934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8197-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Eastern Orthodox Church was led by a patriarch."@en ;
  dcterms:modified "2026-02-12T08:59:21.486043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8197-2
  a curric:KeyLearningPoint ;
  rdfs:label "The patriarch was based in the city of Constantinople."@en ;
  dcterms:modified "2026-02-12T08:59:21.486047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8197-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eastern Orthodoxy and Roman Catholicism share many similarities and several differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8197-4
  a curric:KeyLearningPoint ;
  rdfs:label """There were elements of both change and continuity within Christianity after the Great Schism in 1054."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cordoba was the centre of cultural life in the Cordoban Caliphate."@en ;
  dcterms:modified "2026-02-12T08:59:21.486084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8199-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many ancient texts were translated into Arabic and Latin in Cordoba."@en ;
  dcterms:modified "2026-02-12T08:59:21.486088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8199-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cultural and economic ties with North Africa were important in Cordoba."@en ;
  dcterms:modified "2026-02-12T08:59:21.486092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8199-4
  a curric:KeyLearningPoint ;
  rdfs:label "Buildings in Cordoba drew on influences from across the Mediterranean."@en ;
  dcterms:modified "2026-02-12T08:59:21.486096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8199-5
  a curric:KeyLearningPoint ;
  rdfs:label "Cordoba had some differences to the eastern Islamic world."@en ;
  dcterms:modified "2026-02-12T08:59:21.486100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Islamic caliphates existed in the Middle East during this period."@en ;
  dcterms:modified "2026-02-12T08:59:21.486161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5199-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Seljuk Empire was a powerful Islamic state in the 11th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.486164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5199-3
  a curric:KeyLearningPoint ;
  rdfs:label """Desert and steppe nomads fought in a similar style, which was effective against sedentary civilisations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5199-4
  a curric:KeyLearningPoint ;
  rdfs:label "By the 11th century, the Seljuk Empire was expanding into Byzantium's territory."@en ;
  dcterms:modified "2026-02-12T08:59:21.486172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indigenous peoples of North America were divided into different groups from small families to large empires."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5283-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some North American tribes would be both farmers and hunter-gatherers like the Iroquois tribe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5283-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some well-known empires of North America included the Inuits in the North and Mayans and Aztecs in the South."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5283-4
  a curric:KeyLearningPoint ;
  rdfs:label """European travellers to North America started from the 900s with the Viking and Greenland explorers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5252-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike his successful warrior-king father, Henry VI was a weak Lancastrian king, lacking leadership and strength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5252-2
  a curric:KeyLearningPoint ;
  rdfs:label """Between 1450 and 1453 England lost land in France including Normandy and Gascony and rebellion rose in southern England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5252-3
  a curric:KeyLearningPoint ;
  rdfs:label """Henry VI collapsed and Richard, Duke of York, a noble of royal blood, seized his chance to take control of government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5252-4
  a curric:KeyLearningPoint ;
  rdfs:label """In December 1454, Henry VI resumed his rule and excluded York from government, leading to the Battle of St Albans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5252-5
  a curric:KeyLearningPoint ;
  rdfs:label """England had become unstable due Henry's weakness and York's willingness to use force against him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5303-1
  a curric:KeyLearningPoint ;
  rdfs:label """The events of 1688-9 swiftly became known as the 'Glorious Revolution', coined by the MP John Hampden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5303-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Scotland some people who supported James II became known as the Jacobites and rebelled, but were defeated by 1690."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5303-3
  a curric:KeyLearningPoint ;
  rdfs:label """James II landed in Ireland with French backing with the aim of reclaiming his throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5303-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Irish parliament declared that James II remained king and James built his army in Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5303-5
  a curric:KeyLearningPoint ;
  rdfs:label """William of Orange defeated James II at the Battle of Boyne in July 1690, ending his chances of reclaiming his throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5285-1
  a curric:KeyLearningPoint ;
  rdfs:label "Europeans settled in the New World by taking land from the native peoples."@en ;
  dcterms:modified "2026-02-12T08:59:21.487197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5285-2
  a curric:KeyLearningPoint ;
  rdfs:label """Europeans believed they had a moral duty to convert Native Americans to Christianity and thus can take land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5285-3
  a curric:KeyLearningPoint ;
  rdfs:label """European conquests of land were often violent and pushed Native Americans out of their home lands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5285-4
  a curric:KeyLearningPoint ;
  rdfs:label """Europeans accidentally introduced new diseases into the land, killing around 80% of Native Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5285-5
  a curric:KeyLearningPoint ;
  rdfs:label """Indigenous beliefs and practices continued despite European attempts to remove them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8200-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sicily had become a Muslim province in the 9th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.487479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8200-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mediterranean trade was most important for Sicily."@en ;
  dcterms:modified "2026-02-12T08:59:21.487483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8200-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sicily was conquered by the Normans during the 11th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.487487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8200-4
  a curric:KeyLearningPoint ;
  rdfs:label "There were profound differences between Sicily, Cordoba and Baghdad."@en ;
  dcterms:modified "2026-02-12T08:59:21.487493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5282-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth's reign has sometimes been described as a 'Golden Age'."@en ;
  dcterms:modified "2026-02-12T08:59:21.487741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5282-2
  a curric:KeyLearningPoint ;
  rdfs:label "The benefits of the 'Golden Age' were not shared equally in society."@en ;
  dcterms:modified "2026-02-12T08:59:21.487745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5282-3
  a curric:KeyLearningPoint ;
  rdfs:label "Social historians are interested in studying the lives of ordinary people."@en ;
  dcterms:modified "2026-02-12T08:59:21.487752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5282-4
  a curric:KeyLearningPoint ;
  rdfs:label """Social historians have sometimes argued that Elizabeth's reign was not a 'Golden Age' for the poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5226-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Wallace and the Scottish resistance had several victories against the English."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5226-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scottish resistance helped to develop a common Scottish identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.487808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5226-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I died in 1307 and Robert the Bruce continued the Scottish resistance."@en ;
  dcterms:modified "2026-02-12T08:59:21.487812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5226-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stirling Bridge was important because it was the first bridge across the River Forth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5226-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Battle of Stirling Bridge was an important victory because it boosted Scottish resistance against English rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5239-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mali expanded throughout the Sahel during the 13th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.487826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5239-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mali used its superior army to conquer its neighbours, such as the Jolof in the west and the Songhai in the east."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5239-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mali had a successful governmental structure - it was a federation and the Mansa installed a farimba in each kingdom"""@en ;
  dcterms:modified "2026-02-12T08:59:21.487834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5239-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mali’s wealth was built on its access to gold and salt."@en ;
  dcterms:modified "2026-02-12T08:59:21.487838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5239-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Malian elite used gold to enrich themselves and enhance the empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.487842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5281-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1601 Poor Law divided the poor into three distinct categories based upon their ability and willingness to work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5281-2
  a curric:KeyLearningPoint ;
  rdfs:label """These categories were dealt with differently, either by giving them aid, work or punishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5281-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1601 Poor Law had mixed results; however, it remained a law for more than 230 years before being revised."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5277-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Tudor period saw great advances which were not equally enjoyed by the rich and poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5277-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poverty became a greater political issue in the late 16th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.488118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5277-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1590s saw a series of bad harvests which accelerated levels of poverty."@en ;
  dcterms:modified "2026-02-12T08:59:21.488122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5277-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Elizabethan elite were worried that rebellions fuelled by poverty might spring up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5265-1
  a curric:KeyLearningPoint ;
  rdfs:label "The printing press helped to spread Luther's ideas around Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.488133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5265-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different people took up Luther's ideas and added to them."@en ;
  dcterms:modified "2026-02-12T08:59:21.488137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5265-3
  a curric:KeyLearningPoint ;
  rdfs:label """Zwingli believed that icons, relics and music distracted people from worship and should be removed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5265-4
  a curric:KeyLearningPoint ;
  rdfs:label """Groups of Protestants emerged who believed in the views of different leaders like Zwingli and Luther."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5267-1
  a curric:KeyLearningPoint ;
  rdfs:label """Thomas Cromwell was an important minister who helped Henry VIII increase his power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5267-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cranmer used theological ideas to argue for the annulment of Henry’s marriage to Catherine of Aragon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5267-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Reformation Parliament (1529-1536) radically changed the powers of the monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5267-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1534 Act of Supremacy made Henry the 'Supreme Head of the Church of England'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5267-5
  a curric:KeyLearningPoint ;
  rdfs:label "Henry had to rely on Parliament for the Break with Rome."@en ;
  dcterms:modified "2026-02-12T08:59:21.488166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5269-1
  a curric:KeyLearningPoint ;
  rdfs:label "Henry VIII previously protected the pope against Protestant ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.488271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5269-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry had different reasons for the Reformation in England from those in Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.488274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5269-3
  a curric:KeyLearningPoint ;
  rdfs:label """The English Reformation had some specific causes not found in the Reformation in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5269-4
  a curric:KeyLearningPoint ;
  rdfs:label "England's religious beliefs changed based on the monarch."@en ;
  dcterms:modified "2026-02-12T08:59:21.488282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5269-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Reformation in England followed a different course to the Reformations in Europe, although there were similarities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5293-1
  a curric:KeyLearningPoint ;
  rdfs:label "The return of King Charles II in 1660 was known as the 'Restoration'."@en ;
  dcterms:modified "2026-02-12T08:59:21.488311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Charles II was known as the 'Merry Monarch'."@en ;
  dcterms:modified "2026-02-12T08:59:21.488315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5293-3
  a curric:KeyLearningPoint ;
  rdfs:label """Charles II tried to move past divisions by working with Parliament and forgiving most people who fought for Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5293-4
  a curric:KeyLearningPoint ;
  rdfs:label "Puritan influence in England was reduced duirng the Restoration."@en ;
  dcterms:modified "2026-02-12T08:59:21.488325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5292-1
  a curric:KeyLearningPoint ;
  rdfs:label """The years from 1649 - 1660 when England was a republic are known as the Interregnum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oliver Cromwell became the most powerful figure in England during the Interregnum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Puritans hoped to make England a more godly country."@en ;
  dcterms:modified "2026-02-12T08:59:21.488338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5292-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sects like the Fifth Monarchists emerged but often opposed the actions of the government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5292-5
  a curric:KeyLearningPoint ;
  rdfs:label """Cromwell's rule was unpopular as he reduced the power of Parliament and relied heavily on the army."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5291-1
  a curric:KeyLearningPoint ;
  rdfs:label """After the First English Civil War, Parliament and the New Model Army began trusting each other less"""@en ;
  dcterms:modified "2026-02-12T08:59:21.488350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5291-2
  a curric:KeyLearningPoint ;
  rdfs:label """Charles encouraged Scotland to wage war with England, which was seen as a betrayal"""@en ;
  dcterms:modified "2026-02-12T08:59:21.488354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5291-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Pride's Purge' was when MPs who were sympathetic to the king were not allowed to enter Parliament"""@en ;
  dcterms:modified "2026-02-12T08:59:21.488358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5291-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Rump Parliament' put Charles I on trial for treason"@en ;
  dcterms:modified "2026-02-12T08:59:21.488362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5291-5
  a curric:KeyLearningPoint ;
  rdfs:label "Charles was executed by beheading on 30 January 1649"@en ;
  dcterms:modified "2026-02-12T08:59:21.488367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9783-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Silk Road was a trading route stretching across Eurasia."@en ;
  dcterms:modified "2026-02-12T08:59:21.597556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9783-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Silk Road facilitated economic and cultural exchange between Europe and Asia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9783-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Mongol Empire controlled important points along the Silk Road in the thirteenth and fourteenth centuries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5298-1
  a curric:KeyLearningPoint ;
  rdfs:label """Conflicts between local kingdoms would lead to prisoners of war who would be sold as enslaved people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5298-2
  a curric:KeyLearningPoint ;
  rdfs:label """The European involvement in the Slave trade led to more conflicts in West Africa leading to more enslaved people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5298-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some kingdoms, like the kingdom of Benin, refused to trade with Europeans but would struggle as other kingdoms profited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some African kingdoms, like the Allada kingdom, became reliant on trade with the Europeans for power and wealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5298-5
  a curric:KeyLearningPoint ;
  rdfs:label """The nature of the trade in enslaved people changed, it was no longer just prisoners of war sold into slavery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5280-1
  a curric:KeyLearningPoint ;
  rdfs:label "Monasteries supported the poor in the early Tudor period."@en ;
  dcterms:modified "2026-02-12T08:59:21.598452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5280-2
  a curric:KeyLearningPoint ;
  rdfs:label """After the dissolution of the monasteries, many people were forced to become vagrants and beggars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5280-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tudor monarchs and the elite were unsympathetic towards vagrants and beggars."@en ;
  dcterms:modified "2026-02-12T08:59:21.598491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5280-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1601 Poor Law, issued by Elizabeth I, was the most far-reaching Act to support those living in poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5258-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance began in the 14th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.598600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5258-2
  a curric:KeyLearningPoint ;
  rdfs:label "More scholars were interested in the Greek and Roman world."@en ;
  dcterms:modified "2026-02-12T08:59:21.598609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5258-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance was sparked by intellectual curiosity."@en ;
  dcterms:modified "2026-02-12T08:59:21.598617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5258-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance began in southern Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.598626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5258-5
  a curric:KeyLearningPoint ;
  rdfs:label "Educated people such as humanists communicated in Latin."@en ;
  dcterms:modified "2026-02-12T08:59:21.598635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5305-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Whig vision of history is now not accepted by most historians; revisionists have argued against it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5305-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some revisionists argue that the Glorious Revolution was unrevolutionary and was less significant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5305-3
  a curric:KeyLearningPoint ;
  rdfs:label """John Morrill called it the 'Sensible Revolution' as a result, suggesting it was a very conservative development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5305-4
  a curric:KeyLearningPoint ;
  rdfs:label """Other revisionists argue that the Glorious Revolution actually represented very significant revolutionary change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5305-5
  a curric:KeyLearningPoint ;
  rdfs:label """Steven Pincus called it the 'first modern revolution', saying it was violent, popular and divisive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5257-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Wars of the Roses can tell us a lot about why England became unstable in the 15th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5257-2
  a curric:KeyLearningPoint ;
  rdfs:label """Henry VI’s reign shows how important having a strong, warrior king who could control the nobility was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite his qualities, Edward IV’s inability to control his nobility led to further instability and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5257-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Wars of the Roses show how actions by dissatisfied, powerful nobles like Warwick often led to further instability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5257-5
  a curric:KeyLearningPoint ;
  rdfs:label """Richard III’s actions show how England was still an unstable place when arguments about who should rule broke out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5286-1
  a curric:KeyLearningPoint ;
  rdfs:label """American colonies were a great source of wealth for the Spanish who founded gold and silver mines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sir Walter Raleigh tried to persuade Elizabeth I in growing an empire to be able to compete with the Spanish."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5286-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth gave permission for colonies in North America such as Roanoke, Virginia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poor relations between colonists and Native Americans contributed to Roanoke's failure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5286-5
  a curric:KeyLearningPoint ;
  rdfs:label """The colony of Roanoke disappeared and to this day historians do not know exactly what happened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5227-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I had failures in his campaign to unify Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.598877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5227-2
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I had successes in his campaign to unify Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.598886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5227-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edward faced resistance from the Welsh and Scottish."@en ;
  dcterms:modified "2026-02-12T08:59:21.598895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5227-4
  a curric:KeyLearningPoint ;
  rdfs:label """The success of Scottish and Welsh resistance was affected by how united people were in resisting Edward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20418-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death killed up to half the population in many European countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.599310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20418-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death changed how people interacted with each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.599319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20418-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different countries responded to and were affected by the Black Death in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20418-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Black Death affected the lives of Europeans for centuries after the plague first struck."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5302-1
  a curric:KeyLearningPoint ;
  rdfs:label """William III of Orange was concerned that England may form an alliance with Catholic France against the Protestant Dutch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5302-2
  a curric:KeyLearningPoint ;
  rdfs:label """In November 1688 William of Orange, Protestant son-in-law to James II, landed in England and James fled for France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5302-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1669 a new Parliament met, which issued the Bill of Rights and offered William and Mary the crown."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5302-4
  a curric:KeyLearningPoint ;
  rdfs:label """This declaration greatly limited the power of the monarchy by creating a constitutional monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5302-5
  a curric:KeyLearningPoint ;
  rdfs:label """It established frequent Parliaments, free elections, freedom of speech within Parliament and other Parliamentary powers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5264-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1517 Martin Luther questioned the teachings of the Catholic Church in his '95 Theses'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5264-2
  a curric:KeyLearningPoint ;
  rdfs:label """Luther challenged Church practices that did not appear in the Bible, such as indulgences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5264-3
  a curric:KeyLearningPoint ;
  rdfs:label """Luther's ideas challenged the power of the Church, leading to him being accused of heresy and being excommunicated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5264-4
  a curric:KeyLearningPoint ;
  rdfs:label "Henry VIII defended the pope in 1521 'Defence of the Seven Sacraments'."@en ;
  dcterms:modified "2026-02-12T08:59:21.599990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5264-5
  a curric:KeyLearningPoint ;
  rdfs:label """Luther's ideas led to widespread religious and political reform over the next few centuries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5223-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I wanted to be overlord of all Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.600748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5223-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wales was divided between Welsh princes, the Marcher lords and the English king."@en ;
  dcterms:modified "2026-02-12T08:59:21.600756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5223-3
  a curric:KeyLearningPoint ;
  rdfs:label """Llywelyn ap Gruffudd conquered two-thirds of Wales and was known as the Prince of Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5223-4
  a curric:KeyLearningPoint ;
  rdfs:label "Llywelyn refused to renew his homage to Edward I."@en ;
  dcterms:modified "2026-02-12T08:59:21.600777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5223-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I defeated the Welsh princes and Llewellyn finally paid homage in 1278."@en ;
  dcterms:modified "2026-02-12T08:59:21.600785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5347-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution saw new inventions which significantly changed manufacturing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5347-2
  a curric:KeyLearningPoint ;
  rdfs:label """During the Industrial Revolution many people migrated to urban areas and industrial cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5347-3
  a curric:KeyLearningPoint ;
  rdfs:label """During the Industrial Revolution there were calls for political change which led to the 1832 Great Reform Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Historians debate the extent of change to ordinary peoples' lives that took place during the Industrial Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many Germans felt betrayed by the Treaty of Versailles which had placed limits upon Germany and their military."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5378-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hitler’s speeches became popular in a weakened Germany."@en ;
  dcterms:modified "2026-02-12T08:59:21.601325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5378-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1929 Wall Street Crash caused a global economic depression."@en ;
  dcterms:modified "2026-02-12T08:59:21.601334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5378-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fascists throughout Europe, including Hitler and Mussolini, believed a dictatorship would resolve economic issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5378-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hitler came to power in Germany in 1933 and established the Third Reich."@en ;
  dcterms:modified "2026-02-12T08:59:21.601350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5402-1
  a curric:KeyLearningPoint ;
  rdfs:label """The medieval Church was extremely powerful and had a significant influence on people's ideas about the role of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Medieval Britain was a patriarchal society in which men had more power, control, and opportunities than women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5402-3
  a curric:KeyLearningPoint ;
  rdfs:label """The work completed by medieval women was partly determined by whether they lived in the countryside or in towns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5402-4
  a curric:KeyLearningPoint ;
  rdfs:label "The medieval Church represented one route to greater independence for women."@en ;
  dcterms:modified "2026-02-12T08:59:21.601879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5402-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some medieval women became literate through the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.601892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5188-1
  a curric:KeyLearningPoint ;
  rdfs:label "William of Normandy made thorough preparations for the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.601900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5188-2
  a curric:KeyLearningPoint ;
  rdfs:label "William of Normandy defeated Harold Godwinson at the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.601908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5188-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Bayeux Tapestry is an important source for the study of the Battle of Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5188-4
  a curric:KeyLearningPoint ;
  rdfs:label """Historians have to use the Bayeux Tapestry carefully when establishing what happened during the Battle of Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5204-1
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda married the Holy Roman Emperor when she was only 12 years old."@en ;
  dcterms:modified "2026-02-12T08:59:21.602439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5204-2
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda spent much of her early life in Germany."@en ;
  dcterms:modified "2026-02-12T08:59:21.602447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5204-3
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda took an active role in the government of the Holy Roman Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.602455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5204-4
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda's husband died and she was married again to Geoffrey Plantagenet."@en ;
  dcterms:modified "2026-02-12T08:59:21.602463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5204-5
  a curric:KeyLearningPoint ;
  rdfs:label "Matilda expected to inherit her father's throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.602470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5256-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1483 Edward died suddenly at the age of just 40, with his sons too young to rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5256-2
  a curric:KeyLearningPoint ;
  rdfs:label "A struggle to control the princes began and England once again became unstable."@en ;
  dcterms:modified "2026-02-12T08:59:21.602485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edward’s brother, Richard, took charge and made himself Protector, saying he would rule until Edward V was of age."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Richard took Edward V to the Tower of London and declared himself king, leading to noble rebellion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5256-5
  a curric:KeyLearningPoint ;
  rdfs:label """Richard III took Edward V’s brother to the Tower and instability arose due to arguments over his actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5237-1
  a curric:KeyLearningPoint ;
  rdfs:label "Islam was the dominant religion throughout North Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.602719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5237-2
  a curric:KeyLearningPoint ;
  rdfs:label "Muslim traders helped other Muslim traders."@en ;
  dcterms:modified "2026-02-12T08:59:21.602727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5237-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Islamic tradition prized literacy and education."@en ;
  dcterms:modified "2026-02-12T08:59:21.602734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5237-4
  a curric:KeyLearningPoint ;
  rdfs:label "Islamic thought influenced the culture of the Mali Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.602742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5237-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many books were copied or written in the Mali Empire, and mosques were built to house some of these."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5253-1
  a curric:KeyLearningPoint ;
  rdfs:label """After the Battle of St Albans, Henry VI’s wife, Margaret of Anjou, was determined to preserve her husband’s rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5253-2
  a curric:KeyLearningPoint ;
  rdfs:label """She ruled on his behalf and built Lancastrian support for Henry, removing Yorkists from court."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5253-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fighting broke out in 1460 with the powerful Earl of Warwick supporting the Yorkists, but York was killed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5253-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edward, York’s son, replaced him and defeated the Yorkists at Mortimer’s Cross and Towton, claiming the throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5253-5
  a curric:KeyLearningPoint ;
  rdfs:label """England had once again been made unstable by arguments over who should be in charge of the country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5240-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Peasants' Revolt took place in 1381."@en ;
  dcterms:modified "2026-02-12T08:59:21.603392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5240-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Peasants' Revolt had many long-term causes."@en ;
  dcterms:modified "2026-02-12T08:59:21.603400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5240-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some historians argue that the Black Death was related to the causes of the Peasants' Revolt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5240-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death arrived in England in 1348."@en ;
  dcterms:modified "2026-02-12T08:59:21.603415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5240-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death killed around half of the English population."@en ;
  dcterms:modified "2026-02-12T08:59:21.603423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5345-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Corn Laws were introduced in 1815 to keep the price of wheat high by putting tariffs on foreign imports."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5345-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Corn Laws meant many poor people could no longer afford bread."@en ;
  dcterms:modified "2026-02-12T08:59:21.604155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5345-3
  a curric:KeyLearningPoint ;
  rdfs:label """The government ignored industrial workers who had no right to vote, which increased calls for universal suffrage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5345-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tens of thousands of industrial workers gathered at St Peter's Field in Manchester in 1819 to peacefully protest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5345-5
  a curric:KeyLearningPoint ;
  rdfs:label """The local yeomanry attacked protestors at St Peter's Field, killing 16, this became known as 'the Peterloo Massacre'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5304-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the 17th century, a political party known as the Whigs emerged who were opposed to Catholicism and absolute monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5304-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whig historians share a belief that society developed and made progress over time, leading to constitutional monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5304-3
  a curric:KeyLearningPoint ;
  rdfs:label """Whig historians see the Glorious Revolution positively, seeing it as significant & underpinned by established tradition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5304-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Whig interpretation was almost unquestioned for nearly 300 years, but it did contain flaws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5205-1
  a curric:KeyLearningPoint ;
  rdfs:label "Henry I had a male heir, William Adelin."@en ;
  dcterms:modified "2026-02-12T08:59:21.605142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5205-2
  a curric:KeyLearningPoint ;
  rdfs:label "William Adelin died on the White Ship in 1120."@en ;
  dcterms:modified "2026-02-12T08:59:21.605150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5205-3
  a curric:KeyLearningPoint ;
  rdfs:label "The death of William Adelin prompted a succession crisis in England."@en ;
  dcterms:modified "2026-02-12T08:59:21.605158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5205-4
  a curric:KeyLearningPoint ;
  rdfs:label "The English barons swore to recognise Matilda as the heir."@en ;
  dcterms:modified "2026-02-12T08:59:21.605169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5205-5
  a curric:KeyLearningPoint ;
  rdfs:label "Stephen of Blois took the crown following Henry I's death."@en ;
  dcterms:modified "2026-02-12T08:59:21.605177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5266-1
  a curric:KeyLearningPoint ;
  rdfs:label """Henry VIII trying to get a divorce from Catherine of Aragon was known as the 'King's Great Matter'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5266-2
  a curric:KeyLearningPoint ;
  rdfs:label "Henry wished to marry Anne Boleyn because he needed a son for an heir."@en ;
  dcterms:modified "2026-02-12T08:59:21.605590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5266-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Church did not want to give Henry an annulment."@en ;
  dcterms:modified "2026-02-12T08:59:21.605598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5266-4
  a curric:KeyLearningPoint ;
  rdfs:label "The failure of Wolsey to secure an annulment led to his fall from power."@en ;
  dcterms:modified "2026-02-12T08:59:21.605605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5287-1
  a curric:KeyLearningPoint ;
  rdfs:label "The first successful North American English colony was Jamestown."@en ;
  dcterms:modified "2026-02-12T08:59:21.605617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5287-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colonials at first relied on Native Americans for help with food."@en ;
  dcterms:modified "2026-02-12T08:59:21.605625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tensions rose between colonists and Native Americans, leading to multiple conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5346-1
  a curric:KeyLearningPoint ;
  rdfs:label "Britain's unreformed parliament represented industrial workers poorly."@en ;
  dcterms:modified "2026-02-12T08:59:21.605691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5346-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Whig government of Earl Grey and the Birmingham Political Union (BPU) helped bring about the 1832 Great Reform Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5346-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Reform Act expanded the franchise and gave representation to industrial towns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5346-4
  a curric:KeyLearningPoint ;
  rdfs:label "Despite the Great Reform Act, only one in five men could vote after 1832."@en ;
  dcterms:modified "2026-02-12T08:59:21.605722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5346-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rules around being an MP were not changed by the Reform Act and remained a barrier to industrial workers representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5232-1
  a curric:KeyLearningPoint ;
  rdfs:label "The living conditions of Norwich's poor were far below those of the rich."@en ;
  dcterms:modified "2026-02-12T08:59:21.606134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5232-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some poor residents of Norwich were involved in the Peasants' Revolt in 1381."@en ;
  dcterms:modified "2026-02-12T08:59:21.606142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5232-3
  a curric:KeyLearningPoint ;
  rdfs:label "The lives of the poor are less well preserved in the historical record."@en ;
  dcterms:modified "2026-02-12T08:59:21.606149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5232-4
  a curric:KeyLearningPoint ;
  rdfs:label "The elites in Norwich were concerned to preserve the social order."@en ;
  dcterms:modified "2026-02-12T08:59:21.606157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5295-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sahel was home to kingdoms rich in culture and wealth such as Mali, Kano and Mossi."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5295-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Sahel was rich in gold which was the basis of trade between West African kingdoms and Islamic states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5295-3
  a curric:KeyLearningPoint ;
  rdfs:label """West African kingdoms traded gold in exchange for textiles, meaning a unequal trade with wealth leaving West Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5295-4
  a curric:KeyLearningPoint ;
  rdfs:label """The trade across the Sahel attracted thieves and robbers increasing violence in the region."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5295-5
  a curric:KeyLearningPoint ;
  rdfs:label "Europeans arrived in West Africa from the 1440s looking for gold."@en ;
  dcterms:modified "2026-02-12T08:59:21.606239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5279-1
  a curric:KeyLearningPoint ;
  rdfs:label "Social life was affected by changes to the Church and changes to the seasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.606678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5279-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many forms of entertainment remained the same throughout the Tudor period."@en ;
  dcterms:modified "2026-02-12T08:59:21.606685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5279-3
  a curric:KeyLearningPoint ;
  rdfs:label "Blood sports became more popular during the Tudor period."@en ;
  dcterms:modified "2026-02-12T08:59:21.606692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5279-4
  a curric:KeyLearningPoint ;
  rdfs:label "Theatres were built in London as a venue for plays to be performed."@en ;
  dcterms:modified "2026-02-12T08:59:21.606700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5297-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Triangular trade was the system of trade across the Atlantic."@en ;
  dcterms:modified "2026-02-12T08:59:21.606707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5297-2
  a curric:KeyLearningPoint ;
  rdfs:label "Manufactured goods were transported from Europe to be traded in West Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.606718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5297-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enslaved people were transported across the Atlantic and forced to work on plantations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5297-4
  a curric:KeyLearningPoint ;
  rdfs:label """Crops like tobacco, sugar and cotton would be grown by enslaved people on plantations and then sold in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5297-5
  a curric:KeyLearningPoint ;
  rdfs:label """As slavery had existed across Africa, European traders used this to take enslaved people to their colonies in America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5236-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gold was the main resource traded in the Sahel."@en ;
  dcterms:modified "2026-02-12T08:59:21.606788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5236-2
  a curric:KeyLearningPoint ;
  rdfs:label "Empires in the Sahel could make a large profit from this trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.606795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5236-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Ghana and Mali empires indirectly controlled the goldfields through trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.606802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5236-4
  a curric:KeyLearningPoint ;
  rdfs:label "The trade enriched the Islamic ruling elite of the Mali Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.606810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5236-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Mali Empire used its wealth from the gold trade to improve its levels of knowledge and understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5225-1
  a curric:KeyLearningPoint ;
  rdfs:label "In 1292 Edward became overlord of Scotland."@en ;
  dcterms:modified "2026-02-12T08:59:21.607956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5225-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many Scots resisted Edward’s rule and invaded northern England."@en ;
  dcterms:modified "2026-02-12T08:59:21.607963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5225-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edward believed he could unite England and Scotland because many Scottish leaders cooperated with Edward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5225-4
  a curric:KeyLearningPoint ;
  rdfs:label "Edward responded brutally to the Scottish rebellion."@en ;
  dcterms:modified "2026-02-12T08:59:21.607978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5225-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edward’s rule placed more demands on the Scots and created further resistance."@en ;
  dcterms:modified "2026-02-12T08:59:21.607985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5262-1
  a curric:KeyLearningPoint ;
  rdfs:label "Northern Renaissance art looked different."@en ;
  dcterms:modified "2026-02-12T08:59:21.607993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5262-2
  a curric:KeyLearningPoint ;
  rdfs:label "Painters like Holbein developed a different style."@en ;
  dcterms:modified "2026-02-12T08:59:21.608000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5262-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some English art belonged to the northern Renaissance."@en ;
  dcterms:modified "2026-02-12T08:59:21.608007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5262-4
  a curric:KeyLearningPoint ;
  rdfs:label "English monarchs became patrons of the Northern Renaissance."@en ;
  dcterms:modified "2026-02-12T08:59:21.608015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5262-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Northern Renaissance developed later."@en ;
  dcterms:modified "2026-02-12T08:59:21.608026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5234-1
  a curric:KeyLearningPoint ;
  rdfs:label "West Africa is rich in gold deposits."@en ;
  dcterms:modified "2026-02-12T08:59:21.608464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5234-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Sahel is an area between the Sahara Desert and the savannah."@en ;
  dcterms:modified "2026-02-12T08:59:21.608471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5234-3
  a curric:KeyLearningPoint ;
  rdfs:label "Important trade routes existed from North Africa through to the Far East."@en ;
  dcterms:modified "2026-02-12T08:59:21.608478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5234-4
  a curric:KeyLearningPoint ;
  rdfs:label "These trade routes also stretched across the Sahel."@en ;
  dcterms:modified "2026-02-12T08:59:21.608486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5234-5
  a curric:KeyLearningPoint ;
  rdfs:label "Powers like the Ghana Empire profited from these trade routes."@en ;
  dcterms:modified "2026-02-12T08:59:21.608493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9784-1
  a curric:KeyLearningPoint ;
  rdfs:label "The origins of the Black Death have only recently become clearer."@en ;
  dcterms:modified "2026-02-12T08:59:21.608709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9784-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Black Death affected people in the Middle East, China and Central Asia as well as Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9784-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some historians have argued that the Black Death arrived in Europe along the Silk Road."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9784-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death killed up to half the population of Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.608735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5301-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1685, the Catholic James II succeeded Charles II; his succession was smooth despite England being Protestant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5301-2
  a curric:KeyLearningPoint ;
  rdfs:label """Soon after, James II had to defeat the Monmouth Rebellion which sought to depose him due to his Catholic beliefs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5301-3
  a curric:KeyLearningPoint ;
  rdfs:label """James II expanded the size of the army and appointed Catholics to important positions without Parliament's agreement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5301-4
  a curric:KeyLearningPoint ;
  rdfs:label """James II also attempted to bring greater freedoms to Catholics in England through the Declaration of Indulgence in 1687."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5301-5
  a curric:KeyLearningPoint ;
  rdfs:label """The birth of James' son in 1688 scared his opponents about a possible Catholic succession."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5289-1
  a curric:KeyLearningPoint ;
  rdfs:label "Charles I believed in the Divine Right of Kings"@en ;
  dcterms:modified "2026-02-12T08:59:21.609187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5289-2
  a curric:KeyLearningPoint ;
  rdfs:label """Parliament was angered by Charles I's religious, financial and political policies"""@en ;
  dcterms:modified "2026-02-12T08:59:21.609195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5289-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parliament produced the Grand Remonstrance in 1641 to convey its many complaints to Charles I"""@en ;
  dcterms:modified "2026-02-12T08:59:21.609202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5289-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Grand Remonstrance was published as a pamphlet to help Parliament put pressure on the king to make changes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.609209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5273-1
  a curric:KeyLearningPoint ;
  rdfs:label """English privateers had been raiding Spanish ships in the Atlantic and stealing their gold."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5273-2
  a curric:KeyLearningPoint ;
  rdfs:label """England supported Dutch Protestant rebels in the Netherlands against the Spanish."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5273-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Spanish King, Philip II, wished to make England Catholic."@en ;
  dcterms:modified "2026-02-12T08:59:21.609309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5273-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Spanish Armada in 1588 was a Spanish attempt to invade England."@en ;
  dcterms:modified "2026-02-12T08:59:21.609316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5273-5
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth I used the victory over the Spanish in propaganda."@en ;
  dcterms:modified "2026-02-12T08:59:21.609324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5284-1
  a curric:KeyLearningPoint ;
  rdfs:label """During the Renaissance, European thinkers began to learn more about navigating the globe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5284-2
  a curric:KeyLearningPoint ;
  rdfs:label """Christopher Columbus was able to sail across the Atlantic Ocean and land in the Americas in 1492."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5284-3
  a curric:KeyLearningPoint ;
  rdfs:label "First European involvement in the Americas was for trade and exploration."@en ;
  dcterms:modified "2026-02-12T08:59:21.609345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5284-4
  a curric:KeyLearningPoint ;
  rdfs:label "Europeans called the Americas the 'New World'."@en ;
  dcterms:modified "2026-02-12T08:59:21.609357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5284-5
  a curric:KeyLearningPoint ;
  rdfs:label "Europeans began to claim land in the 'New World' for themselves."@en ;
  dcterms:modified "2026-02-12T08:59:21.609364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5300-1
  a curric:KeyLearningPoint ;
  rdfs:label """West African kingdoms were rich in culture and wealth due to trade across the Sahel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5300-2
  a curric:KeyLearningPoint ;
  rdfs:label "African Kingdoms traded in people who were enslaved due to war."@en ;
  dcterms:modified "2026-02-12T08:59:21.610433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5300-3
  a curric:KeyLearningPoint ;
  rdfs:label """The arrival of Europeans meant an increase in wars in West Africa leading to more people being enslaved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5300-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many West African kingdoms became reliant on trade with the Europeans which destabilised the African kingdoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5300-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Transatlantic trade exacerbated the trade in weapons and people leading to collapse of many kingdoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pamphlets represent an important source for historians studying early modern England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pamphlets were used as a form of propaganda during the Wars of the Three Kingdoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5294-3
  a curric:KeyLearningPoint ;
  rdfs:label """Historians can read these pamphlets carefully to understand the culture of seventeenth century England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5299-1
  a curric:KeyLearningPoint ;
  rdfs:label """The British arrived in West Africa from the 1660s, with the support of King Charles II and later King James II."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5299-2
  a curric:KeyLearningPoint ;
  rdfs:label """The arrival of the British led to more conflict between and within kingdoms in West Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5299-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before enslaved labour was used on plantations, Britain used a system of indentured labour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5299-4
  a curric:KeyLearningPoint ;
  rdfs:label "Barbados was the most profitable colony with the growth of sugar."@en ;
  dcterms:modified "2026-02-12T08:59:21.611707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5299-5
  a curric:KeyLearningPoint ;
  rdfs:label """The British transported enslaved people to new colonies in the Caribbean, such as Jamaica and Barbados."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5343-1
  a curric:KeyLearningPoint ;
  rdfs:label """New technological inventions fuelled the Industrial Revolution and made the production of goods more efficient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5343-2
  a curric:KeyLearningPoint ;
  rdfs:label "Canals and waterways were built to transport raw materials like coals to towns."@en ;
  dcterms:modified "2026-02-12T08:59:21.612006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5343-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cotton mills were developed to produce cloth using steam and power."@en ;
  dcterms:modified "2026-02-12T08:59:21.612013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5343-4
  a curric:KeyLearningPoint ;
  rdfs:label "Inventions made production more efficient but also replaced many jobs."@en ;
  dcterms:modified "2026-02-12T08:59:21.612021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5288-1
  a curric:KeyLearningPoint ;
  rdfs:label "European colonisation of the Americas had a range of devastating impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.612068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Europeans used religion to dispossess Native Americans and to change their culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5288-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conflict and disease had devastating impacts on Native American peoples."@en ;
  dcterms:modified "2026-02-12T08:59:21.612082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5288-4
  a curric:KeyLearningPoint ;
  rdfs:label "European colonisation involved exploitation of Native American peoples."@en ;
  dcterms:modified "2026-02-12T08:59:21.612090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5290-1
  a curric:KeyLearningPoint ;
  rdfs:label "The English Civil War involved fighting between Royalists and Parliamentarians."@en ;
  dcterms:modified "2026-02-12T08:59:21.612557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5290-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Civil War divided communities and even families."@en ;
  dcterms:modified "2026-02-12T08:59:21.612564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5290-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Parliamentarians were supported by a Scottish army from 1644 - 1646."@en ;
  dcterms:modified "2026-02-12T08:59:21.612570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5290-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pamphlets were used as a form of propaganda by both sides during the Civil War."@en ;
  dcterms:modified "2026-02-12T08:59:21.612580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5306-1
  a curric:KeyLearningPoint ;
  rdfs:label """Whig and revisionist historians have different interpretations of how revolutionary the Glorious Revolution was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5306-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whigs focus on the passing of the Bill of Rights and the growth in power of Parliament at the expense of the monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5306-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some revisionists argue that little changed, others say it was a very significant event that caused profound change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5306-4
  a curric:KeyLearningPoint ;
  rdfs:label """Whig and revisionist historians focus on different aspects of the Glorious Revolution in order to make their case."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5268-1
  a curric:KeyLearningPoint ;
  rdfs:label """Henry kept some ideas of Catholicism, like transubstantiation, and executed people who deviated from it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5268-2
  a curric:KeyLearningPoint ;
  rdfs:label """The closure of monasteries in England was known as the Dissolution of the Monasteries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5268-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Dissolution of Monasteries and religious changes led to a rebellion in 1536 known as the 'Pilgrimage of Grace'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5268-4
  a curric:KeyLearningPoint ;
  rdfs:label """Henry's son, Edward VI, made England more Protestant and introduced the Book of Common Prayer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5268-5
  a curric:KeyLearningPoint ;
  rdfs:label "Henry's daughter, Mary I, was Catholic and restored Catholicism in England."@en ;
  dcterms:modified "2026-02-12T08:59:21.612957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5278-1
  a curric:KeyLearningPoint ;
  rdfs:label "The population of England was growing in the 16th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.612965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5278-2
  a curric:KeyLearningPoint ;
  rdfs:label "Urban areas grew more rapidly than rural areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.612972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5278-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes to land use in rural areas meant less food was being grown."@en ;
  dcterms:modified "2026-02-12T08:59:21.612979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5278-4
  a curric:KeyLearningPoint ;
  rdfs:label "There was a relationship between population growth and poverty."@en ;
  dcterms:modified "2026-02-12T08:59:21.612986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5274-1
  a curric:KeyLearningPoint ;
  rdfs:label """The growth in importance of the gentry caused a great deal of change in English society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5274-2
  a curric:KeyLearningPoint ;
  rdfs:label """There was a growth in literacy rates and expansion of arts during the Elizabethan 'Golden Age'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5274-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth faced a lot of factionalism in her government at a time of bad harvests and growing unemployment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5274-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tyrone rebelled against Elizabeth in Ireland."@en ;
  dcterms:modified "2026-02-12T08:59:21.613998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5274-5
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth faced a rebellion from the Earl of Essex."@en ;
  dcterms:modified "2026-02-12T08:59:21.614005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5254-1
  a curric:KeyLearningPoint ;
  rdfs:label """Although Edward IV’s rule was secure by 1464, he jeopardised stability by marrying Elizabeth Woodville."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5254-2
  a curric:KeyLearningPoint ;
  rdfs:label """This marriage angered many at court, including Warwick, especially after the Woodvilles began to gain more influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5254-3
  a curric:KeyLearningPoint ;
  rdfs:label """Queen Margaret and Warwick combined forces to usurp Edward, who fled abroad, and the crown was returned to Henry VI."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5254-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edward returned to defeat Warwick and Margaret at Barnet, Henry VI was murdered and Edward VI was restored as king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5254-5
  a curric:KeyLearningPoint ;
  rdfs:label """England had been made unstable by Edward IV’s inability to keep the support of his nobles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9785-1
  a curric:KeyLearningPoint ;
  rdfs:label "At the beginning of the 18th century England was an emerging empire-builder."@en ;
  dcterms:modified "2026-02-12T08:59:21.614663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9785-2
  a curric:KeyLearningPoint ;
  rdfs:label """England was agricultural with a large middling sort who provided a base to trade with and settle in distant places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9785-3
  a curric:KeyLearningPoint ;
  rdfs:label """England had established colonies in North America and the Caribbean, with which English merchants traded."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9785-4
  a curric:KeyLearningPoint ;
  rdfs:label """350 000 had emigrated to colonies in the Americas; trade with them, bolstered by enslavement, was worth a great deal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9785-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Navigation Act created a mercantilist framework for English trade with its colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5322-1
  a curric:KeyLearningPoint ;
  rdfs:label """European Enlightenment ideas had spread to America, causing a revolution which France had supported."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5322-2
  a curric:KeyLearningPoint ;
  rdfs:label "The French monarchy was deep in debt and taxed the poorest in society the most."@en ;
  dcterms:modified "2026-02-12T08:59:21.614811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5322-3
  a curric:KeyLearningPoint ;
  rdfs:label """The inequality of the Ancien Régime and successive poor harvests angered ordinary people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5322-4
  a curric:KeyLearningPoint ;
  rdfs:label """King Louis XVI and Queen Marie Antoinette spent money lavishly whilst their people were starving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5322-5
  a curric:KeyLearningPoint ;
  rdfs:label """The people of France rose up against the monarchy in revolution in 1789 leading to the execution of the king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5309-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mughal power at the start of Akbar's reign was not fully secure."@en ;
  dcterms:modified "2026-02-12T08:59:21.614842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5309-2
  a curric:KeyLearningPoint ;
  rdfs:label "Akbar expanded the size of the Mughal Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.614849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5309-3
  a curric:KeyLearningPoint ;
  rdfs:label "Akbar was a strong military leader who conquered many rival states."@en ;
  dcterms:modified "2026-02-12T08:59:21.614856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5309-4
  a curric:KeyLearningPoint ;
  rdfs:label "Akbar also used diplomacy to help expand the empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.614862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5340-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Royal Navy defeated Napoleon at the Battle of Trafalgar in 1805."@en ;
  dcterms:modified "2026-02-12T08:59:21.614916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5340-2
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon coerced countries like Russia into a 'continental system' which banned trade with Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5340-3
  a curric:KeyLearningPoint ;
  rdfs:label "Napoleon invaded Russia in 1812 but this invasion was a failure."@en ;
  dcterms:modified "2026-02-12T08:59:21.614933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5340-4
  a curric:KeyLearningPoint ;
  rdfs:label "Napoleon was defeated and sent into exile."@en ;
  dcterms:modified "2026-02-12T08:59:21.614940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5340-5
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon returned from exile but was defeated a second time at the Battle of Waterloo in 1815."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5308-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Mughal Empire suffered from political instability at the beginning of Humayun's reign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5308-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humayun lost control of the empire in 1540 and was forced into exile."@en ;
  dcterms:modified "2026-02-12T08:59:21.615075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5308-3
  a curric:KeyLearningPoint ;
  rdfs:label "Humayun used diplomacy to gain support from the Persian Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.615085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5308-4
  a curric:KeyLearningPoint ;
  rdfs:label """Humayun reconquered India in 1555 at a time when political instability weakened his enemies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5317-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1756, war was triggered by the EIC building fortifications without permission from the Nawab of Bengal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5317-2
  a curric:KeyLearningPoint ;
  rdfs:label """The EIC achieved significant military victories in India at the Battles of Plassey and Buxar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5317-3
  a curric:KeyLearningPoint ;
  rdfs:label "After 1757, the EIC installed puppet leaders in Bengal."@en ;
  dcterms:modified "2026-02-12T08:59:21.615214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5317-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1765 Treaty of Allahabad allowed the EIC to formally control Bengal and collect taxes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5317-5
  a curric:KeyLearningPoint ;
  rdfs:label """The years between 1757 and 1765 have been referred to as part of the Plassey Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5321-1
  a curric:KeyLearningPoint ;
  rdfs:label """Enlightenment ideas were discussed and debated among the educated classes in Europe during the 1600s and 1700s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5321-2
  a curric:KeyLearningPoint ;
  rdfs:label """The American people did not have representation in the British parliament which created their heavy taxes and laws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5321-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the American settlers challenged England on these issues, they were ignored, leading to war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5321-4
  a curric:KeyLearningPoint ;
  rdfs:label "The American people declared their independence from Britain in 1776."@en ;
  dcterms:modified "2026-02-12T08:59:21.615539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5321-5
  a curric:KeyLearningPoint ;
  rdfs:label """America secured the new republic with the US Constitution and inspired similar unrest in France at the end of the 1780s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5313-1
  a curric:KeyLearningPoint ;
  rdfs:label "The East India Company (EIC) was created in 1601 for trade with the East."@en ;
  dcterms:modified "2026-02-12T08:59:21.615552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5313-2
  a curric:KeyLearningPoint ;
  rdfs:label "The EIC competed with other Europeans such as the Portuguese and Dutch."@en ;
  dcterms:modified "2026-02-12T08:59:21.615562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5313-3
  a curric:KeyLearningPoint ;
  rdfs:label "The EIC constructed factories to support its trade in India."@en ;
  dcterms:modified "2026-02-12T08:59:21.615572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5313-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EIC required permission from the Mughal Emperors to conduct its activities in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5313-5
  a curric:KeyLearningPoint ;
  rdfs:label "During Child's War, the Mughal Empire defeated the forces of the EIC."@en ;
  dcterms:modified "2026-02-12T08:59:21.615585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5312-1
  a curric:KeyLearningPoint ;
  rdfs:label """By the end of the 17th century, the Mughals ruled over most of the Indian subcontinent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5312-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mughal conquest was often violent, especially involving wars against other Indian states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5312-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of non-violent factors contributed to the Mughal conquests in India."@en ;
  dcterms:modified "2026-02-12T08:59:21.615903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5312-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the factors responsible for Mughal conquests enhanced the effects of one another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5311-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jahangir, Shah Jahan and Aurangzeb ruled the Mughal Empire for most of the 17th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5311-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shah Jahan contributed significantly to Mughal architecture."@en ;
  dcterms:modified "2026-02-12T08:59:21.616122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5311-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Mughal Empire reached its maximum extent during the reign of Aurangzeb."@en ;
  dcterms:modified "2026-02-12T08:59:21.616129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5311-4
  a curric:KeyLearningPoint ;
  rdfs:label "Expansion and conflict made the empire increasingly costly to maintain."@en ;
  dcterms:modified "2026-02-12T08:59:21.616135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5311-5
  a curric:KeyLearningPoint ;
  rdfs:label "Rebellions increasingly destabilised the Mughal Empire by the late 17th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.616142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5307-1
  a curric:KeyLearningPoint ;
  rdfs:label "No single power ruled over India at the start of the 16th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.616148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5307-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Mughals came from Central Asia and were led by Babur."@en ;
  dcterms:modified "2026-02-12T08:59:21.616155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5307-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Mughals invaded India in 1525 and achieved important military victories in 1526 and 1527."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5307-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Delhi Sultanate suffered from divisions before the Mughal invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.616168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5307-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many historians date the foundation of the Mughal Empire to 1526."@en ;
  dcterms:modified "2026-02-12T08:59:21.616174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5336-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French Revolution led to the execution of King Louis XVI and social upheaval in France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5336-2
  a curric:KeyLearningPoint ;
  rdfs:label """Burke and others feared that the French Revolution would inspire similar social upheaval across Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5336-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pamphlets became popular at this time which historians use to understand British responses to the French Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5336-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wollstonecraft and Paine believed Britain should implement a written constitution like the French or US constitution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5336-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pitt feared the unrest that the French Revolution was causing in Britain and brought in new laws to deal with this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5315-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aurangzeb's death was followed by a period of political struggle over the Mughal throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5315-2
  a curric:KeyLearningPoint ;
  rdfs:label "Successor states to the Mughal Empire emerged in the early 18th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.616504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5315-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successor states claimed to be loyal but focused on building up their own power."@en ;
  dcterms:modified "2026-02-12T08:59:21.616510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5315-4
  a curric:KeyLearningPoint ;
  rdfs:label "In 1739, the Persian army sacked Delhi, the capital of the Mughal Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.616517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5337-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ireland was a religiously divided country where a minority Anglican elite ruled over a majority Catholic population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5337-2
  a curric:KeyLearningPoint ;
  rdfs:label """The French Revolution inspired the 'United Irishmen' to try and unite Protestants and Catholics against British rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5337-3
  a curric:KeyLearningPoint ;
  rdfs:label """United Irishmen leader Wolf Tone met with Napoleon to win support for an Irish Rebellion against Great Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5337-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Irish Rebellion of 1798 ultimately failed despite France's promised support."@en ;
  dcterms:modified "2026-02-12T08:59:21.617011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5337-5
  a curric:KeyLearningPoint ;
  rdfs:label """The failed Irish Rebellion led to increased British control over Ireland and ultimately to formal unification in 1801."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24149-1
  a curric:KeyLearningPoint ;
  rdfs:label """During the 'long eighteenth century' Britain underwent both agricultural and industrial revolutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24149-2
  a curric:KeyLearningPoint ;
  rdfs:label """Historians have debated the extent to which these domestic developments led to the growth of the empire, or vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24149-3
  a curric:KeyLearningPoint ;
  rdfs:label """A growing population in North America and the burgeoning trade in enslaved people created a demand for British goods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24149-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some have argued that British manufacturing production owed more to demand from the domestic market than from overseas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24149-5
  a curric:KeyLearningPoint ;
  rdfs:label """Others have suggested that protectionist trade policies led to colonies becoming a burden on Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5341-1
  a curric:KeyLearningPoint ;
  rdfs:label """Contemporary cartoons give us insight into contemporary responses to the Napoleonic period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Historians look at the provenance of a source to determine the purpose of its creation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5341-3
  a curric:KeyLearningPoint ;
  rdfs:label "Historians also look at the provenance of a source to determine its reliability."@en ;
  dcterms:modified "2026-02-12T08:59:21.617070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Historians can discern nuance in contemporary opinion on the Napoleonic era by studying contemporary political cartoons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5318-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mughal authority grew weaker during the late-17th and 18th centuries."@en ;
  dcterms:modified "2026-02-12T08:59:21.617083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5318-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Mughals were challenged by rebellions, leadership struggles, the rise of successor states and foreign invasions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5318-3
  a curric:KeyLearningPoint ;
  rdfs:label """The British East India Company's power grew significantly during the 18th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most historians agree that Mughal authority collapsed at some point during the 18th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5318-5
  a curric:KeyLearningPoint ;
  rdfs:label """Historians evaluating Mughal collapse often focus on the emperor's level of political control and military power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain's population, now incorporating Scotland and Ireland, had risen to 12 million, many of whom worked in industry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27104-2
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had gone through a consumer revolution and had become the world’s first mass consumer society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27104-3
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had gained additional territories in America, the Caribbean, Africa and India, and trade had flourished."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before abolition in 1807, Britain had been the largest carrier of enslaved people to the Americas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27104-5
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had developed the Royal Navy which played a key role in establishing Britain as the dominant world power"""@en ;
  dcterms:modified "2026-02-12T08:59:21.617206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5339-1
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon seized power in 1799, failed to recapture Saint-Domingue and completed the Louisiana Purchase in 1803."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon made himself 'Emperor of the French' in 1804 and took on absolute power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5339-3
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon introduced the Code Napoleon in 1804 which replaced feudalism with a modern legal framework."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5339-4
  a curric:KeyLearningPoint ;
  rdfs:label """Britain, France and Russia entered a military coalition against France in 1805 known as the Third Coalition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5339-5
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon conquered much of Europe and exported French laws and ideals to those territories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5310-1
  a curric:KeyLearningPoint ;
  rdfs:label """Akbar was a Muslim but generally followed a policy of religious tolerance for non-Muslims."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5310-2
  a curric:KeyLearningPoint ;
  rdfs:label """Akbar believed that religious intolerance would make the empire harder to govern."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5310-3
  a curric:KeyLearningPoint ;
  rdfs:label "A new taxation system, the dahsala, was introduced during Akbar's reign."@en ;
  dcterms:modified "2026-02-12T08:59:21.617723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5310-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dahsala was designed to help serve the interests of both the Mughal government and ordinary people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9786-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1701 Act of Settlement forbade any Catholics from sitting upon the British throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9786-2
  a curric:KeyLearningPoint ;
  rdfs:label """William III and Mary II did not have any children and so the throne passed to Mary's sister, Anne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9786-3
  a curric:KeyLearningPoint ;
  rdfs:label "Queen Anne did not have any surviving children by the end of her reign."@en ;
  dcterms:modified "2026-02-12T08:59:21.617886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9786-4
  a curric:KeyLearningPoint ;
  rdfs:label "Parliament intervened to ensure a Protestant succession; George I was made king."@en ;
  dcterms:modified "2026-02-12T08:59:21.617892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9786-5
  a curric:KeyLearningPoint ;
  rdfs:label "George I was less involved in the running of government."@en ;
  dcterms:modified "2026-02-12T08:59:21.617898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5324-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Enlightenment was a series of ideas that criticised absolutist governments."@en ;
  dcterms:modified "2026-02-12T08:59:21.618598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5324-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Enlightenment inspired groups of people to challenge their governments."@en ;
  dcterms:modified "2026-02-12T08:59:21.618604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5324-3
  a curric:KeyLearningPoint ;
  rdfs:label "The American Revolution was inspired by Enlightened ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.618610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5324-4
  a curric:KeyLearningPoint ;
  rdfs:label "The French Revolution was inspired by the Americans and Enlightenment ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.618621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5324-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Enlightenment ideas inspired further revolutions across the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.618628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5338-1
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon, a young revolutionary from Corsica, became the most powerful general in the French army."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5338-2
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon conquered a portion of northern Italy and established a new country based on revolutionary principles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5338-3
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon had initial success conquering Egypt but was ultimately forced to retreat to France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5338-4
  a curric:KeyLearningPoint ;
  rdfs:label """Parisians at this time were unhappy with the Directorate and began to agitate for a change in the Republic's leadership."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5338-5
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon took power through a coup d'etat in 1799, declared himself First Consul and established a military dictatorship"""@en ;
  dcterms:modified "2026-02-12T08:59:21.618689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5316-1
  a curric:KeyLearningPoint ;
  rdfs:label "Trade was considered important for a country's power in the 18th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.618927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5316-2
  a curric:KeyLearningPoint ;
  rdfs:label """The British East India Company and French Compagnie des Indes competed over trade in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5316-3
  a curric:KeyLearningPoint ;
  rdfs:label "The British and French made alliances with Indian successor states."@en ;
  dcterms:modified "2026-02-12T08:59:21.618939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5316-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EIC and Compagnie des Indes recruited private armies, mostly made up of sepoys."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5316-5
  a curric:KeyLearningPoint ;
  rdfs:label """The EIC and Comapgnie des Indes used their armies to fight against one another, and to support their Indian allies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5314-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mughal emperors, including Aurangzeb, were Muslims."@en ;
  dcterms:modified "2026-02-12T08:59:21.618982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5314-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mughal emperors traditionally showed tolerance towards non-Muslims."@en ;
  dcterms:modified "2026-02-12T08:59:21.618989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5314-3
  a curric:KeyLearningPoint ;
  rdfs:label "Aurangzeb reintroduced the jizya and even destroyed Hindu temples."@en ;
  dcterms:modified "2026-02-12T08:59:21.618995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5314-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hindu and Sikh groups rebelled against the Mughals during Aurangzeb's reign."@en ;
  dcterms:modified "2026-02-12T08:59:21.619001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5314-5
  a curric:KeyLearningPoint ;
  rdfs:label """A growing number of non-Muslims served as Mughal officials during Aurangzeb's reign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5235-1
  a curric:KeyLearningPoint ;
  rdfs:label """New civilisations grew up in the Sahel as the Ghana Empire declined and trade increased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5235-2
  a curric:KeyLearningPoint ;
  rdfs:label """Trade from new gold fields bypassed the Ghana Empire, which made other kingdoms in the region wealthy and powerful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5235-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Mali Empire was one new civilisation which expanded."@en ;
  dcterms:modified "2026-02-12T08:59:21.627577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5235-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rulers of Mali and the people who lived in cities were generally followers of Islam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5235-5
  a curric:KeyLearningPoint ;
  rdfs:label """The people who lived in the countryside generally retained their traditional religious practices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5260-1
  a curric:KeyLearningPoint ;
  rdfs:label "New artistic techniques were developed during the Renaissance."@en ;
  dcterms:modified "2026-02-12T08:59:21.627595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5260-2
  a curric:KeyLearningPoint ;
  rdfs:label "Da Vinci's artworks like the Mona Lisa display these techniques."@en ;
  dcterms:modified "2026-02-12T08:59:21.627631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5260-3
  a curric:KeyLearningPoint ;
  rdfs:label "Painters studied one another's work to improve their craft."@en ;
  dcterms:modified "2026-02-12T08:59:21.627637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5260-4
  a curric:KeyLearningPoint ;
  rdfs:label "St Peter's Basilica in Rome is a classic example of Renaissance architecture."@en ;
  dcterms:modified "2026-02-12T08:59:21.627642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5260-5
  a curric:KeyLearningPoint ;
  rdfs:label "Renaissance architecture drew on classical models."@en ;
  dcterms:modified "2026-02-12T08:59:21.627647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5263-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of sources can be used to learn about a period."@en ;
  dcterms:modified "2026-02-12T08:59:21.627651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5263-2
  a curric:KeyLearningPoint ;
  rdfs:label "These sources can be used to answer different questions."@en ;
  dcterms:modified "2026-02-12T08:59:21.627656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5263-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance was expressed through book production."@en ;
  dcterms:modified "2026-02-12T08:59:21.627661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5263-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance was expressed through writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.627669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5263-5
  a curric:KeyLearningPoint ;
  rdfs:label "The Renaissance was expressed through art and architecture."@en ;
  dcterms:modified "2026-02-12T08:59:21.627676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5275-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth used symbols within paintings to present different ideas about herself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5275-2
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth used speeches to persuade and rally support."@en ;
  dcterms:modified "2026-02-12T08:59:21.627972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5275-3
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth tightly controlled how she was depicted during her own lifetime."@en ;
  dcterms:modified "2026-02-12T08:59:21.627977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5275-4
  a curric:KeyLearningPoint ;
  rdfs:label "Popular interpretations of Elizabeth I have changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.627982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5222-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I was a strong leader and skilled in warfare."@en ;
  dcterms:modified "2026-02-12T08:59:21.628048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5222-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edward I wanted to unite England after it had been divided by a civil war between the king and his barons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5222-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I showed he could be a just ruler, and called a Model Parliament in 1295."@en ;
  dcterms:modified "2026-02-12T08:59:21.628058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5222-4
  a curric:KeyLearningPoint ;
  rdfs:label "Parliament persuaded Edward I to expel Jewish people from England."@en ;
  dcterms:modified "2026-02-12T08:59:21.628062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5222-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edward I was the first medieval king not to be faced with a civil war."@en ;
  dcterms:modified "2026-02-12T08:59:21.628067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gold and the wealth of West African kingdoms brought the Europeans to West Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5296-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power in West Africa became concentrated in smaller kingdoms who were able to trade with Europeans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5296-3
  a curric:KeyLearningPoint ;
  rdfs:label """The growth of Portuguese trade in the Sahel led to collapse of some African kingdoms, but also to the growth of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5296-4
  a curric:KeyLearningPoint ;
  rdfs:label """Europeans soon started selling enslaved people in the Americas to make more profit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Germany occupied much of Europe during WW2."@en ;
  dcterms:modified "2026-02-12T08:59:21.629635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5387-2
  a curric:KeyLearningPoint ;
  rdfs:label """German expansion increased the Jewish population under Nazi rule and led to more extreme persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5387-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ghettos were set up across Europe but their purpose changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.629647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5387-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'Final Solution' was decided upon by the end of 1941."@en ;
  dcterms:modified "2026-02-12T08:59:21.629652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5387-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extermination camps were set up as part of the 'Final Solution' and killed millions of Jews."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5393-1
  a curric:KeyLearningPoint ;
  rdfs:label """After the Second World War, Britain had initially hoped to retain control of its empire in Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5393-2
  a curric:KeyLearningPoint ;
  rdfs:label """From 1945, demands for independence from nationalist movements across Britain's African colonies intensified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5393-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nkrumah led peaceful protests against British rule in the Gold Coast, which became independent as Ghana in 1957."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5393-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Mau Mau Uprising meant that Kenya's transition to independence was more violent than in other African colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5393-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Mau Mau Uprising helped to demonstrate that Britain could no longer rule Kenya and it became independent in 1963."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5381-1
  a curric:KeyLearningPoint ;
  rdfs:label """In June 1941 Hitler launched an invasion of the Soviet Union, seeking to increase German territory to its east."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5381-2
  a curric:KeyLearningPoint ;
  rdfs:label """At first Nazi Germany was successful, taking control of much of the western parts of the Soviet Union."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5381-3
  a curric:KeyLearningPoint ;
  rdfs:label """In December 1941 Japan attacked the USA at Pearl Harbour, leading to them declaring war on both Japan and Nazi Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5381-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Nazis attempted to take Stalingrad in 1942 but were ultimately unsuccessful after 5 months of fighting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5381-5
  a curric:KeyLearningPoint ;
  rdfs:label """The period 1941-2 was a turning point as it weakened Nazi Germany and led to the entry of the USA into the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5395-1
  a curric:KeyLearningPoint ;
  rdfs:label """The British Empire experienced significant decolonisation after the Second World War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5395-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although decolonisation was complex and experiences varied considerably, it was a peaceful process in many places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5395-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decolonisation was more likely to involve violence in the colonies that were the most valuable to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5395-4
  a curric:KeyLearningPoint ;
  rdfs:label """Decolonisation in Ireland, India and Palestine was a violent process involving controversial partition processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5395-5
  a curric:KeyLearningPoint ;
  rdfs:label """British actions were directly or indirectly responsible for much of the violence that took place during decolonisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5384-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Holocaust involved the deliberate murder of around 6 million European Jews."@en ;
  dcterms:modified "2026-02-12T08:59:21.631182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5384-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nazi ideology held that Jewish people were racially inferior and a threat."@en ;
  dcterms:modified "2026-02-12T08:59:21.631187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5384-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Holocaust represented an attempt to murder all Jews."@en ;
  dcterms:modified "2026-02-12T08:59:21.631192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5384-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Holocaust is distinct from other genocides and other instances of Nazi persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Despite opposition to female suffrage, a number of suffrage groups were set up across the country from the 1860s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5361-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1897, Millicent Fawcett set up the National Union of Women's Suffrage Societies (NUWSS)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5361-3
  a curric:KeyLearningPoint ;
  rdfs:label "The NUWSS preferred peaceful means such as writing letters to MPs."@en ;
  dcterms:modified "2026-02-12T08:59:21.632959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5361-4
  a curric:KeyLearningPoint ;
  rdfs:label """Early campaigns for women's suffrage involved a mixture of middle- and working-class women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5361-5
  a curric:KeyLearningPoint ;
  rdfs:label """Early campaigns for women's suffrage had failed to gain women the right to vote by 1914."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5371-1
  a curric:KeyLearningPoint ;
  rdfs:label """The estimated four million British men who fought in for Britain fought mostly in trenches, with huge losses of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The war revolutionised life in Britain, particularly with women entering the workforce."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The war slowed Ireland's journey towards independence from Britain, which would result in partition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5371-4
  a curric:KeyLearningPoint ;
  rdfs:label """The British army were supported by around three million soldiers from the British empire and former colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5391-1
  a curric:KeyLearningPoint ;
  rdfs:label """A strong nationalist movement existed in India in the early 20th century; WW2 led to increased calls for independence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tensions between Hindus and Muslims increased after WW2 and India's Muslims demanded their own state: Pakistan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5391-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1947, India was partitioned into two states: India and Pakistan; East Pakistan would become Bangladesh in 1971."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Partition resulted in mass migration, which displaced 17-18 million people and unleashed a wave of lethal violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5391-5
  a curric:KeyLearningPoint ;
  rdfs:label "Partition created a legacy of mistrust and hostility between India and Pakistan."@en ;
  dcterms:modified "2026-02-12T08:59:21.633052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5366-1
  a curric:KeyLearningPoint ;
  rdfs:label """The increasing influence of Germany in the early twentieth century caused anxiety in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5366-2
  a curric:KeyLearningPoint ;
  rdfs:label """Germany signed a military alliance with Italy and Austria-Hungary in 1882, known as the Triple Alliance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5366-3
  a curric:KeyLearningPoint ;
  rdfs:label """By 1907, Britain had formed a military alliance with Russia and France, known as the Triple Entente."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5366-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the early twentieth century powers in Europe began building up their militaries, known as the 'arms race'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5351-1
  a curric:KeyLearningPoint ;
  rdfs:label "Britain had no colonies in East Asia in the early 19th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.636751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5351-2
  a curric:KeyLearningPoint ;
  rdfs:label """A lack of Chinese interest and restrictions imposed by the Qing Empire limited British trade with China."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5351-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Opium Wars between Britain and the Qing Empire are an example of gunboat diplomacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5351-4
  a curric:KeyLearningPoint ;
  rdfs:label "Britain expanded its formal empire by gaining control over Hong Kong."@en ;
  dcterms:modified "2026-02-12T08:59:21.636766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5351-5
  a curric:KeyLearningPoint ;
  rdfs:label """Growing British influence in the Qing Empire helped it develop an informal empire after the Opium Wars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5392-1
  a curric:KeyLearningPoint ;
  rdfs:label """During WW1, Britain occupied Palestine and made conflicting promises to different groups of people which caused tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5392-2
  a curric:KeyLearningPoint ;
  rdfs:label """After WW1, the British government administered Palestine, allowing Jewish immigration which caused tension and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5392-3
  a curric:KeyLearningPoint ;
  rdfs:label """After the Holocaust, large numbers of European Jews travelled to Palestine to form a Jewish state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5392-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1947, the UN proposed the partition of Palestine to create separate Arab and Jewish states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5392-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1948, Israel declared independence leading to the 1948 war involving neighbouring Arab states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5385-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jewish communities had existed in Europe since the Classical age."@en ;
  dcterms:modified "2026-02-12T08:59:21.637619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5385-2
  a curric:KeyLearningPoint ;
  rdfs:label "Most European Jews lived in Central and Eastern Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.637624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5385-3
  a curric:KeyLearningPoint ;
  rdfs:label "Levels of assimilation differed across Jewish communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.637629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5385-4
  a curric:KeyLearningPoint ;
  rdfs:label """Factors other than religion, including family, age and wealth, also had a significant influence on Jewish lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5367-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tensions rose in the Balkans due to the rise of nationalist movements and opposition to Austrian influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5367-2
  a curric:KeyLearningPoint ;
  rdfs:label """The trigger for war was the assassination of the Austrian Archduke Franz Ferdinand in Serbia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5367-3
  a curric:KeyLearningPoint ;
  rdfs:label "German-supported Austria declared war on Serbia, supported by Russia."@en ;
  dcterms:modified "2026-02-12T08:59:21.639697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5367-4
  a curric:KeyLearningPoint ;
  rdfs:label """The system of alliances caused Germany and Russia to declare war, dragging other powers into the conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5367-5
  a curric:KeyLearningPoint ;
  rdfs:label """The failure of Germany's Schlieffen Plan, which assumed British neutrality, contributed to the outbreak of a global war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The government increased general taxation to pay for child allowances to alleviate child poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5397-2
  a curric:KeyLearningPoint ;
  rdfs:label """The government introduced National Insurance, to which all workers contributed from their salary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5397-3
  a curric:KeyLearningPoint ;
  rdfs:label """The National Insurance scheme would give people state support if they became ill or lost their job."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5397-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1948, the National Health Service (NHS) was created which was universal and free at the point of use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5397-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reforms introduced by the government formed the basis of the modern welfare state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5362-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some suffragists were becoming disillusioned with the lack of progress made by the NUWSS."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5362-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1903 the Women's Social and Political Union (WSPU) was formed by Emmeline Pankhurst and her daughters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5362-3
  a curric:KeyLearningPoint ;
  rdfs:label "The WSPU employed more radical tactics, such as large demonstrations."@en ;
  dcterms:modified "2026-02-12T08:59:21.642771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5362-4
  a curric:KeyLearningPoint ;
  rdfs:label """The aims of the WSPU became more conservative, only aiming to vote on the same terms as men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5362-5
  a curric:KeyLearningPoint ;
  rdfs:label "The actions of the WSPU became more violent from 1906."@en ;
  dcterms:modified "2026-02-12T08:59:21.642781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5399-1
  a curric:KeyLearningPoint ;
  rdfs:label """During WW2, many women entered the workforce or were conscripted into military support services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5399-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the late 1940s, labour shortages meant women were encouraged to re-enter the labour market."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5399-3
  a curric:KeyLearningPoint ;
  rdfs:label "Women were seen as secondary workers and were paid less than men."@en ;
  dcterms:modified "2026-02-12T08:59:21.643684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5399-4
  a curric:KeyLearningPoint ;
  rdfs:label """Women campaigned for equal pay throughout the 1950s and 1960s, with teachers granted equal pay in 1955."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many married women undertook paid work in the 1960s but still faced significant discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5349-1
  a curric:KeyLearningPoint ;
  rdfs:label """By the 1850s, most of the Indian subcontinent was under the control of the East India Company."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5349-2
  a curric:KeyLearningPoint ;
  rdfs:label """The social, political and economic impacts of Company rule made the EIC unpopular in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5349-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1857 Indian Rebellion threatened British rule in India."@en ;
  dcterms:modified "2026-02-12T08:59:21.644758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5349-4
  a curric:KeyLearningPoint ;
  rdfs:label """After the Indian Rebellion, India became a Crown Colony governed directly by the British Government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5349-5
  a curric:KeyLearningPoint ;
  rdfs:label "Taxes remained high in British India after 1858."@en ;
  dcterms:modified "2026-02-12T08:59:21.644767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5374-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Bolsheviks were a revolutionary party led by Vladimir Lenin."@en ;
  dcterms:modified "2026-02-12T08:59:21.646873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5374-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Provisional Government was toppled by the Bolshevik Party in October 1917."@en ;
  dcterms:modified "2026-02-12T08:59:21.646878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5374-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lenin withdrew Russia from WW1 and by agreeing to the Treaty of Brest-Litovsk in 1918."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5374-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Bolsheviks shot Tsar Nicolas and limited opposition in Russia."@en ;
  dcterms:modified "2026-02-12T08:59:21.646888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Due to their belief in social democracy, the Labour government were committed to a programme of nationalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5398-2
  a curric:KeyLearningPoint ;
  rdfs:label """They believed that this would lead to lower prices and create more jobs, with better working conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5398-3
  a curric:KeyLearningPoint ;
  rdfs:label """By 1951, key industries were nationalised: the coal mines; iron, gas and steel industries; and the railways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5398-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Conservatives, critics of nationalisation, took over in 1951, but allowed these industries to remain nationalised."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5398-5
  a curric:KeyLearningPoint ;
  rdfs:label """Output increased and more places were connected by rail but the process only artificially helped declining industries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5401-1
  a curric:KeyLearningPoint ;
  rdfs:label """Clement Attlee talked of creating a 'New Jerusalem' and the new welfare state did improve quality of life for many."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5401-2
  a curric:KeyLearningPoint ;
  rdfs:label "Key industries were nationalised, creating a mixed economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.648244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many groups, such as women and Caribbean migrants, still experienced significant discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5401-4
  a curric:KeyLearningPoint ;
  rdfs:label """One's experience of life in post-war Britain depended on many aspects, including race, gender and class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5401-5
  a curric:KeyLearningPoint ;
  rdfs:label """A good assessment of post-war Britain will make a balanced case for its status as a 'New Jerusalem'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5400-1
  a curric:KeyLearningPoint ;
  rdfs:label """Labour shortages after WW2 were a significant problem for Britain, who needed migrant workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5400-2
  a curric:KeyLearningPoint ;
  rdfs:label """The British Nationality Act of 1948 made all Commonwealth subjects British citizens, able to work and settle in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5400-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1948 act and government encouragement led to c. 500 000 Caribbean people moving to Britain during the 1950s-1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5400-4
  a curric:KeyLearningPoint ;
  rdfs:label """This 'Windrush generation' made important contributions to public life in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5400-5
  a curric:KeyLearningPoint ;
  rdfs:label """Caribbean migrants in Britain experienced significant racism and discrimination in many aspects of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Six million Jews from many different backgrounds were murdered during the Holocaust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5388-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many people acted as perpetrators during the Holocaust."@en ;
  dcterms:modified "2026-02-12T08:59:21.648483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5388-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many more people knew about the Holocaust but did not intervene."@en ;
  dcterms:modified "2026-02-12T08:59:21.648490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5388-4
  a curric:KeyLearningPoint ;
  rdfs:label "There were Holocaust perpetrators and collaborators across Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.648495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5373-1
  a curric:KeyLearningPoint ;
  rdfs:label "Russia in the early 20th century was governed by an absolutist tsar."@en ;
  dcterms:modified "2026-02-12T08:59:21.648973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5373-2
  a curric:KeyLearningPoint ;
  rdfs:label """Russian society was largely rural with 85% of Russians living in the countryside."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Russian society was unequal. The aristocracy and middle classes had far greater wealth than peasants and workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fighting was going badly on the Eastern Front, causing high levels of poverty in Russia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5373-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strikes and riots broke out in early 1917, forcing the Tsar to abdicate and go into exile."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5369-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fighting took place throughout European colonies in Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.648997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colonial troops from across Britain's empire took part in fighting."@en ;
  dcterms:modified "2026-02-12T08:59:21.649002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5369-3
  a curric:KeyLearningPoint ;
  rdfs:label "The war in the colonies explains why 1914-1918 is called a world war."@en ;
  dcterms:modified "2026-02-12T08:59:21.649006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5360-1
  a curric:KeyLearningPoint ;
  rdfs:label """The franchise had been expanded in the nineteenth century but did not include women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5360-2
  a curric:KeyLearningPoint ;
  rdfs:label """Women had secured some legal rights, such as the 1882 Married Women's Property Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5360-3
  a curric:KeyLearningPoint ;
  rdfs:label """Women had contributed to political movements throughout the nineteenth century, including abolition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5383-1
  a curric:KeyLearningPoint ;
  rdfs:label """In August 1945 the USA dropped two atomic bombs on Japan, leading to the end of the Second World War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5383-2
  a curric:KeyLearningPoint ;
  rdfs:label """The tide of WW2 began to turn with the Battle of Britain, Nazi Germany's invasion of the USSR and the USA's entrance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5383-3
  a curric:KeyLearningPoint ;
  rdfs:label """As the Nazis were forced back in the USSR, the D-Day landings and the use of atomic bombs led to the war's end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5383-4
  a curric:KeyLearningPoint ;
  rdfs:label "A good narrative will describe the events of WW2 in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.650651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5383-5
  a curric:KeyLearningPoint ;
  rdfs:label """A good narrative will identify and describe turning points leading to the end of WW2, explaining their role."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5394-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1930s saw unrest in Britain's Caribbean colonies, including strikes and riots over living and working conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5394-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Moyne Report recognised these conditions, recommending political and economic reforms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5394-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1944, a new constitution was made for Jamaica which gave the country greater autonomy and self government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Britain unsuccessfully attempted to unite its Caribbean colonies into the West Indian Federation (1958-62)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5394-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1962, Jamaica and Trinidad and Tobago were granted independence from Britain, with many states following suit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5365-1
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the growth in female political participation, sexist attitudes prevailed by the late 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5365-2
  a curric:KeyLearningPoint ;
  rdfs:label """Early suffrage campaigns led to a Conciliation Bill; this wasn't passed due to Liberal fears about how women would vote."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5365-3
  a curric:KeyLearningPoint ;
  rdfs:label """WSPU tactics split the suffrage movement and hurt women's chances of getting the vote as government attitudes hardened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5365-4
  a curric:KeyLearningPoint ;
  rdfs:label """WW1 was a turning point in the campaign for women's suffrage due to their war work and the need for a new franchise act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5365-5
  a curric:KeyLearningPoint ;
  rdfs:label """A good explanation of why it took so long for women to get the vote in Britain will examine long and short term factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5270-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth succeeded her sister Mary I to the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.652907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5270-2
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth had foreign suitors in marriage such as Philip II of Spain ."@en ;
  dcterms:modified "2026-02-12T08:59:21.652912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5270-3
  a curric:KeyLearningPoint ;
  rdfs:label "There were rumours of Elizabeth loving the Earl of Leicester."@en ;
  dcterms:modified "2026-02-12T08:59:21.652916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5270-4
  a curric:KeyLearningPoint ;
  rdfs:label """By 1580 Elizabeth used propaganda to present herself as the 'Virgin Queen' after rejecting all suitors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's successor was the Scottish king James VI of Scotland and I of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5396-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of WW2, Britain was in a desperate state, an election was called, leading to a landslide Labour victory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5396-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Labour leader, Clement Attlee, signalled the government's desire to make post-war Britain a 'New Jerusalem'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5396-3
  a curric:KeyLearningPoint ;
  rdfs:label "After WW2, many British people wanted aspects of state control to remain."@en ;
  dcterms:modified "2026-02-12T08:59:21.656731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5396-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Labour government aimed to implement recommendations from the Beveridge Report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5396-5
  a curric:KeyLearningPoint ;
  rdfs:label """Beveridge argued that the state had a duty to provide protection to people from "cradle to grave"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5348-1
  a curric:KeyLearningPoint ;
  rdfs:label "The British Empire was very large and ruled over a diverse mix of people."@en ;
  dcterms:modified "2026-02-12T08:59:21.657059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5348-2
  a curric:KeyLearningPoint ;
  rdfs:label "Charles Darwin developed the theory of natural selection and evolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.657064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Social Darwinism adapted Darwin's theories to claim that some groups of humans were superior to others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5348-4
  a curric:KeyLearningPoint ;
  rdfs:label "Social Darwinism was used to justify imperialism."@en ;
  dcterms:modified "2026-02-12T08:59:21.657074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5348-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many ideas were used to justify British imperialism, such as the desire to spread Christianity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5364-1
  a curric:KeyLearningPoint ;
  rdfs:label "War broke out in Europe in 1914, causing the suffrage campaign to be suspended."@en ;
  dcterms:modified "2026-02-12T08:59:21.657101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Women entered the workforce in unprecedented numbers during the war to replace men who had gone to fight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5364-3
  a curric:KeyLearningPoint ;
  rdfs:label """Women's contributions to the war effort strengthened the campaign for women's suffrage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5364-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1918 Representation of the People Act gave the vote to all men and married women aged over 30."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5364-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1928, the Equal Franchise Act gave votes to everyone aged 21 or older, including women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5390-1
  a curric:KeyLearningPoint ;
  rdfs:label """Prior to WW1, the Home Rule movement gathered momentum in Ireland and looked likely to become reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5390-2
  a curric:KeyLearningPoint ;
  rdfs:label """With the onset of war, these plans were delayed and Irish nationalists staged a rebellion against British rule in 1916."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5390-3
  a curric:KeyLearningPoint ;
  rdfs:label """Britain violently crushed the rebellion and war broke out between the IRA and the British Blacks and Tans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5390-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1921, the Anglo-Irish Treaty partitioned Ireland into Northern Ireland and the Irish Free State."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5390-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 1949, the Irish Free State became the Republic of Ireland, completely separate from the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5386-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Nazis believed Jews were 'inferior' and enemies of Germany."@en ;
  dcterms:modified "2026-02-12T08:59:21.657969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5386-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Nazis subjected German Jews to persecution from 1933 onwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.657973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5386-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Nazis wanted to exclude the Jews from German society."@en ;
  dcterms:modified "2026-02-12T08:59:21.657978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5386-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nazi persecution became more violent in 1938, including during Kristallnacht."@en ;
  dcterms:modified "2026-02-12T08:59:21.657983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5386-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some Jews emigrated to escape Nazi persecution."@en ;
  dcterms:modified "2026-02-12T08:59:21.657987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27890-1
  a curric:KeyLearningPoint ;
  rdfs:label "A major uprising occurred in the Warsaw Ghetto in 1943."@en ;
  dcterms:modified "2026-02-12T08:59:21.660375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27890-2
  a curric:KeyLearningPoint ;
  rdfs:label "After the Warsaw Ghetto Uprising was defeated, most survivors were murdered."@en ;
  dcterms:modified "2026-02-12T08:59:21.660380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27890-3
  a curric:KeyLearningPoint ;
  rdfs:label "Leaders in the Lodz Ghetto chose to comply with German orders."@en ;
  dcterms:modified "2026-02-12T08:59:21.660385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27890-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many Jews faced 'choiceless choices' during the Holocaust."@en ;
  dcterms:modified "2026-02-12T08:59:21.660389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27890-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Choiceless choices' gave Jews little real control over whether they survived or not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5323-1
  a curric:KeyLearningPoint ;
  rdfs:label "After the French Revolution, a republic was created in France."@en ;
  dcterms:modified "2026-02-12T08:59:21.661304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5323-2
  a curric:KeyLearningPoint ;
  rdfs:label """European monarchs feared that the events of France could take place in their countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5323-3
  a curric:KeyLearningPoint ;
  rdfs:label "European monarchs waged war with the new French republic."@en ;
  dcterms:modified "2026-02-12T08:59:21.661314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5323-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ideas of liberty and criticism of absolutist governments spread across the Atlantic to Haiti."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5323-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other areas across the Atlantic rose up in revolution, inspired by ideas of liberty and freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5320-1
  a curric:KeyLearningPoint ;
  rdfs:label """Enlightenment ideas around observation, experience and experiment helped pave the way for greater scientific thought."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5320-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Enlightened thinkers believed that governments should work for the benefit of the people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5320-3
  a curric:KeyLearningPoint ;
  rdfs:label """More people believed in the idea that people should be able to hold their governments to account."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5320-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some Enlightened thinkers began to question ideas of monopolies and trade, arguing they should benefit all, not a few."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5320-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some Enlightened thinkers developed racist ideas of European superiority and African inferiority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5405-1
  a curric:KeyLearningPoint ;
  rdfs:label """By 1900, many women believed the ability to vote was essential to further improve the lives of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5405-2
  a curric:KeyLearningPoint ;
  rdfs:label """Suffragists and suffragettes campaigned for the franchise for women using very different tactics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5405-3
  a curric:KeyLearningPoint ;
  rdfs:label """Women's contribution during the First World War helped women win the franchise in 1918."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5405-4
  a curric:KeyLearningPoint ;
  rdfs:label """Winning the franchise did not immediately lead to a radical transformation in the status and position of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5405-5
  a curric:KeyLearningPoint ;
  rdfs:label """Young women in urban areas began to challenge traditional social expectations for women during the 1920s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5407-1
  a curric:KeyLearningPoint ;
  rdfs:label "Women in British society have often existed within patriarchal structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.663110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5407-2
  a curric:KeyLearningPoint ;
  rdfs:label """There was significant continuity in the role of women between the medieval and early modern period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5407-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution had a significant impact on the role of women including on the work they did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5407-4
  a curric:KeyLearningPoint ;
  rdfs:label """Women winning the right to vote in 1918 had a dramatic impact on the role of women in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5407-5
  a curric:KeyLearningPoint ;
  rdfs:label """The availability of the contraceptive pill from 1961 had a significant impact on the role of women in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5406-1
  a curric:KeyLearningPoint ;
  rdfs:label """After World War 2, the British economy recovered and there was an increase in the number of women in paid employment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5406-2
  a curric:KeyLearningPoint ;
  rdfs:label """During the 1950s, most people continued to believe that a woman's role should be focused on the home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Women campaigned for equality with men and these campaigns gathered momentum during the 1960s and 1970s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5406-4
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigns to end discrimination against women in the workplace were only partially successful and progress was slow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5406-5
  a curric:KeyLearningPoint ;
  rdfs:label """The contraceptive pill and the legalisation of abortion meant women had more control over if and when they had children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5403-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Reformation did not have a significant impact on attitudes towards women."@en ;
  dcterms:modified "2026-02-12T08:59:21.663894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Early modern Britain remained a patriarchal society."@en ;
  dcterms:modified "2026-02-12T08:59:21.663898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Work for the majority of women centred on the home and was combined with childcare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5403-4
  a curric:KeyLearningPoint ;
  rdfs:label """Opportunities for women to receive an education were limited and linked to social class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5403-5
  a curric:KeyLearningPoint ;
  rdfs:label "Husbands in the early modern period had a huge amount of power over their wives."@en ;
  dcterms:modified "2026-02-12T08:59:21.663912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5319-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 16th century Scientific Revolution caused people to question the authority of the establishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5319-2
  a curric:KeyLearningPoint ;
  rdfs:label """Immanuel Kant tried explaining the concept of 'enlightenment' in 1784 which gave a name to the movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5319-3
  a curric:KeyLearningPoint ;
  rdfs:label """Kant argued people should use reason and logic to reach conclusions about right and wrong, not follow rules blindly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5319-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Enlightenment challenged the established authority of monarchy and the Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5319-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Enlightenment's calls for equality often did not extend beyond white Europeans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Changes to the way people worked during the Industrial Revolution created new opportunities and challenges for women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5404-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the 19th century, married women were expected to stay home to raise children and look after their husbands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5404-3
  a curric:KeyLearningPoint ;
  rdfs:label """Legislation was passed during the 19th century that limited working opportunities for women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5404-4
  a curric:KeyLearningPoint ;
  rdfs:label """By the end of the 19th century, there was a divide between work considered suitable for men and for women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5404-5
  a curric:KeyLearningPoint ;
  rdfs:label """The growth of professions like nursing and teaching created new opportunities for some women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had been fighting a war against Napoleon since 1793 - the aftermath of the execution of Louis XVI of France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5334-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many Britons believed their fight was for freedom against tyranny; enslavement was seen as tyranny not freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5334-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other Britons drew comparisons between poor working conditions at home and the plight of enslaved people on plantations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1807 Slave Trade Act banned the buying, selling and transportation of enslaved humans throughout the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5334-5
  a curric:KeyLearningPoint ;
  rdfs:label """The British Navy then enforced abolition, policing the Atlantic and capturing slave ships, freeing those held on board."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5344-1
  a curric:KeyLearningPoint ;
  rdfs:label "The population of Britain more than doubled between 1750 and 1841."@en ;
  dcterms:modified "2026-02-12T08:59:21.705720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many people moved from the countryside to industrial towns like Birmingham, Manchester and Glasgow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5344-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many people in industrial towns lived in poor conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.705729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5344-4
  a curric:KeyLearningPoint ;
  rdfs:label "Working conditions in factories were dangerous and unpleasant."@en ;
  dcterms:modified "2026-02-12T08:59:21.705734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5344-5
  a curric:KeyLearningPoint ;
  rdfs:label "Cotton mills commonly employed chiildren as workers."@en ;
  dcterms:modified "2026-02-12T08:59:21.705740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5245-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some historians argue that the Peasants’ Revolt was caused by class conflict between the lords and the peasants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5245-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence for class conflict includes the burning of court rolls by rebels, which recorded their feudal obligations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5245-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other historians argue that class conflict over feudalism was not the cause as feudalism was already in decline."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instead these historians argue that the Peasants' Revolt was against taxation and growing government power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5379-1
  a curric:KeyLearningPoint ;
  rdfs:label """Germany deployed a tactic known as Blitzkrieg to rapidly defeat and conquer other European nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5379-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Netherlands, Belgium, France and Luxembourg had all surrendered to the Nazis by 1940."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5379-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to conquer Britain, Nazi Germany planned to defeat the RAF before a seaborne invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5379-4
  a curric:KeyLearningPoint ;
  rdfs:label """This led to the Battle of Britain in which the RAF repulsed the Luftwaffe, preventing invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5379-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although Nazi Germany then carried out the Blitz, they gave up on their plans to invade Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5330-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French colony of Saint-Domingue's economy was based on enslaved people working on plantations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5330-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most of the people on Saint-Domingue were enslaved people, but the population was diverse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5330-3
  a curric:KeyLearningPoint ;
  rdfs:label """French revolutionary ideas of equality and liberty caused a growth in abolitionist feeling among the colony's people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5330-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1791, a slave revolt broke out on the island, assisted by so-called 'free blacks' and indigenous people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5330-5
  a curric:KeyLearningPoint ;
  rdfs:label "Toussaint L'Ouverture emerged as the leader of the Haitian Revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.707707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5332-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1801, Saint-Domingue's governor L'Ouverture issued a new constitution demanding their total independence from France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5332-2
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon Bonaparte, having seized power in France, wanted to re-establish French control over Saint-Domingue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5332-3
  a curric:KeyLearningPoint ;
  rdfs:label """French troops betrayed a truce and captured L'Ouverture, reinstating slavery wherever they had control on the island."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5332-4
  a curric:KeyLearningPoint ;
  rdfs:label """The fight continued and, with the help of Napoleon's Polish troops who switched sides, the rebels drove the French out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5332-5
  a curric:KeyLearningPoint ;
  rdfs:label "In 1804, Saint-Domingue was proclaimed a free country and renamed Haiti."@en ;
  dcterms:modified "2026-02-12T08:59:21.708561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5335-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Haitian Revolution was a successful slave revolt and Britain feared this would inspire more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5335-2
  a curric:KeyLearningPoint ;
  rdfs:label """Britain’s attempt to reinstate slavery in Haiti strengthened abolitionism, resulting in the 1807 Slave Trade Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5335-3
  a curric:KeyLearningPoint ;
  rdfs:label """France initially opposed the Haitian Revolution, but being unable to put it down, abolished slavery in 1794."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5335-4
  a curric:KeyLearningPoint ;
  rdfs:label """Economic problems in France led to Napoleon trying (and failing) to recapture the colony and restore slavery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5335-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Haitian Revolution contributed to the end of slavery in Britain and France, but hardened US attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5333-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1772 it was established that slavery went against English law and many people felt uneasy about Britain's role in it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5333-2
  a curric:KeyLearningPoint ;
  rdfs:label """People in Britain began to criticise the conditions on slave ships across the 'Middle Passage' to the Americas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The case of the Zong Massacre created public outrage in Britain at the conditions in which enslaved people were living."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5333-4
  a curric:KeyLearningPoint ;
  rdfs:label """Groups and individuals such as Olaudah Equiano and William Wilberforce worked for abolition in Britain and its colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5333-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Haitian Revolution created fear amongst British plantation owners about similar uprisings across the Caribbean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5331-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1791, a slave revolt erupted in the French colony of Saint-Domingue and Toussaint L'Ouverture became its leader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5331-2
  a curric:KeyLearningPoint ;
  rdfs:label """L'Ouverture aimed to emancipate all people on the island, including in the island's Spanish-controlled territory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5331-3
  a curric:KeyLearningPoint ;
  rdfs:label """L'Ouverture organised the rebels into a formidable army. Britain, worried Caribbean slave revolts would spread, invaded."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5331-4
  a curric:KeyLearningPoint ;
  rdfs:label """Britain tried to restore slavery there so France promised L'Ouverture's soldiers freedom if they helped defeat Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5331-5
  a curric:KeyLearningPoint ;
  rdfs:label """Britain's defeat saw France allow L'Ouverture to rule as governor of Saint-Domingue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5231-1
  a curric:KeyLearningPoint ;
  rdfs:label """Women in medieval Norwich were involved in a wide range of trades and industries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5231-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some women in Norwich entered religious communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.716575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5231-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some women in Norwich enjoyed high levels of literacy, including Julian of Norwich."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5231-4
  a curric:KeyLearningPoint ;
  rdfs:label "Women faced many barriers such as restricted opportunities and male jealousy."@en ;
  dcterms:modified "2026-02-12T08:59:21.716584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5231-5
  a curric:KeyLearningPoint ;
  rdfs:label "Women's experiences were affected by their class."@en ;
  dcterms:modified "2026-02-12T08:59:21.716588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5389-1
  a curric:KeyLearningPoint ;
  rdfs:label "Violent and nonviolent methods were used by Jews to resist the Holocaust."@en ;
  dcterms:modified "2026-02-12T08:59:21.719477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Jews from a wide range of backgrounds were engaged in resistance."@en ;
  dcterms:modified "2026-02-12T08:59:21.719484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5389-3
  a curric:KeyLearningPoint ;
  rdfs:label "Violent resistance included uprisings and partisan actions."@en ;
  dcterms:modified "2026-02-12T08:59:21.719488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5389-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nonviolent resistance included acts like smuggling."@en ;
  dcterms:modified "2026-02-12T08:59:21.719493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5389-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many obstacles discouraged or limited the effectiveness of Jewish resistance."@en ;
  dcterms:modified "2026-02-12T08:59:21.719499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5356-1
  a curric:KeyLearningPoint ;
  rdfs:label """By the early 20th century, Germany and the USA had overtaken Britain as dominant global powers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5356-2
  a curric:KeyLearningPoint ;
  rdfs:label """The British government created the 'two-power standard' in 1889 to maintain British naval supremacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anxiety around the decline of Britain's empire led to a movement called 'national efficiency'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5356-4
  a curric:KeyLearningPoint ;
  rdfs:label "By the end of the First World War Britain's power was severely weakened."@en ;
  dcterms:modified "2026-02-12T08:59:21.723547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5352-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain's African colonies were mostly confined to coastal areas in the early 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5352-2
  a curric:KeyLearningPoint ;
  rdfs:label "Trade was a key British interest in Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.723556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5352-3
  a curric:KeyLearningPoint ;
  rdfs:label """British colonisation in Africa was limited by resistance, disease and the unwillingness of some officials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5352-4
  a curric:KeyLearningPoint ;
  rdfs:label "Britain's empire in Africa grew significantly during the Scramble for Africa."@en ;
  dcterms:modified "2026-02-12T08:59:21.723565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rivalry with other European empires was a key motive for British colonisation during the Scramble for Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5375-1
  a curric:KeyLearningPoint ;
  rdfs:label "There was a civil war in Russia between 1918 and 1921."@en ;
  dcterms:modified "2026-02-12T08:59:21.725910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5375-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Russian Civil War mainly involved fighting between the Reds and the Whites."@en ;
  dcterms:modified "2026-02-12T08:59:21.725914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other groups such as national minorities (the Greens) and foreign powers also fought the Reds in the Russian Civil War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5375-4
  a curric:KeyLearningPoint ;
  rdfs:label """Methods such as War Communism and the Red Terror helped the Reds to win the Civil War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5375-5
  a curric:KeyLearningPoint ;
  rdfs:label "War Communism and the Red Terror led to the deaths of many ordinary Russians."@en ;
  dcterms:modified "2026-02-12T08:59:21.725930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5230-1
  a curric:KeyLearningPoint ;
  rdfs:label "The wool trade became important for Norwich in the later medieval period."@en ;
  dcterms:modified "2026-02-12T08:59:21.726755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5230-2
  a curric:KeyLearningPoint ;
  rdfs:label "Herring and other goods had been important items of trade earlier on."@en ;
  dcterms:modified "2026-02-12T08:59:21.726760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5230-3
  a curric:KeyLearningPoint ;
  rdfs:label "Norwich was an important centre of trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.726764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5230-4
  a curric:KeyLearningPoint ;
  rdfs:label "Goods were often sent to Europe from the coastal towns."@en ;
  dcterms:modified "2026-02-12T08:59:21.726768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5230-5
  a curric:KeyLearningPoint ;
  rdfs:label """Textile merchants invested some of their wealth in constructing new buildings around Norwich."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5241-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death killed around half of the English population."@en ;
  dcterms:modified "2026-02-12T08:59:21.726780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5241-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Black Death caused labour shortages."@en ;
  dcterms:modified "2026-02-12T08:59:21.726784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5241-3
  a curric:KeyLearningPoint ;
  rdfs:label "Labourers began to demand better pay for their work."@en ;
  dcterms:modified "2026-02-12T08:59:21.726788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5241-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Statute of Labourers ordered labourers to stop asking for more money."@en ;
  dcterms:modified "2026-02-12T08:59:21.726793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5241-5
  a curric:KeyLearningPoint ;
  rdfs:label "Historians disagree about the aims of the Statute of Labourers."@en ;
  dcterms:modified "2026-02-12T08:59:21.726797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5355-1
  a curric:KeyLearningPoint ;
  rdfs:label """British dominance was challenged towards the end of the 19th century by the rise of Germany and the USA."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5355-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Imperial anxiety' was caused by international competition and nationalist movements in the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Queen Victoria's Diamond Jubilee celebration in 1897 was designed to celebrate the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5372-1
  a curric:KeyLearningPoint ;
  rdfs:label "The philosopher Karl Marx developed an influential theory about communism."@en ;
  dcterms:modified "2026-02-12T08:59:21.728493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5372-2
  a curric:KeyLearningPoint ;
  rdfs:label """Marx concluded that the working classes were exploited by those who owned property."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5372-3
  a curric:KeyLearningPoint ;
  rdfs:label """Marx described the workers as the proletariat and the property-owners as the bourgeoisie."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5372-4
  a curric:KeyLearningPoint ;
  rdfs:label "Marx envisioned this class conflict would end in revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.728508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5372-5
  a curric:KeyLearningPoint ;
  rdfs:label """Marxist thought inspired socialist movements throughout the world, including in Russia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5377-1
  a curric:KeyLearningPoint ;
  rdfs:label """In February 1917, tsarist rule in Russia came to an end and in October 1917, Communist Party rule began."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Communist Party policies introduced by Stalin modernised agriculture and industry in the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5377-3
  a curric:KeyLearningPoint ;
  rdfs:label "Russian tsars and the Communist Party both ruled Russia with absolute power."@en ;
  dcterms:modified "2026-02-12T08:59:21.728529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5377-4
  a curric:KeyLearningPoint ;
  rdfs:label """Communist Party rule significantly reduced wealth inequality but created new types of inequality in the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5228-1
  a curric:KeyLearningPoint ;
  rdfs:label "A 1404 charter granted Norwich a mayor."@en ;
  dcterms:modified "2026-02-12T08:59:21.728648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5228-2
  a curric:KeyLearningPoint ;
  rdfs:label "The elite had almost exclusive control over government in Norwich."@en ;
  dcterms:modified "2026-02-12T08:59:21.728680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5228-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Norwich elite was mostly made up of wealthy merchants."@en ;
  dcterms:modified "2026-02-12T08:59:21.728686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5228-4
  a curric:KeyLearningPoint ;
  rdfs:label "The elite used architecture and donations to show off their status."@en ;
  dcterms:modified "2026-02-12T08:59:21.728692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5229-1
  a curric:KeyLearningPoint ;
  rdfs:label "Norwich was home to many religious houses."@en ;
  dcterms:modified "2026-02-12T08:59:21.728854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5229-2
  a curric:KeyLearningPoint ;
  rdfs:label "Norwich Cathedral was the most prominent religious community in Norwich."@en ;
  dcterms:modified "2026-02-12T08:59:21.728858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5229-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Cathedral was wealthier than any other group in Norwich."@en ;
  dcterms:modified "2026-02-12T08:59:21.728863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5229-4
  a curric:KeyLearningPoint ;
  rdfs:label "Churchmen provided a range of social services including charity and education."@en ;
  dcterms:modified "2026-02-12T08:59:21.728867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5229-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other religious houses like the Blackfriars were more popular than the monks at the Cathedral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5244-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Peasants' Revolt began in June 1381 when residents of a town in Essex refused to pay the poll tax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5244-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wat Tyler, a low-born labourer from Essex, became the leader of the revolt."@en ;
  dcterms:modified "2026-02-12T08:59:21.730454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5244-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rebels committed acts of violence against the king’s tax collectors and the king’s advisors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5244-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Peasants' Revolt was a failure for the peasants but strengthened the position of Richard II."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5244-5
  a curric:KeyLearningPoint ;
  rdfs:label "Historians do not agree on the causes of the Peasants' Revolt."@en ;
  dcterms:modified "2026-02-12T08:59:21.730485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5255-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edward’s second reign was much more peaceful and England prospered."@en ;
  dcterms:modified "2026-02-12T08:59:21.730944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5255-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lawlessness and conflict among the nobility subsided and Elizabeth Woodville was accepted as queen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5255-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edward set up councils to rule lawless areas in the Welsh Marches and the North."@en ;
  dcterms:modified "2026-02-12T08:59:21.730955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5255-4
  a curric:KeyLearningPoint ;
  rdfs:label """The wool trade boomed and Edward forced the king of France to pay him money when he threatened invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5255-5
  a curric:KeyLearningPoint ;
  rdfs:label """Edward’s second reign saw stability because he kept order and with Henry VI dead, he had the support of the nobility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9787-1
  a curric:KeyLearningPoint ;
  rdfs:label """The South Sea Company was a prominent joint-stock company in the early 18th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9787-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many British people had been persuaded to invest their money in the Company."@en ;
  dcterms:modified "2026-02-12T08:59:21.731700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9787-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Company collapsed, provoking a major political crisis."@en ;
  dcterms:modified "2026-02-12T08:59:21.731704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9787-4
  a curric:KeyLearningPoint ;
  rdfs:label """Robert Walpole managed the crisis and emerged as the nation's first Prime Minister."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9787-5
  a curric:KeyLearningPoint ;
  rdfs:label "Walpole formalised the system of cabinet governance."@en ;
  dcterms:modified "2026-02-12T08:59:21.731712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Now that America had ended its policy of isolationism, it was committed to fighting Japan and her ally, Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5382-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Japanese occupied most of southeast Asia, their brutal conduct was influenced by a military code."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5382-3
  a curric:KeyLearningPoint ;
  rdfs:label """The daring amphibious D-Day landings took place in June 1944, meaning Nazi Germany was now fighting on two fronts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5382-4
  a curric:KeyLearningPoint ;
  rdfs:label """The landings were a major turning point in the war as they hastened Germany's surrender in May 1945."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5382-5
  a curric:KeyLearningPoint ;
  rdfs:label """Germany surrendered after being surrounded by the Allied armies from the west and the Soviet forces from the east."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5363-1
  a curric:KeyLearningPoint ;
  rdfs:label """WSPU protestors began undertaking publicity stunts, such as chaining themselves to railings outside parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5363-2
  a curric:KeyLearningPoint ;
  rdfs:label """From 1908 some women in prison began going on hunger strike, and they were force fed by the government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5363-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1913 the government passed a law that released female prisoners on hunger strike, dubbed the Cat and Mouse Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Emily Davison threw herself in front of the King's horse in 1913 and died a few days later."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5363-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Liberal government refused to concede to the violent and disruptive tactics of the suffragettes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8198-1
  a curric:KeyLearningPoint ;
  rdfs:label "Baghdad was in decline by the 11th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.735818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8198-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Abbasids remained the nominal rulers of much of the Middle East."@en ;
  dcterms:modified "2026-02-12T08:59:21.735824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8198-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power over government really lay with groups like the Seljuks."@en ;
  dcterms:modified "2026-02-12T08:59:21.735828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8198-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Islamic world was more fragmented that it superficially appeared."@en ;
  dcterms:modified "2026-02-12T08:59:21.735832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9788-1
  a curric:KeyLearningPoint ;
  rdfs:label "The franchise remained limited after the 1832 Great Reform Act."@en ;
  dcterms:modified "2026-02-12T08:59:21.737910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9788-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reform Acts in 1867 and 1884 expanded the franchise."@en ;
  dcterms:modified "2026-02-12T08:59:21.737914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9788-3
  a curric:KeyLearningPoint ;
  rdfs:label "Working class voters were enfranchised for the first time in 1867."@en ;
  dcterms:modified "2026-02-12T08:59:21.737917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9788-4
  a curric:KeyLearningPoint ;
  rdfs:label "Property qualifications continued to disenfranchise the poorest voters."@en ;
  dcterms:modified "2026-02-12T08:59:21.737921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9788-5
  a curric:KeyLearningPoint ;
  rdfs:label "Women remained disenfranchised throughout the 19th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.737925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5233-1
  a curric:KeyLearningPoint ;
  rdfs:label "Life was different for men and for women in medieval Norwich."@en ;
  dcterms:modified "2026-02-12T08:59:21.738123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5233-2
  a curric:KeyLearningPoint ;
  rdfs:label "Life was different for elites and for the poor in medieval Norwich."@en ;
  dcterms:modified "2026-02-12T08:59:21.738127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5233-3
  a curric:KeyLearningPoint ;
  rdfs:label "Historians are interested in similarity and difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.738131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5233-4
  a curric:KeyLearningPoint ;
  rdfs:label """Historians study the extent of similarity and difference between groups' experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5370-1
  a curric:KeyLearningPoint ;
  rdfs:label "WWI had a significant impact on life in Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.738285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5370-2
  a curric:KeyLearningPoint ;
  rdfs:label """The government took control of key industries such as railways, shipping and coal mining."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5370-3
  a curric:KeyLearningPoint ;
  rdfs:label """Large numbers of men in Britain volunteered to fight in the war before conscription was introduced in 1916."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5370-4
  a curric:KeyLearningPoint ;
  rdfs:label "Calls for Irish independence were delayed by the outbreak of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.738297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5370-5
  a curric:KeyLearningPoint ;
  rdfs:label """A large number of women entered the workforce to replace the men that had gone to fight in the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5368-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lord Kitchener quickly began to recruit more soldiers in Britain as he anticipated a long, drawn out war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5368-2
  a curric:KeyLearningPoint ;
  rdfs:label """The troops who volunteered to fight found themselves fighting a war of attrition from the trenches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5368-3
  a curric:KeyLearningPoint ;
  rdfs:label """The attempt to break the stalemate during the 1916 Battle of the Somme caused large loss of life for little gain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5368-4
  a curric:KeyLearningPoint ;
  rdfs:label """The British and French troops fought alongside the British Indian Army on the Western Front."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5368-5
  a curric:KeyLearningPoint ;
  rdfs:label "Over 1.5 million Indian troops fought for Britain in the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.738675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5358-1
  a curric:KeyLearningPoint ;
  rdfs:label """New historical perspectives on the British Empire have emerged in recent decades."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5358-2
  a curric:KeyLearningPoint ;
  rdfs:label """'New imperial history' emphasises the relationship between the metropole (Britain) and the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5358-3
  a curric:KeyLearningPoint ;
  rdfs:label """'New imperial history' explores how the colonies have shaped the metropole (Britain)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5358-4
  a curric:KeyLearningPoint ;
  rdfs:label """The end of the 20th century saw a trend of scholarship from non-British perspectives such as Said and Bhabha."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5358-5
  a curric:KeyLearningPoint ;
  rdfs:label """The significance of the impact of Britain on the colonies has also been debated by historians."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Agriculture in England before 1700 was not very productive."@en ;
  dcterms:modified "2026-02-12T08:59:21.742246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Farmers and landowners developed more profitable farming techniques during the 18th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5342-3
  a curric:KeyLearningPoint ;
  rdfs:label "The use of fertiliser and field drainage meant farmers could grow more crops."@en ;
  dcterms:modified "2026-02-12T08:59:21.742254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5342-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Agricultural Revolution increased food production, encouraged migration and increased profits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5354-1
  a curric:KeyLearningPoint ;
  rdfs:label """The use of gunboat diplomacy in the Don Pacifico Affair increased the British conviction in empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5354-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Exhibition was opened in 1851 to showcase the best of British design and manufacture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5354-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Exhibition showcased goods from Britain's colonies and the wider world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5354-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Great Exhibition aimed to demonstrate the importance of the Empire to British supremacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5353-1
  a curric:KeyLearningPoint ;
  rdfs:label """Historians can study the British Empire by focusing on its extent, governance, quality of life and justifications."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5353-2
  a curric:KeyLearningPoint ;
  rdfs:label "The British Empire grew significantly during the 19th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.743631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ideas such as Christianity and Social Darwinism were used to justify British imperialism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rebellions in India and Jamaica triggered changes in how those colonies were governed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hitler believed in perpetual struggle: nations that were hard-working would prosper, those that did not would fade away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5380-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1936, Hitler moved troops into the Rhineland, the response emboldened him to acquire more 'living space' for Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5380-3
  a curric:KeyLearningPoint ;
  rdfs:label "Countries like Britain followed a policy of appeasement with Hitler."@en ;
  dcterms:modified "2026-02-12T08:59:21.744512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5380-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hitler annexed Austria and Czechoslovakia, securing Germany’s eastern border."@en ;
  dcterms:modified "2026-02-12T08:59:21.744515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5380-5
  a curric:KeyLearningPoint ;
  rdfs:label """War broke out in 1939 when Hitler invaded Poland, whom Britain had promised to defend."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5242-1
  a curric:KeyLearningPoint ;
  rdfs:label """Peasants were a social group with no wealth or property rights under the feudal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5242-2
  a curric:KeyLearningPoint ;
  rdfs:label "The feudal system was showing signs of weakness before 1348."@en ;
  dcterms:modified "2026-02-12T08:59:21.744717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5242-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some historians argue lords reimposed feudalism after 1351."@en ;
  dcterms:modified "2026-02-12T08:59:21.744721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5242-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some historians argue lords were incapable of reimposing feudalism after 1351."@en ;
  dcterms:modified "2026-02-12T08:59:21.744725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5359-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspectives on British Empire have changed over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.746414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5359-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the 19th century, the Empire was celebrated in Britain and seen as a source of pride."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5359-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many contemporary historians view the impact of the British Empire negatively."@en ;
  dcterms:modified "2026-02-12T08:59:21.746422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many historians have revised interpretations of Empire to include the perspectives of the colonised."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5359-5
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of postcolonialism argues that the impacts of colonialism are still felt today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5350-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most of colonial Jamaica's population was Black."@en ;
  dcterms:modified "2026-02-12T08:59:21.747009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5350-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the early 1860s, Black Jamaicans suffered from widespread political and socioeconomic difficulties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5350-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1865, Black Jamaicans rebelled against British rule during the Morant Bay Rebellion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5350-4
  a curric:KeyLearningPoint ;
  rdfs:label "Jamaica became a Crown Colony after the Morant Bay Rebellion."@en ;
  dcterms:modified "2026-02-12T08:59:21.747025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5350-5
  a curric:KeyLearningPoint ;
  rdfs:label """No financial assistance was provided to combat poverty after the Morant Bay Rebellion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had emerged from the Second World War as a diminished power, reliant on America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5357-2
  a curric:KeyLearningPoint ;
  rdfs:label """After the Second World War, a wave of nationalist movements took place in the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5357-3
  a curric:KeyLearningPoint ;
  rdfs:label """India gained its independence from Britain in 1947 which led to the partition of India and Pakistan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5357-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1948, Palestine was partitioned into two separate independent states: Israel and Palestine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5357-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the 1960s, independence was granted to many of Britain's African and Caribbean colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5243-1
  a curric:KeyLearningPoint ;
  rdfs:label "Richer people tended to be able to escape the worst effects of the plague."@en ;
  dcterms:modified "2026-02-12T08:59:21.747203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5243-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1377,  the ten-year-old Richard became king. He was largely controlled by his uncle, John of Gaunt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5243-3
  a curric:KeyLearningPoint ;
  rdfs:label "Richard inherited a continuing war with France, the Hundred Years' War."@en ;
  dcterms:modified "2026-02-12T08:59:21.747211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5243-4
  a curric:KeyLearningPoint ;
  rdfs:label """A poll tax was introduced because kings needed money to continue the war against France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5243-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poll tax became even more unpopular when Richard II tripled the tax from 4 pence to 12 pence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5271-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabeth was known as the 'Supreme Governor of the Church of England'."@en ;
  dcterms:modified "2026-02-12T08:59:21.748050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5271-2
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth's religious settlement, the 'Middle Way', found a middle ground between Catholic and Protestant beliefs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5271-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 1570, Elizabeth was excommunicated giving Catholics a justification to act against her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5271-4
  a curric:KeyLearningPoint ;
  rdfs:label """Radical Protestants, known as Puritans, wanted more changes in the English Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5271-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth was able to defend her religious settlement from both Catholics and Protestants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5272-1
  a curric:KeyLearningPoint ;
  rdfs:label """Religious differences between the Catholic Mary and Presbytarian Scotland led to Mary having to flee the country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5272-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mary Queen of Scots, a Catholic, was seen by many as the rightful heir to Elizabeth's throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5272-3
  a curric:KeyLearningPoint ;
  rdfs:label "There were a number of plots to execute Elizabeth and replace her with Mary."@en ;
  dcterms:modified "2026-02-12T08:59:21.749361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5272-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mary had been imprisoned from when she arrived in England."@en ;
  dcterms:modified "2026-02-12T08:59:21.749366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5272-5
  a curric:KeyLearningPoint ;
  rdfs:label "Mary was executed in 1587 for her role in the Babington Plot."@en ;
  dcterms:modified "2026-02-12T08:59:21.749370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5376-1
  a curric:KeyLearningPoint ;
  rdfs:label "In 1922, the Soviet Union (USSR) was established as a single party dictatorship."@en ;
  dcterms:modified "2026-02-12T08:59:21.749980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stalin became leader of the USSR after Lenin's death. Stalin used the secret police to purge those who opposed him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5376-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stalin attempted to modernise the Soviet economy through collectivisation and rapid industrialisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Collectivisation increased the food supplies secured by the Soviet state but led to lower levels of agricultural output."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5376-5
  a curric:KeyLearningPoint ;
  rdfs:label """The USSR became the second largest industrial economy in the world but the quality of its output remained poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750000Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-5238
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe the consequences of Mansa Musa's pilgrimage."@en ;
  dcterms:modified "2026-02-12T08:59:24.444483Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5207
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how Matilda's actions affected the battles fought during the Anarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:24.444709Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5208
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how a study of Matilda's later life can lead to a greater understanding of the political role of medieval women."""@en ;
  dcterms:modified "2026-02-12T08:59:24.444771Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5216
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain why many consider John to be the model of a bad king."@en ;
  dcterms:modified "2026-02-12T08:59:24.444816Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5218
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain why Magna Carta was reissued."@en ;
  dcterms:modified "2026-02-12T08:59:24.444828Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5224
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how Edward I conquered and ruled Wales."@en ;
  dcterms:modified "2026-02-12T08:59:24.444832Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5220
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain the struggle between the king and the barons and the introduction of parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:24.444836Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5213
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe Henry II's conflict with Thomas Becket and explain the impacts this had on Church and crown."""@en ;
  dcterms:modified "2026-02-12T08:59:24.444848Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5221
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how Magna Carta survived."@en ;
  dcterms:modified "2026-02-12T08:59:24.444852Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5206
  a curric:PupilLessonOutcome ;
