# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-welfare-state
  a curric:Keyword ;
  schema:name "welfare state"@en ;
  schema:description """a system in which the government accepts responsibility for protecting people's quality of life"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789396Z"^^xsd:dateTime .

oakcurric:keyword-unsanitary
  a curric:Keyword ;
  schema:name "unsanitary"@en ;
  schema:description "dirty or unhealthy and therefore likely to cause disease"@en ;
  dcterms:modified "2026-02-12T08:59:15.789405Z"^^xsd:dateTime .

oakcurric:keyword-exile
  a curric:Keyword ;
  schema:name "exile"@en ;
  schema:description """being banned from living in your native country, usually for acting against those in charge"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789470Z"^^xsd:dateTime .

oakcurric:keyword-commonwealth
  a curric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oakcurric:keyword-boycott
  a curric:Keyword ;
  schema:name "boycott"@en ;
  schema:description "refusing to use a service as a form of protest"@en ;
  dcterms:modified "2026-02-12T08:59:15.789514Z"^^xsd:dateTime .

oakcurric:keyword-empire
  a curric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oakcurric:keyword-propaganda
  a curric:Keyword ;
  schema:name "Propaganda"@en ;
  schema:description """Propaganda is information, especially of a biased or misleading nature, used to promote a political cause or point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789531Z"^^xsd:dateTime .

oakcurric:keyword-censorship
  a curric:Keyword ;
  schema:name "Censorship"@en ;
  schema:description """The act of preventing something from being seen or made available to the public for political reasons is known as censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789536Z"^^xsd:dateTime .

oakcurric:keyword-autonomy
  a curric:Keyword ;
  schema:name "autonomy"@en ;
  schema:description """having the freedom and independence to make your own decisions without being controlled by others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789563Z"^^xsd:dateTime .

oakcurric:keyword-assimilate
  a curric:Keyword ;
  schema:name "assimilate"@en ;
  schema:description "to become part of a group, country, society or culture"@en ;
  dcterms:modified "2026-02-12T08:59:15.789748Z"^^xsd:dateTime .

oakcurric:keyword-colonial
  a curric:Keyword ;
  schema:name "colonial"@en ;
  schema:description """referring to colonialism, where a country establishes control over another country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789753Z"^^xsd:dateTime .

oakcurric:keyword-descendant
  a curric:Keyword ;
  schema:name "descendant"@en ;
  schema:description """a person who is related to you and who lives after you, such as your child or grandchild."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789947Z"^^xsd:dateTime .

oakcurric:keyword-government
  a curric:Keyword ;
  schema:name "government"@en ;
  schema:description "a government is a group of leaders who make laws and decisions for a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.790003Z"^^xsd:dateTime .

oakcurric:keyword-famine
  a curric:Keyword ;
  schema:name "famine"@en ;
  schema:description """a famine is a situation in which there is not enough food for a great number of people, causing illness and death, or a particular period when this happens"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790016Z"^^xsd:dateTime .

oakcurric:keyword-plot
  a curric:Keyword ;
  schema:name "plot"@en ;
  schema:description "what happens in the story"@en ;
  dcterms:modified "2026-02-12T08:59:15.790041Z"^^xsd:dateTime .

oakcurric:keyword-discrimination
  a curric:Keyword ;
  schema:name "discrimination"@en ;
  schema:description """discrimination is the unjust treatment of a person or group of people, usually on the grounds of a physical quality or belief"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790161Z"^^xsd:dateTime .

oakcurric:keyword-flattery
  a curric:Keyword ;
  schema:name "flattery"@en ;
  schema:description "when the writer flatters the recipient"@en ;
  dcterms:modified "2026-02-12T08:59:15.790221Z"^^xsd:dateTime .

oakcurric:keyword-pilgrimage
  a curric:Keyword ;
  schema:name "pilgrimage"@en ;
  schema:description "a pilgrimage is a holy journey"@en ;
  dcterms:modified "2026-02-12T08:59:15.790740Z"^^xsd:dateTime .

oakcurric:keyword-hajj
  a curric:Keyword ;
  schema:name "Hajj"@en ;
  schema:description "the Hajj is the Muslim pilgrimage to Mecca, one of the Five Pillars of Islam"@en ;
  dcterms:modified "2026-02-12T08:59:15.790746Z"^^xsd:dateTime .

oakcurric:keyword-manifesto
  a curric:Keyword ;
  schema:name "manifesto"@en ;
  schema:description """a clear statement of beliefs, goals, or intentions, often published publicly by a person, group, or organisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790750Z"^^xsd:dateTime .

oakcurric:keyword-feminist
  a curric:Keyword ;
  schema:name "feminist"@en ;
  schema:description """someone who believes in  and supports gender equality, advocating for the rights of all genders"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790758Z"^^xsd:dateTime .

oakcurric:keyword-illegitimate
  a curric:Keyword ;
  schema:name "Illegitimate"@en ;
  schema:description """refers to someone who was born without their parents being married; it is not a term we use very often today"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790860Z"^^xsd:dateTime .

oakcurric:keyword-reliable
  a curric:Keyword ;
  schema:name "reliable"@en ;
  schema:description """reliable data is data that would show the same result were it to be collected on a comparably similar occasion"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790938Z"^^xsd:dateTime .

oakcurric:keyword-colonisation
  a curric:Keyword ;
  schema:name "colonisation"@en ;
  schema:description """when a country establishes control over another country, exploiting it for economic gain"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790961Z"^^xsd:dateTime .

oakcurric:keyword-racism
  a curric:Keyword ;
  schema:name "racism"@en ;
  schema:description "discrimination and prejudice against people based on their race or ethnicity"@en ;
