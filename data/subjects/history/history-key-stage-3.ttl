oakcurric:priorknowledge-511-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that women have experienced unfair treatment in historical
  societies."""@en ;
  dcterms:modified "2026-06-07T15:29:23.407934Z"^^xsd:dateTime .

oakcurric:priorknowledge-511-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that the power of the throne was considered worth fighting for."@en ;
  dcterms:modified "2026-06-07T15:29:23.407949Z"^^xsd:dateTime .

oakcurric:priorknowledge-525-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that Europe was isolated from North America."@en ;
  dcterms:modified "2026-06-07T15:29:23.473473Z"^^xsd:dateTime .

oakcurric:priorknowledge-525-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that explorers would sail across seas, to discover new lands to trade
  with."""@en ;
  dcterms:modified "2026-06-07T15:29:23.473484Z"^^xsd:dateTime .

oakcurric:priorknowledge-525-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that indigenous populations existed in North America, unbeknown to
  Europeans."""@en ;
  dcterms:modified "2026-06-07T15:29:23.473490Z"^^xsd:dateTime .

oakcurric:priorknowledge-527-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that slavery is a form of forced labour without compensation."@en ;
  dcterms:modified "2026-06-07T15:29:23.506342Z"^^xsd:dateTime .

oakcurric:priorknowledge-527-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that enslaved people endured much suffering."@en ;
  dcterms:modified "2026-06-07T15:29:23.506357Z"^^xsd:dateTime .

oakcurric:priorknowledge-527-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that Europeans bought enslaved people in Africa."@en ;
  dcterms:modified "2026-06-07T15:29:23.506363Z"^^xsd:dateTime .

oakcurric:priorknowledge-524-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that there was a big difference between the lives of the rich and the
  poor in early modern societies."""@en ;
  dcterms:modified "2026-06-07T15:29:23.710147Z"^^xsd:dateTime .

oakcurric:priorknowledge-524-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that people feel that monarchs have a duty of care to their people."@en ;
  dcterms:modified "2026-06-07T15:29:23.710161Z"^^xsd:dateTime .

oakcurric:priorknowledge-521-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that the medieval Church exercised power in society."@en ;
  dcterms:modified "2026-06-07T15:29:23.731402Z"^^xsd:dateTime .

oakcurric:priorknowledge-521-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that the Pope was very powerful."@en ;
  dcterms:modified "2026-06-07T15:29:23.731419Z"^^xsd:dateTime .

oakcurric:priorknowledge-521-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that there were tensions between the power of the Church and the power
  of the king."""@en ;
  dcterms:modified "2026-06-07T15:29:23.731427Z"^^xsd:dateTime .

oakcurric:priorknowledge-521-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that Henry VIII had six wives."@en ;
  dcterms:modified "2026-06-07T15:29:23.731433Z"^^xsd:dateTime .

oakcurric:priorknowledge-526-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that England had always been ruled over by monarchs since the
  Anglo-Saxons."""@en ;
  dcterms:modified "2026-06-07T15:29:23.801978Z"^^xsd:dateTime .

oakcurric:priorknowledge-526-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that the king had lots of power."@en ;
  dcterms:modified "2026-06-07T15:29:23.802005Z"^^xsd:dateTime .

oakcurric:priorknowledge-526-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that kings were bound to work with Parliament."@en ;
  dcterms:modified "2026-06-07T15:29:23.802017Z"^^xsd:dateTime .

oakcurric:priorknowledge-526-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that the power of kings could be challenged."@en ;
  dcterms:modified "2026-06-07T15:29:23.802027Z"^^xsd:dateTime .

oakcurric:priorknowledge-530-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that access to trade routes brings wealth and power."@en ;
  dcterms:modified "2026-06-07T15:29:23.823347Z"^^xsd:dateTime .

oakcurric:priorknowledge-530-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that India was an important destination for international trade."@en ;
  dcterms:modified "2026-06-07T15:29:23.823362Z"^^xsd:dateTime .

oakcurric:priorknowledge-530-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that there was a demand for spices in Europe."@en ;
  dcterms:modified "2026-06-07T15:29:23.823369Z"^^xsd:dateTime .

oakcurric:priorknowledge-1078-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "That trade across Europe and Asia was a feature of the medieval world."@en ;
  dcterms:modified "2026-06-07T15:29:23.874714Z"^^xsd:dateTime .

oakcurric:priorknowledge-1078-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "That Islamic and Christian worlds had been in contact since late antiquity."@en ;
  dcterms:modified "2026-06-07T15:29:23.874726Z"^^xsd:dateTime .

oakcurric:priorknowledge-536-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that countries would colonise other countries in order to gain land,
  money and power."""@en ;
  dcterms:modified "2026-06-07T15:29:23.970030Z"^^xsd:dateTime .

oakcurric:priorknowledge-536-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that in the early modern and modern periods, many European nations
  competed to have the largest and most successful empires."""@en ;
  dcterms:modified "2026-06-07T15:29:23.970043Z"^^xsd:dateTime .

oakcurric:priorknowledge-522-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that female rulers have not always been viewed in the same way that male
  rulers have been."""@en ;
