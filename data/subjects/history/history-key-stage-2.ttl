# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-welfare-state
  a curric:Keyword ;
  schema:name "welfare state"@en ;
  schema:description """a system in which the government accepts responsibility for protecting people's quality of life"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789396Z"^^xsd:dateTime .

oakcurric:keyword-campaign
  a curric:Keyword ;
  schema:name "campaign"@en ;
  schema:description "a series of military operations, usually with the aim of defeating an enemy"@en ;
  dcterms:modified "2026-02-12T08:59:15.789466Z"^^xsd:dateTime .

oakcurric:keyword-empire
  a curric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-formidable
  a curric:Keyword ;
  schema:name "formidable"@en ;
  schema:description "causing fear or dread"@en ;
  dcterms:modified "2026-02-12T08:59:15.789757Z"^^xsd:dateTime .

oakcurric:keyword-enquiry
  a curric:Keyword ;
