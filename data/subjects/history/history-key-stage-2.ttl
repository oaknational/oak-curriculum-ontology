  schema:description "when an item is dated, the time period it was made in is identified"@en ;
  dcterms:modified "2026-02-12T08:59:15.817873Z"^^xsd:dateTime .

oakcurric:keyword-fortified
  a curric:Keyword ;
  schema:name "fortified"@en ;
  schema:description "made strong or secure"@en ;
  dcterms:modified "2026-02-12T08:59:15.821126Z"^^xsd:dateTime .

oakcurric:keyword-ornamental
  a curric:Keyword ;
  schema:name "ornamental"@en ;
  schema:description "something that is ornamental is used for decoration"@en ;
  dcterms:modified "2026-02-12T08:59:15.821676Z"^^xsd:dateTime .

oakcurric:keyword-taotie
  a curric:Keyword ;
  schema:name "taotie"@en ;
  schema:description """the taotie is a mythical animal-like creature that is often used as decoration on items"""@en ;
  dcterms:modified "2026-02-12T08:59:15.821680Z"^^xsd:dateTime .

oakcurric:keyword-mingqi
  a curric:Keyword ;
  schema:name "mingqi"@en ;
  schema:description """mingqi are jade figures of servants, which were buried in the tombs of the wealthy to serve them in the afterlife"""@en ;
  dcterms:modified "2026-02-12T08:59:15.821685Z"^^xsd:dateTime .

oakcurric:keyword-ce
  a curric:Keyword ;
  schema:name "CE"@en ;
  schema:description "CE stands for Common Era is the time from the year 1 onwards"@en ;
  dcterms:modified "2026-02-12T08:59:15.822573Z"^^xsd:dateTime .

oakcurric:keyword-founded
  a curric:Keyword ;
  schema:name "founded"@en ;
  schema:description "founded means the time when something was first started or created"@en ;
  dcterms:modified "2026-02-12T08:59:15.822577Z"^^xsd:dateTime .

oakcurric:keyword-byzantine-empire
  a curric:Keyword ;
  schema:name "Byzantine Empire"@en ;
  schema:description """the Byzantine Empire is the name given by historians to the eastern half of the Roman Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822590Z"^^xsd:dateTime .

oakcurric:keyword-luxury-goods
  a curric:Keyword ;
  schema:name "luxury goods"@en ;
  schema:description "objects that are expensive and not a necessity are described as luxury goods"@en ;
  dcterms:modified "2026-02-12T08:59:15.822614Z"^^xsd:dateTime .

oakcurric:keyword-minted
  a curric:Keyword ;
  schema:name "minted"@en ;
  schema:description "when coins are made they are said to be minted"@en ;
  dcterms:modified "2026-02-12T08:59:15.822618Z"^^xsd:dateTime .

oakcurric:keyword-dictator
  a curric:Keyword ;
  schema:name "dictator"@en ;
  schema:description "a dictator is a person with complete power and control over a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.822684Z"^^xsd:dateTime .

oakcurric:keyword-mesolithic-era
  a curric:Keyword ;
  schema:name "Mesolithic Era"@en ;
  schema:description "the Mesolithic Era was the middle period of the Stone Age"@en ;
  dcterms:modified "2026-02-12T08:59:15.822747Z"^^xsd:dateTime .

oakcurric:keyword-campsite
  a curric:Keyword ;
  schema:name "campsite"@en ;
  schema:description "a group of temporary shelters is called a campsite"@en ;
  dcterms:modified "2026-02-12T08:59:15.822751Z"^^xsd:dateTime .

oakcurric:keyword-la-tne
  a curric:Keyword ;
  schema:name "La Tène"@en ;
  schema:description """a popular later style of Celtic art which uses curves, swirls and leafy patterns is called La Tène"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822760Z"^^xsd:dateTime .

oakcurric:keyword-torc
  a curric:Keyword ;
  schema:name "torc"@en ;
  schema:description "a torc is a large solid ring worn around the neck"@en ;
  dcterms:modified "2026-02-12T08:59:15.822766Z"^^xsd:dateTime .

oakcurric:keyword-ding
  a curric:Keyword ;
  schema:name "ding"@en ;
  schema:description "a ding is an object that can hold food, used for ceremonies or for display"@en ;
  dcterms:modified "2026-02-12T08:59:15.822770Z"^^xsd:dateTime .

oakcurric:keyword-status
  a curric:Keyword ;
  schema:name "status"@en ;
  schema:description "a person's rank or importance compared to others is their status"@en ;
  dcterms:modified "2026-02-12T08:59:15.822775Z"^^xsd:dateTime .

oakcurric:keyword-beaker-people
  a curric:Keyword ;
  schema:name "Beaker people"@en ;
  schema:description """Beaker people were a group of people from Europe known for their clay pottery; they came to Britain during the Bronze Age"""@en ;
  dcterms:modified "2026-02-12T08:59:15.822809Z"^^xsd:dateTime .

oakcurric:keyword-metalwork
  a curric:Keyword ;
  schema:name "metalwork"@en ;
  schema:description "metalwork is the process of creating items from metal"@en ;
  dcterms:modified "2026-02-12T08:59:15.822813Z"^^xsd:dateTime .

oakcurric:keyword-pakistan
  a curric:Keyword ;
  schema:name "Pakistan"@en ;
  schema:description "Pakistan is a country in southern Asia that shares a border with India"@en ;
  dcterms:modified "2026-02-12T08:59:15.825028Z"^^xsd:dateTime .

oakcurric:keyword-sparta
  a curric:Keyword ;
  schema:name "Sparta"@en ;
  schema:description "Sparta was a militaristic city in the southern part of Ancient Greece"@en ;
  dcterms:modified "2026-02-12T08:59:15.825160Z"^^xsd:dateTime .

oakcurric:keyword-militaristic
  a curric:Keyword ;
  schema:name "militaristic"@en ;
  schema:description """a culture or society is described as militaristic when war and fighting are important to it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825166Z"^^xsd:dateTime .

oakcurric:keyword-peloponnesian-war
  a curric:Keyword ;
  schema:name "Peloponnesian War"@en ;
  schema:description """the Peloponnesian War was a war fought between Athens and Sparta over who would dominate Ancient Greece"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825170Z"^^xsd:dateTime .

oakcurric:keyword-city-state
  a curric:Keyword ;
  schema:name "city-state"@en ;
  schema:description "a city-state is a city that rules itself and the land around it"@en ;
  dcterms:modified "2026-02-12T08:59:15.826663Z"^^xsd:dateTime .

oakcurric:keyword-figurine
  a curric:Keyword ;
  schema:name "figurine"@en ;
  schema:description "a small statue or model of a person is called a figurine"@en ;
  dcterms:modified "2026-02-12T08:59:15.828341Z"^^xsd:dateTime .

oakcurric:keyword-granary
  a curric:Keyword ;
  schema:name "granary"@en ;
  schema:description "a granary is a large building used to store grain from the harvest"@en ;
  dcterms:modified "2026-02-12T08:59:15.828345Z"^^xsd:dateTime .

oakcurric:keyword-polis
  a curric:Keyword ;
  schema:name "polis"@en ;
  schema:description "a polis is the Ancient Greek word for a city-state"@en ;
  dcterms:modified "2026-02-12T08:59:15.828350Z"^^xsd:dateTime .

oakcurric:keyword-temple
  a curric:Keyword ;
  schema:name "temple"@en ;
  schema:description "a temple is a building where a god or gods are worshipped"@en ;
  dcterms:modified "2026-02-12T08:59:15.828354Z"^^xsd:dateTime .

oakcurric:keyword-precious
  a curric:Keyword ;
  schema:name "precious"@en ;
  schema:description "when something is of great worth or value it is said to be precious"@en ;
  dcterms:modified "2026-02-12T08:59:15.828382Z"^^xsd:dateTime .

oakcurric:keyword-expansion
  a curric:Keyword ;
  schema:name "expansion"@en ;
  schema:description "expansion often means becoming more permanent and larger in size"@en ;
  dcterms:modified "2026-02-12T08:59:15.828386Z"^^xsd:dateTime .

oakcurric:keyword-seafaring
  a curric:Keyword ;
  schema:name "seafaring"@en ;
  schema:description "seafaring means regularly travelling by sea"@en ;
  dcterms:modified "2026-02-12T08:59:15.828390Z"^^xsd:dateTime .

oakcurric:keyword-saga
  a curric:Keyword ;
  schema:name "saga"@en ;
  schema:description """a saga is a story of achievements or events in the history in Old Norse or Old Icelandic"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828394Z"^^xsd:dateTime .

oakcurric:keyword-account
  a curric:Keyword ;
  schema:name "account"@en ;
  schema:description "an account is a version of events that may have happened in the past"@en ;
  dcterms:modified "2026-02-12T08:59:15.828851Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-celts-iron-age-people-two
  a curric:Misconception ;
  curric:statement """That Celts and Iron Age people were two different things and there was a Celtic Era."""@en ;
  curric:correction "Ensure children understand that the Celtic people lived during the Iron Age."@en ;
  dcterms:modified "2026-02-12T08:59:18.676201Z"^^xsd:dateTime .

oakcurric:misconception-neolithic-houses-built-stone
  a curric:Misconception ;
  curric:statement "That all Neolithic houses were built from stone."@en ;
  curric:correction """Explain that many Neolithic house in Britain were built from wood and daub. Houses at Skara Brae were built from stone as no wood was available."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676305Z"^^xsd:dateTime .

oakcurric:misconception-difficult-young-learners-grasp-long
  a curric:Misconception ;
  curric:statement """It can be difficult for young learners to grasp how long 3000 years actually is and therefore appreciate just how long standing and important the Ancient Egyptian civilisation was."""@en ;
  curric:correction """Draw a timeline with 1AD in the middle, 2086 BCE on the left end and 2024 on the right end. Use this to demonstrate that the Ancient Egyptians existed for even longer than the time that has passed since 1 AD to today."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676525Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-everything-made-bronze
  a curric:Misconception ;
  curric:statement "Pupils might think that everything was made from bronze during the Bronze Age."@en ;
  curric:correction "Items such as jewellery were often made from gold."@en ;
  dcterms:modified "2026-02-12T08:59:18.676977Z"^^xsd:dateTime .

oakcurric:misconception-children-understand-iron-age-coins
  a curric:Misconception ;
  curric:statement """Children may not understand that the Iron Age coins were not just different to modern day coins but the first coins ever used in Britain."""@en ;
  curric:correction """Explain that during the Iron Age was the first time coins and the concept of money was used in Britain. Previously, people would have traded by swapping different goods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676986Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-comprehend-slow
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to comprehend the slow and painstaking nature of carrying out excavations."""@en ;
  curric:correction """Carter began excavating the Valley of the Kings many years before finding Tutankhamun's tomb; they were about to give up when they found it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677152Z"^^xsd:dateTime .

oakcurric:misconception-one-hieroglyph-picture-equivalent-letter
  a curric:Misconception ;
  curric:statement """That there was one hieroglyph (picture) equivalent to each letter of the English alphabet."""@en ;
  curric:correction """The Ancient Egyptians did not have an alphabet in the same way we do today. Hieroglyphs represented sounds and sometimes whole words. There were a lot more hieroglyphs than there are letters of the alphabet."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677173Z"^^xsd:dateTime .

oakcurric:misconception-writing-created-pens-pencils
  a curric:Misconception ;
  curric:statement "Writing is only created with pens or pencils."@en ;
  curric:correction """Discuss different forms of writing such as print on a poster, graffiti, and lettering on clothing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677383Z"^^xsd:dateTime .

oakcurric:misconception-farmers-iron-age-same-tools
  a curric:Misconception ;
  curric:statement "Farmers in the Iron Age had the same tools farmers have today such as tractors."@en ;
  curric:correction """Ensure children understand that farming was done by hand with a few iron tools to help. New tools such as the ard plough and iron sickle made a huge impact on farming."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677532Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-floods-destructive
  a curric:Misconception ;
  curric:statement "Pupils may think floods are only destructive."@en ;
  curric:correction """Explain that floodwaters can be very dangerous and cause much damage, but they also bring water and nutrients to the land for growing crops."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677560Z"^^xsd:dateTime .

oakcurric:misconception-bronze-natural-resource-metal-man
  a curric:Misconception ;
  curric:statement "Bronze is a natural resource (metal) and not man-made."@en ;
  curric:correction "Ensure children understand that bronze is a product that was made by humans."@en ;
  dcterms:modified "2026-02-12T08:59:18.677584Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-kingdoms-places-egypt
  a curric:Misconception ;
  curric:statement "Pupils may think that the kingdoms are places in Egypt."@en ;
  curric:correction """Kingdoms are are periods of time in Egyptian history; the Old Kingdom, the Middle Kingdom and the New Kingdom."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677688Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-river-nile-river
  a curric:Misconception ;
  curric:statement "Pupils may think that the River Nile is a river found only in Egypt."@en ;
  curric:correction """The River Nile does flow through Egypt, but it also flows through 10 other countries in east Africa. It is Africa's longest river."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677735Z"^^xsd:dateTime .

oakcurric:misconception-categorically-one-thing-considered-significant
  a curric:Misconception ;
  curric:statement """That there is categorically one thing that can be considered the most significant legacy."""@en ;
  curric:correction """Significance differs according to perspective and context. Something that is of great significance to one person may be of little significance to another, it all depends on the criteria that it is being judged against."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677781Z"^^xsd:dateTime .

oakcurric:misconception-baghdad-place-unrest
  a curric:Misconception ;
  curric:statement "Baghdad was a place of unrest."@en ;
  curric:correction "Baghdad was a wealthy and populous city, often referred to as the City of Peace."@en ;
  dcterms:modified "2026-02-12T08:59:18.677790Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-trenches-dug-like
  a curric:Misconception ;
  curric:statement "Pupils may think trenches were dug like long, straight ditches."@en ;
  curric:correction "Trenches were dug in a zig zag shape for better protection."@en ;
  dcterms:modified "2026-02-12T08:59:18.677812Z"^^xsd:dateTime .

oakcurric:misconception-benin-city-primitive-undeveloped-society
  a curric:Misconception ;
  curric:statement "Benin City was a primitive or undeveloped society."@en ;
  curric:correction """Benin City was a thriving metropolis with well-planned streets, organised urban spaces, and impressive architecture."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677838Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-monasteries-place-prayer
  a curric:Misconception ;
  curric:statement "Pupils may think monasteries were only a place for prayer."@en ;
  curric:correction """Monasteries were places for learning and culture where people could pray, study the bible and create things."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677852Z"^^xsd:dateTime .

oakcurric:misconception-pupils-gain-impression-ancient-romans
  a curric:Misconception ;
  curric:statement """Pupils may gain the impression that the Ancient Romans destroyed all aspects of Celtic worship."""@en ;
  curric:correction """Remind pupils that although the druids were wiped out, the worship of Celtic gods was tolerated as long as Ancient Roman ones were also respected."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677861Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-christianity-survived-because
  a curric:Misconception ;
  curric:statement "Pupils may think Christianity survived because of one reason."@en ;
  curric:correction """Christianity survived because of a few reasons. It survived in the places the Anglo-Saxons did not settle. It also survived because monasteries were set up and missionaries spread the the religion to other places."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677865Z"^^xsd:dateTime .

oakcurric:misconception-people-caribbean-travelled-britain-without
  a curric:Misconception ;
  curric:statement "People from the Caribbean travelled to Britain without being invited."@en ;
  curric:correction """These people were invited to become British citizens by the government in 1948 to help the country recover and lots had contributed in the armed forces during the war too."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677891Z"^^xsd:dateTime .

oakcurric:misconception-bodies-remain-preserved-state-death
  a curric:Misconception ;
  curric:statement "That all bodies remain in a preserved state after death."@en ;
  curric:correction "Explain that after death the body normally decomposes and a skeleton remains."@en ;
  dcterms:modified "2026-02-12T08:59:18.677932Z"^^xsd:dateTime .

oakcurric:misconception-obas-benin-male
  a curric:Misconception ;
  curric:statement "All Obas of Benin were male."@en ;
  curric:correction """While historically most Obas were, indeed, male, there were exceptions, and a few female rulers, known as "Queen Mothers," held significant influence and power. The Queen Mothers often acted as regents for young kings or played advisory roles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677936Z"^^xsd:dateTime .

oakcurric:misconception-british-people-fought-britain-second
  a curric:Misconception ;
  curric:statement "Only British people fought for Britain during the Second World War."@en ;
  curric:correction """Highlight how millions of men and women from around the world helped the British armed forces."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677961Z"^^xsd:dateTime .

oakcurric:misconception-pupils-realise-viking-army-large
  a curric:Misconception ;
  curric:statement """Pupils may not realise that the Viking army was so large it was able to split its forces which led to its success across Britain."""@en ;
  curric:correction """The Viking army was so large, it could split into different sections and fight in different parts of Britain at the same time. The army could also send reinforcements from one section to support another section in need."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677972Z"^^xsd:dateTime .

oakcurric:misconception-kingdom-benins-trade-europe-solely
  a curric:Misconception ;
  curric:statement """The Kingdom of Benin's trade with Europe solely revolved around the transatlantic slave trade."""@en ;
  curric:correction """While the Kingdom of Benin did participate in the slave trade to some extent, it also engaged in other forms of trade, including the exchange of goods such as ivory, pepper, cloth, and brassware."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678025Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-caratacus-resistance-boudicas
  a curric:Misconception ;
  curric:statement """Pupils may think that Caratacus' resistance and Boudica's rebellion took place at the same time."""@en ;
  curric:correction """Remind pupils that roughly 20 years had passed since Caratacus' defeat when Boudica rebelled."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678030Z"^^xsd:dateTime .

oakcurric:misconception-queen-margarita-buried-queens-tomb
  a curric:Misconception ;
  curric:statement """Queen Margarita was buried in the queen's tomb discovered by archaeologists in 1993 in Copan."""@en ;
  curric:correction """While the tomb is known as the Margarita Tomb, the name does not necessarily refer to an individual named Margarita."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678034Z"^^xsd:dateTime .

oakcurric:misconception-christianity-western-religion
  a curric:Misconception ;
  curric:statement "Christianity is a Western religion."@en ;
  curric:correction """Christianity originated in the Middle East and quickly spread across various regions, including Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678071Z"^^xsd:dateTime .

oakcurric:misconception-ancient-greeks-go-mount-olympus
  a curric:Misconception ;
  curric:statement """That the Ancient Greeks could go up Mount Olympus to find the gods or see the gods and talk to them there."""@en ;
  curric:correction """Mount Olympus is the highest mountain in Greece, reaching almost 10,000 ft. There were no paths and there was no climbing equipment like we have today. Climbing the rough, rocky terrain was so dangerous it could cost the life of anyone who tried."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678091Z"^^xsd:dateTime .

oakcurric:misconception-house-wisdom-exclusively-muslim
  a curric:Misconception ;
  curric:statement "The House of Wisdom was exclusively Muslim."@en ;
  curric:correction """The House of Wisdom was inclusive and multicultural, attracting scholars from various religious and ethnic backgrounds, including Christians, Jews, and Zoroastrians. This diversity helped in the exchange of ideas and knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678098Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-life-returned-normal
  a curric:Misconception ;
  curric:statement """Pupils may think that life returned to normal for everyone after the war was over."""@en ;
  curric:correction "Emphasise how the changes brought by the Second World War were permanent."@en ;
  dcterms:modified "2026-02-12T08:59:18.678131Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-people-roman-britain
  a curric:Misconception ;
  curric:statement "Pupils may think that all people in Roman Britain lived in Roman towns."@en ;
  curric:correction """Make it clear to pupils that although many people came to the towns, Britain remained largely rural, with lots of small Celtic settlements."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678149Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-britain-changed-worse
  a curric:Misconception ;
  curric:statement "Pupils may think that Britain only changed for the worse because of the Vikings."@en ;
  curric:correction """Britain changed in multiple positive ways because of Viking invasion and settlement through trade, changing place names, creating a new generation and even creating the England we know today."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678153Z"^^xsd:dateTime .

oakcurric:misconception-early-christian-councils-selected-books
  a curric:Misconception ;
  curric:statement "The early Christian councils selected the books of the New Testament."@en ;
  curric:correction """Though various local regional councils published lists of Old and New Testament books, there is no evidence of councils meeting to vote on the New Testament canon."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678201Z"^^xsd:dateTime .

oakcurric:misconception-al-mansur-planned-baghdad-circle
  a curric:Misconception ;
  curric:statement """Al-Mansur planned Baghdad as a circle solely because of his love for the Ancient Greek science of mathematics."""@en ;
  curric:correction """While Al-Mansur did have an interest in maths, the circular design of Baghdad was likely influenced by a combination of factors, including practical considerations such as defence and urban planning, as well as symbolic and religious significance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678211Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-leaders-recorded-history
  a curric:Misconception ;
  curric:statement "Pupils may think that all leaders are recorded in history."@en ;
  curric:correction """Female leaders, like Aethelflaed, are often written out of history as there was prejudice towards women. Despite Aethelflaed's success and the respect she gained, she was likely erased from history so it did not undermine male leaders at the time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678215Z"^^xsd:dateTime .

oakcurric:misconception-christianity-popular-roman-times-its
  a curric:Misconception ;
  curric:statement """As Christianity was popular in Roman times before its return, pupils may think this isn't a change."""@en ;
  curric:correction """Due to two forms of Christianity being practiced before the Synod of Whitby, there was a significant change to religion in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678237Z"^^xsd:dateTime .

oakcurric:misconception-king-offa-solely-responsible-mercian
  a curric:Misconception ;
  curric:statement "King Offa was solely responsible for Mercian supremacy."@en ;
  curric:correction """Although it was mostly King Offa, the supremacy of Mercia was already beginning before his reign and continued for a short while afterwards."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678241Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-aspects-religion-aspects
  a curric:Misconception ;
  curric:statement """Pupils may think that all aspects of religion, or all aspects of buildings changed."""@en ;
  curric:correction """Remind pupils that within an area of study that we define, there can be elements of both change and continuity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678246Z"^^xsd:dateTime .

oakcurric:misconception-widely-believed-st-patrick-brought
  a curric:Misconception ;
  curric:statement "It is widely believed that St Patrick brought Christianity to Ireland."@en ;
  curric:correction """Christianity had reached Ireland through contact with Roman Britain and as a result some Irish people converted to the religion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678251Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-kingdoms-part-one
  a curric:Misconception ;
  curric:statement "Some pupils may believe the kingdoms were part of one united kingdom of England."@en ;
  curric:correction """The Anglo-Saxon kingdoms had their own ruler and England was not a united kingdom or nation at this point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678257Z"^^xsd:dateTime .

oakcurric:misconception-baghdad-connected-east-trade
  a curric:Misconception ;
  curric:statement "Baghdad was only connected to the East through trade."@en ;
  curric:correction """Baghdad was also a centre for cultural, scientific, and intellectual exchange. It housed the House of Wisdom where scholars translated and studied works from other cultures and facilitated an exchange of ideas and knowledge, not just goods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678262Z"^^xsd:dateTime .

oakcurric:misconception-bloodletting-common-widespread-practice-among
  a curric:Misconception ;
  curric:statement """Bloodletting was a common and widespread practice among all Maya individuals on a regular basis."""@en ;
  curric:correction """Bloodletting rituals were primarily performed by the Maya elite, such as rulers, priests, and nobles, and were often reserved for specific ceremonial occasions or important events."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678271Z"^^xsd:dateTime .

oakcurric:misconception-students-think-national-insurance-wwii
  a curric:Misconception ;
  curric:statement """Students may think that National Insurance before WWII allowed men to receive healthcare without paying for it."""@en ;
  curric:correction """They had to pay with some of their wages to be entitled to the benefits of healthcare."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678278Z"^^xsd:dateTime .

oakcurric:misconception-baghdad-city-everyone-expected-follow
  a curric:Misconception ;
  curric:statement "Baghdad was a city where everyone was expected to follow Islam."@en ;
  curric:correction """People from all over the world visited Baghdad and practising other religions was tolerated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678310Z"^^xsd:dateTime .

oakcurric:misconception-people-killed-wwi-remembered-street
  a curric:Misconception ;
  curric:statement "Only people who were killed in WWI are remembered by street names and buildings."@en ;
  curric:correction """Many people made a significant contribution to WWI in their local area and are remembered for this with street names and buildings."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678319Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-athelstan-easily-united
  a curric:Misconception ;
  curric:statement "Pupils may think Athelstan easily united the kingdoms to create England."@en ;
  curric:correction """It is likely that Aethelstan was able to achieve so much due to the success and influence of his father, Edward, and aunt, Aethelflaed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678323Z"^^xsd:dateTime .

oakcurric:misconception-egypt-mesopotamia-places-early-civilisations
  a curric:Misconception ;
  curric:statement "Egypt and Mesopotamia are the only places to have had early civilisations."@en ;
  curric:correction """Look at a map of the world and point out the locations of the Indus Valley and Shang civilisations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678333Z"^^xsd:dateTime .

oakcurric:misconception-church-emerge-roman-empire-roman
  a curric:Misconception ;
  curric:statement "The only Church to emerge from the Roman Empire is the Roman Catholic Church."@en ;
  curric:correction """Two Christian Churches with slightly different ideologies emerged: the Roman Catholic Church was a product of the Western Roman Empire and the Eastern Orthodox Church developed in the Eastern Roman (Byzantine) Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678339Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-hadrians-wall-high
  a curric:Misconception ;
  curric:statement """Pupils may think that Hadrian's Wall was not very high, as the remaining stretches have been damaged."""@en ;
  curric:correction """Remind pupils that Hadrian's Wall is over a thousand years old, and any sections still standing were much taller in the past."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678372Z"^^xsd:dateTime .

oakcurric:misconception-mesoamerican-civilizations-primitive-less-advanced
  a curric:Misconception ;
  curric:statement """Mesoamerican civilizations were primitive or less advanced compared to European counterparts."""@en ;
  curric:correction """Mesoamerican societies achieved remarkable advancements in architecture, mathematics, astronomy, agriculture, and writing systems. E.g., the Maya developed calendar systems and made contributions to mathematics, including the concept of zero."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678407Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-women-britain-served
  a curric:Misconception ;
  curric:statement "Pupils may think that only women from Britain served in the armed forces."@en ;
  curric:correction """Highlight how thousands of women from across the British Empire at the time joined organisations like the ATS to help the British war effort."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678412Z"^^xsd:dateTime .

oakcurric:misconception-constantine-forced-everyone-roman-empire
  a curric:Misconception ;
  curric:statement "Constantine forced everyone in the Roman Empire to be Christian during his rule."@en ;
  curric:correction """Constantine issued a law, the Edict of Milan, that protected all faiths from religious persecution so that everyone in the Roman Empire could practise the religion they wanted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678431Z"^^xsd:dateTime .

oakcurric:misconception-prophet-muhammad-pbuh-founder-islam
  a curric:Misconception ;
  curric:statement "The Prophet Muhammad (PBUH) was the founder of Islam."@en ;
  curric:correction "The Prophet Muhammad (PBUH) was messenger sent to deliver the message of Islam."@en ;
  dcterms:modified "2026-02-12T08:59:18.678436Z"^^xsd:dateTime .

oakcurric:misconception-ancient-times-roman-meant-city
  a curric:Misconception ;
  curric:statement "In ancient times, being Roman meant being from the city of Rome."@en ;
  curric:correction """Initially, being Roman meant being from the city of Rome but later it included people who followed Roman ideology all over the Roman world."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678447Z"^^xsd:dateTime .

oakcurric:misconception-country-democratic-government-involves-people
  a curric:Misconception ;
  curric:statement """That a country having a democratic government involves all the people in the country having a say."""@en ;
  curric:correction """In Ancient Greece, only men were allowed to be part of the Assembly and take part in votes. Women were not allowed to vote, the men made the decisions and the women had to abide by them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678488Z"^^xsd:dateTime .

oakcurric:misconception-archaeologists-used-actual-artefacts-found
  a curric:Misconception ;
  curric:statement """That the archaeologists used the actual artefacts found in the grave to make the reconstruction of the chariot."""@en ;
  curric:correction """Ensure pupils understand that archaeologists used new materials to make a replica chariot based on the evidence in the grave."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678493Z"^^xsd:dateTime .

oakcurric:misconception-oba-edo-society-merely-religious
  a curric:Misconception ;
  curric:statement "The Oba in Edo society was merely a religious figure."@en ;
  curric:correction """While the Oba did have significant religious functions and was seen as having a special connection to the divine, his role also extended to that of political leader, responsible for governance, justice, and maintaining order within the kingdom."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678500Z"^^xsd:dateTime .

oakcurric:misconception-kingdom-macedon-modern-republic-north
  a curric:Misconception ;
  curric:statement """That the Kingdom of Macedon and the modern republic of North Macedonia are the same place."""@en ;
  curric:correction """Although North Macedonia's name stems from Macedon, they are not exactly the same location. Most of North Macedonia was part of Macedon, but Macedon also covered large parts of what is now northern Greece, southern Bulgaria and eastern Albania."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678505Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-offa-anglo-saxon
  a curric:Misconception ;
  curric:statement "Pupils may believe that Offa was the only Anglo-Saxon king to mint coins."@en ;
  curric:correction """Offa was the first, but other kings minted coins with their head on too. The Archbishop of Canterbury has also been found on coins as well as Offa's queen: Cynethryth."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678552Z"^^xsd:dateTime .

oakcurric:misconception-alexander-great-title-alexander-living
  a curric:Misconception ;
  curric:statement """Alexander 'The Great' was the title that Alexander had when he was a living ruler."""@en ;
  curric:correction """'The Great' is not a title. It is a type of nickname called an epithet. Epithets are only used to refer to people that have died and they tell us more about something significant the person did or what the person was like."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678566Z"^^xsd:dateTime .

oakcurric:misconception-nomadic-lifestyles-longer-exist
  a curric:Misconception ;
  curric:statement "Nomadic lifestyles no longer exist."@en ;
  curric:correction """Discuss the fact that many people in different parts of the world still live a nomadic lifestyle, some through choice and others as part of a continuing and ancient tradition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678571Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-objects-prove-trade
  a curric:Misconception ;
  curric:statement """Pupils may not understand how the objects prove the trade links around the world."""@en ;
  curric:correction """Particular objects during this time could only come from certain places. For example, silk was only made in China and travelled via the Silk Road to the Middle East and onto Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678576Z"^^xsd:dateTime .

oakcurric:misconception-rome-empire
  a curric:Misconception ;
  curric:statement "Rome was always an Empire."@en ;
  curric:correction """Before the Roman Empire was founded, Rome was first ruled by kings and then Rome became a republic."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678601Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-people-britain-formed
  a curric:Misconception ;
  curric:statement """Pupils may think that the people of Britain formed a united kingdom at this time."""@en ;
  curric:correction """Remind pupils that 1st century CE Britain was made up of various Celtic people, kingdoms and tribes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678606Z"^^xsd:dateTime .

oakcurric:misconception-pupils-grasp-artefacts-act-like
  a curric:Misconception ;
  curric:statement """Pupils may not grasp that artefacts act like pieces to a puzzle that help us learn about how people lived in a specific time or place."""@en ;
  curric:correction """The more artefacts archaeologists uncover, the more opportunity there is to study them carefully to learn about how people lived in a specific time or place."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678615Z"^^xsd:dateTime .

oakcurric:misconception-wwi-soldiers-remembered-memorials
  a curric:Misconception ;
  curric:statement "It is only WWI soldiers who are remembered with memorials."@en ;
  curric:correction """All those who lost their lives in WWI are remembered through memorials (medical staff, civilians, animals etc)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678620Z"^^xsd:dateTime .

oakcurric:misconception-olympia-mount-olympus-either-same
  a curric:Misconception ;
  curric:statement "That Olympia and Mount Olympus are either the same thing or in the same place."@en ;
  curric:correction """There are approximately 200 miles between the locations of Olympia and Mount Olympus. Mount Olympus is the highest mountain in Greece, whereas Olympia was a large flat plain. Mount Olympus was the mythical home of the 12 major gods, Olympia was not."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678631Z"^^xsd:dateTime .

oakcurric:misconception-historical-places-named-still-exist
  a curric:Misconception ;
  curric:statement "That the historical places named still exist today."@en ;
  curric:correction """Over time, names and boundaries of places can change. Some places cease to exist entirely while the locations of some places do still exist but they have a different name today. A large area of Persia for example is in the modern-day country of Iran."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678637Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-nurses-tasks-like
  a curric:Misconception ;
  curric:statement """Pupils may think that nurses only did tasks like cleaning wards and providing meals."""@en ;
  curric:correction """Nurses did three years of training and had to pass exams in anatomy and physiology. They handled weapons on the front line and ran the hospitals caring for the injured in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678643Z"^^xsd:dateTime .

oakcurric:misconception-art-drawings-paintings
  a curric:Misconception ;
  curric:statement "Art is only drawings or paintings."@en ;
  curric:correction """Look at lots of different examples of ancient art, such as sculpture, textiles, jewellery, decorated household objects, weapons and armour."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678648Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-vikings-came-britain
  a curric:Misconception ;
  curric:statement """Pupils may not understand that the Vikings came to Britain for different reasons over a long period of time."""@en ;
  curric:correction """The Vikings first came to Britain to raid monasteries; they then invaded and settled in some Anglo-Saxon kingdoms. Finally, they tried to capture all of Britain but were unsuccessful. However, they were able to stay and control the Danelaw."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678652Z"^^xsd:dateTime .

oakcurric:misconception-anglo-saxons-called-because-angles
  a curric:Misconception ;
  curric:statement "The Anglo-Saxons are called that because only Angles and Saxons came to Britain."@en ;
  curric:correction """'Anglo-Saxon' is a term historians use to describe all the groups of tribes who came to Britain from Europe around this time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678661Z"^^xsd:dateTime .

oakcurric:misconception-cacao-same-cocoa
  a curric:Misconception ;
  curric:statement "Cacao is the same as cocoa."@en ;
  curric:correction """While they come from the same source, the cacao bean, there are differences in processing. Cacao generally refers to the raw or minimally processed form of the bean, while cocoa usually refers to the processed and roasted form."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678668Z"^^xsd:dateTime .

oakcurric:misconception-pupils-perceptions-vikings-fierce-fighters
  a curric:Misconception ;
  curric:statement "Pupils may have perceptions of Vikings as only fierce fighters."@en ;
  curric:correction """Evidence shows that the Vikings who settled in York were peaceful; they farmed the land and were known for being great craftsmen, traders, artists, engineers and ship builders."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678673Z"^^xsd:dateTime .

oakcurric:misconception-medals-awarded-leaders-fought-wwi
  a curric:Misconception ;
  curric:statement "Medals were only awarded to leaders who fought in WWI."@en ;
  curric:correction "Medals were awarded for acts of bravery across all ranks of soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:18.678704Z"^^xsd:dateTime .

oakcurric:misconception-philosophical-questions-like-questions-answers
  a curric:Misconception ;
  curric:statement "That philosophical questions, like all questions, must have answers."@en ;
  curric:correction """Questions that relate to factual information usually do have answers. Philosophical questions are not about facts. Philosophical questions are about people's opinions, feelings and perspectives on life, so they can have many and varied responses."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678771Z"^^xsd:dateTime .

oakcurric:misconception-battles-fought-land-soldiers-warriors
  a curric:Misconception ;
  curric:statement """That battles are always fought on land, by soldiers or warriors who are physically fighting each other."""@en ;
  curric:correction """Battles can be fought many ways - some Ancient Greek battles were land based and warriors used chariots and weapons like javelins. Other battles were at sea using boats that would be rammed into the enemy and archers that would fire arrows at them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678775Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-britons-became-pagans
  a curric:Misconception ;
  curric:statement "Pupils may think all Britons became pagans."@en ;
  curric:correction """It is likely that some Britons adopted pagan beliefs when the Anglo-Saxons settled. Some may have continued to follow Christianity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678811Z"^^xsd:dateTime .

oakcurric:misconception-ancient-writing-stories-rulers-gods
  a curric:Misconception ;
  curric:statement "Ancient writing was only for stories about rulers and gods."@en ;
  curric:correction """Discuss the four different uses of ancient writing: trade, laws, religion and rulers. Discuss how these are similar to modern use, like laws needed for an ancient civilisation to develop, and think about the kinds of laws they would have needed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678832Z"^^xsd:dateTime .

oakcurric:misconception-elections-fair-way-make-decisions
  a curric:Misconception ;
  curric:statement "Elections are the most fair and just way to make decisions."@en ;
  curric:correction """Elections, when they are run honestly, are a fair and just way to make decisions. However, sometimes people can interfere with results of elections or try to sway people to vote in a certain way which means the outcome can be predictable."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678839Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-pagan-beliefs-polytheistic
  a curric:Misconception ;
  curric:statement """Pupils might think that pagan beliefs were polytheistic and all non-pagan beliefs are monotheistic."""@en ;
  curric:correction """Though many pagan religions were polytheistic, there are non-pagan religions that are polytheistic such as Hinduism."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678853Z"^^xsd:dateTime .

oakcurric:misconception-housewife-easy-role
  a curric:Misconception ;
  curric:statement "That being a housewife was an easy role."@en ;
  curric:correction """Working in the home on domestic tasks for 70 hours a week was more than a full time working week with a paid job."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678858Z"^^xsd:dateTime .

oakcurric:misconception-children-think-word-great-referring
  a curric:Misconception ;
  curric:statement """Children may think that the word 'Great' when referring to WWI may mean that the war was a great idea."""@en ;
  curric:correction """To remind pupils that 'Great' in this context refers to the both the size and scale of the war."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678863Z"^^xsd:dateTime .

oakcurric:misconception-alexandria-city-greece
  a curric:Misconception ;
  curric:statement "Alexandria is a city in Greece."@en ;
  curric:correction """Alexander the Great founded the city of Alexandria in Egypt, not on the mainland or any island of Ancient Greece. There is still a city called Alexandria on the original site in Egypt today; some ruins of the ancient city can be visited by tourists."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678867Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-britain-formed-separate
  a curric:Misconception ;
  curric:statement """Pupils may not understand that Britain was formed of separate Anglo-Saxon kingdoms."""@en ;
  curric:correction """At this time, Britain was formed of four separate kingdoms: East Anglia, Northumbria, Mercia and Wessex."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678910Z"^^xsd:dateTime .

oakcurric:misconception-people-living-arabian-peninsula-followed
  a curric:Misconception ;
  curric:statement "The people living on the Arabian peninsula have always followed Islam."@en ;
  curric:correction """Pre-Islamic Arabia followed a mix of Judaism, Christianity and polytheism (the belief in many gods)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678921Z"^^xsd:dateTime .

oakcurric:misconception-muslims-intolerant-other-religions
  a curric:Misconception ;
  curric:statement "Muslims were intolerant of other religions."@en ;
  curric:correction """People living in Muslim-controlled territories were allowed to follow their own religion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678930Z"^^xsd:dateTime .

oakcurric:misconception-silk-roads-specific-defined-roads
  a curric:Misconception ;
  curric:statement "The Silk Roads were specific, defined roads."@en ;
  curric:correction """The Silk Roads were not actual roads nor a single route; it was in fact a network of trade routes running between China and Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678935Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-troy-real-place
  a curric:Misconception ;
  curric:statement """Pupils may think that Troy was a real place and that the Trojan War was a real conflict."""@en ;
  curric:correction """The story of the Trojan War is from Greek mythology. Myths are stories that people have told by word of mouth for thousands of years, some people do claim that myths are true but they are in fact fictional stories - they did not happen in real life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678939Z"^^xsd:dateTime .

oakcurric:misconception-maya-one-calendar
  a curric:Misconception ;
  curric:statement "The Maya had just one calendar."@en ;
  curric:correction """They actually used several interconnected calendars. The most notable ones are the Tzolk'in (a 260-day ceremonial calendar), the Haab' (a 365-day solar calendar), and the Long Count calendar, which tracked longer periods of time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678944Z"^^xsd:dateTime .

oakcurric:misconception-turning-point-temporary-change
  a curric:Misconception ;
  curric:statement "That a turning point is a temporary change."@en ;
  curric:correction "A turning point is usually a major, decisive and permanent change."@en ;
  dcterms:modified "2026-02-12T08:59:18.678959Z"^^xsd:dateTime .

oakcurric:misconception-war-fought-soldiers-won-battlefields
  a curric:Misconception ;
  curric:statement "The war was only fought by soldiers and won on battlefields."@en ;
  curric:correction """Civilians at home did much work to support the war effort and this was known as 'the Home Front'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678966Z"^^xsd:dateTime .

oakcurric:misconception-byzantines-werent-roman
  a curric:Misconception ;
  curric:statement "The Byzantines weren’t Roman."@en ;
  curric:correction """The Byzantine Empire, also known as the Eastern Roman Empire, was a continuation of the Roman Empire. The term "Byzantine" is a modern designation used by historians, but the people of that time considered themselves Romans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678980Z"^^xsd:dateTime .

oakcurric:misconception-evidence-christianity-4th-century-definitive
  a curric:Misconception ;
  curric:statement """Evidence of Christianity from the 4th century is definitive proof of when it was introduced to Britain."""@en ;
  curric:correction """The evidence of Christianity found in Britain dates back to the 4th century and this gives historians reason to believe this is around the time Christianity was introduced and became popular in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678991Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-churchill-unpopular-because
  a curric:Misconception ;
  curric:statement """Pupils may think that Churchill was unpopular because the majority of the British public did not vote for him in 1945."""@en ;
  curric:correction """Churchill was a popular individual. It was the lack of promises of his political party to make social changes that lost him the election in 1945."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679018Z"^^xsd:dateTime .

oakcurric:misconception-egyptian-people-related-blood-previous
  a curric:Misconception ;
  curric:statement """That only Egyptian people who were related by blood to the previous pharaoh could become a pharaoh."""@en ;
  curric:correction """Alexander was an ancient Greek. He was not Egyptian by birth or by blood but the Egyptian people still made him a pharaoh after Alexander drove the Persians out of Egypt."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679022Z"^^xsd:dateTime .

oakcurric:misconception-christianity-started-birth-jesus-christ
  a curric:Misconception ;
  curric:statement "Christianity started with the birth of Jesus Christ."@en ;
  curric:correction """Christianity developed after the death of Jesus when his followers continued to spread his teachings."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679052Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-ethelreds-reign-completely
  a curric:Misconception ;
  curric:statement "Pupils may think Ethelred's reign was completely unsuccessful."@en ;
  curric:correction """Although Ethelred made some poor decisions during his reign, evidence from his charters and coins suggest that Ethelred’s government was more effective than was once believed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679057Z"^^xsd:dateTime .

oakcurric:misconception-maya-single-unified-empire
  a curric:Misconception ;
  curric:statement "The Maya were a single, unified empire."@en ;
  curric:correction """They were organised into independent city-states with their own rulers, languages, and alliances. While they shared cultural traits and religious beliefs, they were politically fragmented entities that sometimes engaged in conflicts with each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679090Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-york-strategically-important
  a curric:Misconception ;
  curric:statement """Pupils may think York was only strategically important because the rivers acted as a natural defence."""@en ;
  curric:correction """York was strategically important because the rivers were a natural defence, but they were also key routes for trade."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679095Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fighting-second-world
  a curric:Misconception ;
  curric:statement """Some pupils may think that the fighting in the Second World War only happened in Europe."""@en ;
  curric:correction """Discuss how the fighting was global and happened across three different continents with millions of people worldwide involved."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679099Z"^^xsd:dateTime .

oakcurric:misconception-students-think-something-taught-history
  a curric:Misconception ;
  curric:statement """Students may think that for something to be taught as history, all historians have to agree on it."""@en ;
  curric:correction """Historians do not always agree about the past and what sources tell us. It is important to remember this when being historians ourselves!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.679104Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-soon-christianity-returned
  a curric:Misconception ;
  curric:statement """Pupils may think that as soon as Christianity returned to Britain, pagan traditions disappeared completely."""@en ;
  curric:correction """Paganism did not completely vanish. Though the majority of Anglo-Saxons were Christians, pagan beliefs and traditions were still present."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679109Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-children-evacuated-areas
  a curric:Misconception ;
  curric:statement """Pupils may think that children were only evacuated to areas in Britain during the Second World War."""@en ;
  curric:correction "Children were sent to other countries like Australia and South Africa in 1940."@en ;
  dcterms:modified "2026-02-12T08:59:18.679115Z"^^xsd:dateTime .

oakcurric:misconception-benin-bronzes-created-trade-europeans
  a curric:Misconception ;
  curric:statement "The Benin Bronzes were created for trade with Europeans."@en ;
  curric:correction """The Benin Bronzes were created to serve as significant cultural and religious artefacts within the Benin Kingdom and made from the manilla used as payment for goods."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679120Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-combination-factors-led
  a curric:Misconception ;
  curric:statement """Pupils may not understand that it was a combination of factors that led to laying the foundations of England."""@en ;
  curric:correction """Aethelflaed and Edward were able to lay the foundations for England by establishing strongholds to protect their towns and cities, combining their forces and leading campaigns together."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679129Z"^^xsd:dateTime .

oakcurric:misconception-pupils-realise-significant-leading-role
  a curric:Misconception ;
  curric:statement """Pupils may not realise the significant leading role Aethelflaed had during this time."""@en ;
  curric:correction """Aethelflaed was thought to have been a strong, independent and well-educated woman. She had learnt a great deal about military leadership and strategy by watching her father King Alfred."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679134Z"^^xsd:dateTime .

oakcurric:misconception-students-think-know-anglo-saxons
  a curric:Misconception ;
  curric:statement """Students may think that we only know about the Anglo-Saxons because of written history."""@en ;
  curric:correction """We know mostly about the Anglo-Saxons because of grave goods and other archeological finds."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679147Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-scots-tribe-originally
  a curric:Misconception ;
  curric:statement "Pupils may believe the Scots tribe were originally from Scotland."@en ;
  curric:correction """The Scots tribe originated from Ireland but the name 'Scotland' comes from the tribe after they migrated there."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679156Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-dividing-england-clever
  a curric:Misconception ;
  curric:statement """Pupils may not understand that dividing England was a clever move for Alfred to make."""@en ;
  curric:correction """Alfred divided England and allowed the Vikings to control some areas. Alfred knew he could not get the Vikings to leave Britain as too many had already settled."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679174Z"^^xsd:dateTime .

oakcurric:misconception-ancient-generals-men
  a curric:Misconception ;
  curric:statement "Ancient generals were only men."@en ;
  curric:correction """The story of Fu Hao as one of the best Shang Dynasty generals at this time disproves this. There are records of around 600 women in the army at this time too."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679181Z"^^xsd:dateTime .

oakcurric:misconception-fall-western-roman-empire-happened
  a curric:Misconception ;
  curric:statement "The fall of the Western Roman Empire happened when it was sacked in 410 CE."@en ;
  curric:correction "The fall of the Western Roman Empire happened gradually over time."@en ;
  dcterms:modified "2026-02-12T08:59:18.679186Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-archaeologists-learn-artefacts
  a curric:Misconception ;
  curric:statement """Pupils may think that what archaeologists learn from artefacts is definitive knowledge."""@en ;
  curric:correction """Archaeologists carefully study artefacts to learn how people lived in specific times and places. New knowledge can be discovered and can change their understanding of how people lived."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679202Z"^^xsd:dateTime .

oakcurric:misconception-baghdad-cordoba-identical-their-cultural
  a curric:Misconception ;
  curric:statement """Baghdad and Cordoba were identical in their cultural and architectural influences during their respective golden ages."""@en ;
  curric:correction """Baghdad was influenced by Persian, Greek, and Indian cultures. In contrast, Cordoba, part of Al-Andalus, had a unique blend of Islamic, Christian, and Jewish influences, contributing to its distinctive architectural styles and cultural heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679228Z"^^xsd:dateTime .

oakcurric:misconception-modern-republic-benin-kingdom-benin
  a curric:Misconception ;
  curric:statement "The modern republic of Benin and the kingdom of Benin are the same place."@en ;
  curric:correction "The modern republic of Benin has no historical relation to the kingdom of Benin."@en ;
  dcterms:modified "2026-02-12T08:59:18.679235Z"^^xsd:dateTime .

oakcurric:misconception-people-spoke-totally-different-language
  a curric:Misconception ;
  curric:statement """That people spoke a totally different language in Ancient Greece than they speak today in modern Greece."""@en ;
  curric:correction """The Greek alphabet has been in use for more than 2,000 years; the same alphabet that was used in Ancient Greece is used in Greece today. Much of the Greek language stems from or is the same as Ancient Greek."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679243Z"^^xsd:dateTime .

oakcurric:misconception-missionaries-found-easy-convert-people
  a curric:Misconception ;
  curric:statement "The missionaries found it easy to convert people to Christianity."@en ;
  curric:correction """The missionaries like St Columba and St Columbanus experienced resistance from kings and bishops which sometimes led to major problems and even battle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679266Z"^^xsd:dateTime .

oakcurric:misconception-baghdad-especially-abbasid-caliphate-isolated
  a curric:Misconception ;
  curric:statement """Baghdad, especially during the Abbasid Caliphate, was an isolated or insular city."""@en ;
  curric:correction """Baghdad was a major hub of trade, communication, and intellectual exchange, connecting the Islamic world with both Asia and Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679271Z"^^xsd:dateTime .

oakcurric:misconception-europe-mediterranean-asia-early-9th
  a curric:Misconception ;
  curric:statement """Europe, the Mediterranean, and Asia in the early 9th century were largely isolated, with minimal contact and influence between these regions."""@en ;
  curric:correction """There was much interaction between the regions during this period with extensive trade networks, such as the Silk Road, connected them and political leaders across these regions often maintained diplomatic relations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679285Z"^^xsd:dateTime .

oakcurric:misconception-widow-gender-neutral-term
  a curric:Misconception ;
  curric:statement "Widow is a gender neutral term."@en ;
  curric:correction """Widow is a gendered term for a woman whose husband has died. A widower is a husband whose wife has died."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679295Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-archaeologists-find-past
  a curric:Misconception ;
  curric:statement "Pupils may think archaeologists only find out about the past through excavation."@en ;
  curric:correction """Archaeologists use a range of ways to find out about the past which include excavation, field walking, surveying and aerial photography."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679318Z"^^xsd:dateTime .

oakcurric:misconception-children-confused-etymology-girdle-hangers
  a curric:Misconception ;
  curric:statement "Children may be confused by the etymology of 'girdle-hangers' ."@en ;
  curric:correction """Though they symbolise keys, girdle-hangers are called this because they hang from the girdle (belt or sash)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679708Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-ancient-civilisations-existed
  a curric:Misconception ;
  curric:statement "Pupils may think that all these ancient civilisations existed at separate times."@en ;
  curric:correction """Although beginning thousands of years apart, by the time of the Shang Dynasty, the Ancient Sumerian, Ancient Egyptian and Indus Valley civilisations were still going!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.680058Z"^^xsd:dateTime .

oakcurric:misconception-think-shang-dynasty-symbols-exactly
  a curric:Misconception ;
  curric:statement """Some may think that the Shang Dynasty symbols are exactly the same as the modern Chinese written symbols."""@en ;
  curric:correction """There are lots of similarities between them but they are different. Lots of the modern Chinese symbols are clearly based on the ancient Shang Dynasty ones."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680223Z"^^xsd:dateTime .

oakcurric:misconception-archaeologists-historians-know-exactly-discovered
  a curric:Misconception ;
  curric:statement """Archaeologists and historians always know exactly what discovered items were used for in the past."""@en ;
  curric:correction """Archaeologists and historians have to make guesses about what the discovered items were used for in the past, using their knowledge and other objects to help them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680745Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-vikings-motivation-raid
  a curric:Misconception ;
  curric:statement """Pupils may think that the Vikings' motivation to raid Lindisfarne was to murder the monks rather than it being a consequence of the raids."""@en ;
  curric:correction """The Vikings raided monasteries because they were easy targets on the coast and they had many valuable objects they could steal."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687184Z"^^xsd:dateTime .

oakcurric:misconception-mummification-case-wrapping-body-bandages
  a curric:Misconception ;
  curric:statement "That mummification is just a case of wrapping a body in bandages and burying it."@en ;
  curric:correction """There are several stages in the mummification process, each of which must be done precisely and carefully in order to be successful."""@en ;
  dcterms:modified "2026-02-12T08:59:18.687223Z"^^xsd:dateTime .

oakcurric:misconception-ever-one-type-human
  a curric:Misconception ;
  curric:statement "That there has only ever been one type of human."@en ;
  curric:correction """Explain there was more than one type of early human but they are all extinct now. All modern humans are Homo sapiens."""@en ;
  dcterms:modified "2026-02-12T08:59:18.688985Z"^^xsd:dateTime .

oakcurric:misconception-our-knowledge-past-factual
  a curric:Misconception ;
  curric:statement "That our knowledge of the past is factual."@en ;
  curric:correction """Explain that our understanding of the past is based on evidence that helps to build up a picture. New discoveries are made all the time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694282Z"^^xsd:dateTime .

oakcurric:misconception-humans-living-stone-age-homo
  a curric:Misconception ;
  curric:statement "All humans living in the Stone Age were Homo sapiens."@en ;
  curric:correction """Ensure pupils understand that there were different types of humans such as Neanderthals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695215Z"^^xsd:dateTime .

oakcurric:misconception-dates-artefacts-exact-precise
  a curric:Misconception ;
  curric:statement "Dates of artefacts are exact and precise."@en ;
  curric:correction """Ensure children understand that archaeologists use a variety of strategies to estimate an approximate date."""@en ;
  dcterms:modified "2026-02-12T08:59:18.695899Z"^^xsd:dateTime .

oakcurric:misconception-assume-jade-green-colour
  a curric:Misconception ;
  curric:statement "Some might assume that jade is always green in colour."@en ;
  curric:correction """Jade is a natural stone and so the colour varies greatly. It can appear as many colours including black, brown, yellow, white, green and blue. Different colours have been more desirable at different points in Chinese history."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701140Z"^^xsd:dateTime .

oakcurric:misconception-bce-ce-denote-times-year
  a curric:Misconception ;
  curric:statement "BCE and CE denote times before and after the year 0."@en ;
  curric:correction """There is no year 0. BCE denotes the time before the year 1 and CE denotes the time from the year 1."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702090Z"^^xsd:dateTime .

oakcurric:misconception-people-byzantine-times-called-themselves
  a curric:Misconception ;
  curric:statement "People in Byzantine times never called themselves Byzantium."@en ;
  curric:correction "People in Byzantine times always called themselves Roman."@en ;
  dcterms:modified "2026-02-12T08:59:18.702113Z"^^xsd:dateTime .

oakcurric:misconception-connected-mean-geographically-physically-rather
  a curric:Misconception ;
  curric:statement """That by connected we mean geographically or physically rather thank via communication and trade."""@en ;
  curric:correction """Discuss the meaning of the word connected. Explore maps of the areas concerned. Explain that Britain and Europe were connected by communication and trade."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702140Z"^^xsd:dateTime .

oakcurric:misconception-julius-caesar-emperor-roman-empire
  a curric:Misconception ;
  curric:statement "Julius Caesar was an emperor of the Roman Empire."@en ;
  curric:correction """Julius Caesar was not an emperor of the Roman Empire but a dictator of the Roman Republic."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702180Z"^^xsd:dateTime .

oakcurric:misconception-archaeologists-historians-right-information-past
  a curric:Misconception ;
  curric:statement """That archaeologists and historians are always right. That information about the past is always factual."""@en ;
  curric:correction """Explain that archaeologists and historians use clues to piece together what they think the past was like. These views and opinions can change over time as more sources or information is discovered."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702204Z"^^xsd:dateTime .

oakcurric:misconception-think-celtic-people-iron-age
  a curric:Misconception ;
  curric:statement """Some may think that Celtic people and Iron Age people lived in different time periods."""@en ;
  curric:correction "Celtic people lived during the Iron Age."@en ;
  dcterms:modified "2026-02-12T08:59:18.702262Z"^^xsd:dateTime .

oakcurric:misconception-campsite-used-holidays
  a curric:Misconception ;
  curric:statement "That a campsite is used for holidays."@en ;
  curric:correction """Discuss the difference between campsites in the Mesolithic Era and a campsite today to highlight the differences."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702280Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-our-knowledge-iron
  a curric:Misconception ;
  curric:statement """Pupils may think that all of our knowledge of the Iron Age is definitely correct."""@en ;
  curric:correction """Explain that archaeologists use artefacts to learn about the past, they get ideas and clues from the artefacts and build up a picture of what they think the past was like. There is very little written evidence about the Celts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702301Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sacrifices-offered-gods
  a curric:Misconception ;
  curric:statement "Pupils may think that sacrifices were only offered to gods."@en ;
  curric:correction """The belief that the ancestors held power over the living family was very strong in the Shang Dynasty. The people wanted to remember them, keep them happy and asked for blessings for their actions in life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702306Z"^^xsd:dateTime .

oakcurric:misconception-changes-bronze-age-iron-age
  a curric:Misconception ;
  curric:statement "The changes between the Bronze Age and the Iron Age happened instantly."@en ;
  curric:correction """Explain that the changes between the Bronze Age and Iron Age happened gradually over time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702350Z"^^xsd:dateTime .

oakcurric:misconception-women-hold-positions-power-shang
  a curric:Misconception ;
  curric:statement "Women could not hold positions of power in the Shang Dynasty."@en ;
  curric:correction """The tomb of Fu Hao tells us that she was a powerful queen and one of the most successful and important army generals of her time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704702Z"^^xsd:dateTime .

oakcurric:misconception-civilisation-indus-valley-began-8000
  a curric:Misconception ;
  curric:statement "That the civilisation in the Indus Valley began 8000 years ago."@en ;
  curric:correction """Archaeologists believe farming in the valley began around 8000 years ago but the evidence for the cities and civilisation dates from around 5000 years ago."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704958Z"^^xsd:dateTime .

oakcurric:misconception-city-states-ancient-greece-same
  a curric:Misconception ;
  curric:statement """That all city-states in Ancient Greece had the same structure, and the people in each state had the same roles and values. That the city-states were peaceful and lived happily alongside each other."""@en ;
  curric:correction """Although there were some similarities across Ancient Greece, each individual city-state had differences. Societies in Athens and Sparta were very different. Sometimes, the city-states fought each other for the right to rule over all of the lands."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705149Z"^^xsd:dateTime .

oakcurric:misconception-pupils-associate-making-guesses-wrong
  a curric:Misconception ;
  curric:statement "Pupils may associate making guesses with being wrong."@en ;
  curric:correction """Reassure pupils that making guesses is necessary to learn new things, and essential in jobs like archaeology. Acknowledge that the guesses are educated and based on drawing information from lots of sources to make conclusions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705969Z"^^xsd:dateTime .

oakcurric:misconception-ancient-greece-greece-exactly-same
  a curric:Misconception ;
  curric:statement "Ancient Greece and Greece are exactly the same place."@en ;
  curric:correction """Modern-day Greece is part of the area that made up Ancient Greece, but it is smaller than Ancient Greece; the extent of the spread of Ancient Greece changed over time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706997Z"^^xsd:dateTime .

oakcurric:misconception-farmers-lived-cities
  a curric:Misconception ;
  curric:statement "That only farmers lived in the cities."@en ;
  curric:correction """Evidence has been found suggesting lots of different skilled individuals lived and worked in the cities of the Indus Valley."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707489Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-possible-read-ancient
  a curric:Misconception ;
  curric:statement """Pupils might think that it will never be possible to read the ancient Indus Valley civilisation script."""@en ;
  curric:correction """A new discovery similar to the Rosetta Stone could unlock the key to deciphering the writing and help to solve some of the mysteries!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.709757Z"^^xsd:dateTime .

oakcurric:misconception-city-states-differences-nothing-common
  a curric:Misconception ;
  curric:statement "The city-states had only differences; they had nothing common with each other."@en ;
  curric:correction """The biggest link between the city-states is that they were all part of Ancient Greece. They must have had similarities as well as differences because they were all part of the same ancient civilisation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709761Z"^^xsd:dateTime .

oakcurric:misconception-art-indus-valley-civilisation-found
  a curric:Misconception ;
  curric:statement "Art from the Indus Valley civilisation has only been found in the Indus Valley."@en ;
  curric:correction """Art from the Indus Valley civilisation has been found in places like Mesopotamia, showing us that the Indus Valley people probably travelled there and traded with the Ancient Mesopotamians."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709793Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-vikings-raided-places
  a curric:Misconception ;
  curric:statement "Pupils may think the Vikings only raided places and left."@en ;
  curric:correction """Vikings expansion involved sailing to explore new places which they often raided for goods. The Vikings then began to settle and trade in these places."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709798Z"^^xsd:dateTime .

oakcurric:misconception-everything-read-past-true
  a curric:Misconception ;
  curric:statement "That everything we read about the past is always true."@en ;
  curric:correction """Historians try to tell as accurate a story about the past as possible by carefully investigating and studying evidence. Sometimes though, historians do not always agree with each other especially about finer details, and so make generalisations."""@en ;
