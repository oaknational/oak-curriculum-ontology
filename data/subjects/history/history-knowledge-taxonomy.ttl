natcurric:contentdescriptor-identify-significant-events-analyse-trends
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Identify significant events, make connections, draw contrasts, and analyse 
  trends within periods and over long arcs of time."""@en ;
  curric:supportingGuidance "Supporting guidance text..."@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-historical-concepts ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

