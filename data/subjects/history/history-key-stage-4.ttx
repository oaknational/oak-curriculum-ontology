  dcterms:modified "2026-02-12T08:59:15.828136Z"^^xsd:dateTime .

oak:keyword-pluralist
  a oakcurric:Keyword ;
  schema:name "pluralist"@en ;
  schema:description "someone who holds more than one position within the Church"@en ;
  dcterms:modified "2026-02-12T08:59:15.828154Z"^^xsd:dateTime .

oak:keyword-primacy
  a oakcurric:Keyword ;
  schema:name "primacy"@en ;
  schema:description "the state of being most important"@en ;
  dcterms:modified "2026-02-12T08:59:15.828158Z"^^xsd:dateTime .

oak:keyword-diocese
  a oakcurric:Keyword ;
  schema:name "diocese"@en ;
  schema:description "an area under the control of a bishop"@en ;
  dcterms:modified "2026-02-12T08:59:15.828162Z"^^xsd:dateTime .

oak:keyword-circulation
  a oakcurric:Keyword ;
  schema:name "circulation"@en ;
  schema:description "the movement of blood around your body"@en ;
  dcterms:modified "2026-02-12T08:59:15.828253Z"^^xsd:dateTime .

oak:keyword-waterlogged
  a oakcurric:Keyword ;
  schema:name "waterlogged"@en ;
  schema:description "when land has become full of water"@en ;
  dcterms:modified "2026-02-12T08:59:15.828257Z"^^xsd:dateTime .

oak:keyword-sharecropper
  a oakcurric:Keyword ;
  schema:name "sharecropper"@en ;
  schema:description """a sharecropper was a farmer who rented a small area of land from a landowner; they had to give a share of the crops they grew to their landlord"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828612Z"^^xsd:dateTime .

oak:keyword-mountainous
  a oakcurric:Keyword ;
  schema:name "mountainous"@en ;
  schema:description "having many mountains"@en ;
  dcterms:modified "2026-02-12T08:59:15.828749Z"^^xsd:dateTime .

oak:keyword-retaliation
  a oakcurric:Keyword ;
  schema:name "retaliation"@en ;
  schema:description """retaliation involves harming another person or group after they have acted in a way which hurt you"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828860Z"^^xsd:dateTime .

oak:keyword-public-works
  a oakcurric:Keyword ;
  schema:name "public works"@en ;
  schema:description """public works involve the construction of roads, bridges, hospitals and similar things that are paid for by the government"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828864Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oak:misconception-nhs-feature-britains-welfare-state
  a oakcurric:Misconception ;
  oakcurric:statement """The NHS was the only feature of Britain's welfare state which supported public health."""@en ;
  oakcurric:correction """The NHS was very important but slum clearance and new house building were also important features of the welfare state which benefitted public health."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675429Z"^^xsd:dateTime .

oak:misconception-norman-invasion-1066-castles-unknown
  a oakcurric:Misconception ;
  oakcurric:statement "Before the Norman invasion in 1066, castles were unknown in Anglo-Saxon England."@en ;
  oakcurric:correction """In fact, Ralph the Timid built a motte-and-bailey castle in Hereford to guard the city against attacks from Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675453Z"^^xsd:dateTime .

oak:misconception-migrants-kenya-uganda-mid-20th
  a oakcurric:Misconception ;
  oakcurric:statement """All migrants from Kenya and Uganda during the mid-20th century were of Asian descent."""@en ;
  oakcurric:correction """Not all migrants from Kenya and Uganda during the mid-20th century were of Asian descent; however, large numbers of them were due to the discrimination they faced in newly-independent Kenya and Uganda."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675463Z"^^xsd:dateTime .

oak:misconception-usa-black-civil-rights-movement
  a oakcurric:Misconception ;
  oakcurric:statement "That only the USA had a black civil rights movement."@en ;
  oakcurric:correction """Britain also experienced its own civil rights movement; it is often thought to have begun with the Bristol Bus Boycott in June 1963."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675468Z"^^xsd:dateTime .

oak:misconception-medieval-period-expected-rulers-ruthless
  a oakcurric:Misconception ;
  oakcurric:statement """In the medieval period it was expected that rulers would be ruthless in killing anyone who opposed them."""@en ;
  oakcurric:correction """Rulers were expected to be just and merciful in the medieval period, and Willian faced criticism across Europe for his brutality in crushing opposition in the North of England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675619Z"^^xsd:dateTime .

oak:misconception-students-believe-fascism-factor-nazi
  a oakcurric:Misconception ;
  oakcurric:statement """Students might believe that fascism was only a factor in Nazi Germany, and be unaware of the existence of  fascist groups in Britain."""@en ;
  oakcurric:correction """Fascism spread across Europe in the 1930s, including to Britain, although Britain's strong democratic tradition meant it did not take hold as it did in other countries at the time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675642Z"^^xsd:dateTime .

oak:misconception-supreme-court-ordered-schools-desegregate
  a oakcurric:Misconception ;
  oakcurric:statement """When the Supreme Court ordered all schools to desegregate, they were quick to follow this instruction because it came from the Supreme Court."""@en ;
  oakcurric:correction """Although the Supreme Court was the highest court in the USA, many schools were slow to desegregate and some refused to desegregate until they were eventually forced."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675658Z"^^xsd:dateTime .

oak:misconception-voting-rights-act-1965-marked
  a oakcurric:Misconception ;
  oakcurric:statement """The Voting Rights Act (1965) marked the end of protests to fight against racial injustice."""@en ;
  oakcurric:correction """Many people felt the acts were too little too late as unemployment rates remained high and daily discrimination continued - for many, in the form of poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675663Z"^^xsd:dateTime .

oak:misconception-great-plague-last-serious-plague
  a oakcurric:Misconception ;
  oakcurric:statement "The Great Plague was the last serious plague epidemic because a cure was found."@en ;
  oakcurric:correction """No effective cure had been developed to treat plague at the time of the Great Plague."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675677Z"^^xsd:dateTime .

oak:misconception-african-migrants-early-modern-period
  a oakcurric:Misconception ;
  oakcurric:statement "All African migrants in the early modern period were 'unfree' servants."@en ;
  oakcurric:correction """While many African migrants were 'unfree' servants, there were also free men and women who worked in other jobs - for example, John Blanke and Mary Fillis."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675690Z"^^xsd:dateTime .

oak:misconception-usa-lead-throughout-space-race
  a oakcurric:Misconception ;
  oakcurric:statement "The USA was in the lead throughout the Space Race."@en ;
  oakcurric:correction """The USSR beat the USA to launch the first satellite into orbit and to put both the first man and first woman in space."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675783Z"^^xsd:dateTime .

oak:misconception-nato-established-response-ussr-setting
  a oakcurric:Misconception ;
  oakcurric:statement "NATO was established in response to the USSR setting up the Warsaw Pact."@en ;
  oakcurric:correction """The Warsaw Pact was a response to NATO's formation in April 1949 (which itself followed the Berlin Crisis and Soviet takeover of Czechoslovakia)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675838Z"^^xsd:dateTime .

oak:misconception-one-individual-martin-luther-king
  a oakcurric:Misconception ;
  oakcurric:statement """One individual, Martin Luther King, was responsible for the success of the civil rights movement from 1960 to 1965."""@en ;
  oakcurric:correction """While Martin Luther King played a huge role of the success seen in these years, the success was also the result of several civil rights leaders and the work of their organisations as well an increasing support from the president."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675842Z"^^xsd:dateTime .

oak:misconception-bishops-role-equivalent-modern-times
  a oakcurric:Misconception ;
  oakcurric:statement "Bishops have always had a role equivalent to modern times."@en ;
  oakcurric:correction """In fact, bishops in the medieval period were involved in government and even led armies into battle, such as bishop Odo of Bayeux."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675884Z"^^xsd:dateTime .

oak:misconception-britain-joined-eu-intention-encouraging
  a oakcurric:Misconception ;
  oakcurric:statement """Britain joined the EU with the intention of encouraging greater migration from Europe."""@en ;
  oakcurric:correction """When Britain joined the EU in 1973, it was primarily for economic reasons as they hoped to boost their economy through trading relationships with Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675891Z"^^xsd:dateTime .

oak:misconception-william-used-chapel-st-john
  a oakcurric:Misconception ;
  oakcurric:statement "William I often used the Chapel of St John for his own private worship."@en ;
  oakcurric:correction "Although this was the plan, William died before the chapel was finished."@en ;
  dcterms:modified "2026-02-12T08:59:18.675960Z"^^xsd:dateTime .

oak:misconception-dub-eks-reforms-demonstrate-communist
  a oakcurric:Misconception ;
  oakcurric:statement "Dubček's reforms demonstrate that he was not a communist."@en ;
  oakcurric:correction """Dubček did want to liberalise politics and the economy in Czechoslovakia but he was still a communist. He considered these reforms necessary to ensure that a communist government could survive without being overthrown."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675964Z"^^xsd:dateTime .

oak:misconception-students-make-connection-civil-rights
  a oakcurric:Misconception ;
  oakcurric:statement """Students may not make the connection between the civil rights movement in the USA and the efforts of black activists in the UK in the 1960s."""@en ;
  oakcurric:correction """Explain to students that the influence of Martin Luther King Jr and Malcolm X spread outside of America."""@en ;
  dcterms:modified "2026-02-12T08:59:18.675987Z"^^xsd:dateTime .

oak:misconception-nato-established-response-stalin-setting
  a oakcurric:Misconception ;
  oakcurric:statement "NATO was established in response to Stalin setting up the Warsaw Pact."@en ;
  oakcurric:correction """The Warsaw Pact was a response to NATO's formation in April 1949 (following the Berlin Crisis and Soviet takeover of Czechoslovakia)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676017Z"^^xsd:dateTime .

oak:misconception-york-became-important-city-viking
  a oakcurric:Misconception ;
  oakcurric:statement "York only became an important city under Viking rule."@en ;
  oakcurric:correction """York was an important army base under the rule of the Romans, but was also used as a capital city under Anglo-Saxon rule. Its location along important trade routes made it an attractive city to any conqueror."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676024Z"^^xsd:dateTime .

oak:misconception-industrial-revolution-meant-agricultural-work
  a oakcurric:Misconception ;
  oakcurric:statement "The Industrial Revolution meant that no agricultural work was needed anymore."@en ;
  oakcurric:correction """The Industrial Revolution led to an increase in demand for workers in heavy industries - however, there was still some work in agricultural industries and so not all rural people migrated into towns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676029Z"^^xsd:dateTime .

oak:misconception-motte-bailey-castles-took-years
  a oakcurric:Misconception ;
  oakcurric:statement "Motte-and-bailey castles took years to build."@en ;
  oakcurric:correction """Stone castles could take several years to build; however, the Normans could erect the main defences of a motte-and-bailey castle in as little as a week, usually using large amounts of local labour."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676059Z"^^xsd:dateTime .

oak:misconception-americans-won-war-independence-because
  a oakcurric:Misconception ;
  oakcurric:statement "The Americans won the War of Independence because they had a better army."@en ;
  oakcurric:correction """For much of the war, the American army was a poorly trained militia. Whilst they fought bravely and Washington proved to be an able general, they received significant support from France and Spain which swung the balance of the conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676068Z"^^xsd:dateTime .

oak:misconception-everyone-joins-armed-forces-willingly
  a oakcurric:Misconception ;
  oakcurric:statement """Everyone who joins the armed forces does so willingly and supports the actions of the government."""@en ;
  oakcurric:correction """Conscription is common around the world, and many people are forced to join the armed forces against their will."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676072Z"^^xsd:dateTime .

oak:misconception-migrants-liverpool-ireland
  a oakcurric:Misconception ;
  oakcurric:statement "All migrants in Liverpool were from Ireland."@en ;
  oakcurric:correction """While Irish migrants made up most of the migrant community in Liverpool, there were also a growing number of African and Caribbean sailors who settled in the city."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676080Z"^^xsd:dateTime .

oak:misconception-migrants-predominantly-white-nations-welcomed
  a oakcurric:Misconception ;
  oakcurric:statement """All migrants from predominantly white nations were welcomed by authorities and local communities."""@en ;
  oakcurric:correction """Although Irish migrants were encouraged to migrate, they often faced hostility on arriving in Britain. Like Caribbean migrants, many struggled to find suitable accommodation as landlords were unwilling to rent to them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676084Z"^^xsd:dateTime .

oak:misconception-vaccinations-made-compulsory-ensure-uptake
  a oakcurric:Misconception ;
  oakcurric:statement "Vaccinations have been made compulsory to ensure uptake in modern Britain."@en ;
  oakcurric:correction """Vaccinations have been voluntary for people to receive in modern Britain but many have been provided free of charge and their benefits promoted to encourage people."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676122Z"^^xsd:dateTime .

oak:misconception-william-conqueror-hostile-towards-anglo
  a oakcurric:Misconception ;
  oakcurric:statement "William the Conqueror was hostile towards all Anglo-Saxons from the start."@en ;
  oakcurric:correction """Some Anglo-Saxons, if they had not fought against William at Hastings, were allowed to keep their land."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676138Z"^^xsd:dateTime .

oak:misconception-passing-civil-rights-act-1964
  a oakcurric:Misconception ;
  oakcurric:statement """The passing of the Civil Rights Act in 1964 marked the end of the civil rights movement."""@en ;
  oakcurric:correction """While the Civil Rights Act (1964) was a landmark moment, bringing significant change, it left much to campaign for - particularly issues of voter registration amongst black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676143Z"^^xsd:dateTime .

oak:misconception-jenners-vaccine-became-widespread-popular
  a oakcurric:Misconception ;
  oakcurric:statement "Jenner's vaccine became widespread and popular almost immediately."@en ;
  oakcurric:correction """There was considerable opposition to Jenner's smallpox vaccine which delayed widespread use of vaccination in Britain until later in the 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676153Z"^^xsd:dateTime .

oak:misconception-alternative-medicines-mostly-abandoned-course
  a oakcurric:Misconception ;
  oakcurric:statement """Alternative medicines were mostly abandoned during the course of the 20th century."""@en ;
  oakcurric:correction """Alternative medicines, including practices like homeopathy and the use of herbal medicines, have remained popular, even in 21st century Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676264Z"^^xsd:dateTime .

oak:misconception-students-commonly-provide-enough-detail
  a oakcurric:Misconception ;
  oakcurric:statement """Students commonly do not provide enough detail from their historic environment in their answers."""@en ;
  oakcurric:correction """Try to back up your analysis of the question with specific facts and details from your historic environment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676273Z"^^xsd:dateTime .

oak:misconception-according-bayeux-tapestry-odo-played
  a oakcurric:Misconception ;
  oakcurric:statement """According to the Bayeux Tapestry, Odo played an important role in the Norman invasion."""@en ;
  oakcurric:correction """There is reason to be sceptical about this depiction. The Bayeux Tapestry was commissioned by Odo. This perhaps explains why Odo is self-importantly shown as central to the planning and delivery of the invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676282Z"^^xsd:dateTime .

oak:misconception-jewish-migrants-invited-england-purely
  a oakcurric:Misconception ;
  oakcurric:statement """Jewish migrants were invited to England for purely economic reasons, just as they were under the Normans."""@en ;
  oakcurric:correction """In the early modern period, the rule of the Puritans meant that Jewish people were invited to England in 1655 for both religious and economic reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676287Z"^^xsd:dateTime .

oak:misconception-migrants-workers-settled-england-work
  a oakcurric:Misconception ;
  oakcurric:statement "All migrants workers settled in England to work in the wool trade."@en ;
  oakcurric:correction """Not all migrant workers settled in England to work in the wool trade. Italian bankers are an example of a migrant group who were invited to work as moneylenders, and had very little to do with the English wool trade."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676291Z"^^xsd:dateTime .

oak:misconception-jim-crow-laws-impacted-southern
  a oakcurric:Misconception ;
  oakcurric:statement "Jim Crow laws only impacted southern states in the US."@en ;
  oakcurric:correction """Although Jim Crow laws were implemented in every southern state, there was still some segregation in northern states."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676314Z"^^xsd:dateTime .

oak:misconception-william-planned-replace-anglo-saxons
  a oakcurric:Misconception ;
  oakcurric:statement """William always planned to replace Anglo-Saxons in key government positions with loyal Normans."""@en ;
  oakcurric:correction """At first, William intended to boost his claim to be the legitimate heir of Edward by keeping earls Edwin, Morcar and Waltheof in place in his government of England - alongside new earls such as Earl Odo of Kent or Earl William of Hereford."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676365Z"^^xsd:dateTime .

oak:misconception-northumbria-anglo-saxon-earldom-fully
  a oakcurric:Misconception ;
  oakcurric:statement """Northumbria was an Anglo-Saxon earldom that was fully integrated into the kingdom of England."""@en ;
  oakcurric:correction """Northumbria had a shifting northern border with Scotland and was part of the Danelaw and had different laws and customs from southern England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676376Z"^^xsd:dateTime .

oak:misconception-opposition-civil-rights-movement-limited
  a oakcurric:Misconception ;
  oakcurric:statement """Opposition to the civil rights movement was limited to organisations formed by the public"""@en ;
  oakcurric:correction """Opposition to the civil rights movement was organised both within the public and within the US government"""@en ;
  dcterms:modified "2026-02-12T08:59:18.676385Z"^^xsd:dateTime .

oak:misconception-reformation-led-increase-number-protestant
  a oakcurric:Misconception ;
  oakcurric:statement """The Reformation only led to an increase in the number of Protestant refugees in England."""@en ;
  oakcurric:correction """The Reformation eventually led to Puritan rule, under which Jewish migrants were reinvited to England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676390Z"^^xsd:dateTime .

oak:misconception-medieval-modern-church-power-equivalent
  a oakcurric:Misconception ;
  oakcurric:statement "Medieval and modern Church power is equivalent."@en ;
  oakcurric:correction """Explicitly outline the Church's organisational power: land ownership, clergy social status, and spiritual authority."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676405Z"^^xsd:dateTime .

oak:misconception-vikings-come-norway
  a oakcurric:Misconception ;
  oakcurric:statement "Vikings come from Norway."@en ;
  oakcurric:correction """Whilst Vikings did come from Norway, some of the most problematic Vikings from an English perspective came from Denmark. Vikings also came from Sweden."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676468Z"^^xsd:dateTime .

oak:misconception-us-lost-vietnam-war-north
  a oakcurric:Misconception ;
  oakcurric:statement "The US lost the Vietnam War: the North had little agency or impact on events."@en ;
  oakcurric:correction """North Vietnam was a formidable fighting force who had fought several wars over many years. Their strength was a major reason why they won."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676481Z"^^xsd:dateTime .

oak:misconception-londons-new-sewage-system-built
  a oakcurric:Misconception ;
  oakcurric:statement """London's new sewage system was built in response to John Snow's findings and recommendations."""@en ;
  oakcurric:correction """Snow's work was generally overlooked by officials. Instead, London's new sewers were built in response to the Great Stink of 1858."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676495Z"^^xsd:dateTime .

oak:misconception-shield-wall-sophisticated-effective-military
  a oakcurric:Misconception ;
  oakcurric:statement "The shield wall was not a very sophisticated or effective military tactic."@en ;
  oakcurric:correction """In fact, the shield wall proved effective in holding off the Norman attacks for many hours."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676642Z"^^xsd:dateTime .

oak:misconception-paying-homage-swearing-allegiance-making
  a oakcurric:Misconception ;
  oakcurric:statement "Paying homage, swearing allegiance, or making promises were weak obligations."@en ;
  oakcurric:correction """In fact, these promises are with the king and God. It was unlikely you would break a public and spiritual promise like this. It would not be good for your reputation or your soul!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.676654Z"^^xsd:dateTime .

oak:misconception-agreement-why-usa-dropped-atomic
  a oakcurric:Misconception ;
  oakcurric:statement """There is agreement about why the USA dropped atomic bombs on Hiroshima and Nagasaki."""@en ;
  oakcurric:correction """The US decision to use atomic bombs at the end of WW2 remains deeply controversial and historians disagree about the motivation with some arguing that it was to force the Japanese to surrender while others arguing it was to intimidate the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676763Z"^^xsd:dateTime .

oak:misconception-americans-supportive-war-against-communist
  a oakcurric:Misconception ;
  oakcurric:statement "Americans were supportive of any war against a communist country."@en ;
  oakcurric:correction """Many Americans did support action against communists but an increasing number did not support the manner in which their country was fighting"""@en ;
  dcterms:modified "2026-02-12T08:59:18.676768Z"^^xsd:dateTime .

oak:misconception-white-migrants-positive-experiences-modern
  a oakcurric:Misconception ;
  oakcurric:statement "All white migrants had positive experiences in the modern period."@en ;
  oakcurric:correction """Although they were often favoured by immigration laws, they still faced hostility on arriving in Britain. For example, many Irish migrants experienced the same discrimination from landlords as Caribbean migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676772Z"^^xsd:dateTime .

oak:misconception-benefits-ww2-experienced-evenly-groups
  a oakcurric:Misconception ;
  oakcurric:statement "The benefits of WW2 were experienced evenly by all groups of Americans."@en ;
  oakcurric:correction """Women and African Americans enjoyed many benefits from the stimulus created by WW2, but continued discrimination in the armed forces and on the home front meant that they did not always benefit as much as White Americans did from wartime recovery."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676843Z"^^xsd:dateTime .

oak:misconception-vikings-nothing-brutal-savages
  a oakcurric:Misconception ;
  oakcurric:statement "The Vikings were nothing but brutal savages."@en ;
  oakcurric:correction """Whilst the Viking aptitude for battle is well known, they were also exceptional explorers and traders. Raiding was simply another way for them to gain wealth as opposed to their only way of life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676848Z"^^xsd:dateTime .

oak:misconception-martin-luther-king-jr-part
  a oakcurric:Misconception ;
  oakcurric:statement "Martin Luther King Jr had always been part of the civil rights movement."@en ;
  oakcurric:correction """King entered the spotlight following the Montgomery Bus Boycott and became a successful, popular leader as he was not associated with any large organisations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676853Z"^^xsd:dateTime .

oak:misconception-period-d-tente-1970s-mark
  a oakcurric:Misconception ;
  oakcurric:statement """The period of Détente in the 1970s did not mark the beginning of the end of the Cold War."""@en ;
  oakcurric:correction """Although there was a reduction in tensions between the USA and the USSR during the early 1970s, tensions had increased again by the end of the decade."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676857Z"^^xsd:dateTime .

oak:misconception-us-soviet-relations-began-decline
  a oakcurric:Misconception ;
  oakcurric:statement """US-Soviet relations only began to decline when Reagan became US President in January 1981."""@en ;
  oakcurric:correction """There had been a significant decline in superpower relations before Reagan became US President. For example, in 1979, the Soviet invasion of Afghanistan and Carter’s response led to a serious increase in tension."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676968Z"^^xsd:dateTime .

oak:misconception-normans-rulers-england-entirely-positive
  a oakcurric:Misconception ;
  oakcurric:statement """As the Normans were rulers of England, they had entirely positive experiences and faced no hostility."""@en ;
  oakcurric:correction """The Normans faced rebellions from Anglo-Saxon communities, but were largely unaffected as these rebellions were brutally put down. However, French monks faced increasingly hostility from English subjects."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677118Z"^^xsd:dateTime .

oak:misconception-benefits-mass-production-car-industry
  a oakcurric:Misconception ;
  oakcurric:statement """The benefits of mass production in the car industry were felt equally by all groups."""@en ;
  oakcurric:correction """Mass production benefited consumers and businesses greatly but workers suffered from monotonous work and restrictions on trade unionism."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677177Z"^^xsd:dateTime .

oak:misconception-northern-ireland-protestant-elsewhere-ireland
  a oakcurric:Misconception ;
  oakcurric:statement """All those in Northern Ireland were Protestant and all those elsewhere in Ireland were Catholic."""@en ;
  oakcurric:correction """Ireland was predominantly Catholic but there was a population in the north who were predominantly Protestant, who remained part of the UK as Northern Ireland after partition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677182Z"^^xsd:dateTime .

oak:misconception-resistance-williams-rule-england-came
  a oakcurric:Misconception ;
  oakcurric:statement "Resistance to William’s rule of England, came only from the English."@en ;
  oakcurric:correction """In 1075, two Norman earls revolted against William, and English forces helped to stop the rebellion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677186Z"^^xsd:dateTime .

oak:misconception-increased-success-direct-action-1960s
  a oakcurric:Misconception ;
  oakcurric:statement """The increased success of the direct action in the 1960s was the result of minimal opposition."""@en ;
  oakcurric:correction """Direct action in the 1960s was increasingly successful because of the increased opposition that was captured by national and international news reporters."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677191Z"^^xsd:dateTime .

oak:misconception-effective-responses-black-death
  a oakcurric:Misconception ;
  oakcurric:statement "There were no effective responses to the Black Death."@en ;
  oakcurric:correction """No effective treatments existed in the medieval period but some preventative methods, such as quarantines, could help protect people from plague."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677304Z"^^xsd:dateTime .

oak:misconception-minority-groups-experienced-hardship-result
  a oakcurric:Misconception ;
  oakcurric:statement "Minority groups only experienced hardship as a result of discrimination."@en ;
  oakcurric:correction """Some groups such as African Americans experienced economic hardship because of broader structural changes - especially the decline of American agriculture which hurt the South where most African Americans lived."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677439Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-monarch-held-power
  a oakcurric:Misconception ;
  oakcurric:statement "An Anglo-Saxon monarch held all the power in their kingdom."@en ;
  oakcurric:correction """In fact, Anglo-Saxon nobles could force their monarchs to do things they did not want to do. For example, King Edward was forced to allow the House of Godwin back from exile and restore them to their earldoms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677451Z"^^xsd:dateTime .

oak:misconception-took-many-weeks-travel-south
  a oakcurric:Misconception ;
  oakcurric:statement """It took many weeks to travel from the south to the north of England in medieval times."""@en ;
  oakcurric:correction """Harold and his housecarls were able to cover 185 miles in just four days in 1066: an amazing achievement."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677465Z"^^xsd:dateTime .

oak:misconception-jewish-migrants-settled-england-medieval
  a oakcurric:Misconception ;
  oakcurric:statement """The Jewish migrants who settled in England in the medieval, early modern and industrial periods all migrated for similar reasons and had similar experiences."""@en ;
  oakcurric:correction """In each period, there are marked differences in the reasons for Jewish migration but also in the experiences of Jewish migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677470Z"^^xsd:dateTime .

oak:misconception-d-tente-ended-suddenly-following
  a oakcurric:Misconception ;
  oakcurric:statement """Détente ended suddenly following the Soviet invasion of Afghanistan in December 1979."""@en ;
  oakcurric:correction """The Soviet invasion of Afghanistan is normally considered to mark the end of Détente but US-Soviet tensions had been increasing since 1975 due to conflict over human rights issues and increased Soviet support for communist groups around the world."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677546Z"^^xsd:dateTime .

oak:misconception-william-conqueror-crowned-king-england
  a oakcurric:Misconception ;
  oakcurric:statement """After William the Conqueror was crowned King of England, he and the Normans were immediately accepted as rightful rulers and peace reigned across the kingdom."""@en ;
  oakcurric:correction """In fact, William faced a hostile Anglo-Saxon population and threats of invasion from Wales and Scotland, requiring him to take measures to establish further control."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677642Z"^^xsd:dateTime .

oak:misconception-castro-communist-overthrew-batistas-government
  a oakcurric:Misconception ;
  oakcurric:statement "Castro was a communist when he overthrew Batista's government in 1959."@en ;
  oakcurric:correction """Although some people involved in the Cuban Revolution were communist, Castro was a nationalist and only declared that he was a communist at the end of 1961 after the failed Bay of Pigs Invasion led Cuba to develop a closer relationship with the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677649Z"^^xsd:dateTime .

oak:misconception-poor-people-medieval-england-survived
  a oakcurric:Misconception ;
  oakcurric:statement "Poor people in medieval England survived by eating potatoes."@en ;
  oakcurric:correction "Potatoes were unknown in Europe until the 16th century."@en ;
  dcterms:modified "2026-02-12T08:59:18.677693Z"^^xsd:dateTime .

oak:misconception-martin-luther-kings-famous-dream
  a oakcurric:Misconception ;
  oakcurric:statement """After Martin Luther King's famous 'I have a dream' speech, the civil rights movement continued to progress until the Civil Rights Act was passed."""@en ;
  oakcurric:correction """The assassination of President Kennedy stalled the momentum the movement had gained with the events in Birmingham, he was the president that many black American had put their hope in - and many feared their hope died with him."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677697Z"^^xsd:dateTime .

oak:misconception-palatines-protestant-migrants-entirely-negative
  a oakcurric:Misconception ;
  oakcurric:statement """As Palatines were not all Protestant migrants they had entirely negative experiences as migrants in England."""@en ;
  oakcurric:correction """Palatines were initially welcomed and supported, as authorities believed they were Protestant refugees. Their experiences became negative as authorities realised that many were Catholics seeking better economic opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677702Z"^^xsd:dateTime .

oak:misconception-matyas-rakosi-leader-hungary-start
  a oakcurric:Misconception ;
  oakcurric:statement "Matyas Rakosi was the leader of Hungary at the start of the Hungarian Uprising."@en ;
  oakcurric:correction """Rakosi was forced to quit as leader in July 1956 when he lost the support of the USSR. Rakosi was replaced by his close friend, Erno Gero, then Khrushchev installed Imre Nagy as leader on 26th October 1956 in an attempt to end the uprising."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677723Z"^^xsd:dateTime .

oak:misconception-migrant-experiences-dependent-solely-migrated
  a oakcurric:Misconception ;
  oakcurric:statement "Migrant experiences were dependent solely on when they migrated to England."@en ;
  oakcurric:correction """Migrant experiences were dependent on a variety of factors, this includes when they migrated, the relationship between each migrant group and the authorities and where in England they settled."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677730Z"^^xsd:dateTime .

oak:misconception-malcolm-xs-main-philosophy-use
  a oakcurric:Misconception ;
  oakcurric:statement """Malcolm X's main philosophy was the use of violence in order to fight racial injustice."""@en ;
  oakcurric:correction """Malcolm X supported Black Nationalism and encouraged black Americans to defend themselves by any means necessary, although this did endorse violence, Malcolm X spent much of his time with the Black Muslims supporting black Americans in poorer areas."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677758Z"^^xsd:dateTime .

oak:misconception-huguenots-settle-england-protestant-nation
  a oakcurric:Misconception ;
  oakcurric:statement """Huguenots had to settle in England as it was the only Protestant nation in Europe."""@en ;
  oakcurric:correction """Huguenots were looking to flee to a safe Protestant nation, and England became the choice for around 50 000 Huguenots as it was known to be more tolerant - not because there were no other nations where Huguenots could settle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677765Z"^^xsd:dateTime .

oak:misconception-protestant-migrants-entirely-positive-experiences
  a oakcurric:Misconception ;
  oakcurric:statement "All Protestant migrants had entirely positive experiences."@en ;
  oakcurric:correction """Most Protestant migrants had largely positive experiences in this period, however, there are still examples of Protestants who did not maintain the support of the authorities and the Church, such as the Palatines."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677769Z"^^xsd:dateTime .

oak:misconception-civil-rights-organisations-worked-north
  a oakcurric:Misconception ;
  oakcurric:statement "Civil rights organisations only worked in the north."@en ;
  oakcurric:correction """Civil rights organisations worked across the USA, although they would get more support from white Americans in northern states and would therefore seem more successful in the north."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677786Z"^^xsd:dateTime .

oak:misconception-nixon-showed-little-interest-civil
  a oakcurric:Misconception ;
  oakcurric:statement """As Nixon showed little interest in the civil rights movement after his election, the movement largely regressed in the 1970s."""@en ;
  oakcurric:correction """The extent of progress in the civil rights movement was largely dependent on the area of life you consider. For example, there was little change politically but there was some progress economically."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677795Z"^^xsd:dateTime .

oak:misconception-german-democratic-republic-gdr-west
  a oakcurric:Misconception ;
  oakcurric:statement "The German Democratic Republic (GDR) was West Germany."@en ;
  oakcurric:correction """The GDR was East Germany - the Democratic part of the name is confusing as it was not democratic in the Western sense of being able to choose freely between different political parties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677799Z"^^xsd:dateTime .

oak:misconception-people-migrated-england-flanders-similar
  a oakcurric:Misconception ;
  oakcurric:statement "All people who migrated to England from Flanders had similar experiences."@en ;
  oakcurric:correction """Walloon weavers had more positive experiences in Canterbury and were awarded greater freedoms, when compared to Flemish weavers in Sandwich."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677806Z"^^xsd:dateTime .

oak:misconception-castro-immediately-turned-ussr-support
  a oakcurric:Misconception ;
  oakcurric:statement "Castro immediately turned to the USSR for support after the Cuban Revolution."@en ;
  oakcurric:correction """Castro mainly turned to the USSR for support in 1960, after the USA had already begun restricting trade with Cuba."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677884Z"^^xsd:dateTime .

oak:misconception-forest-norman-england-meant-land
  a oakcurric:Misconception ;
  oakcurric:statement "That forest in Norman England always meant land covered by trees."@en ;
  oakcurric:correction """Forest in Norman England meant an area that was reserved for hunting and so could include open land, village land, even towns, as well as woodland."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677907Z"^^xsd:dateTime .

oak:misconception-common-misconception-castles-military-function
  a oakcurric:Misconception ;
  oakcurric:statement "A common misconception is that castles only had a military function."@en ;
  oakcurric:correction """However, castles also had a psychological impact on the people of England. They served as a permanent reminder to the English of a foreign occupier in their land. They were also centres of administration."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677911Z"^^xsd:dateTime .

oak:misconception-poorer-people-afghanistan-supported-communist
  a oakcurric:Misconception ;
  oakcurric:statement "Poorer people in Afghanistan supported the communist PDPA government."@en ;
  oakcurric:correction """The PDPA's land reforms were tainted by corruption and angered many poorer Afghans because they received poor quality land. Many Afghans opposed the PDPA's attempts to create a secular society, which they saw as an attack on their faith and culture."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677921Z"^^xsd:dateTime .

oak:misconception-communist-states-fell-complete-soviet
  a oakcurric:Misconception ;
  oakcurric:statement """All communist states fell under complete Soviet control because of the Brezhnev Doctrine."""@en ;
  oakcurric:correction """Some states such as China, Yugoslavia, Romania and Albania became less trusting of the USSR and made increased efforts to develop their own independent relations to protect themselves against it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677952Z"^^xsd:dateTime .

oak:misconception-historians-agree-cold-war-started
  a oakcurric:Misconception ;
  oakcurric:statement """Historians agree that the Cold War started in 1945 with the end of World War Two."""@en ;
  oakcurric:correction """The breakdown of the wartime alliance and the emerging ideological rift between communism and capitalism unfolded over several years. The exact start date of the Cold War is often debated among historians."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677957Z"^^xsd:dateTime .

oak:misconception-alexander-dubcek-committed-communist
  a oakcurric:Misconception ;
  oakcurric:statement "Alexander Dubcek was not a committed communist."@en ;
  oakcurric:correction """Dubcek was a committed communist. The purpose of the Prague Spring reforms was to preserve communist rule in Czechoslovakia and win support for communism by removing its worst features (e.g., censorship, secret police etc.)"""@en ;
  dcterms:modified "2026-02-12T08:59:18.677968Z"^^xsd:dateTime .

oak:misconception-great-depression-americans-significantly-less
  a oakcurric:Misconception ;
  oakcurric:statement """During the Great Depression, Americans had significantly less access to entertainment."""@en ;
  oakcurric:correction """Americans continued to access entertainments on a large scale. Radio ownership doubled, cinema attendance recovered as a form of escapism and new forms of popular literature like comics flourished."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677991Z"^^xsd:dateTime .

oak:misconception-berlin-crisis-solely-status-west
  a oakcurric:Misconception ;
  oakcurric:statement "The Berlin Crisis was solely about the status of West Berlin."@en ;
  oakcurric:correction """While the status of West Berlin was a significant aspect of the Berlin Crisis, it was not the only factor. The crisis was also influenced by broader Cold War dynamics, including the arms race and competition for influence in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678004Z"^^xsd:dateTime .

oak:misconception-end-british-empire-growth-commonwealth
  a oakcurric:Misconception ;
  oakcurric:statement """The end of the British Empire and the growth of the Commonwealth led to increasing migration from the Commonwealth throughout the second half of the 20th century."""@en ;
  oakcurric:correction """Although migration to Britain initially increased in the second part of the 20th century, it was limited by immigration laws introduced in the 1960s - which aimed to target black and Asian migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678009Z"^^xsd:dateTime .

oak:misconception-towns-cities-richest-people-society
  a oakcurric:Misconception ;
  oakcurric:statement "Towns and cities have always been where the richest people in society live."@en ;
  oakcurric:correction """For most of English history, the richest people were landowners and lived in the manor house of their manorial estate."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678047Z"^^xsd:dateTime .

oak:misconception-norman-castles-built-same-design
  a oakcurric:Misconception ;
  oakcurric:statement "All Norman castles were built to the same design."@en ;
  oakcurric:correction """In fact, although we learn about the classic motte-and-bailey castle (and maybe even make models of them in school), there was a very wide variety of castle designs in England and in Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678058Z"^^xsd:dateTime .

oak:misconception-women-usa-experienced-changes-same
  a oakcurric:Misconception ;
  oakcurric:statement "All women in the USA experienced changes in the same way during the 1920s."@en ;
  oakcurric:correction """The ways in which women experienced changes often differed depending on factors such as race, wealth and location."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678062Z"^^xsd:dateTime .

oak:misconception-improved-working-opportunities-women-african
  a oakcurric:Misconception ;
  oakcurric:statement """Improved working opportunities for women and African Americans represented an end to discrimination against them."""@en ;
  oakcurric:correction """African Americans and women continued to face discrimination in the workplace. Women entered 'male' jobs but were paid less than men and many employers still hired disproportionately low numbers of African Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678081Z"^^xsd:dateTime .

oak:misconception-england-almost-conquered
  a oakcurric:Misconception ;
  oakcurric:statement "England has almost never been conquered."@en ;
  oakcurric:correction """England was conquered repeatedly before and during the medieval period, and was even arguably conquered as late as 1688."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678085Z"^^xsd:dateTime .

oak:misconception-huguenots-separate-protestant-denomination-other
  a oakcurric:Misconception ;
  oakcurric:statement """Huguenots were a separate Protestant denomination from other Protestants in Euope."""@en ;
  oakcurric:correction """Huguenots were Calvinist Protestants, which was a very common form of Protestantism. The term 'Huguenot' merely means they were Protestants from France."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678139Z"^^xsd:dateTime .

oak:misconception-significant-tension-members-grand-alliance
  a oakcurric:Misconception ;
  oakcurric:statement """There was only significant tension between members of the Grand Alliance at the Potsdam Conference when the war had ended and Roosevelt had been replaced by Truman as US President."""@en ;
  oakcurric:correction """Although tensions increased significantly by the Potsdam Conference, there was a high level of mistrust between the members of the Grand Alliance from early on. This is illustrated by Stalin's concern about the delays in opening a second front."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678144Z"^^xsd:dateTime .

oak:misconception-marcher-earls-completely-independent-king
  a oakcurric:Misconception ;
  oakcurric:statement "The Marcher earls were completely independent of the king."@en ;
  oakcurric:correction """Although the Marcher earls had a lot of independence and special privileges, they were still vassals of the king and swore to obey him. Their feudal duties included providing the king with knights."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678162Z"^^xsd:dateTime .

oak:misconception-natural-features-england-havent-changed
  a oakcurric:Misconception ;
  oakcurric:statement "The natural features of England haven't changed much in 1000 years."@en ;
  oakcurric:correction """England has changed enormously in 1000 years! The coastline has shifted so that it would be unrecognisable for a traveller from 1000 years ago, and other natural features, such as The Fens, have shrunk and changed considerably."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678167Z"^^xsd:dateTime .

oak:misconception-reason-people-opposed-new-deal
  a oakcurric:Misconception ;
  oakcurric:statement """The only reason people opposed the New Deal was because it increased costs for the rich and wealthy."""@en ;
  oakcurric:correction """Radical opposition to the New Deal was based on the idea that it did not do enough to help the poor. Opposition from the Supreme Court was based on judgements that some aspects of the New Deal were unconstitutional."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678174Z"^^xsd:dateTime .

oak:misconception-sending-fyrd-defences-home-september
  a oakcurric:Misconception ;
  oakcurric:statement """Sending the fyrd defences home in September is evidence of Harold's poor decision making."""@en ;
  oakcurric:correction """In fact, Anglo-Saxon leaders had always struggled with the 60-day limit for the fyrd. Harold had actually kept the fyrd out for twice as long as usual: evidence of his impressive influence as a leader."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678181Z"^^xsd:dateTime .

oak:misconception-one-dimensional-view-william-violent
  a oakcurric:Misconception ;
  oakcurric:statement "The one-dimensional view of William as a violent conqueror."@en ;
  oakcurric:correction """In fact, William was very pious and he repented some of the atrocities he had committed during his reign and insisted his treasures should be used to rebuild some of the areas he had harried."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678185Z"^^xsd:dateTime .

oak:misconception-usa-considered-responsibility-protect-europe
  a oakcurric:Misconception ;
  oakcurric:statement """The USA always considered it had a responsibility to protect Europe from threats."""@en ;
  oakcurric:correction """Before the Second World War, the USA had a policy of isolationism which meant not getting involved in the affairs of other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678190Z"^^xsd:dateTime .

oak:misconception-migrants-empire-includes-travelled-far
  a oakcurric:Misconception ;
  oakcurric:statement """Migrants from the Empire only includes those who travelled from as far as Asia and Africa."""@en ;
  oakcurric:correction """As Ireland did not become part of Britain in 1801, many people considered Ireland a colony and therefore Irish migrants are often treated as migrants from within Britain's empire."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678197Z"^^xsd:dateTime .

oak:misconception-european-countries-created-colonies-africa
  a oakcurric:Misconception ;
  oakcurric:statement "European countries only created colonies in Africa and the Americas."@en ;
  oakcurric:correction "European countries set up colonies all over the world, including in Asia."@en ;
  dcterms:modified "2026-02-12T08:59:18.678289Z"^^xsd:dateTime .

oak:misconception-us-presidents-use-federal-intervention
  a oakcurric:Misconception ;
  oakcurric:statement "US presidents would only use federal intervention when pressured by the media."@en ;
  oakcurric:correction """Kennedy marked a change in the involvement of the president, as he was not pressured by the media to use federal intervention to support Meredith. Unlike in Little Rock, Kennedy's support came before the outbreak of violence from white Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678294Z"^^xsd:dateTime .

oak:misconception-one-cold-war-crisis-involving
  a oakcurric:Misconception ;
  oakcurric:statement """There was only one Cold War crisis involving Berlin: the USSR's blockade of Berlin in 1948 and the Berlin Airlift launched by the Western powers in response to this."""@en ;
  oakcurric:correction """Berlin was a source of conflict between the USA and the USSR from the start of the Cold War. The crisis that took place between 1958 and 1963 and resulted in the construction of the Berlin Wall is sometimes referred to as the Second Berlin Crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678300Z"^^xsd:dateTime .

oak:misconception-plantations-large-cash-crop-farms
  a oakcurric:Misconception ;
  oakcurric:statement "Plantations are large cash-crop farms found in the Americas."@en ;
  oakcurric:correction """Cash-crop plantations can be found all over the world, but the first plantations were established in Ireland. Protestants loyal to the monarch were 'planted' in Irish Catholic lands to help establish control of the area."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678358Z"^^xsd:dateTime .

oak:misconception-refugees-welcome-other-migrants-britain
  a oakcurric:Misconception ;
  oakcurric:statement """Refugees were more welcome than other migrants as Britain wanted to support the idea that they were a liberal and tolerant nation."""@en ;
  oakcurric:correction """Refugees were sometimes more welcome than other migrants. The British government was often careful with their criteria for who was classed as a refugee and, from the 1990s, introduced a number of laws to restrict access to Britain for refugees."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678362Z"^^xsd:dateTime .

oak:misconception-normans-reforms-church-specific-england
  a oakcurric:Misconception ;
  oakcurric:statement "The Normans reforms of the Church were specific to England."@en ;
  oakcurric:correction """The Church reforms were part of a much bigger European reform movement led by a succession of popes known as the Reform Papacy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678457Z"^^xsd:dateTime .

oak:misconception-roles-fixed-anglo-saxon-society
  a oakcurric:Misconception ;
  oakcurric:statement "Roles were fixed in Anglo-Saxon society - a peasant would always be a peasant."@en ;
  oakcurric:correction """Anglo-Saxon society was more open to social mobility: a hard-working peasant could gain more land and become a thegn, some slaves became free and an earl could even become king!"""@en ;
  dcterms:modified "2026-02-12T08:59:18.678472Z"^^xsd:dateTime .

oak:misconception-normans-destroyed-anglo-saxon-government
  a oakcurric:Misconception ;
  oakcurric:statement "That the Normans destroyed all Anglo-Saxon government."@en ;
  oakcurric:correction """Anglo-Saxon government systems were sophisticated, perhaps more developed than Normandy’s. The Normans retained and built on the existing Anglo-Saxon governmental institutions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678477Z"^^xsd:dateTime .

oak:misconception-students-fail-see-significance-admission
  a oakcurric:Misconception ;
  oakcurric:statement """Students might fail to see the significance of the admission by the police that they acted with racist prejudice."""@en ;
  oakcurric:correction """This was the first time the police had admitted to treating the black community unfairly and was a turning point in the development of civil rights."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678484Z"^^xsd:dateTime .

oak:misconception-medieval-sources-biased-events-record
  a oakcurric:Misconception ;
  oakcurric:statement "Medieval sources may be biased but the events they record did take place."@en ;
  oakcurric:correction """Medieval sources were influenced by classical authors, and events were often made up to match classical accounts - for example, great events being delayed because the wind was in the wrong direction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678580Z"^^xsd:dateTime .

oak:misconception-students-believe-pilgrimages-introduced-normans
  a oakcurric:Misconception ;
  oakcurric:statement "Some students may believe that pilgrimages were introduced by the Normans."@en ;
  oakcurric:correction """Christians have gone on pilgrimages since the 4th century, although the 'golden age' was from the early 11th to the 16th century."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678585Z"^^xsd:dateTime .

oak:misconception-students-believe-iron-curtain-real
  a oakcurric:Misconception ;
  oakcurric:statement """Students may believe that the Iron Curtain was a real barrier (often mixing it up with the Berlin Wall)."""@en ;
  oakcurric:correction """The Iron Curtain was not a real barrier but metaphor for the divide imposed between East and West by the USSR, first referred to in a speech by Churchill."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678657Z"^^xsd:dateTime .

oak:misconception-english-unprepared-williams-invasion
  a oakcurric:Misconception ;
  oakcurric:statement "The English were unprepared for William's invasion."@en ;
  oakcurric:correction """Harold led detailed preparations for the invasion, with those preparations delivering an army for the Battle of Hastings despite the disbanding of the southern fyrd and the previous formation of two fyrd armies to combat the earlier Viking invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678680Z"^^xsd:dateTime .

oak:misconception-monks-poor
  a oakcurric:Misconception ;
  oakcurric:statement "Monks were all poor."@en ;
  oakcurric:correction """Although individual monks gave up all their possessions, Norman monasteries were often extremely wealthy because they held very large amount of land granted to them by the king or Norman barons and knights."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678722Z"^^xsd:dateTime .

oak:misconception-normans-invented-romanesque-architecture
  a oakcurric:Misconception ;
  oakcurric:statement "The Normans invented Romanesque architecture."@en ;
  oakcurric:correction """The Normans were enthusiastic adopters of Romanesque building style, but it was developed in northern Italy and France, combining Roman features with elements of Byzantine design."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678727Z"^^xsd:dateTime .

oak:misconception-students-think-marcher-earls-governed
  a oakcurric:Misconception ;
  oakcurric:statement "Students may think that the Marcher earls governed their earldoms themselves."@en ;
  oakcurric:correction """In fact, the Marcher earls were busy men with important matters to deal with in Normandy and England. They appointed deputies, including sheriffs, to govern their earldoms in their absence."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678732Z"^^xsd:dateTime .

oak:misconception-real-areas-wilderness-left-england
  a oakcurric:Misconception ;
  oakcurric:statement """There were no real areas of wilderness left in England by the time of the Norman Conquest."""@en ;
  oakcurric:correction """The population of England in 1066 is generally estimated to have been about two million. The people of England were not evenly spread around the country however, and large parts of the land had no human habitation at all."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678736Z"^^xsd:dateTime .

oak:misconception-shareholders-speculators-lost-wall-street
  a oakcurric:Misconception ;
  oakcurric:statement "Only shareholders and speculators lost out from the Wall Street Crash."@en ;
  oakcurric:correction """Once speculators went bankrupt, they were unable to repay their debts to banks causing them to fail. Bank failures wiped out the savings of millions of Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678741Z"^^xsd:dateTime .

oak:misconception-richard-lionheart-one-greatest-english
  a oakcurric:Misconception ;
  oakcurric:statement "Richard the Lionheart was one of the greatest English kings."@en ;
  oakcurric:correction """Although he was king of England and was born in England, Richard almost certainly did not consider himself English. He never learnt the language and only spent a maximum of 6 months in England during his 10 year reign; he didn't like the weather."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678745Z"^^xsd:dateTime .

oak:misconception-european-migrants-said-migrated-similar
  a oakcurric:Misconception ;
  oakcurric:statement """All European migrants can be said to have migrated for similar reasons and therefore had similar experiences."""@en ;
  oakcurric:correction """While there were some similarities in patterns of migration, the experiences of migrants often depended largely on their religion and their relationship with authorities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678750Z"^^xsd:dateTime .

oak:misconception-jewish-people-migrated-england-worked
  a oakcurric:Misconception ;
  oakcurric:statement "All Jewish people who migrated to England worked as moneylenders."@en ;
  oakcurric:correction """Not all Jewish migrants took up jobs as moneylenders; many took up other jobs and assimilated into English society."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678755Z"^^xsd:dateTime .

oak:misconception-reform-monasteries-came-cluniac-order
  a oakcurric:Misconception ;
  oakcurric:statement "That all reform in monasteries came from the Cluniac order."@en ;
  oakcurric:correction """In fact, some Benedictine monasteries also introduced reform, and monasteries were reforming in 10th century Anglo-Saxon England well before the Cluniac order arrived in England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678784Z"^^xsd:dateTime .

oak:misconception-students-forget-use-sources-provided
  a oakcurric:Misconception ;
  oakcurric:statement """Students can forget to use the sources provided, and instead simply rely on their own knowledge."""@en ;
  oakcurric:correction """The historical environment questions are mainly source-based and therefore students should base their answers on the sources, using their knowledge to explain what is in the sources and to judge the utility of the sources."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678789Z"^^xsd:dateTime .

oak:misconception-people-underestimate-length-berlin-wall
  a oakcurric:Misconception ;
  oakcurric:statement """Some people underestimate the length of the Berlin Wall and believe that it only divided the city of Berlin."""@en ;
  oakcurric:correction """The Berlin Wall divided the city of Berlin but it also encircled the city. The iconic stretch of wall that divided Berlin was approximately 26 miles in length. The total length of the Berlin Wall was approximately 96 miles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678795Z"^^xsd:dateTime .

oak:misconception-strategic-defence-initiative-sdi-fully
  a oakcurric:Misconception ;
  oakcurric:statement """The Strategic Defence Initiative (SDI) was fully operational when it was announced by Reagan in 1983."""@en ;
  oakcurric:correction """Although they were technologically more advanced than the USSR, the USA did not have the necessary technology to launch SDI in 1983. Reagan hoped the USSR would attempt to compete and this would cause their struggling economy to collapse."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678800Z"^^xsd:dateTime .

oak:misconception-malcolm-x-founded-black-panther
  a oakcurric:Misconception ;
  oakcurric:statement "Malcolm X founded the Black Panther Party."@en ;
  oakcurric:correction """The ideas of Malcolm X in his later life would inspire the Black Power movement; this in turn inspired the Black Panther Party in the year after his death. The party was founded by Bobby Seale and Huey Newton."""@en ;
  dcterms:modified "2026-02-12T08:59:18.678948Z"^^xsd:dateTime .

oak:misconception-britain-involved-transatlantic-slave-trade
  a oakcurric:Misconception ;
  oakcurric:statement "Britain was always involved in the Transatlantic Slave Trade."@en ;
  oakcurric:correction """Britain became involved in the trade in the 1500s, initially selling enslaved people onto plantations in Spanish and Portuguese colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679223Z"^^xsd:dateTime .

oak:misconception-falkland-islands-uncontested-british-territory
  a oakcurric:Misconception ;
  oakcurric:statement "The Falkland Islands have always been uncontested British territory."@en ;
  oakcurric:correction """There is a complex and prolonged sovereignty dispute with Argentina over the Falkland Islands and there were once historical claims by Spain."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679300Z"^^xsd:dateTime .

oak:misconception-englands-monarchs-spoke-english-their
  a oakcurric:Misconception ;
  oakcurric:statement "England’s monarchs always spoke English as their first language."@en ;
  oakcurric:correction """In fact, after the Norman conquest it would take over 300 years for the monarch of England to speak English as their first language."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679304Z"^^xsd:dateTime .

oak:misconception-harold-godwinson-help-his-brother
  a oakcurric:Misconception ;
  oakcurric:statement "Harold Godwinson would help his brother Tostig."@en ;
  oakcurric:correction """Harold’s ambitions to be king meant he did little to help his brother Tostig. If Harold became king, he would want to avoid making enemies of Mercia and Northumbria. He wanted to show the Witan that he was loyal to England, beyond his family."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679309Z"^^xsd:dateTime .

oak:misconception-nixon-president-wanted-remove-us
  a oakcurric:Misconception ;
  oakcurric:statement "Nixon was the only president who wanted to remove US troops from Vietnam."@en ;
  oakcurric:correction """Kennedy and Johnson wanted the same, but, like Nixon, found themselves getting more involved in order to prop up the South Vietnamese govt."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679386Z"^^xsd:dateTime .

oak:misconception-allies-open-honest-other-friends
  a oakcurric:Misconception ;
  oakcurric:statement "Allies are open and honest with each other, as friends should be."@en ;
  oakcurric:correction """Countries break alliances frequently and regularly act against the interests of long-time allies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679435Z"^^xsd:dateTime .

oak:misconception-england-fortified-settlements-until-normans
  a oakcurric:Misconception ;
  oakcurric:statement "England did not have any fortified settlements until the Normans built castles."@en ;
  oakcurric:correction """In fact, Anglo-Saxon burhs were fortified settlements, built to protect towns from Viking attacks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679636Z"^^xsd:dateTime .

oak:misconception-large-scale-protests-mean-people
  a oakcurric:Misconception ;
  oakcurric:statement "Large-scale protests must mean that most people are against something."@en ;
  oakcurric:correction """A majority of people rarely, if ever, get involved in public protests, so we cannot draw absolute conclusions about what the majority thinks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679642Z"^^xsd:dateTime .

oak:misconception-gorbachev-succeeded-brezhnev-leader-soviet
  a oakcurric:Misconception ;
  oakcurric:statement "Gorbachev succeeded Brezhnev as leader of the Soviet Union in March 1985."@en ;
  oakcurric:correction """Brezhnev died in November 1982. Following his death, the Soviet Union was ruled by two leaders who were in poor health and ruled only briefly: Yuri Andropov (November 1982 - February 1984) and Konstantin Chernenko (February 1984 - March 1985)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679660Z"^^xsd:dateTime .

oak:misconception-collapse-soviet-union-happened-suddenly
  a oakcurric:Misconception ;
  oakcurric:statement "The collapse of the Soviet Union happened suddenly."@en ;
  oakcurric:correction """The collapse of the Soviet Union was a complex process that unfolded over several years, starting with political reforms under Mikhail Gorbachev in the late 1980s and culminating in the formal dissolution in December 1991."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679664Z"^^xsd:dateTime .

oak:misconception-historians-disagree-means-discussing-probably
  a oakcurric:Misconception ;
  oakcurric:statement """If historians disagree, it means what they are discussing probably never happened."""@en ;
  oakcurric:correction """Historians disagree about interpretations of an event: instead of historical evidence being about proving something to be true or false, it is much more about how strong the evidence is to support one interpretation over another."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679813Z"^^xsd:dateTime .

oak:misconception-black-power-movement-entirely-separate
  a oakcurric:Misconception ;
  oakcurric:statement "The Black Power movement was entirely separate from the civil rights movement."@en ;
  oakcurric:correction """Many of the leading figures of the Black Power movement began as civil rights activists, who had grown frustrated with the lack of progress and looked to more radical methods and beliefs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679905Z"^^xsd:dateTime .

oak:misconception-arms-race-made-superpowers-hostile
  a oakcurric:Misconception ;
  oakcurric:statement "The arms race only made the superpowers more hostile towards one another."@en ;
  oakcurric:correction """The high costs and growing power of nuclear weapons developments meant both the USSR and USA were interested in finding ways to improve relations between them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680062Z"^^xsd:dateTime .

oak:misconception-relatively-sources-norman-england-historians
  a oakcurric:Misconception ;
  oakcurric:statement """There are relatively few sources for Norman England, so historians have less to say about this period than later periods of English history."""@en ;
  oakcurric:correction """Historians have plenty to say about Norman England because they are able to interpret the sources available in many different ways to support many different theories."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680161Z"^^xsd:dateTime .

oak:misconception-controversies-conflicts-crown-church-specific
  a oakcurric:Misconception ;
  oakcurric:statement """The controversies and conflicts between the crown and the Church were specific to Norman England."""@en ;
  oakcurric:correction """In fact, the controversies and conflicts between the Church and the crown happened in many kingdoms in Europe, and were more severe than in England in particular cases, especially the Holy Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680266Z"^^xsd:dateTime .

oak:misconception-everybody-agreed-possession-nuclear-weapons
  a oakcurric:Misconception ;
  oakcurric:statement """Everybody agreed the possession of nuclear weapons made the world more dangerous."""@en ;
  oakcurric:correction """Many people argued that as the US and USSR both possessed nuclear weapons this deterred them from going to war with one another - otherwise they woudl afce mutually assured destruction."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680271Z"^^xsd:dateTime .

oak:misconception-william-knights-won-battle-hastings
  a oakcurric:Misconception ;
  oakcurric:statement """If William had more knights, he would have won the Battle of Hastings more quickly."""@en ;
  oakcurric:correction """Knights may have been less effective against the shield wall than infantry, because the unarmoured horses were vulnerable. They were probably much more effective in later stages of the battle, once the shield wall had been broken up."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680275Z"^^xsd:dateTime .

oak:misconception-cuban-missile-crisis-made-war
  a oakcurric:Misconception ;
  oakcurric:statement "The Cuban Missile Crisis made war more likely between the superpowers."@en ;
  oakcurric:correction """Both the US and USSR were shocked at how close they had come to war and were relieved to have avoided it. Further steps were agreed between both countries after the crisis had ended to make war less likely in future."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680280Z"^^xsd:dateTime .

oak:misconception-wars-won-battlefield
  a oakcurric:Misconception ;
  oakcurric:statement "Wars are only won on the battlefield."@en ;
  oakcurric:correction """A variety of factors influence the outcome of a war, such as a nation's economy, geography, and popular sentiment towards the war."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680304Z"^^xsd:dateTime .

oak:misconception-highly-trained-members-military-government
  a oakcurric:Misconception ;
  oakcurric:statement "Highly-trained members of the military and government tend not to make mistakes."@en ;
  oakcurric:correction """Everyone is capable of making errors, sometimes big and far-reaching ones, especially if they are under a great deal of stress."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680546Z"^^xsd:dateTime .

oak:misconception-1950s-onwards-ussrs-human-rights
  a oakcurric:Misconception ;
  oakcurric:statement "From the 1950s onwards, the USSR's human rights record continually improve."@en ;
  oakcurric:correction """Under Khrushchev, more respect was shown for political and social freedoms but these restrictions were tightened again once Brezhnev took power in 1964."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680867Z"^^xsd:dateTime .

oak:misconception-us-large-powerful-lose-war
  a oakcurric:Misconception ;
  oakcurric:statement "The US has always been too large and powerful to lose a war."@en ;
  oakcurric:correction """The majority of people regard the Vietnam War as a loss for the US: they did not achieve their stated goal of containing communism."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680872Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-monarch-power
  a oakcurric:Misconception ;
  oakcurric:statement "An Anglo-Saxon monarch had all the power."@en ;
  oakcurric:correction """In fact, Anglo-Saxon nobles could force their monarchs to do things they did not want to do. For example, King Edward was forced to allow the House of Godwin back from exile and restore them to their earldoms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681261Z"^^xsd:dateTime .

oak:misconception-know-sure-william-used-feigned
  a oakcurric:Misconception ;
  oakcurric:statement """We know for sure that William used a feigned retreat tactic at the Battle of Hastings."""@en ;
  oakcurric:correction """In fact, the best sources we have for the battle say different things, for example, that a real retreat gave William the idea of using feigned retreats, or that the 'real' retreat was planned all along."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681409Z"^^xsd:dateTime .

oak:misconception-confusion-guerilla-gorilla
  a oakcurric:Misconception ;
  oakcurric:statement "There is often confusion between guerilla and gorilla!"@en ;
  oakcurric:correction """Same sound, different spelling, very different meaning!  'Guerilla' comes from the Spanish word 'guerra', meaning 'war'."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681452Z"^^xsd:dateTime .

oak:misconception-ussr-immediately-refused-cooperate-usa
  a oakcurric:Misconception ;
  oakcurric:statement """The USSR immediately refused to cooperate with the USA after a U2 was show down in May 1960."""@en ;
  oakcurric:correction """The USSR still attended the Paris Summit but walked out when the US refused to apologise for spying on it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681645Z"^^xsd:dateTime .

oak:misconception-william-copied-landholding-system-norman
  a oakcurric:Misconception ;
  oakcurric:statement "William copied the landholding system for Norman England from Normandy."@en ;
  oakcurric:correction """Landholding in Normandy was different from landholding in Norman England. William was not the owner of all the land in Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681705Z"^^xsd:dateTime .

oak:misconception-fyrd-low-military-value-because
  a oakcurric:Misconception ;
  oakcurric:statement "The fyrd had low military value because it was made up of untrained peasants."@en ;
  oakcurric:correction """The general fyrd had a lower military value in some contexts (though guarding a coastline might not have been one of them), but the select fyrd meant Anglo-Saxon fyrd armies could include trained and well-equipped men as well."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681711Z"^^xsd:dateTime .

oak:misconception-limited-number-communists-usa-meant
  a oakcurric:Misconception ;
  oakcurric:statement """The limited number of communists in the USA meant few people were affected by the Red Scare."""@en ;
  oakcurric:correction """Millions of Americans were investigated during the Red Scare and thousands lost their jobs and social standing due to suspicions about their political beliefs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681715Z"^^xsd:dateTime .

oak:misconception-war-ended-50-years-ago
  a oakcurric:Misconception ;
  oakcurric:statement "A war that ended 50 years ago does not affect anybody any more."@en ;
  oakcurric:correction """Much of the Vietnamese landscape and people are still impacted or recovering from the effects of the war even today."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681771Z"^^xsd:dateTime .

oak:misconception-britain-competing-european-powers-met
  a oakcurric:Misconception ;
  oakcurric:statement """Britain and competing European powers met at the Berlin Conference before the scramble for Africa had begun."""@en ;
  oakcurric:correction """Britain and competing European powers had already been 'scrambling' for Africa for the majority of the 19th century. The Berlin Conference was an attempt to put an end to the fighting between European powers over Africa's land and resources."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681792Z"^^xsd:dateTime .

oak:misconception-ussr-experienced-benefits-korean-war
  a oakcurric:Misconception ;
  oakcurric:statement "The USSR only experienced benefits from the Korean War."@en ;
  oakcurric:correction """Some new strains were created in Sino-Soviet relations due to limits on assistance from the USSR which were intended to avoid a direct conflict between the Soviets and Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682014Z"^^xsd:dateTime .

oak:misconception-monarch-dies-their-eldest-child
  a oakcurric:Misconception ;
  oakcurric:statement """After a monarch dies, their eldest child automatically becomes monarch after them."""@en ;
  oakcurric:correction """In Anglo-Saxon England, an heir was always in a strong position, but even if there was an heir, the Witan could use their influence for someone else to be made monarch - if, for example, the heir was too young."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682053Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-monarchs-great-warriors
  a oakcurric:Misconception ;
  oakcurric:statement "Anglo-Saxon monarchs had to be great warriors to be made king."@en ;
  oakcurric:correction """In fact some monarchs, such as Edward the Confessor, were not warriors but instead very religious men whose faith inspired others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682096Z"^^xsd:dateTime .

oak:misconception-work-martin-luther-king-ended
  a oakcurric:Misconception ;
  oakcurric:statement "The work of Martin Luther King ended with the Voting Right Acts in 1965."@en ;
  oakcurric:correction """With continued violence, rioting and protests, King continued to fight for change in the North. However, he faced greater opposition than he did in the South."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682137Z"^^xsd:dateTime .

oak:misconception-us-assistance-south-vietnam-immediately
  a oakcurric:Misconception ;
  oakcurric:statement """US assistance to South Vietnam immediately included the deployment of American ground troops."""@en ;
  oakcurric:correction """The US began supporting South Vietnam in 1954 but did not deploy US ground troops there until 1965."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682198Z"^^xsd:dateTime .

oak:misconception-norman-conquest-brutal-military-occupation
  a oakcurric:Misconception ;
  oakcurric:statement """The Norman conquest was a brutal military occupation which resulted in wholescale change of the English Church."""@en ;
  oakcurric:correction """Whilst there were significant changes, the English Church retained its basic structure and liturgy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682246Z"^^xsd:dateTime .

oak:misconception-economic-impacts-wartime-production-confined
  a oakcurric:Misconception ;
  oakcurric:statement """The economic impacts of wartime production were confined to weapons manufacturers."""@en ;
  oakcurric:correction """Wartime demand extended to a wide range of goods including weapons, foodstuffs, fuel and raw materials. This led to many sectors of the US economy benefitting from wartime production."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682385Z"^^xsd:dateTime .

oak:misconception-communist-countries-members-warsaw-pact
  a oakcurric:Misconception ;
  oakcurric:statement "All communist countries were members of the Warsaw Pact."@en ;
  oakcurric:correction """The Warsaw Pact was primarily a European military alliance so non-European communist countries like China and Cuba were not members. Some European countries like Yugoslavia were never members while others joined and then left like Albania in 1968."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682396Z"^^xsd:dateTime .

oak:misconception-result-legal-changes-significant-progress
  a oakcurric:Misconception ;
  oakcurric:statement """As a result of legal changes, there was significant progress for all black Americans by 1960."""@en ;
  oakcurric:correction """Legal changes led to some change for black Americans, although a significant amount of opposition from within and outside the government led to limited change for most black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682410Z"^^xsd:dateTime .

oak:misconception-montgomery-bus-boycott-successful-peaceful
  a oakcurric:Misconception ;
  oakcurric:statement """The Montgomery Bus Boycott was a successful, peaceful boycott that was carried out with minimal resistance."""@en ;
  oakcurric:correction """The boycott was a peaceful means of protest, but continued despite huge resistance throughout Montgomery. Those who participated risked arrest, unemployed and sometimes their lives."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682414Z"^^xsd:dateTime .

oak:misconception-soviet-missile-bases-cuba-important
  a oakcurric:Misconception ;
  oakcurric:statement """The Soviet missile bases in Cuba were important because they provided the USSR with the ability to strike the USA with nuclear weapons."""@en ;
  oakcurric:correction """The USSR had ICBMs which meant they already had the ability to attack the USA with nuclear weapons, however these were expensive and the USA had more. The USSR had more IRBMs, so placing these missiles in Cuba gave them an important advantage."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682421Z"^^xsd:dateTime .

oak:misconception-vikings-same-experience-england-adopting
  a oakcurric:Misconception ;
  oakcurric:statement """All Vikings had the same experience of England, adopting very little of the local culture."""@en ;
  oakcurric:correction """The Viking experience of England was nuanced, depending on where they settled some experienced great hostility. Some were also able to adopt local Christian practices while maintaining some of their pagan practices."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682449Z"^^xsd:dateTime .

oak:misconception-migrants-18th-19th-centuries-migrated
  a oakcurric:Misconception ;
  oakcurric:statement """All migrants in the 18th and 19th centuries migrated for economic reasons and led successful lives in Britain as a result."""@en ;
  oakcurric:correction """Although most migrants settled for economic reasons, the expansion of the British Empire and greater civil liberties also attracted a greater number of migrants in this period."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682465Z"^^xsd:dateTime .

oak:misconception-village-life-same-norman-england
  a oakcurric:Misconception ;
  oakcurric:statement "Village life was the same all over Norman England."@en ;
  oakcurric:correction """While there were many common features, the Viking settlement of the Danelaw meant that freemen in villages in the east were much more independent of the lord of their village's manor than in other parts of the country."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682491Z"^^xsd:dateTime .

oak:misconception-white-tower-bustling-royal-activity
  a oakcurric:Misconception ;
  oakcurric:statement "The White Tower was always bustling with royal activity."@en ;
  oakcurric:correction """Royal residents were seldom present. Most of the time, the White Tower was managed by the keeper and housed a garrison of soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682495Z"^^xsd:dateTime .

oak:misconception-ussr-believe-usa-bothered-nuclear
  a oakcurric:Misconception ;
  oakcurric:statement """The USSR did not believe that the USA would be bothered by nuclear missiles in Cuba."""@en ;
  oakcurric:correction """The Soviets were aware that missile deployments to Cuba could trigger a crisis but believed they could help resolve the balance of power and deter any American attacks on Cuba."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682502Z"^^xsd:dateTime .

oak:misconception-germans-strongly-supported-nazis
  a oakcurric:Misconception ;
  oakcurric:statement "Most Germans strongly supported the Nazis."@en ;
  oakcurric:correction """Many complied out of fear, peer pressure, or survival - not necessarily belief. Resistance was dangerous, but still present in different forms across society."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682507Z"^^xsd:dateTime .

oak:misconception-people-think-survey-domesday-book
  a oakcurric:Misconception ;
  oakcurric:statement "People think the survey and Domesday Book are one and the same thing."@en ;
  oakcurric:correction """In fact, the survey was ordered in 1085, and later compiled into what became known as Domesday Book."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682511Z"^^xsd:dateTime .

oak:misconception-norman-conquest-fully-achieved-victory
  a oakcurric:Misconception ;
  oakcurric:statement "The Norman conquest was fully achieved by the victory at the Battle of Hastings."@en ;
  oakcurric:correction """In reality, there were many defiant Anglo-Saxons ready to carry on fighting and it took time for William to gain meaningful control over a hostile Anglo-Saxon population."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682559Z"^^xsd:dateTime .

oak:misconception-civil-rights-movement-co-ordinated
  a oakcurric:Misconception ;
  oakcurric:statement """The civil rights movement was always co-ordinated and led by older men and women."""@en ;
  oakcurric:correction """In the 1960s, there was a shift in the civil rights movement as students began to take a leading role in the fight against racial injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682563Z"^^xsd:dateTime .

oak:misconception-colonial-soldiers-joined-british-war
  a oakcurric:Misconception ;
  oakcurric:statement """Colonial soldiers joined the British war effort in both world wars, out of a sense of nationalism and pride for their 'motherland'."""@en ;
  oakcurric:correction """Colonial soldiers had often already been part of standing armies that were ordered to join the war effort, and by 1939 many colonial soldiers were only fighting in the hope that it might win them independence from the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682568Z"^^xsd:dateTime .

oak:misconception-pupils-likely-unaware-laws-protecting
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils are likely to be unaware that laws protecting UK citizens against discrimination did not start until mid-60s."""@en ;
  oakcurric:correction """Prior to the Race Relations Act 1965, it was possible to discriminate against black people, for example, refuse to serve them. This was extended in 1968 to include discrimination in housing and education."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682590Z"^^xsd:dateTime .

oak:misconception-students-believe-rationing-britain-ww2
  a oakcurric:Misconception ;
  oakcurric:statement "Students may believe that there was only rationing in Britain during WW2."@en ;
  oakcurric:correction "Rationing continued until 1954."@en ;
  dcterms:modified "2026-02-12T08:59:18.682630Z"^^xsd:dateTime .

oak:misconception-ussr-made-compromises-crisis
  a oakcurric:Misconception ;
  oakcurric:statement "Only the USSR made compromises during the crisis."@en ;
  oakcurric:correction """Both superpowers agreed to compromises in order to avoid war and resolve the crisis. Soviet missiles were withdrawn from Cuba whilst the US promised not to invade Cuba and to withdraw its own missiles from Turkey."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682675Z"^^xsd:dateTime .

oak:misconception-discrimination-exclusion-opportunities-migrants-face
  a oakcurric:Misconception ;
  oakcurric:statement """The discrimination and exclusion from opportunities that migrants sometimes face is just something these communities have to accept."""@en ;
  oakcurric:correction """In fact, migrants set up self-help schemes and organise their own resources to ensure discrimination and lack of government help do not hold back their community and especially their children's access to opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682680Z"^^xsd:dateTime .

oak:misconception-gorbachevs-reforms-intended-bring-end
  a oakcurric:Misconception ;
  oakcurric:statement """Gorbachev's reforms were intended to bring an end to communism and end Soviet control over Eastern Europe."""@en ;
  oakcurric:correction """Gorbachev intended his reforms to strengthen communism both within the Soviet Union and its satellite states in Eastern Europe, however, once reform started in Eastern Europe, Gorbachev was unable to contain it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682684Z"^^xsd:dateTime .

oak:misconception-william-used-violence-control-england
  a oakcurric:Misconception ;
  oakcurric:statement "William always used violence to control England."@en ;
  oakcurric:correction """Although violence was a recurring tactic of William's, he also allowed some Anglo-Saxons to keep some of their land and was willing to negotiate and pay the Danes to leave England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682694Z"^^xsd:dateTime .

oak:misconception-source-limitation-reliable-useful-historical
  a oakcurric:Misconception ;
  oakcurric:statement """If a source has a limitation then it is not reliable or useful for a historical study."""@en ;
  oakcurric:correction """All sources have limitations as well as strengths, which historians take account of, and does not mean that the source should not be used by a historian."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682700Z"^^xsd:dateTime .

oak:misconception-focus-new-deal-create-new
  a oakcurric:Misconception ;
  oakcurric:statement "The only focus of the New Deal was to create new jobs and reduce unemployment."@en ;
  oakcurric:correction """Relief and reform were also important aims of the New Deal. Major policies like the Emergency Banking Act and Social Security Act were more concerned with reform and relief, respectively, than job creation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682732Z"^^xsd:dateTime .

oak:misconception-england-invaded-norman-conquest
  a oakcurric:Misconception ;
  oakcurric:statement "England had not been invaded before the Norman Conquest."@en ;
  oakcurric:correction """Britain had been invaded many times before the Norman Conquest: by the Romans, the tribes known as Angles and Saxons and by the Vikings."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682737Z"^^xsd:dateTime .

oak:misconception-church-leaders-role-anglo-saxon
  a oakcurric:Misconception ;
  oakcurric:statement "Church leaders had no role in how Anglo-Saxon England was governed."@en ;
  oakcurric:correction """Archbishops, bishops and other Church leaders could be part of the Witan, and that meant they were involved in advising the monarch about the government of Anglo-Saxon England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682744Z"^^xsd:dateTime .

oak:misconception-weimar-germany-completely-free-modernist
  a oakcurric:Misconception ;
  oakcurric:statement "Weimar Germany was a completely free and modernist society."@en ;
  oakcurric:correction """While it was a hub of cultural experimentation, it was also deeply divided, with strong conservative resistance and widespread political unrest. Many Germans viewed the cultural changes as dangerous and sought to restore traditional values."""@en ;
  dcterms:modified "2026-02-12T08:59:18.683166Z"^^xsd:dateTime .

oak:misconception-germany-formally-lost-first-world
  a oakcurric:Misconception ;
  oakcurric:statement """Germany formally lost the First World War in the traditional sense, with a decisive military defeat."""@en ;
  oakcurric:correction """Germany was not defeated in battle, it sought peace and agreed to an armistice. The German military leadership recognised that the war was unwinnable due to resource shortages, economic collapse, and the deteriorating morale of troops and citizens."""@en ;
  dcterms:modified "2026-02-12T08:59:18.683375Z"^^xsd:dateTime .

oak:misconception-belief-stab-back-theory-based
  a oakcurric:Misconception ;
  oakcurric:statement "The belief that the 'stab-in-the-back' theory was based on factual evidence."@en ;
  oakcurric:correction """The theory was a narrative promoted by the military elite to distance themselves from the Armistice surrender. Germany's defeat was primarily due to military exhaustion and economic collapse, not treachery by Weimar politicians."""@en ;
  dcterms:modified "2026-02-12T08:59:18.683517Z"^^xsd:dateTime .

oak:misconception-hitler-already-powerful-dictator-1934
  a oakcurric:Misconception ;
  oakcurric:statement "Hitler was already an all-powerful dictator by 1934."@en ;
  oakcurric:correction """While Hitler had crushed political opposition, the military remained a powerful, independent force. The SA purge was crucial to win over the army, which still had the power to challenge him."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684315Z"^^xsd:dateTime .

oak:misconception-kaiser-simply-order-naval-expansion
  a oakcurric:Misconception ;
  oakcurric:statement "The Kaiser could simply order naval expansion without resistance."@en ;
  oakcurric:correction """In reality, the Kaiser needed Reichstag approval for funding, so winning public support was a crucial step in pressuring parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684372Z"^^xsd:dateTime .

oak:misconception-pupils-think-unemployed-germans-turned
  a oakcurric:Misconception ;
  oakcurric:statement "Pupils may think that most unemployed Germans turned to communism."@en ;
  oakcurric:correction """While the Communist Party gained support, many Germans, especially the middle class and business owners, feared communism and instead supported the Nazis as a defence against a potential revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684520Z"^^xsd:dateTime .

oak:misconception-everyone-benefited-nazi-economic-policies
  a oakcurric:Misconception ;
  oakcurric:statement "Everyone benefited from Nazi economic policies."@en ;
  oakcurric:correction """Reinforce that benefits were selective, often dependent on loyalty, and many gains were cancelled out by longer hours and lost freedoms."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684569Z"^^xsd:dateTime .

oak:misconception-proportional-representation-purely-positive-step
  a oakcurric:Misconception ;
  oakcurric:statement """Proportional representation was purely a positive step forward because it gave a voice to smaller political parties."""@en ;
  oakcurric:correction """In fact, proportional representation led to fragmentation, with many small parties gaining seats in the Reichstag. This made it difficult to pass laws because no single party had a majority."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684685Z"^^xsd:dateTime .

oak:misconception-final-solution-decided-once
  a oakcurric:Misconception ;
  oakcurric:statement "The Final Solution was decided all at once."@en ;
  oakcurric:correction """It was an evolving process. Historians have debated whether genocide was inevitable from 1933 — policies escalated over time, with many historians seeing Wannsee as marking the coordination point, not the start."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684705Z"^^xsd:dateTime .

oak:misconception-people-known-hitler-once-power
  a oakcurric:Misconception ;
  oakcurric:statement "People “should have known” what Hitler would do once in power."@en ;
  oakcurric:correction """In reality, many elites and citizens saw the Nazis as a lesser evil amid crisis — not as future dictators. The horror of what was to come wasn’t yet clear to them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684718Z"^^xsd:dateTime .

oak:misconception-religious-leaders-opposed-nazis
  a oakcurric:Misconception ;
  oakcurric:statement "All religious leaders opposed the Nazis."@en ;
  oakcurric:correction """In reality, many remained silent or even cooperated, hoping to protect their institutions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684723Z"^^xsd:dateTime .

oak:misconception-nazi-concentration-camps-extermination-camps
  a oakcurric:Misconception ;
  oakcurric:statement "Nazi concentration camps and extermination camps were the same thing."@en ;
  oakcurric:correction """Concentration camps were used for imprisonment, forced labour and punishment, not initially for mass murder. Extermination camps, built later, were designed specifically for killing on an industrial scale."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684741Z"^^xsd:dateTime .

oak:misconception-nazis-gained-power-fear-intimidation
  a oakcurric:Misconception ;
  oakcurric:statement "The Nazis only gained power through fear and intimidation."@en ;
  oakcurric:correction """In reality, while violence played a role, their rise was also driven by economic despair, propaganda, Hitler’s appeal, and democratic failures. Many Germans voted for them willingly, believing they offered hope and stability."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684773Z"^^xsd:dateTime .

oak:misconception-weimar-republics-reliance-freikorps-suggest
  a oakcurric:Misconception ;
  oakcurric:statement """The Weimar Republic’s reliance on the Freikorps might suggest that the government supported right-wing ideologies."""@en ;
  oakcurric:correction """The Weimar Government used the Freikorps out of desperation to suppress left-wing uprisings, but this reliance highlighted its inability to maintain order independently, rather than an alignment with right-wing ideologies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684778Z"^^xsd:dateTime .

oak:misconception-students-believe-germany-fully-mobilised
  a oakcurric:Misconception ;
  oakcurric:statement """Students may believe Germany fully mobilised its population, including women, like the Allies did."""@en ;
  oakcurric:correction "Nazi ideology restricted women's roles in industry, despite labour shortages."@en ;
  dcterms:modified "2026-02-12T08:59:18.684787Z"^^xsd:dateTime .

oak:misconception-nazis-completely-solved-unemployment-revived
  a oakcurric:Misconception ;
  oakcurric:statement "The Nazis completely solved unemployment and revived the economy."@en ;
  oakcurric:correction """While official unemployment figures dropped dramatically, some of this was due to manipulated statistics and forced labour schemes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684852Z"^^xsd:dateTime .

oak:misconception-everyone-germany-fully-believed-nazi
  a oakcurric:Misconception ;
  oakcurric:statement "Everyone in Germany fully believed the Nazi propaganda."@en ;
  oakcurric:correction """While some people genuinely believed, many conformed due to fear, peer pressure, or habit. Propaganda created surface unity - not universal belief."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684856Z"^^xsd:dateTime .

oak:misconception-hitler-invented-antisemitism
  a oakcurric:Misconception ;
  oakcurric:statement "Hitler invented antisemitism."@en ;
  oakcurric:correction """Antisemitism had deep roots across Europe and the wider world long before Hitler. The Nazis built on these longstanding prejudices, turning them into official state policy and using them to justify persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684894Z"^^xsd:dateTime .

oak:misconception-enabling-act-passed-fairly
  a oakcurric:Misconception ;
  oakcurric:statement "The Enabling Act was passed fairly."@en ;
  oakcurric:correction """The vote was deeply manipulated: communist Reichstag members were banned, others intimidated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684898Z"^^xsd:dateTime .

oak:misconception-germany-existed-one-country-existed
  a oakcurric:Misconception ;
  oakcurric:statement """Germany has always existed as one country, or has existed in its current form for a long time."""@en ;
  oakcurric:correction """Before 1871, 'Germany' did not exist as a single nation. It was a collection of over 30 independent, mostly German-speaking states, each with its own ruler."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684903Z"^^xsd:dateTime .

oak:misconception-students-think-youth-blindly-accepted
  a oakcurric:Misconception ;
  oakcurric:statement "Students may think all youth blindly accepted Nazi ideas."@en ;
  oakcurric:correction """While many participated, some - like Sophie Scholl - resisted. Peer pressure, fear, and excitement all played a role."""@en ;
  dcterms:modified "2026-02-12T08:59:18.684914Z"^^xsd:dateTime .

oak:misconception-pupils-assume-concentration-camps-period
  a oakcurric:Misconception ;
  oakcurric:statement """Pupils may assume that all concentration camps in this period were death camps like Auschwitz."""@en ;
  oakcurric:correction """Emphasise that early camps (1933–1939) were brutal prisons for political opponents and ‘undesirables’, but were not yet part of a systematic extermination programme. The Holocaust’s industrial death camps came later."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685009Z"^^xsd:dateTime .

oak:misconception-spd-genuine-power-becoming-largest
  a oakcurric:Misconception ;
  oakcurric:statement "The SPD had genuine power after becoming the largest party in the Reichstag."@en ;
  oakcurric:correction """The Reichstag could debate and vote on budgets, but the Kaiser chose the chancellor, controlled the military and could close the Reichstag at will. Foreign and military policy stayed entirely in his hands, so real political power never shifted."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685055Z"^^xsd:dateTime .

oak:misconception-women-opposed-nazi-policies
  a oakcurric:Misconception ;
  oakcurric:statement "All women opposed Nazi policies."@en ;
  oakcurric:correction """Women's experiences under Nazi rule varied: some embraced traditional roles and rewards, while others resisted and faced punishment, showing a complex, not uniform, response to Nazi policies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685064Z"^^xsd:dateTime .

oak:misconception-hyperinflation-affected-everyone-equally
  a oakcurric:Misconception ;
  oakcurric:statement "Hyperinflation affected everyone equally."@en ;
  oakcurric:correction """Some people, like businessmen who hoarded essentials to sell at inflated prices, profited during the crisis. Meanwhile, many middle-class Germans saw their savings wiped out and were forced to barter for survival."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685240Z"^^xsd:dateTime .

oak:misconception-weimar-republics-golden-age-benefited
  a oakcurric:Misconception ;
  oakcurric:statement "The Weimar Republic’s 'Golden Age' benefited all Germans equally."@en ;
  oakcurric:correction """This period brought economic growth, higher wages and social reforms, but not all Germans benefited equally. Many still faced poverty, unemployment and housing struggles. Conservatives also opposed cultural changes, leading to social tensions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685250Z"^^xsd:dateTime .

oak:misconception-lean-years-meant-nazis-completely
  a oakcurric:Misconception ;
  oakcurric:statement """The 'lean years' meant the Nazis were completely unsuccessful and struggling in every way."""@en ;
  oakcurric:correction """The ‘lean years’ mainly refers to the Nazis’ limited electoral success. While they weren’t winning many votes, they were strengthening their organisation, refining propaganda and gaining rural support. These years were crucial for their later rise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685651Z"^^xsd:dateTime .

oak:misconception-kellogg-briand-pact-1928-legally
  a oakcurric:Misconception ;
  oakcurric:statement """The Kellogg-Briand Pact of 1928 was a legally binding agreement that could prevent all future wars."""@en ;
  oakcurric:correction """The pact lacked enforcement mechanisms and relied on goodwill, making it more symbolic than practical."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685682Z"^^xsd:dateTime .

oak:misconception-south-vietnam-needed-us-troops
  a oakcurric:Misconception ;
  oakcurric:statement """South Vietnam needed US troops because they didn't have much of an army of their own."""@en ;
  oakcurric:correction """The South Vietnamese Army was one of the largest in the world. What they lacked was modern equipment and training."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685753Z"^^xsd:dateTime .

oak:misconception-munich-putsch-immediate-success-leading
  a oakcurric:Misconception ;
  oakcurric:statement "The Munich Putsch was an immediate success, leading to Hitler’s rise to power."@en ;
  oakcurric:correction """The Munich Putsch was a failure in the short-term - Hitler was arrested and the Nazi Party was banned. However, in the long-term, the event gave Hitler national attention and led him to change his strategy, focusing on gaining power legally."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685761Z"^^xsd:dateTime .

oak:misconception-germanys-recovery-1920s-completely-solved
  a oakcurric:Misconception ;
  oakcurric:statement """Germany's recovery in the 1920s completely solved its economic problems and secured long-term stability."""@en ;
  oakcurric:correction """Much of the recovery depended on American loans. What happens to Germany’s economy if those loans are withdrawn or if the US faces its own crisis? This shows how fragile the recovery really was."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685779Z"^^xsd:dateTime .

oak:misconception-hitlers-rise-power-purely-due
  a oakcurric:Misconception ;
  oakcurric:statement "Hitler's rise to power was purely due to his use of violence and intimidation."@en ;
  oakcurric:correction """While violence and intimidation played a role, Hitler’s personal appeal was a major factor in attracting support. He was a highly skilled public speaker and capable of delivering passionate speeches that resonated with many Germans."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685808Z"^^xsd:dateTime .

oak:misconception-ussr-favout-us-decision-improve
  a oakcurric:Misconception ;
  oakcurric:statement """The USSR was in favout of the US decision to improve relations with communist China."""@en ;
  oakcurric:correction """Because of the Sino-Soviet split, the Soviets worried that improved US-China relations might lead them to form an anti-Soviet alliance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685869Z"^^xsd:dateTime .

oak:misconception-viet-minh-gained-full-control
  a oakcurric:Misconception ;
  oakcurric:statement "The Viet Minh gained full control over Vietnam after defeating the French."@en ;
  oakcurric:correction """Vietnam was divided in two at the 1954 Geneva Conference, leaving the Viet Minh only in control of the north."""@en ;
  dcterms:modified "2026-02-12T08:59:18.685948Z"^^xsd:dateTime .

oak:misconception-us-soldiers-highly-trained-highly
  a oakcurric:Misconception ;
  oakcurric:statement "US soldiers are highly trained, highly motivated troops."@en ;
  oakcurric:correction """Conscription generally offers a larger fighting force at the expense of a decline in quality - not everyone called to serve wants to be there."""@en ;
  dcterms:modified "2026-02-12T08:59:18.686053Z"^^xsd:dateTime .

oak:misconception-change-medieval-surgery
  a oakcurric:Misconception ;
  oakcurric:statement "There was no change in medieval surgery."@en ;
  oakcurric:correction """New developments did occur, such as the use of opium as an anaesthetic and wine to use against infection, but the impact of these was limited."""@en ;
  dcterms:modified "2026-02-12T08:59:18.692892Z"^^xsd:dateTime .

oak:misconception-british-sources-imperial-expansion-positive
  a oakcurric:Misconception ;
  oakcurric:statement "All British sources on imperial expansion were positive."@en ;
  oakcurric:correction """Not all British sources on imperial expansion were positive. There was nuance due to British awareness of the realities of empire. However, British sources are more likely to be positive in outlook regarding British imperial expansion."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693090Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-monasteries-followed-same
  a oakcurric:Misconception ;
  oakcurric:statement """That Anglo-Saxon monasteries all followed the same rules, as set out by St Benedict."""@en ;
  oakcurric:correction """In fact, the abbot of a monastery was able to decide what the rules of their monastery should be, so that there was a lot of variation between monasteries."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693096Z"^^xsd:dateTime .

oak:misconception-bayeux-tapestry-created-franco-normans
  a oakcurric:Misconception ;
  oakcurric:statement "The Bayeux Tapestry was created by Franco-Normans in Bayeux."@en ;
  oakcurric:correction """The Bayeux Tapestry was commissioned by Odo, the Bishop of Bayeux, for Bayeux Cathedral, but historians are now almost certain that it was created in Canterbury by English seamstresses."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693101Z"^^xsd:dateTime .

oak:misconception-foreign-aid-support-packages-instance
  a oakcurric:Misconception ;
  oakcurric:statement """Foreign aid support packages, for instance Marshall Aid, are made up of just money."""@en ;
  oakcurric:correction """Equipment such as heavy machinery or weapons, natural resources such as coal, as well as money, make up foreign aid support packages."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700057Z"^^xsd:dateTime .

oak:misconception-saints-celebrated-modern-britain
  a oakcurric:Misconception ;
  oakcurric:statement "That saints have always been celebrated as they are in modern Britain."@en ;
  oakcurric:correction """In fact, medieval saints established a cult with many people believing that a prayer close to a saints' relics provided the best chance of help or healing."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700119Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-clergy-religious
  a oakcurric:Misconception ;
  oakcurric:statement "The Anglo-Saxon clergy were not religious."@en ;
  oakcurric:correction """While the Norman reformers viewed many Anglo-Saxon clergy as unsuitable due to their secular lifestyles, this does not mean all were irreligious."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700328Z"^^xsd:dateTime .

oak:misconception-conquerors-normans-make-changes-wanted
  a oakcurric:Misconception ;
  oakcurric:statement "As conquerors, the Normans could make any changes they wanted to."@en ;
  oakcurric:correction """The Normans were greatly outnumbered in England and William hoped to convince most English people that his was going to rule in the same way as King Edward the Confessor."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700365Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-church-old-fashioned
  a oakcurric:Misconception ;
  oakcurric:statement "The Anglo-Saxon Church was old-fashioned and corrupt."@en ;
  oakcurric:correction """The Normans were keen to present the Anglo-Saxon Church that way, but Edward the Confessor had kept up with reforms from the rest of Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700377Z"^^xsd:dateTime .

oak:misconception-priory-religious-function-norman-england
  a oakcurric:Misconception ;
  oakcurric:statement "A priory would only have had a religious function in Norman England."@en ;
  oakcurric:correction """In fact, the Normans used religion extensively in gaining political, social, cultural and economic control over England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700381Z"^^xsd:dateTime .

oak:misconception-racial-tension-issue-african-americans
  a oakcurric:Misconception ;
  oakcurric:statement "Racial tension was only an issue for African Americans in the 1920s."@en ;
  oakcurric:correction """In both the North and South, Catholics, Jews and recently arrived immigrants frequently experienced prejudice, discrimination and even violence from WASPs, just as African Americans did."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700387Z"^^xsd:dateTime .

oak:misconception-once-bishop-removed-exiled-effectively
  a oakcurric:Misconception ;
  oakcurric:statement """Once a bishop is removed or exiled, they are effectively cancelled from the English nobility forever."""@en ;
  oakcurric:correction """In fact, William Saint Calais and Ranulf Flambard were both restored to their bishoprics after being removed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700659Z"^^xsd:dateTime .

oak:misconception-cultural-exchange-britain-india-one
  a oakcurric:Misconception ;
  oakcurric:statement "Cultural exchange between Britain and India was 'one-way'."@en ;
  oakcurric:correction """Cultural exchange between Britain and India moved in both directions, with both countries being permanently changed by the other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700808Z"^^xsd:dateTime .

oak:misconception-hundred-years-war-war-fought
  a oakcurric:Misconception ;
  oakcurric:statement "The Hundred Years' War was a war that was fought continuously for 100 years."@en ;
  oakcurric:correction """The Hundred Years' War lasted for 116 years, but there were many years during this period which saw limited or no fighting. It is better to think of this as a period of heightened animosity in which war was either present or not far off."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700885Z"^^xsd:dateTime .

oak:misconception-medieval-people-interested-good-personal
  a oakcurric:Misconception ;
  oakcurric:statement "Medieval people were not interested in good personal hygiene."@en ;
  oakcurric:correction """Personal hygiene was considered important by most, but access to washing facilities was unequal so levels of personal hygiene differed considerably between different groups of the population, such as nuns and monks and poor residents of towns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700890Z"^^xsd:dateTime .

oak:misconception-soviet-invasion-czechoslovakia-created-risk
  a oakcurric:Misconception ;
  oakcurric:statement """The Soviet invasion of Czechoslovakia created the risk of war between the superpowers."""@en ;
  oakcurric:correction """The USA opposed the invasion but was unwilling to become involved in a military conflict involving the USSR and so limited its oppositions to criticism rather than taking steps to protect Czechoslovakia."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700895Z"^^xsd:dateTime .

oak:misconception-china-ussr-fought-alongside-north
  a oakcurric:Misconception ;
  oakcurric:statement """China and the USSR fought alongside North Korea from the beginning of the Korean War."""@en ;
  oakcurric:correction """China and the USSR supported the North Korean invasion but did not participate. China only joined the war at a later stage."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700899Z"^^xsd:dateTime .

oak:misconception-students-think-white-tower-castle
  a oakcurric:Misconception ;
  oakcurric:statement "Students may think that the White Tower was the only castle in Norman London."@en ;
  oakcurric:correction """In fact, there were two other castles in Norman London: Baynard's Castle and Montfichet's Tower."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700938Z"^^xsd:dateTime .

oak:misconception-students-assume-businesses-benefitted-boom
  a oakcurric:Misconception ;
  oakcurric:statement "Students assume that only businesses benefitted from the boom."@en ;
  oakcurric:correction """Consumers benefitted from the boom through increased employment, rising wages, and the ease of buying goods which improved standards of life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701158Z"^^xsd:dateTime .

oak:misconception-because-priory-large-home-many
  a oakcurric:Misconception ;
  oakcurric:statement """Because the priory is so large, it must have been home to many hundreds of monks."""@en ;
  oakcurric:correction """In fact, only 20 to 30 monks lived at Castle Acre Priory at any one time, and the original number when the priory was first being built was only around 6."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701859Z"^^xsd:dateTime .

oak:misconception-india-totally-controlled-east-india
  a oakcurric:Misconception ;
  oakcurric:statement """India was totally controlled by the East India Company at the time of the Indian Rebellion in 1857."""@en ;
  oakcurric:correction """Two-thirds of India was controlled by the East India Company at the time of the Indian Rebellion in 1857."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701935Z"^^xsd:dateTime .

oak:misconception-government-fully-implemented-edwin-chadwicks
  a oakcurric:Misconception ;
  oakcurric:statement "The government fully implemented Edwin Chadwick's recommendations."@en ;
  oakcurric:correction """Chadwick's recommendations were included in the 1848 Public Health Act but were not compulsory, so many local authorities ignored them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702319Z"^^xsd:dateTime .

oak:misconception-british-nationality-act-1948-led
  a oakcurric:Misconception ;
  oakcurric:statement """The British Nationality Act of 1948 led to an immediate and easy integration of Commonwealth immigrants into British society"""@en ;
  oakcurric:correction """Although the British Nationality Act of 1948 allowed Commonwealth citizens to settle in the UK, many immigrants faced significant challenges upon arrival."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702331Z"^^xsd:dateTime .

oak:misconception-william-barons-said-because-feudalism
  a oakcurric:Misconception ;
  oakcurric:statement "William barons had to do what he said because of feudalism."@en ;
  oakcurric:correction """Feudalism in Normandy was not as strict as it would be in Norman England, and the barons also argued that their promises to obey William were for Normandy - they didn't extend across the Channel to England."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702336Z"^^xsd:dateTime .

oak:misconception-new-laws-immediately-improved-lives
  a oakcurric:Misconception ;
  oakcurric:statement "New laws immediately improved the lives of women and African Americans."@en ;
  oakcurric:correction """Poor enforcement and unchanged attitudes undermined the impact of some changes in the law."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702829Z"^^xsd:dateTime .

oak:misconception-john-hunters-medical-impact-entirely
  a oakcurric:Misconception ;
  oakcurric:statement "John Hunter's medical impact was entirely beneficial."@en ;
  oakcurric:correction """Hunter's ideas about venereal disease were incorrect but widespread respect for his expertise meant this mistake wasn't corrected for decades."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702966Z"^^xsd:dateTime .

oak:misconception-smoking-cause-lung-cancer
  a oakcurric:Misconception ;
  oakcurric:statement "Smoking is the only cause of lung cancer."@en ;
  oakcurric:correction """Non-smokers can also develop lung cancer. Sometimes this is because of passive smoking, but other causes like air pollution can also be responsible."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703079Z"^^xsd:dateTime .

oak:misconception-native-americans-killed-battle-british
  a oakcurric:Misconception ;
  oakcurric:statement "Most of the Native Americans were killed in battle by British colonists."@en ;
  oakcurric:correction """Although many Native Americans succumbed to British violence, the overwhelming majority of Native Americans were killed by European diseases, to which they had no natural immunity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703183Z"^^xsd:dateTime .

oak:misconception-william-took-land-anglo-saxons
  a oakcurric:Misconception ;
  oakcurric:statement "William took land from Anglo-Saxons and gave it to his Norman followers."@en ;
  oakcurric:correction """While William certainly did redistribute land from Anglo-Saxons to Normans, he followed a legal process for this, based on forfeiture - he took the lands of those who did not submit to him as their king, which included those fighting him at Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703303Z"^^xsd:dateTime .

oak:misconception-antiseptics-developed-wwi-able-sterilise
  a oakcurric:Misconception ;
  oakcurric:statement """Antiseptics developed before WWI were able to sterilise wounds against infections like gas gangrene."""@en ;
  oakcurric:correction """Antiseptics such as carbolic acid could destroy some bacteria, but had no effect on those which caused gas gangrene. The sodium hypochlorite solution used in the Carrel-Dakin method could destroy the bacteria which caused gas gangrene though."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703309Z"^^xsd:dateTime .

oak:misconception-brown-v-board-ruling-1954
  a oakcurric:Misconception ;
  oakcurric:statement "The Brown v. Board ruling in 1954 led to desegregation across the South."@en ;
  oakcurric:correction """School desegregation was resisted bitterly in many parts of the South. In some states, the Brown v. Board decision had no effect on how schools were run even by the start of the 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703567Z"^^xsd:dateTime .

oak:misconception-americans-affected-same-way-great
  a oakcurric:Misconception ;
  oakcurric:statement "All Americans were affected in the same way by the Great Depression."@en ;
  oakcurric:correction """Some issues experienced during the Great Depression differed between rural and urban areas. African Americans also tended to suffer more, with higher rates of unemployment than average."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703598Z"^^xsd:dateTime .

oak:misconception-lifestyle-factors-considered-important-persons
  a oakcurric:Misconception ;
  oakcurric:statement """Lifestyle factors have only been considered important for a person's health in the modern period."""@en ;
  oakcurric:correction """Lifestyle factors like diet have been considered important for many centuries, but before the 20th century this was often based on inaccurate ideas like the Theory of Four Humours."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703607Z"^^xsd:dateTime .

oak:misconception-us-responses-loss-china-based
  a oakcurric:Misconception ;
  oakcurric:statement "US responses to the 'loss' of China were only based on international concerns."@en ;
  oakcurric:correction """As a democracy, American policy-makers and leaders had to pay attention to domestic opinion as well as international issues. Both of these factors encouraged tough anti-communism after the 'loss' of China."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703624Z"^^xsd:dateTime .

oak:misconception-william-introduced-whole-new-social
  a oakcurric:Misconception ;
  oakcurric:statement """William I introduced a whole new social system called the feudal system which was completely different from what came before."""@en ;
  oakcurric:correction """In fact, many of the features of what became known as the feudal system were already in place in Anglo-Saxon England. William took the opportunity to increase his control over society to enable the extraction of wealth; his successors built on this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703628Z"^^xsd:dateTime .

oak:misconception-british-public-uniformly-supported-imperial
  a oakcurric:Misconception ;
  oakcurric:statement "The British public uniformly supported imperial expansion and wars."@en ;
  oakcurric:correction """British public opinion was not monolithic; there were varied reactions to imperial policies and military actions, including support, indifference and opposition."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703633Z"^^xsd:dateTime .

oak:misconception-use-technology-modern-medicine-means
  a oakcurric:Misconception ;
  oakcurric:statement """The use of technology in modern medicine means doctors aren't very involved in making diagnoses."""@en ;
  oakcurric:correction """Technology can help patients to monitor some health conditions themselves but many technologies that help diagnosis require a doctor to operate them or to interpret the information they provide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703637Z"^^xsd:dateTime .

oak:misconception-migration-period-voluntary-driven-individual
  a oakcurric:Misconception ;
  oakcurric:statement "All migration in this period was voluntary and driven by individual choices."@en ;
  oakcurric:correction """Not all migrations were voluntary at this time. For instance, indentured labour schemes often coerced individuals into migration under harsh conditions. Additionally, Jewish migration was frequently driven by persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703897Z"^^xsd:dateTime .

oak:misconception-hospitals-locations-people-cured-their
  a oakcurric:Misconception ;
  oakcurric:statement "Hospitals were locations for people to be cured of their illnesses."@en ;
  oakcurric:correction """Christian influences meant that medieval hospitals did not try to cure people's illnesses as this might appear to challenge God's will. Instead spiritual care was prioritised in hospitals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704191Z"^^xsd:dateTime .

oak:misconception-race-relations-acts-completely-addressed
  a oakcurric:Misconception ;
  oakcurric:statement """The Race Relations Acts completely addressed the issues of racism that were rampant in post-war Britain."""@en ;
  oakcurric:correction """The Race Relations Act went a long way in showing changing government attitudes and providing some protection to black and Asian people in post-war Britain - but they could not and did not change public attitudes overnight."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704284Z"^^xsd:dateTime .

oak:misconception-acceptance-many-islamic-medical-works
  a oakcurric:Misconception ;
  oakcurric:statement """The acceptance of many Islamic medical works also encouraged challenges to Galen in medieval Europe."""@en ;
  oakcurric:correction """Islamic medical works were widely accepted but were ignored where they criticised or encouraged challenges to Galen."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704324Z"^^xsd:dateTime .

oak:misconception-singular-accurate-interpretation-events-periods
  a oakcurric:Misconception ;
  oakcurric:statement """There is always a singular accurate interpretation of events and periods in history."""@en ;
  oakcurric:correction """There can be many accurate interpretations of historical periods and these may differ from one another depending on what they focus on."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704709Z"^^xsd:dateTime .

oak:misconception-martin-luther-king-wanted-avoid
  a oakcurric:Misconception ;
  oakcurric:statement """Martin Luther King wanted to avoid violent reactions from opponents of the Civil Rights Movement."""@en ;
  oakcurric:correction """King stuck to peaceful protest but deliberately campaigned in locations like Birmingham where it was believed opponents were likely to react violently."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704714Z"^^xsd:dateTime .

oak:misconception-norman-period-england-ended-death
  a oakcurric:Misconception ;
  oakcurric:statement "The Norman period in England ended with the death of William I."@en ;
  oakcurric:correction """In fact, there were four more Normans after William I: William II and Henry I (both sons of William I), Matilda (the daughter of Henry I) and Stephen (Henry's nephew). Matilda was not accepted as England's queen, leading to civil war with Stephen."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705161Z"^^xsd:dateTime .

oak:misconception-castles-purely-defensive-structures
  a oakcurric:Misconception ;
  oakcurric:statement "Castles were purely defensive structures."@en ;
  oakcurric:correction """Norman castles were effective defensive structures, but they also performed other essential tasks. They were the administrative centre of the local area, the home for the local lord or sheriff and a symbol of Norman power over the Anglo-Saxons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705165Z"^^xsd:dateTime .

oak:misconception-anglo-saxons-castles-therefore-their
  a oakcurric:Misconception ;
  oakcurric:statement """Anglo-Saxons did not have castles so therefore their settlements did not have strong fortifications."""@en ;
  oakcurric:correction """Anglo-Saxon burhs were fortified settlements, surrounded by strong walls designed to deter Vikings from attacking."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705170Z"^^xsd:dateTime .

oak:misconception-power-church-medieval-modern-period
  a oakcurric:Misconception ;
  oakcurric:statement "The power of the Church in the medieval and modern period is equivalent."@en ;
  oakcurric:correction """The medieval Church was a very powerful institution, it was involved in governing Anglo-Saxon England (as bishops served as advisors to kings) and it was a very wealthy landholder. The modern-day Church in England has less powers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705248Z"^^xsd:dateTime .

oak:misconception-kings-passed-their-whole-kingdoms
  a oakcurric:Misconception ;
  oakcurric:statement "Kings have always passed on their whole kingdoms to one successor."@en ;
  oakcurric:correction """Throughout history, there have been many examples of rulers dividing their lands amongst their sons. Quite frequently, this led to war between the sons in an attempt to reunite the realm."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705363Z"^^xsd:dateTime .

oak:misconception-cecil-rhodes-prime-minister-south
  a oakcurric:Misconception ;
  oakcurric:statement "Cecil Rhodes was Prime Minister of South Africa."@en ;
  oakcurric:correction """Cecil Rhodes was Prime Minister of the Cape Colony - the British colony in the region of southern Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705368Z"^^xsd:dateTime .

oak:misconception-medieval-approaches-treatment-prevention-ineffective
  a oakcurric:Misconception ;
  oakcurric:statement "All medieval approaches to treatment and prevention were ineffective."@en ;
  oakcurric:correction """Some effective methods, such as the use of mint in herbal remedies, existed but the scientific reason for their health benefits was not understood."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705372Z"^^xsd:dateTime .

oak:misconception-corrections-galens-work-accepted-virtually
  a oakcurric:Misconception ;
  oakcurric:statement "Corrections to Galen's work were accepted virtually immediately."@en ;
  oakcurric:correction """Many medical professionals were reluctant to challenge Galen's works and so new ideas, like those of Vesalius, were not accepted immediately."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705379Z"^^xsd:dateTime .

oak:misconception-prohibition-led-fall-alcohol-consumption
  a oakcurric:Misconception ;
  oakcurric:statement "Prohibition led to a fall in alcohol consumption in the USA."@en ;
  oakcurric:correction """A rise in the number of bars and alcohol-related offences after 1920 suggests that drinking became more common during the Prohibition era."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705392Z"^^xsd:dateTime .

oak:misconception-european-economic-community-eec-european
  a oakcurric:Misconception ;
  oakcurric:statement """The European Economic Community (EEC) and the European Union (EU) have always been the same entity with identical goals and functions."""@en ;
  oakcurric:correction """The evolution from the EEC to the EU over several decades, showing progressively deepening integration. This was not a seamless transition but involved significant changes in scope and objectives."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705397Z"^^xsd:dateTime .

oak:misconception-1900-british-governments-accepted-large
  a oakcurric:Misconception ;
  oakcurric:statement """By 1900, British governments accepted large-scale responsibility for managing public health."""@en ;
  oakcurric:correction """British governments still limited their actions to improve public health by 1900 because of laissez-faire attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705439Z"^^xsd:dateTime .

oak:misconception-patients-severe-wounds-prioritised-operations
  a oakcurric:Misconception ;
  oakcurric:statement "Patients with the most severe wounds were prioritised for operations at CCSs."@en ;
  oakcurric:correction """Patients with the most severe wounds who were unlikely to survive were sent to moribund wards rather than being operated on at CCSs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705443Z"^^xsd:dateTime .

oak:misconception-westward-migration-refers-migration-americas
  a oakcurric:Misconception ;
  oakcurric:statement "Westward migration always refers to migration to the Americas."@en ;
  oakcurric:correction """Westward migration also includes the migration of Protestant settlers from Great Britain to Ulster."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705470Z"^^xsd:dateTime .

oak:misconception-treatments-hospitals-became-significantly-effective
  a oakcurric:Misconception ;
  oakcurric:statement """Treatments in hospitals became significantly more effective as more medical staff were employed there."""@en ;
  oakcurric:correction """Treatments in most hospitals continued to be based on the incorrect Theory of the Four Humours so unhelpful practices such as bloodletting remained common."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705518Z"^^xsd:dateTime .

oak:misconception-empire-windrush-brought-caribbean-migrants
  a oakcurric:Misconception ;
  oakcurric:statement "The Empire Windrush brought all Caribbean migrants to Britain."@en ;
  oakcurric:correction "The Empire Windrush brought the first group of Caribbean migrants to Britain."@en ;
  dcterms:modified "2026-02-12T08:59:18.705977Z"^^xsd:dateTime .

oak:misconception-surgical-treatment-provided-base-hospitals
  a oakcurric:Misconception ;
  oakcurric:statement "Most surgical treatment was provided at Base Hospitals."@en ;
  oakcurric:correction """Most surgeries occurred at Casualty Clearing Stations due to the need to attend to wounded soldiers' needs quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706084Z"^^xsd:dateTime .

oak:misconception-surgery-continually-improved-19th-century
  a oakcurric:Misconception ;
  oakcurric:statement "Surgery continually improved during the 19th century."@en ;
  oakcurric:correction """Improvements in anaesthetics led to more invasive surgeries which actually made infection a greater problem in the mid-19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706111Z"^^xsd:dateTime .

oak:misconception-british-european-power-trying-gain
  a oakcurric:Misconception ;
  oakcurric:statement "The British were the only European power trying to gain control over India."@en ;
  oakcurric:correction """The British, French and Dutch were all attempting to gain a foothold in India and expand their influence there."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706380Z"^^xsd:dateTime .

oak:misconception-development-smallpox-vaccine-helped-scientists
  a oakcurric:Misconception ;
  oakcurric:statement """Development of the smallpox vaccine helped scientists to develop vaccines for other diseases."""@en ;
  oakcurric:correction """It was not understood why the smallpox vaccine worked, so no new vaccines were developed until the last decades of the 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706384Z"^^xsd:dateTime .

oak:misconception-poisonous-gas-amongst-deadliest-weapons
  a oakcurric:Misconception ;
  oakcurric:statement """Poisonous gas was amongst the deadliest weapons used against British soldiers during WWI."""@en ;
  oakcurric:correction "Gas attacks accounted for only 1% of deaths amongst British soldiers during WWI."@en ;
  dcterms:modified "2026-02-12T08:59:18.706916Z"^^xsd:dateTime .

oak:misconception-negotiations-quick-affairs
  a oakcurric:Misconception ;
  oakcurric:statement "Negotiations are quick affairs."@en ;
  oakcurric:correction """Negotiations can sometimes take place over many years before any progress is made."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706990Z"^^xsd:dateTime .

oak:misconception-civil-rights-campaigners-avoided-situations
  a oakcurric:Misconception ;
  oakcurric:statement """Civil rights campaigners avoided situations where they might be attacked by opponents."""@en ;
  oakcurric:correction """Attacks by opponents helped generate more publicity and sympathy for civil rights protests so risky situations were not avoided."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707006Z"^^xsd:dateTime .

oak:misconception-women-experienced-economic-improvements-post
  a oakcurric:Misconception ;
  oakcurric:statement "Women experienced no economic improvements in the post-war period."@en ;
  oakcurric:correction """Female employment fell and women suffered from lower pay than men but average incomes for women did still rise."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707011Z"^^xsd:dateTime .

oak:misconception-religion-medieval-explanation-causes-disease
  a oakcurric:Misconception ;
  oakcurric:statement """Religion was the only medieval explanation for the causes of disease and illness."""@en ;
  oakcurric:correction """Religion was a widespread and commonly used explanation for disease but many other theories were also used including miasma, astrology and the Theory of the Four Humours."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707052Z"^^xsd:dateTime .

oak:misconception-migrants-experience-same-hardships-migrated
  a oakcurric:Misconception ;
  oakcurric:statement "Migrants all experience the same hardships and migrated for similar reasons."@en ;
  oakcurric:correction """Migrants' experiences differed greatly from group to group and from person to person. Motivations amongst migrants also differed, even within particular migrant groups."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707270Z"^^xsd:dateTime .

oak:misconception-renaissance-led-widespread-acceptance-scientific
  a oakcurric:Misconception ;
  oakcurric:statement "The Renaissance led to widespread acceptance of scientific ideas in medicine."@en ;
  oakcurric:correction """Opposition to change from physicians and the limits of new discoveries meant that many ideas about the causes of disease remained unchanged."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707275Z"^^xsd:dateTime .

oak:misconception-usa-fought-prevent-construction-berlin
  a oakcurric:Misconception ;
  oakcurric:statement "The USA fought to prevent the construction of the Berlin Wall."@en ;
  oakcurric:correction """The USA believed that the construction of the wall meant they would no longer be threatened in West Berlin and used it as a valuable propaganda symbol."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707279Z"^^xsd:dateTime .

oak:misconception-florence-nightingale-encouraged-reforms-based
  a oakcurric:Misconception ;
  oakcurric:statement "Florence Nightingale encouraged reforms based on her acceptance of Germ Theory."@en ;
  oakcurric:correction """A lot of Nightingale's ideas were informed by the idea of miasma and how to protect people from it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707284Z"^^xsd:dateTime .

oak:misconception-romanesque-buildings-began-built-england
  a oakcurric:Misconception ;
  oakcurric:statement """Romanesque buildings only began to be built in England after the Norman Conquest."""@en ;
  oakcurric:correction """Edward the Confessor's Westminster Abbey was built in Romanesque style and completed in 1065."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707498Z"^^xsd:dateTime .

oak:misconception-blood-transfusions-common-world-wars
  a oakcurric:Misconception ;
  oakcurric:statement "Blood transfusions were common before the World Wars."@en ;
  oakcurric:correction """Blood transfusions were carried out in the 19th century but were not common until after the two World Wars in the 20th century."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707502Z"^^xsd:dateTime .

oak:misconception-limited-access-medical-care-medieval
  a oakcurric:Misconception ;
  oakcurric:statement "There was limited access to medical care in medieval Britain."@en ;
  oakcurric:correction """Although few people were able to afford physicians, most people were able to turn to other sources of care such as that offered by hospitals, wise people or members of their own family."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707507Z"^^xsd:dateTime .

oak:misconception-criticisms-bloodletting-meant-practiced-less
  a oakcurric:Misconception ;
  oakcurric:statement "Criticisms of bloodletting meant it was practiced less."@en ;
  oakcurric:correction """Bloodletting and other humoural treatments remained popular and were even used to try and treat King Charles II in 1685."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707554Z"^^xsd:dateTime .

oak:misconception-older-americans-opposed-teenage-culture
  a oakcurric:Misconception ;
  oakcurric:statement "All older Americans were opposed to teenage culture in the 1940s and 1950s."@en ;
  oakcurric:correction """Adults working in advertising as well as some in the entertainment industry were happy to target teenage audiences."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707607Z"^^xsd:dateTime .

oak:misconception-well-developed-plans-anarchists-communists
  a oakcurric:Misconception ;
  oakcurric:statement """There were well-developed plans for anarchists and communists to stage a revolution in the USA."""@en ;
  oakcurric:correction """Although the fear of 'Reds' was widespread, the failure of the Palmer Raids revealed that there were no real plans in place for a revolution which could threaten the USA."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707613Z"^^xsd:dateTime .

oak:misconception-non-white-soldiers-citizens-commonwealth
  a oakcurric:Misconception ;
  oakcurric:statement """Non-white soldiers and citizens of the Commonwealth played a small role during and after both World Wars."""@en ;
  oakcurric:correction """Non-white soldiers and citizens of the Commonwealth played a significant role during and after both World Wars."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707618Z"^^xsd:dateTime .

oak:misconception-germ-theorys-accuracy-meant-immediately
  a oakcurric:Misconception ;
  oakcurric:statement "Germ Theory's accuracy meant that it was immediately accepted in Britain."@en ;
  oakcurric:correction """Many doctors still defended spontaneous generation and it took the additional proof provided by Robert Koch's work to convince many that microbes caused disease."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707623Z"^^xsd:dateTime .

oak:misconception-alexander-fleming-developed-penicillin-antibiotic
  a oakcurric:Misconception ;
  oakcurric:statement "Alexander Fleming developed penicillin as an antibiotic."@en ;
  oakcurric:correction """Fleming did not believe penicillin would work as an antibiotic. Florey and Chain developed penicillin as an antibiotic."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707627Z"^^xsd:dateTime .

oak:misconception-trial-combat-trial-ordeal-punishments
  a oakcurric:Misconception ;
  oakcurric:statement "Trial by combat and trial by ordeal were punishments for crimes."@en ;
  oakcurric:correction """Trial by combat and trial by ordeal were ways of finding out who God judged as being innocent and guilty, though the ordeal was certainly punishing for both parties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707944Z"^^xsd:dateTime .

oak:misconception-government-policies-1960s-focused-improving
  a oakcurric:Misconception ;
  oakcurric:statement """Government policies in the 1960s were only focused on improving civil rights in the USA."""@en ;
  oakcurric:correction """The New Frontier and Great Society were both varied programmes that involved policy action to improve many different aspects of life in America."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707949Z"^^xsd:dateTime .

oak:misconception-castles-built-normans-designed-intimidate
  a oakcurric:Misconception ;
  oakcurric:statement """Castles built by the Normans were designed to intimidate the local Anglo-Saxons and provided no benefit for them."""@en ;
  oakcurric:correction """One of the primary functions of castles was to intimidate the local population, but castles also frequently drew people to them and created an urban centre, which boosted the local economy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708104Z"^^xsd:dateTime .

oak:misconception-black-power-groups-focused-use
  a oakcurric:Misconception ;
  oakcurric:statement "Black Power groups only focused on the use of violence."@en ;
  oakcurric:correction """Groups such as the Black Panthers provided many services to support black communities, such as free breakfast programmes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708109Z"^^xsd:dateTime .

oak:misconception-decolonisation-happened-everywhere-once
  a oakcurric:Misconception ;
  oakcurric:statement "Decolonisation happened everywhere at once."@en ;
  oakcurric:correction """Decolonisation happened in different places at different points throughout the 20th century, for reasons specific to each area's context."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708113Z"^^xsd:dateTime .

oak:misconception-ccp-kmt-soviet-us-control
  a oakcurric:Misconception ;
  oakcurric:statement "The CCP and KMT were under Soviet and US control."@en ;
  oakcurric:correction """Both sides in the Chinese Civil War were able to resist attempts by foreign powers to control their actions, such as the KMT in 1946 and CCP in 1949."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708279Z"^^xsd:dateTime .

oak:misconception-cathedrals-like-museums-ordinary-people
  a oakcurric:Misconception ;
  oakcurric:statement "Cathedrals are like museums and ordinary people can access all areas."@en ;
  oakcurric:correction """In fact, in medieval times ordinary people could not cross the screen which partitions the nave from the quire."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708403Z"^^xsd:dateTime .

oak:misconception-jewish-persecution-antisemitism-happened-europe
  a oakcurric:Misconception ;
  oakcurric:statement """Jewish persecution and antisemitism only happened in Europe during the 1930s and 1940s."""@en ;
  oakcurric:correction """Jewish persecution and antisemitism had been happening for thousands of years, with Britain expelling all Jews in 1290, without letting them return for hundreds of years."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708550Z"^^xsd:dateTime .

oak:misconception-men-opposed-feminist-movement
  a oakcurric:Misconception ;
  oakcurric:statement "Only men opposed the Feminist Movement."@en ;
  oakcurric:correction """The Feminist Movement faced opposition from some women such as Phyllis Schlafly as well as some men."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708593Z"^^xsd:dateTime .

oak:misconception-anglo-saxon-prelates-church-leaders
  a oakcurric:Misconception ;
  oakcurric:statement "All Anglo-Saxon prelates (Church leaders) were replaced by Normans."@en ;
  oakcurric:correction """Although most bishops and priors were replaced, especially those involved in rebellion, those accused of simony or pluralism and those already married, others were not. The first prior appointed by William St Calais was an Anglo-Saxon called Alwin."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708599Z"^^xsd:dateTime .

oak:misconception-losers-belonged-minority-groups-suffered
  a oakcurric:Misconception ;
  oakcurric:statement """Losers were only those who belonged to minority groups who suffered because of racism."""@en ;
  oakcurric:correction """Economic problems made life difficult for many people aside from racist issues. These issues affected minorities and non-minorities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708604Z"^^xsd:dateTime .

oak:misconception-norman-castles-built-standard-motte
  a oakcurric:Misconception ;
  oakcurric:statement "All Norman castles were built to a standard motte-and-bailey design."@en ;
  oakcurric:correction """In fact, although mottes and baileys were features of most Norman castles, how these were positioned could vary a lot, especially if they were built on the site of earlier Roman or Iron Age forts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709183Z"^^xsd:dateTime .

oak:misconception-new-civil-rights-led-immediate
  a oakcurric:Misconception ;
  oakcurric:statement "New civil rights led to immediate improvements in African American lives."@en ;
  oakcurric:correction """New civil rights were not always enforced by the government and many problematic areas of life, such as black American poverty, were not legislated for."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709188Z"^^xsd:dateTime .

oak:misconception-bay-pigs-invasion-directly-involved
  a oakcurric:Misconception ;
  oakcurric:statement "The Bay of Pigs Invasion directly involved US combat forces."@en ;
  oakcurric:correction """JFK refused to involve US ground troops or air support in the invasion whcih relied upon a small group of Cuban exiles."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709193Z"^^xsd:dateTime .

oak:misconception-salt-1-represented-end-cold
  a oakcurric:Misconception ;
  oakcurric:statement "SALT 1 represented an end to the Cold War."@en ;
  oakcurric:correction """SALT 1 helped to moderate some elements of the Cold War such as the arms race but did not bring a complete stop to this. US and Soviet rivalry continued after 1972 and so did the Cold War."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709440Z"^^xsd:dateTime .

oak:misconception-lanfrancs-reforms-introduced-new-concepts
  a oakcurric:Misconception ;
  oakcurric:statement """Lanfranc's reforms introduced new concepts like celibacy for monks, Benedictine rules for monasteries and separate courts for the Church (or even archdeacons)."""@en ;
  oakcurric:correction """All these were already present in Anglo-Saxon England - monasteries had been following the laws of St Benedict for centuries, for example - but Lanfranc revitalised them, ensured that they were carried out and repurposed them to boost Norman control."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709456Z"^^xsd:dateTime .

oak:misconception-correcting-galens-mistakes-led-immediate
  a oakcurric:Misconception ;
  oakcurric:statement "Correcting Galen's mistakes led to immediate improvements in medical practices."@en ;
  oakcurric:correction """Despite Harvey's theory suggesting bloodletting would be dangerous, most physicians continued to recommend the procedure as a common form of treatment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709626Z"^^xsd:dateTime .

oak:misconception-m-ty-s-r-kosi
  a oakcurric:Misconception ;
  oakcurric:statement "Mátyás Rákosi was the leader of Hungary at the start of the Hungarian Uprising."@en ;
  oakcurric:correction """Rákosi was forced to quit as leader in July 1956 when he lost the support of the USSR but widespread anger amongst ordinary Hungarians remained. Khrushchev installed Imre Nagy as leader on 26th October 1956 in an attempt to end protests."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709635Z"^^xsd:dateTime .

oak:misconception-local-environment-western-front-significance
  a oakcurric:Misconception ;
  oakcurric:statement """The local environment on the Western Front had no significance for medicine and the health of British forces."""@en ;
  oakcurric:correction """Waterlogged and muddy ground threatened soldiers and slowed down medical evacuations whilst bacteria in the local soil created a serious risk of infections."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709640Z"^^xsd:dateTime .

oak:misconception-groups-america-experienced-increased-hardship
  a oakcurric:Misconception ;
  oakcurric:statement """All groups in America experienced increased hardship as a result of the Great Depression."""@en ;
  oakcurric:correction """Increased hardship was the most common experience during the Great Depression but there still gains for some groups: overall female employment increased and some Americans, such as Hollywood stars, were still able to become very wealthy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710114Z"^^xsd:dateTime .

oak:misconception-wales-isolated-because-mountains-wales
  a oakcurric:Misconception ;
  oakcurric:statement "Wales was isolated because of the mountains between Wales and England."@en ;
  oakcurric:correction """In fact, Wales' extensive coastline meant it had excellent communications with other countries in Europe, especially Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710305Z"^^xsd:dateTime .

oak:misconception-president-hoover-nothing-try-help
  a oakcurric:Misconception ;
  oakcurric:statement """President Hoover did nothing to try and help Americans during the Great Depression."""@en ;
  oakcurric:correction """At times, Hoover refused to act to provide relief, especially at the start of the Great Depression, but by 1932, the president was taking more action to try and help, such as setting up the Reconstruction Finance Corporation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710429Z"^^xsd:dateTime .

oak:misconception-early-medieval-kings-ruled-royal
  a oakcurric:Misconception ;
  oakcurric:statement "That early medieval kings ruled from a royal palace."@en ;
  oakcurric:correction """In fact, early medieval kings and their courts travelled from one location to another."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710590Z"^^xsd:dateTime .

oak:misconception-attempts-prevent-infections-surgery-mainly
  a oakcurric:Misconception ;
  oakcurric:statement """Attempts to prevent infections during surgery mainly focused mainly on antiseptic methods by the start of the 20th century."""@en ;
  oakcurric:correction """Antiseptic methods remained in use but methods of aseptic surgery were also commonly practiced by the start of the 20th century to prevent infections."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710599Z"^^xsd:dateTime .
