# Key Learning Points
# ----------------------------------------------------------------------

oak:keylearningpoint-lesson-28923-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Britain created a welfare state during the 1940s."@en ;
  dcterms:modified "2026-02-12T08:59:21.481105Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28923-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Beveridge Report and public support for the war effort during WWII encouraged the creation of the welfare state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28923-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The NHS and new house building were key features of the welfare state."@en ;
  dcterms:modified "2026-02-12T08:59:21.481116Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28923-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The NHS provides free treatments for patients."@en ;
  dcterms:modified "2026-02-12T08:59:21.481120Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28923-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Funding difficulties have affected access to and the quality of some support provided by the welfare state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481129Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7361-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the middle of the 11th century, Gruffydd ap Llywelyn was the most powerful figure in Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481162Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7361-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In the 1050s, Ralph the Timid, a Norman, was Earl of Hereford."@en ;
  dcterms:modified "2026-02-12T08:59:21.481167Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7361-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1055, Gruffydd ap Llywelyn attacked Hereford and defeated its defenders."@en ;
  dcterms:modified "2026-02-12T08:59:21.481171Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7361-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold and Tostig Godwinson led a military campaign against Gruffydd ap Llywelyn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481175Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7361-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gruffydd ap Llywelyn was killed and power in Wales was again divided amongst smaller kingdoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481179Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7270-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Following the independence of many countries in Asia and Africa, there was a wave of migration to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481199Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7270-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Commonwealth citizens felt connected to tolerant Britain, and were encouraged to move there by the British government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481205Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7270-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Following independence in Kenya and Uganda, people of Asian descent experienced discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7270-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1972, Ugandan President Idi Amin expelled Asian people from the country, many of whom moved to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481214Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7270-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The immigration of this group influenced British immigration policies amid racial disparities and societal divisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7492-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Caribbean migrants settled in Bristol, impacting the built environment and culture of the city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7492-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British Civil Rights movement is often said to have started in Bristol, with the Bristol Bus Boycott."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7492-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Ugandan Asian migrants settled in Leicester in the 1970s, although the local council were openly hostile to them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481280Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7492-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Asian community in Leicester was able to have a significant impact on politics and the built environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481284Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7320-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William’s control of the North was threatened by rebellions."@en ;
  dcterms:modified "2026-02-12T08:59:21.481796Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7320-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William aimed to destroy the spirit of rebellion and ensure that no future rebellion could support itself in the North."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481800Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7320-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman soldiers systematically killed rebels and destroyed food across Yorkshire – later known as ‘Harrying the North’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7320-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The resulting famine caused as many as 100 000 people to vanish from the records."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7320-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were no further uprisings in the North, but William was criticised for excessive brutality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481812Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7495-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1952, the Metropolitan Police was made up of predominantly white men, despite some black people trying to join."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481893Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7495-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tensions between the black community and the police increased in the 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.481898Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7495-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The increasing activism of anti-immigrant groups exacerbated tension between the police and the black community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481905Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7507-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1950s, many schools across the US were still segregated, especially in the South."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481975Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7507-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As a result of the Brown v. Topeka ruling, schools began to desegregate - although this was slow across the south."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481979Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7507-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some powerful local figures tried to oppose the desegregation of schools, particularly in the south."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481983Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7507-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although Eisenhower was reluctant, the federal government was pressured to enforce desegregation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481986Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7517-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite the passing of new acts, rates of unemployment and poverty were still high amongst black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481990Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7517-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Watts riots triggered three summers of rioting across the US."@en ;
  dcterms:modified "2026-02-12T08:59:21.481994Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7517-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """President Johnson ordered an investigation into the causes of the riots, to prevent further outbreaks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7517-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Kerner Report said the lack of economic opportunity and ongoing racial discrimination as the cause of the riots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482002Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28910-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Over 100 000 people in London alone were killed by the Great Plague."@en ;
  dcterms:modified "2026-02-12T08:59:21.482046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28910-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The actual cause of the plague was still not understood in 1665."@en ;
  dcterms:modified "2026-02-12T08:59:21.482050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28910-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "No effective cures for the plague existed at the time."@en ;
  dcterms:modified "2026-02-12T08:59:21.482054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28910-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Authorities used social distancing to try and prevent the spread of the plague."@en ;
  dcterms:modified "2026-02-12T08:59:21.482058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28910-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Social distancing methods included household quarantines."@en ;
  dcterms:modified "2026-02-12T08:59:21.482062Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7477-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """England's role in the Transatlantic Slave Trade increased the number of African migrants in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7477-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most African migrants in early modern England lived as ‘unfree’ servants."@en ;
  dcterms:modified "2026-02-12T08:59:21.482091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7477-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some historical records show African migrants being baptised and working in various jobs, usually in large port cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482095Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7294-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Space Race was a competition between the US and USSR in the 1950s and 1960s."@en ;
  dcterms:modified "2026-02-12T08:59:21.482419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7294-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Security and prestige both motivated the Space Race."@en ;
  dcterms:modified "2026-02-12T08:59:21.482423Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7294-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR launched the first satellite, Sputnik, in 1957."@en ;
  dcterms:modified "2026-02-12T08:59:21.482427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7294-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Soviet successes in space triggered fears that the US was falling behind."@en ;
  dcterms:modified "2026-02-12T08:59:21.482431Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7294-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US astronauts landed on the moon in 1969."@en ;
  dcterms:modified "2026-02-12T08:59:21.482435Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7295-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR and Germany were considered threats to Western Europe after WW2."@en ;
  dcterms:modified "2026-02-12T08:59:21.482608Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7295-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "NATO was founded in 1949 as a military alliance of Western countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.482612Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7295-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "West Germany was allowed to join NATO in 1955."@en ;
  dcterms:modified "2026-02-12T08:59:21.482616Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7295-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR opposed West German entry into NATO."@en ;
  dcterms:modified "2026-02-12T08:59:21.482622Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7295-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Warsaw Pact was an alliance of Eastern European countries founded in 1955."@en ;
  dcterms:modified "2026-02-12T08:59:21.482626Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7516-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The widespread use of non-violent direct action led to greater support from black and white Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482630Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7516-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The support of Kennedy led to rapid progress and greater federal intervention."@en ;
  dcterms:modified "2026-02-12T08:59:21.482634Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7516-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As president, Johnson continued Kennedy's efforts passing both the Civil Rights Act and the Voting Rights Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7372-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William I dealt with the rebellious north by enacting the Harrying of the North."@en ;
  dcterms:modified "2026-02-12T08:59:21.482749Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7372-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Aethelwine, the Bishop of Durham, was imprisoned for involvement in rebellion and replaced by William Walcher."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7372-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William I built a castle next to the cathedral to provide protection for the Bishop of Durham."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7372-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William I created the role of prince-bishop which had increased powers to control the north."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7372-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William of Saint Calais ordered the building of Durham Cathedral."@en ;
  dcterms:modified "2026-02-12T08:59:21.482765Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27237-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the 1960s, the British government hoped to improve relations with mainland Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482769Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27237-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Britain had been unable to join the European Union (EU) until 1973."@en ;
  dcterms:modified "2026-02-12T08:59:21.482775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27237-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1992 Maastricht Treaty led to increasing migration from Europe to Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.482779Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27237-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migration from the EU rapidly increased in 2004, when eight Eastern European countries joined."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27237-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Migration declined rapidly after Britain formally left the EU in 2020."@en ;
  dcterms:modified "2026-02-12T08:59:21.482787Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7411-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Tower had a religious function; the Chapel of St John is an integral part of the White Tower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483032Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7411-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Chapel of St John was constructed in the Romanesque style."@en ;
  dcterms:modified "2026-02-12T08:59:21.483036Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7411-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Chapel of St John was intended for religious worship and to impress visitors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483040Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7571-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were many problems for people living under communist rule in Czechoslovakia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483047Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7571-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In the late 1960s, protests began to spread in Czechoslovakia."@en ;
  dcterms:modified "2026-02-12T08:59:21.483051Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7571-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Alexander Dubček became leader of Czechoslovakia at the start of 1968."@en ;
  dcterms:modified "2026-02-12T08:59:21.483057Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7571-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Dubček introduced liberalising reforms known as the Prague Spring."@en ;
  dcterms:modified "2026-02-12T08:59:21.483061Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7571-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Dubček considered reform necessary to preserve communist rule."@en ;
  dcterms:modified "2026-02-12T08:59:21.483065Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7496-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Notting Hill riots and the murder of Kelso Cochrane increased tension in the Notting Hill area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7496-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Claudia Jones was one of several activists who looked to rebuild a positive sense of community in the area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7496-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Caribbean carnival was a huge success, and would go onto become Notting Hill Carnival."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7496-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British Black Panther Party (BBP) was set up to campaign against continued racism and discrimination in the 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483139Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7546-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The establishment of NATO (1949) and the Warsaw Pact (1955) divided Europe into two rival alliance systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7546-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The American development of the atomic bomb started an arms race between the USA and the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483147Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7546-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1953, hopes that new leaders in the USA and USSR would improve relations were short-lived: the arms race continued."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483151Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7546-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The development of ICBMs (1957) meant the USA and USSR could fire nuclear weapons at targets in different continents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483155Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7546-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Both the USA and the USSR developed huge stockpiles of nuclear weapons as a form of deterrence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483159Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7470-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Vikings conquered York because it was rich and important."@en ;
  dcterms:modified "2026-02-12T08:59:21.483163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7470-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """York lay on an important east-west trading route, and was therefore well placed to expand Scandinavian trade routes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483169Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7470-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The settled Vikings helped expand York and make it the centre of Viking culture and trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483174Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7481-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "From c. 1750 to 1850, Britain was transformed by the Industrial Revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.483177Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7481-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution led to huge changes in industry, moving from largely agriculture to heavy industry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483181Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7481-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The changes in industry and transport led to a rapid increase in internal migration, but also migration from abroad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483185Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7382-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey Castle was originally a Roman fort."@en ;
  dcterms:modified "2026-02-12T08:59:21.483279Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7382-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey Castle was a motte-and-bailey castle."@en ;
  dcterms:modified "2026-02-12T08:59:21.483283Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7382-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey Castle was initially built from wood and a mound of earth."@en ;
  dcterms:modified "2026-02-12T08:59:21.483287Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7382-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was strengthened further after the Norman Conquest."@en ;
  dcterms:modified "2026-02-12T08:59:21.483291Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7252-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Americans were growing angry at having to pay taxes without having representation in Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483309Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7252-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1773 Boston Tea Party, when protestors dumped tea into the harbour, sparked revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483313Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7252-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1776 the Declaration of Independence was produced that set out the American Constitution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483317Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7252-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British were defeated at Yorktown in 1781 and lost all 13 colonies in America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483321Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7252-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The American Revolution led to radical ideas which were influential in the French Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483327Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7532-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Americans protested against the Vietnam War for a variety of reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.483332Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7532-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """These reasons included the cost in American lives, racism and inequality, expense of the war and how unethical it was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483336Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7532-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Protests took a variety of forms, such as marches and burning draft cards, but were predominantly peaceful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483340Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7485-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Irish migrants made up most of the migrant community in Liverpool, most migrating as a result of the Great Famine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483343Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7485-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """African and Caribbean sailors would settle in Liverpool, looking for work when they were not hired for return trips."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483347Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7485-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Life for migrants in Liverpool was often positive, as the large existing migrant community provided many opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483353Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7485-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants in Liverpool had a significant impact on the local and national economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7488-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As a result of the damage caused by the Second World War, Britain was in need of 1.3 million workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483364Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7488-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1948 Nationality Act increased the number of migrants from the Commonwealth."@en ;
  dcterms:modified "2026-02-12T08:59:21.483368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7488-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """New laws were intended to encourage the migration of workers from predominantly white nations (e.g. Ireland and Poland)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7488-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although their migration was encouraged, migrants often faced prejudice and hostility on arriving in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28925-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Clean Air Acts and low-emission zones have been introduced to prevent air pollution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483488Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28925-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mass vaccination campaigns were launched for diseases including diphtheria and polio."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483492Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28925-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vaccine refusal has led to rising cases of some diseases like measles."@en ;
  dcterms:modified "2026-02-12T08:59:21.483496Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28925-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Healthy lifestyle campaigns have aimed to combat issues such as obesity."@en ;
  dcterms:modified "2026-02-12T08:59:21.483500Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7450-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Battle of Hastings, William took the land of all those who had fought against him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483546Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7450-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At first William kept some Anglo-Saxons in positions of power to help him be accepted as England’s new king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7450-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The uprisings against Norman rule changed William’s mind about including Anglo-Saxons in positions of power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483554Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7450-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William used his control over England’s land to transfer power from Anglo-Saxons to Normans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7450-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William’s methods of maintaining control included: military strength, harrying and castles, and government power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483561Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7515-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """President Kennedy was instrumental in the successes of the civil rights movement in the early 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483565Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7515-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Johnson was able to pass the Civil Rights Act in 1964: considered one of the greatest successes of the movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483569Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7515-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The  march from Selma began in March 1965, protesting against continued voting restrictions for black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483576Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7515-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The success of the march from Selma led to the Voting Rights Act of 1965 which directly addressed voting restrictions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28911-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Smallpox killed many people in Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.483598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28911-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Inoculation could provide immunity, but also carried some risks."@en ;
  dcterms:modified "2026-02-12T08:59:21.483605Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28911-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edward Jenner discovered an effective and safe vaccine for smallpox in 1796."@en ;
  dcterms:modified "2026-02-12T08:59:21.483609Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28911-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was considerable opposition to Jenner's vaccine."@en ;
  dcterms:modified "2026-02-12T08:59:21.483614Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28911-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British government provided increasing support for smallpox vaccination over the 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483617Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28924-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Technology used to produce medicine has made some treatments more widely available."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484040Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28924-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Technology has allowed new treatments to be developed for a wide range of conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484044Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28924-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Alternative treatments continue to be used in modern Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.484048Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28924-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Acupuncture, herbal remedies and homeopathy are all popular treatments."@en ;
  dcterms:modified "2026-02-12T08:59:21.484052Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7414-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.484079Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7414-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484083Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7414-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7414-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.484091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7414-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484094Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7327-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman conquest changed the lives of aristocrats such as Lanfranc and Odo, who in turn impacted  England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484098Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7327-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Odo was made Bishop of Bayeux despite being more focused on secular affairs than spiritual ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484102Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7327-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Odo played an important part in the planning and execution of the Norman invasion of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484108Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7327-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Odo was rewarded with land and power; he was made regent, the earl of Kent, and became extraordinarily wealthy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7327-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Odo abused his powers, and in 1082, William imprisoned him."@en ;
  dcterms:modified "2026-02-12T08:59:21.484116Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9775-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Under Puritan rule, Jewish migrants were reinvited to England for religious and economic reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484123Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9775-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jewish migrants were largely welcomed in the early modern period, with increasing protection from authorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9775-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some English merchants were hostile towards Jewish migrants as they feared they would bring competition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9775-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jewish migrants in this period had the greatest impact on the built environment and culture in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7473-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From as early as the Norman conquest, rulers of England looked to grow the economy using European workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484139Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7473-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wider events, such as the Black Death, led to a demand for more merchants and craftspeople."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7473-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The actions of rulers throughout the medieval period directly impacted the experiences of merchants and craftspeople."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484147Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7473-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although sometimes welcomed by the authorities, many migrants faced increasing hostility from local merchants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484153Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7473-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Merchants and craftspeople had a significant impact on the economy, especially the wool trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484160Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7505-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1865, slavery came to an end, but racism would not disappear overnight."@en ;
  dcterms:modified "2026-02-12T08:59:21.484244Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7505-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jim Crow laws had enforced segregation across southern states in the US, but also some northern states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7505-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jim Crows laws were introduced to limit the freedoms introduced in the Reconstruction era."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7505-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Discrimination and segregation increased in the late 1800s, and worsened after the Plessy v Ferguson verdict (1896)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.484256Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7457-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At first, William planned to share government with Anglo-Saxon nobles and Church leaders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7457-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After 1070, William replaced Anglo-Saxon nobles and churchmen with loyal Normans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7457-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William FitzOsbern and Odo of Bayeux were important figures in government."@en ;
  dcterms:modified "2026-02-12T08:59:21.484419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7457-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lanfranc became a key figure in government after 1070."@en ;
  dcterms:modified "2026-02-12T08:59:21.484426Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7457-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Matilda of Flanders became the first Queen of England, though was most influential as William's regent in Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484430Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7371-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Northumbria was important because it guarded the frontiers against Scottish and Danish (Viking) invaders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484457Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7371-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Northumbria was part of the Danelaw and had different laws and customs from southern England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484461Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7371-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham was important because it was a main town in Northumbria which could help deal with Scottish and Danish raids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7371-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earl Tostig and Aethelwine, the bishop of Durham, were seen as southern outsiders and abused their powers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484471Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7371-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1065 uprising in Northumbria resulted in Tostig being exiled but Aethelwine remained the bishop of Durham."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484475Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9966-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The KKK gained more support as opposition to the civil rights movement grew."@en ;
  dcterms:modified "2026-02-12T08:59:21.484501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9966-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Increased opposition led to increase violence (e.g. the murder of Emmett Till)."@en ;
  dcterms:modified "2026-02-12T08:59:21.484506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9966-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Citizens' Councils were an example of organised opposition to civil rights in the south."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484510Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9966-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was opposition to the civil rights movement within the US government, often led by the 'Dixiecrats'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7475-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Reformation led to huge changes in Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.484518Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7475-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As England became a stable Protestant nation, migration of Protestant refugees increased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484522Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7475-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Renaissance increased migration to England as migrants settled there to spread new ideas and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484526Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7475-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The emergence of the British Empire led to small numbers of Asian and African migrants settling in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484530Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7245-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Anglo-Saxon defeat against the Vikings in the 991 Battle of Maldon led to the Danegeld."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7245-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Aethelred provoked the Danish Vikings by ordering the massacre of all Danes during the St Brice’s Day Massacre in 1002."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7245-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1016 King Cnut invaded and conquered England and became king."@en ;
  dcterms:modified "2026-02-12T08:59:21.484825Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7245-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Under King Cnut, England became part of the North Sea Empire which included Denmark and Norway."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7245-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the early violence of invasion, Cnut's reign saw a period of peace in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484835Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7539-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Vietnam had a great many strengths that enabled it to win the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.484860Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7539-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The North Vietnamese Army was highly experienced and fought to unify and liberate their country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484864Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7539-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Vietnam received a great deal of support from sympathisers in the South."@en ;
  dcterms:modified "2026-02-12T08:59:21.484868Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7539-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """North Vietnam also received a great deal of support from the powerful communist countries of China and the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484872Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28916-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people in Britain died in cholera epidemics."@en ;
  dcterms:modified "2026-02-12T08:59:21.484908Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28916-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "John Snow identified that contaminated water spread cholera."@en ;
  dcterms:modified "2026-02-12T08:59:21.484912Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28916-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Snow's findings were generally not accepted by officials."@en ;
  dcterms:modified "2026-02-12T08:59:21.484916Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28916-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Great Stink led to a new sewage system being built in London."@en ;
  dcterms:modified "2026-02-12T08:59:21.484920Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28916-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were no cholera epidemics in London once its new sewage system was built."@en ;
  dcterms:modified "2026-02-12T08:59:21.484924Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7379-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.485178Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7379-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485184Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7379-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485188Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7379-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.485192Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7379-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485196Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7312-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William of Normandy invaded England after Harold had fought the Battle of Stamford Bridge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485529Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7312-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold's army consisted of an elite of housecarls with the majority being the untrained peasant conscripts of the fyrd."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7312-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold held the high ground on Senlac Hill with a shield wall."@en ;
  dcterms:modified "2026-02-12T08:59:21.485540Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7312-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William’s army mainly consisted of professional soldiers using a mix of archers and cavalry charges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485544Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7312-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William's tactics brought him victory while Harold and many Anglo-Saxon nobles were killed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485548Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7322-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The strict conditions for holding land from the king became known as the feudal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7322-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The feudal system made landholding less secure than it had been under Anglo-Saxon kings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485586Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7322-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A key relationship in the feudal system was between a vassal and their overlord."@en ;
  dcterms:modified "2026-02-12T08:59:21.485590Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7322-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Holding land came with obligations such as paying homage, providing knight service or labour service."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485594Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7322-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The feudal system increased William’s power and control over England."@en ;
  dcterms:modified "2026-02-12T08:59:21.485598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7275-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA set up the secret Manhattan Project to develop the world's first atomic bomb by July 1945."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485981Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7275-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR used espionage to find out about the development of the atomic bomb before it was announced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485986Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7275-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA used atomic bombs to force Japan to surrender but also to demonstrate American power, especially to the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485990Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7275-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet response to the American atomic bomb was to develop their own atomic bomb, which they achieved by 1949."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485994Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7275-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Long and Novikov Telegrams reveal that relations between the USA and the USSR had become very hostile by 1946."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7528-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """America’s involvement in Vietnam escalated up to 1968, with successive presidents committing more troops to the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7528-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Support for their country’s involvement in Vietnam was initially high in America, but diminished as the war dragged on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7528-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Large-scale protests against the war in Vietnam became more and more frequent in America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7950-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most migrants settled in Britain because of changes in laws, the growth of the Commonwealth or for economic reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7950-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Patterns of migration changed throughout the period as a result of new laws and changing attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7950-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """While race became an increasingly defining factor in migrant experiences, all migrants experienced some hostility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486021Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7950-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants had a significant impact on the economy, but growing migrant communities also impacted politics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486025Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7600-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The New Deal supported the American economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.486288Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7600-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1930s continued to be a difficult time for many people."@en ;
  dcterms:modified "2026-02-12T08:59:21.486292Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7600-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "WW2 stimulated the American economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.486296Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7600-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Unemployment dropped and investment increased during the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.486300Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7600-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Experiences of economic recovery in the USA were uneven."@en ;
  dcterms:modified "2026-02-12T08:59:21.486304Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7244-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Prior to the arrival of the Vikings the British Isles was populated by Germanic tribes - the Anglo-Saxons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486308Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7244-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Vikings invaded Britain as it was a wealthy country and Scandinavia was overpopulated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486312Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7244-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From the 790s the Vikings took East Anglia, Mercia and Northumbria and attempted to take Wessex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486315Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7244-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At the 878 Battle of Edington, King Alfred defeated the Vikings which led to the creation of the Danelaw."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486319Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7244-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the creation of the Danelaw many Vikings settled and the number of raids decreased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486323Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7509-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Montgomery Bus Boycott, Martin Luther King emerged as an important leader of the movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486327Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7509-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Martin Luther King established the Southern Christian Leadership Conference (SCLC)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486331Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7509-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The SCLC organised a campaign for voter registration amongst black people."@en ;
  dcterms:modified "2026-02-12T08:59:21.486337Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7509-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eisenhower enforced a Civil Rights Bill, although it was considered 'watered down'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486341Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7560-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA and USSR followed a policy of Détente during the 1970s."@en ;
  dcterms:modified "2026-02-12T08:59:21.486345Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7560-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA and USSR wanted to divert money spent on the arms race to address domestic social and economic problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486352Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7560-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA pursued a policy of Détente because they thought it would help them to end their involvement in the Vietnam War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486356Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7560-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SALT I agreement included important limitations on arms and agreements between the USA and the USSR to cooperate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486362Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7560-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """SALT I had significant limitations, for example, not all nuclear weapons were covered by the agreement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486366Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20703-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 1970s, the USA and the USSR followed a policy of Détente, which led to reduced tensions and greater cooperation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20703-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Détente had ended by the end of the 1970s; events like the Soviet invasion of Afghanistan led to increased tensions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486792Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20703-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan's confrontational approach led to a period of increased hostility known as the Second Cold War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486820Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20703-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gorbachev's 'new thinking' encouraged a positive response from the USA and led to an improvement in US-Soviet relations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20703-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the end of 1991, the USSR had collapsed due to economic problems and demands for independence from its republics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486847Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7471-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1066, the Normans conquered England for political and religious influence as well as the opportunity for wealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7471-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although migrants normally had ‘alien’ status, the Normans experience England as rulers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487650Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7471-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans migrated in fairly small numbers but impacted the economy, culture and built environment of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487654Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7471-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The migration of French monks supported Church reforms and restored England’s place in Christendom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487658Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7584-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Henry Ford developed an assembly line to speed up production."@en ;
  dcterms:modified "2026-02-12T08:59:21.487865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7584-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cars became more affordable throughout the 1920s due to mass production and increases in popularity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487869Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7584-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """New roads and housing complexes were built to accommodate the new cars and people's changing habits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487873Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7584-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The motor industry generated investment and led to a boom in other industries like oil and hospitality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487877Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7262-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In the 19th century there was significant migration from Ireland to Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.487881Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7262-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Potato Famine and the availability of jobs in Britain were key reasons for migration from Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487885Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7262-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The early experiences of Irish immigration were discrimination and xenophobia."@en ;
  dcterms:modified "2026-02-12T08:59:21.487889Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7262-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1922 Ireland was partitioned into Northern Ireland and the Irish Free State, the latter an independent republic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487895Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7262-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The partition of Ireland led to a legacy of violence between unionists and republicans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487901Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20363-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Three of William’s own earls rebelled against him in 1075, all believing they deserved more land and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487906Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20363-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Waltheof confessed the plot to Lanfranc."@en ;
  dcterms:modified "2026-02-12T08:59:21.487910Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20363-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "English and Norman forces cooperated to stop the revolt."@en ;
  dcterms:modified "2026-02-12T08:59:21.487914Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20363-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William punished most rebels with prison or banishment, however, Waltheof was executed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487918Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20363-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The revolt revealed England was tired of resistance and William could rely on Anglo-Norman leadership to secure England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487922Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7512-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1960, the Supreme Court had ordered interstate bus terminals and stations to desegregate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487926Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7512-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """CORE, SNCC and the SCLC came together to organise Freedom Rides to see whether this ruling was being carried out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487930Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7512-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Freedom Riders were an integrated group who faced extreme violence on their journey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7512-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Violent opposition was supported and enabled by the KKK, police chiefs and the FBI."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487937Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7512-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Freedom Rides were considered a success by most as they raised awareness of the civil rights movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487941Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28903-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The actual cause of the Black Death was not understood at the time."@en ;
  dcterms:modified "2026-02-12T08:59:21.488251Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28903-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One-third of Britain's population was killed by the Black Death."@en ;
  dcterms:modified "2026-02-12T08:59:21.488255Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28903-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people believed the Black Death was a punishment from God."@en ;
  dcterms:modified "2026-02-12T08:59:21.488259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28903-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Medieval treatments were ineffective against the plague."@en ;
  dcterms:modified "2026-02-12T08:59:21.488263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28903-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some people avoided plague by reducing contact with those who were infected."@en ;
  dcterms:modified "2026-02-12T08:59:21.488267Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7399-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.597948Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7399-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597963Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7399-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597973Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7399-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.597982Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7399-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7588-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people benefitted from the 'boom years'."@en ;
  dcterms:modified "2026-02-12T08:59:21.598001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7588-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The benefits were not evenly shared out."@en ;
  dcterms:modified "2026-02-12T08:59:21.598011Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7588-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was regional variation in benefits from the 'boom years'."@en ;
  dcterms:modified "2026-02-12T08:59:21.598020Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7588-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An individual's background influenced an experience of the 'boom years'."@en ;
  dcterms:modified "2026-02-12T08:59:21.598030Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7308-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After years in exile in Normandy, Edward the Confessor's position as king was weak; he relied on Earl Godwin's support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598077Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7308-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1051 the Godwins were exiled after tensions over Edward's Norman advisers."@en ;
  dcterms:modified "2026-02-12T08:59:21.598087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7308-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After threatening to invade, the Godwins returned to positions of power."@en ;
  dcterms:modified "2026-02-12T08:59:21.598096Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7308-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edward relied more and more on the Godwins, whose power increased."@en ;
  dcterms:modified "2026-02-12T08:59:21.598106Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7308-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In a trip to Normandy in 1064, Harold Godwin made promises to William, Duke of Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598115Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7311-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold Godwinson raised an army to defend southern England from a potential Norman attack."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7311-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harald Hardrada and Tostig Godwinson launched an invasion in northern England."@en ;
  dcterms:modified "2026-02-12T08:59:21.598228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7311-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold defeated Hardrada and Tostig at the Battle of Stamford Bridge."@en ;
  dcterms:modified "2026-02-12T08:59:21.598238Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7311-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold’s military forces were weakened by the battles."@en ;
  dcterms:modified "2026-02-12T08:59:21.598247Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7486-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In the 1880s, there was a wave of Jewish migration from Eastern Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.598262Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7486-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Jewish migrants who settled in the East End in the 1880s were poorer than those who had migrated in earlier periods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598272Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7486-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most Jewish migrants experienced a lot of hostility, and were forced to find work in poor conditions with low wages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7486-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although they did not have a large impact on the economy, Jewish migrants impacted the built environment in this period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598292Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20700-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Helsinki Accords were an attempt to reach agreement on security, international cooperation and human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20700-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Helsinki Accords are sometimes considered to be the high-point of Détente."@en ;
  dcterms:modified "2026-02-12T08:59:21.598922Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20700-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Disagreements about human rights were one source of tension between the USA and the USSR after Helsinki."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598931Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20700-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the end of the 1970s, hopes for improved relations between the USA and the USSR had faded."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598940Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20700-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA and USSR signed SALT II but after the Soviet invasion of Afghanistan it was not ratified in the USA."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598949Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7317-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William was crowned king but the Normans continued to plunder England."@en ;
  dcterms:modified "2026-02-12T08:59:21.599768Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7317-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William faced unrest throughout most of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.599777Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7317-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "To help him rule, William rewarded his most loyal supporters with land."@en ;
  dcterms:modified "2026-02-12T08:59:21.599790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7317-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William appointed Odo and FitzOsbern as regents."@en ;
  dcterms:modified "2026-02-12T08:59:21.599800Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7317-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William created new Marcher earldoms to defend the Welsh border."@en ;
  dcterms:modified "2026-02-12T08:59:21.599808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7554-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1959, Fidel Castro led a nationalist revolution in Cuba which overthrew Batista's unpopular, US-backed government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599817Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7554-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castro confiscated US property; the USA responded with economic sanctions which led Cuba to move closer to the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599831Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7554-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA's attempt to use CIA-trained, Cuban exiles to overthrow Castro ended with defeat at the Bay of Pigs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599840Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7554-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Bay of Pigs incident damaged the reputation of Kennedy and the USA and meant Cuba and the USSR became closer allies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599849Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7554-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Kennedy was concerned that the USSR would place missiles in Cuba but Khrushchev assured him that this would not happen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7454-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Almost everyone in Norman England farmed for a living."@en ;
  dcterms:modified "2026-02-12T08:59:21.600233Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7454-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different categories of peasants did different amounts of work for the lord of the manor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600242Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7454-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was a big difference between the diets of the rich and the diets of the poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7454-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was little change to the work that people did after the Norman conquest."@en ;
  dcterms:modified "2026-02-12T08:59:21.600259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7454-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The diets of the rich became more varied after the Norman conquest."@en ;
  dcterms:modified "2026-02-12T08:59:21.600268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7514-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """King wrote the 'Letter from Birmingham Jail' after he was arrested following demonstrations in Birmingham, Alabama."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7514-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Kennedy became directly involved in Birmingham in May 1963, deciding to introduce a Civil Rights Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600285Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7514-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In August 1963, the March on Washington became one of the most famous moments of the movement with 250,000 protestors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7514-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the assassination of Kennedy in November 1963, many felt the civil rights movement began to slow down."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600307Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7514-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Freedom Summer aimed to increase voter registration in Mississippi, but their schools became targets of violent attacks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600316Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7948-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Palatine migrants settled in England to escape the devastation of war, in the hope of migrating onto North America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600325Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7948-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Palatines had a largely negative experience once the government and Church realised that one third were Catholics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7948-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As very few Palatines remained in England, they had little impact beyond the 1709 act being revoked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7550-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Hungarian Uprising (1956) was caused by anger due to declining living standards and a desire for greater freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600510Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7550-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Khrushchev attempted to end the Hungarian Uprising by installing Imre Nagy as leader and supporting his reforms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600519Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7550-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When Nagy announced that Hungary would leave the Warsaw Pact, the USSR invaded and crushed the Hungarian Uprising."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7550-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During the Hungarian Uprising, the Hungarians begged for support from the West but the USA and NATO refused to help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600535Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7550-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The defeat of the Hungarian Uprising strengthened the USSR and Khrushchev and led to a worsening of US-Soviet relations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7474-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People migrated because of the potential for political and religious influence as well as financial gain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600552Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7474-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrant experiences varied across the period, they depended on the relationship between the authorities and migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7474-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants had an impact on the economy, built environment and culture of medieval England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600568Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7519-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In his early life, Malcolm X belonged to the Black Muslims (Nation of Islam)."@en ;
  dcterms:modified "2026-02-12T08:59:21.600831Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7519-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Malcolm X did not agree with the involvement of white Americans in the civil rights movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600840Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7519-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In his later life, Malcolm X changed his views and left the Black Muslims (Nation of Islam)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7480-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tens of thousands of Huguenot migrants settled in England in the 1680s as a result of religious persecution in France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7480-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most Huguenots had positive experiences as they were wealthy migrants who received great protection from the monarch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600864Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7480-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Huguenots migrants had the greatest impact on the English economy, although they also impacted English culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600872Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9782-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the early modern period, religion and economic opportunities were the main reasons for migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600881Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9782-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were a small number of migrants who settled in England as a result of the Renaissance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600889Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9782-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Protestant migrants often had more positive experiences; receiving support from the monarchy, government and Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600897Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9782-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Positive relations with authorities could lead to more positive experiences, even for non-Protestant migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600905Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-9782-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants had a significant impact on all areas of life, but most significantly on the economy and culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7369-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.601054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7369-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601062Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7369-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601070Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7369-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.601078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7369-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601086Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7506-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The NAACP and the CORE were created to fight against racial injustice."@en ;
  dcterms:modified "2026-02-12T08:59:21.601095Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7506-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The NAACP was founded in 1909 and would mainly challenge segregation in the courts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601103Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7506-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """CORE was formed in 1942 and used non-violent direct action to challenge segregation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601115Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7506-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Church organisations played an important role in the civil rights movement, especially in the South."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601124Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7522-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Progress in politics was limited by Nixon, who showed little intention of supporting the civil rights movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7522-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although changes in education were slow, the bussing initiative brought rapid progress in the 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601194Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7522-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """One area Nixon offered some support was the economy, although rates of unemployment remained higher for black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601202Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7545-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA, the USSR, Britain and France disagreed about how to administer a divided Germany and a divided Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7545-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin's response to the creation of Trizonia and the introduction of the Deutschmark in 1948 led to the Berlin Crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7545-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between June 1948 and May 1949, the USSR set up a blockade to force the Western allies to abandon Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601226Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7545-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Western allies responded to the Berlin Blockade by successfully supplying Berlin from the air."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7545-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Berlin Crisis confirmed the long-term division of Germany and Berlin and led to the creation of NATO."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601242Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7476-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """To improve England’s economy, William Cecil invited Flemish and Walloon weavers to Sandwich and later Canterbury."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7476-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although they faced increasing hostility, Flemish and Walloon weavers established a community and thrived economically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601258Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7476-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Flemish and Walloon weavers impacted the economy and the built environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.601266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7542-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA set up the secret Manhattan Project to develop the world's first atomic bomb by July 1945."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7542-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR used espionage to find out about the development of the atomic bomb before it was announced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601494Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7542-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA used atomic bombs to force Japan to surrender but also to demonstrate American power, especially to the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601502Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7542-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet response to the American atomic bomb was to develop their own atomic bomb, which they achieved by 1949."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601510Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7542-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Long and Novikov Telegrams reveal that relations between the USA and the USSR had become very hostile by 1946."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601517Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7566-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA was closely interested in Cuba in the mid-20th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.601931Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7566-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Batista government was very unpopular in Cuba."@en ;
  dcterms:modified "2026-02-12T08:59:21.601939Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7566-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fidel Castro gained power in Cuba after a revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.601946Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7566-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The US opposed many of the actions of the Castro government."@en ;
  dcterms:modified "2026-02-12T08:59:21.601958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7566-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cuba increasingly developed trade and security relations with the USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.601966Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7455-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Forest law was a new set of laws introduced to England by the Normans."@en ;
  dcterms:modified "2026-02-12T08:59:21.602066Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7455-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William and his successors increased the area classed as forest until a third of England was covered by Forest law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7455-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Punishments for breaking Forest law could be much more severe than punishments in common law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7455-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Forest law made life much harder for peasants because they were now banned from using resources they depended on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602094Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7455-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Forest law was resented by ordinary people but also by Norman tenants of the king, since it affected their lands too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602106Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7389-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.602114Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7389-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602121Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7389-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602129Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7389-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.602137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7389-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602144Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7318-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castles were almost unknown in Anglo-Saxon England."@en ;
  dcterms:modified "2026-02-12T08:59:21.602156Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7318-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles had a military function, acting as bases for troops who would control and oppress key areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602164Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7318-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles had a psychological impact of terrifying and dominating the local population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602172Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7318-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles were centres of Norman power, acting as bases for Norman nobles to administer an area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602180Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7318-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most Norman castles were variations of the motte-and-bailey design."@en ;
  dcterms:modified "2026-02-12T08:59:21.602188Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7323-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The medieval Church was a powerful and influential institution, which William used to spread Norman control in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602195Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7323-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William reformed the Church arguing it was in moral decline. It is likely he saw the leadership as a threat to his rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602203Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7323-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most Anglo-Saxon bishops were replaced with Normans, and Lanfranc was appointed as Archbishop of Canterbury."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602211Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7323-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lanfranc oversaw a programme of church-building, and bishops were transferred from villages to cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602219Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7323-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lanfranc’s other reforms included introducing more discipline and a greater separation from non-religious life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602226Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7562-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A communist group called the PDPA took control of Afghanistan in 1978 and governed with Soviet support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602277Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7562-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reforms introduced by the PDPA to transform Afghanistan into a communist country were deeply unpopular."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602285Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7562-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR invaded Afghanistan in December 1979 to prevent the mujahideen from overthrowing the communist government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7562-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet invasion of Afghanistan increased tensions with the USA who responded with the Carter Doctrine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7562-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In response to the Soviet invasion, the USA led a boycott of the 1980 Moscow Olympics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602313Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7573-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Brezhnev Doctrine justified the invasion of Czechoslovakia."@en ;
  dcterms:modified "2026-02-12T08:59:21.602521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7573-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Brezhnev Doctrine claimed reforms in one communist country affected all communist countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602528Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7573-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Brezhnev Doctrine helped the USSR maintain its control over Eastern Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.602536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7573-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some communist states became less trusting of the USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.602544Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25397-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ideological differences meant there were tensions between the USA and USSR even when they were allies during WW2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25397-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1945, the Soviet creation of satellite states and the US development of the atomic bomb increased tensions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25397-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Concerned about Soviet expansion, Truman committed the USA to a policy of containment in 1947."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602572Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25397-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1948, the Berlin Crisis significantly increased Cold War tensions."@en ;
  dcterms:modified "2026-02-12T08:59:21.602579Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25397-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cold War intensified during the 1950s due to the escalation of the arms race and the Soviet invasion of Hungary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602587Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20698-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After Czechoslovakia became a Soviet satellite state, people faced economic challenges and limits on their freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602633Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20698-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1957, under the leadership of Antonin Novotny, standards of living declined and calls for reform increased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20698-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Alexander Dubcek became leader in January 1968 and introduced a series of reforms known as the Prague Spring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602648Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20698-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Brezhnev was concerned that the Prague Spring would weaken communism and Czechoslovakia would leave the Warsaw Pact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20698-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In August 1968, a Soviet-led invasion removed Dubcek from power and ended the Prague Spring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602663Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7597-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The New Deal extended specific support to help jobless artists."@en ;
  dcterms:modified "2026-02-12T08:59:21.602819Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7597-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Jazz remained popular although many individual artists suffered."@en ;
  dcterms:modified "2026-02-12T08:59:21.602826Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7597-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Radio ownership doubled in the 1930s."@en ;
  dcterms:modified "2026-02-12T08:59:21.602834Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7597-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A wide range of literature, ranging from novels to comics, flourished."@en ;
  dcterms:modified "2026-02-12T08:59:21.602846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7597-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cinemas remained a very popular form of entertainment."@en ;
  dcterms:modified "2026-02-12T08:59:21.602854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8205-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1958, over 3 million people had left East Germany via Berlin to live in West Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602862Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8205-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Khrushchev issued the Berlin Ultimatum to put pressure on the Western powers to abandon Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8205-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between 1958 and 1961, leaders from the USA and the USSR met four times to try and resolve disagreements over Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602878Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8205-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Paris Summit (May 1960) failed when an American U-2 spy plane was shot down over the Soviet Union."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602885Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8205-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Vienna Summit (June 1961) failed when Khrushchev unsuccessfully attempted to bully new US President, John F Kennedy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602893Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7489-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although the British Empire began to come to an end from the late 1940s, many former colonies joined the Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602901Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7489-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "As members of the Commonwealth, migration from former colonies continued."@en ;
  dcterms:modified "2026-02-12T08:59:21.602908Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7489-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Increasing migration from the Commonwealth led to new laws introduced to control and limit migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.602919Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7451-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were around 100 towns in Norman England in 1086, but most had a few hundred inhabitants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603205Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7451-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The immediate impact of the Norman conquest was bad for towns, with houses demolished and trade disrupted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603213Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7451-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Over time, many towns grew as Norman lords spent money in towns and trade links developed with Normandy and Flanders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7451-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Unlike in some areas, Anglo-Saxons with skills in crafts and industries continued to do well under Norman rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7451-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Immigration from Normandy and Jewish immigration were a feature of Norman town life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603236Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7408-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans loved an architectural style known now as Romanesque which looked back to features of Roman architecture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603244Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7408-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castles changed the landscape of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.603252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7408-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stone keeps and walls began to replace the wooden castle buildings and fortifications in the 12th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7408-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The architect of the White Tower was a monk from Normandy, called Gundulf."@en ;
  dcterms:modified "2026-02-12T08:59:21.603267Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7408-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Tower was built as a massive rectangular structure, with four corner turrets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603275Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7587-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Women were enfranchised in 1920 but enjoyed limited gains form this in the 1920s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7587-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Opportunities for women to work increased."@en ;
  dcterms:modified "2026-02-12T08:59:21.603294Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7587-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Women's work was usually less skilled and lower-paying than men's."@en ;
  dcterms:modified "2026-02-12T08:59:21.603303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7587-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many women enjoyed new social freedoms, especially flappers."@en ;
  dcterms:modified "2026-02-12T08:59:21.603310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7587-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Not all women were equally able, or willing, to enjoy new social freedoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.603318Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7599-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Censorship and rationing were introduced in the USA during WWII."@en ;
  dcterms:modified "2026-02-12T08:59:21.603430Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7599-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Seven million women entered the American workforce between 1940 and 1945."@en ;
  dcterms:modified "2026-02-12T08:59:21.603442Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7599-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The types of work completed by women became more varied."@en ;
  dcterms:modified "2026-02-12T08:59:21.603450Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7599-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "African Americans gained new opportunities for employment during the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.603458Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7599-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """African Americans continued to face discrimination both in the military and on the home front."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603470Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7249-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The invasion of the Vikings led to the merging of Viking culture and customs with Anglo-Saxon culture and customs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603479Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7249-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman conquest and establishment of the Angevin Empire forged a cultural connection between England and France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7249-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were many changes that took place to language, government, land ownership and the Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603494Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7249-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were aspects of continuity, including Christianity and parts of the Anglo-Saxon language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603502Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7249-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the loss of the Hundred Years' War, England began to see itself as having a separate English identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7446-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William faced unrest throughout most of England, and threats from Scotland and Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603863Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7446-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William rewarded his most loyal supporters with land so they would help him establish control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603871Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7446-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William also needed to pay mercenaries and show gratitude to the pope for his support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7446-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William made Odo and FitzOsbern earls in the south and appointed them as regents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603886Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7446-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William created new Marcher earldoms to defend the Welsh border."@en ;
  dcterms:modified "2026-02-12T08:59:21.603894Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7253-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During the Reformation, Henry VIII made England a Protestant country while France and Spain remained Catholic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603945Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7253-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the 1688 Glorious Revolution it became law that all English monarchs must be Protestant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603953Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7253-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 16th century many of the Huguenots began migrating to Britain to avoid persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603961Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7253-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the 1685 Edict of Nantes removed freedom of worship for Protestants, more Huguenots migrated to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603969Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7253-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Huguenots impacted British industry by continuing to practice as textile weavers, goldsmiths and bankers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603977Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7274-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Grand Alliance put aside their differences during the Second World War to defeat their common enemy, Nazi Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603984Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7274-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tensions emerged amongst the Grand Alliance because of different ideologies and priorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7274-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Important agreements were made at the Tehran Conference and the Yalta Conference about the post-war world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7274-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tensions increased at the Potsdam Conference for a range of reasons including a change in US President."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7274-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet occupation of Eastern Europe remained a source of significant tension between the USA and USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604015Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20693-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ideological differences meant there were tensions between the USA and USSR even when they were allies during WW2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604023Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20693-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1945, the Soviet creation of satellite states and the US development of the atomic bomb increased tensions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20693-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Concerned about Soviet expansion, Truman committed the USA to a policy of containment in 1947."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20693-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1948, the Berlin Crisis significantly increased Cold War tensions."@en ;
  dcterms:modified "2026-02-12T08:59:21.604050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20693-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cold War intensified during the 1950s due to the escalation of the arms race and the Soviet invasion of Hungary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7363-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wales was not a threat to Norman England, but the border situation helped those resisting Norman control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7363-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1067 and 1069, Eadric the Wild attacked Hereford and Shrewsbury with help from Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7363-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William I responded by creating the Marcher earldoms in Chester, Shrewsbury and Hereford."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604201Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7363-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Marcher earls were granted special privileges to help them control and colonise the Marches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604209Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7363-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """While there was no systematic plan to conquer Wales, the Marcher earls encouraged land grabs of Welsh territory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7380-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey is located on the south coast of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.604224Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7380-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey has a shallow beach."@en ;
  dcterms:modified "2026-02-12T08:59:21.604239Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7380-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey is on a peninsula."@en ;
  dcterms:modified "2026-02-12T08:59:21.604247Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7380-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex is an arable part of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.604255Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7380-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was able to maintain links with Normandy."@en ;
  dcterms:modified "2026-02-12T08:59:21.604263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7596-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some Republicans continued to support a laissez-faire approach."@en ;
  dcterms:modified "2026-02-12T08:59:21.604271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7596-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some businesses resented increased government interference under the New Deal."@en ;
  dcterms:modified "2026-02-12T08:59:21.604278Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7596-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Radicals argued that the New Deal did not do enough to help the American people."@en ;
  dcterms:modified "2026-02-12T08:59:21.604286Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7596-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Roosevelt's New Deal won widespread support as part of his landslide election victory in 1936."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604294Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7596-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Supreme Court declared some parts of the New Deal to be unconstitutional."@en ;
  dcterms:modified "2026-02-12T08:59:21.604305Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7313-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William was an experienced and organised military leader who held his army together in the summer of 1066."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604313Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7313-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold was an experienced military leader who was weakened by fighting at Stamford Bridge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604321Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7313-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The English troops had a varied skill level which held an effective shield wall that eventually broke."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7313-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman troops had a mix of professional skills which used a retreat tactic to break the English line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604336Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7313-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians recognise there were multiple reasons for William's victory at Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604344Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20364-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William had a stern personality, shown in the tension with his eldest son, Robert, (who he nicknamed ‘shorty-pants’)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604352Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20364-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Robert believed that William was denying him power, and in 1077, he rebelled."@en ;
  dcterms:modified "2026-02-12T08:59:21.604360Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20364-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William's deathbed succession announcement lacked clarity and divided his kingdom and duchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20364-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some of the Norman aristocracy agreed that Robert, as the eldest son, deserved to inherit both Normandy and England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604375Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20364-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Robert, Bishop Odo of Bayeux, and six of William’s largest landholders launched a failed attempt to remove William II."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604387Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7544-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Truman was concerned that high levels of poverty would allow communism to spread more easily in post-war Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604395Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7544-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Truman Doctrine committed the USA to a policy of containment."@en ;
  dcterms:modified "2026-02-12T08:59:21.604403Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7544-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The aim of the Marshall Plan was to stop the spread of communism by providing economic support to Western Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7544-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In response to the Marshall Plan, Stalin established Cominform and Comecon."@en ;
  dcterms:modified "2026-02-12T08:59:21.604419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7544-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Truman Doctrine and Marshall Plan (and the Soviet response they provoked) widened the divide between East and West."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604426Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7483-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From the 1700s the British Empire began to expand, leading to increasing numbers of migrants from both Asia and Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604434Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7483-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1800s saw the rapid growth of the British Empire in Africa, leading to greater numbers of African migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604446Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7483-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite most migrants having negative experiences, there were a number of exceptions who lived successful lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7483-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants from across the empire had the greatest impact on politics and the economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7523-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vietnam had previously been part of a French colony known as French Indochina."@en ;
  dcterms:modified "2026-02-12T08:59:21.605186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7523-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The French fought against a Vietnamese nationalist group, the Viet Minh."@en ;
  dcterms:modified "2026-02-12T08:59:21.605198Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7523-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The French were defeated by the Viet Minh and forced to withdraw from Vietnam."@en ;
  dcterms:modified "2026-02-12T08:59:21.605206Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7523-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "At the Geneva Conference in 1954, Vietnam was divided along the 17th parallel."@en ;
  dcterms:modified "2026-02-12T08:59:21.605213Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7513-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Brown v. Topeka ruling, many universities were slow to desegregate in the south - if at all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7513-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """James Meredith had tried several times to enrol at the University of Mississippi, with no success."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605229Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7513-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """With the support of President Kennedy, James Meredith enrolled at the University of Mississippi in 1962."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605237Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7513-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Federal intervention in the James Meredith case led to the 'Battle of Oxford'."@en ;
  dcterms:modified "2026-02-12T08:59:21.605245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7513-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite continued resistance across the south, federal intervention showed that attitudes were changing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20699-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between 1958 and 1970, a series of crises increased tensions between the USA and the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605260Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20699-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Second Berlin Crisis resulted in the building of the Berlin Wall which confirmed the division of Germany and Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20699-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cuban Missile Crisis almost led to nuclear war and highlighted the dangers of following a policy of brinkmanship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20699-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Cuban Missile Crisis, the USA and the USSR took action to prevent a similar crisis happening in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605283Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20699-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The invasion of Czechoslovakia damaged the USSR's relationship with the USA and also with some other communist states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605291Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7254-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite the Protestant Reformation, Ireland remained Catholic and the Irish resisted Protestant influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7254-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1609 James I established the Ulster plantations where English and Scottish Protestants moved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605745Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7254-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Irish Catholics were forced to move and the plantations created resentment of Protestants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605752Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7254-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Highlanders were Jacobites and spoke Gaelic, which British monarchs wanted to stamp out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605760Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7254-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many in the Scottish Highlands were forced to move away from their lands due to changes in land use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605767Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7491-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1905 Aliens Act was the first law to distinguish between refugees and other migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7491-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During World War Two, Britain allowed 10 000 Jewish refugees to settle as part of the Kindertransport programme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605782Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7491-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """International instability after the end of the Cold War meant increasing numbers of people migrating to safer countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7491-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From the 1990s, the British government gradually introduced laws restricting the migration of refugees."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605798Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7466-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Popes from the mid-11th century wished to reform the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.606247Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7466-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pope had given William of Normandy the papal banner to invade England."@en ;
  dcterms:modified "2026-02-12T08:59:21.606254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7466-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In return, William promised to reform the English Church in line with the Reform Papacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7466-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Pope Gregory IX issued his Dictatus Papae which said the pope had the power to depose monarchs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606274Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7466-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Reform Papacy clashed with monarchs in Europe, especially the Holy Roman Emperor, Henry IV."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25396-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA, the USSR, Britain and France disagreed about how to administer a divided Germany and a divided Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606290Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25396-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin's response to the creation of Trizonia and the introduction of the Deutschmark in 1948 led to the Berlin Crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25396-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between June 1948 and May 1949, the USSR set up a blockade to force the Western allies to abandon Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25396-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Western allies responded to the Berlin Blockade by successfully supplying Berlin from the air."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-25396-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Berlin Crisis confirmed the long-term division of Germany and Berlin and led to the creation of NATO."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606321Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7304-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Anglo-Saxons were a group of tribes which settled in England from northern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7304-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Anglo-Saxon society was hierarchical with the king at the top and slaves at the bottom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606383Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7304-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The aristocracy included the earls who helped the king to govern the country."@en ;
  dcterms:modified "2026-02-12T08:59:21.606391Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7304-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The majority of society lived in villages and were peasant farmers."@en ;
  dcterms:modified "2026-02-12T08:59:21.606399Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7304-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Anglo-Saxon society was not fixed."@en ;
  dcterms:modified "2026-02-12T08:59:21.606410Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7324-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The most significant change in Norman England was the change in the ruling elite."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7324-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A positive change was a reduction in the number of enslaved people."@en ;
  dcterms:modified "2026-02-12T08:59:21.606426Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7324-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """While some areas were damaged by Norman actions, generally the economy recovered under the Normans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606438Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7324-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Anglo-Saxon government systems were sophisticated and the Normans kept much more than they changed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606447Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7324-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One area of law that changed significantly was Forest law."@en ;
  dcterms:modified "2026-02-12T08:59:21.606454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7497-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Frank Crichlow set up the Mangrove all-night restaurant on All Saints Road in Notting Hill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7497-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It was visited by singers and musicians and became the heart of the black community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606470Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7497-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The police targetted the restaurant, claiming it was being used to deal drugs, and revoked its licence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606477Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7497-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British Black Panthers organised a protest march against police racism and discrimination, which led to arrests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606485Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7497-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Mangrove Nine were acquitted."@en ;
  dcterms:modified "2026-02-12T08:59:21.606516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7396-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Luck was considered important in both Anglo-Saxon and Norman cultures and was linked to God's favour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606940Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7396-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Viking invasion of September 1066 had significant consequences for William's invasion and the Battle of Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606948Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7396-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Medieval battles were often decided by luck, but William's planning, tactics and leadership were significant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606955Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7396-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William was fortunate not to face further attacks after the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.606962Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7418-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "De Warenne was an important ally of William I's."@en ;
  dcterms:modified "2026-02-12T08:59:21.606970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7418-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "De Warenne was religious and had been on pilgrimage."@en ;
  dcterms:modified "2026-02-12T08:59:21.606977Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7418-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "De Warenne was inspired by his visit to Cluny."@en ;
  dcterms:modified "2026-02-12T08:59:21.606984Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7418-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """De Warenne was a powerful earl in England; had been granted large amounts of land in Norfolk."""@en ;
  dcterms:modified "2026-02-12T08:59:21.606995Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7418-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "De Warenne founded Castle Acre Priory in Norfolk in around 1085."@en ;
  dcterms:modified "2026-02-12T08:59:21.607006Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7424-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The question will ask about either change, continuity, cause or consequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.607468Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7424-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Arguments about change, continuity, cause or consequence should be backed up with relevant evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7424-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The question will provide one factor to consider, to which you should add two more alternatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607483Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7424-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning your answer helps to achieve a sustained judgement."@en ;
  dcterms:modified "2026-02-12T08:59:21.607490Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7424-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """It is always important to use specific knowledge about your historic environment in your answer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7321-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Battle of Hastings, William took the land of all those who had fought against him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7321-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At first William kept some Anglo-Saxons in positions of power to help him be accepted as England’s new king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7321-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The uprisings against Norman rule changed William’s mind about including Anglo-Saxons in positions of power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607524Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7321-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William used his control over England’s land to transfer power from Anglo-Saxons to Normans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607531Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7321-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William’s methods of maintaining control included: military strength, harrying and castles, and government power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7543-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin agreed to free elections in Eastern Europe at Yalta but had no intention of allowing this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607545Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7543-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin believed Soviet control of Eastern Europe was essential to protect the USSR from any future invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607556Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7543-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1945 to 1948, the USSR used similar methods to turn most Eastern European countries into Soviet satellite states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7543-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR's establishment of satellite states in Eastern Europe significantly increased Cold War tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607571Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7543-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Churchill's 'Iron Curtain' speech in 1946 was a response to Soviet expansion into Eastern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607625Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7393-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "King Harold made careful preparations against William of Normandy's invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.607754Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7393-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The invasion by Hardrada and Tostig had not been expected, but the north had defences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7393-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different factors contributed to Harold's defeat of the Viking invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.607769Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7393-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman plundering of Wessex may have been designed to provoke Harold to battle William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607776Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7393-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold was advised to spend longer preparing for the Battle of Hastings than he did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.607783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7467-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As well as his Church reforms, Lanfranc also oversaw reform of English monasteries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608038Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7467-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "English monasteries grew in number and size under the Normans."@en ;
  dcterms:modified "2026-02-12T08:59:21.608049Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7467-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans introduced Cluniac monasteries to England."@en ;
  dcterms:modified "2026-02-12T08:59:21.608057Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7467-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "English abbots were replaced with Normans."@en ;
  dcterms:modified "2026-02-12T08:59:21.608064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7453-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans loved an architectural style known now as Romanesque."@en ;
  dcterms:modified "2026-02-12T08:59:21.608071Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7453-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Romanesque style looked back to features of ancient Roman architecture, such as huge stone columns and rounded arches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7453-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles were a major change to the built environment; stone replaced timber for building mainly from the 12th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608085Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7453-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Within 30 years of the Norman conquest, most church buildings in England were being rebuilt in Romanesque style."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7453-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were several reasons for the vast programme of rebuilding, including religious reforms and Norman wealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608103Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7365-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Vassals were people who swore allegiance to their overlord and received land from him in return for service."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7365-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Marcher earls often relied on vassals to defend the border and expand Norman control in Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608119Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7365-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman barons exploited weaknesses in Welsh resistance during power struggles between Welsh rulers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608126Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7365-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman barons such as Robert of Rhuddlan used brutal tactics to take control of parts of Wales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608134Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7381-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex was a mixture of rich coastal areas and poor heavily-forested areas."@en ;
  dcterms:modified "2026-02-12T08:59:21.608141Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7381-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex was home to important religious centres."@en ;
  dcterms:modified "2026-02-12T08:59:21.608148Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7381-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex had established trade links with Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.608155Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7381-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex formed a part of the earldom of Wessex."@en ;
  dcterms:modified "2026-02-12T08:59:21.608162Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7381-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sussex was one of the Godwin family's bases."@en ;
  dcterms:modified "2026-02-12T08:59:21.608173Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7591-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Speculation led to increases in private debt and shares became overvalued."@en ;
  dcterms:modified "2026-02-12T08:59:21.608181Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7591-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """American goods were overproduced in the US but tariffs made them too expensive for European markets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608189Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7591-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Share prices collapsed during the Wall Street Crash, ruining many speculators and shareholders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608196Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7591-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "659 banks collapsed in 1929."@en ;
  dcterms:modified "2026-02-12T08:59:21.608203Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7591-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bank failures hurt millions of Americans, including those who had not traded in shares."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7247-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman conquest meant that there was a strong cultural connection between England and France."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7247-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After the Anarchy, Henry II formed the Angevin Empire when he became king."@en ;
  dcterms:modified "2026-02-12T08:59:21.608225Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7247-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1171 Henry II invaded Ireland and became known as 'overlord of Ireland'."@en ;
  dcterms:modified "2026-02-12T08:59:21.608232Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7247-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During the reign of King John, most of the continental territory of the Angevin Empire was lost."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608239Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7247-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The loss of territories in France under King John contributed to the First Barons' War and Magna Carta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608247Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7482-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The start of the Hanoverian reign led to an increase in German migration, with German migrants welcomed by authorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7482-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The French Revolution led to increasing migration from France."@en ;
  dcterms:modified "2026-02-12T08:59:21.608261Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7482-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite French migrants initially being welcomed, attitudes towards French migrants became more hostile in the 1800s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7482-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Due to the Italian Wars of Independence, many Italian migrants settled and impacted various areas of life in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608275Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7472-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Jewish people were invited to migrate to England by Norman rulers."@en ;
  dcterms:modified "2026-02-12T08:59:21.608283Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7472-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Jewish people were encouraged to work as moneylenders, although many also worked in other professions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608294Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7472-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Due to increasing antisemitism, Jewish people faced greater discrimination from the late 1100s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608302Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7472-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jewish people were expelled by Edward I in 1290, not to return for nearly 400 years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608312Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7416-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cluny Abbey was founded in 910 by the Duke of Aquitaine (a region in France), as a Benedictine monastery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7416-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cluny Abbey was largely independent and returned to strictly following the Rule of St Benedict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608512Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7416-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cluniac order developed a much longer and more complex liturgy, in the aim of providing perpetual prayer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608519Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7416-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cluniac order spent so much time praying that they relied on local employees to do all their manual work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608527Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7416-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cluniac priories were brought to England by the Normans, but remained under the strict control of Cluny Abbey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608534Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7952-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three types of historical environment questions on Notting Hill."@en ;
  dcterms:modified "2026-02-12T08:59:21.608545Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7952-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """They require you to demonstrate specific knowledge and understanding of the key features of the period you have studied."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608553Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7952-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You need to analyse and use sources to make supported judgements, using your knowledge of the context of Notting Hill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608561Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20696-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Escalating tensions after the Vienna Summit (June 1961) led to an increase in people attempting to leave East Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608568Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20696-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In August 1961, to stop people leaving East Berlin, East Germany began to build what would become the Berlin Wall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20696-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Berlin Wall made it extremely difficult and dangerous to move between East Berlin and West Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608583Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20696-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Berlin Wall confirmed the division of Berlin and Germany between East and West until it fell in 1989."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608594Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20696-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Berlin Wall reduced the chance that the superpowers would go to war over Berlin and temporarily reduced tensions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608602Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7563-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan was strongly anti-communist and made it clear that fighting communism would be the focus of his foreign policy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608609Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7563-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan’s tougher approach to the USSR led to a period of increased tension and hostility known as the Second Cold War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608617Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7563-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan inflamed tensions by describing the USSR as 'evil' and adopting an aggressive approach towards negotiations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608624Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7563-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan's announcement of the Strategic Defence Initiative (SDI) in 1983 caused great alarm in the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7563-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan hoped that Soviet attempts to ensure they could compete in the arms race would cause their economy to collapse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.608638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7521-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Panther Party was founded in 1966, and was inspired by the beliefs of the Black Power movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609695Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7521-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Panther Party encouraged self-sufficiency in the black community and sought to take down 'the establishment'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609702Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7521-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Panther Party's biggest achievement was the Free Breakfast for Children Program."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609709Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7521-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Panther Party eventually disbanded after constant targeting from the FBI and the murder of 27 Black Panthers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609716Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7271-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Post-decolonisation, some small countries remained in the British Empire as British Overseas Territories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612142Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7271-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Falkland Islands, near Argentina, had been claimed by Britain in 1833 and British people had settled there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612149Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7271-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1982, Britain sent troops to defend the Falklands from Argentine invasion, which they defeated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612156Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7271-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Falklands War created tension between Britain and Argentina which still exists today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612163Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7326-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman aristocracy brought with them a distinct warrior culture which included castles and chivalry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612173Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7326-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman aristocracy viewed their simple and pious culture as superior to the Anglo-Saxon culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612181Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7326-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """English churches were rebuilt in the new Romanesque style that was fashionable amongst the Norman aristocracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612189Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7326-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman aristocracy spoke Norman-French and used Latin for the Church and official documents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7309-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tostig Godwinson was made the earl of Northumbria, part of the Danelaw."@en ;
  dcterms:modified "2026-02-12T08:59:21.612208Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7309-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Earl Tostig's actions made him very unpopular."@en ;
  dcterms:modified "2026-02-12T08:59:21.612215Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7309-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1065, there was an uprising against Tostig."@en ;
  dcterms:modified "2026-02-12T08:59:21.612223Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7309-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "King Edward ordered his other earls to put down the rebellion."@en ;
  dcterms:modified "2026-02-12T08:59:21.612230Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7309-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold Godwinson ignored Edward's order and Tostig Godwinson was exiled."@en ;
  dcterms:modified "2026-02-12T08:59:21.612237Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7534-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon attempted a change in policy in Vietnam in order to reduce US involvement."@en ;
  dcterms:modified "2026-02-12T08:59:21.612706Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7534-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The change in policy had mixed results and led to an expansion of the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.612713Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7534-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """US public opinion towards the war was mixed, although the popularity of the war declined overall as it wore on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612720Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7535-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Johnson began negotiations in 1968, but little to no progress was made."@en ;
  dcterms:modified "2026-02-12T08:59:21.612992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7535-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nixon began secret negotiations with North Vietnam when he became president in 1969."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7535-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A breakthrough in the secret negotiations happened in 1972, but South Vietnam refused to accept the draft peace treaty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613007Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7535-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """War continued whilst negotiations were ongoing, through actions like the Easter Offensive and Operation Linebacker II."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613014Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7306-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earls were very powerful, holding economic, legal and military control over their earldoms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614187Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7306-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "King Edward relied on the earls for military power and government."@en ;
  dcterms:modified "2026-02-12T08:59:21.614194Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7306-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earldoms provided a local government and legal system which was divided into shires, hundreds, tithings, and hides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614201Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7306-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Every five hides had to provide one man for the fyrd."@en ;
  dcterms:modified "2026-02-12T08:59:21.614208Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7306-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Local government provided a centralised Anglo-Saxon state with justice administered in local communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614214Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7533-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After anti-war protests, Nixon called on the ‘Silent Majority’ of Americans to support his methods of ending the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7533-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon’s popularity increased greatly after this speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.614228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7533-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People supported the war because of their patriotism and fear of communism."@en ;
  dcterms:modified "2026-02-12T08:59:21.614235Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7533-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Blue-collar workers in favour of US involvement in Vietnam held their own rallies and attacked anti-war protesters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7564-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "By the mid-1980s, the USSR was facing a range of serious problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.614349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7564-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gorbachev became Soviet leader in March 1985, determined to reform communism in the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614356Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7564-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Through his policy of perestroika, Gorbachev reorganised and restructured the Soviet state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7564-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Through Gorbachev's policy of glasnost, the USSR adopted a more open approach to government and foreign relations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614370Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7564-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Reagan worked with Gorbachev to reduce Cold War tensions and important steps were taken to limit nuclear weapons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614377Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20702-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1989, the Soviet Union lost control of Eastern Europe and Germany was reunified as a democratic state."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614384Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20702-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Warsaw Pact ended in July 1991."@en ;
  dcterms:modified "2026-02-12T08:59:21.614391Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20702-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In August 1991, Gorbachev was briefly overthrown by a coup and when he returned to power his authority was weakened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614398Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20702-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1990 onwards, demands for independence from Soviet republics critically weakened the Soviet Union."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614405Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20702-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """On 25th December 1991, Gorbachev resigned as Soviet leader and announced the dissolution of the Soviet Union."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614412Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7442-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After his coronation, King Harold II expected an invasion from Normandy."@en ;
  dcterms:modified "2026-02-12T08:59:21.615134Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7442-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harald Hardrada, king of Norway, also had a claim to the English throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.615141Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7442-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hardrada and Tostig Godwinson launched an invasion of England in September 1066."@en ;
  dcterms:modified "2026-02-12T08:59:21.615151Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7442-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold Godwinson defeated Hardrada and Tostig at the Battle of Stamford Bridge."@en ;
  dcterms:modified "2026-02-12T08:59:21.615159Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7442-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold Godwinson's victory had consequences for the Norman invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.615166Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7395-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William had Battle Abbey constructed on the site of the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.615173Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7395-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Key features of the battlefield included a hill, a ridge and marshy ground."@en ;
  dcterms:modified "2026-02-12T08:59:21.615179Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7395-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The battle took place at a strategic location, rather than just where the two armies happened to meet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615186Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7395-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There has been dispute about the actual location of the battlefield."@en ;
  dcterms:modified "2026-02-12T08:59:21.615193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7520-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Continued riots and unrest following the Civil Rights Act (1964) led to some looking for new methods of protest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615699Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7520-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stokely Carmichael led several other members of SNCC to reject many groups and create their own political force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615705Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7520-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Power movement faced a lot of criticism because some believed it meant separatism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615712Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7520-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Mexico Olympics (1968) raised the profile of the Black Power Movement, with several athletes pledging their support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615718Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7541-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Grand Alliance put aside their differences during the Second World War to defeat their common enemy, Nazi Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7541-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tensions emerged amongst the Grand Alliance because of different ideologies and priorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615864Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7541-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Important agreements were made at the Tehran Conference and the Yalta Conference about the post-war world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7541-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Tensions increased at the Potsdam Conference for a range of reasons including a change in US President."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615876Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7541-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet occupation of eastern Europe remained a source of significant tension between the USA and USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615883Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7443-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William of Normandy invaded England after Harold had fought the Battle of Stamford Bridge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616318Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7443-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold's army consisted of an elite of housecarls with the majority being the untrained peasant conscripts of the fyrd."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616325Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7443-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold held the high ground on Senlac Hill with a shield wall."@en ;
  dcterms:modified "2026-02-12T08:59:21.616331Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7443-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William’s army mainly consisted of professional soldiers using a mix of archers and cavalry charges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7443-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William's tactics brought him victory while Harold and many Anglo-Saxon nobles were killed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616344Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7292-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New leaders came to power in both the USA and USSR after 1953."@en ;
  dcterms:modified "2026-02-12T08:59:21.616682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7292-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Khrushchev and Eisenhower both believed US and Soviet differences did not need to be settled through conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616689Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7292-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1955 Geneva Summit was attended by both Eisenhower and Khrushchev."@en ;
  dcterms:modified "2026-02-12T08:59:21.616698Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7292-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Geneva Summit was the first meeting between the leaders of the superpowers since the end of WW2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616705Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7292-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "No agreements were reached during the Geneva Summit."@en ;
  dcterms:modified "2026-02-12T08:59:21.616712Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7368-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617284Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7368-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.617291Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7368-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.617297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7368-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans sometimes exploited the Welsh"@en ;
  dcterms:modified "2026-02-12T08:59:21.617303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7368-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians debate the extent of the Norman exploitation of Wales"@en ;
  dcterms:modified "2026-02-12T08:59:21.617310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7465-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The crown and the Church were separate institutions."@en ;
  dcterms:modified "2026-02-12T08:59:21.617933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7465-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was a contemporary debate about royal involvement in the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.617938Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7465-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William I and Lanfranc cooperated on Church matters."@en ;
  dcterms:modified "2026-02-12T08:59:21.617945Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7465-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William II and Anselm argued over Church matters."@en ;
  dcterms:modified "2026-02-12T08:59:21.617951Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7465-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Henry I and Anselm argued over investiture."@en ;
  dcterms:modified "2026-02-12T08:59:21.617957Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7293-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The development of the atomic bomb triggered a nuclear arms race."@en ;
  dcterms:modified "2026-02-12T08:59:21.617963Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7293-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA and USSR competed to develop larger and more powerful nuclear weapons."@en ;
  dcterms:modified "2026-02-12T08:59:21.617969Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7293-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "By 1961, both superpowers had the ability to destroy the world many times over."@en ;
  dcterms:modified "2026-02-12T08:59:21.617975Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7293-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mutually Assured Destruction suggested nuclear weapons deterred war."@en ;
  dcterms:modified "2026-02-12T08:59:21.617990Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7293-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The nuclear arms race became increasingly focused on deterrence."@en ;
  dcterms:modified "2026-02-12T08:59:21.617997Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7391-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Norman army contained a mix of infantry and cavalry."@en ;
  dcterms:modified "2026-02-12T08:59:21.618006Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7391-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Norman army was made up of professional soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.618012Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7391-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Norman infantry included foot soldiers and archers."@en ;
  dcterms:modified "2026-02-12T08:59:21.618019Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7391-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Norman army featured military innovations that were new to England."@en ;
  dcterms:modified "2026-02-12T08:59:21.618025Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7391-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The shield wall needed to be weakened before Norman cavalry could be effective."@en ;
  dcterms:modified "2026-02-12T08:59:21.618031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7570-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Both superpowers were glad not to have gone to war."@en ;
  dcterms:modified "2026-02-12T08:59:21.618037Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7570-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "JFK's tough stance against the USSR was praised in the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.618046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7570-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR benefitted from American promises not to attack Cuba and to withdraw missiles from Turkey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618052Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7570-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Khrushchev's reputation suffered in the USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.618058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7570-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Agreements were made between the superpowers aimed at making a future war between them less likely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618065Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7527-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """American engagement in Vietnam escalated through the use of advanced technology and increased numbers of troops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618197Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7527-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Americans believed that victory was sure to come soon."@en ;
  dcterms:modified "2026-02-12T08:59:21.618203Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7527-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Vietcong and NVA launched a huge surprise attack across South Vietnam during the Tet national holiday."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618209Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7527-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Tet Offensive failed to make any gains and resulted in significant losses for the communists."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618215Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7527-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "However, it shocked America and made them doubt whether they could win the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.618224Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7251-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Before the arrival of the Europeans, West Africa was wealthy and central to growing trade networks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619330Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7251-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The arrival of the Europeans de-stabilised West African society and led to the trade in enslaved people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619339Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7251-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between the 16th and 19th centuries, enslaved West Africans were transported to work on plantations in the Americas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619346Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7251-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Those who were enslaved faced brutal conditions on the plantations and the loss of their freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619352Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7251-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The enslaved West Africans brought with them a mixture of language and traditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7526-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US President Lyndon B. Johnson continued US involvement in Vietnam."@en ;
  dcterms:modified "2026-02-12T08:59:21.619596Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7526-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An American ship was attacked by North Vietnamese patrol boats in the Gulf of Tonkin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619602Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7526-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "American ships thought they were attacked a second time, but they were mistaken."@en ;
  dcterms:modified "2026-02-12T08:59:21.619607Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7526-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "America launched air strikes on North Vietnam in response."@en ;
  dcterms:modified "2026-02-12T08:59:21.619613Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7526-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """America did not officially declare war on North Vietnam, but Congress authorised aggressive action to be taken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619619Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7423-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620977Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7423-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.620983Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7423-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.620992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7423-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pope supported the reforms"@en ;
  dcterms:modified "2026-02-12T08:59:21.620998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7423-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians study the changing rules within the English Church"@en ;
  dcterms:modified "2026-02-12T08:59:21.621004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7413-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7413-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.621629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7413-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.621635Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7413-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norman religious buildings may have intimidated local Anglo-Saxons"@en ;
  dcterms:modified "2026-02-12T08:59:21.621640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7413-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians debate the main impact of Norman Church reform"@en ;
  dcterms:modified "2026-02-12T08:59:21.621646Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7574-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The arms race continued in the 1960s."@en ;
  dcterms:modified "2026-02-12T08:59:21.621845Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7574-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Vietnam War created tensions between the USA and USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.621851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7574-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA was critical of the Soviet's record on human rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.621856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7574-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many rights were heavily restricted in the USSR, or not respected at all."@en ;
  dcterms:modified "2026-02-12T08:59:21.621865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7536-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon used a ‘carrot and stick’ approach to restart negotiations"@en ;
  dcterms:modified "2026-02-12T08:59:21.621872Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7536-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The US accepted the unification of Vietnam during the Paris Peace Agreement"@en ;
  dcterms:modified "2026-02-12T08:59:21.621878Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7536-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA had to withdraw from Vietnam"@en ;
  dcterms:modified "2026-02-12T08:59:21.621883Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7536-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA agreed not to involve itself in Vietnamese affairs"@en ;
  dcterms:modified "2026-02-12T08:59:21.621889Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7536-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Saigon fell to North Vietnam when the North invaded South Vietnam again in 1975"@en ;
  dcterms:modified "2026-02-12T08:59:21.621895Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7388-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622090Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7388-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.622096Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7388-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.622101Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7388-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was used by the Norman elite to help them rule England"@en ;
  dcterms:modified "2026-02-12T08:59:21.622107Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7388-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians debate the extent to which the Normans used castles to project power"@en ;
  dcterms:modified "2026-02-12T08:59:21.622113Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7440-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After years in exile in Normandy, Edward the Confessor's position as king was weak; he relied on Earl Godwin's support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622719Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7440-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1051 the Godwins were exiled after tensions over Edward's Norman advisers."@en ;
  dcterms:modified "2026-02-12T08:59:21.622725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7440-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After threatening to invade, the Godwins returned to positions of power."@en ;
  dcterms:modified "2026-02-12T08:59:21.622731Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7440-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edward relied more and more on the Godwins, whose power increased."@en ;
  dcterms:modified "2026-02-12T08:59:21.622736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7440-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In a trip to Normandy in 1064, Harold Godwin made promises to William, Duke of Normandy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622742Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7458-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The strict conditions for holding land from the king became known as the feudal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622773Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7458-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The feudal system made landholding less secure than it had been under Anglo-Saxon kings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622782Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7458-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A key relationship in the feudal system was between a vassal and their overlord."@en ;
  dcterms:modified "2026-02-12T08:59:21.622788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7458-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Holding land came with obligations such as paying homage, providing knight service or labour service."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7458-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The feudal system increased William’s power and control over England."@en ;
  dcterms:modified "2026-02-12T08:59:21.622799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7378-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623183Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7378-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.623189Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7378-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.623195Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7378-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral may have inspired Anglo-Saxons to further worship"@en ;
  dcterms:modified "2026-02-12T08:59:21.623200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7378-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians debate the impact of the new building upon ordinary people"@en ;
  dcterms:modified "2026-02-12T08:59:21.623206Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7392-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Normans used a range of weapons at the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.623365Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7392-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norman armour was effective but did have disadvantages."@en ;
  dcterms:modified "2026-02-12T08:59:21.623370Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7392-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William used different tactics in the battle until he found ones that worked."@en ;
  dcterms:modified "2026-02-12T08:59:21.623376Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7392-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One of the Norman tactics may have been a feigned retreat."@en ;
  dcterms:modified "2026-02-12T08:59:21.623381Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7444-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William was an experienced and organised military leader who held his army together in the summer of 1066."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623570Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7444-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Harold was an experienced military leader who was weakened by fighting at Stamford Bridge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623575Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7444-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The English troops had a varied skill level which held an effective shield wall that eventually broke."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623583Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7444-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Norman troops had a mix of professional skills which used a retreat tactic to break the English line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7444-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians recognise there were multiple reasons for William's victory at Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623594Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7525-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Vietcong were a guerilla group opposed to Diem's government in South Vietnam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7525-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Strategic Hamlets Program was created by Diem's government to combat the Vietcong."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623655Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7525-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US President, John F. Kennedy, increased America's involvement in Vietnam."@en ;
  dcterms:modified "2026-02-12T08:59:21.623660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7525-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Diem was assassinated because of his repressive policies, such as the Strategic Hamlets Program."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7297-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US and Soviet relations showed signs of improvement at the end of the 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.624067Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7297-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1960 Paris Summit was scheduled to try and resolve issues such as Berlin, Cuba and nuclear testing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7297-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In May 1960, a US U2 spy plane was shot down over the USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.624078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7297-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The U2 Crisis helped trigger the collapse of the Paris Summit."@en ;
  dcterms:modified "2026-02-12T08:59:21.624083Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7297-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Tensions between the US and USSR increased as a result of the U2 Crisis."@en ;
  dcterms:modified "2026-02-12T08:59:21.624091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7459-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In Norman England, all land was owned by the king."@en ;
  dcterms:modified "2026-02-12T08:59:21.624276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7459-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In Anglo-Saxon England, people held land in a range of different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.624282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7459-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Changes in tenure in Norman England also affected the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.624287Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7459-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The king was able to influence inheritance in Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.624292Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7459-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Large numbers of Anglo-Saxons lost the land which they had previously."@en ;
  dcterms:modified "2026-02-12T08:59:21.624297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7390-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Anglo-Saxons did not have a standing army."@en ;
  dcterms:modified "2026-02-12T08:59:21.624303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7390-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The elite Anglo-Saxon soldiers were known as housecarls."@en ;
  dcterms:modified "2026-02-12T08:59:21.624311Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7390-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The fyrd made up the majority of an Anglo-Saxon army."@en ;
  dcterms:modified "2026-02-12T08:59:21.624317Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7390-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Historians talk about a 'select fyrd' and a 'general fyrd'."@en ;
  dcterms:modified "2026-02-12T08:59:21.624322Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7390-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The fyrd had advantages and disadvantages in the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.624330Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7603-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA experienced the second Red Scare during the 1940s and 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.624336Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7603-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historical, international and domestic factors contributed to the second Red Scare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7603-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A wide range of Americans were investigated during hunts for communists."@en ;
  dcterms:modified "2026-02-12T08:59:21.624349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7603-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Joseph McCarthy became a leading anti-communist figure."@en ;
  dcterms:modified "2026-02-12T08:59:21.624355Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7603-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "McCarthyism involved accusing others of being communists with little proof."@en ;
  dcterms:modified "2026-02-12T08:59:21.624361Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7540-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vietnam veterans suffered problems upon their return to the US."@en ;
  dcterms:modified "2026-02-12T08:59:21.624567Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7540-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Vietnam War caused the US public to lose faith in their government."@en ;
  dcterms:modified "2026-02-12T08:59:21.624573Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7540-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Vietnamese people and landscape suffered greatly due to the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.624578Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7540-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although all of Indochina became communist, no other Southeast Asian country did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624584Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7540-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Relations between the US and the USSR and China improved, which made nuclear war less likely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624589Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7259-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic interests and imperial expansion drove European interest in African colonies in the 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624669Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7259-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1875 Britain bought shares in the Suez Canal and effectively controlled Egypt until the 1950s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7259-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1884-5 Berlin Conference partitioned Africa and led to British dominance."@en ;
  dcterms:modified "2026-02-12T08:59:21.624694Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7259-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """European colonisation had far-reaching and enduring consequences that have shaped Africa's history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624700Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7398-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Different types of sources provide insights into the historical context of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625297Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7398-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Three types of sources are visual sources, text sources and material sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.625303Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7398-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Each type of source has strengths and limitations."@en ;
  dcterms:modified "2026-02-12T08:59:21.625310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7283-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Korean War ended in 1953."@en ;
  dcterms:modified "2026-02-12T08:59:21.625829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7283-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA rollback strategy failed during the Korean War."@en ;
  dcterms:modified "2026-02-12T08:59:21.625835Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7283-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Korean War was a proxy war between the USA and USSR."@en ;
  dcterms:modified "2026-02-12T08:59:21.625843Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7283-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Proxy wars allowed the superpowers to avoid direct conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.625851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7283-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Soviet influence over China grew during and immediately after the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.625856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7441-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were four claimants to the throne in 1066."@en ;
  dcterms:modified "2026-02-12T08:59:21.626037Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7441-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold Godwinson had the support of the Witan."@en ;
  dcterms:modified "2026-02-12T08:59:21.626042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7441-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William of Normandy claimed to have been promised the throne by Edward the Confessor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7441-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harald Hardrada claimed a historical right to the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.626056Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7441-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edgar the Aetheling was Edward the Confessor's closest living relative."@en ;
  dcterms:modified "2026-02-12T08:59:21.626061Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7305-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The king had a duty to protect the kingdom and had powers over the army, laws, landownership, and money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626253Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7305-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In return, the people had a duty to obey the laws and serve the king through taxes and military service."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626290Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7305-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Edward the Confessor’s power was balanced by powerful earls who controlled thegns and armies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626296Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7305-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edward had gained legitimacy through his piety and law-making."@en ;
  dcterms:modified "2026-02-12T08:59:21.626301Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7305-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Witan advised the king and had a role in selecting his successor."@en ;
  dcterms:modified "2026-02-12T08:59:21.626306Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7449-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William’s control of the North was threatened by rebellions."@en ;
  dcterms:modified "2026-02-12T08:59:21.626434Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7449-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William aimed to destroy the spirit of rebellion and ensure that no future rebellion could support itself in the North."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626442Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7449-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman soldiers systematically killed rebels and destroyed food across Yorkshire – later known as ‘Harrying the North’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626447Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7449-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The resulting famine caused as many as 100 000 people to vanish from the records."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626452Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7449-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There were no further uprisings in the North, but William was criticised for excessive brutality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626457Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7518-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Martin Luther King Jr moved north in 1966 to tackle issues of poverty and poor housing for black Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7518-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Chicago Freedom Movement used non-violent direct action to attempt to bring about change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626493Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7518-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some celebrated the movement as a success, but most felt it was a failure and brought little actual change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7518-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When King was assassinated in 1968, riots broke across the US and many look for more radical forms of protest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7285-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "South Vietnam was supported by the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.626756Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7285-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US involvement in Vietnam escalated between 1954 and 1968."@en ;
  dcterms:modified "2026-02-12T08:59:21.626761Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7285-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Vietnam was supported by the USSR and China."@en ;
  dcterms:modified "2026-02-12T08:59:21.626771Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7285-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US prestige was damaged by the conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.626776Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7468-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans changed many aspects of the English Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.626975Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7468-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norman personnel were installed in senior Church positions."@en ;
  dcterms:modified "2026-02-12T08:59:21.626980Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7468-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The English Church was brought in line with ideas of the Reform Papacy."@en ;
  dcterms:modified "2026-02-12T08:59:21.626985Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7598-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA joined the Second World War in December 1941."@en ;
  dcterms:modified "2026-02-12T08:59:21.627684Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7598-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In the 1930s, Neutrality Acts had kept the USA out of foreign conflicts"@en ;
  dcterms:modified "2026-02-12T08:59:21.627689Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7598-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cash and Carry and Lend Lease involved the US in supplying countries like Britain with wartime supplies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627694Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7598-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearmament led to growth in industrial and agricultural production."@en ;
  dcterms:modified "2026-02-12T08:59:21.627699Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7598-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rearmament led to a significant fall in American unemployment."@en ;
  dcterms:modified "2026-02-12T08:59:21.627703Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7558-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Brezhnev believed that Alexander Dubcek's Prague Spring reforms in Czechoslovakia were a threat to the Warsaw Pact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627735Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7558-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In August 1968, the USSR invaded Czechoslovakia and replaced Dubcek with Gustav Husak who reversed Dubcek's reforms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627739Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7558-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Brezhnev Doctrine was used to justify the invasion, claiming it was necessary to protect the Warsaw Pact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627744Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7558-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA condemned the Soviet invasion but they did not intervene due to presidential elections and the war in Vietnam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627749Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7558-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Soviet invasion damaged the USSR's relationship with other communist countries including China."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627754Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7510-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was legal progress in achieving desegregation in education, although there was significant resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627802Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7510-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was significant progress in achieving desegregation in transport, despite violent resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627809Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7510-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Organised opposition limited the progress made by black Americans by 1960."@en ;
  dcterms:modified "2026-02-12T08:59:21.627815Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7510-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1960, the position of black Americans had started to improve as a result of non-violent direct action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627820Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7508-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rosa Parks refused to give up her seat for a white man."@en ;
  dcterms:modified "2026-02-12T08:59:21.627824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7508-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Black Americans came together to boycott the buses in Montgomery."@en ;
  dcterms:modified "2026-02-12T08:59:21.627829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7508-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Martin Luther King Jr became the leader of the Montgomery bus boycott."@en ;
  dcterms:modified "2026-02-12T08:59:21.627834Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7508-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The boycott ended in the successful desegregation of buses in Montgomery."@en ;
  dcterms:modified "2026-02-12T08:59:21.627841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7508-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The boycott was one of the first successful mass non-violent protests."@en ;
  dcterms:modified "2026-02-12T08:59:21.627846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7555-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cuban Missile Crisis began on 14th October 1962 when the USA discovered Soviet missile bases in Cuba."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7555-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Khrushchev built missile bases in Cuba for several reasons but it was partly a response to US missile bases in Turkey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7555-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USA set up a blockade around Cuba; as Soviet ships approached, people feared the possibility of nuclear war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627861Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7555-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The US blockade was successful; this strengthened Kennedy's reputation and weakened Khrushchev's position as leader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7555-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the crisis, the USA and the USSR took steps to reduce the risk of a similar crisis happening in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7469-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Vikings invaded England as it was a wealthy country and Scandinavia was overpopulated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627986Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7469-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At the 878 Battle of Edington, King Alfred defeated the Vikings which led to the creation of the Danelaw."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627991Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7469-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1016, King Cnut became King of England; as king, he supported the Church and brought economic prosperity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7949-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution, expansion of empire and increasing civil liberties in Britain led to increasing migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7949-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrant experiences varied, but depended largely how much they could contribute to the economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628077Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7949-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrants had the most significant impact on the economy, politics and built environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628082Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7277-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Truman was concerned that high levels of poverty would allow communism to spread more easily in post-war Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628187Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7277-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Truman Doctrine committed the USA to a policy of containment."@en ;
  dcterms:modified "2026-02-12T08:59:21.628193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7277-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The aim of the Marshall Plan was to stop the spread of communism by providing economic support to Western Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628197Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7277-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In response to the Marshall Plan, Stalin established Cominform and Comecon."@en ;
  dcterms:modified "2026-02-12T08:59:21.628205Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7277-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Truman Doctrine and Marshall Plan (and the Soviet response they provoked) widened the divide between East and West."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7310-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were four claimants to the throne in 1066."@en ;
  dcterms:modified "2026-02-12T08:59:21.628215Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7310-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harold Godwinson had the support of the Witan."@en ;
  dcterms:modified "2026-02-12T08:59:21.628220Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7310-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William of Normandy claimed to have been promised the throne by Edward the Confessor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628225Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7310-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Harald Hardrada claimed a historical right to the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.628230Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7310-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edgar the Aetheling was Edward the Confessor's closest living relative."@en ;
  dcterms:modified "2026-02-12T08:59:21.628234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7452-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Village life followed a seasonal pattern."@en ;
  dcterms:modified "2026-02-12T08:59:21.628263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7452-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many features of village life stayed the same after the Norman conquest."@en ;
  dcterms:modified "2026-02-12T08:59:21.628268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7452-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norman landholders often worked villagers harder and this was resented."@en ;
  dcterms:modified "2026-02-12T08:59:21.628273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7452-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The feudal system meant a decline in the numbers of freemen and a tighter control over villeins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628281Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7452-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some villages in the north were destroyed during the Harrying of the North."@en ;
  dcterms:modified "2026-02-12T08:59:21.628286Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7410-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The White Tower could accommodate royals and nobles."@en ;
  dcterms:modified "2026-02-12T08:59:21.628291Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7410-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the king's absence, the keeper (castellan) was the most important resident of the White Tower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628296Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7410-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Tower housed a garrison who likely stayed in barracks in the bailey or in the first floor hall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628300Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7410-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Tower also housed craftsmen to create and maintain weapons and a chaplain or priest to serve St John's Chapel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628305Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7568-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "American spy planes detected Soviet missile bases on Cuba."@en ;
  dcterms:modified "2026-02-12T08:59:21.628310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7568-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The discovery of Soviet missile bases triggered the Cuban Missile Crisis."@en ;
  dcterms:modified "2026-02-12T08:59:21.628315Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7568-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Soviet missiles on Cuba would be capable of hitting most of the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.628320Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7568-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cuba and the USSR suspected that the US was planning to invade Cuba."@en ;
  dcterms:modified "2026-02-12T08:59:21.628325Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7568-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Khrushchev was concerned by US missiles installed in Turkey."@en ;
  dcterms:modified "2026-02-12T08:59:21.628332Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28880-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis had high levels of support and conformity; it is difficult to gauge the scale of opposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28880-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Resistance came from scattered groups: workers, youth, clergy, and individuals acting in secret."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628347Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28880-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Protestant Confessional Church formed in opposition to the Reich Church; its leader, Niemöller, was imprisoned."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628353Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28880-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Pope attacked Hitler with a public letter; Catholic priests fought against euthanasia of people with disabilities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28880-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Swing Youth and Edelweiss Pirates resisted Nazi control through music, fashion, and secret actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628362Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7325-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1085, William ordered a survey to detail the possessions of his new kingdom of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628367Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7325-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The survey was compiled in 1086, and the two volumes of records became known as Domesday Book."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7325-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians do not fully agree on the purpose, but Domesday Book gave William a very detailed account of landholding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628379Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7325-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Domesday may also have provided William with an accurate account of the tax and soldiers his new kingdom could provide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628384Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7325-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Domesday increased William’s royal authority: the capacity to seize and distribute lands, and to charge accordingly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628389Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7316-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William needed to overcome a hostile Anglo-Saxon population if he wished to control England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7316-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Anglo-Saxon nobility rallied behind Edgar the Aethling as the next king of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628587Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7316-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William’s army was vulnerable, in a foreign land with limited supplies."@en ;
  dcterms:modified "2026-02-12T08:59:21.628592Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7316-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William used harrying and violence to induce submission from the Anglo-Saxon nobility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628596Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7316-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earls Edwin and Morcar, Edgar the Aethling and Stigand, the Archbishop of Canterbury, submitted to William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628601Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7511-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Although many universities had segregated by 1960, many facilities used by students were still segregated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628606Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7511-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Greensboro sit-in was organised by students."@en ;
  dcterms:modified "2026-02-12T08:59:21.628611Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7511-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The sit-in was successful, and became another example of the effectiveness of non-violent direct action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628616Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7511-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The success of the sit-in led to the formation of SNCC."@en ;
  dcterms:modified "2026-02-12T08:59:21.628620Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7511-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "SNCC went on to play a leading role in the civil rights movement."@en ;
  dcterms:modified "2026-02-12T08:59:21.628625Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7487-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As the British Empire had reached its peak by 1914, millions of colonial soldiers fought for Britain in both World Wars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628630Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7487-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the interwar period, race became an increasingly defining feature of the experience of migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628635Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7487-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1939, many colonial soldiers fought in the Second World War with the hopes of earning their independence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7494-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poverty was a problem across London after the end of the Second World War."@en ;
  dcterms:modified "2026-02-12T08:59:21.628725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7494-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Finding places to work and to live was challenging for Caribbean migrants, with few landlords willing to rent to them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7494-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As a result of a lack of available housing, overcrowding became a huge problem for Caribbean migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7494-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Housing was controlled by slum landlords who did nothing to improve living conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628742Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7494-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Housing associations helped to improve housing in Notting Hill."@en ;
  dcterms:modified "2026-02-12T08:59:21.628747Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7493-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As a result of the Second World War, Britain was in dire need of workers in order to rebuild the nation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628754Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7493-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People from across the British Empire had fought for Britain in WW2, but many returned to their home colonies in 1945."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628759Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7493-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The ‘Windrush generation’ is the name given to early migrants to Britain from the Caribbean after 1948."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628764Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7493-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Higher wages in Britain led to Caribbean migration; migrants faced discrimination, poor working and living conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628769Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7493-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1960s became known as the ‘Swinging Sixties’ as conditions improved and people had more time for leisure activities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628774Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7448-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Resentment against Norman rule increased as Anglo-Saxons lost land, money, power and influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628966Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7448-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Eadric the Wild led a revolt against Norman rule in 1067-68."@en ;
  dcterms:modified "2026-02-12T08:59:21.628973Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7448-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The most serious challenge to William's rule occurred in the North in 1069."@en ;
  dcterms:modified "2026-02-12T08:59:21.628978Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7448-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hereward's rebellion in East Anglia in 1070-71 was the last major English rebellion faced by William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628983Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7448-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Revolt of the Earls in 1075 involved Norman earls who wanted to overthrow William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628988Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7569-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Cuban Missile Crisis began on 14th October 1962 when the USA discovered Soviet missile bases in Cuba."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628993Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7569-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "ExComm helped President Kennedy to make decisions during the crisis."@en ;
  dcterms:modified "2026-02-12T08:59:21.628998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7569-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA set up a blockade or 'quarantine zone' around Cuba."@en ;
  dcterms:modified "2026-02-12T08:59:21.629003Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7569-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The risk of war was considered high by both the USA and USSR during the crisis."@en ;
  dcterms:modified "2026-02-12T08:59:21.629008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7569-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The crisis was resolved as both the USA and USSR agreed to make compromises."@en ;
  dcterms:modified "2026-02-12T08:59:21.629013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27025-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Caribbean migrants to the area brought distinct island cultures with them leading to many community meeting places."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27025-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migrant-run shops, markets, cafes, restaurants, nightclubs, shebeens and entertainment venues became common in the area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629023Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27025-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Clubs promoting ska and reggae music became increasingly popular and attracted visitors from outside the area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629027Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27025-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """All Saints Road developed as a centre for migrant culture, as did the Portobello Road Market."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629035Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27025-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mutual self-help organisations such as 'pardner' schemes allowed Caribbean migrants to access credit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629045Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20701-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Under Gorbachev, the USSR gave its satellite states in Eastern Europe the freedom to choose how they were governed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20701-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between 1989 and 1991, the USSR lost control of its Eastern European satellite states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629055Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20701-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In East Germany, there were widespread popular protests demanding democracy and the destruction of the Berlin Wall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629060Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20701-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """On the 9th November 1989, the East German government were forced to open the border with West Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629065Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-20701-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """On 9th November 1989, people from East Berlin and West Berlin crossed the border and began to destroy the Berlin Wall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7319-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """At first, William wanted to include Anglo-Saxons in the government of his new kingdom, including Edwin and Morcar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629103Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7319-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When William reduced their wealth, power and status, Edwin and Morcar rebelled against William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629107Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7319-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Edgar Aethling and the Danish king joined the rebellions, which was dangerous for Norman control of the North."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629113Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7319-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William used different tactics to put down rebellions, one of which was the brutal ‘Harrying of the North’ in 1069-70."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629117Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7319-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A rebellion in East Anglia 1070-71 saw William repeat his successful tactics to defeat the last Anglo-Saxon rebellion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629122Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7498-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """What local records, including newspapers and diaries, can tell us about Notting Hill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7498-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """What national records, including opinion polls and census reports, can tell about Notting Hill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629132Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7498-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sources have different strengths and weaknesses."@en ;
  dcterms:modified "2026-02-12T08:59:21.629137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7595-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """President Roosevelt promised that his New Deal would deliver 3 R’s: relief, recovery and reform."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629257Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7595-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The New Deal involved increased government intervention in the economy."@en ;
  dcterms:modified "2026-02-12T08:59:21.629264Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7595-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many Americans were lifted out of poverty by the New Deal."@en ;
  dcterms:modified "2026-02-12T08:59:21.629269Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7595-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The New Deal did not end unequal treatment of women nor African Americans in the USA."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7246-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1066, the English King, Edward the Confessor, died without an heir, triggering a succession crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629278Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7246-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William of Normandy believed he was the rightful heir and that Edward had promised him the throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629283Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7246-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William invaded England in 1066 and defeated Harold Godwinson at the Battle of Hastings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629288Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7246-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Almost all Anglo-Saxons lost land which was transferred to the Normans in the creation of the feudal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629293Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7246-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans built a number of new buildings such as castles and monasteries and reformed the English Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7307-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Anglo-Saxon England was a wealthy country."@en ;
  dcterms:modified "2026-02-12T08:59:21.629305Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7307-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Towns became centres of trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.629311Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7307-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Scattered rural settlements developed into closer village economies."@en ;
  dcterms:modified "2026-02-12T08:59:21.629315Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7307-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Church was an important part of daily life and focused on local Anglo-Saxon saints."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629320Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7307-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Local priests were part of the community and often got married."@en ;
  dcterms:modified "2026-02-12T08:59:21.629325Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28872-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Weimar Germany's 'Golden Age' saw a cultural flourishing and a culture war between modernism and traditionalism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631335Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28872-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bauhaus movement revolutionised architecture but critics saw it as an attack on German identity with links to communism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631340Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28872-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Artists like Otto Dix and George Grosz challenged idealised traditions and depicted social decay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631345Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28872-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Berlin’s cabarets and daring nightlife defied authority and social norms, but fuelled a reputation of moral  decline."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28872-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Weimar cinema pioneered expressionist film, but was later condemned by the Nazis as "degenerate" art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631354Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28864-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1914 Germany was a constitutional monarchy led by Kaiser Wilhelm II and dominated by military generals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632389Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28864-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A British naval blockade had led to food shortages and the German economy faced crippling debt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632394Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28864-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By autumn 1918, it was clear that Germany would lose the war and was under enormous strain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632399Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28864-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In November sailors mutinied at Kiel, leading to rebellions across Germany and the abdication of Kaiser Wilhelm II."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632403Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28864-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A new republic was declared and an armistice was signed with the Allies, officially ending WW1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632408Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28866-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Weimar Republic faced early opposition for a variety of reasons."@en ;
  dcterms:modified "2026-02-12T08:59:21.633071Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28866-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The government was blamed for signing the Armistice, accused of 'stabbing the army in the back'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633076Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28866-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Germans felt the Treaty of Versailles was harsh and hated the government for agreeing to it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633080Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28866-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The treaty forced Germany to pay hefty reparations and give up territory."@en ;
  dcterms:modified "2026-02-12T08:59:21.633085Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28866-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany's armed forces were significantly reduced and the Rhineland was demilitarised."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633090Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28877-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Röhm’s radical SA posed a threat to the army, business elite, and Nazi Party unity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637164Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28877-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler then removed internal Nazi opposition in the SA along with other opponents in the Night of the Long Knives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637171Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28877-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hitler used the SA purge to gain the military’s trust and secure their loyalty."@en ;
  dcterms:modified "2026-02-12T08:59:21.637176Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28877-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hindenburg’s death let Hitler merge presidency and chancellorship, becoming Germany’s supreme ruler (Führer)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637181Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28877-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A new oath made German soldiers personally loyal to Hitler, not the constitution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637188Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28863-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Wilhelm II replaced Bismarck’s cautious diplomacy with expansionist Weltpolitik for a global empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637428Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28863-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany sought to build a navy to rival Britain’s Royal Navy and secure overseas colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637433Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28863-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Admiral Tirpitz used the Navy League to rally public support and pressure the Reichstag to fund expansion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28863-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Weltpolitik and the Navy Laws expanded Germany’s fleet, boosted national pride and won the Kaiser parliamentary support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637442Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28863-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Weltpolitik and naval expansion increased debt, fuelled tensions with Britain and deepened political divisions at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637446Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28896-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis had high levels of support and conformity; it is difficult to gauge the scale of opposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637545Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28896-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Resistance came from scattered groups: workers, youth, clergy, and individuals acting in secret."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28896-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Both the Protestant and Catholic Churches resisted the Nazis, but in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28896-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Swing Youth and Edelweiss Pirates resisted Nazi control through music, fashion, and secret actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637563Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28896-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During WW2, army plots and the actions of the White Rose group were punished very harshly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637567Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28873-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Wall Street Crash of 1929 triggered a global depression, devastating Germany’s economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638037Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28873-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """American loans funding German businesses were withdrawn and German industry collapsed leading to mass unemployment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638044Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28873-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Weimar government failed to manage the crisis, with Hindenburg using Article 48, fuelling distrust in democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638049Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28873-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Desperation led many unemployed workers to support the Communists, who promised them control over the economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28873-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fear of communism drove many toward Hitler, and violent clashes between Nazis and Communists escalated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28884-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi policies on work and life aimed to forge a loyal ‘people’s community’ by controlling and rewarding workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638339Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28884-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis replaced unions with the Labour Front to control workers once loyal to the KPD or SPD."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638343Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28884-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Three worker organisations controlled labour and offered benefits, though some gains were limited or uneven."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638353Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28884-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Living standards varied, some groups gained, while real wages dropped and hours worked increased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28884-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi economic policies affected big businesses, small businesses and farmers in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28865-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The new Weimar Republic was a representative democracy with several strengths and weaknesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638893Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28865-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The new constitution allowed all adults over 20 to vote and used proportional representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638898Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28865-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Divided power between branches of government caused delays, leading to the creation of Article 48 for emergencies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638903Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28865-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Proportional representation caused fragmented coalitions, making it hard to govern and faced opposition from  all sides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638908Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28865-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Article 48 gave the President powers to act without parliament's approval in an emergency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638912Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28888-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Ghettos isolated Jewish communities in horrific conditions across Nazi-occupied Eastern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639003Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28888-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Task Forces (Einsatzgruppen) carried out mass shootings as Nazi control expanded across Eastern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28888-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Death camps industrialised mass murder using gas chambers and crematoria."@en ;
  dcterms:modified "2026-02-12T08:59:21.639012Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28888-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Wannsee Conference formalised genocide as state policy - known as the 'Final Solution'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28888-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Though awareness varied, many Germans knew of persecution and responded with silence, fear, or complicity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639022Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28875-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Reichstag was in deadlock, forcing leaders to rule by emergency decree under Article 48 of the constitution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639067Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28875-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Conservative elites removed Brüning and signalled a willingness to work with the Nazis to restore order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28875-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By July 1932, the Nazis were the largest party, but Hindenburg refused to make Hitler Chancellor, fearing extremism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639076Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28875-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hindenburg turned to conservative allies Papen and Schleicher, but both failed as Nazis refused to cooperate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639083Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28875-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hindenburg and Papen made Hitler Chancellor, thinking they could control him through a conservative-dominant cabinet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639088Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28892-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany was a deeply religious country and the Nazis saw this as a source of opposition, requiring state control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639093Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28892-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1933, Hitler signed a Concordat with the Pope - but soon broke his promise not to interfere with the Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639098Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28892-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Catholic schools and youth groups were dismantled as part of Nazi religious control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639102Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28892-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A new state Church, the Reich Church, was set up to promote Nazi ideas and unify the Protestant Churches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639107Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28892-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some Church leaders resisted Nazification and, despite arrests and pressure, the Nazis never fully controlled religion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28886-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi racial beliefs were shaped by earlier scientific ideas, but they distorted them for ideological goals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639151Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28886-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi racial ideology divided people into a hierarchy, with Aryans at the top and others labelled as sub-humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639160Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28886-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis used eugenics to justify sterilisation and the euthanasia of people with disabilities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639195Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28886-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi policies targeted Slavs, Roma, Sinti, Afro-Germans and homosexuals as threats to racial purity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28886-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Concentration camps were used to isolate and imprison particular groups of people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639205Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28874-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazi Party gained support as unemployment soared, exploiting economic despair and Weimar democratic failures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28874-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler’s charisma and modern campaign tactics made him appear as Germany’s only hope for stability and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28874-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi propaganda, led by Goebbels, used rallies, posters, and media to target workers, farmers, and the middle class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639319Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28874-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SA used violence and intimidation to silence opponents, with police and courts often favouring the Nazis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639324Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28874-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fear of communism and cultural decline drove many Germans to see Hitler as a necessary protector of Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28894-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Weimar Republic faced violent threats from both sides of the political spectrum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28894-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In January 1919, the Spartacist Uprising rebelled in Berlin but was crushed by the Freikorps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28894-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the Freikorps were ordered to disband, they launched a failed attempt to take over Berlin: the Kapp Putsch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639343Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28894-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The army refused to attack and it was only defeated by a workers' strike in Berlin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639350Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28894-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Other rebellions took place during the 1923, most notably an attempted putsch in Munich by a group called the Nazis"""@en ;
  dcterms:modified "2026-02-12T08:59:21.639355Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28893-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler’s rearmament and economic self-sufficiency prepared Germany for a war economy before 1939."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639385Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28893-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Early victories brought rewards, but defeats in Russia and U.S. entry in 1941 changed the war's course."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639390Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28893-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Speer’s Total War policy prioritised weapons over civilians, relying heavily on forced labour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639395Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28893-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rationing, shortages, and bombings led to hunger, homelessness, and a collapse in German morale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639399Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28893-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1945, Germany’s economy was ruined, cities destroyed, and millions of civilians displaced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639404Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28883-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi unemployment policies supported Hitler’s goal of building a militarised, self-sufficient empire through conquest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28883-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis reduced unemployment through RAD, public works and military rearmament from 1933 to 1939."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639716Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28883-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The autobahns were feats of modern engineering, used by Nazi propaganda as powerful symbols of progress."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639720Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28883-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rearmament reshaped the economy, employing millions and preparing Germany for future war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28883-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis created 'invisible unemployment' by manipulating employment laws and statistics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28879-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi propaganda aimed to build belief, not just obedience, by saturating daily life with its message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28879-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Joseph Goebbels created a simple, repeated narrative to shape public perception and loyalty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639741Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28879-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Spectacles like the Nuremberg Rallies and films like "Triumph of the Will" mesmerised and unified audiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639746Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28879-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Reich controlled all culture - music, art, media - through censorship and state approval to silence opposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639750Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28879-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Propaganda shaped public behaviour; dissent was rare as people feared punishment and social isolation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639755Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28887-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nazi persecution of Jews escalated gradually."@en ;
  dcterms:modified "2026-02-12T08:59:21.639934Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28887-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1933 boycott marked the first state-backed antisemitic action by the Nazi regime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639939Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28887-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nuremberg Laws of 1935 legally stripped Jews of citizenship and rights in Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639944Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28887-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Kristallnacht in 1938 was a state-orchestrated pogrom falsely presented as public outrage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639948Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28887-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1939, Nazi persecution intensified amid fears of war and the drive to remove Jews from German life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639953Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28876-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler gained power legally but lacked full control and planned new elections to secure a majority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28876-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Reichstag Fire was exploited by Nazis to justify emergency powers and crush political opposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639962Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28876-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """With communist members banned and others intimidated by the SA, the Reichstag passed the Enabling Act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639967Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28876-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Act gave Hitler legal authority to rule by decree, marking his transformation of Germany into a dictatorship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639974Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28876-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gleichschaltung made Germany a one-party state, bringing all areas of life under Nazi control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639979Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28861-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Germany was unified in 1871 through war, nationalism and Prussian leadership."@en ;
  dcterms:modified "2026-02-12T08:59:21.639984Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28861-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Militarism shaped German society, values and leadership at every level."@en ;
  dcterms:modified "2026-02-12T08:59:21.639988Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28861-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany’s government was dominated by the Kaiser, his Chancellor and elite advisors - not by parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639996Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28861-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Kaiser Wilhelm II aimed to expand Germany’s power and ruled in an authoritarian, top-down style."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28861-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Rising democratic participation clashed with elite rule, causing growing tension by 1914."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28882-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler viewed children as vital to the Nazi future and used indoctrination to shape them into loyal, obedient citizens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640036Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28882-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Boys and girls were encouraged to join uniformed Nazi youth organisations that offered various activities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640041Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28882-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nazi youth organisations aimed to win total loyalty and prepare boys for war and girls for motherhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640045Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28882-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Education was reshaped to indoctrinate youth with Nazi ideas, and teachers were vetted to ensure loyalty to the regime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28882-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The curriculum was altered to justify racism and future territorial expansion."@en ;
  dcterms:modified "2026-02-12T08:59:21.640055Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28878-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler’s regime built a police state using the SS, Gestapo, SD and concentration camps to control the German population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28878-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SS oversaw other Nazi security bodies and controlled policing, intelligence, racial policy and concentration camps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28878-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Gestapo, Germany’s secret police, monitored people and used fear and denunciations to arrest citizens without trial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640498Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28878-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SD gathered vast amounts of intelligence, helping to create a society gripped by paranoia and silence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640503Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28862-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Kaiser Wilhelm II promoted militarism and empire, and drove industrialisation to make Germany strong on the world stage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640714Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28862-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany’s rapid industrialisation created economic power but deepened hardship and unrest among workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640719Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28862-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Poor working conditions led to trade union growth and increasing support for socialism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640724Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28862-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SPD rose to become the largest Reichstag party, but the Kaiser retained real power and resisted any major reforms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640728Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28862-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1914, Germany was divided between tradition and change, with socialism stirring fears of national instability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640733Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28881-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis reversed Weimar freedoms for women, promoting traditional roles to support a racially “pure” family structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28881-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Kinder, Küche, Kirche' summed up Nazi expectations of women: motherhood, homemaking, and moral guidance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640814Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28881-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler wanted a high birth rate and so women were encouraged to marry and have children in various ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640819Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28881-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Measures were taken to discourage female employment but these policies were not entirely successful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28881-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis shaped women’s appearance and roles; some embraced these ideals, others resisted and were punished."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640828Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28868-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When Germany failed to pay reparations in November 1922, France and Belgium sent troops into the Ruhr Valley."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641486Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28868-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """German workers were ordered to stop work to prevent the soldiers from taking industrial goods as payment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641491Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28868-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Already suffering from inflation, the German economy was harmed by this loss of productivity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641496Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28868-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Weimar Government printed money to support striking workers, flooding the economy and triggering hyperinflation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28868-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hyperinflation wiped out middle-class savings, forcing many to barter for survival while others profited from the chaos."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28871-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic stability under Stresemann improved wages, housing and welfare, but left some Germans struggling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641534Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28871-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Housing projects and unemployment insurance improved living standards but strained the Republic's finances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28871-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Women gained greater freedoms and equality, but many still embraced traditional roles at home and in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28871-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 'New Woman' symbolised independence and embraced leisure, but some saw this freedom as excessive and irresponsible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28871-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Conservatives viewed women’s new workforce roles and social freedoms as threats to family and national recovery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28891-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler's ideology, outlined in 'Mein Kampf', reshaped the Nazi Party and later impacted Germany as a whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643624Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28891-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1926 Bamberg Conference helped Hitler eliminate socialist elements and solidify his absolute control over the party."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28891-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis had limited electoral success as political and economic stability weakened extremism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643634Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28891-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nazis gained rural support by appealing to struggling farmers, and shifting focus from urban workers to landowners."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28891-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1928, the Nazi Party had a national structure, disciplined ideology and tailored propaganda, but lacked mass support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643643Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28870-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "At the end of the First World War, Germany was an international pariah."@en ;
  dcterms:modified "2026-02-12T08:59:21.643791Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28870-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the Locarno Pact, Stresemann secured peace by agreeing to respect its western borders with France and Belgium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643796Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28870-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany joined the League of Nations, restoring its role in global diplomacy and improving relations with prior enemies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643801Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28870-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Germany's agreement to the Kellogg-Briand Pact in 1928 signalled their willingness to avoid conflict in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643805Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28870-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stresemann’s diplomacy rebuilt Germany’s reputation abroad, boosting stability and weakening extremism at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643810Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7529-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nixon promised to end US involvement in Vietnam by strengthening the South Vietnamese Army (ARVN)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644213Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7529-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon believed this would calm anti-war tension in the US."@en ;
  dcterms:modified "2026-02-12T08:59:21.644218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7529-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """American troops began to withdraw while the US continued to heavily fund the South Vietnamese Army (ARVN)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644222Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7529-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Vietnamisation had mixed results for both the US and the South Vietnamese Army (ARVN)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644227Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28890-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The crises leading up to 1923 created a fertile environment for extremism, making rebellion against Weimar more likely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644257Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28890-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Inspired by Mussolini’s ‘March on Rome’, Hitler planned to seize Munich, overthrow Weimar and establish Nazi rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644262Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28890-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The putsch collapsed when Bavarian leaders withdrew support, and Hitler’s 2000-strong march was crushed by armed police."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28890-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the short-term, the Nazi Party was banned, Hitler was jailed and many leading Nazis fled."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28890-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler gained fame from his trial, wrote ‘My Struggle’ and shifted to a strategy of gaining power legally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28867-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Weimar Republic faced violent threats from both sides of the political spectrum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644309Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28867-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1919 Spartacist Uprising, led by communists, sought to establish a workers’ state but was crushed by the Freikorps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28867-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When the Freikorps were ordered to disband they launched a failed attempt to restore the Kaiser: the Kapp Putsch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644318Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28867-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The army refused to attack and it was only defeated by a workers' strike."@en ;
  dcterms:modified "2026-02-12T08:59:21.644323Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28867-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Assassinations, paramilitary clashes and coups, like Hitler's Munich Putsch, revealed deep divisions in Weimar Germany."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644328Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28869-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Gustav Stresemann became chancellor during the hyperinflation crisis before becoming foreign minister."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644358Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28869-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stresemann ended hyperinflation by taking a number of decisive actions including the introduction of a new currency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644363Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28869-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stresemann agreed two new reparations plans with the Allies: the Dawes and Young Plans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644368Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28869-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Industrial production and infrastructure were revitalised, reducing unemployment and boosting Germany’s status."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644372Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28869-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic recovery depended on American loans and extended reparations continued to attract criticism of the Republic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644377Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28889-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler's belief in Pan-Germanism and antisemitism grew in Vienna; it was later shaped by post-war Germany's instability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644501Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28889-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1919, Hitler joined the DAP, which later became the NSDAP promoting nationalism, Volkism and opposition to communism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28889-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 25 Point Programme outlined Nazi core beliefs of reversing Versailles, uniting ethnic Germans and antisemitism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28889-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler used his talent for public speaking and propaganda to attract supporters and spread his extremist ideology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644519Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28889-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SA was a Nazi paramilitary force that protected meetings, attacked opponents and spread Nazi influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644526Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7575-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Détente began between the US and USSR in the early 1970s."@en ;
  dcterms:modified "2026-02-12T08:59:21.644839Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7575-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New leaders in both superpowers helped encourage Détente."@en ;
  dcterms:modified "2026-02-12T08:59:21.644844Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7575-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA and USSR hoped to address domestic social and economic issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.644848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7575-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon believed Détente could help the US end its war in Vietnam."@en ;
  dcterms:modified "2026-02-12T08:59:21.644853Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7575-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Brezhnev was concerned to ensure the US and Chinese did not co-operate against the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644858Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7284-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A war to remove French control over Indochina began in 1946."@en ;
  dcterms:modified "2026-02-12T08:59:21.645226Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7284-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Viet Minh led resistance to the French."@en ;
  dcterms:modified "2026-02-12T08:59:21.645230Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7284-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Viet Minh support ideas of nationalism and communism."@en ;
  dcterms:modified "2026-02-12T08:59:21.645235Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7284-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Viet Minh defeated the French, despite significant US support for the French."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645240Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7284-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vietnam was divided into two states at the 1954 Geneva Conference."@en ;
  dcterms:modified "2026-02-12T08:59:21.645244Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7537-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US strategies in Vietnam were ineffective and often contradictory."@en ;
  dcterms:modified "2026-02-12T08:59:21.645790Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7537-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """US soldiers did not understand Vietnamese culture, which led to poor decision making."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7537-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Communist propaganda painted the US as invaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.645799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7537-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poor tactics meant that Vietnamese civilians frequently became casualties."@en ;
  dcterms:modified "2026-02-12T08:59:21.645804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7537-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Poor discipline and drug use meant that the effectiveness of the US Army diminished after 1970."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645808Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28898-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Medieval surgery was performed by barber-surgeons."@en ;
  dcterms:modified "2026-02-12T08:59:21.674723Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28898-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bloodletting was the most common form of medieval surgery."@en ;
  dcterms:modified "2026-02-12T08:59:21.674728Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28898-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Barber-surgeons also performed procedures such as pulling teeth, amputations and trepanning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674732Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28898-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pain, infection and blood loss were major problems of surgery."@en ;
  dcterms:modified "2026-02-12T08:59:21.674737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28898-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite some helpful developments, the major problems of surgery were not overcome in the medieval period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674742Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7261-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians draw upon a range of sources and interpretations to study the expansion of the British Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675763Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7261-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sources may tell us different things about the expansion of empire depending on their provenance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675767Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7261-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some historians argue that the expansion of empire did have some positive impacts, particularly in India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675772Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7261-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many historians criticise the British for the cruel and violent treatment of indigenous peoples in the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675776Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7415-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 8th century, there were at least 200 monasteries in England, almost all Benedictine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675809Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7415-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Some monasteries were large and wealthy establishments and many were important centres of learning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675814Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7415-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 9th century saw an actual decline in monasticism and also a change in how monasteries were run."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7415-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Viking raids and invasions targeted monasteries and were most responsible for the decline in monasticism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675823Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7415-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A reform movement in the 10th century brought changes to monasticism in southern England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675827Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7386-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey is named in the Bayeux Tapestry."@en ;
  dcterms:modified "2026-02-12T08:59:21.675832Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7386-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The first Norman motte-and-bailey castle was built at Pevensey."@en ;
  dcterms:modified "2026-02-12T08:59:21.675836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7386-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans were well-prepared for their invasion of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.675841Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7386-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After landing at Pevensey, the Normans devastated the towns of Sussex."@en ;
  dcterms:modified "2026-02-12T08:59:21.675845Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7386-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Robert, Count of Mortain, was given control of Pevensey Castle and the surrounding land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675850Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7524-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "America had been opposed to communism long before the Cold War started."@en ;
  dcterms:modified "2026-02-12T08:59:21.704338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7524-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Communism spread rapidly after World War Two."@en ;
  dcterms:modified "2026-02-12T08:59:21.704342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7524-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "America committed itself to containing the spread of communism."@en ;
  dcterms:modified "2026-02-12T08:59:21.704349Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7524-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Eisenhower believed communism might spread in Southeast Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.704356Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7524-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eisenhower committed large amounts of money to supporting Diem to stop the spread of communism in Vietnam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704361Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7370-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cuthbert was a Northumbrian monk-bishop who earned a reputation for spiritual guidance and miraculous healing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704636Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7370-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The cult of Saint Cuthbert spread after many people reported miraculous healings when they prayed at his relics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7370-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The holy island of Lindisfarne was located near to Durham."@en ;
  dcterms:modified "2026-02-12T08:59:21.704649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7370-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Northumbrian monasteries also produced the Venerable Bede whose scholarship and piety earned him veneration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7370-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham became an important place of pilgrimage as it housed the shrine of Saint Cuthbert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704661Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7374-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans replaced unsuitable Anglo-Saxon prelates with reformers from Normandy or elsewhere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705593Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7374-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The canon of the cathedral chapter was replaced with monks who adopted a stricter Benedictine monasticism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705598Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7374-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral was transformed into a centre of monastic life."@en ;
  dcterms:modified "2026-02-12T08:59:21.705631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7374-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral functioned as a pilgrimage site for St Cuthbert and the Venerable Bede."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7374-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The architectural design accommodated the flow of pilgrims."@en ;
  dcterms:modified "2026-02-12T08:59:21.705641Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7462-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Continuity is the term used in history to mean things staying the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.705786Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7462-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William wanted to be accepted as the legitimate heir of Edward the Confessor."@en ;
  dcterms:modified "2026-02-12T08:59:21.705791Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7462-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After 1070, William abandoned plans for power sharing and put Normans in control of the government of Norman England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7462-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Changes to landholding were rapid and significant but the feudal system was probably a  much more gradual change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705800Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7462-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman government relied heavily on Anglo-Saxon government administration and legal systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7377-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.705833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7377-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705837Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7377-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705842Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7377-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.705847Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7421-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The priory was established as a centre for religious worship."@en ;
  dcterms:modified "2026-02-12T08:59:21.705851Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7421-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The priory needed to accommodate a community of Cluniac monks."@en ;
  dcterms:modified "2026-02-12T08:59:21.705856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7421-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The priory's religious function was to benefit everyone, but the de Warennes in particular."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705860Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7421-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The priory also had the political function of increasing Norman control over Norfolk."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7421-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The priory also had important economic and administrative functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.705870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7590-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Ku Klux Klan revived after 1915 and was committed to protecting 'pure Americanism'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705874Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7590-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Membership of the KKK peaked at 5 000 000 and extended nationwide."@en ;
  dcterms:modified "2026-02-12T08:59:21.705879Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7590-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Jim Crow Laws enforced segregation of African American people in the South."@en ;
  dcterms:modified "2026-02-12T08:59:21.705883Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7590-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "African Americans also faced persecution and discrimination in the North."@en ;
  dcterms:modified "2026-02-12T08:59:21.705888Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7590-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recent immigrants, Catholics and Jews were victims of racial tensions."@en ;
  dcterms:modified "2026-02-12T08:59:21.705892Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7375-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William II was more willing to go against the Church and removed William St Calais and Bishop of Durham."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707265Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7375-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William II and Flambard reveal how the relationship between the Church and monarchy could be used for power and money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707272Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7375-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Henry I imprisoned Ranulf Flambard in the Tower of London for embezzlement."@en ;
  dcterms:modified "2026-02-12T08:59:21.707277Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7375-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Flambard escaped and joined Robert Curthose's invasion of England."@en ;
  dcterms:modified "2026-02-12T08:59:21.707282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7375-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Flambard was restored as bishop and is buried in Durham Cathedral's chapter house alongside William Saint-Calais."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707286Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7367-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.707755Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7367-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707760Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7367-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707764Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7367-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.707769Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7258-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By 1876, Queen Victoria was declared Empress of India, ruling with the help of a viceroy and anglicised Indian elite."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707796Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7258-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British improved infrastructure in India for economic purposes and implemented healthcare initiatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707801Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7258-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Britain was criticised for exploiting India’s resources and either failing to prevent, or contributing to, famine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7258-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians' interpretations of the impact of British rule on India differ from one to another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707812Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7447-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles were a military innovation that was almost unknown in Anglo-Saxon England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707965Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7447-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles had a military function, acting as bases for troops who would control and oppress key areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708000Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7447-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles also had a psychological impact of terrifying and dominating the local population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708006Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7447-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Castles were centres of Norman control, acting as bases for Norman nobles to administer an area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708011Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7447-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most Norman castles were variations of the motte-and-bailey design."@en ;
  dcterms:modified "2026-02-12T08:59:21.708017Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7445-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William needed to overcome a hostile Anglo-Saxon population if he wished to control England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708155Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7445-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Anglo-Saxon nobles in London rallied behind Edgar the Aethling as the next king of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708160Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7445-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William’s army was vulnerable, in a foreign land with limited supplies."@en ;
  dcterms:modified "2026-02-12T08:59:21.708164Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7445-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William used harrying and violence to induce submission from the Anglo-Saxon nobility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708169Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7445-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Earls Edwin and Morcar, Edgar the Aethling and Stigand, the Archbishop of Canterbury, submitted to William."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708173Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7248-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Hundred Years' War began in 1337 under King Edward III due to disputes of succession to the French throne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708178Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7248-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Edward III went to war with France to undermine the Auld Alliance and to maintain profitable land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708182Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7248-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Henry V won the Battle of Agincourt and almost ended the Hundred Years' War in 1415."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708191Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7248-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """England was ultimately defeated partly due to Joan of Arc in 1453 and after the infant Henry VI had become king in 1422."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708196Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7248-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """England lost almost all of its land in France and began to develop a separate identity from continental Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28904-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Water in medieval towns was often contaminated by waste and sewage."@en ;
  dcterms:modified "2026-02-12T08:59:21.708205Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28904-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Streets in towns were often dirty because of poor waste disposal."@en ;
  dcterms:modified "2026-02-12T08:59:21.708210Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28904-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Actions to improve public health in towns had limited impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.708217Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28904-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The location of monasteries helped protect them from disease."@en ;
  dcterms:modified "2026-02-12T08:59:21.708221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28904-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Monasteries invested in good sanitation facilities."@en ;
  dcterms:modified "2026-02-12T08:59:21.708226Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7572-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Alexander Dubček's Prague Spring reforms were seen as a threat by other Warsaw Pact leaders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708230Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7572-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR worried that Czechoslovakia might leave the Warsaw Pact."@en ;
  dcterms:modified "2026-02-12T08:59:21.708235Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7572-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR led an invasion of Czechoslovakia in August 1968."@en ;
  dcterms:modified "2026-02-12T08:59:21.708239Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7572-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Prague Spring reforms were overturned and Dubček was replaced with Gustáv Husák."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708244Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7572-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The West opposed the invasion but was unwilling to fight over Czechoslovakia."@en ;
  dcterms:modified "2026-02-12T08:59:21.708248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7282-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Korea was communist and South Korea was capitalist."@en ;
  dcterms:modified "2026-02-12T08:59:21.708255Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7282-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "North Korea invaded South Korea in June 1950."@en ;
  dcterms:modified "2026-02-12T08:59:21.708260Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7282-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "American-led UN forces intervened to defend South Korea."@en ;
  dcterms:modified "2026-02-12T08:59:21.708264Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7282-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "UN forces crossed the 38th parallel and entered into North Korea."@en ;
  dcterms:modified "2026-02-12T08:59:21.708269Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7282-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The UN campaign in North Korea triggered China's entry into the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.708273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7407-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The site chosen for the White Tower was a strategically important one."@en ;
  dcterms:modified "2026-02-12T08:59:21.708499Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7407-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The site of the White Tower made use of the old Roman walls."@en ;
  dcterms:modified "2026-02-12T08:59:21.708506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7407-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A key role for the White Tower was to control London's population."@en ;
  dcterms:modified "2026-02-12T08:59:21.708511Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7407-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Two other castles were also built in London: Baynard's Castle and Montfichet's Tower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708516Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7407-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The White Tower was in close connection with both religious and administrative centres in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7583-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA experienced an economic boom in the 1920s."@en ;
  dcterms:modified "2026-02-12T08:59:21.709422Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7583-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mass production, government policies and the effects of WWI helped make businesses more profitable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7583-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Demand for consumer goods like cars and radios increased."@en ;
  dcterms:modified "2026-02-12T08:59:21.709431Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7583-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Advertising and hire purchase schemes helped create a consumer society."@en ;
  dcterms:modified "2026-02-12T08:59:21.709436Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7583-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The boom was accelerated by a cycle of prosperity which benefitted both businesses and consumers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709440Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7420-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castle Acre Priory was built in the Romanesque style, with Gothic elements."@en ;
  dcterms:modified "2026-02-12T08:59:21.713105Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7420-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castle Acre Priory was designed to meet the needs of a community of monks."@en ;
  dcterms:modified "2026-02-12T08:59:21.713112Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7257-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the 1850s, most of the Indian subcontinent was under the control of the East India Company."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713382Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7257-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The unpopular 'doctrine of lapse' was introduced which allowed Britain to control more Indian territory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713387Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7257-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Indian Rebellion took place in 1857 and represented a serious challenge to British rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713391Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7257-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """British soldiers defeated the Indian rebellion and India became a Crown Colony governed by a viceroy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713396Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28915-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Overcrowding, poor waste disposal and poor access to food and water were major issues in industrial cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715051Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28915-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Successive governments took little action due to laissez-faire attitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.715055Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28915-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edwin Chadwick revealed the impact of poor public health on industrial workers."@en ;
  dcterms:modified "2026-02-12T08:59:21.715060Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28915-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Public Health Acts were introduced in 1848 and 1875."@en ;
  dcterms:modified "2026-02-12T08:59:21.715064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28915-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The extension of the vote encouraged governments to make public health reforms."@en ;
  dcterms:modified "2026-02-12T08:59:21.715069Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7273-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The end of the British Empire and independence caused migration to Britain, often for economic reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715121Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7273-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many people migrated to Britain because they felt a close connection to the country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715126Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7273-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Despite many migrants being invited to Britain they experienced racism and discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715130Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7273-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """British opposition to immigration arguably contributed to the Brexit Referendum in 2016."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715136Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7394-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William's decision to invade England followed the news that Harold had been crowned king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715141Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7394-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William gained Pope Alexander II's support for his invasion, and was given a papal banner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715146Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7394-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pope's support and the promise of land and wealth from England convinced Norman barons to join the invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715150Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7394-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Constructing the Norman fleet and gathering and supplying the Norman army was an impressive achievement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715155Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7394-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William's preparations were upset by bad weather and a near-disastrous first attempt at crossing the Channel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715159Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7617-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many women and African Americans felt like second class citizens."@en ;
  dcterms:modified "2026-02-12T08:59:21.717467Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7617-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Women and African Americans benefitted from changes in the law in the 1950s, 60s and 70s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717471Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7617-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some new laws were poorly enforced."@en ;
  dcterms:modified "2026-02-12T08:59:21.717476Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7617-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some groups continued to oppose equality for women and African Americans."@en ;
  dcterms:modified "2026-02-12T08:59:21.717480Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29054-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "John Hunter practised surgery in hospitals and in the army."@en ;
  dcterms:modified "2026-02-12T08:59:21.718126Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29054-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hunter was a supporter of the scientific method."@en ;
  dcterms:modified "2026-02-12T08:59:21.718131Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29054-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hunter made new discoveries through observation and experimentation, for example, about gunshot wounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718136Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29054-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hunter's incorrect ideas about venereal diseases were accepted for many years."@en ;
  dcterms:modified "2026-02-12T08:59:21.718140Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28926-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lung cancer became more common in Britain after 1900."@en ;
  dcterms:modified "2026-02-12T08:59:21.718597Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28926-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Smoking is the main cause of lung cancer."@en ;
  dcterms:modified "2026-02-12T08:59:21.718601Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28926-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people are diagnosed with lung cancer too late for treatments to help them."@en ;
  dcterms:modified "2026-02-12T08:59:21.718606Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28926-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Governmnet attempts at prevention have mainly focused on stopping smoking."@en ;
  dcterms:modified "2026-02-12T08:59:21.718610Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28926-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Smoking rates and lung cancer death rates have both declined in the 21st century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718615Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28895-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hitler’s regime built a police state using the SS, Gestapo, SD and concentration camps to control the German population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718996Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28895-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SS oversaw other Nazi security bodies and controlled policing, intelligence, racial policy and concentration camps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28895-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Gestapo, Germany’s secret police, monitored people, used fear and denunciations to arrest citizens without trial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28895-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The SD gathered vast amounts of intelligence, helping to create a society gripped by paranoia and silence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28895-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The legal system was restructured to serve Nazi goals, with courts delivering harsh, ideologically driven verdicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719014Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7250-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Exploration of the 'New World' took place under Elizabeth I and James I due to England's sea-faring capability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719088Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7250-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many people migrated to the Americas for economic reasons and to take advantage of fertile farmland and fishing grounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719120Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7250-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nonconformists migrated to the Americas to escape religious persecution after the Reformation and English Civil War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719125Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7250-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Settler colonialists forcibly took land from the Native Americans; many of whom died from smallpox and violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719132Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7250-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The settlers in America forged a new American identity after the colonisation of North America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719137Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7417-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norfolk became part of the Danelaw in 865 CE."@en ;
  dcterms:modified "2026-02-12T08:59:21.719504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7417-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A rebellion against Roman occupation of Norfolk was brutally put down in 60 CE."@en ;
  dcterms:modified "2026-02-12T08:59:21.719508Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7417-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castle Acre was located on two key communication routes."@en ;
  dcterms:modified "2026-02-12T08:59:21.719513Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7417-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norwich was a centre of Norman government and religious control."@en ;
  dcterms:modified "2026-02-12T08:59:21.719517Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7417-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norfolk played a significant role in the Revolt of the Earls in 1075."@en ;
  dcterms:modified "2026-02-12T08:59:21.719522Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28930-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "X-rays were used to help guide surgical work."@en ;
  dcterms:modified "2026-02-12T08:59:21.719526Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28930-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Thomas Splint helped prevent complications from fractured leg bones."@en ;
  dcterms:modified "2026-02-12T08:59:21.719531Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28930-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Debridement and the Carrel-Dakin method were used to sterilise wounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.719535Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28930-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Blood transfusions were used to manage blood loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.719541Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28930-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Advances during WWI enabled blood to be stored and used for transfusions."@en ;
  dcterms:modified "2026-02-12T08:59:21.719546Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7612-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "African Americans suffered from many forms of discrimination."@en ;
  dcterms:modified "2026-02-12T08:59:21.720520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7612-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Segregation was defended by the Supreme Court in 1896."@en ;
  dcterms:modified "2026-02-12T08:59:21.720525Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7612-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Groups like the NAACP and church organisations campaigned in defence of black Americans' civil rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720529Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7612-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Supreme Court declared school segregation unconstitutional in 1954."@en ;
  dcterms:modified "2026-02-12T08:59:21.720533Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7612-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was widespread opposition to school desegregation in many parts of the South."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720542Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7592-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "By 1932, one in four workers was unemployed in the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.720631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7592-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Living standards fell as many Americans lost their homes and were forced to rely on charity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720635Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7592-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Thousands of houseless Americans moved into camps known as Hoovervilles."@en ;
  dcterms:modified "2026-02-12T08:59:21.720640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7592-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One in 20 farmers had been evicted from their land by 1932."@en ;
  dcterms:modified "2026-02-12T08:59:21.720645Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7592-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Farmers suffered from natural disasters and millions living in the Dust Bowl were forced to move."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28918-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lifestyle factors affect people’s health and can cause illness and disease."@en ;
  dcterms:modified "2026-02-12T08:59:21.720678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28918-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Understanding of the impact of lifestyle factors became more scientific in the 20th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720683Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28918-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Genes and DNA determine people's characteristics."@en ;
  dcterms:modified "2026-02-12T08:59:21.720687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28918-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The structure of DNA was discovered in the 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.720691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28918-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some genes responsible for specific diseases have been identified by scientists."@en ;
  dcterms:modified "2026-02-12T08:59:21.720696Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7281-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After 1949, China declared its support for other communist countries."@en ;
  dcterms:modified "2026-02-12T08:59:21.720734Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7281-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Sino-Soviet Friendship Treaty created an alliance between China and the USSR."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720739Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7281-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Communist victory in China was referred to as the 'loss' of China in the US."@en ;
  dcterms:modified "2026-02-12T08:59:21.720746Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7281-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US anti-communism intensified after the 'loss' of China."@en ;
  dcterms:modified "2026-02-12T08:59:21.720750Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7281-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "US officials accepted the Domino Theory."@en ;
  dcterms:modified "2026-02-12T08:59:21.720755Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7456-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many aspects of daily life remained the same for most people."@en ;
  dcterms:modified "2026-02-12T08:59:21.720777Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7456-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Changes included new buildings, laws and people."@en ;
  dcterms:modified "2026-02-12T08:59:21.720783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7456-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Change did not proceed evenly across the entire country."@en ;
  dcterms:modified "2026-02-12T08:59:21.720788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7456-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People in the south had a different experience to those in the north."@en ;
  dcterms:modified "2026-02-12T08:59:21.720793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7456-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The wealthy had a different experience to the poor."@en ;
  dcterms:modified "2026-02-12T08:59:21.720800Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7265-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The expansion of the British Empire created huge financial benefits for Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.720804Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7265-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Britain believed it had a duty to 'civilise' people within the Empire, which is known as a civilising mission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720809Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7265-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British government used propaganda to increase support for empire so they could continue expanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7265-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many products were covered in images of the Empire and in 1887 a range of empire souvenirs were produced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720818Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7265-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Books and newspapers gave positive accounts of overseas wars in the Empire."@en ;
  dcterms:modified "2026-02-12T08:59:21.720822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28919-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Diagnosis in 1900 mainly depended upon the judgement of individual doctors."@en ;
  dcterms:modified "2026-02-12T08:59:21.720829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28919-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Laboratory testing became commonplace during the 20th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.720833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28919-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New technologies have provided more detailed information to support diagnoses."@en ;
  dcterms:modified "2026-02-12T08:59:21.720838Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28919-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many technologies used for modern diagnosis remove the need for invasive procedures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720842Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7267-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people migrated to Britain from the colonies, such as India and Ireland."@en ;
  dcterms:modified "2026-02-12T08:59:21.721969Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7267-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """WW1 and WW2 caused increased migration due to soldiers from the colonies fighting for Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721973Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7267-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many Jewish people migrated to Britain fleeing persecution in Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.721978Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7267-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many people from Britain migrated to other parts of the empire for largely economic reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721982Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7267-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Empire caused migration between different colonies, such as India and parts of Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721988Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28900-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Christianity and the Church had a lot of influence in medieval Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.723252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28900-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Christians believed that disease was sent by God."@en ;
  dcterms:modified "2026-02-12T08:59:21.723257Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28900-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many methods of treatment and prevention were religiously inspired, such as praying."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723262Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28900-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "University training for physicians was controlled by the Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.723266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28900-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Church ran hundreds of hospitals."@en ;
  dcterms:modified "2026-02-12T08:59:21.723270Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7490-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """As increasing numbers of black and Asian people settled in Britain, racism and discrimination also increased."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723574Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7490-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Race Relations Acts were introduced to address issues of ongoing racism in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723578Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7490-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The media was used to exacerbate tensions and to increase support for anti-immigration campaigns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723583Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7490-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Race Relations Acts did not change public attitudes overnight, but did show changing attitudes of the government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723587Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28902-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Islam encouraged developments in medical knowledge and the search for new cures."@en ;
  dcterms:modified "2026-02-12T08:59:21.723780Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28902-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Muslim scholars helped preserve many ancient medical works."@en ;
  dcterms:modified "2026-02-12T08:59:21.723784Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28902-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Al-Razi, Ibn Sina and Ibn al-Nafis all contributed to new medical knowledge of diseases, treatments and human anatomy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28902-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Islamic medical works were translated, spread through medieval Europe and gained influence there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28902-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Muslim challenges to Galen’s works were not accepted in medieval Europe."@en ;
  dcterms:modified "2026-02-12T08:59:21.723798Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7606-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most Americans enjoyed rising incomes after WW2."@en ;
  dcterms:modified "2026-02-12T08:59:21.725623Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7606-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poverty remained widespread and other economic inequalities remained."@en ;
  dcterms:modified "2026-02-12T08:59:21.725629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7606-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Widespread TV and radio ownership allowed many Americans to access popular culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725634Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7606-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Teenage identity and interests were considered dangerous by some older Americans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725639Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7606-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Red Scare threatened many Americans civil liberties."@en ;
  dcterms:modified "2026-02-12T08:59:21.725643Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7614-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Major civil rights protests took place in Birmingham, Washington and Selma."@en ;
  dcterms:modified "2026-02-12T08:59:21.725647Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7614-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Martin Luther King Jr hoped to pressure lawmakers into taking action on civil rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725652Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7614-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The federal government passed the Civil Rights Act in 1964 and the Voting Rights Act in 1965."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725656Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7614-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "King's Chicago Freedom Movement achieved little success."@en ;
  dcterms:modified "2026-02-12T08:59:21.725661Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7366-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Eadric the Wild's revolt relied on support from Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.727627Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7366-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William faced a serious rebellion in 1075 that involved the earl of Hereford."@en ;
  dcterms:modified "2026-02-12T08:59:21.727631Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7366-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Norman control in Wales was reduced during the reign of William Rufus."@en ;
  dcterms:modified "2026-02-12T08:59:21.727636Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7366-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1136, Norman forces in west Wales were defeated at the Battle of Crug Mawr."@en ;
  dcterms:modified "2026-02-12T08:59:21.727640Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7383-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was an administrative centre."@en ;
  dcterms:modified "2026-02-12T08:59:21.727645Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7383-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was one of the most important locations in Sussex."@en ;
  dcterms:modified "2026-02-12T08:59:21.727649Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7383-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey could serve as a garrison."@en ;
  dcterms:modified "2026-02-12T08:59:21.727655Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7383-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey may have intimidated the local Anglo-Saxons."@en ;
  dcterms:modified "2026-02-12T08:59:21.727660Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7383-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey was in a strategic location between London and Normandy."@en ;
  dcterms:modified "2026-02-12T08:59:21.727665Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7406-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "London played an important supporting role in the Battle of Hastings."@en ;
  dcterms:modified "2026-02-12T08:59:21.727669Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7406-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After the Battle of Hastings, the surviving Anglo-Saxon elite chose a new king in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727673Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7406-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William led his army on a strategic march around the southeast of England to intimidate London's population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727678Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7406-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William chose to be crowned in London."@en ;
  dcterms:modified "2026-02-12T08:59:21.727682Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7406-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After his coronation, William ordered the construction of a castle to guard London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7463-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Church was organised into a hierarchy which included archbishops, bishops and priests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727992Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7463-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Church was a powerful institution with influence in the government of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727999Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7463-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Anglo-Saxon Church observed local religious beliefs and practices, language and saints."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728003Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7463-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans criticised the Anglo-Saxon Church for lax discipline and corruption."@en ;
  dcterms:modified "2026-02-12T08:59:21.728008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7463-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are reasons to be skeptical of Norman criticisms as they were used to justify the invasion of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728012Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7384-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William II Rufus fought with his brother, Robert Curthose, for the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.728538Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7384-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some Norman nobles supported William's brother Robert."@en ;
  dcterms:modified "2026-02-12T08:59:21.728542Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7384-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Odo of Bayeux held Pevensey against William."@en ;
  dcterms:modified "2026-02-12T08:59:21.728547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7384-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William Rufus laid siege to Pevensey."@en ;
  dcterms:modified "2026-02-12T08:59:21.728551Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7384-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "William Rufus' siege was successful."@en ;
  dcterms:modified "2026-02-12T08:59:21.728555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7260-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cecil Rhodes made a fortune from gold and diamond mines in South Africa and gained political power there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728560Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7260-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Between 1860-1890 Britain invaded the Boer states in southern Africa due to the discovery of gold and diamonds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728564Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7260-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A peace settlement was reached in 1902 after Britain's use of a scorched earth policy and concentration camps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728568Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7260-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1910 the Cape Colony, Natal and Boer states merged to form South Africa, extending British control over Africa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728573Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7260-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The British government introduced social reforms in Britain due to the poor health of the troops that fought."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728577Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28899-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Treatment aims at restoring good health once a person is ill and prevention focuses on avoiding illness altogether."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728582Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28899-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Religious approaches like prayer, pilgrimages and acts of penance were all used to treat or prevent disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728586Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28899-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Purging and bloodletting were believed to restore the balance between the Four Humours by removing excess liquids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728592Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28899-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Attempts were made to avoid bad smells to prevent miasma."@en ;
  dcterms:modified "2026-02-12T08:59:21.728597Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28899-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some effective herbal remedies were used to treat certain health conditions."@en ;
  dcterms:modified "2026-02-12T08:59:21.728601Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28908-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Paré developed and encouraged new methods to manage the problems of surgery."@en ;
  dcterms:modified "2026-02-12T08:59:21.728606Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28908-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vesalius carried out dissections to identify many mistakes in Galen's work."@en ;
  dcterms:modified "2026-02-12T08:59:21.728610Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28908-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vesalius encouraged others to learn through observation and dissection."@en ;
  dcterms:modified "2026-02-12T08:59:21.728615Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28908-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Vesalius' challenge to Galen's ideas faced considerable opposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.728622Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7586-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1920s have been referred to as the 'Roaring Twenties'."@en ;
  dcterms:modified "2026-02-12T08:59:21.728697Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7586-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Entertainments like mass sports, cinema and jazz became more popular duirng the 1920s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728702Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7586-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Prohibition was introduced in 1920."@en ;
  dcterms:modified "2026-02-12T08:59:21.728711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7586-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Prohibition law was regularly broken by ordinary Americans and corrupt officials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728715Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7586-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was a rise in organised crime during the Prohibition era."@en ;
  dcterms:modified "2026-02-12T08:59:21.728720Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7272-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After WW2, the European Economic Community (EEC) was founded to forge peaceful connections in Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728724Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7272-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Britain joined the EEC (now EU) in 1973 to counter its waning influence after the end of Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7272-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 1980s, a European single market was created which allowed free movement of people within the EEC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728733Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7272-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Eastern European countries joined the EU after the USSR's collapse, many citizens of which moved to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7272-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Opposition to migration from the EU contributed to the 2016 Brexit Referendum."@en ;
  dcterms:modified "2026-02-12T08:59:21.728742Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28920-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People living in poverty usually suffer from worse health."@en ;
  dcterms:modified "2026-02-12T08:59:21.728878Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28920-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Booth and Rowntree Reports and the Boer War made it clear that public health was poor in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728882Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28920-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Liberals introduced several reforms including free school meals and National Insurance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728887Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28920-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Liberal reforms were intended to resolve some of the problems created by poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728891Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28920-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Liberal reforms encouraged future governments to accept more responsibility for public health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728895Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28929-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Triage systems were used in Casualty Clearing Stations (CCCs)."@en ;
  dcterms:modified "2026-02-12T08:59:21.728900Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28929-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """CCSs prioritised wounded soldiers with life-threatening injuries, but who could be saved, over other patients."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728904Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28929-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Base Hospitals were able to care for large numbers of patients."@en ;
  dcterms:modified "2026-02-12T08:59:21.728909Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28929-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An underground hospital was constructed at Arras."@en ;
  dcterms:modified "2026-02-12T08:59:21.728913Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28929-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The underground hospital at Arras was abandoned during a battle."@en ;
  dcterms:modified "2026-02-12T08:59:21.728917Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7387-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.729031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7387-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729035Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7387-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729039Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7387-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.729046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7419-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Monastic life in Norman England was based on the Rule of St Benedict."@en ;
  dcterms:modified "2026-02-12T08:59:21.729053Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7419-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Monasteries were important to Lanfranc's reforms of the English Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.729057Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7419-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "As well as his Church reforms, Lanfranc also circulated new monastic rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.729064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7419-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans introduced Cluniac monasteries to England."@en ;
  dcterms:modified "2026-02-12T08:59:21.729069Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7419-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "English abbots were replaced with Normans."@en ;
  dcterms:modified "2026-02-12T08:59:21.729073Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7255-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Economic interests were a strong motivation for the creation of English colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729077Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7255-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Enslaved people were forcibly transported to the Americas from West Africa in order to increase profits in the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729082Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7255-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Religious persecution was an important reason for migration during the 16th and 17th centuries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729086Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7255-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Migration during this time had a profound impact on national identities in America, Ireland and Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729091Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28907-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many hospitals closed as a result of the Dissolution of the Monasteries."@en ;
  dcterms:modified "2026-02-12T08:59:21.729237Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28907-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """More general and specialist hospitals were set-up in the 17th and 18th centuries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28907-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "After the 16th century, more medical professionals were employed in hospitals."@en ;
  dcterms:modified "2026-02-12T08:59:21.729245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28907-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hospital treatments were often based on the Theory of the Four Humours."@en ;
  dcterms:modified "2026-02-12T08:59:21.729250Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28907-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hospital conditions became more unsanitary during the 18th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.729254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7269-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After WW2, there was a significant labour shortage, so the government invited people from the Commonwealth to work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731136Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7269-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The 1948 Nationality Act created 'Citizens of the United Kingdom and Colonies' who could move to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731140Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7269-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many workers from the Caribbean arrived in 1948 on the Empire Windrush."@en ;
  dcterms:modified "2026-02-12T08:59:21.731144Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7269-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many of the Windrush generation took up roles in transport or as nurses, making important cultural contributions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731148Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7269-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Caribbean immigrants from Britain experienced significant racism and discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731152Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29610-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Royal Army Medical Corps and Voluntary Aid Detachments helped provide medical care to soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731675Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29610-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Chain of Evacuation was used to organise treatment for wounded men."@en ;
  dcterms:modified "2026-02-12T08:59:21.731679Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29610-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Surgeries took place at Casualty Clearing Stations and Base Hospitals."@en ;
  dcterms:modified "2026-02-12T08:59:21.731683Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29610-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A range of methods, including the use of stretcher bearers, were used to transport wounded men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731687Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29610-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Several factors, including the local terrain, could make evacuating wounded soldiers challenging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731691Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28914-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Chloroform was discovered as an an effective anaesthetic in the 1840s."@en ;
  dcterms:modified "2026-02-12T08:59:21.731772Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28914-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Infections became more common in surgeries as improved anaesthetics were used."@en ;
  dcterms:modified "2026-02-12T08:59:21.731776Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28914-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Joseph Lister encouraged the use of carbolic acid as an antiseptic to sterilise wounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731780Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28914-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lister faced considerable medical opposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.731784Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28914-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Surgeons began to practice aseptic methods by the end of the 19th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.731788Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7256-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Prior to the arrival of Britain, the Indian subcontinent was ruled by the Muslim Mughal Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732994Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7256-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Under the rule of Aurangzeb, the power of the Mughals decreased due to war and economic difficulties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732998Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7256-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1600 the East India Company was founded and was given a monopoly over trade in East Asia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733001Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7256-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 1757 Battle of Plassey, Robert Clive's East India Company gained control over India."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7256-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 18th and 19th centuries the East India Company expanded its control along with government involvement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29497-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bloodletting and patent medicines were popular but ineffective treatments."@en ;
  dcterms:modified "2026-02-12T08:59:21.733013Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29497-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "It was not understood why the smallpox vaccine worked."@en ;
  dcterms:modified "2026-02-12T08:59:21.733018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29497-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Louis Pasteur developed a replicable method for developing vaccines."@en ;
  dcterms:modified "2026-02-12T08:59:21.733024Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29497-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Germ Theory did not lead to new treatments before 1900."@en ;
  dcterms:modified "2026-02-12T08:59:21.733029Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-29497-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many successful public health reforms were not based on knowledge of Germ Theory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733033Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7422-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.734795Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7422-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7422-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734803Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7422-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.734807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7397-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.735004Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7397-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735008Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7397-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735011Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7397-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.735015Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28928-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The trench environment led many soldiers to suffer from both physical and mental health conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735403Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28928-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bullets and shrapnel were responsible for most wounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.735407Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28928-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Bullet and shrapnel wounds led to a high risk of infection for soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.735411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28928-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Gas attacks were used on the Western Front."@en ;
  dcterms:modified "2026-02-12T08:59:21.735415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28928-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Gas attacks accounted for a small percentage of overall British deaths."@en ;
  dcterms:modified "2026-02-12T08:59:21.735419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7531-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nixon Doctrine made the US position clear: they would support South Vietnam against communism but remove troops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7531-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Nixon engaged in official and secret negotiations to end the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.735779Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7531-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Nixon expanded the war by attacking the Ho Chi Minh Trail in neighbouring Cambodia and Laos."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735783Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7531-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The US public and Congress were furious when they discovered that Nixon had expanded the war into other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7531-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After a large invasion from the North Vietnamese, Nixon ordered heavy bombing of North Vietnam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7613-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Direct action was one of the methods used to challenge segregation."@en ;
  dcterms:modified "2026-02-12T08:59:21.735838Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7613-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Montgomery Bus Boycott challenged segregation on buses."@en ;
  dcterms:modified "2026-02-12T08:59:21.735842Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7613-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Sit-ins and the Freedom Rides were organised to challenge segregation in the early 1960s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735846Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7613-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Direct action aimed to attract media attention."@en ;
  dcterms:modified "2026-02-12T08:59:21.735850Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7613-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Publicity helped increase participation in protests and create more pressure for change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735854Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7601-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "American incomes rose during the post-war period."@en ;
  dcterms:modified "2026-02-12T08:59:21.735857Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7601-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Americans began to buy more consumer goods after the end of WW2."@en ;
  dcterms:modified "2026-02-12T08:59:21.735861Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7601-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Government policies were introduced in the 1940s to support economic growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.735865Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7601-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many people were unable to live the American Dream."@en ;
  dcterms:modified "2026-02-12T08:59:21.735869Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7601-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were significant inequalities in 1940s and 1950s America."@en ;
  dcterms:modified "2026-02-12T08:59:21.735872Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7439-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The king had a duty to protect the kingdom and had powers over the army, laws, landownership, and money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736032Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7439-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In return, the people had a duty to obey the laws and serve the king through taxes and military service."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736038Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7439-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Edward the Confessor’s power was balanced by powerful earls who controlled thegns and armies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7439-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Edward had gained legitimacy through his piety and law-making."@en ;
  dcterms:modified "2026-02-12T08:59:21.736046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7439-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Witan advised the king and had a role in selecting his successor."@en ;
  dcterms:modified "2026-02-12T08:59:21.736050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28897-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Religion was a widespread explanation for disease in the medieval period."@en ;
  dcterms:modified "2026-02-12T08:59:21.736054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28897-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Non-religious explanations were also used, including astrology, miasma and the Theory of the Four Humours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736059Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28897-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Medieval ideas lacked scientific proof and were often inaccurate."@en ;
  dcterms:modified "2026-02-12T08:59:21.736064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28897-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Theory of the Four Humours was the most popular non-religious explanation for ill health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736067Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28897-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Theory of the Four Humours claimed illness occurred when four liquids, or humours, in the body were out of balance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736100Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7264-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many British men migrated to India in the hopes that they would make their fortune there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736825Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7264-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Indian people migrated to Britain, particularly soldiers who were known as lascars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736829Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7264-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Britain encouraged many Indian people to move to Africa to work on infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736833Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7264-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Indentured labourers from India also moved to Kenya to build railways."@en ;
  dcterms:modified "2026-02-12T08:59:21.736836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7264-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New African infrastructure encouraged many wealthy white Britons to migrate."@en ;
  dcterms:modified "2026-02-12T08:59:21.736840Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28905-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During the Renaissance, some people began to encourage new approaches to learning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736844Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28905-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """New technologies and groups emerged which supported the development of new medical ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736848Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28905-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Thomas Sydenham was a physician who supported the scientific method."@en ;
  dcterms:modified "2026-02-12T08:59:21.736852Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28905-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many physicians did not accept new medical ideas and approaches."@en ;
  dcterms:modified "2026-02-12T08:59:21.736856Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28905-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Medieval explanations for the causes of disease remained widespread."@en ;
  dcterms:modified "2026-02-12T08:59:21.736859Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7565-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "East Germany suffered from a 'brain drain'."@en ;
  dcterms:modified "2026-02-12T08:59:21.736866Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7565-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Khrushchev produced the Berlin Ultimatum in 1958."@en ;
  dcterms:modified "2026-02-12T08:59:21.736870Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7565-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USSR constructed the Berlin Wall in 1961."@en ;
  dcterms:modified "2026-02-12T08:59:21.736873Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7565-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA did not attempt to block the construction of the Berlin Wall."@en ;
  dcterms:modified "2026-02-12T08:59:21.736877Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7565-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA used the Berlin Wall as a symbol in its propaganda."@en ;
  dcterms:modified "2026-02-12T08:59:21.736881Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28913-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Most hospitals were unsanitary and staffed by untrained nurses."@en ;
  dcterms:modified "2026-02-12T08:59:21.736885Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28913-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hospitalism referred to the high risk of infection for patients."@en ;
  dcterms:modified "2026-02-12T08:59:21.736889Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28913-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Florence Nightingale's reputation helped her promote change."@en ;
  dcterms:modified "2026-02-12T08:59:21.736892Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28913-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Nightingale School for Nurses improved nurses' standards and reputation."@en ;
  dcterms:modified "2026-02-12T08:59:21.736896Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28913-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many hospitals were built according to pavilion plans from the 1860s onwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.736902Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7412-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There are three key topics making up the historical context of Norman England."@en ;
  dcterms:modified "2026-02-12T08:59:21.737117Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7412-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Norman conquest and control' covers causes of the conquest, military aspects and establishing and maintaining control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737121Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7412-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Life under the Normans' covers feudalism and government and economic and social changes and their consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737125Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7412-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'The Norman Church and monasticism' covers the Church and monasticism."@en ;
  dcterms:modified "2026-02-12T08:59:21.737129Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7405-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Roman Londinium was fortified by the London Wall, a two-mile long structure built to defend the city from invaders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737929Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7405-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """London declined after the Romans left Britain and by the 5th century had been abandoned as a settlement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737933Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7405-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 886, King Alfred the Great re-established a settlement inside the London Wall as a fortified burh."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737937Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7405-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the 11th century, London was again an important city due to being a centre of trade, religion and government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737940Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7405-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Edward the Confessor had close ties to Westminster, building Westminster Abbey there by 1065."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737944Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28921-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New knowledge and methods improved the effectiveness of blood transfusions."@en ;
  dcterms:modified "2026-02-12T08:59:21.737950Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28921-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Blood loss was no longer a major problem of surgery after 1945."@en ;
  dcterms:modified "2026-02-12T08:59:21.737954Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28921-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Thomas Splint and new methods of plastic surgery helped manage injuries during the World Wars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28921-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Technologies used before and after operations have reduced the impact of surgeries on patients."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737962Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28921-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Technologies have made modern surgery less invasive."@en ;
  dcterms:modified "2026-02-12T08:59:21.737966Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28901-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Physicians observed their patients to diagnose their illnesses."@en ;
  dcterms:modified "2026-02-12T08:59:21.737970Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28901-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Physicians were university-educated but were taught to accept many incorrect theories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737974Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28901-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Apothecaries made and sold medicines and barber-surgeons performed surgical procedures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737978Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28901-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Medieval hospitals cared for the sick but did not try to cure their patients' illnesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737982Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28901-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Most medical care was accessed within local communities from family members and wise people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737985Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28906-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many medieval treatments remained common in the Renaissance period."@en ;
  dcterms:modified "2026-02-12T08:59:21.738139Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28906-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "New American plants were used in treatments."@en ;
  dcterms:modified "2026-02-12T08:59:21.738143Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28906-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was a rise in quack medicine."@en ;
  dcterms:modified "2026-02-12T08:59:21.738148Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28906-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Religion and ancient ideas, like miasma, continued to influence many methods of prevention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738153Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28906-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """People with infectious diseases were sometimes isolated to prevent the disease spreading further."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738157Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7602-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Televisions became widely available and popular."@en ;
  dcterms:modified "2026-02-12T08:59:21.738681Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7602-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A new 'teenage' identity developed in the 1940s and 1950s."@en ;
  dcterms:modified "2026-02-12T08:59:21.738685Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7602-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Rock and Roll became a popular form of music."@en ;
  dcterms:modified "2026-02-12T08:59:21.738689Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7602-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Advertisers and the entertainment industry targeted teenage audiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.738693Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7589-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There was an increase in anti-immigrant feeling in the 1920s."@en ;
  dcterms:modified "2026-02-12T08:59:21.738697Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7589-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some Americans were frightened of a communist revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.738701Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7589-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Strikes in 1919 led to fear of a revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.738705Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7589-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Palmer Raids targeted suspected communists and anarchists."@en ;
  dcterms:modified "2026-02-12T08:59:21.738711Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7589-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Trade unionism declined significantly after the Red Scare."@en ;
  dcterms:modified "2026-02-12T08:59:21.738715Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7266-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """During World War One thousands of Indian soldiers fought on the Western Front, then moved to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738720Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7266-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many African and Caribbean soldiers joined the navy, leading to the 1919 riots in Liverpool and Cardiff."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738725Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7266-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many colonial soldiers also served in World War Two, though they often returned to the colonies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738728Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7266-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """WW2 created a labour shortage that meant that the government encouraged immigration from the Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738732Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28912-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Miasma continued to be widely accepted as a cause of disease."@en ;
  dcterms:modified "2026-02-12T08:59:21.738736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28912-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Spontaneous generation suggested that decay and disease caused microbes to appear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738740Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28912-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Louis Pasteur's Germ Theory disproved spontaneous generation."@en ;
  dcterms:modified "2026-02-12T08:59:21.738744Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28912-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Robert Koch proved certain bacteria cause specific diseases."@en ;
  dcterms:modified "2026-02-12T08:59:21.738748Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28912-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Germ Theory was initially rejected by many British doctors."@en ;
  dcterms:modified "2026-02-12T08:59:21.738752Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28922-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Magic bullets provided cures for some infections."@en ;
  dcterms:modified "2026-02-12T08:59:21.738757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28922-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Alexander Fleming discovered that penicillin can destroy some bacteria."@en ;
  dcterms:modified "2026-02-12T08:59:21.738762Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28922-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Florey and Chain received government support to help develop penicillin into an antibiotic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738766Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28922-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There were fewer deaths from infectious diseases in the 20th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.738771Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28922-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Antibiotic resistance has increased the modern threat posed by infections."@en ;
  dcterms:modified "2026-02-12T08:59:21.738775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7461-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Normans made relatively few changes to the English legal system."@en ;
  dcterms:modified "2026-02-12T08:59:21.740023Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7461-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hundred courts and shire courts remained, but Normans took over as sheriffs and the role increased in power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740027Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7461-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman England had more central control over the legal system than had been the case in Anglo-Saxon England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740031Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7461-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans introduced the murdrum fine and criminalised the use of resources from royal forests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740035Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7461-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Normans and Anglo-Saxons were treated differently by the justice system."@en ;
  dcterms:modified "2026-02-12T08:59:21.740038Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7604-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "President's Kennedy and Johnson both promised regeneration for the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.740042Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7604-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "JFK led the New Frontier programme and LBJ led the Great Society programme."@en ;
  dcterms:modified "2026-02-12T08:59:21.740046Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7604-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poverty declined in the 1960s but inequality remained."@en ;
  dcterms:modified "2026-02-12T08:59:21.740050Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7604-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Access to education and healthcare improved."@en ;
  dcterms:modified "2026-02-12T08:59:21.740054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7604-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Critics argued that the New Frontier and Great Society could have achieved more."@en ;
  dcterms:modified "2026-02-12T08:59:21.740058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7385-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Pevensey Castle played an important role in the Norman Conquest."@en ;
  dcterms:modified "2026-02-12T08:59:21.740657Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7385-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Pevensey Castle continued to play an important role during the Norman occupation of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740661Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7385-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The economy of Sussex was boosted by the arrival of the Normans."@en ;
  dcterms:modified "2026-02-12T08:59:21.740689Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7385-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The town of Pevensey grew to be a significant urban centre."@en ;
  dcterms:modified "2026-02-12T08:59:21.740693Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7615-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Malcolm X helped develop many ideas which inspired the Black Power Movement."@en ;
  dcterms:modified "2026-02-12T08:59:21.740697Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7615-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Black Power Movement was radical."@en ;
  dcterms:modified "2026-02-12T08:59:21.740704Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7615-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Black Panther Party was one of the most well known Black Power groups."@en ;
  dcterms:modified "2026-02-12T08:59:21.740708Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7615-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Membership of the Black Panther Party was relatively small."@en ;
  dcterms:modified "2026-02-12T08:59:21.740712Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7615-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Black Panthers provided many services to support African American communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740718Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7268-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After WW2, the British Empire began to collapse in the face of nationalist and independence movements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740722Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7268-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """India was granted independence in 1947 following the violent partition of India and Pakistan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740726Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7268-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1956, President Nasser of Egypt took control of the Suez Canal which resulted in a failed invasion from Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7268-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "In 1957, Kwame Nkrumah led the successful campaign for Ghanaian independence."@en ;
  dcterms:modified "2026-02-12T08:59:21.740734Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7268-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """After a brutal and violent suppression of the Mau Mau Rebellion, Kenya was granted independence in 1963."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7276-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin agreed to free elections in Eastern Europe at Yalta but had no intention of allowing this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740741Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7276-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Stalin believed Soviet control of Eastern Europe was essential to protect the USSR from any future invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740745Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7276-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """From 1945 to 1948, the USSR used similar methods to turn most Eastern European countries into Soviet satellite states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740749Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7276-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The USSR's establishment of satellite states in Eastern Europe significantly increased Cold War tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740753Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7276-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Churchill's 'Iron Curtain' speech in 1946 was a response to Soviet expansion into Eastern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7280-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Nationalist Party (KMT) ruled China in 1945, but was challenged by the Chinese Communist Party (CCP)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741404Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7280-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "China experienced a civil war lasting from 1946-49."@en ;
  dcterms:modified "2026-02-12T08:59:21.741408Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7280-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The CCP emerged victorious from the Chinese Civil War."@en ;
  dcterms:modified "2026-02-12T08:59:21.741411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7280-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Both the KMT and CCP received foreign support."@en ;
  dcterms:modified "2026-02-12T08:59:21.741417Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7280-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "At times, both the KMT and CCP ignored US and Soviet attempts to control them."@en ;
  dcterms:modified "2026-02-12T08:59:21.741422Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7373-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral was built in a meander of the River Wear, on high ground, which provided natural protection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741730Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7373-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral housed St Cuthbert's shrine."@en ;
  dcterms:modified "2026-02-12T08:59:21.741735Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7373-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral was built in the powerful Romanesque style."@en ;
  dcterms:modified "2026-02-12T08:59:21.741739Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7373-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral contains architectural innovations such as rib vaulting."@en ;
  dcterms:modified "2026-02-12T08:59:21.741743Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7373-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Durham Cathedral was designed to separate the monks from the lay people."@en ;
  dcterms:modified "2026-02-12T08:59:21.741747Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7263-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "By 1850, there were about 40 000 Jewish people living in Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.742261Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7263-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Jewish people lived in poor and unsanitary conditions, with the 1905 Aliens Act designed to limit migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742265Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7263-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Many Jewish people built communities in Britain; many Jewish migrants made furniture and clothes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742269Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7263-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In the 1930s and 1940s many Jewish refugees fled persecution from Nazi Germany and moved to Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7605-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Significant inequalities between men and women encouraged the development of the Feminist Movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742411Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7605-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Women were granted equality under the law during the 1960s and 70s."@en ;
  dcterms:modified "2026-02-12T08:59:21.742415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7605-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Women gained greater sexual freedoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.742419Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7605-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The gender pay gap remained a problem."@en ;
  dcterms:modified "2026-02-12T08:59:21.742423Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7605-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Women as well as men opposed some of the changes the Feminist Movement supported."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742427Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7376-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral was built in a Romanesque style symbolising the dominance and permanence of Norman rule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742431Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7376-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral incorporated some Anglo-Saxon traditions of church design and was used as a shrine to St Cuthbert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7376-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The personnel of Durham Cathedral demonstrated Norman political authority in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742441Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7376-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral had a fortified setting because it was located in the border region."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742445Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7376-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Durham Cathedral reflected Norman religious values including a stricter adherence to Benedictine monasticism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742449Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7585-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Agriculture and the coal industry suffered from overproduction, tariffs and new competition in the 1920s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742453Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7585-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Native Americans lived in poor conditions on reservations and faced discrimination under US law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742457Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7585-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poverty, discrimination and racism made African American lives difficult."@en ;
  dcterms:modified "2026-02-12T08:59:21.742461Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7585-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """By the 1920s, most immigrants travelling to America came from eastern and southern Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742465Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7585-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recent immigrants faced widespread intolerance."@en ;
  dcterms:modified "2026-02-12T08:59:21.742469Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7460-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """In 1085, William ordered a survey to detail the possessions of his new kingdom of England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744729Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7460-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The survey was compiled in 1086, and the two volumes of records became known as Domesday Book."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744733Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7460-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Historians do not fully agree on the purpose, but Domesday Book gave William a very detailed account of landholding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744737Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7460-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Domesday may also have provided William with an accurate account of the tax and soldiers his new kingdom could provide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744740Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7460-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Domesday increased William’s royal authority: the capacity to seize and distribute lands, and to charge accordingly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744744Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7364-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Normans constructed more than 300 castles in Wales before 1215, with 100 built along the Welsh Marches."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744773Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7364-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Norman castles provided security for Norman inhabitants and also symbolised Norman control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744777Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7364-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Normans used castles as a base for expansion further into Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.744781Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7364-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Castles provided the security for Norman colonisation of Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.744785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7616-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1964 Civil Rights Act outlawed racial discrimination."@en ;
  dcterms:modified "2026-02-12T08:59:21.744789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7616-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1965 Voting Rights Act gave all Americans the right to vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.744793Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7616-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The 1968 Civil Rights Act made housing discrimination illegal."@en ;
  dcterms:modified "2026-02-12T08:59:21.744799Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7616-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "African Americans continued to face discrimination and racism."@en ;
  dcterms:modified "2026-02-12T08:59:21.744803Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7567-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA opposed the Castro government in Cuba."@en ;
  dcterms:modified "2026-02-12T08:59:21.744807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7567-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Bay of Pigs Invasion attempted to overthrow Castro."@en ;
  dcterms:modified "2026-02-12T08:59:21.744811Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7567-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Bay of Pigs Invasion was a failure."@en ;
  dcterms:modified "2026-02-12T08:59:21.744815Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7567-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The USA's reputation was damaged by the invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.744819Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7567-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cuba and the Soviet Union deepened their relations after the invasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.744824Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7576-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "President Nixon visited Moscow in 1972."@en ;
  dcterms:modified "2026-02-12T08:59:21.745803Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7576-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "SALT 1 was signed in 1972."@en ;
  dcterms:modified "2026-02-12T08:59:21.745807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7576-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """SALT 1 included arms limitations and agreements between the USA and USSR to cooperate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745813Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7576-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Not all new nuclear weapons were covered by SALT 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.745817Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7576-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Cold War still continued after 1972."@en ;
  dcterms:modified "2026-02-12T08:59:21.745821Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7464-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Stigand was deposed and Lanfranc introduced as Archbishop of Canterbury in 1070."@en ;
  dcterms:modified "2026-02-12T08:59:21.745860Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7464-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lanfranc's reforms aimed to reduce corruption, and to modernise and re-organise the English Church."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745864Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7464-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lanfranc secured primacy for Canterbury over the English Church."@en ;
  dcterms:modified "2026-02-12T08:59:21.745868Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7464-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Lanfranc's reforms involved the replacement of Anglo-Saxon prelates with Normans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745872Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7464-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Lanfranc's reforms included the separation of Church cases from secular courts."@en ;
  dcterms:modified "2026-02-12T08:59:21.745877Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28909-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There was growing emphasis on dissection as a part of Renaissance physicians' medical training."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746392Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28909-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Galen wrote that blood was made in the liver and burned up in the body."@en ;
  dcterms:modified "2026-02-12T08:59:21.746396Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28909-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William Harvey's theory of blood argued that it circulated throughout the body constantly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746400Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28909-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """William Harvey's ideas challenged thousands of years of medical knowledge and practice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746406Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28909-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Many other physicians rejected or ignored William Harvey's new ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.746410Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7296-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The Hungarian Uprising (1956) was caused by anger due to declining living standards and a desire for greater freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746433Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7296-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Khrushchev attempted to end the Hungarian Uprising by installing Imre Nagy as leader and supporting his reforms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746437Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7296-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When Nagy announced that Hungary would leave the Warsaw Pact, the USSR invaded and crushed the Hungarian Uprising."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746441Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7296-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The West opposed the Soviet invasion of Hungary but did not intervene."@en ;
  dcterms:modified "2026-02-12T08:59:21.746445Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7296-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The defeat of the Hungarian Uprising strengthened the USSR and Khrushchev."@en ;
  dcterms:modified "2026-02-12T08:59:21.746451Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28927-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Major battles on the Western Front were fought at Ypres, the Somme, Arras and Cambrai."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746458Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28927-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "British forces suffered high casualties during many major battles."@en ;
  dcterms:modified "2026-02-12T08:59:21.746462Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28927-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Trench systems were developed to protect soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.746466Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28927-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bacteria in the soil in Flanders and northern France increased the risk of infection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746470Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28927-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A wet climate created issues such as flooding and muddy landscapes."@en ;
  dcterms:modified "2026-02-12T08:59:21.746473Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7594-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Business failures, unemployment, poverty and homelessness were common hardships faced during the Great Depression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748578Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7594-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Different groups experienced the bust years differently."@en ;
  dcterms:modified "2026-02-12T08:59:21.748581Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7594-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The very rich often retained more of their wealth than poorer Americans."@en ;
  dcterms:modified "2026-02-12T08:59:21.748587Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7594-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """African Americans and people of Mexican heritage generally experienced greater hardship than the average American."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748591Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7360-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Wales' mountainous regions tended to isolate communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.749375Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7360-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Wales' long coastline has always been important for communication and trade."@en ;
  dcterms:modified "2026-02-12T08:59:21.749380Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7360-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The major centres of Roman power in Wales were Caerleon in the south and Carmarthen in the west."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749383Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7360-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "By the 11th century, Wales had five major kingdoms and several minor kingdoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.749387Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7360-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Monasteries were important in 11th century Wales."@en ;
  dcterms:modified "2026-02-12T08:59:21.749391Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7593-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "President Hoover believed in the idea of ‘rugged individualism’."@en ;
  dcterms:modified "2026-02-12T08:59:21.750005Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7593-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The public often argued that Hoover's policies failed to help them during the Great Depression."""@en ;
