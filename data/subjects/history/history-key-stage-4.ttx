  dcterms:modified "2026-02-12T08:59:15.789461Z"^^xsd:dateTime .

oak:keyword-campaign
  a oakcurric:Keyword ;
  schema:name "campaign"@en ;
  schema:description "a series of military operations, usually with the aim of defeating an enemy"@en ;
  dcterms:modified "2026-02-12T08:59:15.789466Z"^^xsd:dateTime .

oak:keyword-exile
  a oakcurric:Keyword ;
  schema:name "exile"@en ;
  schema:description """being banned from living in your native country, usually for acting against those in charge"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789470Z"^^xsd:dateTime .

oak:keyword-commonwealth
  a oakcurric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oak:keyword-expulsion
  a oakcurric:Keyword ;
  schema:name "expulsion"@en ;
  schema:description "to drive out or force away"@en ;
  dcterms:modified "2026-02-12T08:59:15.789505Z"^^xsd:dateTime .

oak:keyword-colour-bar
  a oakcurric:Keyword ;
  schema:name "colour bar"@en ;
  schema:description """a system where people who are not considered white are denied access to the same services as white people"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789510Z"^^xsd:dateTime .

oak:keyword-boycott
  a oakcurric:Keyword ;
  schema:name "boycott"@en ;
  schema:description "refusing to use a service as a form of protest"@en ;
  dcterms:modified "2026-02-12T08:59:15.789514Z"^^xsd:dateTime .

oak:keyword-empire
  a oakcurric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oak:keyword-propaganda
  a oakcurric:Keyword ;
  schema:name "Propaganda"@en ;
  schema:description """Propaganda is information, especially of a biased or misleading nature, used to promote a political cause or point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789531Z"^^xsd:dateTime .

oak:keyword-censorship
  a oakcurric:Keyword ;
  schema:name "Censorship"@en ;
  schema:description """The act of preventing something from being seen or made available to the public for political reasons is known as censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789536Z"^^xsd:dateTime .

oak:keyword-autonomy
  a oakcurric:Keyword ;
  schema:name "autonomy"@en ;
  schema:description """having the freedom and independence to make your own decisions without being controlled by others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789563Z"^^xsd:dateTime .

oak:keyword-inheritance
  a oakcurric:Keyword ;
  schema:name "inheritance"@en ;
  schema:description """belongings, for example money and property, received from someone after they have died"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789654Z"^^xsd:dateTime .

oak:keyword-migration
  a oakcurric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oak:keyword-assimilate
  a oakcurric:Keyword ;
  schema:name "assimilate"@en ;
  schema:description "to become part of a group, country, society or culture"@en ;
  dcterms:modified "2026-02-12T08:59:15.789748Z"^^xsd:dateTime .

oak:keyword-government
  a oakcurric:Keyword ;
  schema:name "government"@en ;
  schema:description "a government is a group of leaders who make laws and decisions for a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.790003Z"^^xsd:dateTime .

oak:keyword-systematically
  a oakcurric:Keyword ;
  schema:name "systematically"@en ;
  schema:description """when something is done systematically it is done in a way that is done according to an agreed set of methods or organised plan"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790007Z"^^xsd:dateTime .

oak:keyword-scorched-earth
  a oakcurric:Keyword ;
  schema:name "scorched-earth"@en ;
  schema:description """a scorched-earth policy is the act of an army destroying everything in an area such as food, buildings, or equipment that could be useful to an enemy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790011Z"^^xsd:dateTime .

oak:keyword-famine
  a oakcurric:Keyword ;
  schema:name "famine"@en ;
  schema:description """a famine is a situation in which there is not enough food for a great number of people, causing illness and death, or a particular period when this happens"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790016Z"^^xsd:dateTime .

oak:keyword-refugee
  a oakcurric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oak:keyword-jim-crow-laws
  a oakcurric:Keyword ;
  schema:name "Jim Crow laws"@en ;
  schema:description """laws in the United States from the 19th and 20th centuries that enforced racial segregation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790069Z"^^xsd:dateTime .

oak:keyword-veteran
  a oakcurric:Keyword ;
  schema:name "Veteran"@en ;
  schema:description "a former member of the armed forces"@en ;
  dcterms:modified "2026-02-12T08:59:15.790073Z"^^xsd:dateTime .

oak:keyword-institutional-racism
  a oakcurric:Keyword ;
  schema:name "institutional racism"@en ;
  schema:description """discrimination or unequal treatment on the basis of race, which come from systems, structures or expectations within an institution or organisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790094Z"^^xsd:dateTime .

oak:keyword-federal
  a oakcurric:Keyword ;
  schema:name "federal"@en ;
  schema:description """a federal government is a system of government where there is one central government that controls a collection of smaller state governments"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790140Z"^^xsd:dateTime .

oak:keyword-desegregation
  a oakcurric:Keyword ;
  schema:name "desegregation"@en ;
  schema:description "desegregation is when segregation is ended"@en ;
  dcterms:modified "2026-02-12T08:59:15.790144Z"^^xsd:dateTime .

oak:keyword-unconstitutional
  a oakcurric:Keyword ;
  schema:name "unconstitutional"@en ;
  schema:description """something is unconstitutional when it breaks the terms of a country's constitution, especially when it violates the rights given to individuals by the constitution"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790152Z"^^xsd:dateTime .

oak:keyword-school-board
  a oakcurric:Keyword ;
  schema:name "school board"@en ;
  schema:description """a school board is a group of individuals responsible for making decisions about schools in the local area"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790156Z"^^xsd:dateTime .

oak:keyword-discrimination
  a oakcurric:Keyword ;
  schema:name "discrimination"@en ;
  schema:description """discrimination is the unjust treatment of a person or group of people, usually on the grounds of a physical quality or belief"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790161Z"^^xsd:dateTime .

oak:keyword-commission
  a oakcurric:Keyword ;
  schema:name "commission"@en ;
  schema:description """a commission is a group of people trusted by a government to carry out a task, usually an investigation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790165Z"^^xsd:dateTime .

oak:keyword-epidemic
  a oakcurric:Keyword ;
