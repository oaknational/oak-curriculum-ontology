  dcterms:modified "2026-02-12T08:59:15.789396Z"^^xsd:dateTime .

oak:keyword-public-health
  a oakcurric:Keyword ;
  schema:name "public health"@en ;
  schema:description """actions and systems intended to prevent disease and maintain good health within communities"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789400Z"^^xsd:dateTime .

oak:keyword-unsanitary
  a oakcurric:Keyword ;
  schema:name "unsanitary"@en ;
  schema:description "dirty or unhealthy and therefore likely to cause disease"@en ;
  dcterms:modified "2026-02-12T08:59:15.789405Z"^^xsd:dateTime .

oak:keyword-prescription
  a oakcurric:Keyword ;
