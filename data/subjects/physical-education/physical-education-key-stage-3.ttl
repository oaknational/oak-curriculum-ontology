  dcterms:modified "2026-06-07T15:30:29.298062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22670-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: satisfaction comes from getting better and making progress."@en ;
  dcterms:modified "2026-06-07T15:30:29.298066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22670-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working well with others requires sharing of tasks, being kind and willing
