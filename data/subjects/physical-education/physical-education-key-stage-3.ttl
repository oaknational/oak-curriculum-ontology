  dcterms:modified "2026-06-07T15:30:02.403735Z"^^xsd:dateTime .

oakcurric:keyword-foul
  a curric:Keyword ;
  schema:name "foul"@en ;
  schema:description "an unfair act by a player that contravenes the game's laws"@en ;
  dcterms:modified "2026-06-07T15:30:02.403742Z"^^xsd:dateTime .

oakcurric:keyword-incoming-runner
  a curric:Keyword ;
  schema:name "incoming runner"@en ;
