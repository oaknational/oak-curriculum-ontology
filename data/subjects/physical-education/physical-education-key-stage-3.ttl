  a curric:KeyLearningPoint ;
  rdfs:label "Move: drop shots from the back require very little follow through in the swing."@en ;
  dcterms:modified "2026-06-07T15:30:29.298040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22796-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: hitting shots softly requires self-discipline and composure."@en ;
  dcterms:modified "2026-06-07T15:30:29.298044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22796-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: feeding the shuttle to put just enough pressure on your teammates maximises
