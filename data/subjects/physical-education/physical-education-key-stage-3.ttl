  curric:isUnitOf
    natcurric:scheme-physical-education-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-move-application-of-tactics-strategies-and-compositional-ideas ,
    oakcurric:thread-feel-engagement-and-enjoyment .

oakcurric:unit-3034
  a curric:Unit ;
  rdfs:label "Gymnastics jigsaw: technical fluency and group performance analysis"@en ;
  curric:slug "gymnastics-jigsaw-technical-fluency-and-group-performance-analysis" ;
  rdfs:comment """This unit will explore the use of various apparatus and flight based sequences
  whilst also giving pupils the opportunity to master, teach each other and analyse group
  performances. They will also learn how to set out their space safely."""@en ;
  curric:whyThisWhyNow """Pupils will already have experienced core gymnastics skills including
  balances, rotations, rolls and simple partner work. They will now improve their technical
  fluency, movement competence and awareness whilst also analysing group performances. Later
  they will explore rolling, flight and creative movement further through parkour and further
  develop their problem solving and analytical skills.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3034-1 ,
    oakcurric:priorknowledge-3034-2 ,
    oakcurric:priorknowledge-3034-3 ,
    oakcurric:priorknowledge-3034-4 ;
  curric:id "3034"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.541656Z"^^xsd:dateTime ;
