  a curric:KeyLearningPoint ;
  rdfs:label """Move: holding the shot with ‘clean palm and dirty neck’ ensures the put is
  legal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22701-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: maximal levels of force is needed to put the shot and requires rest periods
  to recover."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22701-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: self-belief is required to put the shot due to the weight of the shot and the
  strength required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22701-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: offering encouragement to others will give them confidence to perform this
  challenging event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22768-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing a gather at the end of the run up allows the bowler to take the
  side on position they need to bowl"""@en ;
  dcterms:modified "2026-06-07T15:30:29.292724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22768-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: sending the ball down the pitch at different lengths forces the batter into
  playing different shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22768-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: varying the bowling length will keep the batter guessing and unable to get
  into a good rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22768-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: performing a successful run up, gather and delivery provides a sense of
  achievement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22768-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: helping others to understand where their ball pitched will help them to
  adjust and improve their technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22675-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: throwing and catching with control requires balance to securely ground a
  landing foot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22675-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the landing foot is used to pivot around and to direct the body to open up
  space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22675-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: the tarsals and metatarsals are located in the foot."@en ;
  dcterms:modified "2026-06-07T15:30:29.292777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22675-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: asking for the ball in space and in good time requires confidence."@en ;
  dcterms:modified "2026-06-07T15:30:29.292781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22675-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: sending and receiving the ball requires awareness of where the
  feeder is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22696-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: an approach which is an appropriate length and at near-maximal speed, provides
  the best preparation to jump far."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22696-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hitting the board with the take off foot at the ideal point will maximise jump
  distance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: observing a performance and prioritising what to feedback about can help
  someone else to make improvements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: seeing someone using your feedback to help them to perform better can be
  satisfying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22696-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: coaching a partner to improve through observation and feedback can help
  them to make more progress."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22822-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: arms are outstretched and upright stance between ball carrier and goal line
  when goalkeeping."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22822-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: drive forward quickly in a fast break to exploit space before defenders can
  recover and organise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22822-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: making yourself big and narrowing the angle reduces the shooter's view of
  goal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22822-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: staying alert and balanced to react instantly when rebounding relies on quick
  instincts and timing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22822-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: fast interplay of the ball results in more handling errors that may cause a
  dip in team morale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22774-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: long jumpers should accelerate smoothly to reach maximum speed at the take off
  board after 12-14 strides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22774-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: swinging the arms forward and upward at take off helps to transfer forward
  momentum and increase distance jumped."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: explaining the rules and feeding back to peers on accurate take off from the
  board allows for changes to be made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22774-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: setting personal targets can help motivate and improve future performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.297222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22774-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: recognising when a personal best has been achieved is more motivating than
  comparing your scores to others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.297226Z"^^xsd:dateTime .

