  a curric:KeyLearningPoint ;
  rdfs:label """Move: the arm is recoiled in the direction the ball is travelling for one handed
  catches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22821-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: stepping forward with your opposite foot helps to direct your overhead pass
