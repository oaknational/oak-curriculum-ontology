oakcurric:keylearningpoint-lesson-29762-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: adjusting your swing will modify power and angle to control distance and
  accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29762-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: satisfaction comes from being able to predict and achieve consistent
  results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29762-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: challenging yourself or others to a repeat performance raises levels of
  competition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29765-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: swinging the arms in time with the intended direction of travel increases
  momentum and distance achieved."""@en ;
