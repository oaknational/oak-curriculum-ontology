  dcterms:modified "2026-06-07T15:30:29.298406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: including variation in your training helps avoid boredom and supports
