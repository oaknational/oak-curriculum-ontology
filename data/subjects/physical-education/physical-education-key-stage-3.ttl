  dcterms:modified "2026-06-07T15:29:25.670255Z"^^xsd:dateTime .

oakcurric:priorknowledge-3050-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that they must take responsibility for the safety of themselves
  and all involved in dangerous activities."""@en ;
  dcterms:modified "2026-06-07T15:29:25.670269Z"^^xsd:dateTime .

oakcurric:priorknowledge-3050-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to perform several athletics events to a technically sound
  level."""@en ;
  dcterms:modified "2026-06-07T15:29:25.670276Z"^^xsd:dateTime .

oakcurric:priorknowledge-3050-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils show a willingness to receive constructive feedback on performance in order
  to bring about improvements."""@en ;
  dcterms:modified "2026-06-07T15:29:25.670282Z"^^xsd:dateTime .

oakcurric:priorknowledge-3021-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that all invasion games have similar features of attacking and defensive
  play to either score or deny scoring opportunities respectively."""@en ;
  dcterms:modified "2026-06-07T15:29:25.672573Z"^^xsd:dateTime .

oakcurric:priorknowledge-3021-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that football, netball, rugby, basketball and handball are all
  examples of invasion games with different rules but all games are played as a team."""@en ;
  dcterms:modified "2026-06-07T15:29:25.672587Z"^^xsd:dateTime .

oakcurric:priorknowledge-3021-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are able to control and pass a ball in a variety of ways."@en ;
  dcterms:modified "2026-06-07T15:29:25.672594Z"^^xsd:dateTime .

oakcurric:priorknowledge-3021-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils show a willingness to try new activities and focus on improving their
  skills."""@en ;
  dcterms:modified "2026-06-07T15:29:25.672600Z"^^xsd:dateTime .

oakcurric:priorknowledge-3049-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that cricket requires a balance of taking risks to score runs while
  avoiding losing wickets easily."""@en ;
  dcterms:modified "2026-06-07T15:29:25.779515Z"^^xsd:dateTime .

oakcurric:priorknowledge-3049-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that thoughtful field placements can have a big impact on limiting
  runs scored."""@en ;
  dcterms:modified "2026-06-07T15:29:25.779526Z"^^xsd:dateTime .

oakcurric:priorknowledge-3049-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are able to perform an overarm bowling technique."@en ;
  dcterms:modified "2026-06-07T15:29:25.779532Z"^^xsd:dateTime .

oakcurric:priorknowledge-3049-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils show an appreciation for the need to communicate regularly to be an effective
  team."""@en ;
  dcterms:modified "2026-06-07T15:29:25.779542Z"^^xsd:dateTime .

oakcurric:priorknowledge-3047-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils draw upon a range of stimuli and respond with a range of methods to translate
  the concept into movement."""@en ;
  dcterms:modified "2026-06-07T15:29:25.784957Z"^^xsd:dateTime .

oakcurric:priorknowledge-3047-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have a solid foundation of action-space-dynamics-relationships and their
  constituent features being able to identify their absence."""@en ;
  dcterms:modified "2026-06-07T15:29:25.784968Z"^^xsd:dateTime .

oakcurric:priorknowledge-3047-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils combine choreographic and performative concepts to achieve artistic aims."@en ;
  dcterms:modified "2026-06-07T15:29:25.784975Z"^^xsd:dateTime .

oakcurric:priorknowledge-3047-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils review their own work (or that of others) using the correct terminology,
  insight and offer a range of methods to further develop an idea."""@en ;
  dcterms:modified "2026-06-07T15:29:25.784980Z"^^xsd:dateTime .

oakcurric:priorknowledge-3047-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils apply an understanding of form to their dances, utilising motif development
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:29:25.784984Z"^^xsd:dateTime .

oakcurric:priorknowledge-3038-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that basic fundamental movement skills form the building blocks for
  other physical movement skills."""@en ;
  dcterms:modified "2026-06-07T15:29:26.009820Z"^^xsd:dateTime .

oakcurric:priorknowledge-3038-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that to improve we need to reflect on both the positives and
  negatives of our performance."""@en ;
  dcterms:modified "2026-06-07T15:29:26.009830Z"^^xsd:dateTime .

oakcurric:priorknowledge-3038-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are able to build and maintain trust when working in small groups."@en ;
  dcterms:modified "2026-06-07T15:29:26.009836Z"^^xsd:dateTime .

oakcurric:priorknowledge-3038-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils show patience and resilience when faced with a challenging task."@en ;
  dcterms:modified "2026-06-07T15:29:26.009840Z"^^xsd:dateTime .

oakcurric:priorknowledge-3048-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the importance of getting their body behind the ball or shuttle to
  transfer weight forwards as they hit."""@en ;
  dcterms:modified "2026-06-07T15:29:26.087613Z"^^xsd:dateTime .

oakcurric:priorknowledge-3048-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the importance of their court positioning to avoid leaving big
  gaps for their opponent to hit into."""@en ;
  dcterms:modified "2026-06-07T15:29:26.087623Z"^^xsd:dateTime .

oakcurric:priorknowledge-3048-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to hit basic forehands and backhands underarm and on the volley to
  maintain a rally."""@en ;
  dcterms:modified "2026-06-07T15:29:26.087629Z"^^xsd:dateTime .

oakcurric:priorknowledge-3048-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils show a motivation to transfer and modify their technique between different
  racket sports to suit the unique rules, court set-up and equipment."""@en ;
  dcterms:modified "2026-06-07T15:29:26.087634Z"^^xsd:dateTime .

