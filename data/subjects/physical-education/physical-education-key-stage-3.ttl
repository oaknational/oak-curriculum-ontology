  a curric:Keyword ;
  schema:name "3 steps"@en ;
  schema:description "a player can take up to 3 steps whilst holding the ball"@en ;
  dcterms:modified "2026-06-07T15:30:02.404170Z"^^xsd:dateTime .

oakcurric:keyword-precious
  a curric:Keyword ;
  schema:name "precious"@en ;
  schema:description "an item of great value that should be treated with care"@en ;
  dcterms:modified "2026-06-07T15:30:02.404410Z"^^xsd:dateTime .

oakcurric:keyword-springboard
  a curric:Keyword ;
  schema:name "springboard"@en ;
  schema:description """a specially designed board using in gymnastics to help generate upward
  momentum"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404416Z"^^xsd:dateTime .

oakcurric:keyword-emotional-regulation
  a curric:Keyword ;
  schema:name "emotional regulation"@en ;
  schema:description """controlling your emotions effectively, staying calm and focused in stressful
  or challenging situations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404823Z"^^xsd:dateTime .

oakcurric:keyword-gracious
  a curric:Keyword ;
  schema:name "gracious"@en ;
  schema:description """showing kindness, respect and humility whether you win or lose,
  acknowledging others' efforts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404829Z"^^xsd:dateTime .

oakcurric:keyword-humility
  a curric:Keyword ;
  schema:name "humility"@en ;
  schema:description """the quality of being modest, respectful and not seeking excessive attention
  or praise"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404834Z"^^xsd:dateTime .

oakcurric:keyword-counter-tension
  a curric:Keyword ;
  schema:name "counter tension"@en ;
  schema:description """a pulling balance where we maintain the desired shape in a stationary
  position completely still"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404842Z"^^xsd:dateTime .

oakcurric:keyword-batting-t
  a curric:Keyword ;
  schema:name "batting T"@en ;
  schema:description "a stand to hold the ball steady"@en ;
  dcterms:modified "2026-06-07T15:30:02.405037Z"^^xsd:dateTime .

oakcurric:keyword-backswing
  a curric:Keyword ;
  schema:name "backswing"@en ;
  schema:description """the movement of the bat backward in preparation for a forward swing to
  strike the ball"""@en ;
