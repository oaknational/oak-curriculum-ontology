oakcurric:keylearningpoint-lesson-29765-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: encouraging yourself and/or others shows a commitment to improvement."@en ;
  dcterms:modified "2026-06-07T15:30:29.253420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29770-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: accuracy and control are essential in order to perform using a range of
