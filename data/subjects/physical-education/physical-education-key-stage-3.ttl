  dcterms:modified "2026-06-07T15:30:29.297234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: knowing that risks are situations where someone is exposed to danger is
