  dcterms:modified "2026-06-07T15:30:29.297230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22636-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: gripping onto our team mates successfully and safely requires a strong wrist
