  dcterms:modified "2026-06-07T15:30:29.385864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22726-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: tackles need to be carefully timed to ensure contact with the ball not the
