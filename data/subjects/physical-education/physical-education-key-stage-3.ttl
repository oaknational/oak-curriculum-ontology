  dcterms:modified "2026-06-07T15:30:29.298058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: to build a long rally you need to hit with control and ideally to your
