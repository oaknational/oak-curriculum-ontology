# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "range"@en ;
  schema:description "the range of pitches that an instrument is capable of playing"@en ;
  dcterms:modified "2026-06-07T15:30:02.347362Z"^^xsd:dateTime .

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-specific
  a curric:Keyword ;
  schema:name "specific"@en ;
  schema:description "clearly defined, precise or exact"@en ;
  dcterms:modified "2026-06-07T15:30:02.347910Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-onomatopoeia
  a curric:Keyword ;
  schema:name "onomatopoeia"@en ;
  schema:description "a word that imitates or resembles the sound it describes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348028Z"^^xsd:dateTime .

oakcurric:keyword-dynamic
  a curric:Keyword ;
  schema:name "dynamic"@en ;
  schema:description """a lively and engaging performance, full of energy, to keep the audience
  interested"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348037Z"^^xsd:dateTime .

oakcurric:keyword-projection
  a curric:Keyword ;
  schema:name "projection"@en ;
  schema:description "speaking powerfully and clearly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348210Z"^^xsd:dateTime .

oakcurric:keyword-development
  a curric:Keyword ;
  schema:name "development"@en ;
  schema:description "improving and building on design ideas to make them better"@en ;
  dcterms:modified "2026-06-07T15:30:02.348273Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-fluency
  a curric:Keyword ;
  schema:name "fluency"@en ;
  schema:description "how smooth and natural speech your speech sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.349047Z"^^xsd:dateTime .

oakcurric:keyword-safety
  a curric:Keyword ;
  schema:name "safety"@en ;
  schema:description "State of being not likely to be in danger, risk or injury."@en ;
  dcterms:modified "2026-06-07T15:30:02.349289Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-challenge
  a curric:Keyword ;
  schema:name "challenge"@en ;
  schema:description "question or dispute a belief, decision or idea"@en ;
  dcterms:modified "2026-06-07T15:30:02.349796Z"^^xsd:dateTime .

oakcurric:keyword-calculate
  a curric:Keyword ;
  schema:name "calculate"@en ;
  schema:description "work out the value of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.349841Z"^^xsd:dateTime .

oakcurric:keyword-cadence
  a curric:Keyword ;
  schema:name "cadence"@en ;
  schema:description "a combination of two chords at the end of a phrase or section"@en ;
  dcterms:modified "2026-06-07T15:30:02.350014Z"^^xsd:dateTime .

oakcurric:keyword-momentum
  a curric:Keyword ;
  schema:name "momentum"@en ;
  schema:description "The product of the mass and velocity of a moving object, p = m × v."@en ;
  dcterms:modified "2026-06-07T15:30:02.350159Z"^^xsd:dateTime .

oakcurric:keyword-skill
  a curric:Keyword ;
  schema:name "skill"@en ;
  schema:description """the ability gained through training and experience to do a job or action
  well"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350272Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:02.350302Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "frequency"@en ;
  schema:description """frequency is the number of waves produced each second. Frequency is measured
  in Hertz (Hz)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350761Z"^^xsd:dateTime .

oakcurric:keyword-invade
  a curric:Keyword ;
  schema:name "invade"@en ;
  schema:description """when a group of people attack another country, moving their soldiers into
  it, they invade that country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350825Z"^^xsd:dateTime .

oakcurric:keyword-fairness
  a curric:Keyword ;
  schema:name "fairness"@en ;
  schema:description """the quality of treating people equally, or in a way that is right or
  reasonable"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350868Z"^^xsd:dateTime .

oakcurric:keyword-contraction
  a curric:Keyword ;
  schema:name "contraction"@en ;
  schema:description "two words pushed together"@en ;
  dcterms:modified "2026-06-07T15:30:02.350994Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
  flow of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351040Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.351112Z"^^xsd:dateTime .

oakcurric:keyword-precision
  a curric:Keyword ;
  schema:name "precision"@en ;
  schema:description """Precision refers to how closely results are spread around the mean
  value."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351612Z"^^xsd:dateTime .

oakcurric:keyword-approach
  a curric:Keyword ;
  schema:name "approach"@en ;
  schema:description """the first phase of the long jump in which momentum is created in preparation
  for the jump"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351667Z"^^xsd:dateTime .

oakcurric:keyword-landing
  a curric:Keyword ;
  schema:name "landing"@en ;
  schema:description "the final phase of the long jump in which you enter the sand"@en ;
  dcterms:modified "2026-06-07T15:30:02.351676Z"^^xsd:dateTime .

oakcurric:keyword-tackle
  a curric:Keyword ;
  schema:name "tackle"@en ;
  schema:description "taking the ball away from the feet of another player"@en ;
  dcterms:modified "2026-06-07T15:30:02.351911Z"^^xsd:dateTime .

oakcurric:keyword-jockey
  a curric:Keyword ;
  schema:name "jockey"@en ;
  schema:description "delaying and steering the ball carrier away from goal"@en ;
  dcterms:modified "2026-06-07T15:30:02.351922Z"^^xsd:dateTime .

oakcurric:keyword-channel
  a curric:Keyword ;
  schema:name "channel"@en ;
  schema:description "an imaginary line that divides the court vertically into 3 sections"@en ;
  dcterms:modified "2026-06-07T15:30:02.352035Z"^^xsd:dateTime .

oakcurric:keyword-fitness
  a curric:Keyword ;
  schema:name "fitness"@en ;
  schema:description "the ability to meet the demands of the environment"@en ;
  dcterms:modified "2026-06-07T15:30:02.352249Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
