  dcterms:modified "2026-06-07T15:30:29.298362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22821-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: bouncing back from mistakes and lost possession requires resilience."@en ;
