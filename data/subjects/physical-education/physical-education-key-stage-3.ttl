    natcurric:scheme-physical-education-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-move-movement-competence ,
    oakcurric:thread-think-evaluation-analysis-and-reflection .

oakcurric:unit-3043
  a curric:Unit ;
  rdfs:label "Net and wall games: understand effective performance in badminton"@en ;
  curric:slug "net-and-wall-games-understand-effective-performance-in-badminton" ;
  rdfs:comment """This unit will provide pupils with the opportunity to show commitment to
  developing their badminton skills further in both singles and doubles play. Pupils will
  also refine their skills at officiating, analysing performance and organising a fair
  competition."""@en ;
  curric:whyThisWhyNow """Pupils will already have developed their hand-eye coordination and racket
  skills in badminton with a focus on problem solving to win points and increasing proficiency
  with serves, clears and smashes. Pupils will have been introduced to analysing performance in
  racket sports to identify strengths and weaknesses. Later in net and wall games they will
  transfer ideas and learn new techniques in tennis and table tennis.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3043-1 ,
    oakcurric:priorknowledge-3043-2 ,
    oakcurric:priorknowledge-3043-3 ,
    oakcurric:priorknowledge-3043-4 ;
