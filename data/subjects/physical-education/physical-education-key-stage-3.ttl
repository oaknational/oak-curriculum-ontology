  dcterms:modified "2026-06-07T15:30:29.297238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22636-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: building trust requires consistent and reliable actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.297242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22636-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: trusting others requires you to listen, respect and try others ideas."@en ;
