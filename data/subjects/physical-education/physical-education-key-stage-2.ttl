  dcterms:modified "2026-06-07T15:30:41.099658Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22351
  a curric:PupilLessonOutcome ;
  rdfs:label "I can pass and receive the ball accurately to keep possession of the ball."@en ;
  dcterms:modified "2026-06-07T15:30:41.099662Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22576
  a curric:PupilLessonOutcome ;
  rdfs:label """I can apply attacking tactics in a game situation to create an attack that may
