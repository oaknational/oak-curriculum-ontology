  dcterms:modified "2026-06-07T15:30:29.279709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22610-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: ensuring sufficient space when moving quickly demonstrates responsibility."@en ;
  dcterms:modified "2026-06-07T15:30:29.279713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22610-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: offering suggestions, ideas and feedback is a form of collaboration."@en ;
  dcterms:modified "2026-06-07T15:30:29.279717Z"^^xsd:dateTime .

