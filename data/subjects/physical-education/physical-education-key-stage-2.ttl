  dcterms:modified "2026-06-07T15:30:41.098442Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22569
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create, apply and adapt tactics in order to outwit my opponents and execute
