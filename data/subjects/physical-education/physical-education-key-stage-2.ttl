  dcterms:modified "2026-06-07T15:30:29.280484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22505-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging others and making sure everyone is happy and motivated to try
  their best demonstrates leadership."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22339-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: working as a team to move quickly will help us to complete challenges."@en ;
  dcterms:modified "2026-06-07T15:30:29.280512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: it is important to understand that a successful team has to cooperate and
  trust one another to be successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22339-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: trying our hardest, even when we are not always successful as a team,
  demonstrates excellent resilience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22339-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working together as a team by communicating, to apply simple tactics, helps
  us win the challenge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22563-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: in smaller spaces it’s harder to avoid defenders, so we need to look up and
  use good speed and agility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22563-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: we have to ensure the space we work in is not too big or too small, otherwise
  the game will not be effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: taking responsibility for each pupil feeling involved in the activity shows
  empathy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22563-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: communicating within our teams to evaluate the space required for a game
  demonstrates that we can lead others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: moving quickly to space and passing accurately enables us to keep possession,
  creating shooting chances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22350-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when defending, being close and following the attackers' movements enables us
  to successfully mark the opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: knowing the difference between attacking and defending demonstrates a strong
