  dcterms:modified "2026-06-07T15:30:29.397783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reflecting on our defensive tactics improves our ability to stop our
