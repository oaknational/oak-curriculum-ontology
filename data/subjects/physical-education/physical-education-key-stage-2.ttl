  dcterms:modified "2026-06-07T15:30:29.395748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22567-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using attacking skills consistently at the right time enables our team to
