  dcterms:modified "2026-06-07T15:30:29.278103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22432-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: committing to trying lots of ideas and showing determination to ensure our
