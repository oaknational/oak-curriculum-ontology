  dcterms:modified "2026-06-07T15:30:29.278141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22605-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: making contact and sharing space requires all performers to be
