oakcurric:keylearningpoint-lesson-22382-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: stillness enables us to be able to communicate effectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.393849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22401-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: to run fast we must focus ahead, pump our arms, have a driving leg action and
  be light and springy on our feet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when waiting for the baton, our hand should be ready with our palm pointing up
  and we should look forwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: we can reflect on our relay changeover and work together to explore how to
  make our baton exchange faster."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22401-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: continuing to try even when the relay changeover doesn't go well demonstrates
  resilience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22401-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: trusting our teammates when taking part in a relay race and communicating
  ensures we don't drop the baton."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22466-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: swimming using the front paddle requires reaching and pulling with the arms
  whilst kicking with the legs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22466-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: swimming forwards requires us to pull the water backwards."@en ;
  dcterms:modified "2026-06-07T15:30:29.395640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22466-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: using the correct technique with our head, arms and feet enables us to travel
  through the water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22466-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: showing confidence in our swimming technique will help to improve
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22466-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: showing empathy and encouragement helps others with their technique."@en ;
  dcterms:modified "2026-06-07T15:30:29.395651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22506-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: we can adjust shots by moving our body position and angle of the bat to strike
  the ball in different directions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22506-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: striking the ball so that we aim low and hard reduces the chances of fielders
  catching us out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22506-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: evaluating the opposition helps us to identify strengths and weaknesses so we
  can adapt our tactics in the game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22506-4
  a curric:KeyLearningPoint ;
