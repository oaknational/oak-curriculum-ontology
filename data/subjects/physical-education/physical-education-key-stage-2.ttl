  dcterms:modified "2026-06-07T15:30:29.397683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22569-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to find success in the different tactics our team tries demonstrates
