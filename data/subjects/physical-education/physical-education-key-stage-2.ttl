  dcterms:modified "2026-06-07T15:30:29.280552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to apply our best throughout the game, even if our team is losing,
