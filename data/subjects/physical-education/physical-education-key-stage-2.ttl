  dcterms:modified "2026-06-07T15:30:29.279627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22625-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: encouraging other pupils shows respect and integrity."@en ;
  dcterms:modified "2026-06-07T15:30:29.279631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22552-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: before we receive the relay baton, we start to run forwards with our hand
  behind us and palm up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22552-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the baton needs to be exchanged in the changeover zone so that our team does
  not get disqualified."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: trying our best even if we find the changeover difficult demonstrates
  excellent self-motivation and teamwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: we communicate with each other when exchanging the baton to ensure we do
  not run outside the changeover zone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22610-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing actions at different speeds, including changes in speed, requires
  high levels of control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22610-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: making decisions regarding the speed in which we are going to perform our
