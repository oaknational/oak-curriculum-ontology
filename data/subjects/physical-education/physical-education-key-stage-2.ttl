  dcterms:modified "2026-06-07T15:30:29.257157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29732-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to improve the quality of our balance sequences demonstrates
