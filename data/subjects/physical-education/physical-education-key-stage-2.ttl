oakcurric:keylearningpoint-lesson-29744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: crossing the river without touching the floor requires balance and
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: deciding the best route across the river to collect maximum treasure
  demonstrates problem solving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29744-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: self-discipline helps us to never give up and always strive to achieve."@en ;
  dcterms:modified "2026-06-07T15:30:29.253234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29744-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: offering support and ideas to others will help lead to positive experiences
  for all."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29738-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using accurate sending skills throughout the game leads to greater
  success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29738-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: deciding how much power to apply to a shot, depending on where you are
  aiming, requires problem solving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: self-motivation enables us to continue to apply our best effort throughout a
  game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29738-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: knowing how to play fairly and being consistent with the rules demonstrates
  respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29735-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: stepping forwards with the opposite foot and swinging your arm from low to
  high enables accurate shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29735-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: making effective decisions about which target to aim for requires tactical
  thinking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29735-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: persevering, even if you miss a target, shows resilience."@en ;
  dcterms:modified "2026-06-07T15:30:29.254856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29735-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: playing fairly and by all the rules helps everyone enjoy the game and shows
  respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing a sequence in canon and unison requires accurate timing and
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: focusing on performing in canon and unison requires concentration to ensure
  we move in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29743-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: enjoying creating sequences and striving to improves them requires
  self-discipline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29743-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: linking movements to the music or person on the screen helps the
  performance feel coordinated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29730-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: developing our fitness and challenging our personal best requires using the
  correct technique for each action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29730-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reflection enables us to safely perform each activity using the correct
  technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to challenge our personal best and improve our aerobic fitness
  requires determination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29730-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: respect enables us to watch the technique of others and suggest ways to
  improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: mirroring a partner's actions while performing a sequence requires accurate
