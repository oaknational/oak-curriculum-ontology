  dcterms:modified "2026-06-07T15:30:29.278135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: choreographing dances to communicate unity and cohesion requires careful
