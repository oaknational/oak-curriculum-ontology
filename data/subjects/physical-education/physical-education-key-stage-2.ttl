  dcterms:modified "2026-06-07T15:30:29.279737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22629-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: breaststroke requires steady timing and a pull, breathe, kick, glide
