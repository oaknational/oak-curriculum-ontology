  dcterms:modified "2026-06-07T15:30:29.367020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22485-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: encouraging our team members, even when they make a mistake, demonstrates self
