  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing shapes and actions with precision involves control, balance and
  coordination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22382-2
  a curric:KeyLearningPoint ;
  rdfs:label "Think: deciding when and how to move requires us to think independently."@en ;
  dcterms:modified "2026-06-07T15:30:29.393842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22382-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: identifying when and how to apply our ideas requires self-discipline."@en ;
