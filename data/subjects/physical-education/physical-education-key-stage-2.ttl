  dcterms:modified "2026-06-07T15:30:29.278054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22419-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: communicating and collaborating with our team and with our opponents is an
  excellent way of showing respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22397-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: balancing a beanbag on my body and holding a meditative balance requires being
  still and slow breathing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: linking our meditative balances together can help to extend our focus,
  combining different relaxation techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22397-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: whilst performing our meditative balances, we can notice how being still
  helps our mind and body relax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: when linking our balances, showing self-motivation to keep practising improves
  our performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22397-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting our partner if they find it difficult to balance the beanbag
  requires encouragement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22432-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: quality sequences use movements performed with control and extension to flow
