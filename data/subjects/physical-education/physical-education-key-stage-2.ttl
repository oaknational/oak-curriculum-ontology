  dcterms:modified "2026-06-07T15:30:29.395756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22567-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: demonstrating self-motivation means we always apply our very best and commit
