  dcterms:modified "2026-06-07T15:30:41.098476Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29530
  a curric:PupilLessonOutcome ;
  rdfs:label "I can complete different route challenges using a range of techniques."@en ;
  dcterms:modified "2026-06-07T15:30:41.098485Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22358
  a curric:PupilLessonOutcome ;
  rdfs:label """I can throw the ball accurately into space in order to score points and win
  a game."""@en ;
  dcterms:modified "2026-06-07T15:30:41.098895Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22383
  a curric:PupilLessonOutcome ;
  rdfs:label "I can independently choreograph a simple sequence."@en ;
  dcterms:modified "2026-06-07T15:30:41.098919Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22400
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how and why we need to accelerate at the start of a race."@en ;
  dcterms:modified "2026-06-07T15:30:41.098995Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22457
  a curric:PupilLessonOutcome ;
  rdfs:label """I can combine mime with meditative balances to help me deal with negative emotions
