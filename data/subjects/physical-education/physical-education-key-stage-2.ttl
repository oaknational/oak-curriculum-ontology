  rdfs:label """Move: to perform a standing triple jump we must hop, step, jump in sequence and link
  the actions together smoothly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22551-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: we must swing our arms back for takeoff and forward during the different
  stages for power and balance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22551-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: we must land on both feet as the triple jump is measured from the furthest
  body part back."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: trying to beat our personal best each time we jump shows self-motivation."@en ;
  dcterms:modified "2026-06-07T15:30:29.367007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22551-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: evaluating our partner's jumping technique can help them to jump
  further."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: successful attacks require controlled dribbling, passing and moving skills to
