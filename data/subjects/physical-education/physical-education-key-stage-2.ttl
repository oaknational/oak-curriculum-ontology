  dcterms:modified "2026-06-07T15:30:29.279788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22629-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working collaboratively with peers and responding to feedback improves our
  swimming technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22627-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: swimming front crawl requires a regular breathing pattern whilst maintaining
  the kicking action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22627-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a streamlined position with smooth and continuous arm and leg action will
  increase speed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22627-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: a lower stroke count is more efficient and uses less energy."@en ;
  dcterms:modified "2026-06-07T15:30:29.279804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to improve at challenging tasks demonstrates excellent resilience and
  self-motivation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22627-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: congratulating our peers when they perform well shows that you are
  respectful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22505-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: increasing and decreasing our bowling speed and power makes it difficult for
  the batter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22505-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: it is important to always run to meet the ball when fielding and work with our
