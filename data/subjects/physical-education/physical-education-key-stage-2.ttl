  dcterms:modified "2026-06-07T15:30:29.255810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29742-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: keeping accurate timing while performing with a partner requires
  concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29742-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: striving to ensure all your actions are performed in time with a partner
  requires self-discipline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29742-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: mirroring the person on the screen helps me connect my actions with theirs
  and perform the sequence accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29731-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: challenging our personal best through activities that develop our flexibility
