  dcterms:modified "2026-06-07T15:30:29.256521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29731-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: observing the technique of others to understand how to improve requires
