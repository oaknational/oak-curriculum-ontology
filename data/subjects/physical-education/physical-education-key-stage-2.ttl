  dcterms:modified "2026-06-07T15:30:29.395744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22574-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: it is important to play respectfully to make sure everyone is motivated and
