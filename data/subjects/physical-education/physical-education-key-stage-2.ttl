  resourcefulness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22416-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: self-motivation helps us to apply ourselves throughout the game and lead our
  team to success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22416-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: leading by example and playing by the rules shows effective leadership and
