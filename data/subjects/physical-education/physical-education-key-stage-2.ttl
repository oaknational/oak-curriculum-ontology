  dcterms:modified "2026-06-07T15:30:29.395702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22425-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: congratulating our opponents when they win a point shows you are being
  respectful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22574-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: tagging opponents successfully requires using both hands, focussing on the
