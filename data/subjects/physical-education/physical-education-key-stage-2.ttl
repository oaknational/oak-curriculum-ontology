  dcterms:modified "2026-06-07T15:30:41.099448Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22461
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explore how to pace myself when running over a longer distance."@en ;
  dcterms:modified "2026-06-07T15:30:41.099452Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22596
  a curric:PupilLessonOutcome ;
  rdfs:label """I can make final enhancements to my sequence, performing a variety of movements as a
