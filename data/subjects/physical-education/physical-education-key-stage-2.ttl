  them quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22574-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: when defending, ensuring everyone's in position ready to apply pressure,
  needs concentration and decision making."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22574-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: taking responsibility to officiate our games, to ensure that everyone plays by
