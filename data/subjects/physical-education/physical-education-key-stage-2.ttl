  dcterms:modified "2026-06-07T15:30:41.098438Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22353
  a curric:PupilLessonOutcome ;
  rdfs:label """I can pass and move with the ball into an attacking position and shoot with the
