  dcterms:modified "2026-06-07T15:30:29.278111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: accuracy when performing requires control, coordination, balance and
