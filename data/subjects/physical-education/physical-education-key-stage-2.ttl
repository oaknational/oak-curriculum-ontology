  dcterms:modified "2026-06-07T15:30:29.395669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22506-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: in a game situation, we should always strive to encourage others, so our
  team is motivated within the game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22425-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hitting a forehand shot with control and accuracy allows us to aim for spaces
  (targets) around the court."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22425-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: varying the power of shots and hitting into space moves our opponent around
  the court helping us to win points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22425-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: controlling our forehand shots increases our accuracy and the likelihood of
  us winning points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22425-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: respecting the rules of the game and my opponent even when feeling upset
