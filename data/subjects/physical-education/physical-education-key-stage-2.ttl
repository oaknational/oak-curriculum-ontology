  dcterms:modified "2026-06-07T15:30:29.279720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22416-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when defending, preventing an attack requires applying pressure by marking the
