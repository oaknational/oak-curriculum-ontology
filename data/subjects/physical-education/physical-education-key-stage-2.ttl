  dcterms:modified "2026-06-07T15:30:29.280477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22505-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: creating and applying different tactics and working together as fielders can
  reduce the number of runs scored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22505-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: taking on the role of umpire shows responsibility and an appreciation of the
