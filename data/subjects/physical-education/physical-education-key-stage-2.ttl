  dcterms:modified "2026-06-07T15:30:41.097929Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22595
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create a sequence with a partner that includes quality matching and mirroring
