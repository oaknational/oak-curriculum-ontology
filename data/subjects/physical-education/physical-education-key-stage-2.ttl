  dcterms:modified "2026-06-07T15:30:29.282565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22363-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when we are batting, we must throw or hit the ball into space away from
