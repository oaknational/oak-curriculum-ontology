  dcterms:modified "2026-06-07T15:30:29.256517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: determination enables us to challenge our personal best and improve our
