oakcurric:keylearningpoint-lesson-22629-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: a glide after each stroke uses less energy and reduces resistance."@en ;
  dcterms:modified "2026-06-07T15:30:29.279783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22629-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: improving at challenging tasks demonstrates excellent resilience and
