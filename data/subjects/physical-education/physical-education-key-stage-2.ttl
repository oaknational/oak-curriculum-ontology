  dcterms:modified "2026-06-07T15:30:29.278107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting our partner by allowing them to suggest ideas to develop the
