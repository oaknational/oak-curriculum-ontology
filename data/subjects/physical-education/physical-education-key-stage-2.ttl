  dcterms:modified "2026-06-07T15:30:29.367028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22359-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: it is important to control how far we throw the ball over the net if we want
