# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/physical-education-programme-structure>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Physical education Programme Structure"@en ;
  dc:title "National Curriculum for England - Physical education Programme Structure"@en ;
  rdfs:comment """Physical education programme structure that specifies schemes and progressions,
  and a mapping to strands, sub-strands and content descriptors within the knowledge
  taxonomy."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/physical-education-programme-structure/0.1.1> ;

  dcterms:description """Physical education programme structure that specifies schemes and
  progressions, and a mapping to strands, sub-strands and content descriptors within the
  knowledge taxonomy."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-04T18:01:20Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-04T18:01:20Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-04T18:01:20Z"^^xsd:dateTime ;

