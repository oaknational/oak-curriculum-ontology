  dcterms:modified "2026-06-07T15:30:29.306270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: pupils know that they need to be behind the kicker to be considered onside
  and able to chase down a kick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence to apply new skills in a competitive environment requires repeated
