  dcterms:modified "2026-06-07T15:30:29.275783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24611-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working out together is motivating and supportive and makes the experience
