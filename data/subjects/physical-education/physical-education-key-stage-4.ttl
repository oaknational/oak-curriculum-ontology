  dcterms:modified "2026-06-07T15:30:29.377830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22880-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: awareness to keep the legs straight and forward for an efficient
  rotation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22880-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: being in control with good spatial awareness and timing comes from repeated
