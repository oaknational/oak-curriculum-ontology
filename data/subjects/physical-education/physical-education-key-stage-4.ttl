  dcterms:modified "2026-06-07T15:30:29.306423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23043-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: quick decision making helps maintain possession and build confidence on the
