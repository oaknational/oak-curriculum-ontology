  dcterms:modified "2026-06-07T15:30:29.275772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24611-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: completing an effective warm up prepares muscles and avoids injury."@en ;
