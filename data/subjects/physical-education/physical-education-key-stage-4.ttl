  dcterms:modified "2026-06-07T15:30:29.437027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23076-2
  a curric:KeyLearningPoint ;
  rdfs:label """The input stage receives information from the environment via selective attention to
