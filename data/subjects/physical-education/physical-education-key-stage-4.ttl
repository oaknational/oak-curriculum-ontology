# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-23091-1
  a curric:KeyLearningPoint ;
  rdfs:label """Technology in sport can enhance performer performance through tools for training,
  analysis and injury prevention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23091-2
  a curric:KeyLearningPoint ;
  rdfs:label """Technology can improve the sport experience by providing accurate and instant
  feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23091-3
  a curric:KeyLearningPoint ;
  rdfs:label """Officials benefit from technology through more accurate decision-making and reduced
  errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23091-4
  a curric:KeyLearningPoint ;
  rdfs:label """For audiences, technology enhances the viewing experience with instant replays and
  detailed statistics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23091-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sponsors gain from increased exposure and engagement through technology."@en ;
  dcterms:modified "2026-06-07T15:30:29.001705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analyse fitness and skill strengths and weaknesses in chosen activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.001987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate a training method to increase a fitness weakness."@en ;
  dcterms:modified "2026-06-07T15:30:29.001991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23034-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate a theory to bring about improvement in a skill weakness."@en ;
  dcterms:modified "2026-06-07T15:30:29.001995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23034-4
  a curric:KeyLearningPoint ;
  rdfs:label "Produce a session plan from a named method to increase a fitness component."@en ;
  dcterms:modified "2026-06-07T15:30:29.002000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23034-5
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate intensities correctly and justify their importance for accurate
  training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28800-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analyse aspects of personal performance in a practical activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.002539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28800-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate the strengths and weaknesses of the performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.002545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28800-3
  a curric:KeyLearningPoint ;
  rdfs:label """Produce an action plan which aims to improve the quality and effectiveness of the
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23016-1
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the transverse axis moving along the sagittal plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.251531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23016-2
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the sagittal axis moving along the frontal plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.251536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23016-3
  a curric:KeyLearningPoint ;
  rdfs:label """The body rotates around the longitudinal axis moving along in the transverse
  plane."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23039-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a measured approach with the dominant foot hitting the board at the ideal
  point will allow for a maximal distance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23039-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing a flight phase which allows the body to hang and prepare for
  landing increases the distance jumped."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: taking off at a 20 degree angle will ensure the optimal transfer of
  momentum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: by preparing mentally before the approach, you can perform with maximal effort
  showing self-motivation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23039-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting the accurate measurement of each other's approach distance will
  ensure best results can be achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23046-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keeping your eyes on the ball helps to determine when best to step in and
  tackle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: when there is low threat of a shot, it is best to mark/jockey a player rather
  than dive in with a tackle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23046-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: use body awareness of self and opponent to make a well timed tackle to avoid a
  foul."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: good communication from teammates helps with the decision making process
  when marking a player."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: effective defending involves using a range of travelling and body control
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23053-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: each player has an allocated area on the netball court; stepping into the
  wrong third or D is considered offside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: reflecting on your performance enables you to understand the importance of
  defence across the whole court."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23053-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working with a teammate to be strategic e.g. double marking, will make the
  game more challenging for opponents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28780-1
  a curric:KeyLearningPoint ;
  rdfs:label """A plane is an imaginary flat surface running through the body along which movement
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28780-2
  a curric:KeyLearningPoint ;
  rdfs:label "An axis is an imaginary line which the body can turn."@en ;
  dcterms:modified "2026-06-07T15:30:29.252198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28780-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are sagittal (left and right), frontal (front and back) and transverse (top
  and bottom) planes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28780-4
  a curric:KeyLearningPoint ;
  rdfs:label """The frontal (front to back), transverse (left/right) and longitudinal (vertical)
  axis enable movement analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28777-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different types of lever in the human body."@en ;
  dcterms:modified "2026-06-07T15:30:29.252305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28777-2
  a curric:KeyLearningPoint ;
  rdfs:label "Levers are categorised based on the location of the load, effort and fulcrum."@en ;
  dcterms:modified "2026-06-07T15:30:29.252310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28777-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a first class lever include the neck when heading the ball in
  football."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28777-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a second class lever include pointing the toes at the ankle
  during a jump shot in basketball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28777-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a third class lever include flexion of the elbow in a bicep
  curl."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28799-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analyse fitness and skill strengths and weaknesses in chosen activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.252618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28799-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate a training method to increase a fitness weakness."@en ;
  dcterms:modified "2026-06-07T15:30:29.252623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28799-3
  a curric:KeyLearningPoint ;
  rdfs:label "Produce a training plan to increase a fitness component."@en ;
  dcterms:modified "2026-06-07T15:30:29.252629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28799-4
  a curric:KeyLearningPoint ;
  rdfs:label "Compare pre-PEP data and post-PEP data."@en ;
  dcterms:modified "2026-06-07T15:30:29.252635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23052-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: playing netball requires stamina to continue to execute a pass with good ball
  placement within 3 seconds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23052-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: it is important to consider movements that help to create space for others,
  when attacking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23052-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: remaining in your third will build confidence to control and manage the ball
  moving through the court."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23052-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: knowing my responsibility in dead ball situations is an important part of
  being in the team."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23041-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: the throwing arm long behind the head and weight loaded onto the rear leg
  prepares thrower for weight transfer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23041-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: releasing the javelin with a fast arm at 35 degrees will help to send it as
  far as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23041-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: analysing the flight of the javelin will allow for corrections in future
  attempts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23041-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: perseverance is required as the technique requires multiple actions and
  coordination and takes time to master."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23041-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging peers and offering constructive feedback will increase
  confidence and desire to improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28994-1
  a curric:KeyLearningPoint ;
  rdfs:label "Strategies can be promoted via targeted advertising through the media."@en ;
  dcterms:modified "2026-06-07T15:30:29.253550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of provision to increase participation include facilities, opening times,
  coaching, equipment and funding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28994-3
  a curric:KeyLearningPoint ;
