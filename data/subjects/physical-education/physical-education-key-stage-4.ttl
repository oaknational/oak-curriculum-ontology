  dcterms:modified "2026-06-07T15:30:29.305568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26876-1
  a curric:KeyLearningPoint ;
  rdfs:label """The inverted-U theory illustrates that performance improves with arousal up to an
  optimal point and then declines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26876-2
  a curric:KeyLearningPoint ;
  rdfs:label """The inverted-U graph shows performance on the y-axis, arousal on the x-axis, with a
  curve shaped like an upside down U."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26876-3
  a curric:KeyLearningPoint ;
  rdfs:label """Optimal performance occurs at a moderate level of arousal. Arousal levels too high
  or too low can impair performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Optimal arousal levels differ according to whether the skill being performed is
  gross or fine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23104-1
  a curric:KeyLearningPoint ;
  rdfs:label """A balanced diet consists of the right amounts of macronutrients, micronutrients and
  fibre for their various benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23104-2
  a curric:KeyLearningPoint ;
  rdfs:label """A person's optimum weight varies for several reasons and according to the sports
  they perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23104-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diet is specfic to the needs of the activities performed and athletes will time the
  intake of macronutirents to suit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hydration is a vital factor in health and performance in sport due to the negative
  consequences of dehydration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: kicking the ball with the laces of the foot for greater accuracy and control
