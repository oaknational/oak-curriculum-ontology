  dcterms:modified "2026-06-07T15:30:29.306398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23043-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: precision passes are made with the instep and follow through towards the
