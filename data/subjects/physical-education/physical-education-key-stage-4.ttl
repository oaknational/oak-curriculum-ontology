  dcterms:modified "2026-06-07T15:30:29.383968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22873-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: stick is held with the left hand at the top of the grip and the right hand
  lower down for greater control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22873-2
  a curric:KeyLearningPoint ;
