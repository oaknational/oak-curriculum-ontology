# ----------------------------------------------------------------------
# Prior Knowledge Requirements
# ----------------------------------------------------------------------

oakcurric:priorknowledge-3097-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that some sports and social groups (men) get more media coverage than
  others"""@en ;
  dcterms:modified "2026-06-07T15:29:23.433912Z"^^xsd:dateTime .

oakcurric:priorknowledge-3097-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that minority sports struggle to get exposure"@en ;
  dcterms:modified "2026-06-07T15:29:23.433926Z"^^xsd:dateTime .

oakcurric:priorknowledge-3097-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the importance of role models in promoting sporting
  participation"""@en ;
  dcterms:modified "2026-06-07T15:29:23.433932Z"^^xsd:dateTime .

oakcurric:priorknowledge-3097-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to provide examples of sponsors of individuals, teams, venues and
  leagues"""@en ;
  dcterms:modified "2026-06-07T15:29:23.433937Z"^^xsd:dateTime .

oakcurric:priorknowledge-3097-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to provide examples of good sportsmanship and bad sporting
  behaviour"""@en ;
  dcterms:modified "2026-06-07T15:29:23.433941Z"^^xsd:dateTime .

oakcurric:priorknowledge-3084-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand that regular exercise is required to build fitness"@en ;
  dcterms:modified "2026-06-07T15:29:23.453913Z"^^xsd:dateTime .

oakcurric:priorknowledge-3084-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the different components of fitness and how they contribute to
  well-being and/ or sporting performance"""@en ;
  dcterms:modified "2026-06-07T15:29:23.453927Z"^^xsd:dateTime .

oakcurric:priorknowledge-3084-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can select strengths and weaknesses in a sport of their choice"@en ;
  dcterms:modified "2026-06-07T15:29:23.453933Z"^^xsd:dateTime .

oakcurric:priorknowledge-3078-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the name and location of different joints in the human body (e.g. knee,
  ankle and elbow)"""@en ;
  dcterms:modified "2026-06-07T15:29:23.772069Z"^^xsd:dateTime .

oakcurric:priorknowledge-3078-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that muscles work in antagonistic pairs across a joint to create
  movement via leverage of bones"""@en ;
  dcterms:modified "2026-06-07T15:29:23.772082Z"^^xsd:dateTime .

oakcurric:priorknowledge-3078-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that muscles create movement by contracting and pulling one bone to
  articulate against another bone via connected tendons"""@en ;
  dcterms:modified "2026-06-07T15:29:23.772089Z"^^xsd:dateTime .

oakcurric:priorknowledge-3078-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that some movements and sports require greater force of
  contraction whereas others require prolonged moderate intensity contractions"""@en ;
  dcterms:modified "2026-06-07T15:29:23.772094Z"^^xsd:dateTime .

oakcurric:priorknowledge-3085-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the importance of a sprint start and staying low in the drive phase of
  sprint events"""@en ;
  dcterms:modified "2026-06-07T15:29:23.775904Z"^^xsd:dateTime .

oakcurric:priorknowledge-3085-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the importance of not falling back in long and triple jump as
  measurement is from the furthest back point and you must take off without crossing the
  board"""@en ;
  dcterms:modified "2026-06-07T15:29:23.775917Z"^^xsd:dateTime .

oakcurric:priorknowledge-3085-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the importance of angle of release and not crossing the line when
  throwing"""@en ;
  dcterms:modified "2026-06-07T15:29:23.775924Z"^^xsd:dateTime .

oakcurric:priorknowledge-3085-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the importance of pacing in middle distance events"@en ;
  dcterms:modified "2026-06-07T15:29:23.775929Z"^^xsd:dateTime .

oakcurric:priorknowledge-3085-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to make connections with sprinting events as anaerobic and middle
  distance runs as aerobic and trying to stay just below the lactate threshold"""@en ;
  dcterms:modified "2026-06-07T15:29:23.775935Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the importance of creating and moving into space"@en ;
  dcterms:modified "2026-06-07T15:29:23.809252Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand how to control the ball and kick with different parts of the foot
  for accuracy versus power"""@en ;
  dcterms:modified "2026-06-07T15:29:23.809268Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the importance of eyes up when moving with the ball"@en ;
  dcterms:modified "2026-06-07T15:29:23.809275Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand how to defend, mark and jockey players"@en ;
  dcterms:modified "2026-06-07T15:29:23.809281Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are able to shoot with dominant foot"@en ;
  dcterms:modified "2026-06-07T15:29:23.809286Z"^^xsd:dateTime .

oakcurric:priorknowledge-3086-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the difference between qualitative and quantitative data through
  observation and analysis of performance"""@en ;
  dcterms:modified "2026-06-07T15:29:23.809292Z"^^xsd:dateTime .

oakcurric:priorknowledge-3087-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the footwork rule in netball and importance of pivoting"@en ;
  dcterms:modified "2026-06-07T15:29:23.832030Z"^^xsd:dateTime .

oakcurric:priorknowledge-3087-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the different playing positions and where they are allowed on the
  court"""@en ;
  dcterms:modified "2026-06-07T15:29:23.832051Z"^^xsd:dateTime .

oakcurric:priorknowledge-3087-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand basic shooting technique"@en ;
  dcterms:modified "2026-06-07T15:29:23.832062Z"^^xsd:dateTime .

oakcurric:priorknowledge-3087-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the difference between qualitative and quantitative data through
  observation and analysis of performance"""@en ;
  dcterms:modified "2026-06-07T15:29:23.832072Z"^^xsd:dateTime .

oakcurric:priorknowledge-3096-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that some sports and activities have a bigger or smaller representation
  from certain societal groups (e.g. golf, swimming, lawn bowls)"""@en ;
  dcterms:modified "2026-06-07T15:29:23.916762Z"^^xsd:dateTime .

oakcurric:priorknowledge-3096-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the importance of challenging stereotypes and social injustice"@en ;
  dcterms:modified "2026-06-07T15:29:23.916780Z"^^xsd:dateTime .

oakcurric:priorknowledge-3096-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are able to provide examples of minority or marginalised groups
  (girls etc)"""@en ;
  dcterms:modified "2026-06-07T15:29:23.916787Z"^^xsd:dateTime .

oakcurric:priorknowledge-3258-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know what basic circuit training includes"@en ;
