  dcterms:modified "2026-06-07T15:30:29.377838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22880-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: listening carefully to the feedback from others helps nurture
  friendships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22890-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: accurate placement enables meaning to be projected effectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.377846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Think: finding ways to represent non-human activity requires imagination."@en ;
  dcterms:modified "2026-06-07T15:30:29.377850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22890-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: offering suggestions and opinions involves self-belief."@en ;
  dcterms:modified "2026-06-07T15:30:29.377856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22890-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: cooperation is required when creating or performing choreography."@en ;
  dcterms:modified "2026-06-07T15:30:29.377860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23017-1
  a curric:KeyLearningPoint ;
  rdfs:label "Health involves physical, mental and social well–being."@en ;
  dcterms:modified "2026-06-07T15:30:29.379742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23017-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fitness is the ability to meet the demands of the environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.379746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23017-3
  a curric:KeyLearningPoint ;
  rdfs:label """Being fit does not automatically mean you are healthy. Conversely, a person can be
  healthy without being considered fit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22992-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each feature of a synovial joint has a different function."@en ;
  dcterms:modified "2026-06-07T15:30:29.379754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22992-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cartilage and synovial fluid allow a joint to move freely."@en ;
  dcterms:modified "2026-06-07T15:30:29.379790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22992-3
  a curric:KeyLearningPoint ;
  rdfs:label "The joint capsule and ligaments help prevent dislocation."@en ;
  dcterms:modified "2026-06-07T15:30:29.379797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22992-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hinge and ball and socket joints allow different types of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.379801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24153-1
  a curric:KeyLearningPoint ;
  rdfs:label """High altitude training involves exercising at over 2000m metres above sea level
  where there is less oxygen in the air."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24153-2
  a curric:KeyLearningPoint ;
  rdfs:label """The benefits of altitude training include increased red blood cell production and
  improved oxygen carrying capacity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24153-3
  a curric:KeyLearningPoint ;
  rdfs:label """The limitations of high altitude training include temporary benefits, the risk of
  altitude sickness and the cost."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22858-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: during continuous training, pace is steady with a relaxed and rhythmical arm
  swing in time with legs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22858-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: continuous training improves cardiovascular endurance and muscular
  endurance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: training can result in being comfortable working at an elevated
  breathing/heart rate, with mild leg discomfort."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22858-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: congratulating others on their performance, regardless of how fast they
  were, builds mutual respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24613-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: running with an increased distance, yet maintaining a natural and consistent
  stride with each foot landing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24613-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: adapting training to meet your needs to ensure progression allows flexibility
  and makes training more specific."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24613-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: increasing the distance you run each session may feel tiring on the muscles
  and cardiovascular system."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24613-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working in pairs to provide feedback on progression strategy shows
