oakcurric:keylearningpoint-lesson-22995-1
  a curric:KeyLearningPoint ;
  rdfs:label """The upper body contains muscles such as the deltiod, biceps, triceps, pectorals and
  abdominals and latissimus dorsi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22995-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lower body contains muscles such as the gluteals, quadriceps, hamstrings and
  gastrocnemius."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22995-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles are attached to bones by tendons."@en ;
  dcterms:modified "2026-06-07T15:30:29.257484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22995-4
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles contract and relax to move bones in antagonistic pairs."@en ;
  dcterms:modified "2026-06-07T15:30:29.257488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22995-5
  a curric:KeyLearningPoint ;
  rdfs:label "As one muscle contracts (agonist/prime mover), the other relaxes (antagonist)."@en ;
  dcterms:modified "2026-06-07T15:30:29.257492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23049-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: leading your movement with the shoulders and turning the hips quickly will
