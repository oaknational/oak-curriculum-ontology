  schema:description """a penalty offence for tackling a player who has already passed or kicked the
  ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363405Z"^^xsd:dateTime .

oakcurric:keyword-bronchi
  a curric:Keyword ;
  schema:name "bronchi"@en ;
  schema:description "Tubes that branch from the trachea into each lung."@en ;
  dcterms:modified "2026-06-07T15:30:02.363545Z"^^xsd:dateTime .

oakcurric:keyword-co-ordination
  a curric:Keyword ;
  schema:name "co-ordination"@en ;
  schema:description "joining two simple sentences with 'and', 'but' or 'or'"@en ;
  dcterms:modified "2026-06-07T15:30:02.363558Z"^^xsd:dateTime .

oakcurric:keyword-tramlines
