  dcterms:modified "2026-06-07T15:30:29.305557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29127-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: using imagery can increase success in shooting."@en ;
