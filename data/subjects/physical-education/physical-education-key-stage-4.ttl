  dcterms:modified "2026-06-07T15:30:29.306595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23058-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: follow through with an upward motion of the kicking leg to kick the ball
  higher."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23058-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: scrums are used to reset play but pushing isn’t really required as energy is
