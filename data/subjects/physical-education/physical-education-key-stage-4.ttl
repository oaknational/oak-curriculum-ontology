  schema:description """a shot made by swinging on the same side of your body as your dominant hand;
  the right side for right-handed players"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364348Z"^^xsd:dateTime .

oakcurric:keyword-backhand
  a curric:Keyword ;
  schema:name "backhand"@en ;
  schema:description """a shot made by swinging the racket across your body; for right-handed
  players this means swinging on the left side"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364353Z"^^xsd:dateTime .

oakcurric:keyword-doubles
  a curric:Keyword ;
  schema:name "doubles"@en ;
  schema:description "playing as a pair to form a team partnership"@en ;
  dcterms:modified "2026-06-07T15:30:02.364376Z"^^xsd:dateTime .

oakcurric:keyword-alternate-shots
  a curric:Keyword ;
  schema:name "alternate shots"@en ;
  schema:description """each player on a team must take turns hitting the ball during a rally, so
  that both partners are involved in every point"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364381Z"^^xsd:dateTime .

oakcurric:keyword-positioning
  a curric:Keyword ;
  schema:name "positioning"@en ;
  schema:description "moving effectively to give your partner space to hit the ball"@en ;
  dcterms:modified "2026-06-07T15:30:02.364385Z"^^xsd:dateTime .

oakcurric:keyword-bounce-pass
  a curric:Keyword ;
  schema:name "bounce pass"@en ;
  schema:description "a short pass in a crowded area that hits the ground once"@en ;
  dcterms:modified "2026-06-07T15:30:02.364393Z"^^xsd:dateTime .

oakcurric:keyword-frame
  a curric:Keyword ;
  schema:name "frame"@en ;
