  dcterms:modified "2026-06-07T15:30:29.385963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: decision making is utilised to realise how a position can be maintained
