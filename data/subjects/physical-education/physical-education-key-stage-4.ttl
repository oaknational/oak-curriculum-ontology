  dcterms:modified "2026-06-07T15:30:29.377822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22880-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hinging at the hips when hitting the peak of the jump allows time to prepare
