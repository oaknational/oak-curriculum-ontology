  dcterms:modified "2026-06-07T15:30:29.437035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23076-4
  a curric:KeyLearningPoint ;
  rdfs:label """During the output stage, the chosen response is transmitted as signals to the
  muscles to execute the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23076-5
  a curric:KeyLearningPoint ;
