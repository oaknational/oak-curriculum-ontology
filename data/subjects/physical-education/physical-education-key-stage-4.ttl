  dcterms:modified "2026-06-07T15:30:29.338909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the oval field has defenders, midfielders and forwards, similar to
  football."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22872-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence comes from visualising and experimenting with ways to create gaps
  in the field to attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22872-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: defenders communicate and shift together to prevent any gaps forming."@en ;
  dcterms:modified "2026-06-07T15:30:29.338921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29117-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: pushing the kin-ball in unison will increase the velocity and accuracy of the
