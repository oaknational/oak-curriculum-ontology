  dcterms:modified "2026-06-07T15:30:29.300254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23074-4
  a curric:KeyLearningPoint ;
  rdfs:label """Variable practice involves practising a skill in a variety of settings and
  conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22958-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: applying the correct technique for putting and chipping leads to accurate
