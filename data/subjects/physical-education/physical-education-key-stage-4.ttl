  curl."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29781-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: link movements together with control, balance and fluidity to coordinate
  complex movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29781-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: to improve performance you need to plan, break down actions and sequence
  logically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29781-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: successfully completing challenges will develop confidence and
  satisfaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29781-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: reflecting on your performance can help you support others to increase
  their effectiveness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22859-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performers must lift weights with correct technique (bent knees) and only lift
  weight within their ability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22859-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: feet should always be at least shoulder width apart to provide a
  stable base."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22859-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: to increase strength, performers must lift low repetitions (reps) and high
  weight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22859-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: knowing your own limits and working within them promotes a positive
  mindset."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22859-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: feedback to peers on strengths and areas for improvement on weight lifting
  technique requires sensitivity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28813-1
  a curric:KeyLearningPoint ;
  rdfs:label "The most important components of fitness vary for different sports."@en ;
  dcterms:modified "2026-06-07T15:30:29.260263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28813-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main components of fitness required for different sports and sporting actions
  can be identified via analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28813-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most sporting activities require a variety of components of fitness for success."@en ;
  dcterms:modified "2026-06-07T15:30:29.260271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29788-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: bending your knees when performing sit-ups improves performance by utilising
  abdominals and hip flexors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29788-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: landing on the forefoot and pushing off the ground immediately speeds up
  sprinting performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29788-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: core strength improves posture, reduces back pain, helps prevent injuries and
  improves functional movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29788-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: lactic acid build up causes fatigue and discomfort, but endorphin release
  during exercise improves mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29788-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: challenging others to complete a workout helps with motivation and energy
  levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260697Z"^^xsd:dateTime .

