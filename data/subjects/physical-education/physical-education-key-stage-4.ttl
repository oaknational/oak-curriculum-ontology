  dcterms:modified "2026-06-07T15:30:29.289691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28782-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries carry blood away from the heart at high pressure. They have thick walls and
  a smaller lumen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28782-2
  a curric:KeyLearningPoint ;
  rdfs:label """Veins carry blood back to the heart. They have thinner walls and contain valves to
  prevent backflow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28782-3
  a curric:KeyLearningPoint ;
  rdfs:label """Capillaries facilitate the exchange of gases, nutrients, and waste products between
  blood and tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28782-4
  a curric:KeyLearningPoint ;
  rdfs:label "Red blood cells transport oxygen, carbon dioxide and nutrients."@en ;
  dcterms:modified "2026-06-07T15:30:29.291785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28782-5
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells fight infections, platelets enable blood clotting and plasma makes
  up the main blood volume."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27977-1
  a curric:KeyLearningPoint ;
