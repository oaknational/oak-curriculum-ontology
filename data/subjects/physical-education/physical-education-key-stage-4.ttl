oakcurric:keylearningpoint-lesson-29462-1
  a curric:KeyLearningPoint ;
  rdfs:label """A balanced diet includes a variety of foods to provide essential nutrients, vitamins
  and minerals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29462-2
  a curric:KeyLearningPoint ;
  rdfs:label """No single food item provides all the necessary nutrients so diversity in food
  choices is crucial."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29462-3
  a curric:KeyLearningPoint ;
  rdfs:label """Calorie requirements are dependent on activity levels and the length and intensity
  of the activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29462-4
  a curric:KeyLearningPoint ;
  rdfs:label """Athletes may need to eat more of a specific nutrient to meet their needs, e.g.
  weightlifters and protein."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29462-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hydration is a vital factor in health and performance in sport due to the negative
  consequences of dehydration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23089-1
  a curric:KeyLearningPoint ;
  rdfs:label """The golden triangle illustrates the interconnection between sport, sponsorship and
  the media."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23089-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sport benefits from media exposure, which helps increase viewership and
  popularity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23089-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sponsorship provides financial support and resources for sport, often driven by
  media visibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23089-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media coverage can enhance sponsorship value by reaching wider audiences and
  boosting brand association."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23089-5
  a curric:KeyLearningPoint ;
  rdfs:label """The relationship among these three elements can influence the development and
  commercial success of sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28858-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skill refers to the learned ability to bring about predetermined results with
  maximum certainty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28858-2
  a curric:KeyLearningPoint ;
  rdfs:label """A motor skill is a function that involves specific movements of the body's muscles
  to perform a certain task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Skilful movement is efficient, pre-determined, co-ordinated, fluent and
  aesthetically pleasing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23078-1
  a curric:KeyLearningPoint ;
  rdfs:label "Intrinsic feedback comes from the performer's own senses and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.264176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23078-2
  a curric:KeyLearningPoint ;
  rdfs:label "Extrinsic feedback comes from external sources like coaches or peers."@en ;
  dcterms:modified "2026-06-07T15:30:29.264180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23078-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concurrent feeback is given during the performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.264184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23078-4
  a curric:KeyLearningPoint ;
  rdfs:label "Terminal feedback is given at the end of a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.264691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23078-5
  a curric:KeyLearningPoint ;
  rdfs:label "Effective feedback depends on multiple situational factors."@en ;
  dcterms:modified "2026-06-07T15:30:29.264696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sportsmanship is upholding fairness, respect and graciousness in victory or defeat,
  demonstrating ethical conduct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28851-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gamesmanship involves using clever yet unethical tactics to gain a competitive edge
  without breaking the rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28851-3
  a curric:KeyLearningPoint ;
  rdfs:label "Deviance is cheating and goes against the etiquette of sport."@en ;
  dcterms:modified "2026-06-07T15:30:29.265485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28851-4
  a curric:KeyLearningPoint ;
  rdfs:label "Violence occurs as a result of frustration, pressure and the desire to win."@en ;
  dcterms:modified "2026-06-07T15:30:29.265490Z"^^xsd:dateTime .

