  dcterms:modified "2026-06-07T15:30:29.338897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22923-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: clear, confident communication helps coordinate movement in the lineout and
