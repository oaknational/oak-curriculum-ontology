  dcterms:modified "2026-06-07T15:30:29.306460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23037-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: maintaining an effective smooth, upright and relaxed running technique will
