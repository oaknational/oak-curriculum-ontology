  a curric:KeyLearningPoint ;
  rdfs:label "Bones protect vital organs, produce red blood cells and store minerals."@en ;
  dcterms:modified "2026-06-07T15:30:29.586144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28665-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each feature of a synovial joint has a different function."@en ;
  dcterms:modified "2026-06-07T15:30:29.586149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28665-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cartilage and synovial fluid allow a joint to move freely."@en ;
  dcterms:modified "2026-06-07T15:30:29.586154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28665-3
  a curric:KeyLearningPoint ;
  rdfs:label "The joint capsule and ligaments help prevent dislocation."@en ;
  dcterms:modified "2026-06-07T15:30:29.586161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hinge and ball and socket joints allow different types of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.586166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28665-5
  a curric:KeyLearningPoint ;
  rdfs:label "The neck is a pivot joint and the wrist is a condyoid joint."@en ;
  dcterms:modified "2026-06-07T15:30:29.586171Z"^^xsd:dateTime .

