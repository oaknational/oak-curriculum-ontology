  dcterms:modified "2026-06-07T15:30:29.377826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22880-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: bringing your arms up and over in swivel hips helps create momentum to guide
