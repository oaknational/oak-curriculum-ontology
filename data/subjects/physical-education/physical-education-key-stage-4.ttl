  dcterms:modified "2026-06-07T15:30:29.306603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23058-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence to apply new skills in a competitive environment requires repeated
