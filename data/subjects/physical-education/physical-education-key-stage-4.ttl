  a curric:KeyLearningPoint ;
  rdfs:label "The body is able to recover faster from exercise after a period of training."@en ;
  dcterms:modified "2026-06-07T15:30:29.587046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28804-1
  a curric:KeyLearningPoint ;
  rdfs:label """Long-term effects of exercise refer to the benefits/changes in health and fitness
  after a period of regular training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28804-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body shape may undergo changes due to regular exercise."@en ;
  dcterms:modified "2026-06-07T15:30:29.587082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28804-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exercise leads to increased muscle strength/endurance, speed, suppleness,
  cardiovascular endurance and stamina."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28804-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular exercise can lead to an increase in heart size (hypertrophy) and bradycardia
  (a lower resting heart rate)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28804-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of exercise will develop different components of fitness."@en ;
  dcterms:modified "2026-06-07T15:30:29.587099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Key principle of overload is FITT; Frequency, Intensity, Time and Type."@en ;
  dcterms:modified "2026-06-07T15:30:29.587104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28822-2
  a curric:KeyLearningPoint ;
  rdfs:label """Applyng FITT increases the amount of work the body does, in order to achieve
  progressive overoad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Overtraining should be avoided by using appropriate weights, intensities and
  ensuring sufficient recovery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23029-2
  a curric:KeyLearningPoint ;
  rdfs:label "Appropriate clothing and footwear should be worn to reduce the risk of injury."@en ;
  dcterms:modified "2026-06-07T15:30:29.587118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23029-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hydration should be maintained to prevent dehydration."@en ;
  dcterms:modified "2026-06-07T15:30:29.587123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23029-4
  a curric:KeyLearningPoint ;
  rdfs:label """Technique used should be correct (eg. lifting technique) and spotters used if
  necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28829-1
  a curric:KeyLearningPoint ;
  rdfs:label """Prior to exercise, people should complete a PAR-Q to screen for any potential
  dangers related to their health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28829-2
  a curric:KeyLearningPoint ;
  rdfs:label """Overuse injuries can be avoided by carefully applying progressive overload and
  planning for rest and recovery time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28829-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numerous measures should be taken to ensure the safety of participants during
  activity, including protective equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28829-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facilities and equipment should be carefully checked prior to actvity to ensure no
  risk of injury to participants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28830-1
  a curric:KeyLearningPoint ;
  rdfs:label """A warm up should include a pulse raiser, mobility, stretching, dynamic movements and
  skill rehearsal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28830-2
  a curric:KeyLearningPoint ;
  rdfs:label """Warming up raises body temperature, increasing range of movement and pliability of
  muscles to reduce risk of injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28830-3
  a curric:KeyLearningPoint ;
  rdfs:label "A cool down should involve low intensity exercise and stretching exercises."@en ;
  dcterms:modified "2026-06-07T15:30:29.587160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28830-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cool down helps the transition to a resting state, facilitates the removal of waste
  products to reduce muscle soreness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23024-1
  a curric:KeyLearningPoint ;
  rdfs:label """Key principles of training in sport include specificity, progressive overload,
  reversibility, and tedium."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Principles of traning are used to optimise training and fitness and to prevent
  injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28821-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maximum heart rate is calculated as 220 minus age."@en ;
  dcterms:modified "2026-06-07T15:30:29.587182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28821-2
  a curric:KeyLearningPoint ;
  rdfs:label """Karnoven formula is the mathematical formula that helps you determine your target
  heart rate training zone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28821-3
  a curric:KeyLearningPoint ;
  rdfs:label "The aerobic training zone is 60-80% of maximum heart rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.587191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28821-4
  a curric:KeyLearningPoint ;
  rdfs:label "The anaerobic training zone is 80-90% of maximum heart rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.587205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concussion is the sudden but short-lived loss of mental function that occurs after a
  blow to the head."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23030-2
  a curric:KeyLearningPoint ;
  rdfs:label """A fracture is a partial or complete break in a bone that occurs when subjected to
  more force than it can withstand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23030-3
  a curric:KeyLearningPoint ;
  rdfs:label """A strain is a muscular injury that occurs when the muscle is overstretched
  or torn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23030-4
  a curric:KeyLearningPoint ;
  rdfs:label """A sprain is a joint injury that occurs when the ligament is overstretched or
  torn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23030-5
  a curric:KeyLearningPoint ;
  rdfs:label """Repetitive actions can inflame tendons, as is the case with golfer's elbow and
  tennis elbow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23031-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anabolic steroids and growth hormones help to increase muscle mass and power
  output."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23031-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beta blockers reduce heart rate and help calm a performer but also cause an
  increased risk of heart attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diuretics help reduce body weight by increasing fluid loss which helps to meet
  weight categories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23031-4
  a curric:KeyLearningPoint ;
  rdfs:label """Narcotic analgesics mask pain to enable athletes to keep training/performing but
  risk damage to the underlying injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23031-5
  a curric:KeyLearningPoint ;
  rdfs:label """EPO and blood doping all help with aerobic performance but put strain on the
  cardiovascular system."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23025-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maximum heart rate is calculated as 220 minus age."@en ;
  dcterms:modified "2026-06-07T15:30:29.587257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23025-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aerobic training zone is 60-80% of maximum heart rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.587261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23025-3
  a curric:KeyLearningPoint ;
  rdfs:label "The anaerobic training zone is 80-90% of maximum heart rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.587266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using your one repetition maximum (one rep max) as part of weight training to
  identify a training zone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23025-5
  a curric:KeyLearningPoint ;
  rdfs:label "Strength and power above 70% one rep max and muscular endurance below 70%."@en ;
  dcterms:modified "2026-06-07T15:30:29.587278Z"^^xsd:dateTime .

