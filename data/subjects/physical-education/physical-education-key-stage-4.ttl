  dcterms:modified "2026-06-07T15:30:29.275724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22925-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: providing a teammate with verbal strengths and areas for development is a
