oakcurric:keylearningpoint-lesson-23094-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spectators can positively influence matches by creating an exciting atmosphere and
  providing a home-field advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spectators can negatively impact matches by increasing pressure on performers."@en ;
  dcterms:modified "2026-06-07T15:30:29.439140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Negative influences of spectators include the potential for crowd trouble or
  hooliganism and safety concerns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The presence of spectators can negatively affect participation rates among younger
  performers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Safety measures and crowd management are important to mitigate the negative effects
  of spectator behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439153Z"^^xsd:dateTime .

