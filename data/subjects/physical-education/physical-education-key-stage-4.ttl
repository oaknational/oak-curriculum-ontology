  dcterms:modified "2026-06-07T15:30:29.257799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23049-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a sprinting movement on to the ball or transfer of weight will help to lose an
