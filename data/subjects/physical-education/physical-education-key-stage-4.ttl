  dcterms:modified "2026-06-07T15:30:29.338949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29124-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: depending on body shape and size, different players are better suited to
  different positions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29124-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: guidance and leadership of the players around you can have a huge impact on
