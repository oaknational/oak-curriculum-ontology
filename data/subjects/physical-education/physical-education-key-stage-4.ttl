  dcterms:modified "2026-06-07T15:30:29.338961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23045-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: if defenders are close, the ball needs to be kept closer to your body to
  reduce the risk of being tackled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23045-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: be confident to use a feint or trick to beat an opponent and create space."@en ;
  dcterms:modified "2026-06-07T15:30:29.338974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: the ball travels faster than us so dribbling is often not the best option
  to attack, passing is better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29121-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: using fast feet with a varied rhythm helps to wrong foot the opposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.341153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29121-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: attackers supporting the ball carrier should run on to the ball at pace from
  deep."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29121-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: once you make a pass, it is important to get back onside to support the next
  phase of play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29121-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: individuals need to show determination to get past a defender
  successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29121-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: leadership at the breakdown helps capitalise on opportunities to attack or
  to deny the opposition's attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341169Z"^^xsd:dateTime .

