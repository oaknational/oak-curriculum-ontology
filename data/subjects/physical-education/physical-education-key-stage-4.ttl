  dcterms:modified "2026-06-07T15:30:29.300374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22958-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: deciding where to aim a shot in order to avoid the hazards requires careful
