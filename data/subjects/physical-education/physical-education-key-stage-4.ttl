  dcterms:modified "2026-06-07T15:30:29.299115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22945-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: repeatedly performing the same action to improve performance draws upon
  resilience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: allowing another person control over our actions and safety
  involves trust."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23074-1
  a curric:KeyLearningPoint ;
  rdfs:label "Massed practice involves practising a skill continuously without taking a break."@en ;
