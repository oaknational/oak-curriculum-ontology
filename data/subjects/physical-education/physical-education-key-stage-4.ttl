  dcterms:modified "2026-06-07T15:30:29.300250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fixed practice involves practising a skill in a stable and unchanging
