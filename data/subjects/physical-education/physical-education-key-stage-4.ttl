  dcterms:modified "2026-06-07T15:30:29.385969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22947-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: applying multiple factors at the same time requires resilience."@en ;
  dcterms:modified "2026-06-07T15:30:29.385975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22947-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: a strong frame held by a partner conveys confidence and instils trust."@en ;
  dcterms:modified "2026-06-07T15:30:29.385979Z"^^xsd:dateTime .

