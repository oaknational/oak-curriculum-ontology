  dcterms:modified "2026-06-07T15:30:29.344557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22952-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: resisting the temptation to hit with too much power results in higher
