  schema:description """information collected from a large group of people to show what's typical or
  average, so others can compare to it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364339Z"^^xsd:dateTime .

oakcurric:keyword-protocol
  a curric:Keyword ;
