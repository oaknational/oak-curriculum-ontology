  dcterms:modified "2026-06-07T15:30:29.300378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22958-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: completing the hole in as few shots as possible, avoiding hazards, requires
