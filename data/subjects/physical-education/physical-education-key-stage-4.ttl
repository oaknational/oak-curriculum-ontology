  a curric:Keyword ;
  schema:name "extrinsic feedback"@en ;
  schema:description "information received from outside of the performer, e.g. from a coach"@en ;
  dcterms:modified "2026-06-07T15:30:02.359647Z"^^xsd:dateTime .

oakcurric:keyword-concurrent-feedback
  a curric:Keyword ;
  schema:name "concurrent feedback"@en ;
  schema:description "feedback provided during a performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.359652Z"^^xsd:dateTime .

oakcurric:keyword-terminal-feedback
  a curric:Keyword ;
  schema:name "terminal feedback"@en ;
  schema:description "feedback provided after a performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.359657Z"^^xsd:dateTime .

oakcurric:keyword-etiquette
  a curric:Keyword ;
  schema:name "etiquette"@en ;
  schema:description """a convention or unwritten rule in an activity. It is not an enforceable rule
  but it is usually observed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359989Z"^^xsd:dateTime .

oakcurric:keyword-sportsmanship
  a curric:Keyword ;
  schema:name "sportsmanship"@en ;
  schema:description "conforming to the rules, spirit and etiquette of a sport"@en ;
  dcterms:modified "2026-06-07T15:30:02.359994Z"^^xsd:dateTime .

oakcurric:keyword-gamesmanship
  a curric:Keyword ;
  schema:name "gamesmanship"@en ;
  schema:description """attempting to gain an advantage by bending the rules to their limit (but not
  breaking them)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.359998Z"^^xsd:dateTime .

oakcurric:keyword-deviance
  a curric:Keyword ;
  schema:name "deviance"@en ;
  schema:description """behaviour that is either immoral or seriously breaks the rules and norms of
  the sport"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360055Z"^^xsd:dateTime .

oakcurric:keyword-violence
  a curric:Keyword ;
  schema:name "violence"@en ;
  schema:description """physical acts committed in sport that go beyond the accepted rules of play
  or the expected levels of contact within a contact sport"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360061Z"^^xsd:dateTime .

oakcurric:keyword-alveoli
  a curric:Keyword ;
  schema:name "alveoli"@en ;
  schema:description "Tiny air sacs in the lungs that carry out gas exchange."@en ;
  dcterms:modified "2026-06-07T15:30:02.360108Z"^^xsd:dateTime .

oakcurric:keyword-personality
  a curric:Keyword ;
  schema:name "personality"@en ;
  schema:description "the special qualities that make a character themselves"@en ;
  dcterms:modified "2026-06-07T15:30:02.360391Z"^^xsd:dateTime .

oakcurric:keyword-outwit
  a curric:Keyword ;
  schema:name "outwit"@en ;
  schema:description """to defeat or gain an advantage over an opponent through superior
  intelligence, cleverness or strategy, rather than just physical ability"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360400Z"^^xsd:dateTime .

oakcurric:keyword-competitive
  a curric:Keyword ;
  schema:name "competitive"@en ;
  schema:description "a strong desire to win or succeed"@en ;
  dcterms:modified "2026-06-07T15:30:02.360405Z"^^xsd:dateTime .

oakcurric:keyword-pie-chart
  a curric:Keyword ;
  schema:name "Pie chart"@en ;
  schema:description """A pie chart (pie graph) is a circular graph where sectors represent
  different groups proportionally."""@en ;
  dcterms:modified "2026-06-07T15:30:02.360578Z"^^xsd:dateTime .

oakcurric:keyword-contrast
  a curric:Keyword ;
  schema:name "contrast"@en ;
  schema:description """the difference between elements (like light and dark or rough and smooth)
  that makes parts of an artwork stand out"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360601Z"^^xsd:dateTime .

oakcurric:keyword-diffusion
  a curric:Keyword ;
  schema:name "diffusion"@en ;
  schema:description """Diffusion is the net movement of particles from an area of higher
  concentration to an area of lower concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:02.360641Z"^^xsd:dateTime .

oakcurric:keyword-lactic-acid
  a curric:Keyword ;
  schema:name "lactic acid"@en ;
  schema:description """Lactic acid is a product of anaerobic cellular respiration in humans which
  causes muscle cramps."""@en ;
  dcterms:modified "2026-06-07T15:30:02.360893Z"^^xsd:dateTime .

oakcurric:keyword-aggression
  a curric:Keyword ;
  schema:name "aggression"@en ;
  schema:description """a deliberate intent to harm or injure another person, which can be physical
  or mental"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360997Z"^^xsd:dateTime .

oakcurric:keyword-direct-aggression
  a curric:Keyword ;
  schema:name "direct aggression"@en ;
  schema:description "aggressive act which involves physical contact with others, e.g. a punch"@en ;
  dcterms:modified "2026-06-07T15:30:02.361002Z"^^xsd:dateTime .

oakcurric:keyword-indirect-aggression
  a curric:Keyword ;
  schema:name "indirect aggression"@en ;
  schema:description """aggression which does not involve physical contact but is taken out on an
  object to gain advantage, e.g. hitting a tennis ball hard during a rally"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361010Z"^^xsd:dateTime .

oakcurric:keyword-delay
  a curric:Keyword ;
  schema:name "delay"@en ;
  schema:description "an effect that ‘echoes’ sounds back after a specific time"@en ;
  dcterms:modified "2026-06-07T15:30:02.361586Z"^^xsd:dateTime .

oakcurric:keyword-header
  a curric:Keyword ;
  schema:name "header"@en ;
  schema:description "part of a packet that contains addressing and other data"@en ;
  dcterms:modified "2026-06-07T15:30:02.361829Z"^^xsd:dateTime .

oakcurric:keyword-unders-line
  a curric:Keyword ;
  schema:name "‘unders’ line"@en ;
  schema:description """a running angle where a player cuts back toward the ball carrier’s inside,
  aiming to exploit gaps"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361855Z"^^xsd:dateTime .

oakcurric:keyword-overs-line
  a curric:Keyword ;
  schema:name "‘overs’ line"@en ;
  schema:description """a running angle where a player curves away from the ball carrier, aiming to
  hit the outside space of the defender"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361862Z"^^xsd:dateTime .

oakcurric:keyword-dummy
  a curric:Keyword ;
  schema:name "dummy"@en ;
  schema:description "pretending to pass or kick to deceive the defenders"@en ;
  dcterms:modified "2026-06-07T15:30:02.361867Z"^^xsd:dateTime .

oakcurric:keyword-factor-affecting-participation
  a curric:Keyword ;
  schema:name "factor affecting participation"@en ;
  schema:description """the different aspects that can influence whether people take part in sport
  or physical activity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361892Z"^^xsd:dateTime .

oakcurric:keyword-role-model
  a curric:Keyword ;
  schema:name "role model"@en ;
  schema:description """someone who people look up to and feel inspired by because of their positive
  behaviour, actions or success"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361897Z"^^xsd:dateTime .

oakcurric:keyword-calorie
  a curric:Keyword ;
  schema:name "calorie"@en ;
  schema:description "Unit of energy used on food labels."@en ;
  dcterms:modified "2026-06-07T15:30:02.361927Z"^^xsd:dateTime .

oakcurric:keyword-lateral-pass
  a curric:Keyword ;
  schema:name "lateral pass"@en ;
  schema:description """a pass that goes perpendicular to the try line and hence is not forward but
  is very flat for a player to run on to"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361972Z"^^xsd:dateTime .

oakcurric:keyword-spin-pass
  a curric:Keyword ;
  schema:name "spin pass"@en ;
  schema:description """applying rotation to the ball to help it travel faster and further mostly
  used by backline players (spiral or torpedo pass)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361976Z"^^xsd:dateTime .

oakcurric:keyword-line-runner
  a curric:Keyword ;
  schema:name "line runner"@en ;
  schema:description """a player who runs a well-timed, deliberate run to receive a pass and break
  through the defensive line"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361981Z"^^xsd:dateTime .

oakcurric:keyword-risk
  a curric:Keyword ;
  schema:name "risk"@en ;
  schema:description "Something that increases the chance of something harmful happening."@en ;
  dcterms:modified "2026-06-07T15:30:02.362072Z"^^xsd:dateTime .

oakcurric:keyword-cardiac-muscle
  a curric:Keyword ;
  schema:name "cardiac muscle"@en ;
  schema:description """Specialised tissue found in the heart which rhythmically contracts and
  relaxes together."""@en ;
  dcterms:modified "2026-06-07T15:30:02.362364Z"^^xsd:dateTime .

oakcurric:keyword-valve
  a curric:Keyword ;
  schema:name "valve"@en ;
  schema:description "Flaps in the heart which prevent backflow of blood."@en ;
  dcterms:modified "2026-06-07T15:30:02.362376Z"^^xsd:dateTime .

oakcurric:keyword-knock-on
  a curric:Keyword ;
  schema:name "knock-on"@en ;
  schema:description """when a player drops and fumbles a ball forwards when trying to catch
  a pass"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362382Z"^^xsd:dateTime .

oakcurric:keyword-fumble
  a curric:Keyword ;
  schema:name "fumble"@en ;
  schema:description "clumsy handling that often results in a dropped ball and turnover"@en ;
  dcterms:modified "2026-06-07T15:30:02.362387Z"^^xsd:dateTime .

oakcurric:keyword-support-runner
  a curric:Keyword ;
  schema:name "support runner"@en ;
  schema:description """a player who runs a well-timed, deliberate run off the ball handler to
  receive a pass or draw a defender"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362392Z"^^xsd:dateTime .

oakcurric:keyword-support
  a curric:Keyword ;
  schema:name "support"@en ;
  schema:description """support means to provide assistance or encouragement in order to help
  someone succeed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362427Z"^^xsd:dateTime .

oakcurric:keyword-review
  a curric:Keyword ;
  schema:name "review"@en ;
  schema:description "assess the quality of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.362703Z"^^xsd:dateTime .

oakcurric:keyword-calorie-consumption
  a curric:Keyword ;
  schema:name "calorie consumption"@en ;
  schema:description "the total number of calories consumed through food and drink per day"@en ;
  dcterms:modified "2026-06-07T15:30:02.362809Z"^^xsd:dateTime .

oakcurric:keyword-energy-expenditure
  a curric:Keyword ;
  schema:name "energy expenditure"@en ;
  schema:description """the total number of calories burned through physical activity, exercise, and
