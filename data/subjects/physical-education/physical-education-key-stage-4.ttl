  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a first class lever include overhead tricep extension during a
  rugby line out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a second class lever include plantar flexion at the ankle
  during a jump shot in basketball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23014-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sporting examples of a third class lever include extension at the knee when kicking
  a football."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23014-4
  a curric:KeyLearningPoint ;
  rdfs:label "A second lever system has a high mechanical advantage."@en ;
  dcterms:modified "2026-06-07T15:30:29.261086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23015-1
  a curric:KeyLearningPoint ;
  rdfs:label """A plane is an imaginary flat surface running through the body along which movement
  takes place"""@en ;
  dcterms:modified "2026-06-07T15:30:29.261274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23015-2
  a curric:KeyLearningPoint ;
  rdfs:label """An axis is an imaginary line that runs through the body's centre of gravity,
  allowing the body to rotate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23015-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are sagittal (left and right), frontal (front and back) and transverse (top
  and bottom) planes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23015-4
  a curric:KeyLearningPoint ;
  rdfs:label """The sagittal (side-to-side), transverse (forward/backward) and longitudinal
  (rotational) axis enable movement analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24150-1
  a curric:KeyLearningPoint ;
  rdfs:label """Circuit training involves stations, work-to-rest ratios and different exercises
  based on the focus of training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24150-2
  a curric:KeyLearningPoint ;
  rdfs:label "Continuous training involves sustained exercise at a steady state without rests."@en ;
  dcterms:modified "2026-06-07T15:30:29.261606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fartlek training incorporates varying speeds, terrains and work-to-recovery
  ratios."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24150-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interval training consists of periods of intense exercise interspersed with periods
  of rest or low-intensity exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24150-5
  a curric:KeyLearningPoint ;
  rdfs:label """Weight training involves resistance training with repetitions and sets with an
  emphasis on proper lifting technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Extended questions are marked using level descriptors."@en ;
  dcterms:modified "2026-06-07T15:30:29.261742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29021-2
  a curric:KeyLearningPoint ;
  rdfs:label "The hollistic approach to answering encompasses all three assessment objectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.261745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29021-3
  a curric:KeyLearningPoint ;
