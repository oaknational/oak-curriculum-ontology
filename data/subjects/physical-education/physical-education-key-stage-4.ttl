  dcterms:modified "2026-06-07T15:30:29.435025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28846-5
  a curric:KeyLearningPoint ;
  rdfs:label "Performers can use positive thinking to increase confidence."@en ;
  dcterms:modified "2026-06-07T15:30:29.435029Z"^^xsd:dateTime .

