  dcterms:modified "2026-06-07T15:30:29.332775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: throwing a variety of pitches, including fast and slow balls, reduces the
