  dcterms:modified "2026-06-07T15:30:29.308557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: serve from the back right corner and rotate clockwise when service is won."@en ;
