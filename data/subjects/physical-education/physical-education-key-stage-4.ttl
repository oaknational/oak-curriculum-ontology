  dcterms:modified "2026-06-07T15:30:29.338868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22860-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: stretching during your training programme is crucial to feel good and prevent
