  dcterms:modified "2026-06-07T15:30:02.364462Z"^^xsd:dateTime .

oakcurric:keyword-difficulty-continua
  a curric:Keyword ;
  schema:name "difficulty continua"@en ;
  schema:description "classifying how basic or complex a skill is to perform"@en ;
  dcterms:modified "2026-06-07T15:30:02.364644Z"^^xsd:dateTime .

oakcurric:keyword-environmental-continua
  a curric:Keyword ;
  schema:name "environmental continua"@en ;
  schema:description "classifying how open or closed a skills is"@en ;
  dcterms:modified "2026-06-07T15:30:02.364649Z"^^xsd:dateTime .

oakcurric:keyword-organisational-continua
  a curric:Keyword ;
  schema:name "organisational continua"@en ;
  schema:description "classifying whether a skill is low or high orgainsation."@en ;
  dcterms:modified "2026-06-07T15:30:02.364656Z"^^xsd:dateTime .

oakcurric:keyword-reflection
  a curric:Keyword ;
  schema:name "reflection"@en ;
  schema:description "a careful thought or consideration"@en ;
  dcterms:modified "2026-06-07T15:30:02.364787Z"^^xsd:dateTime .

oakcurric:keyword-joint
  a curric:Keyword ;
  schema:name "joint"@en ;
  schema:description "the place where two materials are joined together"@en ;
  dcterms:modified "2026-06-07T15:30:02.364928Z"^^xsd:dateTime .

oakcurric:keyword-anabolic-steroids
  a curric:Keyword ;
  schema:name "anabolic steroids"@en ;
  schema:description """artificially produced male hormones mimicking testosterone and promote
  muscle and bone growth, and reduce recovery time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364961Z"^^xsd:dateTime .

oakcurric:keyword-blood-doping
  a curric:Keyword ;
  schema:name "blood doping"@en ;
  schema:description "a technique to increase the amount of red blood cells in the body"@en ;
  dcterms:modified "2026-06-07T15:30:02.364966Z"^^xsd:dateTime .

oakcurric:keyword-beta-blockers
  a curric:Keyword ;
  schema:name "beta blockers"@en ;
  schema:description """drugs that are used to steady nerves by controlling heart rate and have a
  calming and relaxing effect"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364973Z"^^xsd:dateTime .

oakcurric:keyword-stimulants
  a curric:Keyword ;
  schema:name "stimulants"@en ;
  schema:description """drugs that have an effect on the central nervous system, i.e., they increase
  mental and/or physical alertness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364977Z"^^xsd:dateTime .

oakcurric:keyword-narcotic-analgesics
  a curric:Keyword ;
  schema:name "narcotic analgesics"@en ;
  schema:description "drugs that can be used to reduce the feeling of pain"@en ;
  dcterms:modified "2026-06-07T15:30:02.364984Z"^^xsd:dateTime .

oakcurric:keyword-sponsors
  a curric:Keyword ;
  schema:name "sponsors"@en ;
  schema:description """an individual or group that provides financial support to an event,
  activity, person or organisation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364991Z"^^xsd:dateTime .

oakcurric:keyword-financial-sponsorship
  a curric:Keyword ;
  schema:name "financial sponsorship"@en ;
  schema:description """when a person or company gives money in exchange for getting their name or
  brand seen by more people"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364996Z"^^xsd:dateTime .

oakcurric:keyword-underarm-throw
  a curric:Keyword ;
  schema:name "underarm throw"@en ;
  schema:description "throwing the ball from below the shoulder level"@en ;
  dcterms:modified "2026-06-07T15:30:02.365257Z"^^xsd:dateTime .

oakcurric:keyword-contact-work
  a curric:Keyword ;
  schema:name "contact work"@en ;
  schema:description "any action that includes physical contact with another performer"@en ;
  dcterms:modified "2026-06-07T15:30:02.365374Z"^^xsd:dateTime .

oakcurric:keyword-contact
  a curric:Keyword ;
  schema:name "contact"@en ;
  schema:description """physical contact is limited. Players cannot push, hold or knock over
  opponents"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365381Z"^^xsd:dateTime .

oakcurric:keyword-blocking
  a curric:Keyword ;
  schema:name "blocking"@en ;
  schema:description """players are not allowed to block or interfere with an opponent's movements
  intentionally"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365386Z"^^xsd:dateTime .

oakcurric:keyword-boxout
  a curric:Keyword ;
  schema:name "boxout"@en ;
  schema:description """is a defensive technique used to secure a rebound after a shot has been
  taken"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365391Z"^^xsd:dateTime .

oakcurric:keyword-nomination
  a curric:Keyword ;
  schema:name "nomination"@en ;
