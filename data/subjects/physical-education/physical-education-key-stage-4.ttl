  dcterms:modified "2026-06-07T15:30:02.363651Z"^^xsd:dateTime .

oakcurric:keyword-explain
  a curric:Keyword ;
  schema:name "explain"@en ;
  schema:description """to make something clear or easy to understand by describing or giving
  information about it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363949Z"^^xsd:dateTime .

oakcurric:keyword-exploit
  a curric:Keyword ;
  schema:name "exploit"@en ;
  schema:description """to take advantage of someone or something unfairly, often for
  personal gain"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364010Z"^^xsd:dateTime .

oakcurric:keyword-cardiovascular-fitness
  a curric:Keyword ;
  schema:name "cardiovascular fitness"@en ;
  schema:description """the ability to exercise your whole body for long periods of time, sometimes
  called stamina or aerobic endurance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364330Z"^^xsd:dateTime .

oakcurric:keyword-muscular-endurance
  a curric:Keyword ;
  schema:name "muscular endurance"@en ;
  schema:description "the ability to use voluntary muscles many times without getting tired"@en ;
  dcterms:modified "2026-06-07T15:30:02.364334Z"^^xsd:dateTime .

oakcurric:keyword-normative-data
  a curric:Keyword ;
