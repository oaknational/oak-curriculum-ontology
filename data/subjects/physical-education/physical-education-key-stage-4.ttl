  dcterms:modified "2026-06-07T15:30:29.289410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22897-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: defending a shot requires quick reactions, teamwork and predicting the
