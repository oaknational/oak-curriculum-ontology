oakcurric:keylearningpoint-lesson-22963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: awareness of 3 touches before the ball is returned over the net but the same
  player can't hit it twice in a row."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: appreciate the adapted version of playing in a seated position."@en ;
  dcterms:modified "2026-06-07T15:30:29.308569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22963-5
  a curric:KeyLearningPoint ;
