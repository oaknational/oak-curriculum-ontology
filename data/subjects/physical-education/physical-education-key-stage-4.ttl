  dcterms:modified "2026-06-07T15:30:29.286137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23005-1
  a curric:KeyLearningPoint ;
  rdfs:label """During inhalation the intercostal muscles and diaphragm contract to expand the
  thoracic cavity volume so air rushes in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23005-2
  a curric:KeyLearningPoint ;
  rdfs:label """During exhalation the intercostal muscles relax, the rib cage returns to its resting
  position and air is expelled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23005-3
  a curric:KeyLearningPoint ;
  rdfs:label """A spirometer trace is a graphical representation of lung volume changes over time
  during breathing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23006-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gaseous exchange is when oxygen and carbon dioxide move or diffuse from high
  concentration to lower concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23006-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oxygen is delivered to the circulatory system and then to the working muscles."@en ;
  dcterms:modified "2026-06-07T15:30:29.288602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23006-3
  a curric:KeyLearningPoint ;
  rdfs:label """The respiratory system gets oxygen into the body, then the circulatory system
  transports it to the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22897-1
  a curric:KeyLearningPoint ;
