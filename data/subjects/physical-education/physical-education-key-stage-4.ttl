  dcterms:modified "2026-06-07T15:30:29.306282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22910-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: moving slowly when searching for locations and moving quickly when returning
