  dcterms:modified "2026-06-07T15:30:29.306390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22910-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: working independently around the school site requires responsibility and
