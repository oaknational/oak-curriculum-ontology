  dcterms:modified "2026-06-07T15:30:29.338891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22923-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: working closely in structured restarts builds a sense of trust and teamwork
