  dcterms:modified "2026-06-07T15:30:02.362814Z"^^xsd:dateTime .

oakcurric:keyword-weight
  a curric:Keyword ;
  schema:name "weight"@en ;
  schema:description """the measure of how heavy an individual is, typically influenced by factors
  such as body composition and overall health"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362819Z"^^xsd:dateTime .

oakcurric:keyword-health
  a curric:Keyword ;
  schema:name "health"@en ;
  schema:description """a state of complete physical, mental and social well-being, and not merely
  the absence of disease or infirmity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.362826Z"^^xsd:dateTime .

oakcurric:keyword-responsibility
  a curric:Keyword ;
  schema:name "responsibility"@en ;
  schema:description "responsibility is when someone has a duty to deal with something"@en ;
  dcterms:modified "2026-06-07T15:30:02.363086Z"^^xsd:dateTime .

oakcurric:keyword-stance
  a curric:Keyword ;
  schema:name "stance"@en ;
  schema:description """a way of thinking about something, especially expressed in a public
