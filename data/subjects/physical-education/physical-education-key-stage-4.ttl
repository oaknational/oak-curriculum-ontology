  schema:description """landing on the trampoline in a seated position with your legs extended and
  hands placed either side"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399741Z"^^xsd:dateTime .

oakcurric:keyword-swivel-hips
  a curric:Keyword ;
  schema:name "swivel hips"@en ;
  schema:description """is a skill where the athlete performs a seat landing, then twists 180
  degrees to land back in a seat landing, facing the opposite direction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399748Z"^^xsd:dateTime .

oakcurric:keyword-axis-of-rotation
  a curric:Keyword ;
  schema:name "axis of rotation"@en ;
  schema:description "refers to the imaginary line around which a gymnast's body rotates."@en ;
  dcterms:modified "2026-06-07T15:30:02.399756Z"^^xsd:dateTime .

oakcurric:keyword-high-altitude-training
  a curric:Keyword ;
  schema:name "high altitude training"@en ;
  schema:description "training at over 2000m above sea level where is less oxygen."@en ;
  dcterms:modified "2026-06-07T15:30:02.400300Z"^^xsd:dateTime .

oakcurric:keyword-oxygen-carrying-capacity
  a curric:Keyword ;
  schema:name "oxygen carrying capacity"@en ;
  schema:description """the ability of the blood to transport oxygen and carbon dioxide, influenced
  by factors such as haemoglobin levels and red blood cell count."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400308Z"^^xsd:dateTime .

oakcurric:keyword-altitude-sickness
  a curric:Keyword ;
  schema:name "altitude sickness"@en ;
  schema:description """a condition caused by exposure to high altitudes where decreased oxygen
  levels can lead to symptoms such as headaches, nausea, and dizziness."""@en ;
  dcterms:modified "2026-06-07T15:30:02.400314Z"^^xsd:dateTime .

oakcurric:keyword-x-axis
  a curric:Keyword ;
  schema:name "X-axis"@en ;
  schema:description "The x-axis is the horizontal line on a graph which goes through zero."@en ;
  dcterms:modified "2026-06-07T15:30:02.400772Z"^^xsd:dateTime .

oakcurric:keyword-y-axis
  a curric:Keyword ;
  schema:name "Y-axis"@en ;
  schema:description "The y-axis is the vertical line on a graph which goes through zero."@en ;
  dcterms:modified "2026-06-07T15:30:02.400779Z"^^xsd:dateTime .

oakcurric:keyword-adaptability
  a curric:Keyword ;
  schema:name "adaptability"@en ;
  schema:description """the ability to modify long-term planning to meet any new conditions that
  arise"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401088Z"^^xsd:dateTime .

oakcurric:keyword-push-pass
  a curric:Keyword ;
  schema:name "push pass"@en ;
  schema:description """used to move the ball quickly and accurately over short distances where
  stick stays in contact with the ball until it is released"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401124Z"^^xsd:dateTime .

oakcurric:keyword-indian-dribble
  a curric:Keyword ;
  schema:name "Indian dribble"@en ;
  schema:description "pushing the ball from left to right and back rapidly"@en ;
  dcterms:modified "2026-06-07T15:30:02.401132Z"^^xsd:dateTime .

oakcurric:keyword-safe-practice
  a curric:Keyword ;
  schema:name "safe practice"@en ;
  schema:description """following rules and using correct technique to prevent injury and keep
  everyone safe"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401452Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-recovery
  a curric:Keyword ;
  schema:name "rate of recovery"@en ;
  schema:description "the speed at which the body returns back to normal after exercise"@en ;
  dcterms:modified "2026-06-07T15:30:02.401522Z"^^xsd:dateTime .

oakcurric:keyword-redistribution-of-blood
  a curric:Keyword ;
  schema:name "redistribution of blood"@en ;
  schema:description """when you exercise, the blood is diverted from inactive areas to the muscles
  that are being used. This action is completed through vasodilation and vasoconstriction
  (aka the vascular shunt mechanism)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401527Z"^^xsd:dateTime .

oakcurric:keyword-trend
  a curric:Keyword ;
  schema:name "trend"@en ;
  schema:description """A trend is a pattern in the data that shows the relationship between the
  independent and dependent variable."""@en ;
  dcterms:modified "2026-06-07T15:30:02.401825Z"^^xsd:dateTime .

oakcurric:keyword-touches
  a curric:Keyword ;
  schema:name "touches"@en ;
  schema:description """when a defender uses one hand to lightly tag the ball carrier on any part of
  their body, clothing or the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402258Z"^^xsd:dateTime .

oakcurric:keyword-muscle-strain
  a curric:Keyword ;
  schema:name "muscle strain"@en ;
  schema:description "an injury where a muscle is overstretched or torn"@en ;
  dcterms:modified "2026-06-07T15:30:02.402264Z"^^xsd:dateTime .

oakcurric:keyword-overuse-injuries
  a curric:Keyword ;
  schema:name "overuse injuries"@en ;
  schema:description """damage to bones, muscles or tendons caused by repetitive stress or strain
  from activities without sufficient rest or recovery time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402272Z"^^xsd:dateTime .

oakcurric:keyword-lob
  a curric:Keyword ;
  schema:name "lob"@en ;
  schema:description """a high lofted shot aimed over the head of your opposition to bounce near the
  baseline"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402304Z"^^xsd:dateTime .

oakcurric:keyword-strain
  a curric:Keyword ;
  schema:name "strain"@en ;
  schema:description "a state of tension or pressure"@en ;
  dcterms:modified "2026-06-07T15:30:02.402592Z"^^xsd:dateTime .

oakcurric:keyword-weakness
  a curric:Keyword ;
  schema:name "weakness"@en ;
  schema:description """when a player has difficulty returning a certain shot in table tennis (e.g.
  spin, location or speed)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402777Z"^^xsd:dateTime .

oakcurric:keyword-static-stretching
  a curric:Keyword ;
  schema:name "static stretching"@en ;
  schema:description "holding a stretch still/held/isometric"@en ;
  dcterms:modified "2026-06-07T15:30:02.402782Z"^^xsd:dateTime .

oakcurric:keyword-rebound-frame
  a curric:Keyword ;
  schema:name "rebound frame"@en ;
  schema:description """the 2 rebound frames are similar to small trampolines and placed at either
  end of the court"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403044Z"^^xsd:dateTime .

oakcurric:keyword-three-step-rule
  a curric:Keyword ;
  schema:name "three step rule"@en ;
  schema:description """players are allowed to take up to 3 steps while holding the ball. This rule
  encourages quick passing and movement"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403049Z"^^xsd:dateTime .

oakcurric:keyword-three-pass-rule
  a curric:Keyword ;
  schema:name "three pass rule"@en ;
  schema:description """a team can make a maximum of 3 passes before they must shoot at the rebound
  frame. This ensures that the game remains fast paced and prevents prolonged possession by
  one team"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403057Z"^^xsd:dateTime .

oakcurric:keyword-aerobic-exercise
  a curric:Keyword ;
  schema:name "aerobic exercise"@en ;
  schema:description """exercise using oxygen, usually done for longer periods of time (e.g. long
  distance running)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403149Z"^^xsd:dateTime .

oakcurric:keyword-off-spin
  a curric:Keyword ;
  schema:name "off spin"@en ;
  schema:description """a type of bowling in cricket where the ball spins from off side to leg side
  for a right-handed batter"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403708Z"^^xsd:dateTime .

oakcurric:keyword-pace-bowling
  a curric:Keyword ;
  schema:name "pace bowling"@en ;
  schema:description """a type of cricket bowling that uses speed and bounce to challenge
  the batter"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403714Z"^^xsd:dateTime .

oakcurric:keyword-punch
  a curric:Keyword ;
  schema:name "punch"@en ;
  schema:description "a strike using a closed fist"@en ;
  dcterms:modified "2026-06-07T15:30:02.403719Z"^^xsd:dateTime .

oakcurric:keyword-front-landing
  a curric:Keyword ;
  schema:name "front landing"@en ;
  schema:description """when you jump and land on your stomach, with legs extended and arms in a
  triangle shape, then bounce back up"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404175Z"^^xsd:dateTime .

oakcurric:keyword-relaxed
  a curric:Keyword ;
  schema:name "relaxed"@en ;
  schema:description "feeling calm and free from tension"@en ;
  dcterms:modified "2026-06-07T15:30:02.404180Z"^^xsd:dateTime .

oakcurric:keyword-push-on-mat
  a curric:Keyword ;
  schema:name "push on mat"@en ;
  schema:description """also referred to as spotting mats which support confidence to learn new
  moves with a softer landing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404186Z"^^xsd:dateTime .

oakcurric:keyword-problem-analysis
  a curric:Keyword ;
  schema:name "problem analysis"@en ;
  schema:description "breaking down the problem to understand it better and identify solutions"@en ;
  dcterms:modified "2026-06-07T15:30:02.404191Z"^^xsd:dateTime .

oakcurric:keyword-block-tackle
  a curric:Keyword ;
  schema:name "block tackle"@en ;
  schema:description """a player holds their stick flat on the ground to block or stop an opponent’s
  dribble or pass"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404394Z"^^xsd:dateTime .

oakcurric:keyword-jab-tackle
  a curric:Keyword ;
  schema:name "jab tackle"@en ;
  schema:description """turning your stick so the face is pointing up and jabbing at the ball to
  disrupt the player on the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404400Z"^^xsd:dateTime .

oakcurric:keyword-goal-side-marking
  a curric:Keyword ;
  schema:name "goal side marking"@en ;
  schema:description """a player stays between their opponent and the goal to block scoring
  opportunities"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404405Z"^^xsd:dateTime .

oakcurric:keyword-vardonoverlap-grip
  a curric:Keyword ;
  schema:name "Vardon/overlap grip"@en ;
  schema:description "involves both hands anchored through the right pinky finger"@en ;
  dcterms:modified "2026-06-07T15:30:02.404801Z"^^xsd:dateTime .

oakcurric:keyword-introvert
  a curric:Keyword ;
  schema:name "introvert"@en ;
  schema:description """a quiet, passive, reserved, shy personality type, usually associated with
  individual sports performance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.405937Z"^^xsd:dateTime .

oakcurric:keyword-extrovert
  a curric:Keyword ;
  schema:name "extrovert"@en ;
  schema:description """sociable, active, talkative, out-going personality type usually associated
  with team sports players"""@en ;
  dcterms:modified "2026-06-07T15:30:02.405942Z"^^xsd:dateTime .

oakcurric:keyword-aerobic-work
  a curric:Keyword ;
  schema:name "aerobic work"@en ;
  schema:description """working at a moderate intensity so that the body has time to utilise oxygen
  for energy production, allowing the body to work for a continuous period, e.g.
  long-distance events, or duration of a match"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407687Z"^^xsd:dateTime .

oakcurric:keyword-anaerobic-work
  a curric:Keyword ;
  schema:name "anaerobic work"@en ;
  schema:description """working at a high intensity without oxygen for energy production, therefore
  limited energy so work period will be short, e.g. sprinting up the wing in a football
  match"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407692Z"^^xsd:dateTime .

oakcurric:keyword-lactate-accumulation
  a curric:Keyword ;
  schema:name "lactate accumulation"@en ;
  schema:description """when lactate levels in the blood/muscle rise due to increased work
  intensity, e.g. moving from aerobic to anaerobic exercise"""@en ;
  dcterms:modified "2026-06-07T15:30:02.407700Z"^^xsd:dateTime .

oakcurric:keyword-cordination
  a curric:Keyword ;
  schema:name "cordination"@en ;
  schema:description "the ability to use two or more body parts together"@en ;
  dcterms:modified "2026-06-07T15:30:02.407706Z"^^xsd:dateTime .

oakcurric:keyword-achievable
  a curric:Keyword ;
  schema:name "achievable"@en ;
  schema:description "something you can really do with the materials and time you have"@en ;
  dcterms:modified "2026-06-07T15:30:02.409344Z"^^xsd:dateTime .

oakcurric:keyword-frontal-axis
  a curric:Keyword ;
  schema:name "frontal axis"@en ;
  schema:description "runs horizontally from front to back"@en ;
  dcterms:modified "2026-06-07T15:30:02.410122Z"^^xsd:dateTime .

oakcurric:keyword-lifestyle-choices
  a curric:Keyword ;
  schema:name "lifestyle choices"@en ;
  schema:description """the choices we make about how we live and behave that impact on our
  health"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410392Z"^^xsd:dateTime .

oakcurric:keyword-recreational-drugs
  a curric:Keyword ;
  schema:name "recreational drugs"@en ;
  schema:description """drugs taken for enjoyment (not for medical purposes) such as alcohol or
  nicotine"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410400Z"^^xsd:dateTime .

oakcurric:keyword-vertical-axis
  a curric:Keyword ;
  schema:name "vertical axis"@en ;
  schema:description "a line of rotation which goes through the body from head to toe"@en ;
  dcterms:modified "2026-06-07T15:30:02.411162Z"^^xsd:dateTime .

oakcurric:keyword-simple-skill
  a curric:Keyword ;
  schema:name "simple skill"@en ;
  schema:description """a skill which is quickly learned as there are very few decisions to be made
  when performing the skill"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411540Z"^^xsd:dateTime .

oakcurric:keyword-open-skills
  a curric:Keyword ;
  schema:name "open skills"@en ;
  schema:description """skills affected by the environment and predominantly perceptual as they must
  be adapted to suit the environment. These are usually externally paced e.g. a pass within
  a game situation in football"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411546Z"^^xsd:dateTime .

oakcurric:keyword-closed-skills
  a curric:Keyword ;
  schema:name "closed skills"@en ;
  schema:description """skills that are performed in a predictable environment e.g. a player taking
  a line out in rugby"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411551Z"^^xsd:dateTime .

oakcurric:keyword-measurable
  a curric:Keyword ;
  schema:name "measurable"@en ;
  schema:description """being clear about what is going to be achieved with a quantitative
  measure"""@en ;
  dcterms:modified "2026-06-07T15:30:02.411728Z"^^xsd:dateTime .

oakcurric:keyword-recorded
  a curric:Keyword ;
  schema:name "recorded"@en ;
  schema:description "ensuring a goal is written down and progress is logged"@en ;
  dcterms:modified "2026-06-07T15:30:02.411734Z"^^xsd:dateTime .

oakcurric:keyword-timed
  a curric:Keyword ;
  schema:name "timed"@en ;
  schema:description "stating when a goal will be achieved by"@en ;
  dcterms:modified "2026-06-07T15:30:02.411739Z"^^xsd:dateTime .

oakcurric:keyword-time-bound
  a curric:Keyword ;
  schema:name "Time-bound"@en ;
  schema:description "stating when a goal will be achieved by"@en ;
  dcterms:modified "2026-06-07T15:30:02.412160Z"^^xsd:dateTime .

oakcurric:keyword-mental-rehearsal
  a curric:Keyword ;
  schema:name "mental rehearsal"@en ;
  schema:description """a relaxation technique which involves the performer picturing themselves
  performing the skill perfectly or imagining positive outcomes before attempting it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413125Z"^^xsd:dateTime .

oakcurric:keyword-deep-breathing
  a curric:Keyword ;
  schema:name "deep breathing"@en ;
  schema:description """a relaxation technique which involves a performer exaggerating their breaths
  in and out"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413130Z"^^xsd:dateTime .

oakcurric:keyword-positive-self-talk
  a curric:Keyword ;
  schema:name "positive self-talk"@en ;
  schema:description "developing cognitive positive thoughts about your own performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.413135Z"^^xsd:dateTime .

oakcurric:keyword-selective-attention
  a curric:Keyword ;
  schema:name "selective attention"@en ;
  schema:description """focussing on the important stimuli and blocking out any which might be
  distracting"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413141Z"^^xsd:dateTime .

oakcurric:keyword-positive-thinking
  a curric:Keyword ;
  schema:name "positive thinking"@en ;
  schema:description "developing cognitive positive thoughts about your own performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.413146Z"^^xsd:dateTime .

oakcurric:keyword-emotional-mental-health
  a curric:Keyword ;
  schema:name "emotional (mental) health"@en ;
  schema:description """can cope with the normal stresses of life, can work productively and
  fruitfully, and is able to make a contribution to her or his community"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413517Z"^^xsd:dateTime .

oakcurric:keyword-accepted
  a curric:Keyword ;
  schema:name "accepted"@en ;
  schema:description """goals must be agreed by the performer and (possibly) others involved, e.g.
  coach"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413581Z"^^xsd:dateTime .

oakcurric:keyword-information-processing
  a curric:Keyword ;
  schema:name "information processing"@en ;
  schema:description """making decisions and gathering data from the display (senses), prioritising
  the most important stimuli to make a suitable decision"""@en ;
  dcterms:modified "2026-06-07T15:30:02.413586Z"^^xsd:dateTime .

oakcurric:keyword-input-stage
  a curric:Keyword ;
  schema:name "input stage"@en ;
  schema:description "information from the display"@en ;
  dcterms:modified "2026-06-07T15:30:02.413591Z"^^xsd:dateTime .

oakcurric:keyword-output-stage
  a curric:Keyword ;
  schema:name "output stage"@en ;
  schema:description "information sent to the muscles to carry out a response"@en ;
  dcterms:modified "2026-06-07T15:30:02.413602Z"^^xsd:dateTime .

oakcurric:keyword-home-field-advantage
  a curric:Keyword ;
  schema:name "home-field advantage"@en ;
  schema:description """the benefit gained from playing in a familiar environment with local
  support"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414044Z"^^xsd:dateTime .

oakcurric:keyword-amateur
  a curric:Keyword ;
  schema:name "amateur"@en ;
  schema:description """this term defines someone who takes part in an activity as a hobby, rather
  than for financial gain"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414049Z"^^xsd:dateTime .

oakcurric:keyword-hooliganism
  a curric:Keyword ;
  schema:name "hooliganism"@en ;
  schema:description """disorderly, aggressive and often violent behaviour by spectators at sporting
  events"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414055Z"^^xsd:dateTime .

oakcurric:keyword-contract-to-compete
  a curric:Keyword ;
  schema:name "contract to compete"@en ;
  schema:description """unwritten agreement to follow and abide by the written and unwritten
  rules"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414344Z"^^xsd:dateTime .

oakcurric:keyword-immediate-effects-of-exercise
  a curric:Keyword ;
  schema:name "immediate effects of exercise"@en ;
  schema:description "effects on the body that occur during and straight after exercise"@en ;
  dcterms:modified "2026-06-07T15:30:02.414358Z"^^xsd:dateTime .

oakcurric:keyword-short-term-effects-of-exercise
  a curric:Keyword ;
  schema:name "short-term effects of exercise"@en ;
  schema:description "effects on the body within 36 hours after exercise"@en ;
  dcterms:modified "2026-06-07T15:30:02.414363Z"^^xsd:dateTime .

oakcurric:keyword-doms
  a curric:Keyword ;
  schema:name "DOMS"@en ;
  schema:description """delayed onset of muscle soreness; muscle pain and stiffness caused by
  microscopic muscle tears"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414371Z"^^xsd:dateTime .

oakcurric:keyword-cramp
  a curric:Keyword ;
  schema:name "cramp"@en ;
  schema:description """sudden, painful involuntary muscle contraction during or after intense
  exercise"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414377Z"^^xsd:dateTime .

oakcurric:keyword-segregation
  a curric:Keyword ;
  schema:name "segregation"@en ;
  schema:description "in sport: act of separating groups of rival fans"@en ;
  dcterms:modified "2026-06-07T15:30:02.414382Z"^^xsd:dateTime .

oakcurric:keyword-alcohol-restrictions
  a curric:Keyword ;
  schema:name "alcohol restrictions"@en ;
  schema:description "limiting when and where alcohol can be purchased and consumed"@en ;
  dcterms:modified "2026-06-07T15:30:02.414387Z"^^xsd:dateTime .

oakcurric:keyword-epoc
  a curric:Keyword ;
  schema:name "EPOC"@en ;
  schema:description """excess post-exercise oxygen consumption is the increased rate of oxygen
  intake following exercise to restore the body to its resting state"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414472Z"^^xsd:dateTime .

oakcurric:keyword-physiology
  a curric:Keyword ;
  schema:name "physiology"@en ;
  schema:description "the study of how the human body works or functions"@en ;
  dcterms:modified "2026-06-07T15:30:02.414511Z"^^xsd:dateTime .

oakcurric:keyword-musculoskeletal
  a curric:Keyword ;
  schema:name "musculoskeletal"@en ;
  schema:description """a combination of the muscular and skeletal system comprising of muscles,
  bones, joints and connective tissues"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414519Z"^^xsd:dateTime .

oakcurric:keyword-agonistprime-mover
  a curric:Keyword ;
  schema:name "agonist/prime mover"@en ;
  schema:description "the muscle or group of muscles responsible for the movement"@en ;
  dcterms:modified "2026-06-07T15:30:02.414524Z"^^xsd:dateTime .

oakcurric:keyword-rotator-cuffs
  a curric:Keyword ;
  schema:name "rotator cuffs"@en ;
  schema:description """group of muscles and tendons in the shoulder that enable a wide range of
  shoulder and arm movements whilst keeping the shoulder stable"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414530Z"^^xsd:dateTime .

oakcurric:keyword-short-bone
  a curric:Keyword ;
  schema:name "short bone"@en ;
  schema:description "a small bone that is used for weight bearing"@en ;
  dcterms:modified "2026-06-07T15:30:02.414535Z"^^xsd:dateTime .

oakcurric:keyword-long-bone
  a curric:Keyword ;
  schema:name "long bone"@en ;
  schema:description "a large bone that is used for leverage and movement"@en ;
  dcterms:modified "2026-06-07T15:30:02.414541Z"^^xsd:dateTime .

oakcurric:keyword-flat-bone
  a curric:Keyword ;
  schema:name "flat bone"@en ;
  schema:description """a bone that protects a vital organ and provides a flat surface for muscle
  attachment"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414546Z"^^xsd:dateTime .

oakcurric:keyword-irregular-bone
  a curric:Keyword ;
  schema:name "irregular bone"@en ;
  schema:description "a bone shaped to provide protection and muscle attachment"@en ;
  dcterms:modified "2026-06-07T15:30:02.414554Z"^^xsd:dateTime .

oakcurric:keyword-voluntary
  a curric:Keyword ;
  schema:name "voluntary"@en ;
  schema:description "when something is under our conscious control"@en ;
  dcterms:modified "2026-06-07T15:30:02.414560Z"^^xsd:dateTime .

oakcurric:keyword-involuntary
  a curric:Keyword ;
  schema:name "involuntary"@en ;
  schema:description "when something is not under our conscious control"@en ;
  dcterms:modified "2026-06-07T15:30:02.414565Z"^^xsd:dateTime .

oakcurric:keyword-slow-twitch
  a curric:Keyword ;
  schema:name "slow twitch"@en ;
  schema:description "a type I muscle fibre type with slow speed and low force of contraction"@en ;
  dcterms:modified "2026-06-07T15:30:02.414570Z"^^xsd:dateTime .

oakcurric:keyword-fast-twitch
  a curric:Keyword ;
  schema:name "fast twitch"@en ;
  schema:description "a type II muscle fibre with a fast speed and high force of contraction"@en ;
  dcterms:modified "2026-06-07T15:30:02.414575Z"^^xsd:dateTime .

oakcurric:keyword-long-term-effects-of-exercise
  a curric:Keyword ;
  schema:name "long term effects of exercise"@en ;
  schema:description """the effects on our body of months and/or years of regular physical
  activity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414721Z"^^xsd:dateTime .

oakcurric:keyword-hypertrophy
  a curric:Keyword ;
  schema:name "hypertrophy"@en ;
  schema:description "the increase in size of skeletal or cardiac muscle"@en ;
  dcterms:modified "2026-06-07T15:30:02.414726Z"^^xsd:dateTime .

oakcurric:keyword-capillarisation
  a curric:Keyword ;
  schema:name "capillarisation"@en ;
  schema:description """the development of blood capillaries in the body which increases through
  long term effects of exercise"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414731Z"^^xsd:dateTime .

oakcurric:keyword-blood-pressure
  a curric:Keyword ;
  schema:name "blood pressure"@en ;
  schema:description "pressure exerted by the blood on the walls of the blood vessels"@en ;
  dcterms:modified "2026-06-07T15:30:02.414739Z"^^xsd:dateTime .

oakcurric:keyword-bradycardia
  a curric:Keyword ;
  schema:name "bradycardia"@en ;
  schema:description """lower resting heart rate below 60 BPM as a result of regular physical
  activity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414756Z"^^xsd:dateTime .

oakcurric:keyword-suppleness
  a curric:Keyword ;
  schema:name "suppleness"@en ;
  schema:description "as with flexibility, the range of movement possible at a joint"@en ;
  dcterms:modified "2026-06-07T15:30:02.414761Z"^^xsd:dateTime .

oakcurric:keyword-type
  a curric:Keyword ;
  schema:name "type"@en ;
  schema:description "the specific training method used to train"@en ;
  dcterms:modified "2026-06-07T15:30:02.414766Z"^^xsd:dateTime .

oakcurric:keyword-injury-prevention
  a curric:Keyword ;
  schema:name "injury prevention"@en ;
  schema:description """strategies and practices aimed at reducing the risk of injuries during
  physical activity or sport"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414771Z"^^xsd:dateTime .

oakcurric:keyword-protective-clothingequipment
  a curric:Keyword ;
  schema:name "protective clothing/equipment"@en ;
  schema:description """something used or worn during an activity with the specific aim of reducing
  the risk of injury"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414780Z"^^xsd:dateTime .

oakcurric:keyword-overuse-injury
  a curric:Keyword ;
  schema:name "overuse injury"@en ;
  schema:description """an injury caused when a muscle or joint is used repetitively over time and
  the stress causes injury"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414785Z"^^xsd:dateTime .

oakcurric:keyword-pulse-raising
  a curric:Keyword ;
  schema:name "pulse raising"@en ;
  schema:description """activities in a warm up that elevate heart rate and increase blood flow to
  muscles"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414790Z"^^xsd:dateTime .

oakcurric:keyword-tedium
  a curric:Keyword ;
  schema:name "tedium"@en ;
  schema:description """boredom that can occur from training the same way every time. Variety is
  needed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414796Z"^^xsd:dateTime .

oakcurric:keyword-maximum-heart-rate-maxhr
  a curric:Keyword ;
  schema:name "maximum heart rate (MaxHR)"@en ;
  schema:description "calculated by 220 - age"@en ;
  dcterms:modified "2026-06-07T15:30:02.414801Z"^^xsd:dateTime .

oakcurric:keyword-aerobic-training-zone
  a curric:Keyword ;
  schema:name "aerobic training zone"@en ;
  schema:description """calculated at 60-80% maximum heart rate to allow the aerobic system to be
  trained"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414809Z"^^xsd:dateTime .

oakcurric:keyword-anaerobic-training-zone
  a curric:Keyword ;
  schema:name "anaerobic training zone"@en ;
  schema:description """calculated at 80-90% maximum heart rate to allow the anaerobic system to be
  trained"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414817Z"^^xsd:dateTime .

oakcurric:keyword-karnoven-formula
  a curric:Keyword ;
  schema:name "karnoven formula"@en ;
  schema:description """mathematical formula that helps you determine your target heart rate
  training zone"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414825Z"^^xsd:dateTime .

oakcurric:keyword-concussion
  a curric:Keyword ;
  schema:name "concussion"@en ;
  schema:description "temporary unconsciousness or confusion caused by a blow on the head"@en ;
  dcterms:modified "2026-06-07T15:30:02.414833Z"^^xsd:dateTime .

oakcurric:keyword-fracture
  a curric:Keyword ;
  schema:name "fracture"@en ;
  schema:description "the cracking or breaking of a bone"@en ;
  dcterms:modified "2026-06-07T15:30:02.414838Z"^^xsd:dateTime .

oakcurric:keyword-dislocation
  a curric:Keyword ;
  schema:name "dislocation"@en ;
  schema:description "injury caused when the normal position of a joint is displaced"@en ;
  dcterms:modified "2026-06-07T15:30:02.414844Z"^^xsd:dateTime .

oakcurric:keyword-sprain
  a curric:Keyword ;
  schema:name "sprain"@en ;
  schema:description "a overstretching or tearing of ligaments"@en ;
  dcterms:modified "2026-06-07T15:30:02.414849Z"^^xsd:dateTime .

oakcurric:keyword-diuretics
  a curric:Keyword ;
  schema:name "diuretics"@en ;
  schema:description """medication that increases urine production, helping to remove excess fluid
  from the body"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414854Z"^^xsd:dateTime .

oakcurric:keyword-training-thresholds
  a curric:Keyword ;
  schema:name "training thresholds"@en ;
  schema:description "the actual boundaries of the target zone"@en ;
  dcterms:modified "2026-06-07T15:30:02.414862Z"^^xsd:dateTime .

oakcurric:keyword-maximum-heart-rate
  a curric:Keyword ;
  schema:name "maximum heart rate"@en ;
  schema:description "calculated by 220 minus age"@en ;
  dcterms:modified "2026-06-07T15:30:02.414868Z"^^xsd:dateTime .

oakcurric:keyword-one-rep-max
  a curric:Keyword ;
  schema:name "one rep max"@en ;
  schema:description """the maximal amount that can be lifted in one repetition by a muscle
  group"""@en ;
  dcterms:modified "2026-06-07T15:30:02.414874Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-believing-technology-improves-performance-without
  a curric:Misconception ;
  curric:statement """Believing that technology always improves performance without considering
  potential drawbacks."""@en ;
  curric:correction """Technology has both positive and negative impacts on different people in
  sport, including performers, sponsors, spectators and officials."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084566Z"^^xsd:dateTime .

oakcurric:misconception-include-fitness-test-protocols-scores
  a curric:Misconception ;
  curric:statement """I must include fitness test protocols and scores to show my fitness strength
  and weakness."""@en ;
  curric:correction """This is not a requirement. The analysis of the fitness components is using
  recent competitive performances, and justifying how it benefited or negatively affected
  that actual performance/s."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084651Z"^^xsd:dateTime .

oakcurric:misconception-memorising-writing-definitions-textbook-earns
  a curric:Misconception ;
  curric:statement "Memorising and writing the definitions from the textbook earns marks."@en ;
  curric:correction """Marks are only awarded for applying your knowledge to explain the
  implications of fitness, skill and tactical decision making on performance. With only 14
  hours to complete the coursework, it is essential to focus time on application of
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084816Z"^^xsd:dateTime .

oakcurric:misconception-three-planes-paired-three-axes
  a curric:Misconception ;
  curric:statement "Any of the three planes can be paired with the three axes."@en ;
  curric:correction """Planes and axes are always paired as; sagittal plane with the transverse
  axis, frontal plane with the sagittal axis and transverse plane with the longitudinal
  axis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085670Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-starting-their-approach
  a curric:Misconception ;
  curric:statement """Pupils believe starting their approach from the furthest point on the runway
  will result in the best possible approach and jump."""@en ;
  curric:correction """The approach is personalised and should be measured to ensure optimal speed
  is reached and the take off is smooth without the need to break stride. For most, the end
  of the runway will not be the ideal starting point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085675Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-defending-important-playing
  a curric:Misconception ;
  curric:statement """Pupils think that defending is only important when playing a defensive
  position or during set pieces."""@en ;
  curric:correction """Defence starts from the striker position and works all the back to the GK.
  Defending well as an individual leads to collective marking and reduction of attacking
  space and opportunities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085789Z"^^xsd:dateTime .

oakcurric:misconception-once-player-released-ball-defenders
  a curric:Misconception ;
  curric:statement "Once a player has released the ball, the defenders' work is done."@en ;
  curric:correction "Stage 3 defending can be used to impact the next phase of play."@en ;
  dcterms:modified "2026-06-07T15:30:15.085843Z"^^xsd:dateTime .

oakcurric:misconception-transverse-plane-linked-transverse-axis
  a curric:Misconception ;
  curric:statement "The transverse plane is linked with the transverse axis."@en ;
  curric:correction """They share the same name, however the transverse plane is linked with the
  longitudinal axis. The transverse axis is linked with the sagittal plane. The frontal
  plane and axis however have the same name and are linked."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085868Z"^^xsd:dateTime .

oakcurric:misconception-joint-movements-require-same-sort
  a curric:Misconception ;
  curric:statement "All joint movements require the same sort of leverage."@en ;
  curric:correction """The orientation of the fulcrum (joint), the effort (muscle) and the load
  dictate which of the three classes of lever it is and also if there is a mechanical
  advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085896Z"^^xsd:dateTime .

oakcurric:misconception-once-planned-need-take-part
  a curric:Misconception ;
  curric:statement """Once planned, I just need to take part in the training without writing
  anything down."""@en ;
  curric:correction """It is useful to keep up to date training logs for each session to help
  monitor progress (these are not included in the word count) as well as doing mid PEP
  fitness testing to check progress and adapt the planned training programme where needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085931Z"^^xsd:dateTime .

oakcurric:misconception-penalty-pass-awarded-player-infringed
  a curric:Misconception ;
  curric:statement "When a penalty pass is awarded, the player infringed has to take the pass."@en ;
  curric:correction """Any player can take the penalty pass if it is in a third they are permitted
  to go into. Players need to communicate who this player can be in order to create an
  attacking advantage, as the player who made the infringement has to stand out of play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085974Z"^^xsd:dateTime .

oakcurric:misconception-common-mistake-pupils-make-using
  a curric:Misconception ;
  curric:statement """A common mistake pupils make is using a 'bowling' style of throw in which the
  throwing arm remains straight throughout the action."""@en ;
  curric:correction """Ask pupils to think about pulling the javelin through, with the elbow leading
  first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086165Z"^^xsd:dateTime .

oakcurric:misconception-provision-includes-funding-money
  a curric:Misconception ;
  curric:statement "Provision only includes funding or money."@en ;
  curric:correction """Increasing provision can also include improving facilities, time, coaching
  and equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086197Z"^^xsd:dateTime .

oakcurric:misconception-sport-activity-one-training-method
  a curric:Misconception ;
  curric:statement "Each sport or activity has only one training method suited to it."@en ;
  curric:correction """Perfomers in most activities can benefit from the use of multiple trianing
  types. For example, a marathon runner would most benefit from continuous training;
  however, weight training could also be used to help condition the muscles and avoid
  injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086346Z"^^xsd:dateTime .

oakcurric:misconception-saggital-plane-linked-saggital-axis
  a curric:Misconception ;
  curric:statement "The saggital plane is linked with the saggital axis."@en ;
  curric:correction """They share the same name; however, the sagittal plane is linked with the
  frontal axis. The saggital axis is linked with the frontal plane."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086773Z"^^xsd:dateTime .

oakcurric:misconception-overload-negative-encouraged-training
  a curric:Misconception ;
  curric:statement "Overload is negative and should not be encouraged during training."@en ;
  curric:correction """Overload is encouarged as a positive aspect of traning as progression is
  being managed correctly to bring about adaptations to fitness. It is not to be confused
  with 'overtraining' which can cause injuries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086787Z"^^xsd:dateTime .

oakcurric:misconception-students-thinking-certain-sports-need
  a curric:Misconception ;
  curric:statement """Students thinking that certain sports only need one type of component of
  fitness to be successful e.g. 100m sprinter just needs speed."""@en ;
  curric:correction """Identify all the components of fitness that are useful for each athlete,
  determining why they are beneficial and justifying which is most important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086802Z"^^xsd:dateTime .

oakcurric:misconception-ngbs-support-elite-sports-people
  a curric:Misconception ;
  curric:statement "NGBs only support elite sports people at the top of their game."@en ;
  curric:correction """NGBs provide support to everyone, from grass roots level all the way up to
  elite level sport."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086814Z"^^xsd:dateTime .

oakcurric:misconception-position-non-striking-foot-changes
  a curric:Misconception ;
  curric:statement """Position of the non striking foot changes depending on where the shot is being
  aimed in the goal."""@en ;
  curric:correction """This is a common myth, however the positioning of the non striking foot
  remains consistent and needs to be at the side of the ball for optimal balance and
  accuracy so the shot is precise and on target."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086899Z"^^xsd:dateTime .

oakcurric:misconception-good-sport-means-fast-strong
  a curric:Misconception ;
  curric:statement "Being good at sport just means being fast or strong."@en ;
  curric:correction """Success in sport depends on coordination and balance, timing and decision
  making, technique and skill execution, awareness of space and teammates, and many other
  factors including experience. Many of these can be practised away from the sports pitch."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087250Z"^^xsd:dateTime .

oakcurric:misconception-big-movements-better
  a curric:Misconception ;
  curric:statement "Big movements are always better."@en ;
  curric:correction """Sometimes more subtle, small emotions can be expressive in how they portray
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087307Z"^^xsd:dateTime .

oakcurric:misconception-need-properly-mapped-area-able
  a curric:Misconception ;
  curric:statement "You need a properly mapped area to be able to participate in orienteering."@en ;
  curric:correction """You can use an image from google maps or your own drawn map and still be able
  to participate in orienteering fully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087477Z"^^xsd:dateTime .

oakcurric:misconception-muscles-pull-push
  a curric:Misconception ;
  curric:statement "Muscles can pull and push."@en ;
  curric:correction """Muscles are only able to pull, they work in antagonistic pairs so one muscle
  can contract to create a movement whilst the other relaxes in opposition and then their
  roles are reversed to move back."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087482Z"^^xsd:dateTime .

oakcurric:misconception-dodge-static-position-good-place
  a curric:Misconception ;
  curric:statement """A dodge from a static position is a good place to showcase a dodge in
  isolation."""@en ;
  curric:correction """In game play, it is encouraged to be active and on the toes and thinking
  about a prelim movement before a change of direction or speed can be executed therefore
  encouraging this in early drills is advised."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087600Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-one-type-guidance
  a curric:Misconception ;
  curric:statement "Pupils may believe that only one type of guidance can be used at any time."@en ;
  curric:correction """Combinations of guidance can be very effective and are common in good
  coaching. For example, visual demonstrations are often combined with verbal explanations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087735Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-get-enough-distance
  a curric:Misconception ;
  curric:statement """Pupils often fail to get enough distance in the middle step phase of the
  triple jump and it is much shorter then the other two phases causing them to lose
  distance."""@en ;
  curric:correction """Help pupils to understand that ideally the distance covered in each phase
  will be similar. It might seem counterintuitive but the short step is often due to the hop
  stage being too long and we need to seek balance between all three stages."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087752Z"^^xsd:dateTime .

oakcurric:misconception-sport-activity-one-specific-type
  a curric:Misconception ;
  curric:statement "Each sport/activity has only one specific type of training suited to it."@en ;
  curric:correction """Performers in many activities can benefit from a variety of training types.
  For example, a marathon runner will mostly benefit from continuous training, however
  weight training could help to condition their muscles and avoid injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087802Z"^^xsd:dateTime .

oakcurric:misconception-improvising-negative-effect-dance-sequence
  a curric:Misconception ;
  curric:statement "Improvising can have a negative effect on a dance sequence."@en ;
  curric:correction """Improvising is actually a useful way to explore ideas, express emotions and
  develop new movements. It allows dancers to be creative and adapt their sequence, which
  can make the dance more interesting and personal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087831Z"^^xsd:dateTime .

oakcurric:misconception-compass-needed-outside
  a curric:Misconception ;
  curric:statement "A compass is only needed outside."@en ;
  curric:correction """A compass can be used anywhere to help us gain an understanding of
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087837Z"^^xsd:dateTime .

oakcurric:misconception-confusion-role-ligaments-tendons
  a curric:Misconception ;
  curric:statement "There can be confusion between the role of ligaments and tendons."@en ;
  curric:correction """Ligaments connect bone to bone to stabilise a joint whereas tendons attach
  muscle to bone to enable movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087854Z"^^xsd:dateTime .

oakcurric:misconception-skills-one-classification-other-e
  a curric:Misconception ;
  curric:statement """Skills must be one classification or the other, e.g., a skill is either gross
  or fine."""@en ;
  curric:correction """Ensure pupils understand a continua allows for skills to be classified
  anywhere along it, and that some skills may fall somewhere between two different
  classifications."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087879Z"^^xsd:dateTime .

oakcurric:misconception-drawing-levers-body-part-needs
  a curric:Misconception ;
  curric:statement "When drawing levers, the body part needs to be included."@en ;
  curric:correction "A lever will always be drawn using four shapes."@en ;
  dcterms:modified "2026-06-07T15:30:15.087887Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tire-latter-phases-100m
  a curric:Misconception ;
  curric:statement """Pupils will tire during the latter phases of a 100m sprint race and may
  withdraw their effort because fatigue is setting in and they expected to perform at
  maximal throughout."""@en ;
  curric:correction """Fatigue will always feature in the final stages if the athlete is giving it
  their best. Recognising this by remaining determined to finish and maintaining technique
  will result in the best possible time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088168Z"^^xsd:dateTime .

oakcurric:misconception-effort-lever-starts-belly-muscle
  a curric:Misconception ;
  curric:statement "The effort in a lever starts in the belly of the muscle."@en ;
  curric:correction """The effort from a muscle will start from the muscle insertion. The insertion
  is the tendon attached to the bone which that muscle moves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088419Z"^^xsd:dateTime .

oakcurric:misconception-either-naturally-good-movement-skills
  a curric:Misconception ;
  curric:statement """You are either naturally good at movement skills and sports, or you
  aren't."""@en ;
  curric:correction """Movement skills are learned and trained, just like maths and music. You need
  to practice and refine your technique to improve confidence and remember that growth
  spurts will temporarily affect coordination and this is perfectly normal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088565Z"^^xsd:dateTime .

oakcurric:misconception-weight-training-people-wanting-improve
  a curric:Misconception ;
  curric:statement "Weight training is only for people wanting to improve muscular strength."@en ;
  curric:correction """Weight training improves strength, muscular endurance, power and speed, as
  well as increasing bone density and joint stability while reducing the risk of injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088571Z"^^xsd:dateTime .

oakcurric:misconception-certain-sports-need-one-type
  a curric:Misconception ;
  curric:statement """Certain sports only need one type of component of fitness to be successful,
  e.g. 100m sprinter just needs speed."""@en ;
  curric:correction """Identify all the components of fitness that are useful for each athlete,
  determining why they are beneficial and justifying which is most important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088577Z"^^xsd:dateTime .

oakcurric:misconception-training-abdominals-6-pack-neglecting
  a curric:Misconception ;
  curric:statement "Training abdominals for a 6 pack but neglecting other core muscles."@en ;
  curric:correction """It is essential to balance training on all core muscles to maintain good
  posture, alignment and strength on anterior and posterior sides of the body."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088793Z"^^xsd:dateTime .

oakcurric:misconception-sport-activity-one-type-training
  a curric:Misconception ;
  curric:statement "Each sport or activity has only one type of training suited to it."@en ;
  curric:correction """Performers in most activities can benefit from a range of training types. A
  marathon runner would benefit most from continuous training; however, weight training and
  static stretching would also help with conditioning and avoiding injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089129Z"^^xsd:dateTime .

oakcurric:misconception-9-mark-answer-make-two
  a curric:Misconception ;
  curric:statement """For a 9 mark answer, I have to make two knowledge points, two applications and
  five AO3s."""@en ;
  curric:correction """9 mark answers are marked holistically using a levelled response grid. Level
  descriptors are applied to the overall response. A quantitative approach to answering
  these questions can be limiting to develop the breadth of knowledge and depth of AO3."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089182Z"^^xsd:dateTime .

oakcurric:misconception-rest-incorporated-types-training
  a curric:Misconception ;
  curric:statement "That rest is not incorporated into these types of training."@en ;
  curric:correction """All of these can be performed as a type of interval training and rest after
  each exercise / session is important to avoid the body getting injured."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089205Z"^^xsd:dateTime .

oakcurric:misconception-dribble-your-hands-feet
  a curric:Misconception ;
  curric:statement "You can only dribble with your hands or feet."@en ;
  curric:correction "You can also use an implement to dribble with."@en ;
  dcterms:modified "2026-06-07T15:30:15.089236Z"^^xsd:dateTime .

oakcurric:misconception-muscle-change-length-contracts
  a curric:Misconception ;
  curric:statement "A muscle will always change length when it contracts."@en ;
  curric:correction """A muscle pulls on a bone to create movement. However, occasionally, if the
  movement is static, the muscle is still contracting and under tension but not changing
  length. This is known as isometric muscle contraction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089377Z"^^xsd:dateTime .

oakcurric:misconception-maximum-repetitions-highest-priority-body
  a curric:Misconception ;
  curric:statement "Maximum repetitions is the highest priority in body weight exercises."@en ;
  curric:correction """Ensuring every exercise is completed with the correct technique to avoid
  injury and through the full range of movement is more important than the total
  repetitions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089397Z"^^xsd:dateTime .

oakcurric:misconception-many-misconceptions-diet-such-need
  a curric:Misconception ;
  curric:statement """There are many misconceptions about diet, such as the need to cut out
  carbohydrates or fat because they are seen as responsible for weight gain."""@en ;
  curric:correction """A balanced diet requires all nutrients because each has its own benefits to
  the body and health. Cutting any of them out completely will negatively impact overall
  health and performance in sport and physical activity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089435Z"^^xsd:dateTime .

oakcurric:misconception-students-think-sport-benefits-media
  a curric:Misconception ;
  curric:statement "Students might think that sport only benefits from media and sponsorship."@en ;
  curric:correction "Media and sponsorship also benefit from the sport."@en ;
  dcterms:modified "2026-06-07T15:30:15.089569Z"^^xsd:dateTime .

oakcurric:misconception-performance-sport-entirely-physiological-capabilities
  a curric:Misconception ;
  curric:statement """Performance in sport is entirely down to physiological capabilities such as
  speed, strength and technique."""@en ;
  curric:correction """Psychological factors such as confidence, motivation and learned behaviours
  from similar experiences in the past, have as much impact on performance in sport, as the
  level of skill that players have."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089787Z"^^xsd:dateTime .

oakcurric:misconception-types-feedback-confused-types-guidance
  a curric:Misconception ;
  curric:statement """Types of feedback are often confused with types of guidance from the previous
  lesson."""@en ;
  curric:correction """Ensure students can differentiate between guidance being information needed
  to understand how to perform a skill, and feedback being information about how well it is
  being performed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090009Z"^^xsd:dateTime .

oakcurric:misconception-students-incorrectly-assume-sportsmanship-gamemanship
  a curric:Misconception ;
  curric:statement """Students may incorrectly assume that sportsmanship and gamemanship are the
  same thing."""@en ;
  curric:correction """Sportsmanship is positively conforming to the rules and etiquette of the
  sport, whereas gamesmanship is more negative because a performer may bend the rules to
  gain advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090199Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-looking-ball-order-maintain
  a curric:Misconception ;
  curric:statement """When dribbling, you should always be looking at the ball in order to maintain
  control."""@en ;
  curric:correction """When dribbling, it is important to look up to see your surroundings, any
  opposition and where the space is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090476Z"^^xsd:dateTime .

oakcurric:misconception-acts-aggression-involve-violence-result
  a curric:Misconception ;
  curric:statement "All acts of aggression involve violence and are the result of anger."@en ;
  curric:correction """Some aggressive acts are controlled and are used to gain a performance
  advantage in sport. They are also within the rules of sports such as rugby and combat
  sports."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090811Z"^^xsd:dateTime .

oakcurric:misconception-running-hard-straight-line-way
  a curric:Misconception ;
  curric:statement """Just running a hard straight line is the only way to evade defenders and break
  the line."""@en ;
  curric:correction """While running a hard straight line can be effective, varying angles like
  overs and unders lines, footwork, and deception through dummying, are also crucial for
  evading defenders and breaking the line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091323Z"^^xsd:dateTime .

oakcurric:misconception-believing-one-factor-affect-participation
  a curric:Misconception ;
  curric:statement """Believing that only one factor can affect participation such as gender, when
  actually there are lots of factors that can affect participation in physical activity."""@en ;
  curric:correction """Some people may not face any barriers to participation, however some people
  may experience a number of different factors that affect whether they participate in a
  sport or not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091334Z"^^xsd:dateTime .

oakcurric:misconception-spin-passes-better-use
  a curric:Misconception ;
  curric:statement "Spin passes are always better to use."@en ;
  curric:correction """Short or soft pop passes can be more effective for quick, controlled
  distribution, especially in close quarters or wet conditions where accuracy and
  catchability matter more than speed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091384Z"^^xsd:dateTime .

oakcurric:misconception-best-thing-defender-tackle-panic
  a curric:Misconception ;
  curric:statement """The best thing to do when a defender is about to tackle you is to (panic) pass
  the ball."""@en ;
  curric:correction """Panic passing before contact in rugby often leads to turnovers, as the pass
  is rushed, inaccurate, and easier for the opposition to intercept or disrupt, therefore
  the best decision can sometimes be to keep hold of the ball and take it into contact."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091645Z"^^xsd:dateTime .

oakcurric:misconception-exercise-id-lose-weight
  a curric:Misconception ;
  curric:statement "\"If I did more exercise, I'd lose weight\""@en ;
  curric:correction """While exercise will increase energy expenditure and could help to achieve a
  calorie deficit needed to lose weight, \"you can't out train a bad diet.\" No matter how
  much exercise is performed, calorie intake is just as important to consider."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092022Z"^^xsd:dateTime .

oakcurric:misconception-running-quickly-tackle-ball-carrier
  a curric:Misconception ;
  curric:statement """Running up quickly to tackle the ball carrier is always the best thing
  to do."""@en ;
  curric:correction """Moving up quickly to tackle the ball carrier is only the right thing to do if
  the rest of your defensive line is with you, as you can leave gaps which makes it easy for
  the ball carrier to stop you and break up the pitch to score a try."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092365Z"^^xsd:dateTime .

oakcurric:misconception-pupils-measure-their-heart-rate
  a curric:Misconception ;
  curric:statement """Pupils may measure their heart rate incorrectly after completing the 150 steps
  for the Harvard step test."""@en ;
  curric:correction """Before starting the Harvard step test, allow pupils an opportunity to
  practice finding and measuring their heart rate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093052Z"^^xsd:dateTime .

oakcurric:misconception-index-finger-back-racket-try
  a curric:Misconception ;
  curric:statement """Having index finger up the back of the racket to try to control the racket in
  a pan handled grip."""@en ;
  curric:correction """Ensure all fingers are wrapped in a shake hands grip to unlock the ability to
  hit with more power even if it feels harder initially. Watch out for others making this
  mistake with their grip and correct them when you see it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093060Z"^^xsd:dateTime .

oakcurric:misconception-doubles-players-stand-left-right
  a curric:Misconception ;
  curric:statement """In doubles, players should stand on the left and right and just hit the ball
  on their side (like tennis or badminton)."""@en ;
  curric:correction """In doubles in table tennis, players have to hit alternate shots which means
  once you have hit the ball, you need to move out of the way so your partner can hit the
  next shot. Just standing on sides will make it difficult to play alternate shots."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093079Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-3-seconds-pass
  a curric:Misconception ;
  curric:statement "Pupils think they only have 3 seconds to pass the ball like in netball."@en ;
  curric:correction "In Korfball pupils have 4 seconds to pass the ball."@en ;
  dcterms:modified "2026-06-07T15:30:15.093085Z"^^xsd:dateTime .

oakcurric:misconception-common-mistake-made-classifying-skills
  a curric:Misconception ;
  curric:statement """A very common mistake made when classifying skills is to name a sport without
  the skill. For example, trying to classify 'rugby' rather than one of the many different
  skills within rugby."""@en ;
  curric:correction """Ensure pupils understand that specific skills are required and that they can
  name multiple examples of skills from different sports."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093226Z"^^xsd:dateTime .

oakcurric:misconception-peds-automatically-illegal-banned-substances
  a curric:Misconception ;
  curric:statement "All PEDs are automatically illegal and banned substances."@en ;
  curric:correction """Not all are instantly illegal or banned. For example, some stimulants are
  legal such as caffeine which is used by many as a stimulant. Beta blockers are available
  on prescription and therefore have certain restrictions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093571Z"^^xsd:dateTime .

oakcurric:misconception-believing-sponsorship-involves-financial-support
  a curric:Misconception ;
  curric:statement "Believing that sponsorship only involves financial support."@en ;
  curric:correction """Sponsorship can include financial support but also include equipment,
  clothing or facility provisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093579Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-korfball-contact-sport
  a curric:Misconception ;
  curric:statement "Pupils think that Korfball is a contact sport where you can push players."@en ;
  curric:correction """Korfball allows incidental contact that is natural movement, e.g. brushing
  shoulders and close marking, however pushing, holding or blocking is not allowed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093810Z"^^xsd:dateTime .

oakcurric:misconception-team-hit-kin-ball-without
  a curric:Misconception ;
  curric:statement "A team hit the kin-ball without properly nominating a team to defend."@en ;
  curric:correction """Each hitting team must shout \"Omnikin\" followed by the colour of the bib
  worn by the nominated team before hitting the kin-ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093816Z"^^xsd:dateTime .

oakcurric:misconception-beginning-sprint-performance-pupils-rise
  a curric:Misconception ;
  curric:statement """At the beginning of a sprint performance, pupils will rise up into an upright
  position as soon as possible."""@en ;
  curric:correction """An effective drive phase of sprinting sees the body gradually rise up over
  the first 20m before assuming an upright position. Trying to get upright too soon after
  starting will hinder acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093833Z"^^xsd:dateTime .

oakcurric:misconception-thinking-physically-fit-means-someone
  a curric:Misconception ;
  curric:statement "Thinking that being physically fit means that someone is healthy."@en ;
  curric:correction """It is possible to be physically fit but unhealthy. It is essential to
  consider social and emotional benefits/aspects of health as well as strength,
  cardiovascular endurance etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093852Z"^^xsd:dateTime .

oakcurric:misconception-power-important-accuracy
  a curric:Misconception ;
  curric:statement "Power is more important than accuracy."@en ;
  curric:correction """Accuracy is crucial to keep the ball within possession of your team so you
  have more opportunities to score."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093863Z"^^xsd:dateTime .

oakcurric:misconception-personal-exercise-programmes-used-people
  a curric:Misconception ;
  curric:statement "Personal exercise programmes are only used by people that play sport."@en ;
  curric:correction """Perosnal exercise programmes can be used by everyone to increase physical
  activity levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093888Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performance-determined-many
  a curric:Misconception ;
  curric:statement """Pupils think that performance is only determined by how many tries you
  scored."""@en ;
  curric:correction """A player can have a strong impact without getting a try by helping their team
  keep possession, organise defence or create space for others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093986Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-interval-training-completed
  a curric:Misconception ;
  curric:statement """Pupils think interval training is completed to increase speed and
  power only."""@en ;
  curric:correction """The rest intervals are really good to enhance stamina and cardiovascular
  endurance. The intense workout does develop power especially in the lower body muscles
  which supports injury prevention when running."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094003Z"^^xsd:dateTime .

oakcurric:misconception-students-think-benefits-exercise-physical
  a curric:Misconception ;
  curric:statement "Students think the only benefits to exercise are physical benefits."@en ;
  curric:correction """Explain the importance of social and emotional benefits too, particularly for
  participants such as elderly people."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094038Z"^^xsd:dateTime .

oakcurric:misconception-students-think-physically-fit-means
  a curric:Misconception ;
  curric:statement """Students think that being physically fit means they are automatically
  healthy."""@en ;
  curric:correction """Explain the importance of social and emotional benefits too, particularly for
  participants such as elderly people."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094124Z"^^xsd:dateTime .

oakcurric:misconception-believing-sedentary-lifestyle-affects-physical
  a curric:Misconception ;
  curric:statement """Believing that a sedentary lifestyle only affects physical health through
  weight gain."""@en ;
  curric:correction """A sedentary lifestyle can have a negative impact on social and emotional
  health too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094171Z"^^xsd:dateTime .

oakcurric:misconception-believing-individuals-fit-exclusively-one
  a curric:Misconception ;
  curric:statement """Believing that individuals fit exclusively into one somatotype category rather
  than having a mix of characteristics."""@en ;
  curric:correction """Individuals can have a mix of characteristics from different somatotypes but
  can also change their somatotype depending on their lifestyle choices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094361Z"^^xsd:dateTime .

oakcurric:misconception-pupils-expend-far-much-energy
  a curric:Misconception ;
  curric:statement """Pupils expend far too much energy by sprint starting instead of finding their
  race pace, leading them to tire in the second half of the race."""@en ;
  curric:correction """Pupils should focus on finding their race pace, not getting over excited at
  the start line, beginning too fast or being influenced by others who do. Ideally, the
  second half of the race is completed quicker than the first (called a negative split)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094560Z"^^xsd:dateTime .

oakcurric:misconception-exclusive-focus-winning-limits-satisfaction
  a curric:Misconception ;
  curric:statement "Exclusive focus on winning limits satisfaction and enjoyment."@en ;
  curric:correction """Games like Kubb should be as much about the enjoyable social experience and
  finding ways to support each other as well as demonstrating honesty and fair play as
  winning the match."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094573Z"^^xsd:dateTime .

oakcurric:misconception-certainly-misconception-many-pupils-ball
  a curric:Misconception ;
  curric:statement """There is certainly a misconception with many pupils that the ball should be
  hit out into the field whenever possible, exacerbated by the need to do this in many other
  striking and fielding games."""@en ;
  curric:correction """Pupils should understand on occasions in cricket, blocking or leaving the
  ball are actually preferable shots to play, rather than shots with a higher risk of
  getting out. It requires a different mindset to a lot of other striking and fielding
  games."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094579Z"^^xsd:dateTime .

oakcurric:misconception-failure-address-parts-question
  a curric:Misconception ;
  curric:statement "Failure to address all parts of the question."@en ;
  curric:correction """The 6 mark extended answer question always requires knowledge from that exam
  paper (component) and the other exam paper (component) and practical application."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094752Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-spike-performed-hand
  a curric:Misconception ;
  curric:statement "Pupils think that a spike is performed with the hand in a fist shape."@en ;
  curric:correction """A spike is performed with an open hand with the fingers together and the ball
  contacting the centre of the palm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095284Z"^^xsd:dateTime .

oakcurric:misconception-many-pupils-softball-totally-new
  a curric:Misconception ;
  curric:statement """For many pupils, softball may be a totally new game. It's a game with a lot of
  different rules from the striking and fielding games they will already know such as
  rounders and cricket."""@en ;
  curric:correction """Learning the intricacies, language and rules of the game in the first lesson
  and playing a version which includes most of the main rules, will allow pupils to relate
  to, and see sense in what they learn later in the unit, to the game itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095289Z"^^xsd:dateTime .

oakcurric:misconception-pupils-throw-shot-leading-elbow
  a curric:Misconception ;
  curric:statement """Pupils often throw the shot by leading with the elbow rather than push it with
  the elbow following behind the shot, which can sometimes lead to pain and injury,
  especially to the wrist."""@en ;
  curric:correction """Emphasise the need to push the shot by extending the arm and not trying to
  bring the shot behind the head to throw. Replace shot with lighter weighted balls
  (medicine) if necessary to avoid injury while the technique is being learned."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095295Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-best-thing-defender
  a curric:Misconception ;
  curric:statement """Pupils think the best thing to do when a defender is about to tackle you is to
  (panic) pass the ball."""@en ;
  curric:correction """Panic passing before contact in rugby often leads to turnovers, as the pass
  is rushed, inaccurate, and easier for the opposition to intercept or disrupt, therefore
  the best decision can sometimes be to keep hold of the ball and take it into contact."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095306Z"^^xsd:dateTime .

oakcurric:misconception-running-type-interval-training
  a curric:Misconception ;
  curric:statement "Running is the only type of interval training."@en ;
  curric:correction """Interval training can be done with any activity as long as it involves high
  intesity work followed by a rest period."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095439Z"^^xsd:dateTime .

oakcurric:misconception-tiring-sprint-whole-course
  a curric:Misconception ;
  curric:statement "It is too tiring to sprint the whole course."@en ;
  curric:correction """Strategise and plan who will take on what role and when to spread more
  difficult actions/moments among the team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095451Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-deception-tricking-your
  a curric:Misconception ;
  curric:statement """Pupils think that deception is only about tricking your opponent with flashy
  shots (e.g. through the legs)."""@en ;
  curric:correction """Effective deception is about subtle changes in timing, swing and shot
  placement. It doesn’t always require exaggerated fakes - small delays or slight
  adjustments can be just as effective in disrupting your opponent’s rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095456Z"^^xsd:dateTime .

oakcurric:misconception-progress-made-same-rate
  a curric:Misconception ;
  curric:statement "Progress will always be made at the same rate."@en ;
  curric:correction """Sometimes different factors affect level of progress (sleep, hormones,
  nutrition) but also training results can plateau and changes to training are needed to
  continue to push the body to adapt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095473Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-yin-yoga-boring
  a curric:Misconception ;
  curric:statement "Pupils think yin yoga is boring."@en ;
  curric:correction """Yin Yoga provides a chance to deeply connect with your body and mind. It can
  be a deeply meditative practice, allowing for self-reflection and stress relief. For many,
  it’s an opportunity to slow down in an otherwise fast-paced life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096228Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-yoga-slow-steady
  a curric:Misconception ;
  curric:statement """Pupils think that yoga is always slow and steady, and is only for
  relaxation."""@en ;
  curric:correction """Yoga can be both calming and energising, depending on the style and intention
  of the practice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096234Z"^^xsd:dateTime .

oakcurric:misconception-pupils-grip-discus-wrapping-their
  a curric:Misconception ;
  curric:statement """Pupils will grip the discus by wrapping their fingers and thumb around the
  edges to prevent it from slipping out or dropping it."""@en ;
  curric:correction """The discus should sit on the palm of the hand with the edge of the discus
  sitting in the last joint crease of the fingers (if you turn the hand over to the top, it
  should fall out). The thumb should not grip the edge at all."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096240Z"^^xsd:dateTime .

oakcurric:misconception-pupils-keep-their-feet-planted
  a curric:Misconception ;
  curric:statement "Pupils keep their feet planted on the ground after taking a shot."@en ;
  curric:correction """Always encourage a release of a shot, moving up onto the toes, so the player
  is in a suitable position to move forward for a rebound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096245Z"^^xsd:dateTime .

oakcurric:misconception-order-get-highest-marks-gcse
  a curric:Misconception ;
  curric:statement """In order to get the highest marks in GCSE PE moderation I need to be very good
  at all the specialist skills in rugby."""@en ;
  curric:correction """Rugby allows for different body shapes that suit specific positions, meaning
  players do not need to master every specialist skill. Forwards focus on scrums, lineouts
  and physical contests, while backs excel in speed, passing and kicking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096699Z"^^xsd:dateTime .

oakcurric:misconception-fitness-testing-brings-improvements-components
  a curric:Misconception ;
  curric:statement "Fitness testing brings about improvements in components of fitness."@en ;
  curric:correction """Training methods bring about improvement in fitness. Fitness testing is
  merely about identifying the strengths and weaknesses of a fitness component so the right
  training method can be allocated and used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096705Z"^^xsd:dateTime .

oakcurric:misconception-pupils-perform-movements-fast-slow
  a curric:Misconception ;
  curric:statement """Pupils perform movements too fast or too slow which disrupts the flow of the
  kata."""@en ;
  curric:correction """Performing Chon-Ji at a consistent tempo and speed helps to develop
  cardiovascular and muscular endurance. It enhances mental focus and breath control. The
  different speeds simulate real combat situations which will vary in speed and
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096710Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-couch-5k-merely
  a curric:Misconception ;
  curric:statement """Pupils think couch to 5k is merely to start running and be able to run 5k
  immediately."""@en ;
  curric:correction """5k is a popular distance due to the park run (a global brand). However, couch
  to 5k is a beginner's approach to running using a gradual training plan, over 9 weeks from
  walking to running."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096716Z"^^xsd:dateTime .

oakcurric:misconception-underestimating-amount-water-body-needs
  a curric:Misconception ;
  curric:statement """Underestimating the amount of water the body needs throughout the day (not
  just during exercise) to maintain hydration."""@en ;
  curric:correction """The general recommendation is 2 litres of water per day, however when
  training, more should be consumed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097240Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-defensive-player-catch
  a curric:Misconception ;
  curric:statement """Pupils think a defensive player must catch the ball outright on initial
  contact from a shot."""@en ;
  curric:correction """It is sometimes more effective to bump a rebound up in the air for a teammate
  to catch, but it does then count as a pass. Whereas if you catch it cleanly or catch your
  own rebound, it doesn't use up one of your passes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097245Z"^^xsd:dateTime .

oakcurric:misconception-tidal-volume-amount-air-breathed
  a curric:Misconception ;
  curric:statement """Tidal volume is the amount of air breathed in and out per breath and the lungs
  completely empty of air when we expire."""@en ;
  curric:correction """Tidal volume is the volume of air breathed in or out per breadth and it
  increases during exercise to enable more air and hence exchange of oxygen and carbon
  dioxide to occur. A residual volume of air always remains in the lungs to keep them
  inflated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097766Z"^^xsd:dateTime .

oakcurric:misconception-oxygen-breathe-used-muscles
  a curric:Misconception ;
  curric:statement "All of the oxygen we breathe in is used by the muscles."@en ;
  curric:correction """The body only extracts a small percentage of the oxygen in each breath so it
  is important we keep breathing during and after exercise. You can only moves gases to an
  area of lower concentration so once that is equal diffusion stops."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098037Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-simple-ball-handling
  a curric:Misconception ;
  curric:statement "Pupils make simple ball handling mistakes due to rushing."@en ;
  curric:correction """You lose possession if the ball is dropped, so whilst you need to make a pass
  within 3 seconds, it is essential not to make rushed decisions for passing and focus on
  catching the ball carefully with both hands before making your next move."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098454Z"^^xsd:dateTime .

oakcurric:misconception-long-answer-questions-better-recall
  a curric:Misconception ;
  curric:statement """In long answer questions, it is better to recall as much of the topic as
  possible."""@en ;
  curric:correction """It is important to recall the specific knowledge relevant to the question,
  but then you must apply and develop that knowledge based on the command word. Simply
  recalling knowledge will only hit AO1 marks awarded."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098541Z"^^xsd:dateTime .

oakcurric:misconception-arteries-carry-oxygenated-blood
  a curric:Misconception ;
  curric:statement "Arteries always carry oxygenated blood."@en ;
  curric:correction """The pulmonary artery is the only artery in the body that carries deoxygenated
  blood as it is pumped back to the lungs to be re-oxygenated. Consequently, the pulmonary
  vein is the only vein in the body that carries oxygenated blood."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099038Z"^^xsd:dateTime .

oakcurric:misconception-pupils-take-approach-straight-towards
  a curric:Misconception ;
  curric:statement """Pupils take an approach straight towards the bar which is not conducive to
  performing the Fosbury flop technique and maximising height jumped."""@en ;
  curric:correction """Pupils should take a curved run up which is J-shaped and will allow them to
  perform the technique required to gain the most height in their jump. The teacher can
  guide them to this through the activities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099066Z"^^xsd:dateTime .

oakcurric:misconception-getting-position-hitting-shot
  a curric:Misconception ;
  curric:statement "Getting out of position after hitting a shot."@en ;
  curric:correction """Learning to lunge and recover quickly to the middle of the court requires
  explosive strength/power but avoids exposing space for your opposition to attack."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099073Z"^^xsd:dateTime .

oakcurric:misconception-retrograde-term-used-dance
  a curric:Misconception ;
  curric:statement "Retrograde is a term only used in dance."@en ;
  curric:correction """Retrograde is a term used in many artforms, it is particularly prevalent in
  music and films."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099084Z"^^xsd:dateTime .

oakcurric:misconception-essential-attack-times
  a curric:Misconception ;
  curric:statement "It is essential to attack at all times."@en ;
  curric:correction """Often it can be just as effective to consistently get the shuttle back into
  play, keeping the shuttle in and forcing your opposition to make mistakes by varying pace
  and placement on the court."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099301Z"^^xsd:dateTime .

oakcurric:misconception-pupils-experienced-ignore-contribution-less
  a curric:Misconception ;
  curric:statement """Pupils who are more experienced may ignore the contribution of less able
  pupils, or even belittle or berate them when they don't contribute well to the team."""@en ;
  curric:correction """Encourage pupils to use their knowledge to offer feedback which can help
  bring about an improvement, emphasising that in team games, an individual cannot and
  should not perform all roles or carry the team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099323Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-self-defence-like
  a curric:Misconception ;
  curric:statement "Pupils think that self-defence is just like fighting."@en ;
  curric:correction """Self-defence focuses on escape and de-escalation. It is about avoiding harm
  and getting away safely."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099329Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-like-dancing
  a curric:Misconception ;
  curric:statement "Pupils don't like dancing."@en ;
  curric:correction """Whilst no activity is attractive to everyone, most pupils enjoy dance when
  the tasks are open ended. This gives them the opportunity to input their own ideas and
  perform actions thay are comfortable with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099340Z"^^xsd:dateTime .

oakcurric:misconception-dance-styles-set-change
  a curric:Misconception ;
  curric:statement "Dance styles are set and never change."@en ;
  curric:correction """Dance styles continually evolve. When studying dances from history or other
  places, we are able to pinpoint key attributes that were relevant at a point in time, they
  may remain or they may be adapted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101165Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-short-associated-height
  a curric:Misconception ;
  curric:statement "Pupils think a short is associated with the height of a shot."@en ;
  curric:correction """A short is when a shot misses the rebound frame completely. It results in a
  fault and change of possession with the defenders restarting play from behind the
  baseline."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101171Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-same-type-shot
  a curric:Misconception ;
  curric:statement "Pupils always use the same type of shot."@en ;
  curric:correction """Just throwing the ball harder at the rebound frame increases the risk of a
  fault from failing to hit the target but is also very predictable for the opposition.
  Therefore vary your angle, speed and deception applied when shooting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101177Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-serving-speed-important
  a curric:Misconception ;
  curric:statement """Pupils think serving speed is the most important factor to an
  effective serve."""@en ;
  curric:correction "The reality of a successful serve is placement and consistency."@en ;
  dcterms:modified "2026-06-07T15:30:15.101185Z"^^xsd:dateTime .

oakcurric:misconception-gaseous-exchange-involves-oxygen
  a curric:Misconception ;
  curric:statement "Gaseous exchange only involves oxygen."@en ;
  curric:correction """Gaseous exchange is when oxygen and carbon dioxide diffuse between the lungs
  and the blood, and then between the blood and muscle tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101466Z"^^xsd:dateTime .

oakcurric:misconception-everyone-needs-exactly-same-nutritional
  a curric:Misconception ;
  curric:statement "Everyone needs exactly the same nutritional plan."@en ;
  curric:correction """Different people have different nutritional needs, at different times in
  life, especially when training for different activities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102143Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-bump-shot-needs
  a curric:Misconception ;
  curric:statement "Pupils think a bump shot needs the hands to come together to make a fist."@en ;
  curric:correction """The correct technique is to place the back of one hand in the palm of the
  other hand with the arms extended and the elbows locked creating a platform with the
  forearms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102157Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-hit-ball
  a curric:Misconception ;
  curric:statement "Pupils think they need to hit the ball hard to slice effectively."@en ;
  curric:correction """Pushing and slicing require a light touch and controlled movements, not
  power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102163Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-spin-passes-better
  a curric:Misconception ;
  curric:statement "Pupils think that spin passes are always better to use."@en ;
  curric:correction """Short or soft pop passes can be more effective for quick, controlled
  distribution, especially in close quarters or wet conditions where accuracy and
  catchability matter more than speed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102172Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gcse-assessment-their
  a curric:Misconception ;
  curric:statement """Pupils think that for GCSE assessment. their defence is looked at
  individually."""@en ;
  curric:correction """In the fully competitive game, part of the assessment is showing an
  understanding of the different types of defence and which would is best to use depending
  on the situation of the game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102179Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-permitted-jump-free
  a curric:Misconception ;
  curric:statement "Pupils think they are not permitted to jump on a free throw."@en ;
  curric:correction """There is no rule stating a jump is not permitted, however the feet can not
  pass the free throw line so players chose to keep their feet planted on the ground."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102184Z"^^xsd:dateTime .

oakcurric:misconception-starting-multi-stage-fitness-test
  a curric:Misconception ;
  curric:statement "Starting the multi stage fitness test too quickly."@en ;
  curric:correction """It can be beneficial to start the multi stage fitness test at fast walking
  pace to conserve energy for the faster levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102358Z"^^xsd:dateTime .

oakcurric:misconception-am-qualified-first-aider-cant
  a curric:Misconception ;
  curric:statement "I am not a qualified first aider so I can't help someone in need."@en ;
  curric:correction """Basic knowledge can allow you to help with minor injuries. Knowing what to do
  in certain circumstances means that you can support and hopefully make a difference for
  any more major situations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102394Z"^^xsd:dateTime .

oakcurric:misconception-pilates-easy-develops-flexibility
  a curric:Misconception ;
  curric:statement "Pilates is easy and only develops flexibility."@en ;
  curric:correction """Pilates builds core strength, stability and muscular endurance, and can be
  challenging for all types of athletes. It’s not just stretching, it’s a full-body workout
  that improves posture, balance and overall strength."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102737Z"^^xsd:dateTime .

oakcurric:misconception-dancers-moving-time
  a curric:Misconception ;
  curric:statement "Dancers should be moving all the time."@en ;
  curric:correction """Stillness is one of the five basic actions. Similar to punctuation in a
  sentence, it can help to bring meaning and context as well as highlight important moments.
  Stillness can include brief pauses as well as prolonged periods of inactivity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102748Z"^^xsd:dateTime .

oakcurric:misconception-counterbalances-symmetrical
  a curric:Misconception ;
  curric:statement "Counterbalances are always symmetrical."@en ;
  curric:correction """Counterbalances can involve the same action as a partner but these can be
  varied by level, direction of size. Counterbalances can also use contrasting body parts to
  connect, e.g. the hand of one dancer pressing against the shoulder of their partner."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102754Z"^^xsd:dateTime .

oakcurric:misconception-believed-certain-sports-require-one
  a curric:Misconception ;
  curric:statement """It might be believed that certain sports only require one type of practice
  structure."""@en ;
  curric:correction """Practice structures vary depending on the skills being practiced and the
  level of ability. Two different skills from within the same sport might benefit from
  different practice structures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103060Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-get-penalty-stroke
  a curric:Misconception ;
  curric:statement "Pupils think we only get a penalty stroke if we break a rule."@en ;
  curric:correction """Explain to pupils that a a penalty stroke is an extra stroke added to your
  score as a result of breaking a rule or hitting the ball into certain areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103100Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-defence-solo-effort
  a curric:Misconception ;
  curric:statement """Pupils think defence is a solo effort and only needed when marking the player
  with the ball."""@en ;
  curric:correction """Individual defensive skills are crucial, however defending as a cohesive unit
  leads to the attacking team being denied space and vision to move the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103157Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stay-upright-while-kneeling
  a curric:Misconception ;
  curric:statement """Pupils stay upright while kneeling in the tripod position, meaning the ball is
  too high for hitting."""@en ;
  curric:correction """It is easier to hit the kin-ball when it is lower down, so be sure to bend
  forward in the kneeling position."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103221Z"^^xsd:dateTime .

oakcurric:misconception-proper-cool-speeds-reduction-heart
  a curric:Misconception ;
  curric:statement """A proper cool down speeds up reduction in heart rate after exercise and
  prevents muscle soreness."""@en ;
  curric:correction """An active cool down actually prolongs the elevated heart and breathing rate
  after exercise to help flush fresh oxygen through the muscles and improve recovery.
  However, DOMS may still occur due to microtears in muscles if training was intense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103328Z"^^xsd:dateTime .

oakcurric:misconception-many-pupils-consider-adaptations-conditions
  a curric:Misconception ;
  curric:statement """Many pupils do not consider how adaptations and conditions can make games more
  enjoyable for different people, preferring to play the full version of a game even when it
  might be a struggle."""@en ;
  curric:correction """Helping pupils to be conscious of other people's motivations and understand
  how adaptations can make the game more accessible and enjoyable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103334Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-jump-backwards
  a curric:Misconception ;
  curric:statement """Pupils think you need to jump backwards to land in a back landing
  position."""@en ;
  curric:correction """A back landing can feel quite scary. Jumping backwards can lead to injury and
  a back landing should only be attempted if your teacher has approved and is confident you
  will not jump backwards and will push the hips forwards when jumping upwards."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103607Z"^^xsd:dateTime .

oakcurric:misconception-pupils-choose-play-one-player
  a curric:Misconception ;
  curric:statement """Pupils choose to play with one player at the net and their partner at the back
  of the court."""@en ;
  curric:correction """Splitting front and back leaves a huge gap diagonally through your court that
  the opposition can exploit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103619Z"^^xsd:dateTime .

oakcurric:misconception-expecting-progress-show-huge-improvements
  a curric:Misconception ;
  curric:statement "Expecting progress to show huge improvements."@en ;
  curric:correction """different factors could affect the level of progress including frequency,
  effort, sleep and nutrition. Further training could show more improvement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103635Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-defenders-screen-attackers
  a curric:Misconception ;
  curric:statement "Pupils think it is only defenders that screen attackers."@en ;
  curric:correction """Attackers should also screen defenders to allow other attacking teammates to
  run into the space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103641Z"^^xsd:dateTime .

oakcurric:misconception-need-strong-throw-good-darts
  a curric:Misconception ;
  curric:statement "You need a strong throw to be good at darts."@en ;
  curric:correction """Darts is more about control and accuracy than power. A smooth, balanced
  stance and consistent release are more important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103649Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-fielder-needs-stationed
  a curric:Misconception ;
  curric:statement """Pupils often assume that a fielder needs to be stationed on each base and that
  it is the job of other fielders to get the ball to them while they remain with their base."""@en ;
  curric:correction """Use the third section of this lesson to introduce the idea that fielding
  positions should be fluid and that infielders, especially, should always be alert to the
  idea of leaving bases or covering other bases."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103655Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-deoxygenated-blood-muscle
  a curric:Misconception ;
  curric:statement """Pupils think deoxygenated blood at the muscle tissue goes straight to the
  lungs rather than via the heart first (i.e. they forget they need to go through the heart
  twice)."""@en ;
  curric:correction """Remind pupils the heart is a double circulatory pump consisting of a
  pulmonary and a systemic loop. Without this, blood pressure would be too low on return
  from the legs to efficiently get blood to the lungs for oxygenation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103663Z"^^xsd:dateTime .

oakcurric:misconception-drop-shots-net-shots-two
  a curric:Misconception ;
  curric:statement "Drop shots and net shots are two terms for the same thing."@en ;
  curric:correction """Whilst both shots play the shuttle just over the net, a drop shot is hit from
  the back of the court whereas a net shot is hit from the front of the court close to the
  net."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103681Z"^^xsd:dateTime .

oakcurric:misconception-thinking-flexibility-useful-gymnasts-dancers
  a curric:Misconception ;
  curric:statement "Thinking that flexibility is only useful for gymnasts or dancers."@en ;
  curric:correction """Discuss wider examples such as hurdlers, footballers and swimmers that will
  also benefit from high levels of flexibility."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103717Z"^^xsd:dateTime .

oakcurric:misconception-progressive-overload-applies-weight-training
  a curric:Misconception ;
  curric:statement "Progressive overload only applies when weight training."@en ;
  curric:correction """Gradually increasing frequency, intensity and time or altering the type of
  exercise through the manipulation of different training methods can develop all fitness
  components. Clear examples must be shared across activities other than weight training."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103767Z"^^xsd:dateTime .

oakcurric:misconception-many-young-batters-fail-move
  a curric:Misconception ;
  curric:statement """Many young batters fail to move their feet when batting, instead they try to
  contort their bodies to deal with all sorts of line and length deliveries with little
  success."""@en ;
  curric:correction """Through practice, pupils can learn how to move their feet in response to
  different pitches of delivery. With short deliveries moving weight on to the back foot and
  changing foot position allows for pull, hook and cut shots."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105069Z"^^xsd:dateTime .

oakcurric:misconception-communication-ball-hit-inconsistent-cricket
  a curric:Misconception ;
  curric:statement """Communication after the ball is hit can be inconsistent in cricket. Having
  four players to coordinate means the need to communicate clearly about how many runs to
  make is even more important."""@en ;
  curric:correction """Allow pupils time to strategise about how they will communicate after the
  ball is hit. For example, they may nominate a captain to make all calls or decide that the
  batter who hit the ball makes the call."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105077Z"^^xsd:dateTime .

oakcurric:misconception-golf-etiquette-polite
  a curric:Misconception ;
  curric:statement "Golf etiquette is just about being polite."@en ;
  curric:correction """Explain to pupils that golf etiquette is about courtesy, consideration and
  respect for other players, the course and the game itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105089Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gcse-assessment-shooting
  a curric:Misconception ;
  curric:statement """Pupils think that for GCSE assessment, shooting is only required in isolation
  to demonstrate the correct techniques."""@en ;
  curric:correction """Shooting needs to be seen in progressive and conditioned practices to
  showcase the technique when faced with decision making. The assessment will be based on
  the choice of shot or drive to the basket depending on the position of the defenders."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105097Z"^^xsd:dateTime .

oakcurric:misconception-arousal-better-perform
  a curric:Misconception ;
  curric:statement "The more arousal you have, the better you perform."@en ;
  curric:correction """The inverted-U theory recognises that after an optimal level of arousal,
  performance will deteriorate with any further heightening of arousal levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105207Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-best-pass-difficult
  a curric:Misconception ;
  curric:statement "Pupils think that it is always best to pass when in a difficult situation."@en ;
  curric:correction """Retaining possession through accurate kicks can at times make more yards than
  passing and being tagged."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105313Z"^^xsd:dateTime .

oakcurric:misconception-matching-similar-incorrect-photo-result
  a curric:Misconception ;
  curric:statement "Matching a similar and incorrect photo as a result of rushing."@en ;
  curric:correction """During photo orienteering, it is important to take your time and look at
  details carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105341Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gcse-assessment-passing
  a curric:Misconception ;
  curric:statement """Pupils think that GCSE assessment for passing is just looking at the
  techniques in isolation."""@en ;
  curric:correction """Passing needs to be seen in progressive and conditioned practices to showcase
  the technique when faced with opposition and decision making."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105349Z"^^xsd:dateTime .

oakcurric:misconception-player-pivot-part-footwork-create
  a curric:Misconception ;
  curric:statement """A player has to pivot as part of footwork to create space after landing when
  the ball has been caught."""@en ;
  curric:correction """Although a pivot may be needed to create space and is permitted, it is better
  to turn in the air when reveiving the ball so landing is the right position for the next
  pass."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105362Z"^^xsd:dateTime .

oakcurric:misconception-pupils-perform-middle-distances-jogging
  a curric:Misconception ;
  curric:statement """Pupils may perform middle distances by jogging the majority to conserve energy
  and putting a sprint in at the end. This often leads to pupils wishing they had put more
  effort into the initial stages."""@en ;
  curric:correction """A well performed 800m requires a fine line between holding back some energy
  for the finish but also performing at around 80-90% maximum effort for around the first
  600m."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105393Z"^^xsd:dateTime .

oakcurric:misconception-rugby-scrum-push-like-union
  a curric:Misconception ;
  curric:statement "In a rugby scrum you have to push (like in union)."@en ;
  curric:correction """Because the scrum half can throw the ball in at angle that is advantageous to
  their team, there is not much point pushing. It's better to save energy to get back to
  defend but if the other side are being lazy, it might be beneficial to push."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105417Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-fully-commit-tackle
  a curric:Misconception ;
  curric:statement """Pupils fail to fully commit to a tackle which allows players to break free and
  score."""@en ;
  curric:correction """Defenders must fully commit to tackle the ball carrier and keep hold until
  they are on the ground to avoid giving the opposition an overlap or charge through scoring
  opportunity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105456Z"^^xsd:dateTime .

oakcurric:misconception-individual-objects-cant-used-make
  a curric:Misconception ;
  curric:statement "Individual objects can't be used to make art."@en ;
  curric:correction """If we collect a range of materials in contrasting colours and various
  textures, we can combine them to produce a nice composition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106093Z"^^xsd:dateTime .

oakcurric:misconception-sitting-volleyball-people-disabilities
  a curric:Misconception ;
  curric:statement "Sitting volleyball is only for people with disabilities."@en ;
  curric:correction """Sitting volleyball is a Paralympic sport, however it is an inclusive and
  adapted sport that anyone can play regardless of ability. Players have to move quickly
  around the court using their upper bodies frequently in a seated position."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106099Z"^^xsd:dateTime .

oakcurric:misconception-one-type-strength-usually-associate
  a curric:Misconception ;
  curric:statement """There is only one type of strength which we usually associate with lifting
  heavy weights."""@en ;
  curric:correction "There are four types of strength: maximal, dynamic, static and explosive."@en ;
  dcterms:modified "2026-06-07T15:30:15.106339Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-cool-sweat-shows
  a curric:Misconception ;
  curric:statement """Pupils think it is not cool to sweat or that it shows they are working too
  hard or are unfit."""@en ;
  curric:correction """The sweating response is essential to homeostasis and keeping your core body
  temperature stable. An increased sweating response is actually an indicator of better
  aerobic fitness and is required when seeking a cardiovascular benefit from training."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107127Z"^^xsd:dateTime .

oakcurric:misconception-6-mark-answer-make-one
  a curric:Misconception ;
  curric:statement """For a 6 mark answer, I have to make one knowledge point, two applications and
  three AO3's."""@en ;
  curric:correction """6 mark answers are marked holistically using a levelled response grid. Level
  descriptors are applied to the overall response. A quantative approach to answering these
  questions can be limiting to develop the breadth of knowledge and depth of AO3."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107356Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stand-straight-against-wall
  a curric:Misconception ;
  curric:statement """Pupils do not stand straight against the wall with their arm touching the wall
  to gain the initial mark for the vertical jump test."""@en ;
  curric:correction """It is important for reliable results when measuring power that the arm is
  against the wall and outreached as high as possible, when taking the initial measurement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107361Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-resistance-bands-make
  a curric:Misconception ;
  curric:statement "Pupils think that resistance bands make exercises easier"@en ;
  curric:correction """Resistance bands actually add extra tension, making movements more
  challenging. They engage muscles throughout the entire movement, improving strength,
  control and stability more effectively than bodyweight exercises alone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107373Z"^^xsd:dateTime .

oakcurric:misconception-ba-dum-heart-beat-represents
  a curric:Misconception ;
  curric:statement """The ba-dum of the heart beat represents the left then right side
  contracting."""@en ;
  curric:correction """The heart relaxes (diastole) to fill with blood then first phase of
  contraction squeezes blood from the top two atria down into the ventricles before the
  valves close off and then the second phase of contraction squeezes blood out of the
  ventricles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107838Z"^^xsd:dateTime .

oakcurric:misconception-pupils-draw-heart-rate-zero
  a curric:Misconception ;
  curric:statement "Pupils often draw heart rate down to zero on a line graph."@en ;
  curric:correction """Even at rest your heart is still beating, on average 72 beats per minute, to
  ensure blood is always circulating around the body to keep you alive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108072Z"^^xsd:dateTime .

oakcurric:misconception-hitting-hard-fast-highest-priority
  a curric:Misconception ;
  curric:statement "Hitting it hard and fast is the highest priority."@en ;
  curric:correction """It is more effective to vary the pace, angle and positioning of where you hit
  the shuttle to create opportunities to win the point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108815Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-best-option-move-ball
  a curric:Misconception ;
  curric:statement "Dribbling is always the best option to move with the ball."@en ;
  curric:correction """While dribbling can be helpful to gain ground up the court, it can slow down
  the game, whereas passing can often be faster and more efficient at breaking through a
  defence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108820Z"^^xsd:dateTime .

oakcurric:misconception-losing-team-automatically-affects-score
  a curric:Misconception ;
  curric:statement """If you are on the losing team, it automatically affects the score you get for
  your handball assessment."""@en ;
  curric:correction """For your GCSE PE moderation, you are measured against how well you can
  demonstrate certain skills, tactics and decision making, not the final score of your game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108981Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-attacking-players-block
  a curric:Misconception ;
  curric:statement """Pupils think the attacking players can block the blitzer so that the
  quarterback remains able to pass the ball."""@en ;
  curric:correction """In flag football, blocking the blitzer is not allowed. Attackers must avoid
  physical contact and the quarterback must rely on quick throws and good timing to avoid
  being tagged by the blitzer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109199Z"^^xsd:dateTime .

oakcurric:misconception-training-seasons-align-seasons-year
  a curric:Misconception ;
  curric:statement "Training seasons align with seasons of the year."@en ;
  curric:correction """They are very different. Training seasons will align with the type of sport
  and their competition period. For example, the football season is currently a different
  time period to the netball super league and hence their seasons will be set by this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109255Z"^^xsd:dateTime .

oakcurric:misconception-skill-ability-interchangeable
  a curric:Misconception ;
  curric:statement "Skill and ability are interchangeable."@en ;
  curric:correction """They are not interchangeable. Skill is learnt and developed through practice,
  while ability is a natural and inherited trait often considered innate. An ability
  provides an opportunity or the potential to develop a skill."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109274Z"^^xsd:dateTime .

oakcurric:misconception-raising-knees-sit-reach-test
  a curric:Misconception ;
  curric:statement "Raising the knees in the sit and reach test."@en ;
  curric:correction """When performing the sit and reach test, the knees should be flat along the
  floor to give an accurate reading of flexibility."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109413Z"^^xsd:dateTime .

oakcurric:misconception-attacking-best-dribble-step-pass
  a curric:Misconception ;
  curric:statement """When attacking, it is always best to just dribble or step and pass the ball
  straight up the court."""@en ;
  curric:correction """Sometimes to create more space, a flat pass across the width of the pitch or
  a crossover move can be used to spread, reposition or confuse defenders which can be more
  successful at enabling a teammate to get through the gap that is created and score."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109515Z"^^xsd:dateTime .

oakcurric:misconception-speed-running-fast
  a curric:Misconception ;
  curric:statement "Speed is just about running fast."@en ;
  curric:correction """An example of speed is moving quickly across the ground but also includes
  other body parts too such as the speed of arms in table tennis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109911Z"^^xsd:dateTime .

oakcurric:misconception-training-lot-automatically-improve-your
  a curric:Misconception ;
  curric:statement "Training a lot more will automatically improve your fitness."@en ;
  curric:correction """Without adequate rest within a training programme, the individual will have a
  higher chance of injury, decreased performance and chronic fatigue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109963Z"^^xsd:dateTime .

oakcurric:misconception-screening-defensive-move-used-stop
  a curric:Misconception ;
  curric:statement """Screening is a defensive move only used to stop the team with the ball
  scoring."""@en ;
  curric:correction """Screening can be used by attackers to 'screen' or block defenders to allow an
  attacking teammate more space to move or score."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110242Z"^^xsd:dateTime .

oakcurric:misconception-students-mix-rotation-circumduction
  a curric:Misconception ;
  curric:statement "Students may mix up rotation and circumduction."@en ;
  curric:correction """When you rotate the shoulder joint you draw a dot with your hand (if the
  elbow is fully extended) whereas circumduction draws a circle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110656Z"^^xsd:dateTime .

oakcurric:misconception-players-allowed-d-apart-goalkeeper
  a curric:Misconception ;
  curric:statement "Players are not allowed in the D apart from the goalkeeper."@en ;
  curric:correction """If you land in the goal area (the D) after taking a shot, the goal will still
  count as long as the ball was released before you entered the area. However, if you enter
  the goal area during regular play, possession is awarded to the opposing team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110872Z"^^xsd:dateTime .

oakcurric:misconception-losing-game-affect-your-gcse
  a curric:Misconception ;
  curric:statement "Losing a game will affect your GCSE PE moderation score."@en ;
  curric:correction """For your GCSE PE moderation, you are measured against how well you can
  demonstrate certain skills, tactics and decision making, not the final score of your game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110898Z"^^xsd:dateTime .

oakcurric:misconception-intrinsic-motivation-best-type-motivation
  a curric:Misconception ;
  curric:statement "Intrinsic motivation is always the best type of motivation."@en ;
  curric:correction """Extrinsic motivation has its time and place, particularly with short term
  goals or with very young people. Intrinsic is much better when long term commitment and
  persistence is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111023Z"^^xsd:dateTime .

oakcurric:misconception-thinking-balance-important-games-players
  a curric:Misconception ;
  curric:statement """Thinking that balance is not important for games players and only useful in
  gymnastics."""@en ;
  curric:correction """Provide examples of when games players would need balance, e.g. a rugby
  player will need balance when kicking a conversion to provide greater accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111050Z"^^xsd:dateTime .

oakcurric:misconception-advantage-delaying-your-shot-playing
  a curric:Misconception ;
  curric:statement """There is no advantage to delaying your shot when playing a compeititve
  game."""@en ;
  curric:correction "Delaying your shot can be effective at wrong footing your opponent."@en ;
  dcterms:modified "2026-06-07T15:30:15.111149Z"^^xsd:dateTime .

oakcurric:misconception-side-heart-left-look-body
  a curric:Misconception ;
  curric:statement """Which side of the heart is the left when you look at the body and which side
  is oxygenated versus deoxygenated."""@en ;
  curric:correction """The left side of the heart is nearest your left armpit and carries oxygenated
  blood, the right side of the heart has deoxygenated blood (remember: LORD - left,
  oxygenated and right, deogygenated)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111893Z"^^xsd:dateTime .

oakcurric:misconception-best-lots-attackers-near-ball
  a curric:Misconception ;
  curric:statement """It is best for lots of attackers to be near the ball so they have more chance
  of keeping possession."""@en ;
  curric:correction """Overcrowding the ball limits passing options, reduces space and makes it
  easier for defenders to win possession, so attackers should spread out to keep better
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112774Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-tagger-remains-breakdown
  a curric:Misconception ;
  curric:statement "Pupils think that just the tagger remains at the breakdown in T1 rugby."@en ;
  curric:correction """After a tag/touch, 2 other defenders need to join the the tager to form a
  triangle at every breakdown."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112812Z"^^xsd:dateTime .

oakcurric:misconception-goalkeeper-important-use-your-stick
  a curric:Misconception ;
  curric:statement "As a goalkeeper it is important to use your stick to hit away the ball."@en ;
  curric:correction """It's often more effective to rely on your pads or kickers for blocking low
  shots and redirecting the ball to safety. The stick is mainly for high / wide shots or
  controlling passes, but your legs and body provide a larger surface area for most shots."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113232Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-twisting-vertical-axis
  a curric:Misconception ;
  curric:statement """Pupils believe twisting on the vertical axis is pointless as they are keen to
  do tricks which are often completed around the horizontal axis."""@en ;
  curric:correction """Learning to twist is fundamental to overcome possible anxiety when in motion
  and not being able to see the cross. In addition, more challenging techniques include a
  twist at the start or the end, so the motor programme is required to build on this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113819Z"^^xsd:dateTime .

oakcurric:misconception-receiving-ball-side-hitting-score
  a curric:Misconception ;
  curric:statement """When receiving the ball from the side, hitting to score is easy with the ball
  at the side."""@en ;
  curric:correction """It is easier to hit the ball with more power by controlling it and positoning
  it slightly to right and forward of your feet before hitting it. This allows a better
  angle for accuracy and power as the ball already has momentum towards the goal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113831Z"^^xsd:dateTime .

oakcurric:misconception-pupils-field-fly-balls-putting
  a curric:Misconception ;
  curric:statement """Pupils may field fly balls by putting their arm up in the air then running to
  where they think it'll land."""@en ;
  curric:correction """Teach pupils to beat the ball to the landing spot by running fast - something
  which can't be done with one arm in the air - then position themselves to catch."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113836Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-hit-ball-flat
  a curric:Misconception ;
  curric:statement """Pupils think they should hit the ball with a flat racket face to generate
  topspin."""@en ;
  curric:correction """To create topspin, you need to angle the racket slightly downward and brush
  up the back of the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113968Z"^^xsd:dateTime .

oakcurric:misconception-misconception-pupils-think-use-two
  a curric:Misconception ;
  curric:statement """Misconception: Pupils think you should always use two hands to shoot in
  Korfball."""@en ;
  curric:correction """Two-handed shots are useful, especially when you're learning, but they’re not
  always the best choice. In a match, you might need to shoot quickly or when a defender is
  close. One-handed shots can be faster and harder to block."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113974Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-landing-somersault-achieved
  a curric:Misconception ;
  curric:statement """Pupils believe that landing a somersault is achieved through speed of
  rotation."""@en ;
  curric:correction """A somersault does require some speed, but if too much power is placed on the
  take off, it can lead to over rotation. A somersault will appear controlled with a
  balanced take off and the rebound of the trampoline initiating the hips for the rotation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115267Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-position-volleyball-determined
  a curric:Misconception ;
  curric:statement """Pupils think a position in volleyball is determined by their physical location
  on the court."""@en ;
  curric:correction """Rotations do occur based on court location but players are also assigned
  positions, with an assigned role, which they can move into directly after the serve."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115274Z"^^xsd:dateTime .

oakcurric:misconception-indoor-caving-squeezing-tight-spaces
  a curric:Misconception ;
  curric:statement """Indoor caving is just about squeezing through tight spaces as quickly as
  possible."""@en ;
  curric:correction """Caving isn't just about speed. It involves planning, moving carefully, using
  spatial awareness and thinking ahead to create and navigate a route that is both enjoyable
  and challenging."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115279Z"^^xsd:dateTime .

oakcurric:misconception-flexibility-training-dancers-gymnasts
  a curric:Misconception ;
  curric:statement "Flexibility training is only for dancers or gymnasts."@en ;
  curric:correction """Flexibility training is useful for all athletes as it can improve mobility,
  posture and reduce muscle tension making all movements easier."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115824Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-scrum-line-t1
  a curric:Misconception ;
  curric:statement """Pupils think a scrum and line out in T1 rugby are contested and they push to
  get the ball."""@en ;
  curric:correction """T1 rugby is a non contact game therefore the scrum and lineouts are both
  uncontested. They are used to draw players into an area to create space on the pitch
  following a restart."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115830Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stick-one-payer-opposite
  a curric:Misconception ;
  curric:statement "Pupils just stick with one payer on the opposite team and chase them."@en ;
  curric:correction """The game moves too fast to just stick with 1 player, so it is better to work
  with teammates to create zonal defence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115835Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-get-effective
  a curric:Misconception ;
  curric:statement "Pupils find it difficult to get into an effective defensive position."@en ;
  curric:correction """A quick transition out of a set position will reduce the chance of this
  occuring."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115841Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gcse-assessment-ball
  a curric:Misconception ;
  curric:statement """Pupils think that GCSE assessment for ball control is just looking at the
  techniques in isolation or in a 1v1."""@en ;
  curric:correction """Dribbling and 1v1 needs to be seen in conditioned practices to showcase the
  technique when faced with the position of the defenders and decision making."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115847Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-stand-next-ball
  a curric:Misconception ;
  curric:statement """Pupils think they should stand next to the ball carrier when running a support
  line."""@en ;
  curric:correction """It is better to start deeper so you are able to catch the ball at full pace
  and have more chance of breaking the gain line"""@en ;
  dcterms:modified "2026-06-07T15:30:15.116652Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-move-ball-2
  a curric:Misconception ;
  curric:statement """Pupils think they can move with the ball more than 2 steps before starting to
  dribble."""@en ;
  curric:correction "This can be seen at the elite level but will break the travelling rule."@en ;
  dcterms:modified "2026-06-07T15:30:15.116821Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-media-coverage-beneficial
  a curric:Misconception ;
  curric:statement """Pupils may think that media coverage is always beneficial for sports, without
  considering potential negative effects and assuming that media only affects athletes and
  fans."""@en ;
  curric:correction """Media coverage can be both positive and negative and can impact performers,
  sports, officials, spectators and the sport itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117299Z"^^xsd:dateTime .

oakcurric:misconception-im-flexible-cant-yoga
  a curric:Misconception ;
  curric:statement "I'm not flexible so I can't do yoga."@en ;
  curric:correction """Flexibility develops over time with consistent practice. Yoga also improves
  strength, balance and mindfulness. Many poses can be modified to suit all levels, so
  anyone can start, no matter their current flexibility."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117602Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-win-hitting-ball
  a curric:Misconception ;
  curric:statement "Pupils believe they can just win by hitting the ball with power."@en ;
  curric:correction """Winning in table tennis isn’t just about power as control, spin, placement
  and consistency are just as important. A well-placed shot forces your opponent into
  difficult returns and increases your accuracy in rallies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117608Z"^^xsd:dateTime .

oakcurric:misconception-ball-control-mainly-dribbling
  a curric:Misconception ;
  curric:statement "Ball control is mainly about dribbling."@en ;
  curric:correction """Control of the ball is the fundamental skill that is the basis of other
  skills such as dribbling, passing or shooting. With good ball control comes an increased
  opportunity to maintain possession of the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117637Z"^^xsd:dateTime .

oakcurric:misconception-defender-mark-1-attacker
  a curric:Misconception ;
  curric:statement "Each defender can only mark 1 attacker."@en ;
  curric:correction """Netball positions are paired, however the competitive situation will
  determine if players swap, if they double mark and which stage of defence they need at
  that point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117642Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-balance-static-position
  a curric:Misconception ;
  curric:statement """Pupils think balance is only a static position, such as standing on one leg,
  and is only really needed in sports like gymnastics."""@en ;
  curric:correction """The ability to balance whilst static is essential in sport and in life, be
  that on one leg or two, but it is important to highlight the kinaesthetic awareness that
  unlocks success is also required in dynamic balances (i.e. while on the move)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118064Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-6-downs-tags
  a curric:Misconception ;
  curric:statement "Pupils think they have 6 'downs/tags' like tag rugby or rugby league."@en ;
  curric:correction """In flag football, teams only have 4 downs (or attempts) to advance the ball
  10 yards or score. If they don't succeed within those 4 downs, the ball is turned over to
  the other team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118070Z"^^xsd:dateTime .

oakcurric:misconception-dance-actions-performed-big-possible
  a curric:Misconception ;
  curric:statement """Dance actions should always be performed as big as possible so they are clear
  and stand out to an audience."""@en ;
  curric:correction """Whilst this is often the case for performance dances, social dances are often
  much smaller and more relaxed in their execution since they are often performed in a
  limited amount of space and purely for pleasure, rather than an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118883Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-believe-impact-your
  a curric:Misconception ;
  curric:statement """Some pupils may struggle to believe the impact your mindset can have on
  performance."""@en ;
  curric:correction """Your mindset can be the difference between giving up and persisting, through
  the use of mindfulness, visualisation and positive self talk anything is possible."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119514Z"^^xsd:dateTime .

oakcurric:misconception-gcse-assessment-assessor-expect-see
  a curric:Misconception ;
  curric:statement """In a GCSE assessment the assessor will expect to see you be on the ball as an
  attacker and trying to beat defenders with tricks and feints."""@en ;
  curric:correction """An assessor is looking for the selection of the most appropriate skill for
  the situation to outwit an opponent which could be a passing option or creating space. It
  is more about the contribution to the team performance and strategic application."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119525Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-putt-ball-successfully
  a curric:Misconception ;
  curric:statement """Pupils think you can putt the ball successfully just by lining up to the ball,
  forgetting that the green slopes and isn't flat."""@en ;
  curric:correction """Explain to pupils that beacuse each green is different and they aren't flat,
  we always have to consider where we aim and the power we apply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120299Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-chant-kabaddi-kabaddi
  a curric:Misconception ;
  curric:statement "Pupils often forget to chant \"Kabaddi Kabaddi\" when they are a raider."@en ;
  curric:correction """Remember chanting \"Kabaddi, Kabaddi\" is how the raider shows they haven't
  taken a breath during the raid and if they forget, the raid doesn't count."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120314Z"^^xsd:dateTime .

oakcurric:misconception-conducting-ruler-drop-test-partner
  a curric:Misconception ;
  curric:statement """When conducting the ruler drop test, the partner or assistant will countdown
  so the performer knows when the ruler is going to be dropped."""@en ;
  curric:correction """Remind students that they need to drop the ruler randomly, rather than when
  the performer knows they will drop it, to really ensure validity to test reaction time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122620Z"^^xsd:dateTime .

oakcurric:misconception-finds-first-wins
  a curric:Misconception ;
  curric:statement "Who finds it first, wins."@en ;
  curric:correction """Accuracy and teamwork so we find the correct outcomes is more important than
  being first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122636Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-defender-need-rush
  a curric:Misconception ;
  curric:statement """Pupils think that as a defender they need to rush individually to stop the
  opposition."""@en ;
  curric:correction """Rushing alone often leaves space for the raider to escape. Defenders are more
  effective when they move together, stay connected and communicate to trap the raider as a
  team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122645Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-run-freely-ball
  a curric:Misconception ;
  curric:statement "Pupils may think they can run freely with the ball in Aussie rules."@en ;
  curric:correction """In Aussie Rules, players must bounce or touch the ball to the ground every 15
  metres when running with it. Running freely without doing so results in a turnover."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122660Z"^^xsd:dateTime .

oakcurric:misconception-important-pupils-listen-music-beginning
  a curric:Misconception ;
  curric:statement """It is important that the pupils listen to the music before beginning to
  choreograph their dances."""@en ;
  curric:correction """Engaging pupils in the active content of the lesson is likely to improve
  motivation and levels of engagement. By playing the music in the background they will
  become familiar with it and allow it to inform the work they create."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122672Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performance-10-bounce
  a curric:Misconception ;
  curric:statement """Pupils think a performance of a 10 bounce routine has to include lots of
  difficult skills."""@en ;
  curric:correction """There is judgement on difficulty through tariffs, however the performance is
  also linked to maintenance of height / execution with good technique. Often it is better
  to go simple with good execution, rather than difficult and have no control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123519Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-good-tennis
  a curric:Misconception ;
  curric:statement """Pupils think you need to be a good tennis player to participate in cardio
  tennis."""@en ;
  curric:correction """The focus is on the workout rather than the execution of shots. It is about
  having fun while exercising. You should prioritise keeping your heart rate elevated for
  the whole lesson rather than great shots or winning rallies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123528Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-hitting-your-targets
  a curric:Misconception ;
  curric:statement """Pupils think hitting your targets is the same as doing the maximum amount you
  can."""@en ;
  curric:correction """A target needs to be SMART. It needs to be specific to the group, one you can
  measure, the group agrees it and it is realistic to all the abilities and fitness levels
  in the group. It also needs an allocated time to achieve it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123554Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-tagged-touched-attacker
  a curric:Misconception ;
  curric:statement """Pupils think that when they are tagged/touched, the attacker can just give the
  ball (1 handed) to their teammate."""@en ;
  curric:correction """When tagged/touched, the attacker should present the ball with 2 hands and
  their teammate should rip the ball with 2 hands to keep it safe and avoid fumbles and
  knock ons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123560Z"^^xsd:dateTime .

oakcurric:misconception-throwing-baton-harder-increases-success
  a curric:Misconception ;
  curric:statement "Throwing the baton harder increases success."@en ;
  curric:correction """Kubb is a game of accuracy and control, replicating the same technique will
  increase accuracy and consistency with practice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123582Z"^^xsd:dateTime .

oakcurric:misconception-believing-certain-sports-activities-suitable
  a curric:Misconception ;
  curric:statement """Believing that certain sports or activities are only suitable for certain
  types of people. For example, girls don't play rugby."""@en ;
  curric:correction """Some people face barriers in accessing sport or physical activity, however,
  these barriers should be broken down to provide opportunities for everyone to access all
  sport and physical activities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123643Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fielding-positions-lose-focus
  a curric:Misconception ;
  curric:statement """Pupils in fielding positions may lose focus when they are not involved for a
  spell of time and then miss an opportunity to field as a result."""@en ;
  curric:correction """Encourage pupils to communicate regularly and relay the ball back to the
  bowler via 1 or 2 fielders to keep everyone alert - e.g. the wicket keeper takes a catch,
  passes it to the slip fielder who sends it to another fielder and then to bowler."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123902Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fast-running-throughout
  a curric:Misconception ;
  curric:statement """Pupils think that fast running throughout will be the best pace to use in
  trail running."""@en ;
  curric:correction """Using smart pacing means the pupils can use variable speeds, across different
  terrain, to keep safe, save engery and complete the run."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123908Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-walking-boring-easy
  a curric:Misconception ;
  curric:statement "Pupils may think that walking is boring and too easy."@en ;
  curric:correction """Walking can be at different speeds, does not have to be boring and is a good
  opportunity to be present in the moment, which enhances positive mental health."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123913Z"^^xsd:dateTime .

oakcurric:misconception-pupils-hold-pads-wrong-height
  a curric:Misconception ;
  curric:statement """Pupils hold the pads at the wrong height or angle or keep their arms too stiff
  or too relaxed."""@en ;
  curric:correction """Encourage pupils to communicate if the pads are at the wrong height or angle
  to give each other corrective feedback. Teach pad holders to “meet” the strike with slight
  forward pressure and a bend in the arms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123924Z"^^xsd:dateTime .

oakcurric:misconception-feeling-disappointed-fitness-test-results
  a curric:Misconception ;
  curric:statement """Feeling disappointed if some fitness test results fall below national
  average."""@en ;
  curric:correction """We all have different strengths and weaknesses and this is why we train to
  improve our areas of weakness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123930Z"^^xsd:dateTime .

oakcurric:misconception-stretching-first-part-warm-routine
  a curric:Misconception ;
  curric:statement "Stretching is the first part of a warm up routine."@en ;
  curric:correction """Before a muscle can be stretched it needs to have an increase in temperature
  and pliability. Therefore, before stretching, an individual should do a pulse raiser to
  increase blood flow to the muscles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123941Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-static-approach-batting
  a curric:Misconception ;
  curric:statement """Pupils may use a static approach to batting, perhaps using only their arms to
  swing the bat with."""@en ;
  curric:correction """Pupils should understand the whole body is involved in a good batting swing
  and that most of the power produced comes from the lower half of the body."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124400Z"^^xsd:dateTime .

oakcurric:misconception-pupils-pay-little-attention-strategy
  a curric:Misconception ;
  curric:statement """Pupils often pay little attention to strategy and think only of themselves and
  not what the team needs. Many will only think of hitting the ball as hard and as far as
  they can."""@en ;
  curric:correction """Encourage pupils to consider team strategy, e.g. the batting line up based on
  strengths of the team. Stronger hitters bring others home and in some cases, a safe hit is
  much more useful to a team than trying to slog and getting caught or struck out."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124408Z"^^xsd:dateTime .

oakcurric:misconception-feet-used-body-part-volleyball
  a curric:Misconception ;
  curric:statement "The feet can not be used as a body part in volleyball."@en ;
  curric:correction """Using the foot to contact the ball is legal but the foot must remain in
  contact with the ground. Players only tend to use this to slide the foot into the path of
  the ball as they simply cannot kick the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124414Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-knock-tournament-best
  a curric:Misconception ;
  curric:statement """Pupils think that a knock out tournament is always the best type of tournament
  to do in sport/ PE."""@en ;
  curric:correction """With 4 or less teams (or if you have a lot of time) a round-robin tournament
  is better so that all teams are able to play each other."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124420Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-same-type-throw
  a curric:Misconception ;
  curric:statement """Pupils always use the same type of throw for passing and shooting (i.e.
  overarm with a focus on power and a direct route to the rebound frame)."""@en ;
  curric:correction """It is easy to defend a square shot or an obvious attack angle at the rebound
  frame. To outwit the opposition, look to vary the type, angle and pace of shots as well as
  utilising fakes (e.g. a switch)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124456Z"^^xsd:dateTime .

oakcurric:misconception-performers-smile-time
  a curric:Misconception ;
  curric:statement "Performers have to smile all the time."@en ;
  curric:correction """Performers use facial expression to communicate the mood or feelings of their
  character. This range can include smiling if happy, weeping if sad, a furrowed brow if
  worried, a cleanched jaw if angry or eye-rolling if annoyed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125041Z"^^xsd:dateTime .

oakcurric:misconception-films-made-entertainment-accurate-representation
  a curric:Misconception ;
  curric:statement """Films made for entertainment are an accurate representation of a social dance
  style."""@en ;
  curric:correction """Whilst many choreographers may have researched a social dance and employed
  the key features, it is unlikely that it is a detailed and accurate representation, and
  should be considered to be 'in the style of' rather than an authentic account."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125049Z"^^xsd:dateTime .

oakcurric:misconception-punching-effective-way-hitting-kin
  a curric:Misconception ;
  curric:statement "Punching is an effective way of hitting the kin-ball."@en ;
  curric:correction """Hitting with your hands clasped together helps to prevent injury, improve
  stability, ensure accuracy and enable faster, stronger hits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125055Z"^^xsd:dateTime .

oakcurric:misconception-kicking-kin-ball-its-side
  a curric:Misconception ;
  curric:statement """Kicking the kin-ball on its side, similar to kicking a football, is considered
  an effective strategy."""@en ;
  curric:correction """It is important to kick the kin-ball on the underside of the ball to help
  reduce the risk of injury and maximise the chances of gaining height and therefore keeping
  it off the floor."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126226Z"^^xsd:dateTime .

oakcurric:misconception-main-consequences-dehydration-headaches-dizziness
  a curric:Misconception ;
  curric:statement "The main consequences of dehydration are headaches and dizziness."@en ;
  curric:correction """Headaches and dizziness are likely effects of dehydration, however the GCSE
  specification expects students to be able to understand the physiological reasons behind
  these such as slow blood flow, increased heart rate and body temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126389Z"^^xsd:dateTime .

oakcurric:misconception-kin-ball-light-full-air
  a curric:Misconception ;
  curric:statement """The kin-ball is light as it is full of air and travels slowly so it doesn't
  require much strength."""@en ;
  curric:correction """When the kin-ball is dropping to the floor, trying to stop it with
  outstretched arms takes significant effort and core strength."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127118Z"^^xsd:dateTime .

oakcurric:misconception-holding-your-breath-performing-different
  a curric:Misconception ;
  curric:statement """Holding your breath when performing different moves or going deeper into a
  stretch is beneficial."""@en ;
  curric:correction """Holding your breath while performing movements or deepening a stretch can
  create tension, reduce oxygen flow and limit flexibility. Focus on steady, controlled
  breathing to help the body relax, move safely and maximise the benefits of each pose."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127219Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-ideas-introduced-teacher
  a curric:Misconception ;
  curric:statement "The pupils should only use ideas introduced by the teacher."@en ;
  curric:correction """Cross curricular lessons offer scope for pupils to include additional content
  by bringing, sharing and consolidating subject knowledge from other curriculum areas.
  Enabling pupils to expand the action content will increase motivation and engagement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130772Z"^^xsd:dateTime .

oakcurric:misconception-pupils-drop-their-guard-blocking
  a curric:Misconception ;
  curric:statement """Pupils often drop their guard after blocking leaving their head and body
  exposed."""@en ;
  curric:correction """Focus on returning to the guard stance after every block and continue to
  prompt pupils throughout the lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130800Z"^^xsd:dateTime .

oakcurric:misconception-long-corners-actually-taken-corner
  a curric:Misconception ;
  curric:statement "Long corners are actually taken from the corner of the pitch."@en ;
  curric:correction """Long corners are taken on the 23m line, in line with where the ball went out.
  They used to be taken from the corners, but the rule changed in 2015."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130806Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-2-goals-scored
  a curric:Misconception ;
  curric:statement "Pupils forget that after 2 goals are scored they swap positions."@en ;
  curric:correction """After 2 goals are scored in Korfball, the attackers then swap and become the
  defenders and the defenders swap and become attackers (on both teams)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131569Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-race-placing-running
  a curric:Misconception ;
  curric:statement "Pupils think the race is about placing and running in the fastest time."@en ;
  curric:correction """Yes placings are given, but the key focus is to complete the race in a time
  that you know is representative of you working to the best of your ability."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131606Z"^^xsd:dateTime .

oakcurric:misconception-pupils-give-training-gets-tough
  a curric:Misconception ;
  curric:statement """Pupils give up when training gets tough rather than pushing themselves closer
  to exhaustion."""@en ;
  curric:correction """To get a fitness benefit, it is essential to work your body harder than it is
  used to and hence a little discomfort is necessary to improve. This is often referred to
  as no pain, no gain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131612Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-drop-backwards
  a curric:Misconception ;
  curric:statement """Pupils think you need to drop backwards and/or lift the legs upwards to
  achieve a seated position."""@en ;
  curric:correction """This will lead to being off balance and not allow any progressions from the
  seat landing. The key to the correct technique is to avoid lifting the legs and jump
  upwards with a hinge at the hip to then land downwards."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131619Z"^^xsd:dateTime .

oakcurric:misconception-projection-means-look
  a curric:Misconception ;
  curric:statement "Projection means that you have to look up."@en ;
  curric:correction """Projection is effectively communicating a dance idea. This often involves
  looking outwards towards an audience but would not be appropriate if communicating a
  concept such a secrecy, nervousness or reluctance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131625Z"^^xsd:dateTime .

oakcurric:misconception-training-high-altitude-leads-permanent
  a curric:Misconception ;
  curric:statement """Training at high altitude leads to permanent change in the body to support
  performance of an endurance athlete."""@en ;
  curric:correction """Adaptations to altitude are lost very quickly when returning to sea level.
  Therefore, an endurance athlete needs to plan carefully when to access altitude to be at
  optimal performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132341Z"^^xsd:dateTime .

oakcurric:misconception-pupils-approach-many-fitness-tasks
  a curric:Misconception ;
  curric:statement """Some pupils approach many fitness tasks as a race/competition and often give
  up as opposed to slowing down and maintaining movement until the end."""@en ;
  curric:correction """Reassure that a finishing position is irrelevant and instead focus on
  personal performance and improvement to their own fitness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132352Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-struggling-achieve-guided
  a curric:Misconception ;
  curric:statement """Pupils think if they are struggling to achieve the guided training in the app,
  they have failed and have to stop."""@en ;
  curric:correction """The app is flexible and can be adapted to individual needs and fitness
  levels. Even though it is set over 9 weeks you can complete it at your own pace and
  revisit weeks / runs if needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133914Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-ball-eyes-looking-ball
  a curric:Misconception ;
  curric:statement "When dribbling the ball eyes should always be down looking at the ball."@en ;
  curric:correction """Whilst it's important to control the ball, always looking down means you
  can't see what's happening in the game. Keeping the head up improves decision-making,
  allowing players to see defenders, find passing options and spaces to dribble into."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133948Z"^^xsd:dateTime .

oakcurric:misconception-salsa-apply-tension-your-whole
  a curric:Misconception ;
  curric:statement "In Salsa you have to apply tension to your whole body."@en ;
  curric:correction """In Salsa it is the torso that is firmly held maintaining an upright stance,
  the arms are also fixed when in hold but change to some degree when moving between holds
  or when moving independently. The legs largely remain soft and fluid."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134501Z"^^xsd:dateTime .

oakcurric:misconception-unsafe-blindfolded
  a curric:Misconception ;
  curric:statement "It is unsafe to be blindfolded."@en ;
  curric:correction """While there is an increased risk in getting injured, listening carefully to
  friends, trusting their guidance and being sensible will all help to reduce the risk
  level."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134506Z"^^xsd:dateTime .

oakcurric:misconception-task-impossible
  a curric:Misconception ;
  curric:statement "The task is impossible."@en ;
  curric:correction """Each stage of the challenge is possible. A reset in order to start again may
  be a good strategy if you get confused."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134515Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-changes-happen-response
  a curric:Misconception ;
  curric:statement """Pupils often mix up what changes happen in response to exercise and what
  changes happen as a long term adaptation to training."""@en ;
  curric:correction """Short-term responses of the body are what happens as soon as we start
  exercising to cope with it, but if we train regularly, then the body adapts to be better
  able to cope with the stress of exercise and hence work more efficiently in performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134619Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-easier-hold-ball
  a curric:Misconception ;
  curric:statement "Pupils may think it easier to hold the ball in 1 hand."@en ;
  curric:correction """Holding the ball in 1 hand might feel easier at first but it reduces control,
  increases the risk of a knock-on and makes it harder to pass accurately in both
  directions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136276Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-squats-limited-gym
  a curric:Misconception ;
  curric:statement "Pupils think squats are only limited to the gym environment."@en ;
  curric:correction """A squat is a functional whole body exercise to strengthen the lower body
  which can completed with weights or without (just using bodyweight as resistance), and can
  be completed anywhere where the space if big enough."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136312Z"^^xsd:dateTime .

oakcurric:misconception-risk-planned
  a curric:Misconception ;
  curric:statement "Every risk can be planned for."@en ;
  curric:correction """There may be some risks that cannot be planned for, so we must be able to
  dynamically risk assess on an ongoing basis (e.g. the piece of equipment you were planning
  to use breaks and becomes unfit for purpose)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136323Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-power-comes-size
  a curric:Misconception ;
  curric:statement "Pupils think power comes from just the size and strength of muscles."@en ;
  curric:correction """Strength is important to generate power but so are speed, timing,
  coordination and the combination of levers to transfer power up from the ground."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137697Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-game-try-hit
  a curric:Misconception ;
  curric:statement """Pupils think that in a game you should always try hit the ball to the back of
  the table to win."""@en ;
  curric:correction """While hitting to the back of the table can be effective, it's not always the
  best strategy. Mixing up your shots, using different spins and placing the ball in various
  spots on the table can be more effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137705Z"^^xsd:dateTime .

oakcurric:misconception-pupils-attack-one-end-court
  a curric:Misconception ;
  curric:statement """Pupils attack one end of the court similar to all other invasion games focused
  on territory and seek to tackle/intercept passes between the opposition."""@en ;
  curric:correction """Tchoukball is a unique game where both teams can score at both ends by
  throwing the ball into the rebound net and not being caught by the opposition. You are not
  allowed to tackle with the opposition while they are in possession of the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138068Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-success-bowling-comes
  a curric:Misconception ;
  curric:statement """Some pupils will think that success in bowling only comes if the ball hits the
  stumps."""@en ;
  curric:correction """In some situations, hitting the stumps is desirable, i.e., bowl a batter out
  / trap them lbw / win a bowl-out. However, all lengths have their uses and a good bowler
  can pitch the ball at a wide range of different lengths."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138866Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tuck-their-thumbs-fingers
  a curric:Misconception ;
  curric:statement "Pupils will often tuck their thumbs under fingers or stick them out."@en ;
  curric:correction """Pupils should lock thumbs around the outside of their fist to adopt the
  correct guard stance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138872Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-dive-straight
  a curric:Misconception ;
  curric:statement """Pupils think you need to dive from a straight forward position to land in a
  front landing position."""@en ;
  curric:correction """The hips should land in the same position as the take off for the front
  landing. This means the hips need to lift and move backwards slightly to initiate the
  forward movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139549Z"^^xsd:dateTime .

oakcurric:misconception-simple-fast-resolution-best-resolution
  a curric:Misconception ;
  curric:statement "A simple or fast resolution is not always the best resolution."@en ;
  curric:correction """Sometimes deeper thinking is required to prevent further problems arising as
  a result of your actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139558Z"^^xsd:dateTime .

oakcurric:misconception-its-defenders-need-good-tackling
  a curric:Misconception ;
  curric:statement "It's only the defenders that need to be good at tackling."@en ;
  curric:correction """Tackling is a crucial skill for all players, not just defenders. Midfielders
  need to win possession and disrupt attacks, while forwards use tackling to press high up
  the pitch and regain the ball in attacking areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140009Z"^^xsd:dateTime .

oakcurric:misconception-hit-ball-golf-lift-your
  a curric:Misconception ;
  curric:statement "To hit the ball in golf, you lift your head up to look at the target."@en ;
  curric:correction """Explain to pupils that in order to hit the ball successfully you need to keep
  your head down and focused on the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140813Z"^^xsd:dateTime .

oakcurric:misconception-pupils-start-exercises-much-intensity
  a curric:Misconception ;
  curric:statement """Pupils often start exercises with too much intensity and quickly recognise
  that they cannot continue when performing conditioning exercises."""@en ;
  curric:correction """When trying to improve muscular endurance and condition, steady and
  continuous activity over a longer period of time gives the best results. Start at a pace
  that is comfortable to begin with and can be maintained as muscles start to fatigue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140819Z"^^xsd:dateTime .

oakcurric:misconception-lesson-gives-impression-two-types
  a curric:Misconception ;
  curric:statement """This lesson gives the impression that there are only two types of people and
  people should be defined as one or the other personality."""@en ;
  curric:correction """Although the AQA specification has clear definitions of how introverts and
  extroverts typically behave, which will be required knowledge in the exam, students should
  understand that people's personality is more nuanced and goes beyond these."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143032Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-situations-body-works
  a curric:Misconception ;
  curric:statement """Pupils are unsure about situations when the body works aerobically and when it
  works anaerobically."""@en ;
  curric:correction """Aerobic exercise requires oxygen from the air we breathe to totally break
  down glucose to release energy for exercise. This is the most efficient mechanism but
  requires exercise to be at a low/ moderate intensity, whereas high intensity is anaerobic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143714Z"^^xsd:dateTime .

oakcurric:misconception-students-think-athletes-require-large
  a curric:Misconception ;
  curric:statement """Some students may think all athletes would require large muscle mass to be
  successful at sport."""@en ;
  curric:correction """Provide a range of examples including marathon runners, sumo wrestlers to
  show how diverse body compositions can be advantageous in different sports."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143722Z"^^xsd:dateTime .

oakcurric:misconception-students-view-lifestyle-choices-something
  a curric:Misconception ;
  curric:statement """Students may view lifestyle choices as something that can only be negative
  (e.g. fatty food, sedentary lifestyle or drugs)."""@en ;
  curric:correction "Reframe thinking using positive examples of each factor."@en ;
  dcterms:modified "2026-06-07T15:30:15.149909Z"^^xsd:dateTime .

oakcurric:misconception-injuries-prevented-sport-physical-activity
  a curric:Misconception ;
  curric:statement "Injuries can be prevented in sport and physical activity."@en ;
  curric:correction """We can significantly reduce the risk of injury using the measures discussed
  in the lesson, however nothing can guarantee an accident causing injury to a performer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150895Z"^^xsd:dateTime .

oakcurric:misconception-common-see-variants-smart-acronym
  a curric:Misconception ;
  curric:statement """It is common to see variants on the SMART acronym, for example, R = realistic,
  from other exam boards or sources. Some sources may extend the acronym to SMARTER."""@en ;
  curric:correction """Ensure it is understood that with the OCR exam board, SMART only ever refers
  to Specific, Measurable, Achieveable, Recorded and Timed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151533Z"^^xsd:dateTime .

oakcurric:misconception-mental-preparation-elite-athletes
  a curric:Misconception ;
  curric:statement "Mental preparation is just for elite athletes."@en ;
  curric:correction """Students should understand that everyone can benefit from mental preparation
  techniques and that performers in many fields of work practice them. They too could
  benefit in their own pursuits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153420Z"^^xsd:dateTime .

oakcurric:misconception-input-part-model-largely-based
  a curric:Misconception ;
  curric:statement """The input part of the model is largely based on being able to use sight to
  inform the brain."""@en ;
  curric:correction """Input is gathering data from all the senses. In sport, these can be what you
  see, hear, feel and touch."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154050Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-x-y-axis
  a curric:Misconception ;
  curric:statement """Pupils can often confuse the x and y axis and therefore not read the correct x
  axis information."""@en ;
  curric:correction """On a bar or line graphs pupils should get into the habit of physically going
  along the bottom to read the information along the x axis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154521Z"^^xsd:dateTime .

oakcurric:misconception-believing-spectators-negative-effect-performance
  a curric:Misconception ;
  curric:statement """Believing that spectators always have a negative effect on performance and
  safety and the impact of spectators is only relevant in professional sport."""@en ;
  curric:correction """Spectators have positive contributions to sport like creating an atmosphere
  and providing home-field advantage which can not only affect professional sport, but also
  amateur and youth sport too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154532Z"^^xsd:dateTime .

oakcurric:misconception-one-value-shown-graph
  a curric:Misconception ;
  curric:statement "Only one value can be shown on a graph."@en ;
  curric:correction """Different values can be broken down into different categories, such as the
  age of people and their participation in different activities, which gives a more detailed
  picture of participants."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154538Z"^^xsd:dateTime .

oakcurric:misconception-graphs-exam-questions-x-y
  a curric:Misconception ;
  curric:statement "Graphs in exam questions will have the x and y axes labelled."@en ;
  curric:correction """One of the skills assessed in GCSE PE exam questions is to label the x and y
  axes, as well as plot data and present as the method requested by the question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154744Z"^^xsd:dateTime .

oakcurric:misconception-analyse-data-need-explain-data
  a curric:Misconception ;
  curric:statement "To analyse data you just need to explain what the data is demonstrating."@en ;
  curric:correction """The analysis skill goes a little further and looks at patterns / trends /
  relationships in the context of data provided."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154834Z"^^xsd:dateTime .

oakcurric:misconception-pupils-incorrectly-assume-sportsmanship-gamemanship
  a curric:Misconception ;
  curric:statement """Pupils may incorrectly assume that sportsmanship and gamemanship are the same
  thing."""@en ;
  curric:correction """Sportsmanship is positively conforming to the rules and etiquette of the
  sport, whereas gamesmanship is more negative because a performer may bend the rules to
  gain advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154840Z"^^xsd:dateTime .

oakcurric:misconception-mixing-immediate-short-term-long
  a curric:Misconception ;
  curric:statement "Mixing up immediate, short-term and long-term effects of exercise."@en ;
  curric:correction """Immediate effects are what happens as soon as we start exercising to cope
  with it, whereas short-term effects are those that happen over the next 36 hours.
  Long-term refers to the adaptations that happen in response to training."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154866Z"^^xsd:dateTime .

oakcurric:misconception-students-mistakenly-believe-hooliganism-limited
  a curric:Misconception ;
  curric:statement "Students might mistakenly believe hooliganism is limited to football."@en ;
  curric:correction """Hooliganism can happen in other sports and activities but is it most widely
  known in football."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154880Z"^^xsd:dateTime .

oakcurric:misconception-exercise-either-aerobic-anaerobic-lactic
  a curric:Misconception ;
  curric:statement "Exercise is either aerobic or anaerobic and lactic acid is bad."@en ;
  curric:correction """All exercise is on a continuum from 100% aerobic (e.g. a long distance walk)
  to 100% anaerobic (e.g. a 1 rep max powerlifter) and the build up of lactic acid is
  perfectly natural and necessary to work at high intensity when insufficient O2 available."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154951Z"^^xsd:dateTime .

oakcurric:misconception-cool-prevent-doms
  a curric:Misconception ;
  curric:statement "A cool down will always prevent DOMS."@en ;
  curric:correction """An active cool down supports better recovery from exercise by prolonging
  elevated heart and breathing rates to flush fresh oxygen through the muscles, but small
  micro tears in the muscles may still result in soreness 24-48 hours after exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154965Z"^^xsd:dateTime .

oakcurric:misconception-mixing-different-body-systems-terminology
  a curric:Misconception ;
  curric:statement """Mixing up the different body systems and terminology used for each (for
  example, not realising the cardio-respiratory system refers to the heart and lungs)."""@en ;
  curric:correction """Ensure pupils understand that muscular means muscles, skeletal means bones,
  cardio means heart, vascular means blood vessels and respiratory means lungs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155059Z"^^xsd:dateTime .

oakcurric:misconception-little-bones-hand-foot-considered
  a curric:Misconception ;
  curric:statement "Little bones in the hand and foot are not considered long bones."@en ;
  curric:correction """Bones are classified based on their shape, if the shaft is longer than than
  the width and depth of a bone, it is referred to as a long bone even if it is small in
  size."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155065Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-different-names
  a curric:Misconception ;
  curric:statement """Pupils may get confused with the different names of fast/ slow and type I/
  type II muscle fibres."""@en ;
  curric:correction """The word slow has an O in it and these fibres use oxygen to contract slowly
  and aerobically. They are our body's first choice of muscle fibre due to fatigue
  resistance, hence type I."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155071Z"^^xsd:dateTime .

oakcurric:misconception-cardio-respiratory-benefits-come-endurance
  a curric:Misconception ;
  curric:statement """Cardio-respiratory benefits only come from endurance training and muscle
  growth only comes from weight training."""@en ;
  curric:correction """Any training that regularly puts the bodily systems under more strain than
  they are in normal life will lead to long term benefits to the muscular, cardiovascular
  and respiratory systems. However, training intensity will effect results."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155280Z"^^xsd:dateTime .

oakcurric:misconception-cardiorespiratory-benefits-come-endurance-training
  a curric:Misconception ;
  curric:statement """Cardiorespiratory benefits only come from endurance training and muscle growth
  only comes from weight training."""@en ;
  curric:correction """Any training that regularly puts the bodily systems under more strain than
  they are in normal life, will lead to long term benefits to the muscular, cardiovascular
  and respiratory systems. However, training intensity will effect results."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155285Z"^^xsd:dateTime .

oakcurric:misconception-last-two-ts-fitt-acronym
  a curric:Misconception ;
  curric:statement "The last two T's of the FITT acronym are interchangeable."@en ;
  curric:correction """The principle is set and the first 'T' references the time used to train and
  the second 'T' references the specific type of training method chosen to achieve the
  optimal fitness gains."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155300Z"^^xsd:dateTime .

oakcurric:misconception-injury-prevention-means-injuries-occur
  a curric:Misconception ;
  curric:statement "Injury prevention means injuries will not occur."@en ;
  curric:correction """Nothing can guarantee that injuries will not happen, however the measures
  discussed in this lesson will significantly reduce the risk of injury. With the best
  prevention measures in place, accidents may still happen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155306Z"^^xsd:dateTime .

oakcurric:misconception-injuries-prevented-using-methods-such
  a curric:Misconception ;
  curric:statement "Injuries can be prevented by using methods such as PAR-Q"@en ;
  curric:correction """Nothing can guarantee that injuries will not happen, however the measures
  discussed in this lesson will significantly reduce the risk of injury. Accidents will
  always happen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155311Z"^^xsd:dateTime .

oakcurric:misconception-training-highest-intensity-best-way
  a curric:Misconception ;
  curric:statement "Training at the highest intensity is the best way to see results."@en ;
  curric:correction """A balanced and accurate approach to training intensity using approximate
  zones is necessary to optimise fitness, recovery and avoid injury."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155317Z"^^xsd:dateTime .

oakcurric:misconception-rice-treatment-required-injuries
  a curric:Misconception ;
  curric:statement "RICE is the treatment required for all injuries."@en ;
  curric:correction """RICE in only suitable for soft tissue injuries such as strains and sprains.
  For other types of injuries , other types of medical care should be sought."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155323Z"^^xsd:dateTime .

oakcurric:misconception-performance-enhancing-drugs-illegal-banned
  a curric:Misconception ;
  curric:statement "All performance enhancing drugs are illegal/banned/negative."@en ;
  curric:correction """The use of some PEDs to enhance performance is perfectly acceptable. Many
  sportspeople use narcotic analgesics to get through an event or drink caffeine for its
  stimulating effect. WADA is responsible for determining which PEDs are allowed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155329Z"^^xsd:dateTime .
