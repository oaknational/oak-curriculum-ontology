  dcterms:modified "2026-06-07T15:30:29.301835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29481-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: applying advanced speed, reaction time, agility, balance and coordination are
  essential for success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29481-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: established pairings have a strong sense of belonging and demonstrate
  self-motivation to work hard throughout."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29481-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: when the ball is hit down the middle, effective communication is essential
  to decide who is best to hit it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22865-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: participating in fitness tests with maximum effort allows for effective
  monitoring of fitness improvements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22865-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: good leaders are reflective so they can constantly evolve to work on their
  areas for improvement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22865-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: seeing improvements to fitness boosts confidence and feels rewarding."@en ;
  dcterms:modified "2026-06-07T15:30:29.301891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22865-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: being reflective demonstrates openness, fostering trust and authenticity
  with others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22930-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing a combination of body/ball feints misleads defenders and creates
  opportunities for passing or shooting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22930-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a firm, stable screen helps a teammate get free and catch the ball in space
  for a better shot on goal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22930-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: evaluating when to set a screen to block defenders ensures they are used
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22930-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence is the result of thorough preparation and practice, knowing you've
  done everything possible to succeed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22930-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: effective communication enhances team cohesion and performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.301917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22918-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: adopting a balanced stance with the same throwing arm and leg forward will
  improve the accuracy of shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22918-2
  a curric:KeyLearningPoint ;
  rdfs:label "Think: ensuring others are clear of your target reduces the risk of harm."@en ;
  dcterms:modified "2026-06-07T15:30:29.301925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22918-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: focusing on progress, not the outcome, will help us manage frustration and
  remain calm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22918-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: taking turns fairly will allow us to work respectfully as part of a
  team."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22904-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a low squat and grounded glove position allows fielders to collect ground
  balls."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: selecting and performing a fast overarm or underarm throw can help beat
  runners to the base and get them out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: fielders need to be alert to cover bases when teammates are required to field
  the ball elsewhere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22904-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: perseverance with practice tasks is required when learning to use unfamiliar
  equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22904-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: sensitivity towards others is required to build up the confidence in others
  after a dropped catch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deoxygenated blood travels from the body through the vena cava into the right atrium
  then down to the right ventricle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23000-2
  a curric:KeyLearningPoint ;
  rdfs:label """From the right ventricle blood is pumped through the pulmonary artery to the lungs
  for oxygenation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23000-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pulmonary vein carries oxygenated blood from the lungs to the left atrium, then
  to the left ventricle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23000-4
  a curric:KeyLearningPoint ;
  rdfs:label """From the left ventricle blood is pumped out through the aorta to be distributed
  throughout the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23000-5
  a curric:KeyLearningPoint ;
  rdfs:label "Valves in the heart prevent the backflow of blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.301975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23063-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: underarm shots have a U-shaped swing with a slightly bent elbow."@en ;
  dcterms:modified "2026-06-07T15:30:29.302007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23063-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: overarm shots have a high elbow and flick movement to meet the shuttle up high
  in front of the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23063-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: it is sometimes best to run round the shuttle to enable a forehand shot but
  that requires fast footwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23063-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence is needed to persevere with tougher backhand shots to maximise
  learning and muscle memory development."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23063-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: striving to help others to improve their performance shows excellent
  teamwork and cooperation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28809-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power can be measured by the vertical  jump test."@en ;
  dcterms:modified "2026-06-07T15:30:29.302141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28809-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flexibility is the range of motion available at a joint and is measured by the sit
  and reach test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28809-3
  a curric:KeyLearningPoint ;
  rdfs:label """Agility is being able to change direction at speed and is measured by the Illinois
  agility test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22855-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: challenging ourselves to work at our maximum level, without compromising
  technique, will help prevent injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: applying progressive overload throughout a training programme will provide
  challenge and decrease boredom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22855-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: planning a specific training plan that meets your needs gives a feeling of
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22855-4
  a curric:KeyLearningPoint ;
