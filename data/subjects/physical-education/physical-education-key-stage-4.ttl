  dcterms:modified "2026-06-07T15:30:29.338957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23045-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using both feet alternately to touch the ball makes it easier to move at pace
