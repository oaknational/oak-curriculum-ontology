  schema:description """a skill which is quickly learned as there are very few decisions to be made
  when performing the skill"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382227Z"^^xsd:dateTime .

oakcurric:keyword-complex-skill
  a curric:Keyword ;
  schema:name "complex skill"@en ;
  schema:description """a skill which requires a lot of decision making, requiring a high level of
  coordination and thinking"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382232Z"^^xsd:dateTime .

oakcurric:keyword-open-skill
  a curric:Keyword ;
  schema:name "open skill"@en ;
  schema:description """a skill which is performed in a certain way to deal with a changing or
  unstable environment, e.g. to outwit an opponent"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382238Z"^^xsd:dateTime .

oakcurric:keyword-closed-skill
  a curric:Keyword ;
  schema:name "closed skill"@en ;
  schema:description "a skill which is not affected by the environment or performers within it"@en ;
  dcterms:modified "2026-06-07T15:30:02.382243Z"^^xsd:dateTime .

oakcurric:keyword-parallel
  a curric:Keyword ;
  schema:name "parallel"@en ;
  schema:description "side by side alignment of the feet on landing"@en ;
  dcterms:modified "2026-06-07T15:30:02.382525Z"^^xsd:dateTime .

oakcurric:keyword-round-robin
  a curric:Keyword ;
  schema:name "round-robin"@en ;
  schema:description """a tournament where every player plays every player in their league, as
  opposed to a knock-out or elimination event"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382552Z"^^xsd:dateTime .

oakcurric:keyword-knowledge-of-results
  a curric:Keyword ;
  schema:name "knowledge of results"@en ;
  schema:description """feedback related to the outcome of a performance such as the result or final
  position"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382564Z"^^xsd:dateTime .

oakcurric:keyword-knowledge-of-performance
  a curric:Keyword ;
  schema:name "knowledge of performance"@en ;
  schema:description "feedback related to how well movements were performed"@en ;
  dcterms:modified "2026-06-07T15:30:02.382568Z"^^xsd:dateTime .

oakcurric:keyword-drive
  a curric:Keyword ;
  schema:name "drive"@en ;
  schema:description "fast attacking shots where the shuttle is kept low over the net"@en ;
  dcterms:modified "2026-06-07T15:30:02.382587Z"^^xsd:dateTime .

oakcurric:keyword-open-face
  a curric:Keyword ;
  schema:name "open face"@en ;
  schema:description """angling the racket strings slightly upwards to play defensive
  rallying shots"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382592Z"^^xsd:dateTime .

oakcurric:keyword-dribbling-feint
  a curric:Keyword ;
  schema:name "dribbling feint"@en ;
  schema:description "a player suddenly changes the direction of their dribble"@en ;
  dcterms:modified "2026-06-07T15:30:02.382597Z"^^xsd:dateTime .

oakcurric:keyword-double-dribble
  a curric:Keyword ;
  schema:name "double dribble"@en ;
  schema:description "bouncing a ball, holding it and bouncing the ball again"@en ;
  dcterms:modified "2026-06-07T15:30:02.382601Z"^^xsd:dateTime .

oakcurric:keyword-travelling
  a curric:Keyword ;
  schema:name "travelling"@en ;
  schema:description """if a player does not pass or shoot the ball before taking the fourth
  step"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382614Z"^^xsd:dateTime .

oakcurric:keyword-receiver
  a curric:Keyword ;
  schema:name "receiver"@en ;
  schema:description """a player who runs routes to catch passes from the quarterback and tries to
  advance the ball without being tagged"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382947Z"^^xsd:dateTime .

oakcurric:keyword-quarterback
  a curric:Keyword ;
  schema:name "quarterback"@en ;
  schema:description "the leader of an offensive play who receives the ball from the snap"@en ;
  dcterms:modified "2026-06-07T15:30:02.382953Z"^^xsd:dateTime .

oakcurric:keyword-blitzer
  a curric:Keyword ;
  schema:name "blitzer"@en ;
  schema:description """the nominated defensive player who rushes towards the quarterback with the
  primary goal of tackling them or forcing a hurried throw"""@en ;
  dcterms:modified "2026-06-07T15:30:02.382958Z"^^xsd:dateTime .

oakcurric:keyword-training-seasons
  a curric:Keyword ;
  schema:name "training seasons"@en ;
  schema:description "division into sectional parts for pre-determined benefits"@en ;
  dcterms:modified "2026-06-07T15:30:02.383041Z"^^xsd:dateTime .

oakcurric:keyword-pre-season
  a curric:Keyword ;
  schema:name "pre-season"@en ;
  schema:description """period leading up to the competitive season, focusing on general aerobic
  fitness and specific fitness for sport"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383047Z"^^xsd:dateTime .

oakcurric:keyword-peak-season
  a curric:Keyword ;
  schema:name "peak season"@en ;
  schema:description """main competitive period when athletes aim to achieve their best performance,
  maintaining fitness and concentration on skills and set plays"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383054Z"^^xsd:dateTime .

oakcurric:keyword-post-season
  a curric:Keyword ;
  schema:name "post-season"@en ;
  schema:description """period following the competitive season, involving rest and active recovery
  through light aerobic work"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383108Z"^^xsd:dateTime .

oakcurric:keyword-ability
  a curric:Keyword ;
  schema:name "ability"@en ;
  schema:description """inherited, stable traits that determine an individual's potential to learn
  or acquire a skill"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383122Z"^^xsd:dateTime .

oakcurric:keyword-predetermined
  a curric:Keyword ;
  schema:name "predetermined"@en ;
  schema:description "an outcome that is decided in advance or predictable"@en ;
  dcterms:modified "2026-06-07T15:30:02.383127Z"^^xsd:dateTime .

oakcurric:keyword-innate
  a curric:Keyword ;
  schema:name "innate"@en ;
  schema:description "existing in a person from birth"@en ;
  dcterms:modified "2026-06-07T15:30:02.383131Z"^^xsd:dateTime .

oakcurric:keyword-protcol
  a curric:Keyword ;
  schema:name "protcol"@en ;
  schema:description """the set of rules, guidelines or procedures that should be followed for a
  specific process or activity to ensure validity, reliability and safety"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383290Z"^^xsd:dateTime .

oakcurric:keyword-width-using-the
  a curric:Keyword ;
  schema:name "width (using the)"@en ;
  schema:description """spreading play across the full horizontal space to stretch the defence and
  create opportunities to score"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383370Z"^^xsd:dateTime .

oakcurric:keyword-crossing
  a curric:Keyword ;
  schema:name "crossing"@en ;
  schema:description """players interchanging position to confuse defenders and open up shooting
  options"""@en ;
  dcterms:modified "2026-06-07T15:30:02.383377Z"^^xsd:dateTime .

oakcurric:keyword-muscle-repair
  a curric:Keyword ;
  schema:name "muscle repair"@en ;
  schema:description "the process by which muscles heal and grow stronger"@en ;
  dcterms:modified "2026-06-07T15:30:02.383884Z"^^xsd:dateTime .

oakcurric:keyword-flexion
  a curric:Keyword ;
  schema:name "flexion"@en ;
  schema:description "movement that causes the angle at a joint to decrease"@en ;
  dcterms:modified "2026-06-07T15:30:02.384462Z"^^xsd:dateTime .

oakcurric:keyword-abduction
  a curric:Keyword ;
  schema:name "abduction"@en ;
  schema:description "movement away from the midline of the body"@en ;
  dcterms:modified "2026-06-07T15:30:02.384467Z"^^xsd:dateTime .

oakcurric:keyword-adduction
  a curric:Keyword ;
  schema:name "adduction"@en ;
  schema:description "movement towards the midline of the body"@en ;
  dcterms:modified "2026-06-07T15:30:02.384471Z"^^xsd:dateTime .

oakcurric:keyword-circumduction
  a curric:Keyword ;
  schema:name "circumduction"@en ;
  schema:description """turning or circular motion around a joint (which occurs in more than one
  plane)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384478Z"^^xsd:dateTime .

oakcurric:keyword-shooting-angle
  a curric:Keyword ;
  schema:name "shooting angle"@en ;
  schema:description """the various positions and directions from which a player can shoot at the
  goal to optimise their chance of scoring"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384606Z"^^xsd:dateTime .

oakcurric:keyword-shot-whilst-falling
  a curric:Keyword ;
  schema:name "shot whilst falling"@en ;
  schema:description """when a player shoots the ball while falling or after losing balance,
  typically to avoid a defender’s block"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384611Z"^^xsd:dateTime .

oakcurric:keyword-forwards
  a curric:Keyword ;
  schema:name "forwards"@en ;
  schema:description """responsible for gaining meters, tackling, contesting the ruck e.g. prop or
  hooker"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384629Z"^^xsd:dateTime .

oakcurric:keyword-backs
  a curric:Keyword ;
  schema:name "backs"@en ;
  schema:description """responsible for creating attacking opportunities, organising plays, kicks
  and using speed and agility to break the defensive line e.g. centre or scrum-half"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384638Z"^^xsd:dateTime .

oakcurric:keyword-open-play
  a curric:Keyword ;
  schema:name "open play"@en ;
  schema:description """any phase of the match where the ball is being passed or kicked between
  teammates"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384643Z"^^xsd:dateTime .

oakcurric:keyword-intrinsic-motivation
  a curric:Keyword ;
  schema:name "intrinsic motivation"@en ;
  schema:description """the drive that comes from within, e.g., for pride, for satisfaction, a sense
  of accomplishment, for self-worth"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384782Z"^^xsd:dateTime .

oakcurric:keyword-extrinsic-motivation
  a curric:Keyword ;
  schema:name "extrinsic motivation"@en ;
  schema:description """the drive to perform well or to win in order to gain external rewards (e.g.,
  prizes, money, praise)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384787Z"^^xsd:dateTime .

oakcurric:keyword-tangible
  a curric:Keyword ;
  schema:name "tangible"@en ;
  schema:description "something that can be seen and touched, e.g. a trophy"@en ;
  dcterms:modified "2026-06-07T15:30:02.384791Z"^^xsd:dateTime .

oakcurric:keyword-singles
  a curric:Keyword ;
  schema:name "singles"@en ;
  schema:description "playing as an individual"@en ;
  dcterms:modified "2026-06-07T15:30:02.384893Z"^^xsd:dateTime .

oakcurric:keyword-inspiratory-reserve-volume
  a curric:Keyword ;
  schema:name "inspiratory reserve volume"@en ;
  schema:description """the additional volume of air that can be forcefully inhaled after a normal
  inhalation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385429Z"^^xsd:dateTime .

oakcurric:keyword-expiratory-reserve-volume
  a curric:Keyword ;
  schema:name "expiratory reserve volume"@en ;
  schema:description """the additional volume of air that can be forcefully exhaled after a normal
  exhalation"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385433Z"^^xsd:dateTime .

oakcurric:keyword-residual-volume
  a curric:Keyword ;
  schema:name "residual volume"@en ;
  schema:description "the amount of air that remains in the lungs after maximal expiration"@en ;
  dcterms:modified "2026-06-07T15:30:02.385438Z"^^xsd:dateTime .

oakcurric:keyword-topspin
  a curric:Keyword ;
  schema:name "topspin"@en ;
  schema:description """a shot that puts forward rotation on the ball by hitting from low to
  high"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385524Z"^^xsd:dateTime .

oakcurric:keyword-ventricles
  a curric:Keyword ;
  schema:name "ventricles"@en ;
  schema:description """the lower chambers of the heart that receive blood from the atria before
  pumping it out to the body/lungs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385528Z"^^xsd:dateTime .

oakcurric:keyword-valves
  a curric:Keyword ;
  schema:name "valves"@en ;
  schema:description "structural feature that prevents backflow of blood"@en ;
  dcterms:modified "2026-06-07T15:30:02.385533Z"^^xsd:dateTime .

oakcurric:keyword-pulmonary-circulation
  a curric:Keyword ;
  schema:name "pulmonary circulation"@en ;
  schema:description """carries deoxygenated blood from the right side of the heart to the lung then
  back to the left side of the heart"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385538Z"^^xsd:dateTime .

oakcurric:keyword-systemic-circulation
  a curric:Keyword ;
  schema:name "systemic circulation"@en ;
  schema:description """carries oxygenated blood from the left side of the heart to the rest of the
  body. After delivering oxygen and nutrients to the body, the blood returns to the right
  side of the heart deoxygenated"""@en ;
  dcterms:modified "2026-06-07T15:30:02.385542Z"^^xsd:dateTime .

oakcurric:keyword-winger
  a curric:Keyword ;
  schema:name "winger"@en ;
  schema:description "an attacking forward player who plays on the left or right side"@en ;
  dcterms:modified "2026-06-07T15:30:02.386025Z"^^xsd:dateTime .

oakcurric:keyword-hockey-team
  a curric:Keyword ;
  schema:name "hockey team"@en ;
  schema:description """comprises of a maximum of 16 players with 11 on the field at any one
  time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386029Z"^^xsd:dateTime .

oakcurric:keyword-overcrowding
  a curric:Keyword ;
  schema:name "overcrowding"@en ;
  schema:description """happens when too many players gather around the ball in a small area,
  reducing space and limiting passing options"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386034Z"^^xsd:dateTime .

oakcurric:keyword-tackle-triangle
  a curric:Keyword ;
  schema:name "tackle triangle"@en ;
  schema:description """a defensive shape formed around the ball carrier after they have been tagged
  by 3 defenders"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386066Z"^^xsd:dateTime .

oakcurric:keyword-routine
  a curric:Keyword ;
  schema:name "routine"@en ;
  schema:description """a series of choreographed movements and skills performed and meeting certain
  requirements"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386311Z"^^xsd:dateTime .

oakcurric:keyword-reverse-stick
  a curric:Keyword ;
  schema:name "reverse stick"@en ;
  schema:description """passing on the backhand side by turning the stick over to ensure the flat
  side of the stick contacts the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386335Z"^^xsd:dateTime .

oakcurric:keyword-push-flick
  a curric:Keyword ;
  schema:name "push flick"@en ;
  schema:description """the ball is lifted off the ground using a controlled pushing motion with the
  stick, without a backswing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386353Z"^^xsd:dateTime .

oakcurric:keyword-goalkeeper-slide
  a curric:Keyword ;
  schema:name "goalkeeper slide"@en ;
  schema:description """the goalkeeper slides on the ground to block a shot or cover more of the
  goal, typically used for low or close range shots"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386360Z"^^xsd:dateTime .

oakcurric:keyword-penatly-shootout
  a curric:Keyword ;
  schema:name "penatly shootout"@en ;
  schema:description """is a tiebreaker where players have 8 seconds to score against the
  goalkeeper"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386364Z"^^xsd:dateTime .

oakcurric:keyword-prevention
  a curric:Keyword ;
  schema:name "prevention"@en ;
  schema:description "stopping something from happening"@en ;
  dcterms:modified "2026-06-07T15:30:02.386928Z"^^xsd:dateTime .

oakcurric:keyword-spotting
  a curric:Keyword ;
  schema:name "spotting"@en ;
  schema:description """is a safety precaution of having people positioned around the edge of the
  trampoline to ensure the performer does not fall off and get injured"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386967Z"^^xsd:dateTime .

oakcurric:keyword-out-bounce
  a curric:Keyword ;
  schema:name "out bounce"@en ;
  schema:description """a straight jump performed at three-quarters height as the final jump in a
  trampoline routine"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386972Z"^^xsd:dateTime .

oakcurric:keyword-hit
  a curric:Keyword ;
  schema:name "hit"@en ;
  schema:description """a player moves the field hockey ball by using a swinging movement with the
  stick towards the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386985Z"^^xsd:dateTime .

oakcurric:keyword-free-hit
  a curric:Keyword ;
  schema:name "free hit"@en ;
  schema:description """the term used when a foul happens or the game needs to be restarted from the
  ball going out of play"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386992Z"^^xsd:dateTime .

oakcurric:keyword-fly-ball
  a curric:Keyword ;
  schema:name "fly ball"@en ;
  schema:description "a ball hit high in the air that will likely be caught by a fielder"@en ;
  dcterms:modified "2026-06-07T15:30:02.386999Z"^^xsd:dateTime .

oakcurric:keyword-crocodile-bite
  a curric:Keyword ;
  schema:name "crocodile bite"@en ;
  schema:description """using both hands to secure the ball like a crocodile’s jaws snapping
  shut"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387003Z"^^xsd:dateTime .

oakcurric:keyword-windmill-pitch
  a curric:Keyword ;
  schema:name "windmill pitch"@en ;
  schema:description """underarm pitching technique used in fast-pitch softball, where the pitcher
  makes a full 360-degree circular motion with their throwing arm before releasing the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387010Z"^^xsd:dateTime .

oakcurric:keyword-defended-shot
  a curric:Keyword ;
  schema:name "defended shot"@en ;
  schema:description """a shot is considered defended if the defender is within arm's reach,
  directly in front of the shooter, actively defending (hand up, facing the attacker)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387149Z"^^xsd:dateTime .

oakcurric:keyword-pump-fake
  a curric:Keyword ;
  schema:name "pump fake"@en ;
  schema:description """a quick motion that mimics a shooting action without actually releasing the
  ball"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387154Z"^^xsd:dateTime .

oakcurric:keyword-overhand-shot
  a curric:Keyword ;
  schema:name "overhand shot"@en ;
  schema:description """a shooting technique where the player throws the ball towards the Korf
  (basket) using an overhead motion"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387161Z"^^xsd:dateTime .

oakcurric:keyword-baulk-line
  a curric:Keyword ;
  schema:name "baulk line"@en ;
  schema:description """a line on each side of the court that the raider must cross to make their
  raid valid and be eligible to score points"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387173Z"^^xsd:dateTime .

oakcurric:keyword-forward-turnover
  a curric:Keyword ;
  schema:name "forward turnover"@en ;
  schema:description """a skill where the athlete rotates forward 225 degrees, often from a standing
  position"""@en ;
  dcterms:modified "2026-06-07T15:30:02.388125Z"^^xsd:dateTime .

oakcurric:keyword-somersault
  a curric:Keyword ;
  schema:name "somersault"@en ;
  schema:description """a movement where the body rotates 360 degrees in the air, typically forwards
  or backwards, in a complete flip"""@en ;
  dcterms:modified "2026-06-07T15:30:02.388132Z"^^xsd:dateTime .

oakcurric:keyword-tuck
  a curric:Keyword ;
  schema:name "tuck"@en ;
  schema:description """bringing your knees into your chest, in the air, to hold the position
  tightly"""@en ;
  dcterms:modified "2026-06-07T15:30:02.388137Z"^^xsd:dateTime .

oakcurric:keyword-setter
  a curric:Keyword ;
  schema:name "setter"@en ;
  schema:description "the player who \"sets\" the ball using an overhead pass to a teammate"@en ;
  dcterms:modified "2026-06-07T15:30:02.389036Z"^^xsd:dateTime .

oakcurric:keyword-libero
  a curric:Keyword ;
  schema:name "libero"@en ;
  schema:description """the defensive specialist in the team whose main responsibility is to receive
  serves and spikes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389047Z"^^xsd:dateTime .

oakcurric:keyword-perseverance
  a curric:Keyword ;
  schema:name "perseverance"@en ;
  schema:description "continuing even when it’s physically or mentally tough"@en ;
  dcterms:modified "2026-06-07T15:30:02.389051Z"^^xsd:dateTime .

oakcurric:keyword-cardiovascular-system
  a curric:Keyword ;
  schema:name "cardiovascular system"@en ;
  schema:description """the body’s system that delivers blood, oxygen and nutrients through the
  blood vessels"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389427Z"^^xsd:dateTime .

oakcurric:keyword-mobility
  a curric:Keyword ;
  schema:name "mobility"@en ;
  schema:description "the ability to be able to move your body or body parts freely and easily"@en ;
  dcterms:modified "2026-06-07T15:30:02.389477Z"^^xsd:dateTime .

oakcurric:keyword-stretching
  a curric:Keyword ;
  schema:name "stretching"@en ;
  schema:description """gently lengthening muscles and tendons to improve elasticity and therefore
  mobility around the joint"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389482Z"^^xsd:dateTime .

oakcurric:keyword-line-out
  a curric:Keyword ;
  schema:name "line out"@en ;
  schema:description "how play is restarted when the ball goes into touch"@en ;
  dcterms:modified "2026-06-07T15:30:02.389489Z"^^xsd:dateTime .

oakcurric:keyword-uncontested
  a curric:Keyword ;
  schema:name "uncontested"@en ;
  schema:description """both teams take part in the restart but they do not compete for the ball
  through physical contact"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389498Z"^^xsd:dateTime .

oakcurric:keyword-zonal-defence
  a curric:Keyword ;
  schema:name "zonal defence"@en ;
  schema:description "when players defend the space instead of marking an opponent directly"@en ;
  dcterms:modified "2026-06-07T15:30:02.389503Z"^^xsd:dateTime .

oakcurric:keyword-behind
  a curric:Keyword ;
  schema:name "behind"@en ;
  schema:description """a score worth one point, awarded when the ball is kicked between the behind
  post and the goal post or if the ball hits a goal post."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389510Z"^^xsd:dateTime .

oakcurric:keyword-extended-hit
  a curric:Keyword ;
  schema:name "extended hit"@en ;
  schema:description """a technique where the kin-ball is hit in the same direction as before,
