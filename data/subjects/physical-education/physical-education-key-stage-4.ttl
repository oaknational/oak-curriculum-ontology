  dcterms:modified "2026-06-07T15:30:29.338933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29117-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: working to achieve a common goal builds connections and strengthens
  relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29117-5
  a curric:KeyLearningPoint ;
