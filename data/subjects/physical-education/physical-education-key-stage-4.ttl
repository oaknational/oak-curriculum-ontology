oakcurric:keylearningpoint-lesson-22997-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are two main types of muscle contraction: isotonic (moving) and isometric
  (static)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22997-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the body is in a fixed position, but the muscle is contracting, it is known as
  an isometric (static) contraction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22997-3
  a curric:KeyLearningPoint ;
  rdfs:label "Isotonic concentric contraction is the shortening of a muscle under tension."@en ;
  dcterms:modified "2026-06-07T15:30:29.262331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22997-4
  a curric:KeyLearningPoint ;
  rdfs:label "Isotonic eccentric contraction is the lengthening of a muscle under tension"@en ;
  dcterms:modified "2026-06-07T15:30:29.262335Z"^^xsd:dateTime .

