  dcterms:modified "2026-06-07T15:30:29.385987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: managing the stress of having no vision is reduced by having trust in your
  teammates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22909-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: respect and clear communication are essential to building trust."@en ;
  dcterms:modified "2026-06-07T15:30:29.385995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: running with short, efficient strides conserves energy for the duration of the
  challenge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22908-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using both lower and upper body when throwing will increase the potential
  power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: sharing your thoughts and reflections out loud enables all team members to
  learn and make informed next steps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22908-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: staying calm when mistakes are made prevents blaming others for errors and
  keeps morale high."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22908-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging and helping all team members increases the chance of
  success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23009-1
  a curric:KeyLearningPoint ;
  rdfs:label """Short-term effects of exercise on the circulatory system include increased heart
  rate, stroke volume and cardiac output."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23009-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blood is redistributed to the working muscles in response to exercise to deliver
  more oxygen and remove carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23009-3
  a curric:KeyLearningPoint ;
  rdfs:label """Respiratory rate, tidal volume and minute ventilation all increase in response to
  exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23009-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our muscles increase in temperature when we exercise."@en ;
  dcterms:modified "2026-06-07T15:30:29.386259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23009-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lactic acid is produced when we exercise at higher intensities."@en ;
  dcterms:modified "2026-06-07T15:30:29.386263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22920-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: use two hands when carrying the ball to avoid knock-ons."@en ;
  dcterms:modified "2026-06-07T15:30:29.389654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22920-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: both arms move across the body and reach out in the direction the ball is
  being passed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22920-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: it's essential to look where you are passing to ensure the receiver is ready,
  rather than focused on defenders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22920-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: problem solving finds gaps in the field to exploit through a mix of running,
  passing and movement off the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22920-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: good awareness is required to support the ball carrier."@en ;
  dcterms:modified "2026-06-07T15:30:29.389669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24612-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keep the correct technique in bodyweight exercises to prevent discomfort and
  reduce injury risk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24612-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: overtraining can increase the chance of injuries like muscle strains, stress
  fractures and tendonitis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24612-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: it is important to listen to your body and know when it is feeling tired or in
  pain to decrease or stop training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24612-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: supporting others to complete a HIIT workout builds mutual respect."@en ;
  dcterms:modified "2026-06-07T15:30:29.389744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22862-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: before starting exercise, checks should be completed for anything that could
  present as a risk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22862-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: risk management practices keep everyone safe, such as designated areas, rules
  and limits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22862-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: creating a risk assessment allows a feeling of safety, comfort and trust in
  the planned training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22862-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: prioritising everyone's safety creates a mutually supportive environment
  where everyone feels secure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29479-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: powerful shots combine levers in the legs, trunk and arms, along with
  transferring body weight forwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29479-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: fast acceleration enables movement to the net at pace."@en ;
  dcterms:modified "2026-06-07T15:30:29.392478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29479-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: moving your body weight forwards as you contact the ball adds significant
  force to the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29479-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: connecting cleanly and forcefully with the ball is a satisfying feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.392486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29479-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: being mindful of where others are on the court as you move and strike the
  ball is important for safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22955-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: changing the pace and spin requires different shapes and sizes of backswing
  and follow-through."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22955-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: once a weakness is identified, it is effective to keep hitting to that area
  (e.g. backhand or close to the body)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22955-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: figuring out how to exploit your opposition's weaknesses is motivating."@en ;
  dcterms:modified "2026-06-07T15:30:29.392502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22955-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: can adjust tactics with a partner to respond to different opposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.392508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28825-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fartlek training is beneficial for sports like football, where players frequently
  change pace and intensity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28825-2
  a curric:KeyLearningPoint ;
  rdfs:label """Continuous training requires aerobic effort for a minimum of 20 minutes, such as
  running, swimming, rowing or cycling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interval training works in the anaerobic training zone and involves work followed by
  rest periods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28825-4
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a static stretch is an isometric muscle contraction as the muscle
  stays the same length."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23018-1
  a curric:KeyLearningPoint ;
  rdfs:label """Muscular endurance requires repeated contractions for a long period of time and is
  tested through the press up test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiovascular endurance is the ability of the heart and lungs to provide oxygen to
  working muscles for a long time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23018-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speed is the ability to perform an action or cover a set distance as quickly as
  possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23018-4
  a curric:KeyLearningPoint ;
  rdfs:label "Strength is measured through the grip strength dynamometer test."@en ;
  dcterms:modified "2026-06-07T15:30:29.393521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29097-1
  a curric:KeyLearningPoint ;
  rdfs:label "Balance is measured by the stork stand test."@en ;
  dcterms:modified "2026-06-07T15:30:29.393525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29097-2
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordination is measured by the alternate hand wall throw test."@en ;
  dcterms:modified "2026-06-07T15:30:29.393529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29097-3
  a curric:KeyLearningPoint ;
  rdfs:label "Agility is measured by the Illinois agility test."@en ;
  dcterms:modified "2026-06-07T15:30:29.393533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29097-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reaction time is measured by the ruler drop test."@en ;
  dcterms:modified "2026-06-07T15:30:29.393537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: releasing the ball high, ideally from a running jump, increases the power in
  our shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22896-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: aiming at the middle/top of the net, increases the chance of scoring."@en ;
  dcterms:modified "2026-06-07T15:30:29.393547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22896-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the rule of three means you have 3 seconds with the ball, 3 passes and 3
  steps before needing to pass or shoot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22896-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: it is illegal to intercept a pass or block a rebound, so everyone feels
  included."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22896-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: respect is shown between all players as a higher priority to winning."@en ;
  dcterms:modified "2026-06-07T15:30:29.393561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27770-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: spin bowling uses a grip across the seam with a quick rotation of the fingers
  on release of the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27770-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: pace bowling requires a faster run up and more aggressive bowling action to
  deliver the ball as fast as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27770-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: different length deliveries will mean the ball arrives at the batter at
  different heights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27770-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: achieving a successful delivery with spin takes lots of repetitive practice
  and perseverance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27770-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: being quiet during your opponent's bowling action demonstrates respect and
  social etiquette."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22938-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: adopting the correct guard stance in martial arts is fundamental to performing
  attacking and defensive skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22938-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: listening to cues, alongside observing your partner, requires
  concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22938-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: trying to learn and continually practise new skills requires courage and
  resilience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22938-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: providing positive feedback to one another creates a positive learning
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22881-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: pushing a safety mat requires strength and good body control."@en ;
  dcterms:modified "2026-06-07T15:30:29.397943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22881-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: positioning the arms and hands in a diamond shape and landing flat on your
  front will help to absorb the impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: visualising the hips landing on the cross in the drop position will support
  achieving the correct body shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: being calm will support a relaxed and controlled jump with fluid movements
  reducing the risk of injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22881-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: using sensitivity when recognising and articulating flaws in the technique
  of others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22916-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: carrying heavy objects effectively requires keeping them close to your body to
  avoid strain on the back."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22916-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: explaining your rationale to the team allows informed decisions to be taken
  on the chosen strategy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22916-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: determination is required to resolve more complex problems."@en ;
  dcterms:modified "2026-06-07T15:30:29.397973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging a teammate to share an idea that resolves a problem builds
  deeper connections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28817-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fitness tests are measured or recorded using various units."@en ;
  dcterms:modified "2026-06-07T15:30:29.397980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28817-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power can be measured by the vertical jump test."@en ;
  dcterms:modified "2026-06-07T15:30:29.397984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28817-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1 rep max test measures strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.397988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28817-4
  a curric:KeyLearningPoint ;
  rdfs:label """Testing procedures encompass how each test is conducted, including organisation of
  facilities and equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22875-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: timing your jab tackle enables you to intercept the ball effectively while
  reducing the risk of committing a foul."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22875-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: getting low in a block tackle improves stability, making it easier to control
  the ball"""@en ;
  dcterms:modified "2026-06-07T15:30:29.399339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22875-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: contacting the body instead of the ball is dangerous and illegal and will
  lead to a free hit to the opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22875-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: self-awareness of the dribbling skills of others helps improve overall success
  rates"""@en ;
  dcterms:modified "2026-06-07T15:30:29.399347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22875-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: clear communication about marking ensures effective defence and prevents
  confusion amongst teammates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22956-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: gripping requires the lead hand on the handle, the trail hand overlaps to
  interlock the pinky of the lead hand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22956-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a fluid and rhythmical backswing, downswing and follow through increases the
  success of our shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22956-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: keeping the feet and head still, focused on the ball, helps control
  the shot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22956-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: recognising and understanding your emotions in different situations
  demonstrates self-discipline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22956-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: clear and constant communication ensures everyone agrees, reduces errors
  and enhances team cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22941-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: exercising at a steady and continuous pace helps to improve muscular strength
  for better kicking technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22941-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: leg conditioning exercises are important for maintaining good form when
  fatigued."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: different leg exercises target specific muscles needed to improve strength
  and stability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22941-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: setting appropriate challenges for others shows you have respect for one
  another"""@en ;
  dcterms:modified "2026-06-07T15:30:29.401607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22941-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting and encouraging each other when fatigued helps to maintain
  motivation and enhance teamwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26878-1
  a curric:KeyLearningPoint ;
  rdfs:label """Introverts are typically shy, quiet and prefer solitude, often excelling in
  individual sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26878-2
  a curric:KeyLearningPoint ;
  rdfs:label "Introverts may perform better in low-arousal situations requiring fine skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.408026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extroverts are sociable, enthusiastic and thrive on interaction, often excelling in
  team sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26878-4
  a curric:KeyLearningPoint ;
  rdfs:label """Team sports suit extroverts due to their high energy, gross motor skills and need
  for social interaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28859-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic exercise is exercise that uses oxygen for energy over extended periods, like
  running or cycling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28859-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic exercise is high-intensity exercise that doesn't rely on oxygen, such as
  sprinting or weightlifting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28859-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fats are a fuel source for low intensity aerobic activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.409895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28859-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrates are a fuel source for higher intensity aerobic and anaerobic
  activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29023-1
  a curric:KeyLearningPoint ;
  rdfs:label "Body composition is the percentage of body weight that is muscle, fat or bone."@en ;
  dcterms:modified "2026-06-07T15:30:29.409903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29023-2
  a curric:KeyLearningPoint ;
  rdfs:label "Balance is being able to keep the body stable when moving."@en ;
  dcterms:modified "2026-06-07T15:30:29.409907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29023-3
  a curric:KeyLearningPoint ;
  rdfs:label "An example of coordination is hand eye coordination."@en ;
  dcterms:modified "2026-06-07T15:30:29.409911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29023-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reaction the time between presentation of a stimulus and the onset of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.409915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28781-1
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the transverse axis moving along the sagittal plane"@en ;
  dcterms:modified "2026-06-07T15:30:29.422847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28781-2
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the frontal axis moving along the frontal plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.422851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28781-3
  a curric:KeyLearningPoint ;
  rdfs:label """The body rotates around the longitudinal axis moving along in the transverse
  plane."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28857-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lifestyle choices can include diet, exercise, sleep."@en ;
  dcterms:modified "2026-06-07T15:30:29.423843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28857-2
  a curric:KeyLearningPoint ;
  rdfs:label "Types of lifestyle choices include using recreational drugs."@en ;
  dcterms:modified "2026-06-07T15:30:29.423847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28857-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lifestyle choices can have positive impacts like feeling energised."@en ;
  dcterms:modified "2026-06-07T15:30:29.423851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28857-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some choices have negative impacts such as they increase the risk of disease."@en ;
  dcterms:modified "2026-06-07T15:30:29.423855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28805-1
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the frontal axis moving along sagittal plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.427327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28805-2
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the sagittal axis moving along the frontal plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.427334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28805-3
  a curric:KeyLearningPoint ;
  rdfs:label "The body rotates around the vertical axis moving along in the transverse plane."@en ;
  dcterms:modified "2026-06-07T15:30:29.427338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28849-1
  a curric:KeyLearningPoint ;
  rdfs:label """Measures taken to ensure the appropriate level of competition include categorising
  by age, gender and experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28849-2
  a curric:KeyLearningPoint ;
  rdfs:label """Personal protective equipment should be worn where necessary to reduce risks and
  limit the severity of injuries ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28849-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sports hall, playing field, artifical outdoor area, swimming pool and fitness centre
  all have unique hazards to monitor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28849-4
  a curric:KeyLearningPoint ;
  rdfs:label """Correct lifting and carrying technique should be taught and used when moving heavy
  objects to reduce the risk of injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29111-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skills can be classified along continua based on their charactersitics."@en ;
