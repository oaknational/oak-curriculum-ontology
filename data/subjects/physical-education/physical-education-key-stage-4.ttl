  dcterms:modified "2026-06-07T15:30:29.384041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22873-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: making eye contact and communicating where you want the ball passed to
