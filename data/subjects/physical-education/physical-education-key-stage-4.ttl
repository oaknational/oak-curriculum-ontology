  rdfs:label """Limitations of fitness testing include tests are often not sport-specific and do not
  replicate movements of an activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28814-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many tests require motivation or have questionable validity."@en ;
  dcterms:modified "2026-06-07T15:30:29.369557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28814-5
  a curric:KeyLearningPoint ;
  rdfs:label """Correct procedures are crucial to increase reliability to ensure accurate assessment
  of fitness levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29114-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: extension of the elbows and fingers when pushing the kin-ball generates more
  power, accuracy and control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29114-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: staying on the balls of the feet, knees bent and weight slightly forward,
  improves agility and stopping quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: reacting to sudden changes in play requires quick thinking."@en ;
  dcterms:modified "2026-06-07T15:30:29.370351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29114-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: being patient and supportive enables others to learn new skills in a safe
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29114-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: planning and reviewing tactics together allows all players to feel
  involved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22933-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: in Downward-Facing Dog, spread your fingers, press heels down, lift hips, keep
  spine long and engage your core."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: exhaling while deepening the movement helps the body stretch more effectively
  and achieve greater flexibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22933-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: feeling the stretch until it's tight helps you understand your limit, ensuring
  a safe and effective stretch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: a group practice allows a shared sense of calm and unity through
  synchronised movement and breath."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23100-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sedentary lifestyle can lead to weight gain, obesity and related health issues
  like heart disease and diabetes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23100-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poor sleep, low self-esteem and lethargy are common consequences of inactivity."@en ;
  dcterms:modified "2026-06-07T15:30:29.372166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23100-3
  a curric:KeyLearningPoint ;
  rdfs:label """Obesity negatively impacts physical performance by limiting stamina, flexibility,
  agility and speed/power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23100-4
  a curric:KeyLearningPoint ;
  rdfs:label """Physically, obesity increases the risk of conditions such as cancer, heart disease
  and high cholesterol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23100-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mentally and socially, obesity can cause depression, loss of confidence, and social
  isolation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22886-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: applying and rehearsing technical skills improves accuracy in performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.376134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22886-2
  a curric:KeyLearningPoint ;
  rdfs:label "Think: anticipating how an action looks to others involves imagination."@en ;
  dcterms:modified "2026-06-07T15:30:29.376138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: giving feedback to others requires self-belief in our knowledge and
  opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22886-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: giving and receiving feedback involves trust and cooperation from all
  involved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22940-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using the bony part of the forearm to block attacks ensures a stronger
  defence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22940-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: blocking with small, controlled movements allows quick reactions to attackers
  movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22940-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: returning quickly to a guard position after each block keeps your defence
  ready."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22940-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: practising controlled and safe blocking and striking techniques develops and
  demonstrates respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22940-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: working cooperatively and communicating clearly with partners ensures safe
  and effective practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22877-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: having the front foot wide and pointing to the target as the injector improves
  the speed and accuracy of the pass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: an auto pass can allow for a quicker restart to catch the opposition off
  guard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: a long corner is taken on the 23m line, in line with where it went off the
  back line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22877-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: repeated practice of set plays improves confidence in a game."@en ;
  dcterms:modified "2026-06-07T15:30:29.376277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22877-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: taking turns helps develop teamwork by ensuring players understand each
  other’s movements and responsibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fitness tests are measured or recorded using various units."@en ;
  dcterms:modified "2026-06-07T15:30:29.377657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23021-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power can be measured either by the vertical or standing jump test."@en ;
  dcterms:modified "2026-06-07T15:30:29.377663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23021-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1 rep max test measures strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.377667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23021-4
  a curric:KeyLearningPoint ;
  rdfs:label """Testing procedures encompass how each test is conducted, including organisation of
  facilities and equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: pivoting with the ball helps you find space and better passing angles to
  accurately reach a teammate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: running into space to catch the ball, shakes off a defender so you can shoot
  or pass to an unmarked teammate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: knowing that only four players from each team are allowed in each half
  supports tactical decision making."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22926-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: a confident person maintains a positive outlook, viewing setbacks as learning
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22926-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: effective communication enables the switching of attackers to defenders
  every second goal, ensuring inclusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keeping your head upright, looking forward, maintains a straight spine and
  improves breathing even when tired."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24615-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: maintaining a steady, sustainable pace helps you keep going without needing
  to stop or walk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24615-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: appreciate that skills and abilities gained from this training that can be
  applied beyond the PE environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: pushing through fatigue to keep going and succeed brings a strong sense of
  achievement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24615-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: congratulating others on their performance, regardless of their 5km time,
  promotes good sportspersonship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29482-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: intensity of movement and endurance is shown to last during repeated long
  rallies and exercise routines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29482-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: progressive overload enables you to train harder and improve fitness whilst
  minimising the risk of injury."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29482-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: enjoyment comes from combining intense exercise with the precision of fine
  motor skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29482-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: covering the court as a trio can reveal creative solutions to win
