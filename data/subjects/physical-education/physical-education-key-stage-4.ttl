  dcterms:modified "2026-06-07T15:30:29.306386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22910-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: accurately identifying matching photos through careful observation of the
