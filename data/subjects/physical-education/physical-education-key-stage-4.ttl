oakcurric:keylearningpoint-lesson-29111-3
  a curric:KeyLearningPoint ;
  rdfs:label """The environmental continua classifies skills between open and closed based on the
  level of environmental influence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428823Z"^^xsd:dateTime .

