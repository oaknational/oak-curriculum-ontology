  dcterms:modified "2026-06-07T15:30:29.299095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22945-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: leading when improvising as a pair requires quick and decisive decision
