# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-specific
  a curric:Keyword ;
  schema:name "specific"@en ;
  schema:description "clearly defined, precise or exact"@en ;
  dcterms:modified "2026-06-07T15:30:02.347910Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-dynamic
  a curric:Keyword ;
  schema:name "dynamic"@en ;
  schema:description """a lively and engaging performance, full of energy, to keep the audience
  interested"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348037Z"^^xsd:dateTime .

oakcurric:keyword-projection
  a curric:Keyword ;
  schema:name "projection"@en ;
  schema:description "speaking powerfully and clearly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348210Z"^^xsd:dateTime .

oakcurric:keyword-body-language
  a curric:Keyword ;
  schema:name "body language"@en ;
  schema:description """how we use our posture and gestures to communicate meaning, confidence and
  feelings"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348227Z"^^xsd:dateTime .

oakcurric:keyword-testing
  a curric:Keyword ;
  schema:name "testing"@en ;
  schema:description "trying something out to see if it works well"@en ;
  dcterms:modified "2026-06-07T15:30:02.348277Z"^^xsd:dateTime .

oakcurric:keyword-imagery
  a curric:Keyword ;
  schema:name "imagery"@en ;
  schema:description """the use of vivid and sensory language that appeals to the reader's senses,
  creating vivid mental pictures and enhancing the emotional impact of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348368Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-describe
  a curric:Keyword ;
  schema:name "describe"@en ;
  schema:description "add detail to"@en ;
  dcterms:modified "2026-06-07T15:30:02.348678Z"^^xsd:dateTime .

oakcurric:keyword-fluency
  a curric:Keyword ;
  schema:name "fluency"@en ;
  schema:description "how smooth and natural speech your speech sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.349047Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-technology
  a curric:Keyword ;
  schema:name "technology"@en ;
  schema:description """the use of scientific knowledge and tools to enhance and support various
  aspects of sport and performance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349569Z"^^xsd:dateTime .

oakcurric:keyword-video-analysis
  a curric:Keyword ;
  schema:name "video analysis"@en ;
  schema:description """uses cameras and software to make real-time decisions or give precise data
  on events during a game"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349574Z"^^xsd:dateTime .

oakcurric:keyword-performance-analysis
  a curric:Keyword ;
  schema:name "performance analysis"@en ;
  schema:description """analyses athlete performance using video and data to evaluate skills,
  strategies and tactics for improvement"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349580Z"^^xsd:dateTime .

oakcurric:keyword-wearable-devices
  a curric:Keyword ;
  schema:name "wearable devices"@en ;
  schema:description """devices worn by athletes to track physical activity, monitor performance and
  collect real-time data like heart rate and movement"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349584Z"^^xsd:dateTime .

oakcurric:keyword-prosthetics
  a curric:Keyword ;
  schema:name "prosthetics"@en ;
  schema:description """artificial body parts that help people move and do things after losing a
  limb"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349589Z"^^xsd:dateTime .

oakcurric:keyword-justify
  a curric:Keyword ;
  schema:name "justify"@en ;
  schema:description "support a case with evidence"@en ;
  dcterms:modified "2026-06-07T15:30:02.349832Z"^^xsd:dateTime .

oakcurric:keyword-impact
  a curric:Keyword ;
  schema:name "impact"@en ;
  schema:description "have a strong effect on someone or something"@en ;
  dcterms:modified "2026-06-07T15:30:02.349836Z"^^xsd:dateTime .

oakcurric:keyword-calculate
  a curric:Keyword ;
  schema:name "calculate"@en ;
  schema:description "work out the value of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.349841Z"^^xsd:dateTime .

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a set idea that people have about what someone or something is like"@en ;
  dcterms:modified "2026-06-07T15:30:02.349897Z"^^xsd:dateTime .

oakcurric:keyword-stress
  a curric:Keyword ;
  schema:name "stress"@en ;
  schema:description "pronouncing one syllable more heavily than other syllables in a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.350057Z"^^xsd:dateTime .

oakcurric:keyword-qualitative-data
  a curric:Keyword ;
  schema:name "qualitative data"@en ;
  schema:description "descriptive, non-numerical information focusing on opinions"@en ;
  dcterms:modified "2026-06-07T15:30:02.350229Z"^^xsd:dateTime .

oakcurric:keyword-quantitative-data
  a curric:Keyword ;
  schema:name "quantitative data"@en ;
  schema:description "numerical information that can be measured or counted"@en ;
  dcterms:modified "2026-06-07T15:30:02.350233Z"^^xsd:dateTime .

oakcurric:keyword-action-plan
  a curric:Keyword ;
  schema:name "action plan"@en ;
  schema:description "a proposed strategy or course of action to improve performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.350240Z"^^xsd:dateTime .

oakcurric:keyword-skill
  a curric:Keyword ;
  schema:name "skill"@en ;
  schema:description """the ability gained through training and experience to do a job or action
  well"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350272Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "frequency"@en ;
  schema:description """frequency is the number of waves produced each second. Frequency is measured
  in Hertz (Hz)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350761Z"^^xsd:dateTime .

oakcurric:keyword-improvisation
  a curric:Keyword ;
  schema:name "improvisation"@en ;
  schema:description "a section of music where the melodic ideas are made up on the spot"@en ;
  dcterms:modified "2026-06-07T15:30:02.350779Z"^^xsd:dateTime .

oakcurric:keyword-observation
  a curric:Keyword ;
  schema:name "observation"@en ;
  schema:description """the process of looking closely at something to notice details for recording
  in drawing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350847Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.351112Z"^^xsd:dateTime .

oakcurric:keyword-precision
  a curric:Keyword ;
  schema:name "precision"@en ;
  schema:description """Precision refers to how closely results are spread around the mean
  value."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351612Z"^^xsd:dateTime .

oakcurric:keyword-transverse-axis
  a curric:Keyword ;
  schema:name "transverse axis"@en ;
  schema:description "a line of rotation which goes from side to side through the hips"@en ;
  dcterms:modified "2026-06-07T15:30:02.351646Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal-axis
  a curric:Keyword ;
  schema:name "longitudinal axis"@en ;
  schema:description "a line of rotation which goes through the body from head to toe"@en ;
  dcterms:modified "2026-06-07T15:30:02.351651Z"^^xsd:dateTime .

oakcurric:keyword-sagittal-axis
  a curric:Keyword ;
  schema:name "sagittal axis"@en ;
  schema:description """a line of rotation which goes through from front to back through the belly
  button"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351655Z"^^xsd:dateTime .

oakcurric:keyword-plane
  a curric:Keyword ;
  schema:name "plane"@en ;
  schema:description """an imaginary flat surface running through the body along which movement
  takes place"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351662Z"^^xsd:dateTime .

oakcurric:keyword-approach
  a curric:Keyword ;
  schema:name "approach"@en ;
  schema:description """the first phase of the long jump in which momentum is created in preparation
  for the jump"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351667Z"^^xsd:dateTime .

oakcurric:keyword-dominant-foot
