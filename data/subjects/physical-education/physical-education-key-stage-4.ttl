  a curric:KeyLearningPoint ;
  rdfs:label "Media coverage, sexism and stereotyping impact sports involvement."@en ;
  dcterms:modified "2026-06-07T15:30:29.312668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28993-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cultural and religious factors, including festivals, can affect sports
  participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28993-5
  a curric:KeyLearningPoint ;
  rdfs:label """Family commitments, leisure time, socio-economic status and activity inclusiveness
  all impact participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29011-1
  a curric:KeyLearningPoint ;
  rdfs:label "Extended questions are marked using level descriptors."@en ;
  dcterms:modified "2026-06-07T15:30:29.312700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29011-2
  a curric:KeyLearningPoint ;
  rdfs:label "The hollistic approach to answering encompasses all three assessment objectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.312704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29011-3
  a curric:KeyLearningPoint ;
  rdfs:label "The command word used in the question determines the AO3 skill required."@en ;
  dcterms:modified "2026-06-07T15:30:29.312708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29011-4
  a curric:KeyLearningPoint ;
  rdfs:label "The skill can be either anlayse, discuss, evaluate or justify."@en ;
  dcterms:modified "2026-06-07T15:30:29.312712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fitness tests are measured or recorded using various units."@en ;
  dcterms:modified "2026-06-07T15:30:29.312716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28811-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power can be measured by the vertical jump test."@en ;
  dcterms:modified "2026-06-07T15:30:29.312720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28811-3
  a curric:KeyLearningPoint ;
  rdfs:label "The hand grip dynamometer tests muscular strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.312726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28811-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 30m sprint test measures speed."@en ;
  dcterms:modified "2026-06-07T15:30:29.312731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: engaging core and glutes when hips are lifted in bridge pose will allow for
  more stability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22936-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: resistance bands help push flexibility limits, providing controlled tension to
  deepen stretches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22936-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: resistance bands will make exercises more challenging and interesting."@en ;
  dcterms:modified "2026-06-07T15:30:29.312767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: using resistance bands to feel your limit of tension, enhances body awareness
  to assist with training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22936-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting classmates in partner work with resistance bands enables further
  improvement in flexibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23001-1
  a curric:KeyLearningPoint ;
  rdfs:label "The cardiac cycle consists of two main phases: diastole and systole."@en ;
  dcterms:modified "2026-06-07T15:30:29.313942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diastole is the phase when the heart chambers relax and fill with blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.313946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23001-3
  a curric:KeyLearningPoint ;
  rdfs:label """Systole is the phase when the heart chambers contract and pump blood out at high
  pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23001-4
  a curric:KeyLearningPoint ;
  rdfs:label """The septum divides the left and right sides of the heart to prevent oxygenated blood
  mixing with deoxygenated blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23002-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heart rate is the number of times the heart beats per minute (bpm)."@en ;
  dcterms:modified "2026-06-07T15:30:29.314732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23002-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stroke volume is the volume of blood pumped by the heart with each beat (measured in
  millilitres, mL)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23002-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiac Output is the volume of blood pumped by the heart per minute (measured in
  litres per minute, L/min)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23002-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiac output (Q) is calculated by multiplying the heart rate (HR) by the stroke
  volume (SV)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23002-5
  a curric:KeyLearningPoint ;
  rdfs:label "A heart rate graph shows exercise intensity over a period of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.314748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28833-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skills can be classified along continua based on their characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.315850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28833-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skills classification between basic and complex is based on how difficult they are
  to perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28833-3
  a curric:KeyLearningPoint ;
  rdfs:label """Skills classification between open and closed is based on how stable the environment
  is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28818-1
  a curric:KeyLearningPoint ;
  rdfs:label "Intrinsic feedback comes from the performer's own senses and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.317757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28818-2
  a curric:KeyLearningPoint ;
  rdfs:label """Extrinsic feedback comes from external sources such as coaches, peers or
  parents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28818-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feedback can be either positive or negative depending on whether it focuses on
  correct or incorrect actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28818-4
  a curric:KeyLearningPoint ;
  rdfs:label "Knowledge of results is feedback concerned with the outcome of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.317768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28818-5
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of performance is feedback concerned with how well movements are
  performed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23062-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: adjusting footwork relative to the shuttle flight enables space to swing and a
  clean contact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a well timed 'whip' to swing is achieved with a snap of the wrist to apply
  power and direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23062-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: to attack the shuttle you need to be behind and underneath it, with a wrist
  snap to angle the shuttle down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23062-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence is required to adjust early to hit underarm rather than
  overarm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23062-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: if your partner is struggling, hitting the shuttle up for an overhead
  forehand clear shot shows kindness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29042-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: accelerating after a fake step in the opposite direction helps to get past a
  defender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29042-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: dribbling with bent knees and a low body position maintains balance and allows
  for agile changes in direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29042-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: passing or shooting the ball before the fourth step/dribble will not break
  the travelling rule."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29042-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: it takes time to reset muscle memory when learning that you can take 3 steps
  while carrying the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29042-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: using good communication and eye contact with teammates enables greater
  success at keeping possession."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29046-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: to score more goals than our opponents we have to accurately time passes and
  movement to support the ball carrier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when our team loses possession, we need to react quickly to be ready to defend
  and stop the attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29046-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reflecting on our performance ensures we understand how we can adapt our
  performance to keep improving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: always supporting our teammates to help them improve regardless of the score
  demonstrates integrity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29046-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: utilising playing positions to work with other members of the team in
  attack and defence shows teamwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22870-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a run is timed to create space to catch the ball from the quarterback to the
  receiver.."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22870-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a blitzer should sprint directly towards the quarterback after the snap to
  pull the tag before the QB can pass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22870-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: unlike American football, no players are allowed to block the blitzer from
  tackling the quarterback."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22870-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: using your imagination helps develop creative ways to outwit the
  opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22870-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: constant communication in defence is needed to enable everyone to know who
  they are marking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pre-season focuses on general aerobic and specific fitness needs to build a base
  before specialising for the sport."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24154-2
  a curric:KeyLearningPoint ;
  rdfs:label """During competition (peak playing season), athletes focus on maintaining fitness
  levels and working on specific skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24154-3
  a curric:KeyLearningPoint ;
  rdfs:label """Post-season (or transition), athletes engage in rest and light aerobic training to
  maintain a level of general fitness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23071-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skill refers to the learned ability to bring about predetermined results with
  maximum certainty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ability refers to the inherited, stable traits that determine an individual's
  potential to learn or acquire skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23071-3
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike skills, abilities are not learned but can influence the ease and speed of
  skill acquisition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29099-1
  a curric:KeyLearningPoint ;
  rdfs:label "Agility is measured by the Illinois agility test."@en ;
  dcterms:modified "2026-06-07T15:30:29.319629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29099-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Illinois agility test is measured in seconds."@en ;
  dcterms:modified "2026-06-07T15:30:29.319633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29099-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flexibility is measured by the sit and reach test"@en ;
  dcterms:modified "2026-06-07T15:30:29.319637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29099-4
  a curric:KeyLearningPoint ;
  rdfs:label "The sit and reach test is measured in centimeters."@en ;
  dcterms:modified "2026-06-07T15:30:29.319641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29045-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: passing the ball quickly from one side of the court to another makes it hard
  for defenders to reposition quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29045-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: incorporating moves like crossing into an attacking play can confuse
  defenders, opening up opportunities to score."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29045-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: responding to how the opposition has positioned themselves utilises decision
  making and tactical awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: taking a pause to use the width of the court in attack requires focus and
  thinking to outwit the defenders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29045-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: communicating effectively with teammates before a tactical move is played
  avoids confusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28806-1
  a curric:KeyLearningPoint ;
  rdfs:label """Muscular endurance is known as dynamic strength and is tested through the sit-up
  bleep test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28806-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiovascular endurance is the ability of the heart and lungs to provide oxygen to
  working muscles for a long time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28806-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speed is the ability to perform an action or cover a set distance as quickly as
  possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28806-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is also known as explosive strength or anaerobic power."@en ;
  dcterms:modified "2026-06-07T15:30:29.321151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23019-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is speed x strength and can be measured by the vertical or standing
  jump test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23019-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reaction time is the time taken to respond to a stimulus, measured by the ruler drop
  test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23019-3
  a curric:KeyLearningPoint ;
  rdfs:label """Flexibility is the range of motion available at a joint and is measured by the sit
  and reach test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22864-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: restoring energy levels with effective rest and recovery enables us to
  participate with maximum effort."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22864-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: knowing that sleep is vital for recovery, repairing muscles and restoring
  energy, boosts training performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22864-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: when you are well-rested, your body feels more energised, focused and
  resilient during training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22864-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: providing tips and encouragement for better sleep helps peers to motivate
  each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: raising your arms as an opponent releases the ball, increases chances of
  blocking the ball and gaining possession."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29044-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: firm body position with a wide stance is crucial for effectively screening an
  opponent to control their movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: using your torso to block a player will not impede the obstruction rule but
  holding or pulling is prohibited."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: using your body to control your opposition’s movement takes confidence and
  assertiveness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29044-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: coordinating with teammates to ensure they recognise the screen helps to
  exploit the space successfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28808-1
  a curric:KeyLearningPoint ;
  rdfs:label """Balance is the ability to maintain the body's centre of mass over its base of
  support, assessed by the stork stand test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28808-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reaction time is the time taken to respond to a stimulus, measured by the ruler drop
  test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Agility is being able to change direction at speed and is measured by the Illinois
  agility test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28808-4
  a curric:KeyLearningPoint ;
  rdfs:label """Coordination is the ability to use different body parts together, tested with the
  alternate hand wall toss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28808-5
  a curric:KeyLearningPoint ;
  rdfs:label """Flexibility is the range of motion available at a joint and is measured by the sit
  and reach test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28807-1
  a curric:KeyLearningPoint ;
  rdfs:label """Muscular endurance is tested through the 1 minute press up test and the 1 minute sit
  up test"""@en ;
  dcterms:modified "2026-06-07T15:30:29.323531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28807-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiovascular endurance is the ability of the heart and lungs to provide oxygen to
  working muscles for a long time"""@en ;
  dcterms:modified "2026-06-07T15:30:29.323535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28807-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speed is the ability to perform an action or cover a set distance as quickly as
  possible"""@en ;
  dcterms:modified "2026-06-07T15:30:29.323539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28807-4
  a curric:KeyLearningPoint ;
  rdfs:label "Strength is measured through the  hand grip strength dynamometer test"@en ;
  dcterms:modified "2026-06-07T15:30:29.323543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27999-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hinge joint only allows flexion and extension to occur."@en ;
  dcterms:modified "2026-06-07T15:30:29.323609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27999-2
  a curric:KeyLearningPoint ;
  rdfs:label "A ball and socket joint allows all types of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.323615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27999-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flexion and extension occur at the shoulder, elbow, hip, knee and ankle joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.323619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27999-4
  a curric:KeyLearningPoint ;
  rdfs:label "Abduction and adduction occur at the shoulder and hip joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.323623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27999-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rotation and circumduction only occur at the shoulder, whilst plantar flexion and
  dorsiflexion only occur at the ankle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29043-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: using varied shots and angles creates unpredictability and increases the
  chances of scoring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29043-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: shooting on the move allows players to maintain momentum and evade
  defenders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29043-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: going into the ‘D’ is only permitted after the ball has been released."@en ;
  dcterms:modified "2026-06-07T15:30:29.324106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29043-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: it takes confidence to jump or shoot while unstable, trusting your ability
  despite the lack of balance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29043-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: having awareness of where the goalkeeper is improves the accuracy of
  scoring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23092-1
  a curric:KeyLearningPoint ;
  rdfs:label """Etiquette is the accepted and expected behaviour in sport, reflecting respect for
  opponents, officials and the rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23092-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sportsmanship is upholding fairness, respect, and graciousness in victory or defeat,
  demonstrating ethical conduct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23092-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gamesmanship involves using clever yet unethical tactics to gain a competitive edge
  without breaking the rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23092-4
  a curric:KeyLearningPoint ;
  rdfs:label "Deviance is cheating and goes against the etiquette of sport."@en ;
  dcterms:modified "2026-06-07T15:30:29.324147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23059-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: cardiovascular endurance helps to maintain the correct playing position
  throughout gameplay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23059-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reacting to open play requires a thorough understanding of the Laws of the
  game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23059-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: depending on body shape and size, different players are better suited to
  different positions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: guidance and leadership of the players around you can have a huge impact on
  team performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23103-1
  a curric:KeyLearningPoint ;
  rdfs:label """A balanced diet includes a variety of foods to provide essential nutrients, vitamins
  and minerals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23103-2
  a curric:KeyLearningPoint ;
  rdfs:label """No single food item provides all the necessary nutrients, so diversity in food
  choices is crucial."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23103-3
  a curric:KeyLearningPoint ;
  rdfs:label """Calorie requirements are dependent on activity levels and the length and intensity
  of the activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23103-4
  a curric:KeyLearningPoint ;
  rdfs:label """Athletes may need to eat more of a specific nutrient to meet their needs., e.g.
  weightlifters and protein."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Intrinsic motivation comes from within, driven by personal satisfaction or
  achievement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26879-2
  a curric:KeyLearningPoint ;
  rdfs:label """Extrinsic motivation comes from external sources, like receiving awards or
  recognition from others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26879-3
  a curric:KeyLearningPoint ;
  rdfs:label """Intrinsic motivation often leads to long-term commitment, as the motivation is
  personal and internal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26879-4
  a curric:KeyLearningPoint ;
  rdfs:label "Extrinsic motivation provides immediate rewards and recognition."@en ;
  dcterms:modified "2026-06-07T15:30:29.324561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Overuse of extrinsic motivation can undermine the strength of intrinsic
  motivation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29024-1
  a curric:KeyLearningPoint ;
  rdfs:label """Agility is being able to change direction at speed and is measured by the Illinois
  agility test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Balance is the ability to maintain the body's centre of mass over its base of
  support, assessed by the stork stand test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29024-3
  a curric:KeyLearningPoint ;
  rdfs:label """Co-ordination is the ability to use different body parts together, tested with the
  alternate hand wall toss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23065-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: performing a serve, clear, smash and then playing out the point illustrates
  competence in a range of shots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23065-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: performing touch shots requires control and precision."@en ;
  dcterms:modified "2026-06-07T15:30:29.324942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23065-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: hitting different shots requires adjustments to body position to ensure a
  sideways position to generate power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23065-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: confidence is required to demonstrate a full range of shots."@en ;
  dcterms:modified "2026-06-07T15:30:29.324949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23065-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: calling the score clearly between every point helps ensure the game is
  played fairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28802-1
  a curric:KeyLearningPoint ;
  rdfs:label """During inhalation the intercostal muscles and diaphragm contract to expand the
  thoracic cavity volume, so air rushes in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28802-2
  a curric:KeyLearningPoint ;
  rdfs:label """During exhalation the intercostal muscles relax, the rib cage returns to its resting
  position and air is expelled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28802-3
  a curric:KeyLearningPoint ;
  rdfs:label """During exercise the lungs can expand more using the pectoralls and
  sternocleidmastoid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28802-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expiration is aided by the abdominals pulling the ribs down quicker to force air
  out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28802-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spirometer trace is a graphical representation of lung volume changes over time
  during breathing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22998-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deoxygenated blood travels from the body into the heart's right side then through
  the pulmonary artery to the lungs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22998-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pulmonary vein carries oxygenated blood from the lungs to the left side of the
  heart then out the aorta to the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22998-3
  a curric:KeyLearningPoint ;
  rdfs:label "Valves in the heart prevent the backflow of blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.327540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22998-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is a double circulatory pump. The pulmonary circuit carries blood to the
  lungs then back to the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22998-5
  a curric:KeyLearningPoint ;
  rdfs:label """The systemic circuit carries oxygenated blood out of the heart to the body tissues
  and returns with deoxygenated blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28760-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deoxygenated blood travels from the body into the heart's right side then through
  the pulmonary artery to the lungs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28760-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pulmonary vein carries oxygenated blood from the lungs to the left side of the
  heart then out the aorta to the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28760-3
  a curric:KeyLearningPoint ;
  rdfs:label "Valves in the heart prevent the backflow of blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.327778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28760-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is a double circulatory pump. The pulmonary circuit carries blood to the
  lungs then back to the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28760-5
  a curric:KeyLearningPoint ;
  rdfs:label """The systemic circuit carries oxygenated blood out of the heart to the body tissues
  and returns with deoxygenated blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28763-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deoxygenated blood travels from the body into the heart's right side then through
  the pulmonary artery to the lungs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28763-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pulmonary vein carries oxygenated blood from the lungs to the left side of the
  heart then out the aorta to the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28763-3
  a curric:KeyLearningPoint ;
  rdfs:label "Valves in the heart prevent the backflow of blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.327802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28763-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is a double circulatory pump. The pulmonary circuit carries blood to the
  lungs then back to the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28763-5
  a curric:KeyLearningPoint ;
  rdfs:label """The systemic circuit carries oxygenated blood out of the heart to the body tissues
  and returns with deoxygenated blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22878-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: passing the ball quickly from one side of the pitch to another makes it hard
  for defenders to reposition quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: movement off the ball when attacking needs to be into space to receive the
  ball/support teammates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: persistence involves staying focused and composed, even when the team is
  behind or facing strong opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22878-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: a good leader consistently demonstrates dedication and a positive attitude,
  inspiring teammates to follow suit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22922-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: stepping quickly into a triangle with 2 other teammates after a tag/touch
  helps to slow down the attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22922-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: moving quickly onside, behind the tackle triangle, stops gaps forming in the
  defensive line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: 2 defenders must place a hand on the tagger to set the offside line from the
  back foot of the triangle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: feeling organised in defence builds confidence to press and stop forward
  momentum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22922-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: communicating clearly in the tackle triangle lets the tagger know you are
  there to support them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22876-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: angling the stick under the ball will generate lift to move it over a
  stick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: as a goalkeeper, using your feet to save low shots allows you to clear the
  ball away faster by kicking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22876-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: a penalty shootout is used as a tiebreaker and players have 8 seconds to
  score against the goalkeeper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: playing in goal takes confidence to commit to saves without hesitation,
  especially in one-on-one situations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22876-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: effective teamwork thrives on open dialogue, where players feel happy
  sharing ideas, feedback and concerns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: aiming for the cross with body tension when jumping will keep the body upright
  and avoid going off at an angle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22879-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: safely getting off the trampoline requires sitting down and sliding off as
  opposed to jumping off."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22879-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: standing close to the trampoline with hands up to spot increases
  awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: building confidence in getting on and off the trampoline safely will enhance
  your overall comfort and performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: spotting others demonstrates teamwork by offering support and ensures
  safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22874-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hitting the ball when it’s about a stick length away and slightly in front of
  you helps you generate more power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22874-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: bending your knees lowers your body, helping you place the stick flat for a
  larger stopping surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22874-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: the ball can not be touched with your feet unless you are the goalkeeper."@en ;
  dcterms:modified "2026-06-07T15:30:29.332756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22874-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: accurate long hits require persistence and practice to master."@en ;
  dcterms:modified "2026-06-07T15:30:29.332763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22874-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: effective teamwork thrives on open dialogue, where players feel happy
  sharing ideas, feedback and concerns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22905-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: a full circular rotation of the arm is executed before releasing the ball in a
  windmill pitch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332771Z"^^xsd:dateTime .

