  dcterms:modified "2026-06-07T15:30:29.308573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22999-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries carry blood away from the heart at high pressure. They have thick walls and
  a smaller lumen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22999-2
  a curric:KeyLearningPoint ;
  rdfs:label """Veins carry blood back to the heart. They have thinner walls and contain valves to
  prevent backflow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22999-3
  a curric:KeyLearningPoint ;
  rdfs:label """Capillaries facilitate the exchange of gases, nutrients, and waste products between
  blood and tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22999-4
  a curric:KeyLearningPoint ;
  rdfs:label "Red blood cells transport oxygen, carbon dioxide and nutrients."@en ;
  dcterms:modified "2026-06-07T15:30:29.309256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22999-5
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells fight infections whilst platelets enable blood clotting and plasma
  makes up the main blood volume."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29022-1
  a curric:KeyLearningPoint ;
