  schema:description """the set of rules, guidelines, or procedures that should be followed for a
  specific process or activity to ensure validity, reliability and safety"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364344Z"^^xsd:dateTime .

oakcurric:keyword-forehand
