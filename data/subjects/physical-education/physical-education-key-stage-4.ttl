  dcterms:modified "2026-06-07T15:30:29.384037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22873-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: passing accurately with the reverse stick consistently requires persistence
