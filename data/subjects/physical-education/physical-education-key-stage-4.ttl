  dcterms:modified "2026-06-07T15:30:29.437015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28843-3
  a curric:KeyLearningPoint ;
  rdfs:label """SMART targets should be analysed for their effectiveness and adjusted where
  necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437019Z"^^xsd:dateTime .

