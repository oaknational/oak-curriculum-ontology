oakcurric:keylearningpoint-lesson-23022-1
  a curric:KeyLearningPoint ;
  rdfs:label "The most important components of fitness vary for different sports."@en ;
  dcterms:modified "2026-06-07T15:30:29.266419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23022-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main components of fitness required for different sports and sporting actions
  can be identified via analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23022-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most sporting activities require a variety of components of fitness for success."@en ;
  dcterms:modified "2026-06-07T15:30:29.266427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28848-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aggression is the deliberate intention to harm another person, either physically or
  mentally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28848-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct aggression is the use of physical contact to cause harm, such as punching or
  grabbing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28848-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect aggression does not involve physical contact, instead the peformer takes
  the aggression out on an object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23056-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: using a change in direction helps to wrong foot the opposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.268566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23056-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: attackers supporting the ball carrier should run on to the ball at pace from
  deep."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23056-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: timing your support run keeps you onside, prevents forward passes and ensures
  the best position to attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23056-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: individuals need to show determination to get back onside at all times."@en ;
  dcterms:modified "2026-06-07T15:30:29.268579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23056-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: leadership at the breakdown helps capitalise on opportunities to attack or
  to deny the opposition's attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23085-1
  a curric:KeyLearningPoint ;
  rdfs:label "Attitudes and role models can significantly influence participation in sports."@en ;
  dcterms:modified "2026-06-07T15:30:29.268590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23085-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accessibility to facilities, clubs and activities is a crucial factor affecting
  participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23085-3
  a curric:KeyLearningPoint ;
  rdfs:label "Media coverage, sexism and stereotyping impact sports involvement."@en ;
  dcterms:modified "2026-06-07T15:30:29.268597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23085-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cultural and religious factors, including festivals, can affect sports
  participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23085-5
  a curric:KeyLearningPoint ;
  rdfs:label """Family commitments, leisure time, socio-economic status and activity inclusiveness
  all impact participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23055-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: when spin passing, the outside hand grips towards the back of the ball to
  produce spin by pulling up on the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23055-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: running straight with the ball draws a defender, creating space for a teammate
  to attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23055-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: only long passes should utilise spin as it is faster to pass and easier to
  catch a short pass without spin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23055-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: self-awareness of the catching skills of others helps improve overall success
  rates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23055-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: making eye contact and signalling where you want the ball passed, helps
  reduce handling errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23054-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: picking up a ball from the floor requires a scoop by reaching first in front
  of the ball to prevent a knock-on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23054-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hold the ball tightly to the chest when being tackled to avoid loss of
  possession."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23054-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the Laws of rugby encourage quick passing and moving to try and evade the
  opposition whilst attacking territory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23054-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: fumbles are reduced with increased time practising ball skills to build
  confidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23054-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: clear communication helps prevent handling errors by increasing awareness
  of the location of other players."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23102-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in calories (Kcal) and is sourced from the food consumed."@en ;
  dcterms:modified "2026-06-07T15:30:29.270327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23102-2
  a curric:KeyLearningPoint ;
  rdfs:label """The average daily calorie requirement is 2,500 Kcal for men and 2,000 Kcal for
  women."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Calorie needs vary based on factors such as age, gender, height, and activity
  duration or intensity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23102-4
  a curric:KeyLearningPoint ;
  rdfs:label "Energy expenditure increases with physical activity, requiring more calories."@en ;
  dcterms:modified "2026-06-07T15:30:29.270340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23102-5
  a curric:KeyLearningPoint ;
  rdfs:label """Balancing calorie intake with energy expenditure is crucial for maintaining weight
  and overall health"""@en ;
  dcterms:modified "2026-06-07T15:30:29.270344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23057-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: tackling is performed with a low body position, arms wrapped to secure the
  ball carrier until they hit the ground."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23057-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: side shuffling whilst getting back onside quickly allows defenders to keep an
  eye on the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23057-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: staying as a flat defensive line will leave no gaps for attackers to run
  through."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23057-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence to initiate contact comes from repeated execution with the correct
  technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23057-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting less confident classmates to execute successful tackles in
  practice conditions shows kindness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28816-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fitness test for cardiovascular fitness is Harvard step test and the 12 minute
  Cooper run/swim"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28816-2
  a curric:KeyLearningPoint ;
  rdfs:label "The minute sit-up and press-up test measure muscular endurance."@en ;
  dcterms:modified "2026-06-07T15:30:29.273233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28816-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fitness tests are measured or recorded using various units (e.g time, distance or
  weight)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28816-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing each fitness test according to protocol is crucial to ensure accurate and
  reliable measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23060-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: the serve requires a solid stance with dominant foot forwards and weight
  transfer to apply power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: releasing the shuttle with good timing, as the racket hand wrist flicks to
  apply speed, maximises consistency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23060-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: analysing serves with a focus on keeping them low over the net prevents
  interceptions and reduces response time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23060-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: focus and composure before every serve helps improve accuracy."@en ;
  dcterms:modified "2026-06-07T15:30:29.273257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23060-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: providing a target for others to aim their serve at and counting successful
  attempts will motivate performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22954-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: stepping aside after hitting the ball gives your partner space to play their
  shot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22954-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: taking turns to hit the ball demonstrates you’re following the
  correct rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22954-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: getting into a rhythm with your partner increases confidence."@en ;
  dcterms:modified "2026-06-07T15:30:29.273310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22954-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: demonstrating communication through a shared goal is key to effective
  teamwork and success in a game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22927-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: receiving a ball safely with one or two hands requires moving our body towards
  the ball to keep it under control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22927-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keeping possession of the ball requires us to execute a variety of accurate
  passes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the ball must be passed within 4 seconds to avoid violating the possession
  rule."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22927-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: increased confidence comes from success but it's also important to notice the
  benefit of learning from mistakes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22927-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: respect is shown for others by playing fairly and safely."@en ;
  dcterms:modified "2026-06-07T15:30:29.273337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23072-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skills can be classified along continua based on their charactersitics."@en ;
  dcterms:modified "2026-06-07T15:30:29.273740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23072-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difficulty continua classifies skills based on how complex they are to
  perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23072-3
  a curric:KeyLearningPoint ;
  rdfs:label """The environmental continua classifies skills based on the level of influence
  environmental factors have when performing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23072-4
  a curric:KeyLearningPoint ;
  rdfs:label """The organisational continua classifies skills based on the ability to break down the
  skill into parts or subroutines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28852-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anabolic agents, stimulants, peptide hormones (EPO) and blood doping can have
  positive effects on performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28852-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diuretics can help aid weight loss or mask other drug use."@en ;
  dcterms:modified "2026-06-07T15:30:29.274510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28852-3
  a curric:KeyLearningPoint ;
  rdfs:label """Narcotic analgesics can be used to mask pain and allow the athlete to perform, even
  when injured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28852-4
  a curric:KeyLearningPoint ;
  rdfs:label """Athletes using prohibited substances and methods to gain an advantage over others
  may do so for fame, money and success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28852-5
  a curric:KeyLearningPoint ;
  rdfs:label """Athletes using prohibited substances or methods do so at the risk to their health,
  reputation and career."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23090-1
  a curric:KeyLearningPoint ;
  rdfs:label """Commercialisation involves the use of sport for financial gain and includes
  activities like sponsorship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23090-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sponsorship is when companies provide support in exchange for promotion and
  visibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23090-3
  a curric:KeyLearningPoint ;
  rdfs:label "Financial sponsorship includes monetary support from companies."@en ;
  dcterms:modified "2026-06-07T15:30:29.274534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23090-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sponsorship of clothing and equipment involves providing sports gear and
  apparel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23090-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sponsorship of facilities includes funding or providing sports venues and training
  locations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22929-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: boxing out by positioning your body between the opponent and the Korf secures
  the rebound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22929-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: putting your hands up to block an attacker prevents them from scoring and
  increases the chance of interception."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22929-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: positioning yourself between your opponent and the Korf enables interception
  of passes and shots to be blocked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22929-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: confidence stems from a strong belief in your skills and abilities to tackle
  challenges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22929-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: coordinating with teammates to switch defenders if a screen or mismatch
  occurs requires quick communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: effectively transitioning between attack and defence involves using a range of
  travelling and body control skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29118-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reacting to open play requires a thorough understanding of the rules and
  different strategies available to teams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29118-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: having persistence involves staying focused and composed, even if the team is
  behind or facing strong opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29118-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: An effective leader shows dedication and positivity, motivating teammates
  to do the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23035-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: effective sprinting technique requires appropriate stride length, high knees
  and strong elbow drive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23035-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: correctly performed sprint starts launch the performer into the drive phase
  and improve overall time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23035-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: remembering to keep low during the drive phase will ensure a quick start."@en ;
  dcterms:modified "2026-06-07T15:30:29.275262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: being focussed and dedicated to performing at maximal levels will ensure you
  achieve your best performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23035-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: assessing a peer and giving feedback will help to check and improve
  technique and motivate them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28855-1
  a curric:KeyLearningPoint ;
  rdfs:label "Health involves physical, emotional and social well–being."@en ;
  dcterms:modified "2026-06-07T15:30:29.275333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28855-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fitness is the ability to meet the demands of the environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.275337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28855-3
  a curric:KeyLearningPoint ;
  rdfs:label "Engaging in regular exercise can have physical benefits to health and fitness."@en ;
  dcterms:modified "2026-06-07T15:30:29.275341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28855-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engaging in physical activities helps individuals control their emotions better."@en ;
  dcterms:modified "2026-06-07T15:30:29.275345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28855-5
  a curric:KeyLearningPoint ;
  rdfs:label """Social benefits of physical activity include opportunities to socialise and make
  friends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29041-1
  a curric:KeyLearningPoint ;
