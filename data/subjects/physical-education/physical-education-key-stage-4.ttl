# ----------------------------------------------------------------------
# Units
# ----------------------------------------------------------------------

oakcurric:unit-3097
  a curric:Unit ;
  rdfs:label "Socio-cultural influences: commercialisation"@en ;
  curric:slug "socio-cultural-influences-commercialisation" ;
  rdfs:comment """This unit will examine the golden triangle relationship between the media,
  sponsors and sportspeople to help understand how sponsorship has benefits and risks for
  all parties as sports increasingly operate as big businesses in a billion dollar industry
  of professional sport."""@en ;
  curric:whyThisWhyNow """Pupils will already know that media exposure helps the growth and reach of
  different physical activities and sports. This unit builds on general knowledge and the big
  business of sponsorship in professional sport. Later in socio-cultural influences pupils will
  study ethics and behaviour with topics such as sportsmanship.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3097-1 ,
    oakcurric:priorknowledge-3097-2 ,
    oakcurric:priorknowledge-3097-3 ,
    oakcurric:priorknowledge-3097-4 ,
    oakcurric:priorknowledge-3097-5 ;
  curric:id "3097"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.433973Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-physical-education-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-connect-cultural-and-ethical-awareness .

oakcurric:unit-3084
  a curric:Unit ;
  rdfs:label "Non-examined assessment: preparing for the written coursework"@en ;
  curric:slug "non-examined-assessment-preparing-for-the-written-coursework" ;
  rdfs:comment """This unit will provide guidance and support to enable pupils to successfully
  complete their exam board specific coursework."""@en ;
  curric:whyThisWhyNow """Pupils will already know how the body systems, physical fitness and sport
  specific training contribute to optimum performance. This unit provides the necessary
  guidance to complete their written coursework worth 10% of their final mark. Later in the
  programme they will need to apply this knowledge independently to produce their written work
  with limited teacher input and in line with awarding organisation (exam board) guidelines.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3084-1 ,
    oakcurric:priorknowledge-3084-2 ,
    oakcurric:priorknowledge-3084-3 ;
  curric:id "3084"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.453971Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-physical-education-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-move-physical-fitness ,
    oakcurric:thread-think-knowledge-of-rules-tactics-strategies-and-compositional-ideas ,
    oakcurric:thread-think-evaluation-analysis-and-reflection .

oakcurric:unit-3078
  a curric:Unit ;
  rdfs:label "Movement analysis and basic biomechanics"@en ;
  curric:slug "movement-analysis-and-basic-biomechanics" ;
  rdfs:comment """This unit will explore basic principles of movement and their effect on sporting
  performance to include the classification of levers, planes of movement and axis of
  rotation. This understanding enables pupils to maximise efficiency of movement or generate
  more power."""@en ;
  curric:whyThisWhyNow """Pupils will already have in-depth understanding of how muscles work in
  antagonistic pairs across a joint to create movement via the leverage of bones. After they
  appreciate the three classes of lever and different planes/ axes our bodies can move in they
  will be in a strong position to develop their understanding of how different types of
  training impact positively on sporting performance. This unit links nicely with learning from
  maths and physics to form the foundations of biomechanical understanding.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3078-1 ,
    oakcurric:priorknowledge-3078-2 ,
    oakcurric:priorknowledge-3078-3 ,
    oakcurric:priorknowledge-3078-4 ;
  curric:id "3078"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.772123Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-physical-education-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-think-knowledge-of-healthy-active-living .

oakcurric:unit-3085
  a curric:Unit ;
  rdfs:label "Non-examined assessment: athletics practical"@en ;
  curric:slug "non-examined-assessment-athletics-practical" ;
  rdfs:comment """This unit provides pupils with the knowledge and opportunity to replicate skills
  in isolation and in performance scenarios across all athletic disciplines. As a popular
  individual sport offered by many pupils it will cover sprinting, middle distance, jumping,
  shot put and javelin events."""@en ;
  curric:whyThisWhyNow """Pupils will already know the correct technique and relevant rules to
  different athletics disciplines from key stage 3 PE. This unit provides the opportunity to
  evaluate technique and record times/ distances to highlight pupils who would perform well at
  athletics as one of their chosen practical sports. Positioned during the summer term of year
  10 it will encourage engagement in extracurricular opportunities to include local
  competitions to improve performance further.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3085-1 ,
    oakcurric:priorknowledge-3085-2 ,
    oakcurric:priorknowledge-3085-3 ,
    oakcurric:priorknowledge-3085-4 ,
    oakcurric:priorknowledge-3085-5 ;
  curric:id "3085"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.775972Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-physical-education-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-move-movement-competence ,
    oakcurric:thread-think-knowledge-of-rules-tactics-strategies-and-compositional-ideas .

oakcurric:unit-3086
  a curric:Unit ;
  rdfs:label "Non-examined assessment: football practical"@en ;
  curric:slug "non-examined-assessment-football-practical" ;
  rdfs:comment """This unit provides pupils with the knowledge and opportunity to replicate skills
  in isolation and in performance scenarios in association football. As a popular team sport
  offered by many pupils it will cover passing/ receiving, dribbling, shooting, ball
  control, tackling and decision making."""@en ;
  curric:whyThisWhyNow """Pupils will already know the correct technique and relevant rules for
  football from key stage 3 PE. This unit builds upon this by providing the opportunity to
  evaluate technique and practise some observation and analysis skills. Positioned during the
  autumn term of year 10, it will encourage engagement in extracurricular opportunities,
  including local clubs and competitions, which will allow further improvement of performance.
  This unit will help to prepare students for the practical GCSE moderation in Year 11.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3086-1 ,
    oakcurric:priorknowledge-3086-2 ,
    oakcurric:priorknowledge-3086-3 ,
    oakcurric:priorknowledge-3086-4 ,
    oakcurric:priorknowledge-3086-5 ,
    oakcurric:priorknowledge-3086-6 ;
  curric:id "3086"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.809329Z"^^xsd:dateTime ;
