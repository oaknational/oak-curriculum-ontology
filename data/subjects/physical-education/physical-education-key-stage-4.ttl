  dcterms:modified "2026-06-07T15:30:29.435475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mental rehearsal involves visualising a successful performance to improve confidence
