  dcterms:modified "2026-06-07T15:30:29.300383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22958-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging and supporting each other boosts morale and fosters a positive
  team environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29128-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: making your body as tall and wide as possible when marking, closes down your
  opponent's space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29128-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: maintaining quick feet while tracking your opponent is the quickest way to
  stay with them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29128-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: diving in to steal the ball risks making contact which will result in a foul
  against you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29128-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: use self awareness of your own upper body to pressure an opponent when off the
  ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29128-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: keeping your body upright and agile when marking the ball shows respect for
  the opposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29113-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: striking a kin-ball with your forearm, with hands together and outstretched
  arms, increases power/control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29113-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: sitting on your heel whilst on 1 knee, chest and head down and palms facing
  up, is a solid base to hold the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29113-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think: creating a square around the set ball limits attacking options."@en ;
  dcterms:modified "2026-06-07T15:30:29.300648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29113-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: hitters should rotate so everyone feels included."@en ;
  dcterms:modified "2026-06-07T15:30:29.300651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29113-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connect: players feel supported when teammates help them."@en ;
  dcterms:modified "2026-06-07T15:30:29.300655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23010-1
  a curric:KeyLearningPoint ;
  rdfs:label """Immediate effects of exercise include sweat, red skin, increased rate and depth of
  breathing, and increased heart rate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23010-2
  a curric:KeyLearningPoint ;
  rdfs:label """Methods to recover from exercise include an active cool down, manipulating diet and
  using ice baths or massage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23010-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic exercise results in oxygen debt and the build up of lactic acid that needs
  to be replenished during recovery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27774-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: an accurate underarm action is required to bowl in stoolball."@en ;
  dcterms:modified "2026-06-07T15:30:29.300975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27774-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: changing the dimensions of the pitch or type of equipment used will alter the
  level of challenge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: players of different prior experience, standard and motivation will respond
  differently to different games."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27774-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: empowerment and creativity help when making new and exciting ways to adapt
  games to teach others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27774-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: taking responsibility for teaching a game to a small group, builds
  communication and leadership skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23093-1
  a curric:KeyLearningPoint ;
  rdfs:label """Athletes with a 'win at all costs' mindset may use PEDs to improve performance and
  gain an unfair competitive edge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23093-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anabolic steroids are used to increase muscles mass, train harder and recover from
  exercise quicker."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23093-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beta blockers reduce anxiety and muscle shakes, which can be beneficial for
  precision sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23093-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stimulants impact the central nervous system to reduce fatigue, increase alertness
  and improve reaction times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22882-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: pushing your hips forward will allow your back to land on the cross."@en ;
  dcterms:modified "2026-06-07T15:30:29.301774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keeping the head slightly up and eyes open looking at the toes will prevent
  neck strain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22882-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: timing the upwards momentum of the bounce so the body absorbs impact helps
  you land safely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: believing in your ability and fully committing to the move will decrease the
  risk of injury and increase success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22882-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: supporting less confident peers builds empathy for the supporter and belief
  for the peer being supported."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29481-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: reactions are sped up by performing a split step as the opponent hits the
  ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29481-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: covering the court effectively requires applying advanced speed, reaction
