oakcurric:keylearningpoint-lesson-28666-1
  a curric:KeyLearningPoint ;
  rdfs:label """A hinge joint only allows flexion and extension to occur whereas a ball and socket
  joint allows all types of movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28666-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flexion and extension occur at the shoulder, elbow, hip, wrist and knee joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.432765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28666-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plantar-flexion and dorsi-flexion occur at the ankle."@en ;
  dcterms:modified "2026-06-07T15:30:29.432769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28666-4
  a curric:KeyLearningPoint ;
  rdfs:label "Abduction and adduction occur at the shoulder, wrist and hip joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.432775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28666-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rotation and circumduction only occur at the shoulder, whilst plantar flexion and
  dorsiflexion only occur at the ankle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28847-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mental preparation techniques help people improve their performance by beneficially
  managing their emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mental rehearsal involves imagining a successful performance to improve confidence
  and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28847-3
  a curric:KeyLearningPoint ;
  rdfs:label """Positive self-talk is a method of thinking positively about an upcoming performance
  and your ability to be successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28847-4
  a curric:KeyLearningPoint ;
  rdfs:label """Visualisation and deep breathing are stress management techniques used to lower
  anxiety and arousal levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28846-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mental preparation techniques help performers improve their performance by
  beneficially managing their emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28846-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mental rehearsal involves imagining a successful performance to improve confidence
  and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28846-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery can be used to imagine being in a happy place and can help lower anxiety
  levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28846-4
  a curric:KeyLearningPoint ;
