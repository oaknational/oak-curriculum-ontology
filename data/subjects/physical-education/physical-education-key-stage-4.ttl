  dcterms:modified "2026-06-07T15:30:29.306394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22910-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: keeping others safe by being aware of risks as you move around the school
