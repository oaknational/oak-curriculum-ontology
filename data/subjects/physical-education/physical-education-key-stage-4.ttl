oakcurric:keylearningpoint-lesson-24611-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: appreciating sprint training boosts metabolism by increasing calorie burn
  both during and after exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24611-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: pushing your body hard in short bursts leaves you breathless, muscles burning,
