  dcterms:modified "2026-06-07T15:30:29.275728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24611-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: sprinting requires a relaxed yet vigorous arm swing, with elbows bent at 90
