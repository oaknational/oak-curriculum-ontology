  responsibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29124-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: cardiovascular endurance helps to maintain the correct playing position
  throughout gameplay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29124-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: reacting to open play requires a thorough understanding of the laws of the
