oakcurric:keylearningpoint-lesson-23011-1
  a curric:KeyLearningPoint ;
  rdfs:label """Long-term effects of exercise refer to the benefits/changes in health and fitness
  after a period of regular training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23011-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular exercise leads to increased bone, muscle and joint strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.587005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23011-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular exercise leads to cardiac hypertrophy and increased oxygen carrying capacity
  of the blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23011-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular exercise leads to stronger respiratory muscles and increased lung
  volumes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23011-5
  a curric:KeyLearningPoint ;
  rdfs:label "The body is able to recover faster from exercise after a period of training."@en ;
  dcterms:modified "2026-06-07T15:30:29.587020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28940-1
  a curric:KeyLearningPoint ;
  rdfs:label """Long term effects of exercise refer to the benefits/changes in health and fitness
  after a period of regular training."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28940-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular exercise leads to increased bone, muscle and joint strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.587029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28940-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular exercise leads to cardiac hypertrophy and increased oxygen carrying capacity
  of the blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28940-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular exercise leads to stronger respiratory muscles and increased lung
  volumes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587041Z"^^xsd:dateTime .

