  a curric:KeyLearningPoint ;
  rdfs:label """Move: the ball is pushed with either one or two hands, with a follow through towards
  an intended target."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29126-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: a bounce pass is most effective when a defender is between you and a
