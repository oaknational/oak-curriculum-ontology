oakcurric:keylearningpoint-lesson-28775-1
  a curric:KeyLearningPoint ;
  rdfs:label """Immediate effects of exercise include increased temperature, sweating, heart rate,
  breathing frequency and depth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28775-2
  a curric:KeyLearningPoint ;
  rdfs:label """Short-term effects of exercise include tiredness, fatigue, light-headedness, nausea,
  aching, DOMS and cramp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23095-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hooliganism can be caused by rivalries, hype, alcohol/drugs, gang culture and
  frustration with officials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23095-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies to combat hooliganism include early kick-offs, creating all-seater
  stadiums and segregating fans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23095-3
  a curric:KeyLearningPoint ;
  rdfs:label """Improved security measures, alcohol restrictions and travel restrictions/banning
  orders can address hooliganism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23095-4
  a curric:KeyLearningPoint ;
  rdfs:label """Education, promotional activities, campaigns, and high-profile endorsements can help
  reduce hooliganism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic exercise is exercise that uses oxygen for energy over extended periods, like
  running or cycling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23007-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic exercise is high-intensity exercise that doesn't rely on oxygen, such as
  sprinting or weightlifting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28860-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lactic acid is produced when we exercise anaerobically."@en ;
  dcterms:modified "2026-06-07T15:30:29.585790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28860-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic exercise is when the intensity is too high to provide sufficient oxygen
  for aerobic respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28860-3
  a curric:KeyLearningPoint ;
  rdfs:label "Anaerobic exercise at high intensity can only last a short duration."@en ;
  dcterms:modified "2026-06-07T15:30:29.585800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28860-4
  a curric:KeyLearningPoint ;
  rdfs:label "During recovery respiratory rates remain elevated to remove lactic acid."@en ;
  dcterms:modified "2026-06-07T15:30:29.585804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28803-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lactic acid is produced when we exercise anaerobically."@en ;
  dcterms:modified "2026-06-07T15:30:29.585825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28803-2
  a curric:KeyLearningPoint ;
  rdfs:label """Excess post-exercise oxygen consumption (EPOC) repays the oxygen debt from vigorous
  exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28803-3
  a curric:KeyLearningPoint ;
  rdfs:label """Performers must maintain elevated breathing rates after exercise to repay the oxygen
  debt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28803-4
  a curric:KeyLearningPoint ;
  rdfs:label "A cool down, manipulation of diet and ice baths/massage can help prevent DOMS."@en ;
  dcterms:modified "2026-06-07T15:30:29.585841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28803-5
  a curric:KeyLearningPoint ;
  rdfs:label "DOMS is the delayed onset of muscle soreness."@en ;
  dcterms:modified "2026-06-07T15:30:29.585846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28443-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anatomy and physiology is the study of the structure of the body and how it
  functions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28443-2
  a curric:KeyLearningPoint ;
  rdfs:label """The axial skeleton is a structural framework that contains the cranium, vertebrae,
  ribs and sternum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28443-3
  a curric:KeyLearningPoint ;
  rdfs:label """The appendicular skeleton contains the bones of the upper and lower limbs, the
  scapula, clavicle and pelvis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28443-4
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles attach to bones and work together to create movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.585940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28443-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bones protect vital organs, produce red blood cells and store minerals."@en ;
  dcterms:modified "2026-06-07T15:30:29.585948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28738-1
  a curric:KeyLearningPoint ;
  rdfs:label """The upper body contains muscles such as the deltiod, biceps, triceps, pectorals,
  abdominals and latissimus dorsi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28738-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lower body contains muscles such as the gluteals, quadriceps, hamstrings and
  gastrocnemius."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28738-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles are attached to bones by tendons."@en ;
  dcterms:modified "2026-06-07T15:30:29.585966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28738-4
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles contract and relax to move bones in antagonistic pairs."@en ;
  dcterms:modified "2026-06-07T15:30:29.585971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28738-5
  a curric:KeyLearningPoint ;
  rdfs:label "As one muscle contracts (agonist/prime mover), the other relaxes (antagonist)."@en ;
  dcterms:modified "2026-06-07T15:30:29.585975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28737-1
  a curric:KeyLearningPoint ;
  rdfs:label """The upper body contains muscles such as the deltiod, biceps, triceps, pectorals,
  abdominals and latissimus dorsi."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28737-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lower body contains muscles such as the gluteals, quadriceps, hamstrings and
  gastrocnemius."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28737-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles are attached to bones by tendons."@en ;
  dcterms:modified "2026-06-07T15:30:29.585990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28737-4
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles contract and relax to move bones in antagonistic pairs."@en ;
  dcterms:modified "2026-06-07T15:30:29.585997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28737-5
  a curric:KeyLearningPoint ;
  rdfs:label "As one muscle contracts (agonist/prime mover), the other relaxes (antagonist)."@en ;
  dcterms:modified "2026-06-07T15:30:29.586002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22991-1
  a curric:KeyLearningPoint ;
  rdfs:label "The shape and type of bones determines their function"@en ;
  dcterms:modified "2026-06-07T15:30:29.586010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22991-2
  a curric:KeyLearningPoint ;
  rdfs:label "Short bones are used for fine movements"@en ;
  dcterms:modified "2026-06-07T15:30:29.586015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22991-3
  a curric:KeyLearningPoint ;
  rdfs:label "Long bones are used for gross movements"@en ;
  dcterms:modified "2026-06-07T15:30:29.586020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22991-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flat bones are used for protection of vital organs"@en ;
  dcterms:modified "2026-06-07T15:30:29.586025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22991-5
  a curric:KeyLearningPoint ;
  rdfs:label "Irregular bones are used for protection and muscle attachment"@en ;
  dcterms:modified "2026-06-07T15:30:29.586029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22994-1
  a curric:KeyLearningPoint ;
  rdfs:label """All skeletal muscles are voluntary muscles, they are under our conscious control
  (e.g. biceps)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Involuntary muscles work without our conscious control and include the walls of our
  digestive system and blood vessels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22994-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiac muscle is a specialist type of involuntary muscle that makes up the thickest
  layer of the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22994-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fast twitch muscle fibres with a high speed and force of contraction are used for
  short, intense exercises."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22994-5
  a curric:KeyLearningPoint ;
  rdfs:label """Slow twitch muscle fibres that are resistant to fatigue are used for long distance
  events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22993-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hinge joint only allows flexion and extension to occur."@en ;
  dcterms:modified "2026-06-07T15:30:29.586059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22993-2
  a curric:KeyLearningPoint ;
  rdfs:label "A ball and socket joint allows all types of movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.586064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flexion and extension occur at the shoulder, elbow, hip and knee joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.586069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Abduction and adduction occur at the shoulder and hip joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.586073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22993-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rotation and circumduction only occur at the shoulder, whilst plantar flexion and
  dorsiflexion only occur at the ankle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27909-1
  a curric:KeyLearningPoint ;
  rdfs:label "The shape and type of bones determines their function"@en ;
  dcterms:modified "2026-06-07T15:30:29.586105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27909-2
  a curric:KeyLearningPoint ;
  rdfs:label "Short bones are used for fine movements"@en ;
  dcterms:modified "2026-06-07T15:30:29.586110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27909-3
  a curric:KeyLearningPoint ;
