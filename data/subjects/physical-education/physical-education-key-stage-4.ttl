oakcurric:keylearningpoint-lesson-28987-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sedentary lifestyle can lead to weight gain, obesity and related health issues
  like heart disease and diabetes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28987-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poor sleep, low self-esteem, and lethargy are common consequences of inactivity."@en ;
  dcterms:modified "2026-06-07T15:30:29.276271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28987-3
  a curric:KeyLearningPoint ;
  rdfs:label """Obesity negatively impacts physical performance by limiting stamina, flexibility,
  agility and speed/power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28987-4
  a curric:KeyLearningPoint ;
  rdfs:label """Physically, obesity increases the risk of conditions such as cancer, heart disease
  and high cholesterol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28987-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mentally and socially, obesity can cause depression, loss of confidence, and social
  isolation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23101-1
  a curric:KeyLearningPoint ;
  rdfs:label """An endomorph is characterised by a higher percentage of body fat and a rounder body
  shape"""@en ;
  dcterms:modified "2026-06-07T15:30:29.276831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23101-2
  a curric:KeyLearningPoint ;
  rdfs:label """A mesomorph has a muscular and well-defined body with a natural ability to gain
  muscle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.276834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23101-3
  a curric:KeyLearningPoint ;
  rdfs:label """An ectomorph is characterised by a slim, lean physique with minimal body fat and
  muscle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.276838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23101-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each somatotype has specific advantages for different types of sports or
  positions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: running at a pace which is suited to your personal capabilities will help
  manage your energy and kick finish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23038-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: ‘kicking’ at an ideal moment towards the end of the race will improve finish
  time and overtake opponents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23038-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: constantly assess your condition and position to decide whether and when to
  kick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23038-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: remaining confident and focused on your pacing strategy will ensure you
  perform at your maximal level."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23038-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: encouraging others when they are taking part in their races can motivate
  them to perform at their best."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22961-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: throwing the baton underarm so it spins end-over-end increases the chances of
  successful strikes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22961-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: understanding how to hit another Kubb when throwing back those knocked over
  by your opposition is an advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22961-3
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: visualisation and deep breathing are effective strategies to mentally prepare
  and reduce anxiety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22961-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: mutual respect among team members creates a positive atmosphere and
  encourages cooperation and enjoyment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27772-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: angling the bat down towards the ground when playing defensive shots greatly
  reduces the risk of being caught out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27772-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: batters can leave the ball by remaining still as it passes both them and the
  wicket."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27772-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: remembering to resist the urge to swing for the ball and remain disciplined
  is key to protecting the wicket."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27772-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: protecting the wicket for a long spell and sensing the frustration of the
  fielders is a satisfying feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27772-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: congratulating a long-standing batter at the end of their innings is good
  sporting behaviour and respectful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23107-1
  a curric:KeyLearningPoint ;
  rdfs:label "Extended questions are marked using level descriptors."@en ;
  dcterms:modified "2026-06-07T15:30:29.278417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23107-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 6 mark synoptic question requires content from both exam papers and application
  through practical examples."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23107-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is essential to BUG the question to understand what it is asking."@en ;
  dcterms:modified "2026-06-07T15:30:29.278424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23107-4
  a curric:KeyLearningPoint ;
  rdfs:label "Planning the answer before using the PEE(L) technique achieves the best marks."@en ;
  dcterms:modified "2026-06-07T15:30:29.278428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23012-1
  a curric:KeyLearningPoint ;
  rdfs:label "In our bodies, levers are made from bones, joints, and muscles working together."@en ;
  dcterms:modified "2026-06-07T15:30:29.279657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23012-2
  a curric:KeyLearningPoint ;
  rdfs:label """A lever consists of a fulcrum (joint), the effort (muscle creating the movement) and
  the load (weight or resistance)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23012-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are three lever systems in the human body."@en ;
  dcterms:modified "2026-06-07T15:30:29.279665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22964-1
  a curric:KeyLearningPoint ;
  rdfs:label "Move: when replicating a basic dig or set shot it is key to cushion the ball."@en ;
  dcterms:modified "2026-06-07T15:30:29.279868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22964-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: quick feet allow you to get in a low position behind the ball before
  bending/straightening the knees to add power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22964-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: control comes from a cushioned impact whereas power comes from a clean
  connection with the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22964-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: working independently requires self-discipline and focus."@en ;
  dcterms:modified "2026-06-07T15:30:29.279879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22964-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: showing respect for others by not getting in their way while practising and
  communicating the key techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22902-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: pitchers send the ball directly over home plate and between the batter’s
  armpits and knees, into the strike zone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22902-2
  a curric:KeyLearningPoint ;
  rdfs:label """Think: batters make quick judgements about a pitch’s trajectory to avoid striking
  out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: dropping the bat carefully before running after a fair hit will avoid other
  players getting injured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22902-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: learning skills and rules for a new game from a different culture can be
  exciting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22902-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: by drawing on the experience within a group, you can support each other to
  grasp new rules/techniques/tactics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: sending the shot requires an explosive ‘corkscrew’ sequence from knee to hips
  to chest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23040-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: sit the shot in the fingers to ensure ‘clean palm, dirty neck’ and the elbow
  high to push behind the ball."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23040-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: self-talk in the moments prior to throwing can help increase focus and
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23040-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: commitment to executing the put with maximum force will ensure each thrower’s
  maximal result."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23040-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: using good communication when helping a peer to improve technical errors
  will increase their chance of success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29119-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: picking up a ball from the floor requires a scoop by reaching first in front
  of the ball to prevent a knock-on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29119-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: hold the ball tightly to the chest when being tackled to avoid loss of
  possession."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29119-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: the laws of rugby encourage quick passing and moving to try and evade the
  opposition whilst attacking territory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29119-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: fumbles are reduced with increased time practising ball skills to build
  confidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Connect: clear communication helps prevent handling errors by increasing awareness
  of the location of other players."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28826-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fartlek training is beneficial for sports like football, where players frequently
  change pace and intensity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28826-2
  a curric:KeyLearningPoint ;
  rdfs:label """Continuous training requires aerobic effort for a minimum of 20 minutes, such as
  running, swimming, rowing or cycling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28826-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interval training works in the anaerobic training zone and involes work followed by
  rest periods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: keeping our shoulders relaxed and our posture upright will conserve energy
  when running over longer sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22911-2
  a curric:KeyLearningPoint ;
  rdfs:label """Move: driving the knees high whilst staying tall and pumping the arms will increase
  speed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22911-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: planning who will run where and in what order will help gain an
  advantage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: clear roles and responsibilities will enable everyone to feel a sense of
  belonging."""@en ;
