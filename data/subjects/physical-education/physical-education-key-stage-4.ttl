oakcurric:keylearningpoint-lesson-22925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Think: monitoring the application of rules and skills in a game is an effective
  analysis technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22925-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feel: reflecting on a performance requires a balanced view of positives and
