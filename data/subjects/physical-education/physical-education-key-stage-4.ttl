  dcterms:modified "2026-06-07T15:30:29.275452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22925-1
  a curric:KeyLearningPoint ;
  rdfs:label """Move: moving quickly behind the foot of the tackle triangle will make sure you are
  onside before the next phase of play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22925-2
  a curric:KeyLearningPoint ;
  rdfs:label "Move: running into gaps with speed will support more try scoring opportunities."@en ;
