  dcterms:modified "2026-06-07T15:30:29.333203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22951-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feel: practicing hitting topspin with accuracy builds confidence and resilience."@en ;
