oakcurric:keyword-competition
  a curric:Keyword ;
  schema:name "competition"@en ;
  schema:description """Living organisms struggle for access to limited resources. This struggle is
  known as competition."""@en ;
  dcterms:modified "2026-06-07T15:30:02.386719Z"^^xsd:dateTime .

oakcurric:keyword-catching
  a curric:Keyword ;
  schema:name "catching"@en ;
  schema:description "to take hold of something that is thrown"@en ;
  dcterms:modified "2026-06-07T15:30:02.386844Z"^^xsd:dateTime .

oakcurric:keyword-listen
  a curric:Keyword ;
  schema:name "listen"@en ;
  schema:description "to pay close attention to words and sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.386849Z"^^xsd:dateTime .

oakcurric:keyword-suggest
  a curric:Keyword ;
  schema:name "suggest"@en ;
  schema:description "offer an idea or a plan that can be tried out"@en ;
  dcterms:modified "2026-06-07T15:30:02.386856Z"^^xsd:dateTime .

oakcurric:keyword-following
  a curric:Keyword ;
  schema:name "following"@en ;
  schema:description "moving in the same direction or copying"@en ;
  dcterms:modified "2026-06-07T15:30:02.387966Z"^^xsd:dateTime .

oakcurric:keyword-tuck
  a curric:Keyword ;
  schema:name "tuck"@en ;
  schema:description """bringing your knees into your chest, in the air, to hold the position
  tightly"""@en ;
  dcterms:modified "2026-06-07T15:30:02.388137Z"^^xsd:dateTime .

oakcurric:keyword-pushing
  a curric:Keyword ;
  schema:name "pushing"@en ;
  schema:description "moving a ball with your racket"@en ;
  dcterms:modified "2026-06-07T15:30:02.389417Z"^^xsd:dateTime .

oakcurric:keyword-winning
  a curric:Keyword ;
  schema:name "winning"@en ;
  schema:description "scoring more goals, tries, points than your opponents"@en ;
  dcterms:modified "2026-06-07T15:30:02.390160Z"^^xsd:dateTime .

oakcurric:keyword-together
  a curric:Keyword ;
  schema:name "together"@en ;
  schema:description "working in cooperation with others to undertake a task"@en ;
  dcterms:modified "2026-06-07T15:30:02.391537Z"^^xsd:dateTime .

oakcurric:keyword-curled
  a curric:Keyword ;
  schema:name "curled"@en ;
  schema:description """an action we perform by rolling our body up tightly in a tucked position
  with a rounded back"""@en ;
  dcterms:modified "2026-06-07T15:30:02.392524Z"^^xsd:dateTime .

oakcurric:keyword-hitting
  a curric:Keyword ;
  schema:name "hitting"@en ;
  schema:description "to reach or strike something in order to score in a game"@en ;
  dcterms:modified "2026-06-07T15:30:02.392958Z"^^xsd:dateTime .

oakcurric:keyword-quartet
  a curric:Keyword ;
  schema:name "quartet"@en ;
  schema:description "a performance by four people"@en ;
  dcterms:modified "2026-06-07T15:30:02.393882Z"^^xsd:dateTime .

oakcurric:keyword-wide
  a curric:Keyword ;
  schema:name "wide"@en ;
  schema:description "actions we perform when our arms and legs are outstretched"@en ;
  dcterms:modified "2026-06-07T15:30:02.394447Z"^^xsd:dateTime .

oakcurric:keyword-racket-head
  a curric:Keyword ;
  schema:name "racket head"@en ;
  schema:description "the top part of a tennis or badminton racket, where the strings are"@en ;
  dcterms:modified "2026-06-07T15:30:02.395113Z"^^xsd:dateTime .

oakcurric:keyword-attackers
  a curric:Keyword ;
  schema:name "attackers"@en ;
  schema:description "the team who is trying score as many points as possible"@en ;
  dcterms:modified "2026-06-07T15:30:02.395882Z"^^xsd:dateTime .

oakcurric:keyword-react
  a curric:Keyword ;
  schema:name "react"@en ;
  schema:description "how you respond or what you do when something happens"@en ;
  dcterms:modified "2026-06-07T15:30:02.395890Z"^^xsd:dateTime .

oakcurric:keyword-communicating
  a curric:Keyword ;
  schema:name "communicating"@en ;
  schema:description "sharing ideas, thoughts or feelings with others"@en ;
  dcterms:modified "2026-06-07T15:30:02.395895Z"^^xsd:dateTime .

oakcurric:keyword-mind
  a curric:Keyword ;
  schema:name "mind"@en ;
  schema:description """the part of a person that thinks, understands, remembers, directs
  and feels"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396769Z"^^xsd:dateTime .

oakcurric:keyword-take-turns
  a curric:Keyword ;
  schema:name "take turns"@en ;
  schema:description "doing something one after another"@en ;
  dcterms:modified "2026-06-07T15:30:02.396806Z"^^xsd:dateTime .

oakcurric:keyword-jumping
  a curric:Keyword ;
  schema:name "jumping"@en ;
  schema:description """using your legs to push yourself up off the ground and into the air for a
  moment"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400473Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-safari-animals-zoo
  a curric:Misconception ;
  curric:statement "There are only safari animals at the zoo."@en ;
  curric:correction """In a zoo, there can often be farm animals, insects, birds and smaller animals
  like frogs too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086116Z"^^xsd:dateTime .

oakcurric:misconception-balances-held-using-one-body
  a curric:Misconception ;
  curric:statement "Balances are held using just on one body part."@en ;
  curric:correction "Balances can be performed on up to 5 body parts at a time."@en ;
  dcterms:modified "2026-06-07T15:30:15.086225Z"^^xsd:dateTime .

oakcurric:misconception-sequence-one-balance-performed-another
  a curric:Misconception ;
  curric:statement "A sequence is one balance performed after another."@en ;
  curric:correction """Sequences need to have linking moves for the balances to flow and for the
  sequence to look good."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086234Z"^^xsd:dateTime .

oakcurric:misconception-dance-music
  a curric:Misconception ;
  curric:statement "Dance has to be to music."@en ;
  curric:correction "Dance can tell stories and actions can be linked to words not just music."@en ;
  dcterms:modified "2026-06-07T15:30:15.086291Z"^^xsd:dateTime .

oakcurric:misconception-dont-change-your-power-knock
  a curric:Misconception ;
  curric:statement "You don't have to change your power to knock over different targets."@en ;
  curric:correction "To knock over specific targets you may need to add a bit more power."@en ;
  dcterms:modified "2026-06-07T15:30:15.086493Z"^^xsd:dateTime .

oakcurric:misconception-superheroes-spend-their-time-superheroes
  a curric:Misconception ;
  curric:statement "Superheroes spend all their time as superheroes."@en ;
  curric:correction """Superheroes often have a normal human life until the world needs saving and
  that is when they transform into superheroes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086538Z"^^xsd:dateTime .

oakcurric:misconception-think-animals-move-same-way
  a curric:Misconception ;
  curric:statement """You may think that all animals move in the same way or have the same
  personality."""@en ;
  curric:correction """Animals move differently and show different characteristics. For example, a
  lion is strong and proud, while a butterfly is gentle and light. Their movements should
  look and feel different when we dance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087203Z"^^xsd:dateTime .

oakcurric:misconception-everyone-move-same-way-jungle
  a curric:Misconception ;
  curric:statement "Everyone will always move the same way through a jungle."@en ;
  curric:correction """Different people might feel different emotions when walking through a
  jungle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087376Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-push-ball-hard
  a curric:Misconception ;
  curric:statement """Some pupils may think they have to push the ball very hard to make it roll
  accurately."""@en ;
  curric:correction "Using a gentle, controlled push helps the ball roll in a straight line."@en ;
  dcterms:modified "2026-06-07T15:30:15.087382Z"^^xsd:dateTime .

oakcurric:misconception-competitive-against-someone-else
  a curric:Misconception ;
  curric:statement "You can only be competitive if you are against someone else."@en ;
  curric:correction """You can also be competitive against yourslef by trying to beat your last
  score or best number of points so far."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087620Z"^^xsd:dateTime .

oakcurric:misconception-good-movement-ideas-stay-same
  a curric:Misconception ;
  curric:statement "Good movement ideas stay at the same level."@en ;
  curric:correction """Moving at different levels challenges the body and encourages the development
  of ideas and self-belief to try new and challenging movements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087654Z"^^xsd:dateTime .

oakcurric:misconception-dance-requires-music
  a curric:Misconception ;
  curric:statement "Dance always requires music."@en ;
  curric:correction """You can still perform dance actions without music if you do not have access
  to it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087729Z"^^xsd:dateTime .

oakcurric:misconception-dont-play-rules-game-playing
  a curric:Misconception ;
  curric:statement """You don't have to play by the rules of the game if you are playing by
  yourself."""@en ;
  curric:correction """Even if you are playing by yourself, you should play by the rules of the game
  to show fairness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087746Z"^^xsd:dateTime .

oakcurric:misconception-kinds-jumps-require-same-technique
  a curric:Misconception ;
  curric:statement "All kinds of jumps require the same technique."@en ;
  curric:correction """Jumping for height and distance require different upper body positions and
  different directions of arm movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087812Z"^^xsd:dateTime .

oakcurric:misconception-throwing-same-foot-forward-throwing
  a curric:Misconception ;
  curric:statement "Throwing with the same foot forward as the throwing hand."@en ;
  curric:correction """Use the opposite foot to the throwing hand for better balance and
  accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088209Z"^^xsd:dateTime .

oakcurric:misconception-movement-using-established-methods-travel
  a curric:Misconception ;
  curric:statement """Movement using established methods of travel is the best way to get from A to
  B."""@en ;
  curric:correction """Everyone moves differently and some people may be more successful and find
  more joy moving in a different way to others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088480Z"^^xsd:dateTime .

oakcurric:misconception-long-extended-strides-needed-run
  a curric:Misconception ;
  curric:statement "Long extended strides are needed to run fast."@en ;
  curric:correction """Long but comfortable and natural strides are more important to stay relaxed
  and in control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088939Z"^^xsd:dateTime .

oakcurric:misconception-useful-take-big-backswing-throwing
  a curric:Misconception ;
  curric:statement "It is always useful to take a big backswing when throwing an object."@en ;
  curric:correction """When throwing a short distance, it is useful to reduce your backswing so you
  are more accurate and don't apply too much power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089348Z"^^xsd:dateTime .

oakcurric:misconception-beat-rhythm-same-thing
  a curric:Misconception ;
  curric:statement "Beat and rhythm are the same thing."@en ;
  curric:correction """The beat is the playing or showing of the steady pulse, while the the rhythm
  is a pattern of sounds we play or sing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089657Z"^^xsd:dateTime .

oakcurric:misconception-peer-feedback-refers-liking-jumps
  a curric:Misconception ;
  curric:statement """Peer feedback refers to liking jumps rather than the quality of skills. Pupils
  only practice one combination of skills. Pupils think they will be judged negatively in
  their performance."""@en ;
  curric:correction """Model good feedback, referring to the quality of skills. Encourage pupils to
  move around the apparatus trying a range of combinations. Encourage pupils to ensure this
  is a positive experience for all and that they should talk kindly to one another."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093656Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dominate-partnership
  a curric:Misconception ;
  curric:statement "Some pupils might dominate the partnership."@en ;
  curric:correction """Cooperation and communication are key factors in any partnership: they must
  share roles and listen to one another's ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093662Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-trying-your-best
  a curric:Misconception ;
  curric:statement """Some pupils might think that trying your best means doing every role within a
  team."""@en ;
  curric:correction """Trying to do everything for a team is admirable, but one person can get tired
  quickly and someone else might also be more skilled at doing it. If everyone gives their
  best effort in their role, the combined effort can be very successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094113Z"^^xsd:dateTime .

oakcurric:misconception-pathways-along-floor
  a curric:Misconception ;
  curric:statement "Pathways are only along the floor."@en ;
  curric:correction """Pathways can be along the floor or in the air. They can also be called floor
  patterns and air patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095179Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-need-kick-ball
  a curric:Misconception ;
  curric:statement """Pupils believe that they need to kick the ball as hard as possible to make a
  good pass, leading to a loss of control."""@en ;
  curric:correction """Emphasise the importance of accuracy over power and that pupils need to be
  able to kick the ball where they want it to go first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095520Z"^^xsd:dateTime .

oakcurric:misconception-body-balanced-still-pupils-find
  a curric:Misconception ;
  curric:statement """The body is only balanced when it is still. Pupils find it difficult to
  balance still."""@en ;
  curric:correction """The body is always balancing whether it is still or moving (static and
  dynamic balances), but focusing on stillness allows pupils to show control in a static
  balance and feel stable. Try focusing on a fixed spot ahead of you to help keep still."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096067Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stand-1-leg-asked
  a curric:Misconception ;
  curric:statement """Pupils only stand on 1 leg when asked to add a balance, or perform a straight
  jump off apparatus."""@en ;
  curric:correction """Encourage creativity by suggesting balances on different body parts or at
  different levels and remind them of a variety of jumps. Celebrate creativity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096073Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-balancing-staying-completely
  a curric:Misconception ;
  curric:statement """Some pupils may think that balancing is only about staying completely
  still."""@en ;
  curric:correction """Activities such as riding a bike, skateboarding, surfing, throwing darts,
  basketball shooting, long jump etc., all need a well-balanced and controlled body position
  whilst the athlete is still moving."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096078Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-use-their-arms
  a curric:Misconception ;
  curric:statement """Pupils will forget to use their arms and/or focus forwards when running into
  spaces. Pupils will run out of the area to avoid being tagged."""@en ;
  curric:correction """Explain and demonstrate running into space staying within the area. Explain
  the consequences of running off the court or pitch in a game. Model the correct technique
  for running and explain why it is important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096084Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-working-team-everyone
  a curric:Misconception ;
  curric:statement """Some pupils may think that when they are working in a team, everyone should
  stay together and do the same thing."""@en ;
  curric:correction """Sometimes, a good tactic to quickly complete a challenge is to split the
  challenge into smaller tasks and share them out amongst the team. A team can still be
  working towards the same goal, even if everyone is working separately on different tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096095Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-crawling-actions-move
  a curric:Misconception ;
  curric:statement """Pupils only use crawling actions to move over or under the apparatus. When
  reflecting on others' practice, pupils only say whether they liked or disliked their
  movements."""@en ;
  curric:correction """Give pupils other ideas to perform under apparatus, such as balance, swing,
  or slide, and other ideas to perform over apparatus, such as sliding or balancing on top
  or jumping over. Encourage pupils to be specific when reflecting on others' actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096817Z"^^xsd:dateTime .

oakcurric:misconception-briskly-means-fast-run
  a curric:Misconception ;
  curric:statement "'Briskly' means fast, so you can run."@en ;
  curric:correction "'Briskly' means quick and energetic. This does not include running."@en ;
  dcterms:modified "2026-06-07T15:30:15.097173Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-balance-fixed-skill
  a curric:Misconception ;
  curric:statement """Some pupils may think that balance is a fixed skill that you are either good
  at or not."""@en ;
  curric:correction """There are many elements to balance: working on all of these elements
  contributes to overall improvement. Improving focus and concentration can help, along with
  developing muscular strength, proprioception and self-belief."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097181Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-techniques-leaping-jumping
  a curric:Misconception ;
  curric:statement """Pupils confuse the techniques for leaping and jumping. Pupils focus on not
  being tagged and forget to jump or leap properly."""@en ;
  curric:correction """Demonstrate both techniques. Explain the importance of using the correct
  technique and demonstrate. Bring in a rule that if pupils run instead of using their
  jumping skills, they have 'tagged' themselves and must stop and perform 5 star jumps."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097187Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-perform-dodge
  a curric:Misconception ;
  curric:statement """Pupils might think they need to perform a dodge as soon as they see a
  defender."""@en ;
  curric:correction """Performing a dodge too early gives the defender time to react and move with
  you (shadow you). Performing a dodge too late means you don't have space to use the best
  technique for your dodge. The right timing will help you avoid the defender."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097193Z"^^xsd:dateTime .

oakcurric:misconception-pupils-push-hit-their-partner
  a curric:Misconception ;
  curric:statement """Pupils push or hit their partner too hard when they are the chaser. Pupils
  bump into each other playing tag."""@en ;
  curric:correction """Teach pupils how to tag and remind them to tap gently. Remind pupils to slow
  down or dodge to avoid collisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097204Z"^^xsd:dateTime .

oakcurric:misconception-traditional-dance-styles-people-country
  a curric:Misconception ;
  curric:statement "Traditional dance styles are how all the people in that country dance."@en ;
  curric:correction """Traditional dance styles are still danced by some people in their communities
  on certain occasions. They will also dance other styles too and these will change
  depending on whether they are in a theatre, temple or at a social event."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097586Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-their-ability-jump
  a curric:Misconception ;
  curric:statement """Some pupils might think that their ability to jump far is fixed and cannot be
  changed or improved."""@en ;
  curric:correction """Everyone is capable of improving their performance. Practice, developing a
  good technique and showing self-belief can all help us to improve."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098362Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-concentrate-dont-realise
  a curric:Misconception ;
  curric:statement """Pupils don't concentrate, so they don't realise when it is their turn. Other
  team members shout at them to take their turn."""@en ;
  curric:correction """Encourage players to pay attention to their team so they know when it's their
  turn. Other team members can kindly prompt them if they miss their turn."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098367Z"^^xsd:dateTime .

oakcurric:misconception-mirroring-copying-same
  a curric:Misconception ;
  curric:statement "Mirroring and copying are the same"@en ;
  curric:correction """Mirroring is a type of copying, it specifically requires the movement to be
  translated to the opposite side of the body to produce the effect of a reflection. Copying
  can be a direct replication of the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098637Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-linear-pathways-follow
  a curric:Misconception ;
  curric:statement "Pupils think that linear pathways should follow the outline of the room."@en ;
  curric:correction """Whilst there is an obvious logic to using the orientation and basic shape of
  the room, linear pathways can bisect the space in any way. They must simply be straight
  lines."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098698Z"^^xsd:dateTime .

oakcurric:misconception-pupils-run-area-avoid-tagged
  a curric:Misconception ;
  curric:statement "Pupils run out of the area to avoid being tagged."@en ;
  curric:correction """Explain the consequences of running out of the area and the fact it will
  limit the points they score."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098864Z"^^xsd:dateTime .

oakcurric:misconception-narrow-actions-vertical-pupils-perform
  a curric:Misconception ;
  curric:statement """Narrow actions are always vertical. Pupils perform gymnastics actions in
  silence to be well-behaved. Pupils show empathy to others only by saying that they like
  their movements and balances."""@en ;
  curric:correction """Narrow actions can be vertical or horizontal. Pupils perform gymnastics
  actions in silence to show good control. Encourage pupils to say why they liked others'
  gymnastics and to suggest improvements or new ideas by communicating kindly with respect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099230Z"^^xsd:dateTime .

oakcurric:misconception-pupils-panic-receiving-ball-game
  a curric:Misconception ;
  curric:statement """Pupils can panic when receiving the ball in a game situation and rush to throw
  it away. Pupils all run towards the ball carrier rather than finding space."""@en ;
  curric:correction """Emphasise the importance of finding space and looking around to understand
  what to do when receiving the ball. Make sure they understand they have time to react and
  think before sending the ball on to their teammates."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099235Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-using-their-hands-pupils
  a curric:Misconception ;
  curric:statement """When dribbling using their hands, pupils use the tips of their fingers or
  their palms to push the ball towards the floor."""@en ;
  curric:correction """Ensure pupils are using the flat part of their fingertips to push the ball
  towards the floor."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099261Z"^^xsd:dateTime .

oakcurric:misconception-pupils-jump-their-whole-body
  a curric:Misconception ;
  curric:statement """Pupils jump up with their whole body for bunny jumps. Pupils hold on to each
  other to support them. Pupils do not hold balances for long enough."""@en ;
  curric:correction """Model correct bunny jumps with hands moving first, then feet moving to hands,
  and repeat. Provide examples of words and advice pupils can use to support each other.
  Encourage pupils to hold balances for at least 3 seconds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101036Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-standing-create-letter
  a curric:Misconception ;
  curric:statement """Pupils think they must be standing up to create letter shapes. When creating
  words, pairs make their letter shapes in the wrong order, or facing the wrong way, so that
  the whole word is not seen."""@en ;
  curric:correction """Letter shapes can be formed standing or lying down. Encourage teams to
  imagine that they are another team looking at their word, are all letters in the correct
  order and facing the same direction?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.101077Z"^^xsd:dateTime .

oakcurric:misconception-pupils-perform-quality-actions-because
  a curric:Misconception ;
  curric:statement """Pupils do not perform quality actions because they don't point their toes.
  They either pull their toes towards their body, so their ankle is 90 degrees, or their
  foot is in a relaxed position."""@en ;
  curric:correction """Some pupils will need to be taught how to point their toes. Remind them to
  push their feet away, making their legs look longer. Practice with everyone at the
  beginning of the lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101273Z"^^xsd:dateTime .

oakcurric:misconception-pupils-jump-high-lose-quality
  a curric:Misconception ;
  curric:statement """Pupils jump too high and lose the quality of shapes. Pupils jump too far
  around in a half-turn jump and lose control of their landing. Pupils round backs on
  landing, causing hands to touch the floor."""@en ;
  curric:correction """Celebrate clear shapes over jumps that are too high. Spend time teaching what
  'half-turn' means, reminding pupils to start facing one direction and end facing the
  opposite direction. Remind pupils to keep their backs straight so they land upright."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101278Z"^^xsd:dateTime .

oakcurric:misconception-using-their-fingertips-bounce-ball
  a curric:Misconception ;
  curric:statement """When using their fingertips to bounce the ball, pupils use the ends of their
  fingers."""@en ;
  curric:correction """Ensure that pupils understand that using the fingertips refers to the flat
  part at the top of their fingers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102058Z"^^xsd:dateTime .

oakcurric:misconception-performance-whole-class
  a curric:Misconception ;
  curric:statement "A performance should be to the whole class."@en ;
  curric:correction """Performing can be to another person, duet or group. This can feel less
  daunting and is a good way to get feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102064Z"^^xsd:dateTime .

oakcurric:misconception-pretend-object-such-car-use
  a curric:Misconception ;
  curric:statement "To pretend to be an object such as a car, we have to use mime."@en ;
  curric:correction """Miming is one way of describing an object, theme or story to an audience
  without using words. You will need to use your imagination to think of other ways that the
  audience will also understand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102069Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-their-arms-communicate
  a curric:Misconception ;
  curric:statement "The pupils will only use their arms to communicate swirling snow."@en ;
  curric:correction """Whilst arms offer a range of possible responses to suggest snow, guiding
  pupils to less conventional ideas such as a hip or an ear, pupils will respond with a far
  wider range of actions, building flexibility, control and coordination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102075Z"^^xsd:dateTime .

oakcurric:misconception-pupils-perform-gymnastics-silence-show
  a curric:Misconception ;
  curric:statement """Pupils perform gymnastics in silence to show good behaviour. Pupils don't use
  the floor as part of the apparatus when practicing skills."""@en ;
  curric:correction """Pupils perform gymnastics in silence to demonstrate good control. Pupils
  should use the floor and the equipment to practice and perform their skills."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102530Z"^^xsd:dateTime .

oakcurric:misconception-competitive-situations-pupils-struggle-apply
  a curric:Misconception ;
  curric:statement """In competitive situations, pupils can struggle to apply the correct technique
  to their actions. Pupils struggle to follow the rules of a game when trying to win."""@en ;
  curric:correction """Encourage pupils to focus on applying the correct technique when rolling and
  stopping the ball. Ensure pupils follow the rules and understand the importance of playing
  with honesty."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102535Z"^^xsd:dateTime .

oakcurric:misconception-pupils-focus-solely-their-arm
  a curric:Misconception ;
  curric:statement """Pupils focus solely on their arm movements and neglect the use of their legs
  and hips to create power."""@en ;
  curric:correction """Ensure pupils understand how that bending their knees and rotating their hips
  can create more power for bigger hits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102541Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-successful-strategies-need
  a curric:Misconception ;
  curric:statement """Some pupils might think that successful strategies need to be very
  complicated."""@en ;
  curric:correction """Simple strategies are usually most successful because everyone on the team
  can be clear about what they have to do and can do their part very easily and quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102782Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performing-mirroring-duets
  a curric:Misconception ;
  curric:statement """Pupils think that when performing mirroring duets they should remain on the
  spot."""@en ;
  curric:correction """Mirroring duets typically remain in situ (and may need to for safety reasons
  e.g. in a small space), but they should be encouraged to lean towards or away from their
  partner, as well as move sideways to prevent the work from becoming purely gestural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102788Z"^^xsd:dateTime .

oakcurric:misconception-travelling-whole-body-movement-involves
  a curric:Misconception ;
  curric:statement """Travelling is only a whole-body movement and involves moving around the space
  available."""@en ;
  curric:correction """Travelling can be either a whole body action or be performed by isolated body
  parts. As well as moving around the space it can also involve going up and down as well as
  turning on the spot."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102794Z"^^xsd:dateTime .

oakcurric:misconception-pupils-neglect-value-need-teamwork
  a curric:Misconception ;
  curric:statement """Some pupils neglect the value of, and need for teamwork, opting to try and
  dribble the ball each time they receive it."""@en ;
  curric:correction """Encourage pupils to make the correct decisions as when to pass and when to
  dribble. Also ensure to implement rules where all pupils must touch the ball before
  scoring."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103496Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-strike-requires-maximum
  a curric:Misconception ;
  curric:statement "Pupils believe that every strike requires maximum power to be good."@en ;
  curric:correction """Explain that different situations need different amounts of power, such as a
  shorter strike. Encourage pupils to also think about technique as well as power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103504Z"^^xsd:dateTime .

oakcurric:misconception-performance-needs-stage-theatre
  a curric:Misconception ;
  curric:statement "A performance needs to be on a stage, at a theatre."@en ;
  curric:correction """Performing is where we show our work to another, it might be on a stage, but
  equally it can be a part of the lesson where we share ideas, thoughts and opinions so that
  we can all improve."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103510Z"^^xsd:dateTime .

oakcurric:misconception-success-means-performing-actions-perfectly
  a curric:Misconception ;
  curric:statement """Success means performing actions perfectly. Pupils land a jump, and their
  hands touch the floor."""@en ;
  curric:correction """Success refers to progress relative to a starting point. Any improvements to
  actions should be viewed as successful. Remind pupils to land with straight backs (not
  rounded) to help them 'land and stand' when they land a jump."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103515Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stand-making-letter-shapes
  a curric:Misconception ;
  curric:statement "Pupils can only stand when making letter shapes."@en ;
  curric:correction "Pupils can lie, sit, or stand to make letter shapes."@en ;
  dcterms:modified "2026-06-07T15:30:15.103873Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fast-heartbeat-makes
  a curric:Misconception ;
  curric:statement """Some pupils may think that a fast heartbeat makes the body move faster rather
  than it being a response to exercise i.e. the heart acts like an engine and a fast
  heartbeat makes you run fast."""@en ;
  curric:correction """Your heartbeat usually changes because of an action or a feeling. When you do
  exercise, you need it to pump more blood to your muscles for energy so it changes its
  speed because of your exercising actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103932Z"^^xsd:dateTime .

oakcurric:misconception-pupils-throw-ball-focusing-throwing
  a curric:Misconception ;
  curric:statement """Pupils throw the ball focusing on throwing it hard and high, instead of
  passing with accuracy."""@en ;
  curric:correction "Ensure pupils understand that a pass requires control and accuracy."@en ;
  dcterms:modified "2026-06-07T15:30:15.104757Z"^^xsd:dateTime .

oakcurric:misconception-dance-performances-include-repetition-ideas
  a curric:Misconception ;
  curric:statement "That dance performances do not include repetition of ideas."@en ;
  curric:correction """Repeating movement material in a dance is similar to the use of a chorus in a
  song, it emphasises the main idea and prevents the audience from being overwhelmed.
  Repetitions are usually varied or developed in some way to maintain interest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104784Z"^^xsd:dateTime .

oakcurric:misconception-pupils-queue-their-favourite-piece
  a curric:Misconception ;
  curric:statement """Pupils queue for their favourite piece of apparatus. After a jump, pupils
  don't hold the landing position for long enough. Pupils jump from wall bars or climbing
  frames."""@en ;
  curric:correction """Encourage pupils to use all of the apparatus and find ways to enter and exit
  the apparatus rather than waiting in a queue. Tell pupils to 'land and stand' after a jump
  and hold still for 2 seconds. Tell pupils they can only jump from a flat surface."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104790Z"^^xsd:dateTime .

oakcurric:misconception-performing-sequences-pupils-perform-many
  a curric:Misconception ;
  curric:statement """When performing sequences, some pupils perform too many actions, the sequence
  goes on for far too long and quality can be lost."""@en ;
  curric:correction """Remind pupils that sequences should have a beginning, a middle and an end so
  they can remember and repeat it. It is better to have a short, high quality sequence than
  a long, low quality one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104796Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-cheer-congratulate-success
  a curric:Misconception ;
  curric:statement """Some pupils might think that you should only cheer and congratulate success,
  e.g., scoring a point or beating an opponent."""@en ;
  curric:correction """All players, on all teams, should be cheered and congratulated for their
  effort, regardless of who scores the points, who wins or which team they are playing for."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104821Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-teams-successful-score
  a curric:Misconception ;
  curric:statement """Some pupils might think that teams are only successful if they score the most
  points or beat their opposition when they compete."""@en ;
  curric:correction """Competing successfully can be measured in different ways. Scoring the most
  points or goals is one measure. Including all team members, playing fairly or bringing
  positivity are all equally important ways of being successful when competing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105147Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-once-solution-found
  a curric:Misconception ;
  curric:statement """Some pupils might think that once a solution has been found to complete a
  challenge, this is the only option that should be used."""@en ;
  curric:correction """Many challenges and problems have various different solutions. One solution
  might suit the skills in your team and a different solution might suit another team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105175Z"^^xsd:dateTime .

oakcurric:misconception-pupils-throw-ball-high-throw
  a curric:Misconception ;
  curric:statement """Pupils throw the ball up too high or throw overarm and then blame their
  partner for being unable to catch it."""@en ;
  curric:correction """Encourage underarm throwing, using gentle passes so the ball makes a rainbow
  shape in the air. Remind pupils that teamwork requires all individuals to work together
  and encouraging others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106156Z"^^xsd:dateTime .

oakcurric:misconception-pupils-lean-backwards-teddy-bear
  a curric:Misconception ;
  curric:statement """Pupils lean backwards in a teddy bear roll, ending up on their back and
  getting stuck there."""@en ;
  curric:correction """Stress the importance of leaning to the side (left or right) on a shoulder
  and placing it close to their knee to start the action, then lifting the opposite leg (not
  both) to help you face the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106192Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-moving-high-means
  a curric:Misconception ;
  curric:statement """Pupils think that moving high only means traveling on tiptoes. Pupils focus on
  the task rather than good movements. Pupils do not hold their balances for long enough."""@en ;
  curric:correction """Celebrate the different ways pupils move high. Remind pupils to move silently
  with control, pointing fingers and toes. Encourage pupils to hold balances for at least 3
  seconds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106217Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-follow-stop-their
  a curric:Misconception ;
  curric:statement """Some pupils forget to follow through and stop their racket immediately after
  hitting the ball."""@en ;
  curric:correction """Ensure pupils understand that a proper follow through, towards the target, is
  crucial for both power and accuracy. Remind them if you see the racket stopping too early
  or ending up pointing to the sky or to the ground."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106223Z"^^xsd:dateTime .

oakcurric:misconception-moving-space-defenders-pupils-panic
  a curric:Misconception ;
  curric:statement """When moving into space and away from defenders, pupils panic and rush which
  causes them to lose control of their ball."""@en ;
  curric:correction """Highlight the importance of always moving with control, even if it means
  moving a little slower at first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107053Z"^^xsd:dateTime .

oakcurric:misconception-lesson-pupils-believe-stop-ball
  a curric:Misconception ;
  curric:statement """In this lesson, pupils may believe they can stop the ball with any part of
  their body."""@en ;
  curric:correction "Encourage pupils to use their hands to stop the ball rolling."@en ;
  dcterms:modified "2026-06-07T15:30:15.107075Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-creating-actions-communicate
  a curric:Misconception ;
  curric:statement """Pupils think that creating actions that communicate wind involves running fast
  for strong wind and walking slow for a light breeze."""@en ;
  curric:correction """We can create actions using changes in size, levels and direction including
  travelling and creating shapes to communicate wind."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107087Z"^^xsd:dateTime .

oakcurric:misconception-pupils-grip-object-hard-hold
  a curric:Misconception ;
  curric:statement """Pupils grip the object too hard and hold onto it too long, releasing it too
  late."""@en ;
  curric:correction """Encourage pupils to use a relaxed grip for better control. Model to pupils
  the correct timing for releasing the object for greater accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107669Z"^^xsd:dateTime .

oakcurric:misconception-pupils-run-instead-hopping-skipping
  a curric:Misconception ;
  curric:statement """Pupils run instead of hopping or skipping. Pupils get upset if points are
  being lost in games (beanbags are taken by the Zookeepers)."""@en ;
  curric:correction """Remind pupils that running is a rule break and celebrate pupils who are
  hopping/skipping not running."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108438Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performing-one-dodge
  a curric:Misconception ;
  curric:statement "Pupils might think that performing one dodge will always be successful."@en ;
  curric:correction """Pupils should remember that the defender will respond to the dodge. Pupils
  might need to dodge again if the defender guesses which way they will dodge and block
  their run into space or another defender might move into the space they are running to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108510Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-someone-designated-team
  a curric:Misconception ;
  curric:statement """Pupils may think that if someone has been designated to a team, this means
  they have been included."""@en ;
  curric:correction """People can feel excluded even when they're part of a team if they are ignored
  or not included in the decisions being made. There are many things that you can do to help
  your teammates to feel included and valued in the team."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108544Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-able-sprint-fast
  a curric:Misconception ;
  curric:statement """Some pupils may think that being able to sprint fast will always make them
  successful in a game or activity."""@en ;
  curric:correction """Being agile involves more than running quickly in one direction. Being on the
  balls of our feet, rotating our hips and using different footwork can help us to move
  quickly, react appropriately, and change direction so that we are successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110096Z"^^xsd:dateTime .

oakcurric:misconception-dance-pretending-subject-creating-dance
  a curric:Misconception ;
  curric:statement """In dance we are pretending to 'be' the subject we are creating a dance
  about."""@en ;
  curric:correction """In dance we use the subject to help us think of movements that show what it
  is like. Pretending to be something is a drama skill that is used in some, but not all
  dance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110102Z"^^xsd:dateTime .

oakcurric:misconception-pupils-stand-still-receiving-ball
  a curric:Misconception ;
  curric:statement """Pupils just stand still when receiving the ball, not understanding the
  importance of positioning."""@en ;
  curric:correction """Encourage pupils to understand the importance of moving towards the ball and
  getting set when receiving it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110124Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sport-physical-activity
  a curric:Misconception ;
  curric:statement """Pupils may think that sport and physical activity is all about competing and
  winning."""@en ;
  curric:correction """Moving and exercising is an important part of daily life, not just for
  organised competition. Exercising can be done for fun and is important to help our bodies
  and minds to stay healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111158Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confusing-techniques-hopping-skipping
  a curric:Misconception ;
  curric:statement """Pupils are confusing the techniques for hopping and skipping and sometimes run
  instead."""@en ;
  curric:correction """Remind pupils that running is a rule break. Celebrate pupils who are hopping
  not running and demonstrate both techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111178Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-land-controlled-way
  a curric:Misconception ;
  curric:statement """Pupils don't land in a controlled way. Pupils don't focus forwards or use
  their arms when they jump."""@en ;
  curric:correction """Demonstrate an effective jump with a controlled landing. Explain and
  demonstrate jumping by swinging the arms up then down and while focusing forwards."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111203Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-realise-its-their
  a curric:Misconception ;
  curric:statement "Pupils don't realise it's their turn to move."@en ;
  curric:correction """Players stand on a 'next player' floor marker to help them to know who's turn
  it is next. Remind pupils to encourage each other with kind words when it's their turn."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112022Z"^^xsd:dateTime .

oakcurric:misconception-pupils-move-limited-incorrect-arm
  a curric:Misconception ;
  curric:statement """Pupils move with limited or incorrect arm action such as punching their arms
  forwards. Pupils often run flat footed and look around at others while running instead of
  focusing forwards."""@en ;
  curric:correction """Tell pupils to run with pumping arms (pump backwards to propel forwards).
  Tell pupils to run with their head focused forwards and on the ball parts of the feet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112047Z"^^xsd:dateTime .

oakcurric:misconception-bouncing-ball-dribble-pupils-slap
  a curric:Misconception ;
  curric:statement """When bouncing a ball to dribble with it, pupils slap the ball down with their
  palms, focusing on power. Pupils dribble with their head down."""@en ;
  curric:correction """Ensure pupils are pushing the ball down with control, using the flat part of
  their fingertips. Encourage pupils to keep their heads up whilst dribbling to ensure they
  can see space, don't bump into others and develops their peripheral view."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113045Z"^^xsd:dateTime .

oakcurric:misconception-line-dancing-use-feet
  a curric:Misconception ;
  curric:statement "Line dancing must use the feet."@en ;
  curric:correction """Whilst it is typically performed with an emphasis on footwork, this can
  easily be adapted to use the arms or any other body part. The emphasis is on the use of a
  repeating pattern, with a change of direction through 90'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113051Z"^^xsd:dateTime .

oakcurric:misconception-teammates-busy-running-taggers-forget
  a curric:Misconception ;
  curric:statement """Teammates are so busy running away from taggers that they forget to look
  carefully and collide with others."""@en ;
  curric:correction """Remind pupils that to avoid collisions, they must look ahead and dodge others
  by changing direction and slowing down."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113057Z"^^xsd:dateTime .

oakcurric:misconception-pupils-shout-loudly-thinking-improve
  a curric:Misconception ;
  curric:statement """Pupils shout loudly thinking this will improve communication. Pupils high 5
  with too much force."""@en ;
  curric:correction """Encourage the use of good sentences spoken at a normal talking volume. Be
  explicit about using gentle high 5s and ask pupils to imagine how a butterfly would high 5
  their friend."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113281Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rely-heavily-using-one
  a curric:Misconception ;
  curric:statement """Pupils rely heavily on using just one part of their foot, neglecting the need
  to use both the inside and the outside for better control."""@en ;
  curric:correction """Emphasise the need to alternate between both parts of the foot for greater
  skill and control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113319Z"^^xsd:dateTime .

oakcurric:misconception-fear-hit-ball-cause-pupils
  a curric:Misconception ;
  curric:statement """A fear of being hit by the ball can cause pupils to flinch, shy away or close
  their eyes."""@en ;
  curric:correction """Ensure pupils understand that they need to keep their eyes on the ball,
  focusing on it until it is in their hands."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113727Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-staying-silent-while
  a curric:Misconception ;
  curric:statement """Some pupils may think that staying silent while someone speaks is all that is
  needed to show respectful listening."""@en ;
  curric:correction """Staying silent can be described as passive listening. Active and respectful
  listening uses thinking skills to understand, remember and respond to what has been said.
  You need to plan your next actions based on the information that has been said."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113733Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-throw-primarily-come
  a curric:Misconception ;
  curric:statement """Pupils believe that the throw should primarily come from the arm, rather than
  using their whole body."""@en ;
  curric:correction """Ensure pupils understand that for greater accuracy and distance, they should
  also use their legs, feet, hands, hips and body."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114051Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-throwing-ball-throwing
  a curric:Misconception ;
  curric:statement """Some pupils struggle with over or under throwing the ball, throwing either too
  hard or too soft. In game situations, pupils often all gravitate towards the ball."""@en ;
  curric:correction """Encourage pupils to continue to use the correct technique and focus on
  following through towards their target. This will eliminate the need to throw harder or
  softer as the technique will support accuracy. Ensure pupils are using the whole space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114283Z"^^xsd:dateTime .

oakcurric:misconception-dance-styles-such-salsa-ballet
  a curric:Misconception ;
  curric:statement "Dance styles such as Salsa or Ballet are 'proper' dancing."@en ;
  curric:correction """All dance styles were created by someone, or a group, and develop e.g. pointe
  work in ballet was introduced in the 1820's/1830's. New styles are still being developed.
  All actions can be dance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114289Z"^^xsd:dateTime .

oakcurric:misconception-pupils-run-instead-skipping-avoid
  a curric:Misconception ;
  curric:statement """Pupils run instead of skipping to avoid being caught. Pupils don't follow the
  rules and take more than one piece of equipment at a time."""@en ;
  curric:correction """Remind pupils that running is a rule break and celebrate pupils who are
  hopping/skipping not running. Explain that this is a rule break and build in a consequence
  for this happening."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114298Z"^^xsd:dateTime .

oakcurric:misconception-pupils-focus-wanting-go-first
  a curric:Misconception ;
  curric:statement """Pupils focus on wanting to go first in their team as opposed to their running
  technique. Pupils think success is all about winning."""@en ;
  curric:correction """Give each pupil a number and rotate who goes first to avoid the distraction.
  Challenge pupils to improve their own team's time instead of racing others to reinforce
  the point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114304Z"^^xsd:dateTime .

oakcurric:misconception-many-pupils-stand-close-far
  a curric:Misconception ;
  curric:statement """Many pupils stand too close or too far away from the ball which makes it hard
  for them to strike the ball effectively."""@en ;
  curric:correction """Encourage pupils to stand roughly an arm's distance away from the ball in a
  well-balanced stance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114926Z"^^xsd:dateTime .

oakcurric:misconception-representing-journey-train-bus-include
  a curric:Misconception ;
  curric:statement """Representing the journey of a train or bus must include mimed actions such as
  pretending to turn a steering wheel."""@en ;
  curric:correction """Whilst pupils may wish to include such gestures, our focus is on the journey
  rather than the mode of transport so there is not a requirement to include the use of
  mime."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114932Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-perform-large-audience
  a curric:Misconception ;
  curric:statement "Some pupils will not want to perform to a large audience."@en ;
  curric:correction """Some pupils practise performing for a small group, and if they still feel
  they can't perform for a larger audience, they don't have to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114943Z"^^xsd:dateTime .

oakcurric:misconception-introducing-defenders-pupils-neglect-technique
  a curric:Misconception ;
  curric:statement """When introducing defenders, pupils often neglect technique and moving with
  close control."""@en ;
  curric:correction "Remind pupils to use gentle, small touches when moving with their ball."@en ;
  dcterms:modified "2026-06-07T15:30:15.115761Z"^^xsd:dateTime .

oakcurric:misconception-two-speeds-slow-fast
  a curric:Misconception ;
  curric:statement "There are only two speeds, slow and fast."@en ;
  curric:correction """There are a wide range of speeds. We might think we can run fast, but a horse
  can run faster than us, a train can travel faster than a horse and an aeroplane can travel
  faster than a train."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116386Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-working-our-muscles
  a curric:Misconception ;
  curric:statement """Some pupils may think that working on our muscles means lifting heavy weights
  to make them big and bulging."""@en ;
  curric:correction """Healthy muscles don't need to be bulging muscles. They need to stay supple so
  they work well; they need rest so they don't get injured; they need to be used regularly
  so they don't become stiff. This can all be achieved without lifting weights."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116400Z"^^xsd:dateTime .

oakcurric:misconception-game-situation-pupils-panic-rush
  a curric:Misconception ;
  curric:statement """In a game situation, pupils can panic and rush their throw without aiming or
  using the correct technique."""@en ;
  curric:correction """Encourage pupils to be composed and even when under pressure to throw
  quickly, ensure pupils understand the importance of throwing accurately with the correct
  technique."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117489Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-coordination-relates-movement
  a curric:Misconception ;
  curric:statement """Pupils may think that coordination relates only to movement of their
  own body."""@en ;
  curric:correction """Coordination requires many different elements to work in combination.
  Improving balance, timing, ball tracking and the way we grip equipment can all contribute
  to improved coordination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117958Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-use-correct-technique
  a curric:Misconception ;
  curric:statement """Pupils forget to use the correct technique for running fast. Pupils are slow
  to react."""@en ;
  curric:correction """Model the correct technique for running. Reiterate the importance of
  acceleration and give pupils another pupil to race against."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117964Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jumping-performed-one
  a curric:Misconception ;
  curric:statement """Some pupils may think that jumping can only be performed in one way for one
  purpose. For example, a half turn jump is used in gymnastics only."""@en ;
  curric:correction """There are lots of different jumping techniques which can be used in lots of
  different circumstances. Selecting the most appropriate jumping technique in a game can
  help you to be successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117980Z"^^xsd:dateTime .

oakcurric:misconception-dynamics-describes-fast-action-performed
  a curric:Misconception ;
  curric:statement "Dynamics describes how fast an action is performed."@en ;
  curric:correction """Dynamics involves both speed and force. Some words do mean speed, e.g. quick,
  whereas others only talk about force, e.g. strong. However some words might mean both,
  e.g. explosive would be both fast and strong."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118603Z"^^xsd:dateTime .

oakcurric:misconception-balances-held-still-long-enough
  a curric:Misconception ;
  curric:statement "Balances are not held still for long enough."@en ;
  curric:correction """Practise balancing still and remind pupils that they should be held still for
  about 4 seconds. Pupils can try focusing on a fixed spot to help them keep still. If they
  close their eyes to balance, they will wobble - try this too!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.118651Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jumping-static-action
  a curric:Misconception ;
  curric:statement """Pupils might think that jumping is a static action to be performed on the
  spot."""@en ;
  curric:correction """Jumping can be a dynamic movement that travels through space and can be
  linked in combination to gain momentum and speed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118716Z"^^xsd:dateTime .

oakcurric:misconception-gymnastics-forward-backward-rolls-bring
  a curric:Misconception ;
  curric:statement """In gymnastics, we only do forward and backward rolls. We bring our feet up to
  our bottom in a tuck jump."""@en ;
  curric:correction """Rolls can be sideways; as long as pupils roll silently with control, they are
  still successful. We bring our feet and knees up towards our chest in a tuck jump."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119327Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-adjust-their-body
  a curric:Misconception ;
  curric:statement """Pupils don't adjust their body position when preparing to stop the ball or
  return the hit. Instead, they stretch and try to hit the ball from an unbalanced position."""@en ;
  curric:correction """Explain to pupils that positioning their body in line with the ball will make
  it easier to stop it going past them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119971Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-dribbling-simply-kicking
  a curric:Misconception ;
  curric:statement """Pupils confuse dribbling with simply kicking the ball away, believing that any
  contact with the ball is dribbling."""@en ;
  curric:correction """Emphasise the importance of soft, controlled touches with the inside of their
  feet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120029Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-strategy-doesnt-work
  a curric:Misconception ;
  curric:statement """Some pupils might think that if a strategy doesn't work, they shouldn't use it
  again."""@en ;
  curric:correction """Deciding when to use a strategy is part of the challenge. A strategy that
  works once will not work every time or against every opponent. Having lots of strategies
  to try will help you find the one that works best each time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120519Z"^^xsd:dateTime .

oakcurric:misconception-game-situation-trying-beat-opponent
  a curric:Misconception ;
  curric:statement """When in a game situation and trying to beat an opponent, pupils focus on
  throwing with more power and speed, rather than focusing on using the correct throwing
  technique."""@en ;
  curric:correction """Explain to pupils that using the correct technique will produce better
  accuracy and eventually the speed and power of throws will increase."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120536Z"^^xsd:dateTime .

oakcurric:misconception-practise-makes-perfect-pupils-forget
  a curric:Misconception ;
  curric:statement """Practise makes perfect. Pupils forget the variety of shapes they can use for
  gymnastics skills and default to using the same basic balances and jumps in every
  sequence."""@en ;
  curric:correction """Practise might not always make a performance perfect, but it will make
  actions and sequences improve. Pupils can work together to help use practise time to
  improve. Display posters or lists of shape ideas for jumps, rolls and balances."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122729Z"^^xsd:dateTime .

oakcurric:misconception-pupils-show-balances-instead-movements
  a curric:Misconception ;
  curric:statement """Pupils show balances instead of movements on the apparatus. Pupils perform
  gymnastics actions in silence to be well-behaved. Pointed toes mean lifting toes towards
  the knees."""@en ;
  curric:correction """Encourage pupils to travel or change their movements, not just hold still.
  Pupils perform gymnastics actions in silence to show good control. Pointed toes mean
  pushing the toes away from the legs, making their legs look longer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123390Z"^^xsd:dateTime .

oakcurric:misconception-warming-needed-outdoor-lessons-cold
  a curric:Misconception ;
  curric:statement "Warming up is only needed for outdoor lessons and in the cold weather."@en ;
  curric:correction """Warming up is a gentle and gradual way of getting the body and mind ready for
  exercise. Our bodies might not be ready for sudden, energetic movements even in warm
  weather or when we are indoors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123395Z"^^xsd:dateTime .

oakcurric:misconception-pupils-underestimate-importance-following-their
  a curric:Misconception ;
  curric:statement """Pupils underestimate the importance of following through with their racket
  when pushing/ striking the ball."""@en ;
  curric:correction """Explain to pupils that the follow through is important for accuracy and
  getting the right amount of power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124079Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-perform-animal-actions
  a curric:Misconception ;
  curric:statement """Pupils don't perform the animal actions for a count of 6. Pupils think they
  have to find the cards for the animal action scavenger hunt in numerical order."""@en ;
  curric:correction """Remind pupils that keeping the rules demonstrates fair play and ensures
  everyone enjoys the game. Pupils can find and perform the animal action cards in any
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124574Z"^^xsd:dateTime .

oakcurric:misconception-transitions-mean-adding-travelling-option
  a curric:Misconception ;
  curric:statement """Transitions mean adding a travelling option as you move from one skill to
  another. Gymnastics lessons always need lots of apparatus and take too long to set up."""@en ;
  curric:correction """Reinforce the concept of transitions as the smooth transfer of one skill
  moving straight into another one. Gymnastics lessons can be taught using just mats and
  benches, that do not take long to set up."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124582Z"^^xsd:dateTime .

oakcurric:misconception-pupils-ignore-importance-their-body
  a curric:Misconception ;
  curric:statement "Pupils ignore the importance of their body position when rolling the ball."@en ;
  curric:correction """Ensure pupils understand that aligning their body with the target, especially
  their feet and shoulders, will help increase their rolling accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124588Z"^^xsd:dateTime .

oakcurric:misconception-moves-performed-specifc-order-effective
  a curric:Misconception ;
  curric:statement "Moves have to be performed in a specifc order to be effective."@en ;
  curric:correction """After learning a few moves, we can ask the pupils which to perform and how
  many. This enables them to develop their choreographic skills of selecting and sequencing
  actions effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124865Z"^^xsd:dateTime .

oakcurric:misconception-pupils-move-their-whole-body
  a curric:Misconception ;
  curric:statement """Pupils move their whole body at once in a bunny hop. Pupils point their toes
  the wrong way by flexing the ankle, causing the foot to point at a 90 degree angle to the
  leg. Pupils jump off wall bars."""@en ;
  curric:correction """Tell pupils to move their hands first, then their feet to their hands and
  repeat. Tell pupils to flex their ankles in the opposite direction and push their toes
  away from their leg, making the leg appear longer. Pupils only jump from flat surfaces."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124888Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-one-attacking-defending
  a curric:Misconception ;
  curric:statement """Pupils might think that after one attacking or defending move, their job in
  the team is finished and they stand still and stop following the play."""@en ;
  curric:correction """Often in a game, you will need to do some attacking work and some defending
  work. Concentrating and reacting to the actions of others will help you to decide if you
  need to attack or defend."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124901Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-speaking-relation-communication
  a curric:Misconception ;
  curric:statement "Some pupils may only think about speaking in relation to communication."@en ;
  curric:correction """Information can be communicated in lots of different ways including signals,
  gestures, sounds, pictures and words. Receiving, interpreting and acting on the
  information sent is also half the process of communication."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124913Z"^^xsd:dateTime .

oakcurric:misconception-pupils-kick-ball-far-ahead
  a curric:Misconception ;
  curric:statement """Pupils kick the ball too far ahead of them, using their toes to kick it,
  rather than keeping control with lighter touches."""@en ;
  curric:correction """Remind pupils that the further the ball is away from them, the easier it is
  for a defender to take it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125832Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-exercising-physical-activity
  a curric:Misconception ;
  curric:statement """Some pupils may think exercising and physical activity are only focused on
  winning and being the best."""@en ;
  curric:correction """Exercising alone or with others can provide opportunities to have fun and try
  new things. Getting better at something or feeling energised can feel just as good as
  winning a game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125837Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-good-aim-fixed
  a curric:Misconception ;
  curric:statement """Some pupils might think that good aim is a fixed skill that you either have or
  do not."""@en ;
  curric:correction """Accuracy and aim is closely linked to balance and technique, i.e. when a
  pupil can hold a steady position and perform an accurate technique, often their aim
  improves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125882Z"^^xsd:dateTime .

oakcurric:misconception-pupils-throw-equipment-high-throw
  a curric:Misconception ;
  curric:statement """Pupils throw equipment too high or throw overarm, and then blame their partner
  for being unable to catch it."""@en ;
  curric:correction """Encourage underarm throwing with a gentle force to help ensure all partners
  can catch and succeed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125888Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jumping-competitions-focus
  a curric:Misconception ;
  curric:statement """Pupils might think that jumping competitions only focus on individual
  ability."""@en ;
  curric:correction """When we are competing as part of a team, our performance is a combined effort
  and everyone in the team can contribute in lots of different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130201Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-understand-combination
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to understand that this combination of three
  elements creates one jump that can be measured from the start of the hop, to the end of
  the jump."""@en ;
  curric:correction """When we combine elements into a hop, step, jump combination we can benefit
  from the power and momentum that builds up. By increasing the distance travelled in each
  element, we increase the overall distance covered in the jump combination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131834Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-top-their-heads
  a curric:Misconception ;
  curric:statement """Pupils use the top of their heads in a forward roll and forget to make their
  back curved. Pupils bend their backs too much when landing a jump, causing their hands to
  touch the floor."""@en ;
  curric:correction """Pupils should tuck their heads in, put their chin on their chests and use the
  back of their head by keeping their back rounded in a forward roll. Remind pupils to keep
  their backs straight so they can land upright ('land and stand')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132752Z"^^xsd:dateTime .

oakcurric:misconception-tall-shape-achieved-stretching-arms
  a curric:Misconception ;
  curric:statement "A tall shape is only achieved by stretching both arms upwards."@en ;
  curric:correction """Whilst stretching both arms upwards is an example of a tall shape, there are
  many others. These might include twists, tilts, balances etc. By encouraging the pupils
  beyond their initial response they will think more deeply and creatively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132770Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-throwing-requires-lot
  a curric:Misconception ;
  curric:statement """Pupils believe that throwing requires a lot of strength rather than proper
  technique."""@en ;
  curric:correction """Ensure that pupils understand that throwing too hard can lead to poor
  technique and less accuracy when aiming for a target."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132807Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-hitting-ball-hard
  a curric:Misconception ;
  curric:statement """Pupils believe that hitting the ball hard is the best way to move and control
  it."""@en ;
  curric:correction """Encourage pupils to keep close contol of their ball by using soft touches to
  keep it close."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132843Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-their-feet-games-pupils
  a curric:Misconception ;
  curric:statement """When dribbling with their feet in games, pupils sometimes think they can pick
  the ball up to protect it from defenders."""@en ;
  curric:correction """Remind pupils that they cannot use their hands when dribbling with their feet
  and that they need to either use their body to protect the ball or move into open space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133803Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-exercise-depth-breathing
  a curric:Misconception ;
  curric:statement """Pupils may not recognise that during exercise, the depth of breathing changes
  as well as the speed per minute. Depth of breathing is a more abstract concept than how
  many breaths are taken per minute."""@en ;
  curric:correction """As well as taking more breaths per minute during exercise, a child will take
  deeper breaths each time. This is also a way for the body to get more oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133818Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-hold-balances-long
  a curric:Misconception ;
  curric:statement """Pupils don't hold balances for long enough because they think they have to
  link straight into the next skill."""@en ;
  curric:correction """Holding a balance still for 4 seconds is part of the balance skill, so it
  should be included even when a balance is used in a linking sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134414Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-react-commands-arent
  a curric:Misconception ;
  curric:statement """Pupils fail to react to the commands as they aren't concentrating. Pupils run
  out of the space to avoid being caught by the sharks. Sharks give up when they can't catch
  a fish."""@en ;
  curric:correction """Remind pupils why it is important to focus in a game. Reiterate the
  consequences of running off the court or pitch in a game. Explain the importance of
  defenders stopping the attackers in a game and why we must speed up when we are defenders
  too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134421Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-rely-others-include
  a curric:Misconception ;
  curric:statement """Some pupils might think they have to rely on others to include them and that
  there isn't anything they can or need to do in order to be included."""@en ;
  curric:correction """There are things that you can do to increase your involvement in a challenge
  and play a role in a team such as sharing ideas and supporting and encouraging others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134836Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-good-team-member
  a curric:Misconception ;
  curric:statement """Pupils may think that they can only be a good team member if they score lots
  of points."""@en ;
  curric:correction """Scoring a point means everyone in the team has done their job well, not just
  the individual who scored. Only some team members need to have the role of scoring points;
  doing your job well will help the team members whose job it is to score points."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134925Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-success-achieved-winning
  a curric:Misconception ;
  curric:statement """Pupils may think that success is only achieved by winning and being
  the best."""@en ;
  curric:correction """Success can be achieved in lots of different ways. You can be successful by
  improving your own performance (regardless of anyone else's performance), setting yourself
  a challenge and reaching a new target or working in cooperation with others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134944Z"^^xsd:dateTime .

oakcurric:misconception-pupils-jump-wall-bars-climbing
  a curric:Misconception ;
  curric:statement "Pupils jump from wall bars or climbing frames."@en ;
  curric:correction "Pupils should only jump from a flat surface."@en ;
  dcterms:modified "2026-06-07T15:30:15.136932Z"^^xsd:dateTime .

oakcurric:misconception-narrative-dance-interpret-word-action
  a curric:Misconception ;
  curric:statement "In a narrative dance you have to interpret every word into an action."@en ;
  curric:correction """In a narrative dance performers aim to communicate the main parts of the
  story. They may add actions and join movements together to show the context and character
  or make it more interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136940Z"^^xsd:dateTime .

oakcurric:misconception-pupils-swing-back-forwards-quickly
  a curric:Misconception ;
  curric:statement """Pupils swing back and forwards quickly to hit the ball with power but take
  their eyes off of the ball, causing them to miss it."""@en ;
  curric:correction """Highlight the importance of keeping eyes on the ball to ensure pupils make
  good contact when hitting it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136946Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-agreeing-tactic-team
  a curric:Misconception ;
  curric:statement """Pupils may believe that after agreeing a tactic, the team will be able to
  perform this tactic accurately every time and that when they do, it will always be
  successful."""@en ;
  curric:correction """Even when we make a great dodge into space and use a tactic, our opponents
  will react with a tactic of their own: this means that a tactic isn't guarenteed to be
  successful every time we use it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138177Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-successful-sport-relies
  a curric:Misconception ;
  curric:statement """Some pupils may think that being successful in sport relies on being able to
  run fast."""@en ;
  curric:correction """In many sports, having good coordination can be more valuable than speed or
  strength. Swimming, rowing, golf, skiing, rhythmic gymnastics, bowling and clay shooting
  all require coordination, but don't rely on speed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138185Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-competitive-games-scoring
  a curric:Misconception ;
  curric:statement """Some pupils could think that competitive games are only about scoring points
  and will focus on this role in a team."""@en ;
  curric:correction """Competitive games require attacking and defensive skills as well as team
  work, listening, communication, decision making, honesty, self-belief and more."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138953Z"^^xsd:dateTime .

oakcurric:misconception-contrast-same-opposite
  a curric:Misconception ;
  curric:statement "Contrast is the same as opposite."@en ;
  curric:correction """Opposite is an example of contrast. For example, a contrast for travelling
  forwards is backwards. But contrast can also mean different. For example, travelling
  around a bend or turning on the spot are different so would also demonstrate contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138961Z"^^xsd:dateTime .

oakcurric:misconception-pupils-hold-onto-object-tightly
  a curric:Misconception ;
  curric:statement """Pupils hold onto the object too tightly and for too long, releasing it too
  late."""@en ;
  curric:correction """Highlight the importance of holding the object with a relaxed grip and
  releasing it high for greater distance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138967Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jumping-strength-consider
  a curric:Misconception ;
  curric:statement """Pupils might think that jumping is all about strength and do not consider the
  importance of coordination and technique."""@en ;
  curric:correction """The power needed for jumping high comes from the combined actions of a range
  of different body parts. The coordination of all these body parts creates a great
  technique for jumping high."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139392Z"^^xsd:dateTime .

oakcurric:misconception-dribbling-game-score-points-pupils
  a curric:Misconception ;
  curric:statement """When dribbling in a game to score points, pupils forget to keep control and
  rush, causing them to kick the ball too far ahead."""@en ;
  curric:correction """Emphasise the importance of keeping the ball close and dribbling with
  control. Highlight how this will lead to scoring more points."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140231Z"^^xsd:dateTime .

oakcurric:misconception-hitting-ball-pupils-focus-power
  a curric:Misconception ;
  curric:statement """When hitting the ball, pupils focus on power and hitting it as hard as they
  can, neglecting the need for technique and accuracy."""@en ;
  curric:correction """Ensure pupils understand the importance of aiming and using the correct
  technique for the best accuracy. It is best to master this before attempting to add more
  power."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140237Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-combine-power-accuracy
  a curric:Misconception ;
  curric:statement """Pupils struggle to combine both power and accuracy, often focusing on just
  one."""@en ;
  curric:correction """Explain to pupils that both power and accuracy are needed. Pupils should aim
  their hit and then think about the power when swinging through."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141087Z"^^xsd:dateTime .
