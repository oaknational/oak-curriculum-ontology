# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-projection
  a curric:Keyword ;
  schema:name "projection"@en ;
  schema:description "speaking powerfully and clearly"@en ;
  dcterms:modified "2026-06-07T15:30:02.348210Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-character
  a curric:Keyword ;
  schema:name "character"@en ;
  schema:description "a person or animal in a story"@en ;
  dcterms:modified "2026-06-07T15:30:02.348600Z"^^xsd:dateTime .

oakcurric:keyword-fluency
  a curric:Keyword ;
  schema:name "fluency"@en ;
  schema:description "how smooth and natural speech your speech sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.349047Z"^^xsd:dateTime .

oakcurric:keyword-challenge
  a curric:Keyword ;
  schema:name "challenge"@en ;
  schema:description "question or dispute a belief, decision or idea"@en ;
  dcterms:modified "2026-06-07T15:30:02.349796Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:02.350302Z"^^xsd:dateTime .

oakcurric:keyword-fairness
  a curric:Keyword ;
  schema:name "fairness"@en ;
  schema:description """the quality of treating people equally, or in a way that is right or
  reasonable"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350868Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
  flow of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351040Z"^^xsd:dateTime .

oakcurric:keyword-expression
  a curric:Keyword ;
  schema:name "expression"@en ;
  schema:description "reading with feelings and emotion to bring the poem to life"@en ;
  dcterms:modified "2026-06-07T15:30:02.351044Z"^^xsd:dateTime .

oakcurric:keyword-gesture
  a curric:Keyword ;
  schema:name "gesture"@en ;
  schema:description "a movement that helps express an idea or meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.351051Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.351112Z"^^xsd:dateTime .

oakcurric:keyword-solo
  a curric:Keyword ;
  schema:name "solo"@en ;
  schema:description """a performance by one instrument; sometimes compositions for an instrument
  with a piano accompaniment are also called a solo"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351505Z"^^xsd:dateTime .

oakcurric:keyword-landing
  a curric:Keyword ;
  schema:name "landing"@en ;
  schema:description "the final phase of the long jump in which you enter the sand"@en ;
  dcterms:modified "2026-06-07T15:30:02.351676Z"^^xsd:dateTime .

oakcurric:keyword-wellbeing
  a curric:Keyword ;
  schema:name "wellbeing"@en ;
  schema:description "the state of being comfortable, healthy, or happy"@en ;
  dcterms:modified "2026-06-07T15:30:02.352059Z"^^xsd:dateTime .

oakcurric:keyword-technique
