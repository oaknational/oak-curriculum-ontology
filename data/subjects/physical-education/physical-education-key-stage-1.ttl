    oakcurric:priorknowledge-2967-6 ,
    oakcurric:priorknowledge-2967-7 ,
    oakcurric:priorknowledge-2967-8 ,
    oakcurric:priorknowledge-2967-9 ,
    oakcurric:priorknowledge-2967-10 ;
  curric:id "2967"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.754239Z"^^xsd:dateTime ;
