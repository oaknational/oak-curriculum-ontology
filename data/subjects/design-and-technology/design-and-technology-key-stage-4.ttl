  a curric:KeyLearningPoint ;
  rdfs:label "Before developing your ideas in CAD, your sketches should be evaluated"@en ;
  dcterms:modified "2026-06-07T15:30:29.252510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27165-1
  a curric:KeyLearningPoint ;
  rdfs:label "A design portfolio is a collection of a designer's work."@en ;
  dcterms:modified "2026-06-07T15:30:29.252518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27165-2
  a curric:KeyLearningPoint ;
  rdfs:label """A design portfolio shows the journey including all of the ideas that were not taken
  through or were not successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27165-3
  a curric:KeyLearningPoint ;
  rdfs:label """A design portfolio should reflect the iterative way in which the designer has
  worked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27165-4
  a curric:KeyLearningPoint ;
  rdfs:label "Digital media can be used to present a design portfolio."@en ;
  dcterms:modified "2026-06-07T15:30:29.252582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27165-5
  a curric:KeyLearningPoint ;
  rdfs:label """The iterative design process is a cycle of creating, testing, and improving a design
  until it meets the user’s needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252587Z"^^xsd:dateTime .

