  schema:description "the rate of flow of charge in a circuit"@en ;
  dcterms:modified "2026-06-07T15:30:02.422763Z"^^xsd:dateTime .

oakcurric:keyword-resistance-r
  a curric:Keyword ;
  schema:name "Resistance (R)"@en ;
  schema:description """is a property of a material, such as a metal, that opposes the flow of
  current"""@en ;
  dcterms:modified "2026-06-07T15:30:02.422769Z"^^xsd:dateTime .

oakcurric:keyword-destructive-testing
  a curric:Keyword ;
  schema:name "destructive testing"@en ;
  schema:description "testing that destroys the material or product"@en ;
  dcterms:modified "2026-06-07T15:30:02.422919Z"^^xsd:dateTime .

oakcurric:keyword-non-destructive-testing
  a curric:Keyword ;
  schema:name "non-destructive testing"@en ;
  schema:description "testing without destroying the material or product"@en ;
  dcterms:modified "2026-06-07T15:30:02.422924Z"^^xsd:dateTime .

oakcurric:keyword-hand-tools
  a curric:Keyword ;
  schema:name "hand tools"@en ;
  schema:description """manually operated tools used for shaping, cutting, joining, and finishing
  materials in practical projects"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423840Z"^^xsd:dateTime .

oakcurric:keyword-respondent
  a curric:Keyword ;
  schema:name "respondent"@en ;
  schema:description "a person who provides answers to questions in a questionnaire"@en ;
  dcterms:modified "2026-06-07T15:30:02.423935Z"^^xsd:dateTime .

oakcurric:keyword-primary-user
  a curric:Keyword ;
  schema:name "primary user"@en ;
  schema:description "the main person that you are designing for"@en ;
  dcterms:modified "2026-06-07T15:30:02.424368Z"^^xsd:dateTime .

oakcurric:keyword-quality-assurance-qa
  a curric:Keyword ;
  schema:name "Quality Assurance (QA)"@en ;
  schema:description "ensuring the production process prevents mistakes and maintains quality"@en ;
  dcterms:modified "2026-06-07T15:30:02.424374Z"^^xsd:dateTime .

oakcurric:keyword-standardise
  a curric:Keyword ;
  schema:name "standardise"@en ;
  schema:description "make components or processes the same to ensure consistency and quality"@en ;
  dcterms:modified "2026-06-07T15:30:02.424381Z"^^xsd:dateTime .

oakcurric:keyword-open-ended-question
  a curric:Keyword ;
  schema:name "Open-ended question"@en ;
  schema:description "a type of question that encourages a detailed, thoughtful response"@en ;
  dcterms:modified "2026-06-07T15:30:02.425103Z"^^xsd:dateTime .

oakcurric:keyword-flexible-manufacturing-systems
  a curric:Keyword ;
  schema:name "Flexible Manufacturing Systems"@en ;
  schema:description "(also known as FMS) adaptable production systems for changing needs"@en ;
  dcterms:modified "2026-06-07T15:30:02.426933Z"^^xsd:dateTime .

oakcurric:keyword-just-in-time-jit
  a curric:Keyword ;
  schema:name "Just-In-Time (JIT)"@en ;
  schema:description "producing only what’s needed, when needed"@en ;
  dcterms:modified "2026-06-07T15:30:02.426938Z"^^xsd:dateTime .

oakcurric:keyword-lean-manufacture
  a curric:Keyword ;
  schema:name "lean manufacture"@en ;
  schema:description "a production method that focuses on minimising waste"@en ;
  dcterms:modified "2026-06-07T15:30:02.426946Z"^^xsd:dateTime .

oakcurric:keyword-downtime
  a curric:Keyword ;
  schema:name "downtime"@en ;
  schema:description """when a machine or system is not operational due to maintenance or
  failure"""@en ;
  dcterms:modified "2026-06-07T15:30:02.426952Z"^^xsd:dateTime .

oakcurric:keyword-lead-time
  a curric:Keyword ;
  schema:name "lead time"@en ;
  schema:description "the length of time from order to production completion"@en ;
  dcterms:modified "2026-06-07T15:30:02.426957Z"^^xsd:dateTime .

oakcurric:keyword-scale-of-production
  a curric:Keyword ;
  schema:name "scale of production"@en ;
  schema:description "the amount/volume of goods produced"@en ;
  dcterms:modified "2026-06-07T15:30:02.428345Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-research-existing-products-secondary-research
  a curric:Misconception ;
  curric:statement "Research into existing products is a secondary research task."@en ;
  curric:correction """Primary research through the disassembly of a product can be extremely
  beneficial to really understand a product, its materials and how it is manufactured."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083986Z"^^xsd:dateTime .

oakcurric:misconception-once-design-decided-upon-cannot
  a curric:Misconception ;
  curric:statement "Once a design has been decided upon, it cannot be altered."@en ;
  curric:correction """A design can continue to be altered, even when at the manufacturing
  stage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083992Z"^^xsd:dateTime .

oakcurric:misconception-design-portfolio-include-your-best
  a curric:Misconception ;
  curric:statement "A design portfolio should only include your best work and your best ideas."@en ;
  curric:correction """A design portfolio should show the journey of the designer, including all of
  the ideas that were not taken through or were not successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084002Z"^^xsd:dateTime .

oakcurric:misconception-life-cycle-product-design-ends
  a curric:Misconception ;
  curric:statement """The life cycle in product design ends once the product is sold to the
  consumer."""@en ;
  curric:correction """The product life cycle includes stages beyond purchase such as: use,
  maintenance, and disposal or recycling. Sustainable design considers the entire life cycle
  to minimise environmental impact."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084060Z"^^xsd:dateTime .

oakcurric:misconception-modelling-takes-place-physical-materials
  a curric:Misconception ;
  curric:statement "Modelling only takes place with physical materials."@en ;
  curric:correction """Virtual modelling using 3D drawing software can help to see ideas in 3D and
  enables quick and easy iteration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084092Z"^^xsd:dateTime .

oakcurric:misconception-final-evaluation-based-upon-designers
  a curric:Misconception ;
  curric:statement """The final evaluation is based upon the designers perspective of the prototype
  and design process."""@en ;
  curric:correction """Testing and evaluations from the user and target market are essential to
  ensure the product meets the clients needs but is also commercially viable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084098Z"^^xsd:dateTime .

oakcurric:misconception-quality-control-quality-assurance-same
  a curric:Misconception ;
  curric:statement "Quality control and quality assurance is the same thing."@en ;
  curric:correction """Quality control focuses on identifying defects in finished products, while
  quality assurance is about preventing defects through planned processes and systems during
  production."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084188Z"^^xsd:dateTime .

oakcurric:misconception-modelling-using-cad-final-step
  a curric:Misconception ;
  curric:statement "Modelling using CAD is the final step in the development of designs."@en ;
  curric:correction """CAD is part of the iterative process. CAD should be used as a way to develop
  your idea by viewing it virtually and analysing the idea. Sketching over your CAD drawings
  can help to develop the idea before going back to make those improvements in CAD."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084202Z"^^xsd:dateTime .

oakcurric:misconception-model-3d-printed-using-fused
  a curric:Misconception ;
  curric:statement "Any model can be 3D printed using fused filament fabrication 3D printing."@en ;
  curric:correction """Design for manufacture rules need to be considered when 3D printing. Not all
  models are suitable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084393Z"^^xsd:dateTime .

oakcurric:misconception-laser-cutting-cutting-simple-shapes
  a curric:Misconception ;
  curric:statement """Laser cutting is about cutting out simple shapes and only really works for 2D
  products and designs."""@en ;
  curric:correction """Laser cutters can be used to develop and manufacture effective and complex 3D
  products."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084606Z"^^xsd:dateTime .

oakcurric:misconception-pupils-come-idea-even-solution
  a curric:Misconception ;
  curric:statement """Pupils may come with an idea or even a solution at this stage and stick with
  it as they feel they do not need another idea."""@en ;
  curric:correction """Encourage pupils to explore a range of ideas and possibilities to avoid
  design fixation and prepare them for the NEA."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084857Z"^^xsd:dateTime .

oakcurric:misconception-renewable-sources-energy-negative-impacts
  a curric:Misconception ;
  curric:statement "Renewable sources of energy do not have any negative impacts."@en ;
  curric:correction """Renewable sources of energy have high initial set up costs, are often weather
  dependent and require effective storage of energy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085664Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-know-designing
  a curric:Misconception ;
  curric:statement """Pupils often think they need to know what they are designing and making
  straight away."""@en ;
  curric:correction """Pupils need to explore the context fully first to identify lots of possible
  design problems to solve before narrowing it down."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085681Z"^^xsd:dateTime .

oakcurric:misconception-physical-properties-working-properties-same
  a curric:Misconception ;
  curric:statement "Physical properties and working properties are the same thing."@en ;
  curric:correction """Physical properties describe inherent features (like density, colour, or
  conductivity), whereas working properties describe how a material behaves under stress
  (like flexibility, toughness, or hardness)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085811Z"^^xsd:dateTime .

oakcurric:misconception-environmental-impact-occurs-products-disposed
  a curric:Misconception ;
  curric:statement "Environmental impact only occurs when products are disposed of."@en ;
  curric:correction """Circular economy and LCA consider the environmental impact at every single
  stage of a product's life cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085873Z"^^xsd:dateTime .

oakcurric:misconception-mould-former-same-thing
  a curric:Misconception ;
  curric:statement "A mould and a former are the same thing."@en ;
  curric:correction """A mould contains the material and shapes it as it sets or solidifies. A
  former is a shape around which a material is bent or stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086283Z"^^xsd:dateTime .

oakcurric:misconception-materials-additional-surface-finishes-applied
  a curric:Misconception ;
  curric:statement "All materials have additional surface finishes applied."@en ;
  curric:correction """Some materials, such as polymers, can be self-finishing and do not require
  additional processes or finishes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086631Z"^^xsd:dateTime .

oakcurric:misconception-design-ideas-produced-sketches-drawings
  a curric:Misconception ;
  curric:statement "Design ideas are produced through sketches and drawings."@en ;
  curric:correction """3D or physical modelling is a great way to get design ideas out of your head.
  It is sometimes easier to work out your idea in 3D rather than worrying about whether you
  can draw it in 3D, especially if its form is complex."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086905Z"^^xsd:dateTime .

oakcurric:misconception-using-standardised-components-limit-creativity
  a curric:Misconception ;
  curric:statement "Using standardised components limit creativity and originality in design."@en ;
  curric:correction """Standardised components can actually enhance innovation by allowing designers
  to focus on customisation, functionality, and efficiency while reducing costs and
  production time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088276Z"^^xsd:dateTime .

oakcurric:misconception-components-work-however-positioned-circuit
  a curric:Misconception ;
  curric:statement "Components all work however they are positioned in a circuit."@en ;
  curric:correction """Some components are polarised and only work if they are the correct way
  round."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089242Z"^^xsd:dateTime .

oakcurric:misconception-same-tools-methods-used-small
  a curric:Misconception ;
  curric:statement """The same tools and methods are used for both small-scale and industrial
  manufacturing."""@en ;
  curric:correction """The scale of production heavily influences tool choice, speed, accuracy, and
  repeatability."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090600Z"^^xsd:dateTime .

oakcurric:misconception-design-briefs-used-creative-fields
  a curric:Misconception ;
  curric:statement """Design briefs are only used in creative fields like product or graphic
  design."""@en ;
  curric:correction """Design briefs are crucial across many industries, including engineering,
  architecture, and product development."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092151Z"^^xsd:dateTime .

oakcurric:misconception-recycling-metals-reduces-their-quality
  a curric:Misconception ;
  curric:statement "Recycling metals reduces their quality."@en ;
  curric:correction """Most metals, including aluminium and steel, can be repeatedly recycled
  without negatively impacting their properties."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093650Z"^^xsd:dateTime .

oakcurric:misconception-practice-using-tools-needed-working
  a curric:Misconception ;
  curric:statement """Practice using the tools is not needed when working with textiles and timbers
  as they are easy to cut."""@en ;
  curric:correction """Practice is needed when using tools to cut all materials. Textiles and
  timbers are easy to cut, but complete control can be lost if cut too quickly. It can be
  challenging to keep on the line, so practice is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094132Z"^^xsd:dateTime .

oakcurric:misconception-quality-control-checks-performed-products
  a curric:Misconception ;
  curric:statement """Quality control checks are performed on products after they are made to ensure
  they meet the required quality standards for sale or use."""@en ;
  curric:correction """Quality control checks are performed throughout the process to ensure quality
  remains constant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094154Z"^^xsd:dateTime .

oakcurric:misconception-polymers-non-biodegradable-last-hundreds
  a curric:Misconception ;
  curric:statement "All polymers are non biodegradable and can last for hundreds of year."@en ;
  curric:correction """Polymers come in many forms including biodegradable and bio-based polymers
  that will break down more easily in the environment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094718Z"^^xsd:dateTime .

oakcurric:misconception-environmental-impact-material-happens-product
  a curric:Misconception ;
  curric:statement """The environmental impact of a material only happens when the product is thrown
  away."""@en ;
  curric:correction """A material’s environmental impact occurs at every stage of its life cycle;
  during manufacture, use, and disposal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095154Z"^^xsd:dateTime .

oakcurric:misconception-paper-boards-seen-weak-materials
  a curric:Misconception ;
  curric:statement "Paper and boards are often seen as weak materials."@en ;
  curric:correction """Many types of paper and boards are designed to be robust and durable, such as
  corrugated cardboard used for packaging."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097167Z"^^xsd:dateTime .

oakcurric:misconception-marking-tool-work-material
  a curric:Misconception ;
  curric:statement "Any marking tool will work on any material."@en ;
  curric:correction """Using the wrong tool (e.g a pencil on metal) can result in unclear or
  inaccurate marks. Different materials require specific marking tools, such as pencils for
  paper and boards and marking knives for wood."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098881Z"^^xsd:dateTime .

oakcurric:misconception-cost-product-concerns-raw-materials
  a curric:Misconception ;
  curric:statement "The cost of a product only concerns raw materials."@en ;
  curric:correction """Other factors like labour, overhead, distribution, and economies of scale
  affect the cost of a product."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098961Z"^^xsd:dateTime .

oakcurric:misconception-timbers-sustainable
  a curric:Misconception ;
  curric:statement "All timbers are sustainable."@en ;
  curric:correction """Timber can be a sustainable material if sourced from a Forest Stewardship
  Council certified supplier. FSC forests are managed to strict environmental, social, and
  ecological standards."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099743Z"^^xsd:dateTime .

oakcurric:misconception-believed-focusing-form-means-sacrificing
  a curric:Misconception ;
  curric:statement """It is often believed that focusing on form means sacrificing function, and
  vice versa. The assumption is that a product can't be both beautiful and functional."""@en ;
  curric:correction """Good design brings together both form and function. The form of a product can
  enhance the function of a product by making it more enjoyable to use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101298Z"^^xsd:dateTime .

oakcurric:misconception-control-systems-programmed-text-based
  a curric:Misconception ;
  curric:statement "Control systems are programmed with text-based languages."@en ;
  curric:correction """Control systems can be programmed using different languages including text,
  blocks or flow charts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101304Z"^^xsd:dateTime .

oakcurric:misconception-data-presented-graph-chart
  a curric:Misconception ;
  curric:statement "All data can be presented as a graph or chart."@en ;
  curric:correction """The way in which data is presented will depend on whether the data is
  quantitative or qualitative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102743Z"^^xsd:dateTime .

oakcurric:misconception-materials-properties-fixed-cannot-changed
  a curric:Misconception ;
  curric:statement "A material's properties are fixed and cannot be changed."@en ;
  curric:correction """Many materials can be altered after they are made to improve their
  properties, e.g. strength."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104038Z"^^xsd:dateTime .

oakcurric:misconception-joining-methods-work-same-material
  a curric:Misconception ;
  curric:statement "All joining methods work the same for every material."@en ;
  curric:correction """Different materials need different joining methods based on their
  properties."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104044Z"^^xsd:dateTime .

oakcurric:misconception-materials-ready-use-their-natural
  a curric:Misconception ;
  curric:statement "All materials are ready to use in their natural state."@en ;
  curric:correction """Raw materials need to go through a range of processing stages to make them
  usable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104097Z"^^xsd:dateTime .

oakcurric:misconception-modern-materials-provide-advantages-designers
  a curric:Misconception ;
  curric:statement "Modern materials only provide advantages to designers and users."@en ;
  curric:correction """Modern materials are often difficult and expensive to produce and are also
  difficult to recycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106242Z"^^xsd:dateTime .

oakcurric:misconception-quality-control-looking-product-end
  a curric:Misconception ;
  curric:statement """Quality control is only about looking at the product at the very end of
  production."""@en ;
  curric:correction """Quality Control can happen throughout production (in-process checks,
  sampling, functional tests), not just at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106511Z"^^xsd:dateTime .

oakcurric:misconception-investigating-context-consider-users-preferences
  a curric:Misconception ;
  curric:statement """When investigating a context, you should only consider the user's
  preferences."""@en ;
  curric:correction """Within a context, there are different groups of people who have different
  preferences. It is important for designers to consider these groups and their different
  social and cultural backgrounds, as well environmental considerations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106870Z"^^xsd:dateTime .

oakcurric:misconception-orthographic-projections-completed-manufacture
  a curric:Misconception ;
  curric:statement "Orthographic projections are completed after manufacture."@en ;
  curric:correction """Orthographic projections are known as a working drawing. These are sent from
  a designer to a manufacturer before manufacturing to enable them to manufacture the
  product or component."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107381Z"^^xsd:dateTime .

oakcurric:misconception-feedback-used-fix-problems
  a curric:Misconception ;
  curric:statement "Feedback is only used to fix problems."@en ;
  curric:correction """Industries use feedback not just to solve issues but also to innovate,
  improve efficiency, enhance customer satisfaction, and stay competitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108187Z"^^xsd:dateTime .

oakcurric:misconception-commercial-viability-relates-well-product
  a curric:Misconception ;
  curric:statement "Commercial viability only relates to how well a product works."@en ;
  curric:correction """A product can work well or be aesthetically pleasing, but if it’s too
  expensive to make, doesn’t meet market demand, or won’t sell at a profit, it isn’t
  commercially viable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110676Z"^^xsd:dateTime .

oakcurric:misconception-research-conducted-beginning-project
  a curric:Misconception ;
  curric:statement "Research is only conducted at the beginning of a project."@en ;
  curric:correction "Research is involved in several stages of the design process."@en ;
  dcterms:modified "2026-06-07T15:30:15.110993Z"^^xsd:dateTime .

oakcurric:misconception-testing-done-using-physical-control
  a curric:Misconception ;
  curric:statement "Testing must always be done using a physical control system."@en ;
  curric:correction """Testing a control system can be done using a physical control system and a
  multimeter or using a CAD simulation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111133Z"^^xsd:dateTime .

oakcurric:misconception-mental-health-wellbeing-challenges-personal
  a curric:Misconception ;
  curric:statement """Mental health and wellbeing challenges are too personal or 'invisible' to be
  designed for."""@en ;
  curric:correction """Designers don’t solve mental health itself, but create supportive products,
  services, or environments that ease challenges."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113001Z"^^xsd:dateTime .

oakcurric:misconception-buzzers-work-same-way
  a curric:Misconception ;
  curric:statement "Buzzers all work in the same way."@en ;
  curric:correction "Different buzzers work in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:15.113016Z"^^xsd:dateTime .

oakcurric:misconception-cheapest-material-best-choice
  a curric:Misconception ;
  curric:statement "The cheapest material is always the best choice."@en ;
  curric:correction """Material selection involves balancing multiple factors, such as strength,
  durability, weight, sustainability, and ease of manufacturing; in addition to cost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113259Z"^^xsd:dateTime .

oakcurric:misconception-technical-drawings-created-cad-correct
  a curric:Misconception ;
  curric:statement "Technical drawings created in CAD are always correct and error-free."@en ;
  curric:correction """Using CAD reduces human error; however, users must add correct and relevant
  dimensions. Incorrect constraints can also result in errors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113435Z"^^xsd:dateTime .

oakcurric:misconception-refinement-making-look-nicer
  a curric:Misconception ;
  curric:statement "Refinement is just “making it look nicer.”"@en ;
  curric:correction """Refinement is purposeful change based on evidence; it improves inclusivity,
  usability, and overall function, not just appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113682Z"^^xsd:dateTime .

oakcurric:misconception-systems-use-one-input
  a curric:Misconception ;
  curric:statement "Systems only use one input."@en ;
  curric:correction "Systems often have multiple inputs. These can be switches and sensors."@en ;
  dcterms:modified "2026-06-07T15:30:15.113798Z"^^xsd:dateTime .

oakcurric:misconception-variable-set-piece-data-change
  a curric:Misconception ;
  curric:statement "A variable is a set piece of data that can not change once collected."@en ;
  curric:correction """A variable is a named piece of data stored in a computer’s memory, accessed
  and changed by a computer program."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113859Z"^^xsd:dateTime .

oakcurric:misconception-prototype-works-definitely-manufactured-successfully
  a curric:Misconception ;
  curric:statement "If a prototype works, it can definitely be manufactured successfully."@en ;
  curric:correction """Functionality doesn’t guarantee feasibility or success. A design might work
  in one-off form but fail in cost, scale, or sustainability when made commercially."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113918Z"^^xsd:dateTime .

oakcurric:misconception-physical-sketching-same-sketching-parametric
  a curric:Misconception ;
  curric:statement "Physical sketching is the same as sketching in parametric CAD."@en ;
  curric:correction """Sketches in parametric CAD need to be constrained in order to create accurate
  and error free models."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114088Z"^^xsd:dateTime .

oakcurric:misconception-using-machinery-manufacture-requires-little
  a curric:Misconception ;
  curric:statement """Using machinery to manufacture requires little skill when compared to using
  hand tools."""@en ;
  curric:correction """Using machinery to manufacture products takes skill and effort to achieve a
  high quaility finish, much like using hand tools."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114241Z"^^xsd:dateTime .

oakcurric:misconception-research-copying-existing-designs
  a curric:Misconception ;
  curric:statement "Research is just “copying” existing designs."@en ;
  curric:correction """Designers critically analyse existing solutions to understand
  strengths/weaknesses for inspiration of new ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114316Z"^^xsd:dateTime .

oakcurric:misconception-specifications-use-same-subheadings
  a curric:Misconception ;
  curric:statement "All specifications must use the same subheadings."@en ;
  curric:correction """Specifications must be specific to the context, design opportunity and design
  brief."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114482Z"^^xsd:dateTime .

oakcurric:misconception-inclusive-design-applies-disability-accessibility
  a curric:Misconception ;
  curric:statement """Inclusive design only applies to disability or accessibility-related
  products."""@en ;
  curric:correction """Inclusive design applies to everyone. It’s about designing for human
  diversity - age, ability, background, culture, and mental wellbeing - across all
  industries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114550Z"^^xsd:dateTime .

oakcurric:misconception-testing-one-activity-happens-end
  a curric:Misconception ;
  curric:statement "Testing is a one-off activity that only happens at the end of designing."@en ;
  curric:correction """Testing is an iterative process - it happens throughout development. Each
  round of testing reveals new insights and informs further refinement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114622Z"^^xsd:dateTime .

oakcurric:misconception-sketch-needed-able-use-extrude
  a curric:Misconception ;
  curric:statement "A sketch is always needed to be able to use the Extrude command in Fusion."@en ;
  curric:correction "Users can extrude from component faces and existing solid bodies."@en ;
  dcterms:modified "2026-06-07T15:30:15.114628Z"^^xsd:dateTime .

oakcurric:misconception-inclusive-design-accessible-design-same
  a curric:Misconception ;
  curric:statement "Inclusive design and accessible design are the same thing."@en ;
  curric:correction """Accessible design is about making sure people with disabilities can use
  something. Inclusive design is about making sure everyone can use it, by thinking about
  all kinds of differences, including mental health and wellbeing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114644Z"^^xsd:dateTime .

oakcurric:misconception-prototypes-polished-look-like-final
  a curric:Misconception ;
  curric:statement "Prototypes must be polished or look like the final product."@en ;
  curric:correction """Early prototypes are rough and quick - their purpose is to test ideas, not
  show perfection."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114656Z"^^xsd:dateTime .

oakcurric:misconception-first-idea-best
  a curric:Misconception ;
  curric:statement "The first idea is always the best."@en ;
  curric:correction """Creativity improves with divergent thinking and iteration - the first idea is
  rarely the final one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114672Z"^^xsd:dateTime .

oakcurric:misconception-testing-prove-design-works
  a curric:Misconception ;
  curric:statement "Testing is only to prove that a design works."@en ;
  curric:correction """Testing is equally about finding flaws and learning what doesn’t work;
  failures provide insight."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114734Z"^^xsd:dateTime .

oakcurric:misconception-larger-diameter-pulley-wheel-higher
  a curric:Misconception ;
  curric:statement "The larger the diameter of a pulley wheel, the higher the output speed."@en ;
  curric:correction """The smaller the pulley wheel, the quicker it will complete a rotation,
  therefore increasing the output speed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114745Z"^^xsd:dateTime .

oakcurric:misconception-medium-fidelity-prototypes-tidier-versions
  a curric:Misconception ;
  curric:statement """Medium-fidelity prototypes are just “tidier” versions of low-fidelity
  ones."""@en ;
  curric:correction """Medium-fidelity is not about neatness - it’s about using stronger materials
  and semi-functional builds to test ergonomics and usability."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114826Z"^^xsd:dateTime .

oakcurric:misconception-3d-printing-sustainable-because-additive
  a curric:Misconception ;
  curric:statement """3D printing is sustainable because it is an additive manufacturing process
  with minimal waste."""@en ;
  curric:correction """3D printing filament is a thermopolymer. As with all manufacturing processes,
  there needs to be consideration of the materials used, their sources and disposal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114938Z"^^xsd:dateTime .

oakcurric:misconception-testing-happens-final-prototype-made
  a curric:Misconception ;
  curric:statement "Testing only happens when the final prototype has been made."@en ;
  curric:correction """Testing should happen throughout the iterative journey, so that design
  decisions are made to meet design requirements and produce a successful design solution."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115457Z"^^xsd:dateTime .

oakcurric:misconception-components-placed-eye-assembly-modelling
  a curric:Misconception ;
  curric:statement "Components can be placed by eye when assembly modelling in Fusion."@en ;
  curric:correction """To create assemblies in Fusion, the correct joints should be used to
  replicate how components are assembled in the real world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115505Z"^^xsd:dateTime .

oakcurric:misconception-adding-physical-materials-components-fusion
  a curric:Misconception ;
  curric:statement """Adding physical materials to components in Fusion is for aesthetic purposes
  only."""@en ;
  curric:correction """Adding physical materials to components alters their appearance and
  properties."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115589Z"^^xsd:dateTime .

oakcurric:misconception-cad-modelling-same-whether-working
  a curric:Misconception ;
  curric:statement "All CAD modelling is the same, whether working in Tinkercad or Fusion."@en ;
  curric:correction """Different CAD applications work in three distinct ways, constructive solid
  geometry, solid modelling and parametric modelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115662Z"^^xsd:dateTime .

oakcurric:misconception-iterations-models-purely-based-thoughts
  a curric:Misconception ;
  curric:statement "Iterations of models are purely based on the thoughts of the designer."@en ;
  curric:correction """Iterations can be based off a range of analysis and evaluations such as
  evaluating against the users needs and wants as well as direct feedback from the user."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115753Z"^^xsd:dateTime .

oakcurric:misconception-sustainability-decisions-happen-product-designed
  a curric:Misconception ;
  curric:statement "Sustainability decisions happen after the product has been designed."@en ;
  curric:correction """At the design stage, designers have a huge responsibility to influence many
  other stages of a product's life cycle through their design decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116137Z"^^xsd:dateTime .

oakcurric:misconception-biomimicry-using-nature-inspire-aesthetics
  a curric:Misconception ;
  curric:statement "Biomimicry is using nature to inspire aesthetics."@en ;
  curric:correction """Biomimicry uses nature to inspire solutions to problems, biomorphism is about
  nature inspiring aesthetics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116726Z"^^xsd:dateTime .

oakcurric:misconception-empathy-means-feeling-sorry-others
  a curric:Misconception ;
  curric:statement "Empathy just means “feeling sorry” for others."@en ;
  curric:correction """Empathy is understanding someone’s perspective and experience to inform
  design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117165Z"^^xsd:dateTime .

oakcurric:misconception-product-safety-consumer-protection
  a curric:Misconception ;
  curric:statement "Product safety is only about consumer protection."@en ;
  curric:correction "Industry safety also includes protecting workers."@en ;
  dcterms:modified "2026-06-07T15:30:15.117735Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-define-product-wish
  a curric:Misconception ;
  curric:statement """Pupils tend to define a product that they wish to design and make at this
  point. They become fixated on a design."""@en ;
  curric:correction """Pupils need to keep their design brief open so that it does not create design
  fixation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117741Z"^^xsd:dateTime .

oakcurric:misconception-3d-sketching-2d-sketching-additional
  a curric:Misconception ;
  curric:statement "3D sketching is just 2D sketching with an additional dimension."@en ;
  curric:correction "To be able to sketch in 3D, we need to understand depth and perspective."@en ;
  dcterms:modified "2026-06-07T15:30:15.118582Z"^^xsd:dateTime .

oakcurric:misconception-smart-materials-fun-products-like
  a curric:Misconception ;
  curric:statement "Smart materials are only for fun products like colour changing mugs!"@en ;
  curric:correction """Smart materials give designers and engineers exciting possibilities when
  developing new products. Possibilities often focus on function and/or form. For example,
  thermochromic materials can be used to indicate a temperature and warn users of danger."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118927Z"^^xsd:dateTime .

oakcurric:misconception-redesigning-product-circular-economy-means
  a curric:Misconception ;
  curric:statement """Redesigning a product for the circular economy only means making it
  recyclable."""@en ;
  curric:correction """Redesign in the circular economy involves designing products to last longer,
  be repaired, reused, or upgraded to reduce waste throughout the product’s entire life
  cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119224Z"^^xsd:dateTime .

oakcurric:misconception-industries-modify-products-make-them
  a curric:Misconception ;
  curric:statement "Industries only modify products to make them cheaper."@en ;
  curric:correction """Industries also improve products for better performance, sustainability,
  customer satisfaction, safety and compliance with regulations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120179Z"^^xsd:dateTime .

oakcurric:misconception-using-machinery-results-greater-accuracy
  a curric:Misconception ;
  curric:statement "Using machinery results in greater accuracy."@en ;
  curric:correction """Machinery or hand tools can result in accurate manufacturing. Accuracy is
  achieved with careful planning and execution with skill."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120570Z"^^xsd:dateTime .

oakcurric:misconception-mass-production-continuous-production-same
  a curric:Misconception ;
  curric:statement "Mass production and continuous production are the same thing."@en ;
  curric:correction "Mass production stops and starts, but continuous production never stops."@en ;
  dcterms:modified "2026-06-07T15:30:15.122941Z"^^xsd:dateTime .

oakcurric:misconception-socioeconomic-status-persons-income
  a curric:Misconception ;
  curric:statement "Socioeconomic status is just about a person's income."@en ;
  curric:correction """It is a combination of things such as income, education, occupation and even
  influence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122973Z"^^xsd:dateTime .

oakcurric:misconception-gantt-charts-used-plan-whole
  a curric:Misconception ;
  curric:statement "Gantt charts are used to plan out the whole design project."@en ;
  curric:correction """Gantt charts can be used as a tool to plan out the whole design project.
  However it can be beneficial to use Gantt charts for the individual phases within the
  project, like the manufacturing stage. This can improve efficiency at crucial stages."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123469Z"^^xsd:dateTime .

oakcurric:misconception-fixating-one-idea-existing-ideas
  a curric:Misconception ;
  curric:statement "Fixating on one idea or existing ideas will lead to innovative designing."@en ;
  curric:correction """Design fixation is the opposite of being innovative and is focussing or
  fixating on one idea or existing ideas. This can limit creativity and innovation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124326Z"^^xsd:dateTime .

oakcurric:misconception-students-think-understand-context-without
  a curric:Misconception ;
  curric:statement """Students often 'think' they understand a context without having fully explored
  it."""@en ;
  curric:correction """Students need to be encouraged to fully explore a context so to understand it
  fully before moving onto designing. This is great practice for the NEA."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124823Z"^^xsd:dateTime .

oakcurric:misconception-high-fidelity-prototypes-appearance-surface
  a curric:Misconception ;
  curric:statement "High-fidelity prototypes are only about appearance and surface finish."@en ;
  curric:correction """High-fidelity prototypes are about realism in both look and function. They
  should operate as closely as possible to the intended product - or convincingly simulate
  that functionality."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125181Z"^^xsd:dateTime .

oakcurric:misconception-new-emerging-technologies-positive-impacts
  a curric:Misconception ;
  curric:statement "New and emerging technologies have only positive impacts."@en ;
  curric:correction """New and emerging technologies can make some products obsolete. It can also
  mean that many workers with limited skills lose their jobs to robots. These workers may
  find it difficult, or may not want to, retrain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125851Z"^^xsd:dateTime .

oakcurric:misconception-considering-products-energy-use-way
  a curric:Misconception ;
  curric:statement """Considering a product's energy use is the only way to design a sustainable
  product."""@en ;
  curric:correction """There are many other ways to design a product to be sustainable when in use,
  including designing products to grow with users, be adjusted, modular, reused etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126231Z"^^xsd:dateTime .

oakcurric:misconception-development-design-ideas-coming-completely
  a curric:Misconception ;
  curric:statement """Development of design ideas is coming up with a completely new idea or the
  idea has to be changed significantly."""@en ;
  curric:correction """Developing an idea can be changing and altering very small things such as
  function, materials, size, proportion or aesthetics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126237Z"^^xsd:dateTime .

oakcurric:misconception-parts-lists-needed-materials-components
  a curric:Misconception ;
  curric:statement """Parts lists are only needed for materials or components which need to be
  bought in."""@en ;
  curric:correction """A parts lists supports the thinking needed in preparation of manufacture for
  all components of a design. They help identify quantities and can highlight mistakes. A
  well-structured parts list speeds up production and ensures cost efficiency."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126577Z"^^xsd:dateTime .

oakcurric:misconception-prototypes-life-size
  a curric:Misconception ;
  curric:statement "All prototypes must be life size."@en ;
  curric:correction """It is not always possible to manufacture life size prototypes. The space to
  manufacture and store may be limited plus the materials may be expensive. A smaller scale
  product saves space and materials but still allows for a product to be manufactured."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126583Z"^^xsd:dateTime .

oakcurric:misconception-repair-maintenance-recycling-sole-responsibility
  a curric:Misconception ;
  curric:statement "Repair, maintenance and recycling is the sole responsibility of the user."@en ;
  curric:correction """Design decisions made at the design/redesign stage can determine the ease and
  ability of a product to be repaired, maintained and recycled."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127046Z"^^xsd:dateTime .

oakcurric:misconception-using-ai-designing-cheating
  a curric:Misconception ;
  curric:statement "Using AI when designing is cheating."@en ;
  curric:correction """AI can be used to help inspire us and is used to develop our own ideas. We
  must just be open and honest in our use of it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127177Z"^^xsd:dateTime .

oakcurric:misconception-designing-products-using-average-measurements
  a curric:Misconception ;
  curric:statement """Designing products using the average measurements in an anthropometric data
  set will provide a successful user experience for all users."""@en ;
  curric:correction """Designing for the average person can diminish user experience and exclude a
  significant portion of the population from using products."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128536Z"^^xsd:dateTime .

oakcurric:misconception-data-involves-numbers
  a curric:Misconception ;
  curric:statement "Data always involves numbers."@en ;
  curric:correction "Data is information and can be recorded using both numbers and words."@en ;
  dcterms:modified "2026-06-07T15:30:15.130180Z"^^xsd:dateTime .

oakcurric:misconception-quality-control-checks-done-products
  a curric:Misconception ;
  curric:statement """Quality control are checks that are done on products once made to ensure they
  are a high enough quality to be sold or used."""@en ;
  curric:correction """Quality control checks are done throughout the process to ensure quality is a
  constant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130594Z"^^xsd:dateTime .

oakcurric:misconception-increasing-size-driven-gear-increases
  a curric:Misconception ;
  curric:statement "Increasing the size of the driven gear, increases the output speed."@en ;
  curric:correction """Decreasing the size of the driven gear (or increasing the size of driver
  gear), increases the speed of the driven gear."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131110Z"^^xsd:dateTime .

oakcurric:misconception-innovation-revolutionary-entirely-original
  a curric:Misconception ;
  curric:statement "Innovation has to be revolutionary and entirely original."@en ;
  curric:correction """Innovation can be revolutinary like the 'cats eye' or evolutionary where
  ideas change gradually and evolve over time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132100Z"^^xsd:dateTime .

oakcurric:misconception-using-sources-inspiration-designing-copying
  a curric:Misconception ;
  curric:statement "Using sources of inspiration when designing is copying."@en ;
  curric:correction """When using sources of inspiration, they are usually not solutions or similar
  products but instead any image or product that inspires a spark of creativity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132105Z"^^xsd:dateTime .

oakcurric:misconception-fairtrade-label-bananas
  a curric:Misconception ;
  curric:statement "Fairtrade is just the label on bananas."@en ;
  curric:correction """Fairtrade is a system that ensures farmers and workers receive fair prices,
  decent working conditions and support for sustainable community development through trade."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132155Z"^^xsd:dateTime .

oakcurric:misconception-systems-simple-one-input-process
  a curric:Misconception ;
  curric:statement "Systems are simple with just one input, process and output."@en ;
  curric:correction """Systems can be complex with multiple inputs, processes and outputs, feedback
  and variables."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133140Z"^^xsd:dateTime .

oakcurric:misconception-once-final-product-complete-further
  a curric:Misconception ;
  curric:statement """Once a final product is complete no further iterations or improvements are
  needed."""@en ;
  curric:correction """Designers constantly seek to improve and develop their designs and products.
  No product is ever perfect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133859Z"^^xsd:dateTime .

oakcurric:misconception-new-technology-good-use
  a curric:Misconception ;
  curric:statement "All new technology is good and we should use it."@en ;
  curric:correction """New technology can be good but may also have negative consequences which
  responsible designers must consider."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137600Z"^^xsd:dateTime .

oakcurric:misconception-timbers-need-varnish-protect-them
  a curric:Misconception ;
  curric:statement "Timbers need a varnish to protect them."@en ;
  curric:correction """There are many different options to finish the surface of timber and these
  are chosen depending on the type of timber, intended use, planned aesthetics etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138976Z"^^xsd:dateTime .

oakcurric:misconception-2-dimensional-products-manufactured-using
  a curric:Misconception ;
  curric:statement "Only 2-dimensional products can be manufactured using a laser cutter."@en ;
  curric:correction """Lamination can be used to create more curved and organic shapes or to create
  strength in an object."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139303Z"^^xsd:dateTime .

oakcurric:misconception-aesthetically-pleasing-idea-best
  a curric:Misconception ;
  curric:statement "The most aesthetically-pleasing idea is the best."@en ;
  curric:correction """Strong design choices balance creativity with inclusivity, feasibility, and
  impact - aesthetics alone aren’t enough."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141697Z"^^xsd:dateTime .

oakcurric:misconception-choosing-materials-based-aesthetics
  a curric:Misconception ;
  curric:statement "Choosing materials is always based on aesthetics."@en ;
  curric:correction """Many factors determine the material choice, such as the purpose and
  environment of the product. For example, cotton calico is absorbent and not suitable for
  damp or humid places unless finished with a waterproof layer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142456Z"^^xsd:dateTime .

oakcurric:misconception-alessi-thought-single-designer
  a curric:Misconception ;
  curric:statement "Alessi is often thought of as a single designer."@en ;
  curric:correction "Alessi is a group of designers."@en ;
  dcterms:modified "2026-06-07T15:30:15.142569Z"^^xsd:dateTime .

oakcurric:misconception-way-reduce-environmental-impact-distribution
  a curric:Misconception ;
  curric:statement """The only way to reduce environmental impact at the distribution stage is
  through using electric vehicles."""@en ;
  curric:correction """There are many ways such as designing flat pack, stackable, lightweight
  products, and location of manufacture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143361Z"^^xsd:dateTime .

oakcurric:misconception-leds-used-individually
  a curric:Misconception ;
  curric:statement "LEDs are always used individually."@en ;
  curric:correction "LEDs can be grouped in strips or matrices to create patterns or messages."@en ;
  dcterms:modified "2026-06-07T15:30:15.143526Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-their-manufacturing-specification
  a curric:Misconception ;
  curric:statement "Pupils will use only their manufacturing specification when making."@en ;
  curric:correction """Many pupils will struggle with time managment when manufacturing. Pupils need
  to plan out their time so that they can keep on track to meet their deadline whilst
  thinking about the operational elements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146785Z"^^xsd:dateTime .

oakcurric:misconception-design-specifications-technical-specifications-same
  a curric:Misconception ;
  curric:statement "Design specifications and technical specifications are the same."@en ;
  curric:correction """Design specifications focus on the overall concept, user needs, and
  appearance. Technical specifications detail the materials and measurement requirements
  needed to build a product."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147146Z"^^xsd:dateTime .

oakcurric:misconception-textiles-made-fossil-fuels
  a curric:Misconception ;
  curric:statement "Textiles are not made from fossil fuels."@en ;
  curric:correction """Synthetic fibres are usually made from fossil fuels such a polyester and
  ripstop nylon."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147897Z"^^xsd:dateTime .

oakcurric:misconception-possible-outcome-design-fixation-limits
  a curric:Misconception ;
  curric:statement """Possible outcome design fixation limits context exploration. Product analysis
  leads to copying."""@en ;
  curric:correction """Product analysis identifies successful features and those which can be
  improved."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147905Z"^^xsd:dateTime .

oakcurric:misconception-motors-operate-same-way
  a curric:Misconception ;
  curric:statement "All motors operate in the same way."@en ;
  curric:correction """DC motors use open-loop systems, and servo motors use a closed-loop
  system."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149344Z"^^xsd:dateTime .

oakcurric:misconception-way-gain-ma-increasing-input
  a curric:Misconception ;
  curric:statement "The only way to gain MA is by increasing the input force."@en ;
  curric:correction """MA can be increased by increasing the distance from the fulcrum and the
  effort. For example, increasing the arm length on the handle of a flat head screwdriver
  when opening a can of paint."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149618Z"^^xsd:dateTime .

oakcurric:misconception-product-analysis-identifying-flaws-problems
  a curric:Misconception ;
  curric:statement "Product analysis is only about identifying flaws or problems in a product."@en ;
  curric:correction """In reality, product analysis is used to improve design, meet user needs, and
  stay competitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152036Z"^^xsd:dateTime .

oakcurric:misconception-branding-logos-same-thing
  a curric:Misconception ;
  curric:statement "Branding and logos are the same thing."@en ;
  curric:correction """Branding is the way of making a company’s product or service more visible and
  recognisable. A logo is just a small part of branding and is a simple symbol or design
  that represents a business or brand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155234Z"^^xsd:dateTime .

oakcurric:misconception-rendering-adding-tone
  a curric:Misconception ;
  curric:statement "Rendering is just adding tone."@en ;
  curric:correction """Rendering should consider tone and depth but also the texture of the material
  the product is made out of."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156618Z"^^xsd:dateTime .

oakcurric:misconception-possible-present-quantitative-data
  a curric:Misconception ;
  curric:statement "It is only possible to present quantitative data."@en ;
  curric:correction "Qualitative data can be presented in other formats to summarise findings."@en ;
  dcterms:modified "2026-06-07T15:30:15.157545Z"^^xsd:dateTime .

oakcurric:misconception-patents-trademarks-same-thing
  a curric:Misconception ;
  curric:statement "Patents and trademarks are the same thing."@en ;
  curric:correction """Trademarks protect brand names and logos whilst patents protect inventions
  and new technologies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160526Z"^^xsd:dateTime .

oakcurric:misconception-envionmental-impact-assessed-product-manufactured
  a curric:Misconception ;
  curric:statement """Envionmental impact can only be assessed after a product has been
  manufactured."""@en ;
  curric:correction """Environmental impact can be assessed at every and all stages of the iterative
  design process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162782Z"^^xsd:dateTime .

oakcurric:misconception-research-needs-take-place-start
  a curric:Misconception ;
  curric:statement """Research only needs to take place at the start of the iterative design
  process."""@en ;
  curric:correction """Research is vital throughout the iterative design process and is not a linear
  activity. Pupils can research at any point to aid their design decisions and provide
  inspiration throughout the iterative process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163013Z"^^xsd:dateTime .

oakcurric:misconception-select-component-same
  a curric:Misconception ;
  curric:statement "When we select a component, they are all the same."@en ;
  curric:correction """Different circuits and control systems require different value components.
  Changing one will affect the others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163194Z"^^xsd:dateTime .

oakcurric:misconception-annotations-replace-need-clear-accurate
  a curric:Misconception ;
  curric:statement "Annotations can replace the need for a clear and accurate sketch."@en ;
  curric:correction """Annotation provides further explanation or clarification on what is not
  visible in the sketch."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163767Z"^^xsd:dateTime .

oakcurric:misconception-hand-tools-outdated-less-accurate
  a curric:Misconception ;
  curric:statement "Hand tools are outdated and less accurate than power tools."@en ;
  curric:correction """Hand tools offer high precision when used correctly, especially for detailed
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164495Z"^^xsd:dateTime .

oakcurric:misconception-questionnaires-used-present-data-graphs
  a curric:Misconception ;
  curric:statement """Questionnaires are only used to present data in graphs when investigating a
  context."""@en ;
  curric:correction """Questionnaires inform designing and provide evidence to justify design
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164610Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-their-primary-user
  a curric:Misconception ;
  curric:statement """Pupils will know who their primary user is and will want to start
  designing."""@en ;
  curric:correction """Pupils need to find out more about the primary user and stakeholders so that
  they can define suitable and researched design requirements. This subsequently leads to
  successful design solutions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165237Z"^^xsd:dateTime .

oakcurric:misconception-qa-qc-same-thing
  a curric:Misconception ;
  curric:statement "QA and QC are the same thing."@en ;
  curric:correction """QA (Quality Assurance) focuses on preventing defects by improving the
  production process, while QC (Quality Control) focuses on identifying and fixing defects
  in the finished product."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165242Z"^^xsd:dateTime .

oakcurric:misconception-using-closed-questions-interview-provide
  a curric:Misconception ;
  curric:statement """Using closed questions in an interview will provide enough effective
  information to support further developments."""@en ;
  curric:correction """Using open-ended questions in an interview will allow for more detailed and
  flexible reponses, providing oppotunites for effective outcomes to support further
  developments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166357Z"^^xsd:dateTime .

oakcurric:misconception-students-become-busy-manufacturing-their
  a curric:Misconception ;
  curric:statement """Students become so busy manufacturing their design solution that they often
  forget to evidence their manufacture."""@en ;
  curric:correction """It's easy to overlook the effort behind a product from the final photo.
  Documenting the manufacturing process highlights the skills, techniques, safety, and
  quality checks students use, proving their work, not the technician's."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166420Z"^^xsd:dateTime .

oakcurric:misconception-three-design-ideas-enough-avoid
  a curric:Misconception ;
  curric:statement "Three design ideas are enough to avoid design fixation."@en ;
  curric:correction """There are many ways to generate design ideas that avoid design fixation and
  produce a range of successful ideas that pupils can develop on their iterative journey."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166757Z"^^xsd:dateTime .

oakcurric:misconception-modifications-quickly-generated-students-personal
  a curric:Misconception ;
  curric:statement """Modifications are often quickly generated by the student's personal opinions,
  rather than their evaluations."""@en ;
  curric:correction """Modifications should be informed from thorough testing and evaluation against
  design requirements with feedback from the primary user/stakeholders/experts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168293Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-know-manufacture-their
  a curric:Misconception ;
  curric:statement """Some pupils will assume that they know how to manufacture their design without
  the need for a manufacturing specification."""@en ;
  curric:correction """Designs are rarely understood by verbal explanation, they need visual
  representations with specific details of materials, dimensions, finishes and suitable
  processes. Communication methods will vary depending on your design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168299Z"^^xsd:dateTime .

oakcurric:misconception-factories-produce-goods-large-amounts
  a curric:Misconception ;
  curric:statement "Factories always produce goods in large amounts."@en ;
  curric:correction """Factories are responsive and often adjust production methods based on
  demand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168562Z"^^xsd:dateTime .

oakcurric:misconception-sketching-way-iterate-design-ideas
  a curric:Misconception ;
  curric:statement "Sketching is the only way to iterate design ideas."@en ;
  curric:correction """Design ideas and iterations can be communicated using various techniques,
  such as sketching, CAD, prototyping, and AI."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168923Z"^^xsd:dateTime .

oakcurric:misconception-pupils-already-know-want-design
  a curric:Misconception ;
  curric:statement """Pupils often already know what they want to design and feel that their first
  prototype is the final solution that doesn't need further development."""@en ;
  curric:correction """The iterative journey transforms an idea into a successful product. Pupils
  should carefully explore, experiment, test, and develop ideas while keeping design
  requirements central to the process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169782Z"^^xsd:dateTime .

oakcurric:misconception-specification-written-research-referred-once
  a curric:Misconception ;
  curric:statement """A specification is written after research and then referred to once the
  product is manufactured."""@en ;
  curric:correction """Design requirements should be used throughout the iterative journey (not just
  at the end!) to test concepts and make effective design decisions to creatively develop
  the product into a successful design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170644Z"^^xsd:dateTime .

oakcurric:misconception-design-brief-specific-identify-product
  a curric:Misconception ;
  curric:statement """A design brief should be very specific and identify a product that will be
  designed and manufactured."""@en ;
  curric:correction """To avoid design fixation, a design brief should be non-specific and open. A
  design brief should focus on the context and the problem, and not name a product that will
  be designed and made."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170980Z"^^xsd:dateTime .

oakcurric:misconception-manufacturing-process-selection-solely-based
  a curric:Misconception ;
  curric:statement "Manufacturing process selection is solely based on cost."@en ;
  curric:correction """Factors like product complexity, material properties, production volume, and
  lead time also play crucial roles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171011Z"^^xsd:dateTime .
