  dcterms:modified "2026-06-07T15:30:29.254936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29579-1
  a curric:KeyLearningPoint ;
  rdfs:label "The type of surface finish depends on the material, product and purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.254961Z"^^xsd:dateTime .

