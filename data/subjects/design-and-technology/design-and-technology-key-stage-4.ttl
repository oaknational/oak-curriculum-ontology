oakcurric:keylearningpoint-lesson-27191-2
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable sources of energy harness naturally occurring phenomenon, such as
  wind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27191-3
  a curric:KeyLearningPoint ;
  rdfs:label "Energy can be stored for later use in batteries."@en ;
