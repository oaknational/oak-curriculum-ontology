oakcurric:keylearningpoint-lesson-29575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most 3D printers in schools use a process called fused filament fabrication
  (FFF)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29575-3
  a curric:KeyLearningPoint ;
  rdfs:label "3D models need to be prepared for printing using a slicing application."@en ;
  dcterms:modified "2026-06-07T15:30:29.000941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29575-4
  a curric:KeyLearningPoint ;
  rdfs:label "3D printing allows manufacturers to change the design quickly and easily."@en ;
  dcterms:modified "2026-06-07T15:30:29.000947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29575-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are basic design for manufacture rules to follow when producing models for 3D
  printing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27158-1
  a curric:KeyLearningPoint ;
  rdfs:label """A laser cutter uses a high-powered laser beam to precisely cut or engrave
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27158-2
  a curric:KeyLearningPoint ;
  rdfs:label """A laser cutter works by directing a powerful laser beam through mirrors or fibre
  optics to a lens."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27158-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make 3D prototypes using CAD on a laser cutter, designers need to consider how to
  turn a 3D design into 2D shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27158-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are different ways a laser cutter can be used to create a 3D product from 2D
  shapes, such as nets and lamination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001818Z"^^xsd:dateTime .

