  a curric:KeyLearningPoint ;
  rdfs:label """Larger machines remove material quickly, more accurately, and consistently
  at scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27213-1
  a curric:KeyLearningPoint ;
  rdfs:label "Design briefs outline the requirements of a project."@en ;
  dcterms:modified "2026-06-07T15:30:29.270688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27213-2
  a curric:KeyLearningPoint ;
  rdfs:label """Focusing too narrowly on one idea can limit creativity and prevent finding the best
