oakcurric:keylearningpoint-lesson-27156-3
  a curric:KeyLearningPoint ;
  rdfs:label "Before developing your ideas in CAD your sketches should be evaluated."@en ;
  dcterms:modified "2026-06-07T15:30:29.000212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29575-1
  a curric:KeyLearningPoint ;
