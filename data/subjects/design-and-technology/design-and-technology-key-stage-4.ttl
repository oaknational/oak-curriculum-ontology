oakcurric:keylearningpoint-lesson-27153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers communicate design ideas with sketches."@en ;
  dcterms:modified "2026-06-07T15:30:29.255870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27153-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designers communicate design ideas using a variety of modelling materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.255874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sketching is a quick, freehand drawing of ideas or concepts, often done as a rough
  outline of an idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27153-4
  a curric:KeyLearningPoint ;
