# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-27150-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials, components and manufacturing processes should be analysed when carrying
  out a product disassembly."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27150-2
  a curric:KeyLearningPoint ;
  rdfs:label "A product disassembly is when we take something apart to investigate it further."@en ;
  dcterms:modified "2026-06-07T15:30:28.999453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Primary research such as a product disassembly can be a great way to investigate and
  analyse a product."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27157-1
  a curric:KeyLearningPoint ;
  rdfs:label "The manufacturing method can influence the design."@en ;
  dcterms:modified "2026-06-07T15:30:28.999461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27157-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designs might need to be modified depending on CAM constraints."@en ;
  dcterms:modified "2026-06-07T15:30:28.999468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29582-1
  a curric:KeyLearningPoint ;
  rdfs:label "A design portfolio is a collection of a designer's work."@en ;
  dcterms:modified "2026-06-07T15:30:28.999473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29582-2
  a curric:KeyLearningPoint ;
  rdfs:label """A design portfolio shows the journey including all of the ideas that were not taken
  through or were not successful."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29582-3
  a curric:KeyLearningPoint ;
  rdfs:label """A design portfolio should reflect the iterative way in which the designer has
  worked."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29582-4
  a curric:KeyLearningPoint ;
  rdfs:label "Digital media can be used to present a design portfolio."@en ;
  dcterms:modified "2026-06-07T15:30:28.999485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29582-5
  a curric:KeyLearningPoint ;
  rdfs:label """The iterative design process is a cycle of creating, testing, and improving a design
  until it meets the user’s needs."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27152-1
  a curric:KeyLearningPoint ;
  rdfs:label "Responsible design considers the environmental impact from design to disposal."@en ;
  dcterms:modified "2026-06-07T15:30:28.999651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27152-2
  a curric:KeyLearningPoint ;
  rdfs:label """A product life cycle is the stages from its introduction to the market until its
  decline or discontinuation."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27152-3
  a curric:KeyLearningPoint ;
  rdfs:label """Life cycle assessment (LCA) is where the environmental impact is assessed at all
  stages of the product’s life cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29572-1
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual modelling is an alternative to physical modelling that brings different
  benefits to the designer."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29572-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual modelling is the creation of digital 3D representations of objects or
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29572-3
  a curric:KeyLearningPoint ;
  rdfs:label "Virtual modelling using CAD can be useful for testing ideas."@en ;
  dcterms:modified "2026-06-07T15:30:28.999751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29572-4
  a curric:KeyLearningPoint ;
  rdfs:label """Designers test their designs to find out what works, what doesn't, and how to make
  them better."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29581-1
  a curric:KeyLearningPoint ;
  rdfs:label """Once a prototype is completed, it is important to evaluate your prototype and
  design."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29581-2
  a curric:KeyLearningPoint ;
  rdfs:label """To do this effectively, the designer needs to gather other people's opinions rather
  than just their own."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29581-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gathering feedback from the user and the target market is essential to ensure the
  prototype meets the needs of the user."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29581-4
  a curric:KeyLearningPoint ;
  rdfs:label """Market testing is trying out a product with your target market and users to see how
  well it works and if they like it."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29578-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers and manufacturers use quality assurance (QA) and quality control (QC)."@en ;
  dcterms:modified "2026-06-07T15:30:29.000149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29578-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quality assurance is about checking the planning and processes."@en ;
  dcterms:modified "2026-06-07T15:30:29.000154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29578-3
  a curric:KeyLearningPoint ;
  rdfs:label """Quality control is about checking the product to make sure it meets the required
  standard."""@en ;
