# ----------------------------------------------------------------------
# Units
# ----------------------------------------------------------------------

oakcurric:unit-3602
  a curric:Unit ;
  rdfs:label "Iterative design: Student Living"@en ;
  curric:slug "interative-design-student-living" ;
  rdfs:comment """Pupils will use disassembly to investigate an existing piece of flat-pack
  furniture, including material sources. They will use this information to inform designs.
  Pupils will focus on user-centred design to create and develop ideas and then plan the
  manufacturer for a product."""@en ;
  curric:whyThisWhyNow """Being proficient with digital modelling and communication skills is
  essential for successful design. Pupils develop knowledge and skills learnt previously in
  units such as Year 7, 'Prototypes with mechanisms: promotional displays', where pupils learnt
  how to create 3D models. This unit develops modelling and CAD skills. This unit prepares the
  pupils for subsequent user-centred iterative design units.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3602-1 ,
    oakcurric:priorknowledge-3602-2 ,
    oakcurric:priorknowledge-3602-3 ,
    oakcurric:priorknowledge-3602-4 ,
    oakcurric:priorknowledge-3602-5 ,
    oakcurric:priorknowledge-3602-6 ;
  curric:id "3602"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.251678Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-design-and-technology-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-sustainability-and-climate-change ,
    oakcurric:thread-user-centred-design ,
    oakcurric:thread-design ,
    oakcurric:thread-materials ,
    oakcurric:thread-critique-and-evaluate ,
    oakcurric:thread-manufacture .

oakcurric:unit-3605
  a curric:Unit ;
  rdfs:label "Core principles"@en ;
  curric:slug "core-principles" ;
  rdfs:comment """In this unit pupils will develop core principles knowledge with an explicit focus
  on exam technique."""@en ;
  curric:whyThisWhyNow """This unit draws together the core principles knowledge learnt in Year 10
  and prior units including the Year 7 materials and processes unit and the Year 8 material
  testing unit. The pupils are taught how to use this knowledge of materials, processes and
  technology in society, effectively and articulately to succeed in terminal exams.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3605-1 ,
    oakcurric:priorknowledge-3605-2 ,
    oakcurric:priorknowledge-3605-3 ,
    oakcurric:priorknowledge-3605-4 ,
    oakcurric:priorknowledge-3605-5 ;
  curric:id "3605"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.766209Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-design-and-technology-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-sustainability-and-climate-change ,
    oakcurric:thread-systems ,
    oakcurric:thread-materials .

oakcurric:unit-3608
  a curric:Unit ;
  rdfs:label "Iterative Design Principles"@en ;
  curric:slug "iterative-design-principles" ;
  rdfs:comment """In this unit pupils will reflect and build upon designing and making principles to
  which they have been introduced previously. this will be assessed in the Non-Examined
  Assessment"""@en ;
  curric:whyThisWhyNow """This unit is the culmination of prior learning of designing, making and
  evaluating. Students can use knowledge from previous Year 10 iterative design units, nature
  and student living as foundations for independence. Here we build on pupils' design and
  technology capability by reflecting on the techniques learnt to design, make and evaluate.
  This unit can be used when introducing the Non-Examined Assessment allowing pupils to have
  autonomy to select the most appropriate technique for the context.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3608-1 ,
    oakcurric:priorknowledge-3608-2 ,
    oakcurric:priorknowledge-3608-3 ,
    oakcurric:priorknowledge-3608-4 ,
    oakcurric:priorknowledge-3608-5 ,
    oakcurric:priorknowledge-3608-6 ,
    oakcurric:priorknowledge-3608-7 ,
    oakcurric:priorknowledge-3608-8 ;
  curric:id "3608"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.778886Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-design-and-technology-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-user-centred-design ,
    oakcurric:thread-design ,
    oakcurric:thread-critique-and-evaluate ,
    oakcurric:thread-manufacture .

oakcurric:unit-3606
  a curric:Unit ;
  rdfs:label "Technical principles"@en ;
  curric:slug "technical-principles" ;
  rdfs:comment """In this unit pupils will develop technical principles knowledge with an explicit
  focus on exam technique."""@en ;
  curric:whyThisWhyNow """This unit draws together the technical principles knowledge learnt in
  prior units, including the Year 10 encouraging a healthy lifestyle unit and the Year 10
  inclusive design unit. Pupils will consolidate and apply this in-depth understanding of a
  specialist material area and the processes and considerations associated with it. In this
  unit, the pupils are taught how to present their technical understanding concisely in the
  terminal exam.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3606-1 ,
    oakcurric:priorknowledge-3606-2 ,
    oakcurric:priorknowledge-3606-3 ,
    oakcurric:priorknowledge-3606-4 ,
    oakcurric:priorknowledge-3606-5 ,
    oakcurric:priorknowledge-3606-6 ;
  curric:id "3606"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.818114Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-design-and-technology-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-sustainability-and-climate-change ,
    oakcurric:thread-systems ,
    oakcurric:thread-materials ,
    oakcurric:thread-manufacture .

oakcurric:unit-3604
  a curric:Unit ;
  rdfs:label "The circular economy: developing countries"@en ;
  curric:slug "case-study-supporting-developing-countries" ;
  rdfs:comment """This unit develops pupils' knowledge of technology in the world around us. The
  pupils consider a case study 'The Washing Machine Project' to empathise with issues faced
  by people in developing countries. Pupils develop knowledge of moral and social issues
  alongside empathy."""@en ;
  curric:whyThisWhyNow """Knowledge of moral and social issues is essential for responsible design.
  Pupils are increasingly independently drawing on, integrating and developing concepts learnt
  previously in units such as Year 9 'Circular economy', and Year 10 'Systems approach to
  design: Sustainable Futures'. Knowledge in this unit will lead on to later 'Iterative design'
  units and 'Designing and making principles'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3604-1 ,
    oakcurric:priorknowledge-3604-2 ,
    oakcurric:priorknowledge-3604-3 ,
    oakcurric:priorknowledge-3604-4 ,
    oakcurric:priorknowledge-3604-5 ;
  curric:id "3604"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.837350Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-design-and-technology-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-sustainability-and-climate-change ,
    oakcurric:thread-user-centred-design ,
    oakcurric:thread-critique-and-evaluate .

oakcurric:unit-3607
  a curric:Unit ;
  rdfs:label "Designing and Making Principles"@en ;
  curric:slug "designing-and-making-principles" ;
  rdfs:comment """In this unit pupils will develop designing and making principles knowledge with an
  explicit focus on exam technique."""@en ;
  curric:whyThisWhyNow """This unit draws together the designing and making principles knowledge
  learnt in prior units, including designing and making constraints alongside the use of
  feedback and research to inform design decisions. The pupils are taught how to apply this
  knowledge efficiently in the terminal exam.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3607-1 ,
    oakcurric:priorknowledge-3607-2 ,
    oakcurric:priorknowledge-3607-3 ,
