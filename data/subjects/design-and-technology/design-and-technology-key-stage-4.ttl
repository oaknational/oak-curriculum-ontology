oakcurric:keylearningpoint-lesson-27191-4
  a curric:KeyLearningPoint ;
  rdfs:label "WEEE is about safely disposing of batteries."@en ;
  dcterms:modified "2026-06-07T15:30:29.251495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27225-1
  a curric:KeyLearningPoint ;
  rdfs:label "Contexts can be investigated using keywords, mind maps or user journeys."@en ;
  dcterms:modified "2026-06-07T15:30:29.251572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27225-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context keywords can be further explored to give a personal perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.251577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27225-3
  a curric:KeyLearningPoint ;
  rdfs:label """Context investigations can identify a range of design opportunities or problems to
