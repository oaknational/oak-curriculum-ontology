  dcterms:modified "2026-06-07T15:30:29.254927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27164-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designers need to gather other people's opinions rather than just their own."@en ;
  dcterms:modified "2026-06-07T15:30:29.254932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27164-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gathering feedback from the user and the target market is essential to ensure the
