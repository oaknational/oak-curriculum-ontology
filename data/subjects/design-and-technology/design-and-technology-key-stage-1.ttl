# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-windmills-create-wind-rather-moved
  a curric:Misconception ;
  curric:statement "Windmills create wind, rather than being moved by it."@en ;
  curric:correction "The wind pushes the windmill's blades to make them turn."@en ;
  dcterms:modified "2026-06-07T15:30:15.150116Z"^^xsd:dateTime .

oakcurric:misconception-envelopes-exactly-same-size-card
  a curric:Misconception ;
  curric:statement """Envelopes have to be exactly the same size as the card that will go
  inside it."""@en ;
  curric:correction "A folded envelope needs to be slightly larger than the card."@en ;
  dcterms:modified "2026-06-07T15:30:15.150142Z"^^xsd:dateTime .

oakcurric:misconception-testing-needs-completed-end-making
  a curric:Misconception ;
  curric:statement "Testing needs to be completed at the end of the making task."@en ;
  curric:correction """Through testing throughout the making process, any issues and changes can be
  addressed. This will make the product more successful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150165Z"^^xsd:dateTime .

oakcurric:misconception-designs-need-decided-upon-followed
  a curric:Misconception ;
  curric:statement "Designs need to be decided upon and followed."@en ;
  curric:correction """Final designs can be adapted and changed, even during the making process.
  This is because it is always good to be reflective throughout the making process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150197Z"^^xsd:dateTime .

oakcurric:misconception-testing-happens-end-making-process
  a curric:Misconception ;
  curric:statement "Testing only happens at the end of the making process."@en ;
  curric:correction """Testing should happen throughout the making process. This allows the
  designers and engineers to change / alter and improve any aspects as they move through the
  making process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150203Z"^^xsd:dateTime .

oakcurric:misconception-detail-puppet-needs-added-template
  a curric:Misconception ;
  curric:statement "All of the detail of the puppet needs to be added to the template."@en ;
  curric:correction """The template is the basic outline of the puppet. The extra detail, such as
  ears, can be added later."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150208Z"^^xsd:dateTime .

oakcurric:misconception-vehicle-chassis
  a curric:Misconception ;
  curric:statement "A vehicle only has a chassis."@en ;
  curric:correction "A vehicle has a chassis and a body."@en ;
  dcterms:modified "2026-06-07T15:30:15.150214Z"^^xsd:dateTime .

oakcurric:misconception-glue-way-join-card-sections
  a curric:Misconception ;
  curric:statement "Glue is the only way to join card sections."@en ;
  curric:correction """Pupils might think that glue is the only joining technique. This lesson will
  explore other methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150242Z"^^xsd:dateTime .

oakcurric:misconception-cars-wheels-axles
  a curric:Misconception ;
  curric:statement "Only cars have wheels and axles."@en ;
  curric:correction """Highlight that many vehicles, including bicycles and toy cars, use wheels and
  axles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150297Z"^^xsd:dateTime .

oakcurric:misconception-design-ideas-cannot-changed
  a curric:Misconception ;
  curric:statement "Design ideas cannot be changed."@en ;
  curric:correction """Design ideas can be changed during the final design and the making tasks.
  Designs might be changed because something does not work, there are other ideas which will
  work better or testing shows problems with part of a design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150320Z"^^xsd:dateTime .

oakcurric:misconception-bridges-look-same
  a curric:Misconception ;
  curric:statement "All bridges look the same."@en ;
  curric:correction """All bridges are different. They use different materials, look unique (look
  different) and made by different designers and engineers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150326Z"^^xsd:dateTime .

oakcurric:misconception-decorations-used-make-look-pretty
  a curric:Misconception ;
  curric:statement "Decorations used are to make it look pretty."@en ;
  curric:correction """As well as appearance, we need to consider usability and safety when choosing
  finishing touches."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150332Z"^^xsd:dateTime .

oakcurric:misconception-play-areas-follow-similar-design
  a curric:Misconception ;
  curric:statement "All play areas follow a similar design."@en ;
  curric:correction """There are a wide variety of play area designs for different users that use
  different materials and shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150349Z"^^xsd:dateTime .

oakcurric:misconception-card-paper-same
  a curric:Misconception ;
  curric:statement "Card and paper are the same."@en ;
  curric:correction """Card is thicker and more durable than paper. Explain the differences in
  characteristics and uses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150378Z"^^xsd:dateTime .

oakcurric:misconception-buttresses-bracing-anchors-wider-bases
  a curric:Misconception ;
  curric:statement """Buttresses, bracing, anchors, wider bases and reinforced sides need to be on
  every single mock-up model for it to be freestanding."""@en ;
  curric:correction """Not all structures need a buttress, bracing, anchors, wider bases or
  reinforcing, it depends on the materials that are being used, the size, height and what
  the object is going to do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150491Z"^^xsd:dateTime .

oakcurric:misconception-fabrics-same
  a curric:Misconception ;
  curric:statement "All fabrics are the same."@en ;
  curric:correction """There are lots of differnet types of fabrics, some are man-made and others
  are natural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150532Z"^^xsd:dateTime .

oakcurric:misconception-children-use-cotton-sew
  a curric:Misconception ;
  curric:statement "Children should use cotton to sew."@en ;
  curric:correction """Using embroidery thread means that it is easier for smaller hands to use and
  it is also more resilient. It can be used with larger eyed needles too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150593Z"^^xsd:dateTime .

oakcurric:misconception-paper-card-comes-trees
  a curric:Misconception ;
  curric:statement "All paper and card comes from trees."@en ;
  curric:correction "Some paper and card can be from recyclable materials"@en ;
  dcterms:modified "2026-06-07T15:30:15.150651Z"^^xsd:dateTime .

oakcurric:misconception-help-split-pin-turn-create
  a curric:Misconception ;
  curric:statement "To help the split pin to turn, create a bigger hole."@en ;
  curric:correction """If the hole is too big, this will allow the split pin to wobble and cause the
  mechanism to not work accurately. Use a standard pencil and turn the split pin when it is
  in place and this will help it the lever to move smoothly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150665Z"^^xsd:dateTime .

oakcurric:misconception-vehicles-made-same-materials
  a curric:Misconception ;
  curric:statement "All vehicles are made from the same materials."@en ;
  curric:correction """Discuss the diversity of materials used in vehicle construction and why
  different vehicles require different materials."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150714Z"^^xsd:dateTime .

oakcurric:misconception-feedback-testing-completed-once-object
  a curric:Misconception ;
  curric:statement """Feedback and testing can only be completed once the object is made and
  finished."""@en ;
  curric:correction """Testing and feedback can be a continuous process through the making and
  designing process. Pupils may reflect on the positives and negatives of any changes made
  in their final evaluation and feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150719Z"^^xsd:dateTime .

oakcurric:misconception-windmill-tested-inside
  a curric:Misconception ;
  curric:statement "Windmill have to be tested inside"@en ;
  curric:correction """The windmill can be tested inside or outside depending upon the conditions
  and supervision."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150812Z"^^xsd:dateTime .

oakcurric:misconception-feedback-got-positive
  a curric:Misconception ;
  curric:statement "Feedback has got to be positive."@en ;
  curric:correction """Feedback can be positive or negative and aims to help the designer to improve
  on their design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150821Z"^^xsd:dateTime .

oakcurric:misconception-completed-vehicles-finished-therefore-need
  a curric:Misconception ;
  curric:statement """Completed vehicles are finished and therefore will not need any changes or
  alterations neeeded to them."""@en ;
  curric:correction """Testing and feedback is a good way to spot any problems with the vehicles and
  therefore time to correct, adapt and alter specific parts of the finished product and
  demonstrates that products always need reviewing and adapting to make them work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151653Z"^^xsd:dateTime .

oakcurric:misconception-whole-puppet-needs-stitched
  a curric:Misconception ;
  curric:statement "The whole puppet needs to be stitched."@en ;
  curric:correction """There are other joining technqiues that can be used to join the felt
  together. The running stitch is one which is advised for this unit, however, staples or
  fabric glue / PVA can be used as an alternative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151659Z"^^xsd:dateTime .

oakcurric:misconception-structures-same
  a curric:Misconception ;
  curric:statement "Structures are all the same."@en ;
  curric:correction """There are different types of structures - frame, shell and brick bonding
  structures. They are all used for different effects, purposes and reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151764Z"^^xsd:dateTime .

oakcurric:misconception-windmills-need-wide-base-stand
  a curric:Misconception ;
  curric:statement "Windmills just need a wide base to stand by themselves."@en ;
  curric:correction """When the wind catches them, they move or fall - windmills need ballast to
  secure them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151775Z"^^xsd:dateTime .

oakcurric:misconception-puppets-made-same-way-using
  a curric:Misconception ;
  curric:statement "All puppets are made the same way using the same materials."@en ;
  curric:correction """Puppets can have different purposes/uses. Some use lollipop sticks, others
  have strings move each part. Puppets are used for storytimes, playtimes, concerts and on
  TV. Some talk with help from their puppeteers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151959Z"^^xsd:dateTime .

oakcurric:misconception-models-need-work-first-time
  a curric:Misconception ;
  curric:statement "Models need to work first time."@en ;
  curric:correction """Through testing and repeat testing, models can be tried and adapted
  to work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152025Z"^^xsd:dateTime .

oakcurric:misconception-designers-plan-follow-their-planning
  a curric:Misconception ;
  curric:statement "Designers plan and follow their planning in the making stage."@en ;
  curric:correction """Designers use their design brief to create a plan. This plan is important but
  changable depending on success of the project, alongside tools, skills and testing points
  along the way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152100Z"^^xsd:dateTime .

oakcurric:misconception-one-strategy-making-moving-windmill
  a curric:Misconception ;
  curric:statement "There is only one strategy to making a moving windmill."@en ;
  curric:correction """There are multiple ways to make the windmill turn. It can be made using
  different materials - such as wood, card, straws, split pins and pins"""@en ;
  dcterms:modified "2026-06-07T15:30:15.152106Z"^^xsd:dateTime .

oakcurric:misconception-rotary-motion-produces-electricity
  a curric:Misconception ;
  curric:statement "Rotary motion always produces electricity."@en ;
  curric:correction """Rotary motion can be designed to lift objects, grind objects or produce
  electricity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152112Z"^^xsd:dateTime .

oakcurric:misconception-structures-anchored-freestanding
  a curric:Misconception ;
  curric:statement "Structures that are anchored down are not freestanding."@en ;
  curric:correction """Structures which are anchored down can be freestanding, such as play
  equipment. A structure which is joined to another structure, such as a radiator joined to
  a wall, is not freestanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152185Z"^^xsd:dateTime .

oakcurric:misconception-common-mistake-understanding-different-joining
  a curric:Misconception ;
  curric:statement """A common mistake is not understanding that different joining methods need to
  be used for different materials and reasons."""@en ;
  curric:correction """Some joining techniques such as PVA can be more messy and cause colours in
  materials to run, for example. Through adding PVA to the object being attached, this
  usually causes a neater, better presented outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152235Z"^^xsd:dateTime .

oakcurric:misconception-lever-seesaw-mechanism-moves
  a curric:Misconception ;
  curric:statement "A lever is just a seesaw mechanism and only moves up and down."@en ;
  curric:correction """Levers move up and down and the end of the lever moves in a curved direction.
  Levers can be turned for different effects."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152291Z"^^xsd:dateTime .

oakcurric:misconception-disassembly-same-evaluation
  a curric:Misconception ;
  curric:statement "A disassembly is the same as an evaluation."@en ;
  curric:correction """A disassembly focuses on the different parts and workings of the product. The
  evaluation focuses on views of what people like and dislike."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152348Z"^^xsd:dateTime .

oakcurric:misconception-bridges-found-water
  a curric:Misconception ;
  curric:statement "Bridges are only found over water."@en ;
  curric:correction """There are different types of bridges, some carry people (footbridge), others
  allow vehicles to cross over water, roads or railways, some bridges carry trains and
  others carry boats (aqueduct)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152422Z"^^xsd:dateTime .

oakcurric:misconception-axle-needs-fixed
  a curric:Misconception ;
  curric:statement "An axle needs to be fixed."@en ;
  curric:correction """An axle needs to be free moving, able to turn. The sails turn on the
  axle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152514Z"^^xsd:dateTime .

oakcurric:misconception-axle-holders-placed-angle
  a curric:Misconception ;
  curric:statement "Axle holders can be placed at any angle."@en ;
  curric:correction "Clarify that axles need to be parallel to ensure proper wheel function."@en ;
  dcterms:modified "2026-06-07T15:30:15.152520Z"^^xsd:dateTime .

oakcurric:misconception-wind-sails-made-wood
  a curric:Misconception ;
  curric:statement "Wind sails are always made of wood."@en ;
  curric:correction """Wind sail structures may be made of wood, but will have fabric to catch the
  wind."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152837Z"^^xsd:dateTime .

oakcurric:misconception-designers-make-plan-follow-plan
  a curric:Misconception ;
  curric:statement "Designers make a plan and follow this plan in the making stage."@en ;
  curric:correction """Designers use their design brief to create a plan. This plan is important but
  changable depending on success of the project, alongside tools, skills and testing points
  along the way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153107Z"^^xsd:dateTime .

oakcurric:misconception-pupils-need-follow-their-design
  a curric:Misconception ;
  curric:statement "Pupils need to follow their design idea and chosen materials."@en ;
  curric:correction """Please remind pupils that they can change their ideas and use alternative
  finishing techniques and joining techniques in their work. Designers are continuously
  reviewing and editing their designs to make sure that they meet the users' needs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153136Z"^^xsd:dateTime .

oakcurric:misconception-slider-mechanisms-pivot-points
  a curric:Misconception ;
  curric:statement "Slider mechanisms have a pivot points."@en ;
  curric:correction """Slider mechanisms do not have pivot points and therefore do not use split
  pins. Slider mechanisms use a guide and a slot. They move in a straight line, rather than
  turning or pivoting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153212Z"^^xsd:dateTime .

oakcurric:misconception-gluing-put-glue-object-glued
  a curric:Misconception ;
  curric:statement "When gluing, always put the glue on the object that is being glued down."@en ;
  curric:correction """By adding the glue to the backing instead of the object being glued down, it
  will prevent mess and reduce excess glue from being used. Additionally, use the a small
  amount of glue first as you can always add more glue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153493Z"^^xsd:dateTime .

oakcurric:misconception-strongest-materials-make-best-bridges
  a curric:Misconception ;
  curric:statement "The strongest materials make the best bridges."@en ;
  curric:correction """Rather than using the strongest materials, sometimes it's better use
  materials the bend a little. This is important in case it is windy or the ground shakes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153750Z"^^xsd:dateTime .

oakcurric:misconception-axle-hold-two-wheels
  a curric:Misconception ;
  curric:statement "An axle must hold two wheels."@en ;
  curric:correction "The axle might hold one or two wheels. The axle can turn with the wheel."@en ;
  dcterms:modified "2026-06-07T15:30:15.163189Z"^^xsd:dateTime .
