# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-disassembly
  a curric:Keyword ;
  schema:name "disassembly"@en ;
  schema:description "taking something apart to see how it works"@en ;
  dcterms:modified "2026-06-07T15:30:02.347952Z"^^xsd:dateTime .

oakcurric:keyword-testing
  a curric:Keyword ;
  schema:name "testing"@en ;
  schema:description "trying something out to see if it works well"@en ;
  dcterms:modified "2026-06-07T15:30:02.348277Z"^^xsd:dateTime .

oakcurric:keyword-user
  a curric:Keyword ;
  schema:name "user"@en ;
  schema:description "who you are designing for"@en ;
  dcterms:modified "2026-06-07T15:30:02.348282Z"^^xsd:dateTime .

oakcurric:keyword-join
  a curric:Keyword ;
  schema:name "join"@en ;
  schema:description "how the letters are connected together"@en ;
  dcterms:modified "2026-06-07T15:30:02.348441Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-natural
  a curric:Keyword ;
  schema:name "natural"@en ;
  schema:description """the natural symbol is used to show a note in the bar has returned to the
  normal pitch"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348642Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:02.350302Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-features
  a curric:Keyword ;
  schema:name "features"@en ;
  schema:description "the parts or characteristics that make something unique"@en ;
  dcterms:modified "2026-06-07T15:30:02.351067Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
  environment or reducing resources for future generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352314Z"^^xsd:dateTime .

oakcurric:keyword-technique
  a curric:Keyword ;
  schema:name "technique"@en ;
  schema:description "the method we use to perform a task"@en ;
  dcterms:modified "2026-06-07T15:30:02.352540Z"^^xsd:dateTime .

oakcurric:keyword-feedback
  a curric:Keyword ;
  schema:name "feedback"@en ;
  schema:description """information and guidance provided to the athlete to help them improve their
  technique"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352657Z"^^xsd:dateTime .

oakcurric:keyword-sketching
  a curric:Keyword ;
  schema:name "sketching"@en ;
  schema:description "quick, freehand drawing of ideas or concepts, often as a rough outline"@en ;
  dcterms:modified "2026-06-07T15:30:02.354474Z"^^xsd:dateTime .

oakcurric:keyword-construct
  a curric:Keyword ;
  schema:name "construct"@en ;
  schema:description "to create or build an image or understanding of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.354608Z"^^xsd:dateTime .

oakcurric:keyword-model
  a curric:Keyword ;
  schema:name "model"@en ;
  schema:description """Scientists use models as simpler representations of complex things and
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:02.354826Z"^^xsd:dateTime .

oakcurric:keyword-unique
  a curric:Keyword ;
  schema:name "unique"@en ;
  schema:description "being one of a kind or unlike anything else"@en ;
  dcterms:modified "2026-06-07T15:30:02.354890Z"^^xsd:dateTime .

oakcurric:keyword-detail
  a curric:Keyword ;
  schema:name "Detail"@en ;
  schema:description "A small part of something that adds to its overall appearance."@en ;
  dcterms:modified "2026-06-07T15:30:02.355330Z"^^xsd:dateTime .

oakcurric:keyword-performance
  a curric:Keyword ;
  schema:name "performance"@en ;
  schema:description """the act of executing the skill to the best of your ability, especially when
  it counts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355489Z"^^xsd:dateTime .

oakcurric:keyword-ideas
  a curric:Keyword ;
  schema:name "ideas"@en ;
  schema:description "thoughts or plans about how to do or create something"@en ;
  dcterms:modified "2026-06-07T15:30:02.356066Z"^^xsd:dateTime .

oakcurric:keyword-lever
  a curric:Keyword ;
  schema:name "lever"@en ;
  schema:description """a lever arm (bone) that rotates or pivots around a fixed point (fulcrum)
  when a force (effort) is applied to move a resistance (load)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356453Z"^^xsd:dateTime .

oakcurric:keyword-material
  a curric:Keyword ;
  schema:name "material"@en ;
  schema:description """A material is what an object is made from. An object can be made from more
  than one material."""@en ;
  dcterms:modified "2026-06-07T15:30:02.358135Z"^^xsd:dateTime .

oakcurric:keyword-sketch
  a curric:Keyword ;
  schema:name "sketch"@en ;
  schema:description "making quick and simple drawings to show ideas or the things we see"@en ;
  dcterms:modified "2026-06-07T15:30:02.358165Z"^^xsd:dateTime .

oakcurric:keyword-appearance
  a curric:Keyword ;
  schema:name "appearance"@en ;
  schema:description "what someone or something looks like"@en ;
  dcterms:modified "2026-06-07T15:30:02.360396Z"^^xsd:dateTime .

oakcurric:keyword-materials
  a curric:Keyword ;
  schema:name "materials"@en ;
  schema:description "the physical substances or tools an artist uses to create their work"@en ;
  dcterms:modified "2026-06-07T15:30:02.360914Z"^^xsd:dateTime .

oakcurric:keyword-foreground
  a curric:Keyword ;
  schema:name "foreground"@en ;
  schema:description "the part of the scene closest to the viewer"@en ;
  dcterms:modified "2026-06-07T15:30:02.360965Z"^^xsd:dateTime .

oakcurric:keyword-background
  a curric:Keyword ;
  schema:name "background"@en ;
  schema:description "the part of the scene that appears furthest away"@en ;
  dcterms:modified "2026-06-07T15:30:02.360972Z"^^xsd:dateTime .

oakcurric:keyword-produce
  a curric:Keyword ;
  schema:name "produce"@en ;
  schema:description """produce is something that people have made, created or grown; it also means
