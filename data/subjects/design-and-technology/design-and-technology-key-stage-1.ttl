# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-27650-1
  a curric:KeyLearningPoint ;
  rdfs:label "Windmills have sails or blades which turn."@en ;
  dcterms:modified "2026-06-07T15:30:29.424783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27650-2
  a curric:KeyLearningPoint ;
  rdfs:label "Windmills use wind to produce electricity or pump water."@en ;
  dcterms:modified "2026-06-07T15:30:29.424787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Windmills use wind to grind wheat into flour."@en ;
  dcterms:modified "2026-06-07T15:30:29.424793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27672-1
  a curric:KeyLearningPoint ;
  rdfs:label "Disassembling an envelope helps us understand how it is constructed."@en ;
  dcterms:modified "2026-06-07T15:30:29.424853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27672-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different paper folding techniques are used to construct envelopes."@en ;
  dcterms:modified "2026-06-07T15:30:29.424857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27672-3
  a curric:KeyLearningPoint ;
  rdfs:label "Envelopes need to be larger than the moving card that goes inside."@en ;
  dcterms:modified "2026-06-07T15:30:29.424861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27672-4
  a curric:KeyLearningPoint ;
  rdfs:label "Envelopes are joined together carefully so the moving card can be removed."@en ;
  dcterms:modified "2026-06-07T15:30:29.424866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27646-1
  a curric:KeyLearningPoint ;
  rdfs:label "Experimenting with mock-ups helps develop designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.424930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27646-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to use the correct glue and/or tape when making."@en ;
  dcterms:modified "2026-06-07T15:30:29.424934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27646-3
  a curric:KeyLearningPoint ;
  rdfs:label "Testing throughout the making process is very important"@en ;
  dcterms:modified "2026-06-07T15:30:29.424938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27646-4
  a curric:KeyLearningPoint ;
  rdfs:label "A minimal amount of glue is needed when joining materials together."@en ;
  dcterms:modified "2026-06-07T15:30:29.424942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27646-5
  a curric:KeyLearningPoint ;
  rdfs:label """Masking tape can be used to join most materials, can be painted over, but can also
  rip easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ideas come from inspiration often by looking at the work of other designers."@en ;
  dcterms:modified "2026-06-07T15:30:29.425004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27645-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ideas come from talking with others."@en ;
  dcterms:modified "2026-06-07T15:30:29.425009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27645-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ideas come from drawing."@en ;
  dcterms:modified "2026-06-07T15:30:29.425013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27648-1
  a curric:KeyLearningPoint ;
  rdfs:label "Testing is an important way to check that the bridge works."@en ;
  dcterms:modified "2026-06-07T15:30:29.425017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27648-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tests can include recording how well the design worked."@en ;
  dcterms:modified "2026-06-07T15:30:29.425021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Talking about the test results helps decide how well the design worked."@en ;
  dcterms:modified "2026-06-07T15:30:29.425025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27648-4
  a curric:KeyLearningPoint ;
  rdfs:label "Feedback helps to make improvements and changes to future ideas and designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.425029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27661-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fabric template is a shape drawn to help in cutting out."@en ;
  dcterms:modified "2026-06-07T15:30:29.425033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27661-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fabric templates help cut fabric accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.425037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27661-3
  a curric:KeyLearningPoint ;
  rdfs:label "Templates are planned on paper."@en ;
  dcterms:modified "2026-06-07T15:30:29.425041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27661-4
  a curric:KeyLearningPoint ;
  rdfs:label "Templates are cut out carefully using scissors and then attached to the felt."@en ;
  dcterms:modified "2026-06-07T15:30:29.425046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27679-1
  a curric:KeyLearningPoint ;
  rdfs:label "The body of the vehicle needs to be attached to the chassis."@en ;
  dcterms:modified "2026-06-07T15:30:29.425052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27679-2
  a curric:KeyLearningPoint ;
  rdfs:label "Card and cardboard can be used to make a realistic vehicle body and reinforced."@en ;
  dcterms:modified "2026-06-07T15:30:29.425056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27679-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wheels and axles are attached to a chassis to make a vehicle move."@en ;
  dcterms:modified "2026-06-07T15:30:29.425060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27679-4
  a curric:KeyLearningPoint ;
  rdfs:label "The body of a vehicle can be modelled in different shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.425064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27679-5
  a curric:KeyLearningPoint ;
  rdfs:label "A range of materials can be used to finish a vehicle."@en ;
  dcterms:modified "2026-06-07T15:30:29.425068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27676-1
  a curric:KeyLearningPoint ;
  rdfs:label "Marking out needs to be done with care."@en ;
  dcterms:modified "2026-06-07T15:30:29.425110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27676-2
  a curric:KeyLearningPoint ;
  rdfs:label "The correct equipment needs to be used to mark out card."@en ;
  dcterms:modified "2026-06-07T15:30:29.425114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27676-3
  a curric:KeyLearningPoint ;
  rdfs:label "Card can be joined using a range of different techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.425118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27673-1
  a curric:KeyLearningPoint ;
  rdfs:label "An axle is a rod on which wheels can rotate."@en ;
  dcterms:modified "2026-06-07T15:30:29.425278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27673-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lots of vehicles use wheels and axles."@en ;
  dcterms:modified "2026-06-07T15:30:29.425282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27673-3
  a curric:KeyLearningPoint ;
  rdfs:label "Toy cars have some of the key parts of cars to make them move."@en ;
  dcterms:modified "2026-06-07T15:30:29.425289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27660-1
  a curric:KeyLearningPoint ;
  rdfs:label "The design brief requires us to make a puppet to use in a puppet show."@en ;
  dcterms:modified "2026-06-07T15:30:29.425333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27660-2
  a curric:KeyLearningPoint ;
  rdfs:label "A range of ideas can be drawn before deciding which one to choose to make."@en ;
  dcterms:modified "2026-06-07T15:30:29.425337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching using pencils on paper is a way to presents our ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.425343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Talking about ideas helps designers choose the final design."@en ;
  dcterms:modified "2026-06-07T15:30:29.425347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27647-1
  a curric:KeyLearningPoint ;
  rdfs:label "Finishing products by decorating them makes them more attractive."@en ;
  dcterms:modified "2026-06-07T15:30:29.425352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27647-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paint and other materials can be used to decorate bridges."@en ;
  dcterms:modified "2026-06-07T15:30:29.425356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27647-3
  a curric:KeyLearningPoint ;
  rdfs:label "Paint can be used on wood and cardboard but not on plastic."@en ;
  dcterms:modified "2026-06-07T15:30:29.425360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27687-1
  a curric:KeyLearningPoint ;
  rdfs:label "A mock-up is a model that is useful for trying out ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.425366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27687-2
  a curric:KeyLearningPoint ;
  rdfs:label "A mock-up shows key design features."@en ;
  dcterms:modified "2026-06-07T15:30:29.425370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27687-3
  a curric:KeyLearningPoint ;
  rdfs:label "A mock-up uses card techniques, which create different effects and appearances."@en ;
  dcterms:modified "2026-06-07T15:30:29.425374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27687-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different materials, with different textures and appearances, can be used for
  different effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27687-5
  a curric:KeyLearningPoint ;
  rdfs:label """Finishing touches help the user to use the play equipment, but also help the user to
  find the play equipment appealing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27681-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes in playground designs are chosen purposefully."@en ;
  dcterms:modified "2026-06-07T15:30:29.425400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27681-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials used in playground designs are chosen purposefully."@en ;
  dcterms:modified "2026-06-07T15:30:29.425405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27681-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching helps us to spot details and features."@en ;
  dcterms:modified "2026-06-07T15:30:29.425409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27675-1
  a curric:KeyLearningPoint ;
  rdfs:label "Card comes from trees and can be sustainable if carefully sourced."@en ;
  dcterms:modified "2026-06-07T15:30:29.425502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27675-2
  a curric:KeyLearningPoint ;
  rdfs:label "Card can be used for many products because of its characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.425506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27675-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of cardboard are used for different reasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.425510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27683-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes, such as springs, can be created by folding card."@en ;
  dcterms:modified "2026-06-07T15:30:29.425883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different joining techniques can be used to join paper and card in different ways to
  create different effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27683-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring and marking out shapes, helps to create mock-up models and different
  effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27683-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different shapes and structures can be made using pipe cleaners."@en ;
  dcterms:modified "2026-06-07T15:30:29.425895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27658-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different types of fabric, including felt."@en ;
  dcterms:modified "2026-06-07T15:30:29.426010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27658-2
  a curric:KeyLearningPoint ;
  rdfs:label """Felt is a fabric usually made of wool and other fibres formed by heat, moisture,
  chemicals, and/or pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27658-3
  a curric:KeyLearningPoint ;
  rdfs:label "Felt is strong and easily shaped."@en ;
  dcterms:modified "2026-06-07T15:30:29.426018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27658-4
  a curric:KeyLearningPoint ;
  rdfs:label "Felt can be joined using glue, staples or stitching."@en ;
  dcterms:modified "2026-06-07T15:30:29.426022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27659-1
  a curric:KeyLearningPoint ;
  rdfs:label "A running stitch is a good way to join fabric together."@en ;
  dcterms:modified "2026-06-07T15:30:29.426178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Weave fabric is a good material to practice a running stitch."@en ;
  dcterms:modified "2026-06-07T15:30:29.426183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27659-3
  a curric:KeyLearningPoint ;
  rdfs:label "When starting to sew, a needle has to be threaded."@en ;
  dcterms:modified "2026-06-07T15:30:29.426187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27667-1
  a curric:KeyLearningPoint ;
  rdfs:label "Card is made of different layers of paper and comes from trees."@en ;
  dcterms:modified "2026-06-07T15:30:29.426366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Card is used to make greetings cards because it is strong, sturdy, not too expensive
  and easy to decorate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Final designs consider users, materials and equipment to organise product
  design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27668-1
  a curric:KeyLearningPoint ;
  rdfs:label "Greetings cards can be folded landscape or portrait."@en ;
  dcterms:modified "2026-06-07T15:30:29.426403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27668-2
  a curric:KeyLearningPoint ;
