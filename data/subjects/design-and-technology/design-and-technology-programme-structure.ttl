# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

natcurric:subjectgroup-design-and-technology
  a curric:SubjectGroup ;
  rdfs:label "Design and technology"@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:coversDiscipline natcurric:discipline-design-and-technology .

# ----------------------------------------------------------------------
# Subjects
# ----------------------------------------------------------------------

natcurric:subject-design-and-technology
  a curric:Subject ;
  rdfs:label "Design and technology"@en ;
  curric:rationale """Design and technology is an inspiring, rigorous and practical subject. 
  Using creativity and imagination, pupils design and make products that solve real and relevant 
  problems within a variety of contexts, considering their own and others’ needs, wants and values. 
  They acquire a broad range of subject knowledge and draw on disciplines such as mathematics, 
  science, engineering, computing and art. Pupils learn how to take risks, becoming resourceful, 
  innovative, enterprising and capable citizens. Through the evaluation of past and present design 
  and technology, they develop a critical understanding of its impact on daily life and the wider 
  world. High-quality design and technology education makes an essential contribution to the 
  creativity, culture, wealth and well-being of the nation."""@en ;
  curric:hasAim
    natcurric:aim-design-and-technology-creative-technical-practical-expertise ,
    natcurric:aim-design-and-technology-design-make-prototypes-and-products ,
    natcurric:aim-design-and-technology-critique-evaluate-test-ideas-products ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSubjectOf natcurric:subjectgroup-design-and-technology ;
  curric:coversStrand
    natcurric:strand-design ,
    natcurric:strand-make ,
    natcurric:strand-evaluate ,
    natcurric:strand-technical-knowledge .

natcurric:subject-food-and-nutrition
  a curric:Subject ;
  rdfs:label "Food and nutrition"@en ;
  curric:rationale "No subject rationale."@en ;
  curric:hasAim
    natcurric:aim-food-and-nutrition-principles-nutrition-how-to-cook ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSubjectOf natcurric:subjectgroup-design-and-technology ;
  curric:coversStrand natcurric:strand-food-and-nutrition .

# ----------------------------------------------------------------------
# Aims
# ----------------------------------------------------------------------

natcurric:aim-design-and-technology-creative-technical-practical-expertise
  a curric:Aim ;
  rdfs:label """Develop the creative, technical and practical expertise needed to perform everyday 
  tasks confidently and to participate successfully in an increasingly technological world."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime .

natcurric:aim-design-and-technology-design-make-prototypes-and-products
  a curric:Aim ;
  rdfs:label """Build and apply a repertoire of knowledge, understanding and skills in order to 
  design and make high-quality prototypes and products for a wide range of users."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime .

natcurric:aim-design-and-technology-critique-evaluate-test-ideas-products
  a curric:Aim ;
  rdfs:label "Critique, evaluate and test their ideas and products and the work of others."@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime .

natcurric:aim-food-and-nutrition-principles-nutrition-how-to-cook
  a curric:Aim ;
  rdfs:label "Understand and apply the principles of nutrition and learn how to cook."@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Schemes
# ----------------------------------------------------------------------

natcurric:scheme-design-and-technology-key-stage-1
  a curric:Scheme ;
  rdfs:label "Design and technology Key Stage 1"@en ;
  dcterms:description """Through a variety of creative and practical activities, pupils should be 
  taught the knowledge, understanding and skills needed to engage in an iterative process of 
  designing and making. They should work in a range of relevant contexts [for example, the home and 
  school, gardens and playgrounds, the local community, industry and the wider environment]."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-design-and-technology ;
  curric:coversKeyStage natcurric:key-stage-1 .

natcurric:scheme-design-and-technology-key-stage-2
  a curric:Scheme ;
  rdfs:label "Design and technology Key Stage 2"@en ;
  dcterms:description """Through a variety of creative and practical activities, pupils should be 
  taught the knowledge, understanding and skills needed to engage in an iterative process of 
  designing and making. They should work in a range of relevant contexts [for example, the home, 
  school, leisure, culture, enterprise, industry and the wider environment]."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-design-and-technology ;
  curric:coversKeyStage natcurric:key-stage-2 .

natcurric:scheme-design-and-technology-key-stage-3
  a curric:Scheme ;
  rdfs:label "Design and technology Key Stage 3"@en ;
  dcterms:description """Through a variety of creative and practical activities, pupils should be 
  taught the knowledge, understanding and skills needed to engage in an iterative process of 
  designing and making. They should work in a range of domestic and local contexts [for example, 
  the home, health, leisure and culture], and industrial contexts [for example, engineering, 
  manufacturing, construction, food, energy, agriculture (including horticulture) and 
  fashion]."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-design-and-technology ;
  curric:coversKeyStage natcurric:key-stage-3 .

natcurric:scheme-food-and-nutrition-key-stage-1
  a curric:Scheme ;
  rdfs:label "Food and nutrition Key Stage 1"@en ;
  dcterms:description """As part of their work with food, pupils should be taught how to cook and 
  apply the principles of nutrition and healthy eating. Instilling a love of cooking in pupils will 
  also open a door to one of the great expressions of human creativity. Learning how to cook is a 
  crucial life skill that enables pupils to feed themselves and others affordably and well, now and 
  in later life."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-food-and-nutrition ;
  curric:coversKeyStage natcurric:key-stage-1 .

natcurric:scheme-food-and-nutrition-key-stage-2
  a curric:Scheme ;
  rdfs:label "Food and nutrition Key Stage 2"@en ;
  dcterms:description """As part of their work with food, pupils should be taught how to cook and 
  apply the principles of nutrition and healthy eating. Instilling a love of cooking in pupils will 
  also open a door to one of the great expressions of human creativity. Learning how to cook is a 
  crucial life skill that enables pupils to feed themselves and others affordably and well, now and 
  in later life."""@en ;
  dcterms:modified "2026-05-04T16:46:48Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-food-and-nutrition ;
  curric:coversKeyStage natcurric:key-stage-2 .

natcurric:scheme-food-and-nutrition-key-stage-3
  a curric:Scheme ;
  rdfs:label "Food and nutrition Key Stage 3"@en ;
  dcterms:description """As part of their work with food, pupils should be taught how to cook and
  apply the principles of nutrition and healthy eating. Instilling a love of cooking in pupils will
  also open a door to one of the great expressions of human creativity. Learning how to cook is a
  crucial life skill that enables pupils to feed themselves and others affordably and well, now and
