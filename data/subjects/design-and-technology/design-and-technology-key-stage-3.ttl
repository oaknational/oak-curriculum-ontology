oakcurric:keylearningpoint-lesson-27825-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials are measured and marked out before they are cut and shaped."@en ;
  dcterms:modified "2026-06-07T15:30:29.279280Z"^^xsd:dateTime .

