# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-present
  a curric:Keyword ;
  schema:name "present"@en ;
  schema:description "describes habitual events in the present, e.g. ‘I do’"@en ;
  dcterms:modified "2026-06-07T15:30:02.347769Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-modifications
  a curric:Keyword ;
  schema:name "modifications"@en ;
  schema:description "making changes or adjustments to improve or alter a design"@en ;
  dcterms:modified "2026-06-07T15:30:02.347970Z"^^xsd:dateTime .

oakcurric:keyword-manufacture
  a curric:Keyword ;
  schema:name "manufacture"@en ;
  schema:description """the process of making products from raw materials using machines or
  labour"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347975Z"^^xsd:dateTime .

oakcurric:keyword-cam
  a curric:Keyword ;
  schema:name "CAM"@en ;
  schema:description "computer aided manufacture"@en ;
  dcterms:modified "2026-06-07T15:30:02.347990Z"^^xsd:dateTime .

oakcurric:keyword-cad
  a curric:Keyword ;
  schema:name "CAD"@en ;
  schema:description "computer aided design"@en ;
  dcterms:modified "2026-06-07T15:30:02.347998Z"^^xsd:dateTime .

oakcurric:keyword-sustainability
  a curric:Keyword ;
  schema:name "sustainability"@en ;
  schema:description "using resources wisely so future generations can also meet their needs"@en ;
  dcterms:modified "2026-06-07T15:30:02.348175Z"^^xsd:dateTime .

oakcurric:keyword-lca
  a curric:Keyword ;
  schema:name "LCA"@en ;
  schema:description """life cycle assessment; assesses the environmental impact at every stage of a
  product’s lifecycle"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348187Z"^^xsd:dateTime .

oakcurric:keyword-purpose
  a curric:Keyword ;
  schema:name "purpose"@en ;
  schema:description "the aim of the text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348243Z"^^xsd:dateTime .

oakcurric:keyword-testing
  a curric:Keyword ;
  schema:name "testing"@en ;
  schema:description "trying something out to see if it works well"@en ;
  dcterms:modified "2026-06-07T15:30:02.348277Z"^^xsd:dateTime .

oakcurric:keyword-user
  a curric:Keyword ;
  schema:name "user"@en ;
  schema:description "who you are designing for"@en ;
  dcterms:modified "2026-06-07T15:30:02.348282Z"^^xsd:dateTime .

oakcurric:keyword-quality-control
  a curric:Keyword ;
  schema:name "quality control"@en ;
  schema:description """checks made on a product before, during and after its production so it meets
  quality and safety standards"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348525Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-tolerance
  a curric:Keyword ;
  schema:name "tolerance"@en ;
  schema:description "the acceptable range of variation in a product's dimensions"@en ;
  dcterms:modified "2026-06-07T15:30:02.348537Z"^^xsd:dateTime .

oakcurric:keyword-iterate
  a curric:Keyword ;
  schema:name "iterate"@en ;
  schema:description "process of refining and improving a design"@en ;
  dcterms:modified "2026-06-07T15:30:02.348556Z"^^xsd:dateTime .

oakcurric:keyword-perspective
  a curric:Keyword ;
  schema:name "perspective"@en ;
  schema:description "creating depth and distance in a composition"@en ;
  dcterms:modified "2026-06-07T15:30:02.348595Z"^^xsd:dateTime .

oakcurric:keyword-natural
  a curric:Keyword ;
  schema:name "natural"@en ;
  schema:description """the natural symbol is used to show a note in the bar has returned to the
  normal pitch"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348642Z"^^xsd:dateTime .

oakcurric:keyword-safety
  a curric:Keyword ;
  schema:name "safety"@en ;
  schema:description "State of being not likely to be in danger, risk or injury."@en ;
  dcterms:modified "2026-06-07T15:30:02.349289Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description """describes something that's based on a person's opinions, individual
  experiences, and biased influences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349519Z"^^xsd:dateTime .

oakcurric:keyword-justify
  a curric:Keyword ;
  schema:name "justify"@en ;
  schema:description "support a case with evidence"@en ;
  dcterms:modified "2026-06-07T15:30:02.349832Z"^^xsd:dateTime .

oakcurric:keyword-friction
  a curric:Keyword ;
  schema:name "friction"@en ;
  schema:description "Friction is the force of one surface gripping or rubbing on another."@en ;
  dcterms:modified "2026-06-07T15:30:02.350023Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:02.350302Z"^^xsd:dateTime .

oakcurric:keyword-design-opportunity
  a curric:Keyword ;
  schema:name "design opportunity"@en ;
  schema:description "a gap or a need where a new or improved product would be beneficial"@en ;
  dcterms:modified "2026-06-07T15:30:02.350338Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-carbon-emissions
  a curric:Keyword ;
  schema:name "carbon emissions"@en ;
  schema:description "volume of carbon produced contributing to global warming"@en ;
  dcterms:modified "2026-06-07T15:30:02.351639Z"^^xsd:dateTime .

oakcurric:keyword-iterative
  a curric:Keyword ;
  schema:name "iterative"@en ;
  schema:description "refining and improving"@en ;
  dcterms:modified "2026-06-07T15:30:02.351680Z"^^xsd:dateTime .

oakcurric:keyword-physical-property
  a curric:Keyword ;
  schema:name "physical property"@en ;
  schema:description "the characteristics of a material, such as appearance and features"@en ;
  dcterms:modified "2026-06-07T15:30:02.351962Z"^^xsd:dateTime .

oakcurric:keyword-working-property
  a curric:Keyword ;
  schema:name "working property"@en ;
  schema:description """the way in which a material responds to an external force or certain
  environment; also referred to as mechanical properties"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351967Z"^^xsd:dateTime .

oakcurric:keyword-circular-economy
  a curric:Keyword ;
  schema:name "circular economy"@en ;
  schema:description """an economic system where products and materials are kept in circulation and
  do not become waste"""@en ;
