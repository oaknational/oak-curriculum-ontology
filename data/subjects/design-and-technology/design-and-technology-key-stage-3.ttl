  a curric:KeyLearningPoint ;
  rdfs:label "Timbers can be cut and shaped using hand tools or machinery."@en ;
  dcterms:modified "2026-06-07T15:30:29.279284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Quality control like checking measurements should be implemented throughout
  production."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27840-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hardness is a material's ability to resist scratching and indentation."@en ;
  dcterms:modified "2026-06-07T15:30:29.282184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27840-2
  a curric:KeyLearningPoint ;
  rdfs:label "Vickers and Brinell are industrial hardness tests."@en ;
  dcterms:modified "2026-06-07T15:30:29.282205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27840-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Vickers and Brinell tests measure hardness by pressing an indenter into the
  material and observing the mark left."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27840-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hardness test can be simulated in a workshop using a centre punch and a
  hammer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27840-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hardness can be tested by scratching the surface of a material with a scribe."@en ;
  dcterms:modified "2026-06-07T15:30:29.282216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27805-1
  a curric:KeyLearningPoint ;
  rdfs:label """All design and technological practice takes place within contexts which inform
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27805-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paper and boards have different physical and mechanical properties"@en ;
  dcterms:modified "2026-06-07T15:30:29.285902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27805-3
  a curric:KeyLearningPoint ;
  rdfs:label """Paper and boards come from different sources and are available in different stock
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27805-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cardboard can be used to create quick physical models."@en ;
  dcterms:modified "2026-06-07T15:30:29.285914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27805-5
  a curric:KeyLearningPoint ;
  rdfs:label """Trees are the source of paper and boards, and many different types can be
  manufactured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27844-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modern materials are continually being developed through the invention of new or
  improved processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27844-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of modern materials include: Nomex, Teflon, Fastskin, PLA, Kevlar and
  composites."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27844-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composite materials combine the properties of two or more materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.309026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27844-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of composite materials include GRP, CFRP and laminates."@en ;
  dcterms:modified "2026-06-07T15:30:29.309030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27844-5
  a curric:KeyLearningPoint ;
  rdfs:label "Modern materials have improved working and/or physical properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.309034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27841-1
  a curric:KeyLearningPoint ;
  rdfs:label "Raw materials need to be sourced and processed into a useable form."@en ;
  dcterms:modified "2026-06-07T15:30:29.324759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are sourced from the earth as ores, which are mined, extracted, and processed
  into usable materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27841-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metals are categorised as ferrous, non-ferrous, or alloys."@en ;
  dcterms:modified "2026-06-07T15:30:29.324770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27841-4
  a curric:KeyLearningPoint ;
  rdfs:label "Processed metals are formed into standard stock forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.324774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27841-5
  a curric:KeyLearningPoint ;
  rdfs:label """Metal properties such as strength, ductility and conductivity determine their
  suitability for different products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27804-1
  a curric:KeyLearningPoint ;
  rdfs:label "Deforming materials changes the shape and not the state."@en ;
  dcterms:modified "2026-06-07T15:30:29.324782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27804-2
  a curric:KeyLearningPoint ;
  rdfs:label "Timber veneer can be deformed by laminating."@en ;
  dcterms:modified "2026-06-07T15:30:29.324786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27804-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vacuum forming is a deforming process for polymers."@en ;
  dcterms:modified "2026-06-07T15:30:29.324790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27866-1
  a curric:KeyLearningPoint ;
  rdfs:label """To successfully integrate technology into a wearable product, all electrical
  components must be protected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27866-2
  a curric:KeyLearningPoint ;
  rdfs:label "Electronic components are easier to integrate when housed in a case."@en ;
  dcterms:modified "2026-06-07T15:30:29.332375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27866-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dimensions of and access to the electronic components must be considered."@en ;
  dcterms:modified "2026-06-07T15:30:29.332379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27866-4
  a curric:KeyLearningPoint ;
  rdfs:label "Paper patterns are used to plan textile designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.332383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27866-5
  a curric:KeyLearningPoint ;
  rdfs:label "Manufacture is planned in advance."@en ;
  dcterms:modified "2026-06-07T15:30:29.332387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27797-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be categorised using aesthetics."@en ;
  dcterms:modified "2026-06-07T15:30:29.349515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27797-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be categorised using physical properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.349519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27797-3
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be categorised using mechanical properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.349522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27797-4
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be categorised using the categories paper and board, timber, metal,
  polymer and textiles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27797-5
  a curric:KeyLearningPoint ;
  rdfs:label """Designers use a justified specification to outline material property
  requirements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27800-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be joined using adhesives"@en ;
  dcterms:modified "2026-06-07T15:30:29.353660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27800-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be joined using mechanical fixings"@en ;
  dcterms:modified "2026-06-07T15:30:29.353664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27803-1
  a curric:KeyLearningPoint ;
  rdfs:label "Minimising waste is important for both economic and environmental reasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.355481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27803-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stencils and templates are used to ensure materials are used efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:29.355485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27803-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nesting is used to ensure materials are used efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:29.355489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27835-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modelling is essential to test designs, gain feedback and improve products before
  manufacturing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27835-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding user needs and wants is critical to designing effective and accessible
  products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27835-3
  a curric:KeyLearningPoint ;
  rdfs:label """Templates are used to save time, ensure consistency and improve the quality of
  prototypes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27835-4
  a curric:KeyLearningPoint ;
  rdfs:label """Prototyping methods, like foam and cardboard modelling, help refine the product’s
  size, shape and function."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27827-1
  a curric:KeyLearningPoint ;
  rdfs:label """When assembling timbers different methods of joining are used e.g. gluing, clamping,
  screws and nails."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27827-2
  a curric:KeyLearningPoint ;
  rdfs:label """When assembling timbers, different methods of joining are used, such as wooden
  joints."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27827-3
  a curric:KeyLearningPoint ;
  rdfs:label """When constructing a screw joint correctly, pilot and clearance holes must used. This
  prevents the timber from splitting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27827-4
  a curric:KeyLearningPoint ;
  rdfs:label """Timber joints are the ways pieces of wood are connected or joined together to form a
  product or structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27812-1
  a curric:KeyLearningPoint ;
  rdfs:label """Laser cutters use concentrated beams of light to cut or engrave materials, requiring
  precise vector files."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27812-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designs must be lowered through the Tinkercad workplane before exporting."@en ;
  dcterms:modified "2026-06-07T15:30:29.378478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27812-3
  a curric:KeyLearningPoint ;
  rdfs:label """Laser cutters must be used with extraction systems to remove harmful fumes and
  ensure safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27812-4
  a curric:KeyLearningPoint ;
  rdfs:label """Efficient use of materials can be achieved through tessellation, which reduces waste
  by tightly arranging shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27867-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tools and equipment are selected and used safely and accurately to manufacture a
  wearable technology product"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27867-2
  a curric:KeyLearningPoint ;
  rdfs:label "During manufacture, quality control checks are made."@en ;
  dcterms:modified "2026-06-07T15:30:29.380873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27802-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reforming materials changes the shape and the state."@en ;
  dcterms:modified "2026-06-07T15:30:29.390608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27802-2
  a curric:KeyLearningPoint ;
  rdfs:label "Injection moulding is a reforming process for polymers."@en ;
  dcterms:modified "2026-06-07T15:30:29.390612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27802-3
  a curric:KeyLearningPoint ;
  rdfs:label "Casting is a reforming process for metals."@en ;
  dcterms:modified "2026-06-07T15:30:29.390618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27834-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cardboard is a thick, strong paper material made from layers of wood pulp."@en ;
  dcterms:modified "2026-06-07T15:30:29.399994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27834-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cardboard used for packaging, crafts, and creating prototypes as it is strong,
  ridgid, light, and easy to cut or fold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27834-3
  a curric:KeyLearningPoint ;
  rdfs:label """Corrugated cardboard is used for prototyping due to its structural integrity,
  strength and versatility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27834-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cardboard can be layered, slotted, folded, scored, and joined to build strong 3D
  models."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27834-5
  a curric:KeyLearningPoint ;
  rdfs:label "When modelling with cardboard, adhesives need to be used."@en ;
  dcterms:modified "2026-06-07T15:30:29.400010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27838-1
  a curric:KeyLearningPoint ;
  rdfs:label "The physical properties of materials can be tested."@en ;
  dcterms:modified "2026-06-07T15:30:29.401794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27838-2
  a curric:KeyLearningPoint ;
  rdfs:label "A material’s density can be calculated by comparing its mass and volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.401798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27838-3
  a curric:KeyLearningPoint ;
  rdfs:label """A material's absorbency can be measured by taking the wet weight away from the dry
  weight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27838-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electrical conductivity of materials can be tested circuits to show whether a
  material is a conductor or an insulator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27798-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be manufactured using wasting techniques such as cutting using
  scissors, shears or saws."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27798-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be manufactured using wasting techniques such as drilling."@en ;
  dcterms:modified "2026-06-07T15:30:29.402403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27798-3
  a curric:KeyLearningPoint ;
  rdfs:label """Risk assessments identify potential risks and list actions to be taken to minimise
  these."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27829-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ergonomics is the relationship between the product and the user."@en ;
  dcterms:modified "2026-06-07T15:30:29.424797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27829-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ergonomic design enhances comfort and usability."@en ;
  dcterms:modified "2026-06-07T15:30:29.424801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27829-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating existing designs helps identify areas for improvement."@en ;
  dcterms:modified "2026-06-07T15:30:29.424806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27810-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Tinkercad Sim Lab, you can test designs using simulations that include gravity,
  collisions, and material properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27810-2
  a curric:KeyLearningPoint ;
  rdfs:label "Simulating is physics based digital testing of CAD models."@en ;
  dcterms:modified "2026-06-07T15:30:29.424909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27810-3
  a curric:KeyLearningPoint ;
  rdfs:label """Several editable variables can be changed in Sim Lab to produce more realistic
  simulations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27810-4
  a curric:KeyLearningPoint ;
  rdfs:label """Model paths can be traced to compare the performance of different materials when
  simulating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27810-5
  a curric:KeyLearningPoint ;
  rdfs:label """Basic stability rules should be followed when modelling to ensure parts can be
  simulated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27818-1
  a curric:KeyLearningPoint ;
  rdfs:label """Orthographic projections are 2D drawings from different sides to show a 3D
  shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27818-2
  a curric:KeyLearningPoint ;
  rdfs:label "Orthographic projections usually include front, top, and side views."@en ;
  dcterms:modified "2026-06-07T15:30:29.425174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27831-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empathy means understanding and feeling what users experience, allowing designers to
  create more accessible products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27831-2
  a curric:KeyLearningPoint ;
  rdfs:label """Simulating impairments helps designers create inclusive solutions by experiencing
  these difficulties firsthand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27831-3
  a curric:KeyLearningPoint ;
  rdfs:label """Task analysis involves breaking down actions into steps to identify obstacles, which
  helps designers simplify processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27831-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptive products can be adjusted or customised to meet the individual needs of
  users."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27831-5
  a curric:KeyLearningPoint ;
  rdfs:label """Assistive products are tools designed to help perform tasks they may find
  difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27832-1
  a curric:KeyLearningPoint ;
  rdfs:label """Polymers are long chains of monomers, classified as natural or synthetic and grouped
  as thermoforming or thermosetting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27832-2
  a curric:KeyLearningPoint ;
  rdfs:label "Most polymers are made from petrochemicals, which are synthetic."@en ;
  dcterms:modified "2026-06-07T15:30:29.425320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27832-3
  a curric:KeyLearningPoint ;
  rdfs:label """Polymers are lightweight, durable, flexible, water-resistant, and good
  insulators."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27832-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers are supplied as granules, sheets, rods, or pipes and have many uses."@en ;
  dcterms:modified "2026-06-07T15:30:29.425329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding tone with shading to a drawing can enhance the 3D effect."@en ;
  dcterms:modified "2026-06-07T15:30:29.425572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27814-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding shadow to 3D drawings can enhance the effect."@en ;
  dcterms:modified "2026-06-07T15:30:29.425576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27799-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose, environment and user of a product determine the material properties
  required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27799-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product properties required determines the material chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.425585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27823-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers collaborate,  to identify design opportunities."@en ;
  dcterms:modified "2026-06-07T15:30:29.425652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27823-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designers collaborate, to create, evaluate and iterate design ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.425656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27823-3
  a curric:KeyLearningPoint ;
  rdfs:label """A design requirement is something which is needed or wanted to make a product
  successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27823-4
  a curric:KeyLearningPoint ;
  rdfs:label """Design requirements can support writing a design brief and along with exploring the
  context, can support designing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27823-5
  a curric:KeyLearningPoint ;
  rdfs:label """One way of designing that can be suited to collaborative work is to use the scribble
  technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27843-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials for manufacture are chosen based on performance, cost, and
  sustainability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27843-2
  a curric:KeyLearningPoint ;
  rdfs:label """Physical and working properties like strength, flexibility, and durability determine
  how well a material performs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27843-3
  a curric:KeyLearningPoint ;
  rdfs:label """Manufacturers must balance trade-offs between performance, cost, and sustainability
  when selecting materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27843-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a school workshop, cost is often the most critical factor when selecting
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27809-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Tinkercad, movement can be simulated using three types of connectors: axle,
  pivot, and slider."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27809-2
  a curric:KeyLearningPoint ;
  rdfs:label "The axle connector allows one part to rotate around another."@en ;
  dcterms:modified "2026-06-07T15:30:29.425939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27809-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pivot connector allows parts to swing or rotate around a fixed point."@en ;
  dcterms:modified "2026-06-07T15:30:29.425943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27809-4
  a curric:KeyLearningPoint ;
  rdfs:label "The slider connector allows parts to move back and forth in a straight line."@en ;
  dcterms:modified "2026-06-07T15:30:29.425948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27856-1
  a curric:KeyLearningPoint ;
  rdfs:label """Decisions at the manufacture and materials processing stage have the potential to
  reduce the environmental impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27856-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairtrade is a global movement ensuring better prices, decent working conditions,
  and fair terms for farmers/workers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27860-1
  a curric:KeyLearningPoint ;
  rdfs:label "Products can be redesigned or adapted to make future successful products."@en ;
  dcterms:modified "2026-06-07T15:30:29.426043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27860-2
  a curric:KeyLearningPoint ;
  rdfs:label """Refillable products enable a reduction in packaging that would otherwise end up in
  landfill."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27860-3
  a curric:KeyLearningPoint ;
  rdfs:label "Existing products can inspire future design."@en ;
  dcterms:modified "2026-06-07T15:30:29.426051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27821-1
  a curric:KeyLearningPoint ;
  rdfs:label """All design and technological practice takes place within contexts which inform
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27821-2
  a curric:KeyLearningPoint ;
  rdfs:label "One-off production is where one item is made to measure."@en ;
  dcterms:modified "2026-06-07T15:30:29.426116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27821-3
  a curric:KeyLearningPoint ;
  rdfs:label "Batch production is where a specific number of products are manufactured."@en ;
  dcterms:modified "2026-06-07T15:30:29.426120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27821-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mass production is where a large number of products are manufactured."@en ;
  dcterms:modified "2026-06-07T15:30:29.426124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27855-1
  a curric:KeyLearningPoint ;
  rdfs:label """Design plays a crucial role in shaping the environmental impact of a product across
  it's entire lifecycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designing products that last longer and can be shared help to reduce environmental
  impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27820-1
  a curric:KeyLearningPoint ;
  rdfs:label """Exploded diagrams visually separate the parts of an object while maintaining their
  relative positions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27820-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective exploded diagrams include a centre line for alignment, equal spacing
  between parts and clear labeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27820-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exploded diagrams can be shown vertically or horizontally."@en ;
  dcterms:modified "2026-06-07T15:30:29.426219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27839-1
  a curric:KeyLearningPoint ;
  rdfs:label "Material properties describe how a material looks, feels, and behaves."@en ;
  dcterms:modified "2026-06-07T15:30:29.426223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27839-2
  a curric:KeyLearningPoint ;
  rdfs:label """Working properties are the way in which a material responds to an external force or
  certain environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27839-3
  a curric:KeyLearningPoint ;
  rdfs:label """Working properties are also called ‘mechanical properties’ because they relate to
  how materials behave when used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27839-4
  a curric:KeyLearningPoint ;
  rdfs:label """Working (mechanical) properties help us select materials based on their
  function."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27849-1
  a curric:KeyLearningPoint ;
  rdfs:label """To support the ideation stage of the design process, designers will produce a list
  of design requirements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27849-2
  a curric:KeyLearningPoint ;
  rdfs:label """A design requirement is something which is needed or wanted to make a product
  successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27849-3
  a curric:KeyLearningPoint ;
  rdfs:label """Designers use different strategies to support ideation. One strategy is to redesign
  existing products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27849-4
  a curric:KeyLearningPoint ;
  rdfs:label """To support the redesign of existing products, a thinking tool called SCAMPER can be
  used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27849-5
  a curric:KeyLearningPoint ;
  rdfs:label """SCAMPER is an acronym that helps designers generate new ideas, develop ideas and
  redesign existing ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27826-1
  a curric:KeyLearningPoint ;
  rdfs:label "Quality control is used in batch production so products are consistent."@en ;
  dcterms:modified "2026-06-07T15:30:29.426378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27826-2
  a curric:KeyLearningPoint ;
  rdfs:label """A tolerance is the acceptable range of variation in a product's dimensions or
  weight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27826-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Gantt chart is a way of displaying tasks in a horizontal bar chart that visually
  displays a schedule over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27850-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers share ideas with sketches."@en ;
  dcterms:modified "2026-06-07T15:30:29.426526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27850-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers share ideas to gather feedback which influence design developments and
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27850-3
  a curric:KeyLearningPoint ;
  rdfs:label "Designers use user feedback to inform and support design iteration."@en ;
  dcterms:modified "2026-06-07T15:30:29.426537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27854-1
  a curric:KeyLearningPoint ;
  rdfs:label """LCA assesses the environmental impact at every stage of a product's life cycle with
  the aim to reduce the impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27854-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers can make environmentally friendly design decisions by considering the
  results of LCA."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27807-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use Group, Ungroup, Align, and Duplicate tools to build complex shapes in
  Tinkercad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27807-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Scribble and Sketch tools are used to create and edit custom shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.426964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27807-3
  a curric:KeyLearningPoint ;
  rdfs:label "Robots are machines that can do tasks; they can sense, think, and act."@en ;
  dcterms:modified "2026-06-07T15:30:29.426968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27807-4
  a curric:KeyLearningPoint ;
  rdfs:label "Robots are often used for repetitive, hard or dangerous jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.426973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27811-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pre-existing CAD models can be accessed, copied, and edited in Tinkercad using the
  gallery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27811-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designs can be modified by ungrouping, resizing, and combining parts to create more
  complex models."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27811-3
  a curric:KeyLearningPoint ;
  rdfs:label "CAD models can be exported and prepared for manufacturing through CAM."@en ;
  dcterms:modified "2026-06-07T15:30:29.426989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27811-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most 3D printers in schools use a process called fused filament fabrication
  (FFF)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27811-5
  a curric:KeyLearningPoint ;
  rdfs:label """Once prepared, the model is sent to a CNC machine, such as a 3D printer, which
  builds the object layer by layer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27859-1
  a curric:KeyLearningPoint ;
  rdfs:label """Design decisions can influence the environmental impact at the repair, maintenance
  and recycling stages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27859-2
  a curric:KeyLearningPoint ;
  rdfs:label "Methods of recycling can be creative."@en ;
  dcterms:modified "2026-06-07T15:30:29.427041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Design optimisation is the process of improving a product without losing quality or
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27851-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers can optimise by adjusting materials, safety or function to better meet
  user needs and be more sustainable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27851-3
  a curric:KeyLearningPoint ;
  rdfs:label """Optimisation is part of design development and helps ensure a product is the best
  version before manufacture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27815-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding material, colour and texture can enhance the drawing."@en ;
  dcterms:modified "2026-06-07T15:30:29.427256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27815-2
  a curric:KeyLearningPoint ;
  rdfs:label """By adding tone and texture to the sketch through rendering, we can show how the
  object will look and feel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27852-1
  a curric:KeyLearningPoint ;
  rdfs:label """Designers reflect on design journeys to learn from what worked and what didn’t,
  including failures and setbacks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27852-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers justify design decisions throughout the design journey, showing how these
  led to the final design outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27852-3
  a curric:KeyLearningPoint ;
  rdfs:label "Designers present final design outcomes to communicate designs clearly."@en ;
  dcterms:modified "2026-06-07T15:30:29.427388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27852-4
  a curric:KeyLearningPoint ;
  rdfs:label """Designers use hand sketches, CAD models, prototypes and AI-generated visuals to
  present their ideas effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27816-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective drawings can be used to show 3D designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.427415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27816-2
  a curric:KeyLearningPoint ;
  rdfs:label """Objects closer to the viewer appear larger, and those farther away appear
  smaller."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27816-3
  a curric:KeyLearningPoint ;
  rdfs:label """Perspective drawings add focus for the viewer's eye which can create a sense of
  movement and scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27842-1
  a curric:KeyLearningPoint ;
  rdfs:label "A Life Cycle Assessment (LCA) checks a product’s impact from start to finish."@en ;
  dcterms:modified "2026-06-07T15:30:29.427445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27842-2
  a curric:KeyLearningPoint ;
  rdfs:label """The carbon footprint rises with energy and resources used in manufacture, use and
  disposal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recycling, reuse, or upcycling reduce the carbon footprint in an LCA."@en ;
  dcterms:modified "2026-06-07T15:30:29.427453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27842-4
  a curric:KeyLearningPoint ;
  rdfs:label "Designers use the LCA to find ways to cut emissions and improve efficiency."@en ;
  dcterms:modified "2026-06-07T15:30:29.427457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27824-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manufacturing specifications are used to communicate the details which will enable a
  design to manufactured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27824-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are used when manufacturing in batches."@en ;
  dcterms:modified "2026-06-07T15:30:29.427544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27824-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cells are when manufacturing tasks and workers are grouped to efficiently produce
  batches of products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27824-4
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting a manufacturing specification can be in a table or a list."@en ;
  dcterms:modified "2026-06-07T15:30:29.427552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27819-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cross-sectional drawings help see inside objects by cutting them open on paper."@en ;
  dcterms:modified "2026-06-07T15:30:29.427556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27819-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cross-sectional drawings are used when important details are hidden inside and can't
  be seen from the outside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27819-3
  a curric:KeyLearningPoint ;
  rdfs:label """A cutting plane is a dashed line with arrows that shows where the object is cut to
  reveal the inside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27819-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hatching indicates a cut section, showing internal details and clarifying it's not
  the full design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27808-1
  a curric:KeyLearningPoint ;
  rdfs:label """A lever is a very simple way to gain a mechanical advantage (MA) to make moving or
  lifting something easier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27808-2
  a curric:KeyLearningPoint ;
  rdfs:label "Levers have three changeable elements on a bar, the fulcrum, effort and load."@en ;
  dcterms:modified "2026-06-07T15:30:29.430126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27808-3
  a curric:KeyLearningPoint ;
  rdfs:label "Linkages are mechanisms that can change the magnitude and directions of a force."@en ;
  dcterms:modified "2026-06-07T15:30:29.430132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27808-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cams convert rotary into reciprocating motion. The shape of a cam determines the
  speed and magnitude of the motion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27808-5
  a curric:KeyLearningPoint ;
  rdfs:label """The shape of the bottom of the follower changes the accuracy of the motion, however,
  this affects wear and friction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27847-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers show empathy when exploring contexts."@en ;
  dcterms:modified "2026-06-07T15:30:29.430420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Empathy is having the ability to understand and share the feelings, thoughts, or
  experiences of another person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27847-3
  a curric:KeyLearningPoint ;
  rdfs:label """Showing empathy supports designing because it helps designers better understand what
  users really need, feel and want."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27847-4
  a curric:KeyLearningPoint ;
  rdfs:label "A user journey map can support showing empathy with users."@en ;
  dcterms:modified "2026-06-07T15:30:29.430433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27847-5
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring experiences can give designers insight into the needs and wants of
  users."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27837-1
  a curric:KeyLearningPoint ;
  rdfs:label "Material properties describe how a material looks, feels, and behaves."@en ;
  dcterms:modified "2026-06-07T15:30:29.430979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27837-2
  a curric:KeyLearningPoint ;
  rdfs:label """Physical properties are the characteristics of a material, such as appearance and
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27837-3
  a curric:KeyLearningPoint ;
  rdfs:label """Physical properties (characteristics) help us choose the right material for a
  product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27837-4
  a curric:KeyLearningPoint ;
  rdfs:label """Physical properties are the characteristics of a material that can be observed
  without doing anything to it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27837-5
  a curric:KeyLearningPoint ;
  rdfs:label "The function of a product decides what material properties are needed."@en ;
  dcterms:modified "2026-06-07T15:30:29.430998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Timbers can be categorised as softwood, hardwood or manufactured boards."@en ;
  dcterms:modified "2026-06-07T15:30:29.431033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27822-2
  a curric:KeyLearningPoint ;
  rdfs:label "Timber is sourced from trees."@en ;
  dcterms:modified "2026-06-07T15:30:29.431037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27822-3
  a curric:KeyLearningPoint ;
  rdfs:label "Timber is available in planks, sheets, mouldings and dowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.431041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27817-1
  a curric:KeyLearningPoint ;
  rdfs:label """Orthographic projections are used to share the details and dimensions of a
  design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27817-2
  a curric:KeyLearningPoint ;
  rdfs:label "Orthographic projections are used to accurately represent 3D designs in 2D."@en ;
  dcterms:modified "2026-06-07T15:30:29.431522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27817-3
  a curric:KeyLearningPoint ;
  rdfs:label """Orthographic projections are drawn to scale and show the true dimensions of
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27817-4
  a curric:KeyLearningPoint ;
  rdfs:label """Orthographic projections use standard conventions, making them
  universal/international."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27853-1
  a curric:KeyLearningPoint ;
  rdfs:label "A linear economy represents 'cradle to grave' product life cycle."@en ;
  dcterms:modified "2026-06-07T15:30:29.431568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27853-2
  a curric:KeyLearningPoint ;
  rdfs:label "Circular economy represents 'cradle to cradle' product life cycle."@en ;
  dcterms:modified "2026-06-07T15:30:29.431572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27813-1
  a curric:KeyLearningPoint ;
  rdfs:label "Isometric drawing is a 3D representation."@en ;
  dcterms:modified "2026-06-07T15:30:29.431818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27813-2
  a curric:KeyLearningPoint ;
  rdfs:label "A box or crate can be used to form the basis of much more complex designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.431822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27845-1
  a curric:KeyLearningPoint ;
  rdfs:label """Smart materials change their material properties in response to an external
  stimulus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smart material examples include thermochromic pigments, photochromic pigments and
  shape memory alloys."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27845-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stimuli include sunlight, water/moisture, pressure and temperature."@en ;
  dcterms:modified "2026-06-07T15:30:29.431835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27845-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smart materials gives designers and engineers exciting possibilities when developing
  new products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27801-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be from natural or synthetic sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.431910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27801-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be from renewable or non-renewable sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.431914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27801-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal ores and polymers made from crude oil are non-renewable materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.431918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27801-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials sourced from plants and animals are renewable."@en ;
  dcterms:modified "2026-06-07T15:30:29.431923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27801-5
  a curric:KeyLearningPoint ;
  rdfs:label "Recycling ensures that materials are useful for longer, before being discarded."@en ;
  dcterms:modified "2026-06-07T15:30:29.431929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27858-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers consider the environmental impact of a product in use."@en ;
  dcterms:modified "2026-06-07T15:30:29.432028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27858-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjustable and modular products have a positive environmental impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.432032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27846-1
  a curric:KeyLearningPoint ;
  rdfs:label "Product development is the steps used to create or improve a product."@en ;
  dcterms:modified "2026-06-07T15:30:29.432064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27846-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers use a design process to support this consisting of the stages empathise,
  define, ideate, prototype and test."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27846-3
  a curric:KeyLearningPoint ;
  rdfs:label "A market pull is when the demand of people drives the creation of new product."@en ;
  dcterms:modified "2026-06-07T15:30:29.432072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27846-4
  a curric:KeyLearningPoint ;
  rdfs:label """Technology push is when new innovations or advancements in technology drive the
  creation of new products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27836-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes are tested to identify and fix problems in a design."@en ;
  dcterms:modified "2026-06-07T15:30:29.432080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27836-2
  a curric:KeyLearningPoint ;
  rdfs:label "Products intended for a wide range of people must be tested by different users."@en ;
  dcterms:modified "2026-06-07T15:30:29.432084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27836-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information gathered can be subjective as people will offer their own opinions based
  on their own beliefs and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27836-4
  a curric:KeyLearningPoint ;
  rdfs:label """After user testing, feedback is used to iterate, ensuring the design improves based
  on testing results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27833-1
  a curric:KeyLearningPoint ;
  rdfs:label "Foam is an effective modelling material for ergonomic testing."@en ;
  dcterms:modified "2026-06-07T15:30:29.432115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27833-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hands-on modelling refines design concepts before final production."@en ;
  dcterms:modified "2026-06-07T15:30:29.432119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27833-3
  a curric:KeyLearningPoint ;
  rdfs:label "Iterative testing improves design functionality and user experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.432123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27806-1
  a curric:KeyLearningPoint ;
  rdfs:label """Computer-aided design (CAD) is the use of computer applications to model 3
  dimensional designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27806-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tinkercad is a CAD application that can be accessed for free online."@en ;
  dcterms:modified "2026-06-07T15:30:29.432494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27806-3
  a curric:KeyLearningPoint ;
  rdfs:label """The workspace is what is seen and interacted with on screen using the mouse and
  keyboard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27806-4
  a curric:KeyLearningPoint ;
  rdfs:label """The workplane is the space used for designing on when using computer-aided
  design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27806-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are usually three buttons on the mouse that can be used to interact with
  Tinkercad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27830-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anthropometrics are the measurements of people. It helps designers create products
  that fit people properly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27830-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anthropometrics are important to ensure that products are comfortable and easy to
  use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27830-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are three percentiles to consider when interpreting anthropometric data: the
  5th, 50th and 95th percentiles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27830-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inclusive and adjustable designs make sure that as many users as possible can use a
  product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27848-1
  a curric:KeyLearningPoint ;
  rdfs:label """Product analysis helps designers identify which features are successful and which
  could be improved on products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27848-2
  a curric:KeyLearningPoint ;
  rdfs:label """Quality standards are guidelines that ensure products or services meet consistent
  and accepted levels of excellence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27848-3
  a curric:KeyLearningPoint ;
  rdfs:label """They include the British Standards Institution (BSI) and European Standards
  (CE)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27848-4
  a curric:KeyLearningPoint ;
  rdfs:label """Designers must ensure their products, meet the correct and current safety and
  quality standards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27848-5
  a curric:KeyLearningPoint ;
  rdfs:label "When analysing products for new parents safety should be a primary focus."@en ;
  dcterms:modified "2026-06-07T15:30:29.433640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27828-1
  a curric:KeyLearningPoint ;
  rdfs:label "Designers collaborate to evaluate designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.434164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27828-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designers modify products after evaluating."@en ;
  dcterms:modified "2026-06-07T15:30:29.434168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27828-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluations help to discover if the final design outcome has addressed the original
  design objectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27828-4
  a curric:KeyLearningPoint ;
  rdfs:label """Design specifications and requirements can be used to support writing an
  evaluation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27864-1
  a curric:KeyLearningPoint ;
  rdfs:label "Design briefs can be refined using the 4Ws."@en ;
  dcterms:modified "2026-06-07T15:30:29.593676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27864-2
  a curric:KeyLearningPoint ;
  rdfs:label "Control systems can be developed and iterated."@en ;
  dcterms:modified "2026-06-07T15:30:29.593680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27861-1
  a curric:KeyLearningPoint ;
  rdfs:label """The context is wearable technology - to keeps pupils safe when travelling to and
  from school in the dark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27861-2
  a curric:KeyLearningPoint ;
  rdfs:label "Electronic systems have input, process and output components."@en ;
  dcterms:modified "2026-06-07T15:30:29.597133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27861-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tinkercad circuits can be used to design and simulate electronic circuits."@en ;
  dcterms:modified "2026-06-07T15:30:29.597137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27862-1
  a curric:KeyLearningPoint ;
  rdfs:label "Control systems use inputs such as switches and sensors."@en ;
  dcterms:modified "2026-06-07T15:30:29.597918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27862-2
  a curric:KeyLearningPoint ;
  rdfs:label "Control systems use processes such as microcontrollers."@en ;
  dcterms:modified "2026-06-07T15:30:29.597922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Control systems use outputs such as sound, light or movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.597926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27862-4
  a curric:KeyLearningPoint ;
  rdfs:label "Control systems use feedback."@en ;
  dcterms:modified "2026-06-07T15:30:29.597930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fabrics can be categorised as natural or synthetic. They can be new or recycled."@en ;
  dcterms:modified "2026-06-07T15:30:29.599777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27865-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fabrics can be categorised by the process by which they are created: woven,
  non-woven and knitted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27865-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fabrics can be fabricated by stitching, adhesives or mechanical fixings."@en ;
  dcterms:modified "2026-06-07T15:30:29.599785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27865-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fabrics different materials and fabrication techniques can help to make informed and
  justified design decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27863-1
  a curric:KeyLearningPoint ;
  rdfs:label "Micro:bits are small computers which are are programmed using codes and blocks."@en ;
  dcterms:modified "2026-06-07T15:30:29.601191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27863-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light sequences and loops can be used to develop control systems further."@en ;
  dcterms:modified "2026-06-07T15:30:29.601195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27863-3
  a curric:KeyLearningPoint ;
  rdfs:label """Control systems can be simulated within Tinkercad and also in the physical
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27868-1
  a curric:KeyLearningPoint ;
  rdfs:label "Observing the user using a product is one method of testing a product."@en ;
  dcterms:modified "2026-06-07T15:30:29.604963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27868-2
  a curric:KeyLearningPoint ;
  rdfs:label "Products are evaluated against the design brief."@en ;
  dcterms:modified "2026-06-07T15:30:29.604967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27857-1
  a curric:KeyLearningPoint ;
  rdfs:label """Decisions for the distribution stage have the potential to reduce environmental
  impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27857-2
  a curric:KeyLearningPoint ;
  rdfs:label "Material options for packaging are evolving to be more sustainable."@en ;
  dcterms:modified "2026-06-07T15:30:29.617560Z"^^xsd:dateTime .

