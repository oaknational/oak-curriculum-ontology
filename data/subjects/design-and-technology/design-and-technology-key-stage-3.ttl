  a curric:PupilLessonOutcome ;
  rdfs:label "I can use materials efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:41.087837Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-27835
  a curric:PupilLessonOutcome ;
  rdfs:label "I can create prototypes using cardboard and foam modelling techniques."@en ;
