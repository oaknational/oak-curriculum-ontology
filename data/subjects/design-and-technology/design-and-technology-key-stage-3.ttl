  a curric:PupilLessonOutcome ;
  rdfs:label "I can prepare and transfer a file for laser cutting."@en ;
  dcterms:modified "2026-06-07T15:30:41.093676Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-27867
  a curric:PupilLessonOutcome ;
