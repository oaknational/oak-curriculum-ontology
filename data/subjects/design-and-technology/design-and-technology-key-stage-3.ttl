# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-model-3d-printed-using-fused
  a curric:Misconception ;
  curric:statement "Any model can be 3D printed using fused filament fabrication 3D printing."@en ;
  curric:correction """Design for manufacture rules need to be considered when 3D printing. Not all
  models are suitable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084393Z"^^xsd:dateTime .

oakcurric:misconception-physical-properties-working-properties-same
  a curric:Misconception ;
  curric:statement "Physical properties and working properties are the same thing."@en ;
  curric:correction """Physical properties describe inherent features (like density, colour, or
  conductivity), whereas working properties describe how a material behaves under stress
  (like flexibility, toughness, or hardness)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085811Z"^^xsd:dateTime .

oakcurric:misconception-environmental-impact-occurs-products-disposed
  a curric:Misconception ;
  curric:statement "Environmental impact only occurs when products are disposed of."@en ;
  curric:correction """Circular economy and LCA consider the environmental impact at every single
  stage of a product's life cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085873Z"^^xsd:dateTime .

oakcurric:misconception-creating-batch-same-design-consider
  a curric:Misconception ;
  curric:statement """When you are creating a batch of the same design then you have to consider
  quality control checks as much as when you are creating a one off design."""@en ;
  curric:correction """Quality control is just as important in batch production as it is in one-off
  designs. Consistency across all items in the batch depends on regular checks to ensure
  each piece meets the same standard."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095109Z"^^xsd:dateTime .

oakcurric:misconception-environmental-impact-material-happens-product
  a curric:Misconception ;
  curric:statement """The environmental impact of a material only happens when the product is thrown
  away."""@en ;
  curric:correction """A material’s environmental impact occurs at every stage of its life cycle;
  during manufacture, use, and disposal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095154Z"^^xsd:dateTime .

oakcurric:misconception-hardness-testing-destructive
  a curric:Misconception ;
  curric:statement "Hardness testing is destructive."@en ;
  curric:correction """Although an indentation is left in the test piece, hardness testing is less
  destructive than many other working property tests, such as tensile testing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096052Z"^^xsd:dateTime .

oakcurric:misconception-paper-boards-seen-weak-materials
  a curric:Misconception ;
  curric:statement "Paper and boards are often seen as weak materials."@en ;
  curric:correction """Many types of paper and boards are designed to be robust and durable, such as
  corrugated cardboard used for packaging."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097167Z"^^xsd:dateTime .

oakcurric:misconception-modern-materials-provide-advantages-designers
  a curric:Misconception ;
  curric:statement "Modern materials only provide advantages to designers and users."@en ;
  curric:correction """Modern materials are often difficult and expensive to produce and are also
  difficult to recycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106242Z"^^xsd:dateTime .

oakcurric:misconception-metals-similar-properties
  a curric:Misconception ;
  curric:statement "All metals have similar properties."@en ;
  curric:correction """When metals are grouped into ferrous, non-ferrous, and alloy metals, their
  properties are different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111102Z"^^xsd:dateTime .

oakcurric:misconception-laminating-paper-card-covered-clear
  a curric:Misconception ;
  curric:statement "Laminating is when paper or card are covered in clear polymer."@en ;
  curric:correction """Laminating means sticking several layers of material together, the clear
  polymer coated paper or card process is encapsulation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111110Z"^^xsd:dateTime .

oakcurric:misconception-cheapest-material-best-choice
  a curric:Misconception ;
  curric:statement "The cheapest material is always the best choice."@en ;
  curric:correction """Material selection involves balancing multiple factors, such as strength,
  durability, weight, sustainability, and ease of manufacturing; in addition to cost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113259Z"^^xsd:dateTime .

oakcurric:misconception-one-method-integrating-components-control
  a curric:Misconception ;
  curric:statement "Only one method of integrating the components in a control system is used."@en ;
  curric:correction """Different methods of integrating components can be combined, depending on the
  device's function and features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113712Z"^^xsd:dateTime .

oakcurric:misconception-sustainability-decisions-happen-product-designed
  a curric:Misconception ;
  curric:statement "Sustainability decisions happen after the product has been designed."@en ;
  curric:correction """At the design stage, designers have a huge responsibility to influence many
  other stages of a product's life cycle through their design decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116137Z"^^xsd:dateTime .

oakcurric:misconception-smart-materials-fun-products-like
  a curric:Misconception ;
  curric:statement "Smart materials are only for fun products like colour changing mugs!"@en ;
  curric:correction """Smart materials give designers and engineers exciting possibilities when
  developing new products. Possibilities often focus on function and/or form. For example,
  thermochromic materials can be used to indicate a temperature and warn users of danger."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118927Z"^^xsd:dateTime .

oakcurric:misconception-wood-plastic-fabric-correct-terminology
  a curric:Misconception ;
  curric:statement "Wood, plastic and fabric are the correct terminology"@en ;
  curric:correction "Timbers and boards, polymers and textiles are the correct terms"@en ;
  dcterms:modified "2026-06-07T15:30:15.119209Z"^^xsd:dateTime .

oakcurric:misconception-redesigning-product-circular-economy-means
  a curric:Misconception ;
  curric:statement """Redesigning a product for the circular economy only means making it
  recyclable."""@en ;
  curric:correction """Redesign in the circular economy involves designing products to last longer,
  be repaired, reused, or upgraded to reduce waste throughout the product’s entire life
  cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119224Z"^^xsd:dateTime .

oakcurric:misconception-glue-guns-better-adhesive-pva
  a curric:Misconception ;
  curric:statement "Glue guns are a better adhesive than PVA glue for timbers."@en ;
  curric:correction """This is not always true. PVA absorbs into the timbers and creates a good
  bond. Glue guns may add thickness to the join."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120577Z"^^xsd:dateTime .

oakcurric:misconception-minimising-waste-means-reducing-size
  a curric:Misconception ;
  curric:statement "Minimising waste means reducing the size of a product."@en ;
  curric:correction """Using materials efficiently can be achieved by reducing size, but also by
  working accurately. This can be done by using stencils / templates, tesselation and
  nesting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122735Z"^^xsd:dateTime .

oakcurric:misconception-user-needs-wants-same-thing
  a curric:Misconception ;
  curric:statement "User needs and wants are the same thing."@en ;
  curric:correction """Needs are the essential features required for the product to function, while
  wants are additional features that aren't necessary but would enhance the product if
  included."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125206Z"^^xsd:dateTime .

oakcurric:misconception-considering-products-energy-use-way
  a curric:Misconception ;
  curric:statement """Considering a product's energy use is the only way to design a sustainable
  product."""@en ;
  curric:correction """There are many other ways to design a product to be sustainable when in use,
  including designing products to grow with users, be adjusted, modular, reused etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126231Z"^^xsd:dateTime .

oakcurric:misconception-using-hot-glue-gun-join
  a curric:Misconception ;
  curric:statement """Using a hot glue gun to join timbers for a final assembly is a durable method
  of joining."""@en ;
  curric:correction """Hot glue is not strong enough for a final timber assembly. It is more
  suitable for temporary joins, as it can weaken over time. For secure, durable joints, use
  screws, joints or wood glue instead."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128562Z"^^xsd:dateTime .

oakcurric:misconception-quality-control-checks-done-products
  a curric:Misconception ;
  curric:statement """Quality control are checks that are done on products once made to ensure they
  are a high enough quality to be sold or used."""@en ;
  curric:correction """Quality control checks are done throughout the process to ensure quality is a
  constant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130594Z"^^xsd:dateTime .

oakcurric:misconception-laser-cutters-burn-melt-materials
  a curric:Misconception ;
  curric:statement "Laser cutters burn or melt the materials they are cutting."@en ;
  curric:correction "Laser cutters actually vaporise the material with high precision."@en ;
  dcterms:modified "2026-06-07T15:30:15.131852Z"^^xsd:dateTime .

oakcurric:misconception-quality-considered-product-completed
  a curric:Misconception ;
  curric:statement "Quality is only considered when the product has been completed."@en ;
  curric:correction "Quality is considered at all stages of manufacture."@en ;
  dcterms:modified "2026-06-07T15:30:15.132854Z"^^xsd:dateTime .

oakcurric:misconception-once-final-product-complete-further
  a curric:Misconception ;
  curric:statement """Once a final product is complete no further iterations or improvements are
  needed."""@en ;
  curric:correction """Designers constantly seek to improve and develop their designs and products.
  No product is ever perfect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133859Z"^^xsd:dateTime .

oakcurric:misconception-reforming-same-deforming
  a curric:Misconception ;
  curric:statement "Reforming is the same as deforming."@en ;
  curric:correction """Reforming changes the state AND the shape; solid, liquid and back to solid.
  Deforming only changes the shape; the materials always remain a solid."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136956Z"^^xsd:dateTime .

oakcurric:misconception-cardboard-weak-material-suitable-modeling
  a curric:Misconception ;
  curric:statement "Cardboard is a weak material that is not suitable for modeling."@en ;
  curric:correction """Cardboard has a fluted layer that increases its strength and rigidity.
  Modelling techniques, such as layering, can be used to increase its strength further,
  making it a versatile and very good material to model with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140243Z"^^xsd:dateTime .

oakcurric:misconception-absorbent-materials-hold-water-their
  a curric:Misconception ;
  curric:statement "Absorbent materials hold water on their surface."@en ;
  curric:correction "Absorbency involves the liquid being drawn into the material."@en ;
  dcterms:modified "2026-06-07T15:30:15.140871Z"^^xsd:dateTime .

oakcurric:misconception-cutting-form-removing-material
  a curric:Misconception ;
  curric:statement "Cutting is the only form of removing material."@en ;
  curric:correction """Removing material can include cutting, drilling and the use of abrasive
  papers and tools."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141079Z"^^xsd:dateTime .

oakcurric:misconception-way-reduce-environmental-impact-distribution
  a curric:Misconception ;
  curric:statement """The only way to reduce environmental impact at the distribution stage is
  through using electric vehicles."""@en ;
  curric:correction """There are many ways such as designing flat pack, stackable, lightweight
  products, and location of manufacture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143361Z"^^xsd:dateTime .

oakcurric:misconception-way-gain-ma-increasing-input
  a curric:Misconception ;
  curric:statement "The only way to gain MA is by increasing the input force."@en ;
  curric:correction """MA can be increased by increasing the distance from the fulcrum and the
  effort. For example, increasing the arm length on the handle of a flat head screwdriver
  when opening a can of paint."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149618Z"^^xsd:dateTime .

oakcurric:misconception-ergonomics-size-product
  a curric:Misconception ;
  curric:statement "Ergonomics is just about the size of a product."@en ;
  curric:correction """Ergonomics is the relationship between the user and the product, including
  its size, how well it fits and interacts with the body, and how easy and comfortable it is
  to use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150122Z"^^xsd:dateTime .

oakcurric:misconception-models-simulated-successfully-sim-lab
  a curric:Misconception ;
  curric:statement "All models can be simulated successfully in Sim Lab."@en ;
  curric:correction """Before being simulated in Sim Lab, models need to be well-designed and
  stable, considering static and moving parts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150159Z"^^xsd:dateTime .

oakcurric:misconception-front-view-detailed-side-shape
  a curric:Misconception ;
  curric:statement "The front view is always the most detailed side of the shape being drawn."@en ;
  curric:correction """The front view is chosen based on the most informative and clear perspective,
  not necessarily the most detailed one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150259Z"^^xsd:dateTime .

oakcurric:misconception-designers-create-successful-products-based
  a curric:Misconception ;
  curric:statement """Designers can create successful products based on their preferences and
  abilities."""@en ;
  curric:correction """To have empathy for someone helps designers create better products because
  they understand users' needs, challenges, and feelings, leading to more useful and
  user-friendly designs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150265Z"^^xsd:dateTime .

oakcurric:misconception-polymers-recycled-therefore-environmentally-ok
  a curric:Misconception ;
  curric:statement "Polymers can all be recycled and are therefore environmentally ok."@en ;
  curric:correction """Polymers are usually made from non renewable resources and even if recycled,
  are not sustainable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150315Z"^^xsd:dateTime .

oakcurric:misconception-rendering-light-source-location-correctly
  a curric:Misconception ;
  curric:statement """When rendering the light source, location might not be correctly
  identified."""@en ;
  curric:correction """Start with real objects and a light source to help students visualise where
  the shadow and highlight would be. Get students to label where the light source is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150398Z"^^xsd:dateTime .

oakcurric:misconception-one-suitable-material-product
  a curric:Misconception ;
  curric:statement "There is only one suitable material for each product."@en ;
  curric:correction """There are many different materials which can be suitable once a choice has
  been made; it is important to explain and justify this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150404Z"^^xsd:dateTime .

oakcurric:misconception-pupils-design-individually-time-taken
  a curric:Misconception ;
  curric:statement """Pupils should design individually, and time should be taken when creating and
  thinking about design ideas."""@en ;
  curric:correction """Designers work in teams and collaborate to create design ideas. Working
  quickly when generating design ideas can prevent overthinking and allows freedom and
  creativity to lead the way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150421Z"^^xsd:dateTime .

oakcurric:misconception-simulating-tinkercad-exactly-like-physical
  a curric:Misconception ;
  curric:statement "Simulating in Tinkercad is exactly like physical testing."@en ;
  curric:correction """Tinkercad is excellent for digitally testing ideas, but you should always
  expect to make adjustments when you build the physical models."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150503Z"^^xsd:dateTime .

oakcurric:misconception-environmental-decision-manufacture-materials-processing
  a curric:Misconception ;
  curric:statement """The only environmental decision at the manufacture and materials processing
  stage is the choice between renewable/non renewable sources of energy."""@en ;
  curric:correction """Environmental decisions include sources of energy, use of recycled materials,
  sustainable land management such as deforestation, pollution including water pollution and
  transportation. During manufacture, ethical impacts should also be considered."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150520Z"^^xsd:dateTime .

oakcurric:misconception-products-made-factory-production-line
  a curric:Misconception ;
  curric:statement """All products are made in a factory on a production line using machines in
  their thousands."""@en ;
  curric:correction """Products can be maufactured in a factory using machines. They can also be
  manufactured by hand or using machines in a workshop. Products are made in varying
  amounts, this depends on their function, purpose and materials used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150570Z"^^xsd:dateTime .

oakcurric:misconception-parts-exploded-diagram-positioned-anywhere
  a curric:Misconception ;
  curric:statement "The parts in an exploded diagram can be positioned anywhere."@en ;
  curric:correction """Parts should be placed along a centre line, positioned vertically or
  horizontally away from the centre."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150605Z"^^xsd:dateTime .

oakcurric:misconception-redesigning-evolving-existing-products-really
  a curric:Misconception ;
  curric:statement """Redesigning and evolving existing products is not really designing and does
  not show any creativity or innovation."""@en ;
  curric:correction """Redesigning existing products is a part of design work and often requires
  significant creativity, insight, and innovation. Some of the most impactful design
  breakthroughs came not from inventing something new, but from improving what already
  exists."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150637Z"^^xsd:dateTime .

oakcurric:misconception-user-feedback-opinions-its-useful
  a curric:Misconception ;
  curric:statement "User feedback is just opinions, it’s not useful when developing designs."@en ;
  curric:correction """Feedback is largely based on opinions. However, it provides real world
  insight into how people interact see, understand and would use a design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150707Z"^^xsd:dateTime .

oakcurric:misconception-robots-take-human-jobs-future
  a curric:Misconception ;
  curric:statement "Robots will take all human jobs in the future."@en ;
  curric:correction """Robots can sometimes replace people in certain jobs, especially when the work
  is dangerous, boring, or very hard for humans to do. People will still be needed to
  design, build and program robots."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150786Z"^^xsd:dateTime .

oakcurric:misconception-repair-maintenance-recycling-sole-responibility
  a curric:Misconception ;
  curric:statement "Repair, maintenance and recycling is the sole responibility of the user."@en ;
  curric:correction """Design decisions made at the design/redesign stage can determine the ease and
  ability of a product to be repaired, maintained and recycled."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150794Z"^^xsd:dateTime .

oakcurric:misconception-design-optimisation-same-design-development
  a curric:Misconception ;
  curric:statement "Design optimisation is the same as design development."@en ;
  curric:correction """Design development is the bigger process of taking an idea and turning it
  into a final product. Optimisation is the specific part of development where you focus on
  preparing the design for making, creating the best version of your existing design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150835Z"^^xsd:dateTime .

oakcurric:misconception-rendering-sketching-same-process
  a curric:Misconception ;
  curric:statement "Rendering and sketching are the same process."@en ;
  curric:correction """Sketching is like creating the blueprint or the structure of the 3D model.
  Rendering happens afterward and focuses on adding realistic appearances to the sketch,
  like making glass look transparent or wood look grainy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150877Z"^^xsd:dateTime .

oakcurric:misconception-your-final-design-already-decided
  a curric:Misconception ;
  curric:statement """When your final design has already been decided, it is a waste of time
  reflecting back on the design journey."""@en ;
  curric:correction """Even though the final design may be decided, reflection is not about changing
  the outcome, it's about understanding how you got there, what you learned, and how you can
  improve in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150903Z"^^xsd:dateTime .

oakcurric:misconception-vanishing-point-anywhere-page
  a curric:Misconception ;
  curric:statement "The vanishing point can be anywhere on the page."@en ;
  curric:correction """The vanishing point represents where everything in the distance seems to
  disappear to your eye. It's usually on the horizon line, which is where the ground and the
  sky meet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150918Z"^^xsd:dateTime .

oakcurric:misconception-manufacturing-specifications-include-dimensions-materials
  a curric:Misconception ;
  curric:statement "Manufacturing specifications only include dimensions and materials."@en ;
  curric:correction """Manufacturing specifications also include finishes, safety requirements,
  assembly instructions and what tasks need completing. These details ensure that a product
  is made correctly, safely, and consistently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150961Z"^^xsd:dateTime .

oakcurric:misconception-cross-sectional-drawing-another-drawing
  a curric:Misconception ;
  curric:statement """A cross-sectional drawing is just another drawing view, such as front
  or side."""@en ;
  curric:correction """A cross-sectional view is an internal view showing what the inside looks like
  when sliced through. It is is meant to reveal hidden details inside an object."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150967Z"^^xsd:dateTime .

oakcurric:misconception-exploring-context-happen-quickly-get
  a curric:Misconception ;
  curric:statement """Exploring the context should happen quickly so that you can get to the most
  important phase of designing."""@en ;
  curric:correction """Designing is an important phase. However, taking the time to really explore
  the context and understand the users needs and wants will provide solid foundations for
  successful designing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151849Z"^^xsd:dateTime .

oakcurric:misconception-physical-working-properties-same
  a curric:Misconception ;
  curric:statement "Physical and working properties are the same."@en ;
  curric:correction """Physical properties are the characteristics of a material, such as appearance
  and features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152013Z"^^xsd:dateTime .

oakcurric:misconception-softwoods-soft-light-hardwoods-hard
  a curric:Misconception ;
  curric:statement "Softwoods are soft and light, hardwoods are hard and heavy."@en ;
  curric:correction """The terms softwood and hardwood don’t refer to how soft or hard the wood is.
  They classify trees based on their seed type. Many softwoods are softer than hardwoods but
  it's not a strict rule. Balsa is a hardwood, but it’s one of the softest woods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152030Z"^^xsd:dateTime .

oakcurric:misconception-orthographic-views-separate-drawings-connect
  a curric:Misconception ;
  curric:statement "Orthographic views are are separate drawings and do not connect."@en ;
  curric:correction """Explain that each view (top, front, and side) represents a different
  perspective of the same object."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152171Z"^^xsd:dateTime .

oakcurric:misconception-circular-economy-means-recycling
  a curric:Misconception ;
  curric:statement "Circular economy only means recycling."@en ;
  curric:correction """The circular economy can be defined as products and materials being kept in
  circulation and not becoming waste. Design decisions within circular economy can be
  generated through consideration of 6 Rs: recycle, reuse, rethink, refuse, repair, reduce."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152191Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-isometric-drawing-oblique
  a curric:Misconception ;
  curric:statement "Students might confuse isometric drawing with oblique drawing."@en ;
  curric:correction """Use side by side comparisons to allow students to see the distinct
  differences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152271Z"^^xsd:dateTime .

oakcurric:misconception-recycling-good-environment
  a curric:Misconception ;
  curric:statement "Recycling is good for the environment."@en ;
  curric:correction """Recycling ensures that materials are useful for longer before being
  discarded, but the processing is an envionmental cost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152305Z"^^xsd:dateTime .

oakcurric:misconception-designing-creative-innovative-ideas-produced
  a curric:Misconception ;
  curric:statement "Designing is only creative when innovative ideas are produced."@en ;
  curric:correction """Designing is creative at every stage, not just when coming up with brand-new
  ideas. Creativity is also shown in solving problems, improving existing products, and
  making designs more user-friendly, sustainable, or affordable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152354Z"^^xsd:dateTime .

oakcurric:misconception-iteration-needed-poor-designs
  a curric:Misconception ;
  curric:statement "Iteration is only needed for poor designs."@en ;
  curric:correction "All designs can benefit from testing, feedback and iteration."@en ;
  dcterms:modified "2026-06-07T15:30:15.152362Z"^^xsd:dateTime .

oakcurric:misconception-models-final-design
  a curric:Misconception ;
  curric:statement "Models are the final design."@en ;
  curric:correction """Iterative design uses prototypes to model and test ideas, gather feedback and
  improve."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152374Z"^^xsd:dateTime .

oakcurric:misconception-cad-applicatons-like-tinkercad-allow
  a curric:Misconception ;
  curric:statement """CAD applicatons like Tinkercad just allow you to recreate an idea or design as
  a digital version."""@en ;
  curric:correction """CAD applications like Tinkercad are great for creating ideas and designs in a
  digital 3D world. They can also help you test your design and even simulate how it could
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152488Z"^^xsd:dateTime .

oakcurric:misconception-inclusive-design-benefits-users-disability
  a curric:Misconception ;
  curric:statement "Inclusive design only benefits users with a disability."@en ;
  curric:correction """Inclusive design benefits all users, not just those with disabilities. It
  aims to create products that as many users as possible can use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152525Z"^^xsd:dateTime .

oakcurric:misconception-product-analysis-leads-copying-designs
  a curric:Misconception ;
  curric:statement "Product analysis leads to copying of designs."@en ;
  curric:correction """Product analysis identifies successful features and those which can be
  improved, this can lead to inspiration for new or improved ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152843Z"^^xsd:dateTime .

oakcurric:misconception-iterations-needed-system-doesnt-work
  a curric:Misconception ;
  curric:statement "Iterations are only needed when a system doesn't work."@en ;
  curric:correction "Systems are iterated to modify, fix, develop and improve."@en ;
  dcterms:modified "2026-06-07T15:30:15.157362Z"^^xsd:dateTime .

oakcurric:misconception-designing-electonics-involve-physical-components
  a curric:Misconception ;
  curric:statement """Designing with electonics must always involve physical components and
  circuits."""@en ;
  curric:correction """Designing with electronics can use physical components, schematics and CAD to
  test and iterate ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158295Z"^^xsd:dateTime .

oakcurric:misconception-external-components-used-microcontrollers-create
  a curric:Misconception ;
  curric:statement """External components must be used with microcontrollers to create control
  systems."""@en ;
  curric:correction """Microcontrollers have on board inputs and ouputs and connection points for
  additional external components."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158579Z"^^xsd:dateTime .

oakcurric:misconception-fabrics-joined-stitching
  a curric:Misconception ;
  curric:statement "Fabrics are always joined by stitching."@en ;
  curric:correction "Fabrics can be joined using stitching, adhesives and mechanical fixings."@en ;
  dcterms:modified "2026-06-07T15:30:15.158914Z"^^xsd:dateTime .

oakcurric:misconception-light-dependant-resistor-ldr-senses
  a curric:Misconception ;
  curric:statement "A light dependant resistor (LDR) only senses light levels."@en ;
  curric:correction """An LDR's resistance changes depending on the amount of light it is exposed
  to. As the light level increases, the resistance decreases. This change in resistance can
  create a voltage change, which can be used as a signal to control an output."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159343Z"^^xsd:dateTime .

oakcurric:misconception-evaluating-one-persons-opinion
  a curric:Misconception ;
  curric:statement "Evaluating is one person's opinion."@en ;
  curric:correction """Evaluating is most effective if it involves more than one person's opinion
  and data gathered from testing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160521Z"^^xsd:dateTime .
