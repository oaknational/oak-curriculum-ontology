# ----------------------------------------------------------------------
# Content Descriptors
# ----------------------------------------------------------------------

natcurric:contentdescriptor-design-purposeful-functional-appealing-products
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Design purposeful, functional, appealing products for themselves and other 
  users based on design criteria."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-design-purposeful-functional-appealing-products ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-generate-model-communicate-ideas-talking
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Generate, develop, model and communicate their ideas through talking, drawing,
  templates, mock-ups and, where appropriate, information and communication technology."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-generate-model-communicate-ideas-talking ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-select-range-tools-equipment-perform
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Select from and use a range of tools and equipment to perform practical tasks
  [for example, cutting, shaping, joining and finishing]."""@en ;
  skos:broader natcurric:substrand-make ;
  skos:narrower natcurric:subcontentdescriptor-select-range-tools-equipment-perform ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-select-wide-range-materials-components
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Select from and use a wide range of materials and components, including
  construction materials, textiles and ingredients, according to their characteristics."""@en ;
  skos:broader natcurric:substrand-make ;
  skos:narrower natcurric:subcontentdescriptor-select-wide-range-materials-components ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-evaluate-range-existing-products
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Explore and evaluate a range of existing products."@en ;
  skos:broader natcurric:substrand-evaluate ;
  skos:narrower natcurric:subcontentdescriptor-evaluate-range-existing-products ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-evaluate-ideas-products-design-criteria
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Evaluate their ideas and products against design criteria."@en ;
  skos:broader natcurric:substrand-evaluate ;
  skos:narrower natcurric:subcontentdescriptor-evaluate-ideas-products-design-criteria ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-build-structures-made-stronger-stiffer
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Build structures, exploring how they can be made stronger, stiffer and more
  stable."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-build-structures-made-stronger-stiffer ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-mechanisms-example-levers-sliders-wheels
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Explore and use mechanisms [for example, levers, sliders, wheels and axles], in
  their products."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-mechanisms-example-levers-sliders-wheels ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-basic-principles-healthy-varied-diet
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use the basic principles of a healthy and varied diet to prepare dishes."@en ;
  skos:broader natcurric:substrand-food-and-nutrition ;
  skos:narrower natcurric:subcontentdescriptor-basic-principles-healthy-varied-diet ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-understand-where-food-comes-from
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Understand where food comes from."@en ;
  skos:broader natcurric:substrand-food-and-nutrition ;
  skos:narrower natcurric:subcontentdescriptor-understand-where-food-comes-from ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-research-design-criteria-inform-design
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use research and develop design criteria to inform the design of innovative,
  functional, appealing products that are fit for purpose, aimed at particular individuals
  or groups."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-research-design-criteria-inform-design ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-generate-model-communicate-ideas-discussion
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Generate, develop, model and communicate their ideas through discussion,
  annotated sketches, cross-sectional and exploded diagrams, prototypes, pattern pieces and
  computer-aided design."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-generate-model-communicate-ideas-discussion ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-select-wider-range-tools-equipment
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Select from and use a wider range of tools and equipment to perform practical
  tasks [for example, cutting, shaping, joining and finishing], accurately."""@en ;
  skos:broader natcurric:substrand-make ;
  skos:narrower natcurric:subcontentdescriptor-select-wider-range-tools-equipment ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-select-wider-range-materials-components
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Select from and use a wider range of materials and components, including
  construction materials, textiles and ingredients, according to their functional properties
  and aesthetic qualities."""@en ;
  skos:broader natcurric:substrand-make ;
  skos:narrower natcurric:subcontentdescriptor-select-wider-range-materials-components ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-investigate-analyse-range-existing-products
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Investigate and analyse a range of existing products."@en ;
  skos:broader natcurric:substrand-evaluate ;
  skos:narrower natcurric:subcontentdescriptor-investigate-analyse-range-existing-products ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-evaluate-ideas-products-own-design
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Evaluate their ideas and products against their own design criteria and 
  consider the views of others to improve their work."""@en ;
  skos:broader natcurric:substrand-evaluate ;
  skos:narrower natcurric:subcontentdescriptor-evaluate-ideas-products-own-design ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-key-events-individuals-design-technology
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand how key events and individuals in design and technology have helped
  shape the world."""@en ;
  skos:broader natcurric:substrand-evaluate ;
  skos:narrower natcurric:subcontentdescriptor-key-events-individuals-design-technology ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-apply-strengthen-stiffen-reinforce-complex
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Apply their understanding of how to strengthen, stiffen and reinforce more
  complex structures."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-apply-strengthen-stiffen-reinforce-complex ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-mechanical-systems-products-example-gears
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand and use mechanical systems in their products [for example, gears,
  pulleys, cams, levers and linkages]."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-mechanical-systems-products-example-gears ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-electrical-systems-products-example-series
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand and use electrical systems in their products [for example, series
  circuits incorporating switches, bulbs, buzzers and motors]."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-electrical-systems-products-example-series ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-apply-computing-program-monitor-control
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Apply their understanding of computing to program, monitor and control their
  products."""@en ;
  skos:broader natcurric:substrand-technical-knowledge ;
  skos:narrower natcurric:subcontentdescriptor-apply-computing-program-monitor-control ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-apply-principles-healthy-varied-diet
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Understand and apply the principles of a healthy and varied diet."@en ;
  skos:broader natcurric:substrand-food-and-nutrition ;
  skos:narrower natcurric:subcontentdescriptor-apply-principles-healthy-varied-diet ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-prepare-cook-variety-savoury-dishes
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Prepare and cook a variety of predominantly savoury dishes using a range of
  cooking techniques."""@en ;
  skos:broader natcurric:substrand-food-and-nutrition ;
  skos:narrower natcurric:subcontentdescriptor-prepare-cook-variety-savoury-dishes ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-seasonality-variety-ingredients-grown-reared
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand seasonality, and know where and how a variety of ingredients are
  grown, reared, caught and processed."""@en ;
  skos:broader natcurric:substrand-food-and-nutrition ;
  skos:narrower natcurric:subcontentdescriptor-seasonality-variety-ingredients-grown-reared ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-research-exploration-such-study-different
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use research and exploration, such as the study of different cultures, to
  identify and understand user needs."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-research-exploration-such-study-different ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-identify-solve-own-design-problems
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Identify and solve their own design problems and understand how to reformulate
  problems given to them."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-identify-solve-own-design-problems ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-specifications-inform-design-innovative-functional
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Develop specifications to inform the design of innovative, functional, 
  appealing products that respond to needs in a variety of situations."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-specifications-inform-design-innovative-functional ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-variety-approaches-example-biomimicry-user
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use a variety of approaches [for example, biomimicry and user-centred design],
  to generate creative ideas and avoid stereotypical responses."""@en ;
  skos:broader natcurric:substrand-design ;
  skos:narrower natcurric:subcontentdescriptor-variety-approaches-example-biomimicry-user ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-05T14:20:00Z"^^xsd:dateTime .

natcurric:contentdescriptor-communicate-design-ideas-annotated-sketches
  a skos:Concept, curric:ContentDescriptor ;
