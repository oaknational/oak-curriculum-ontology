# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-27742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Previous knowledge of 3D shape design in Tinkercad can be applied to create
  additional features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27742-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Tinkercad shapes library has a range of prepared shapes that can be added to our
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27742-3
  a curric:KeyLearningPoint ;
  rdfs:label """If too many shapes are added from the library it can reduce the performance of the
  workspace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27738-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Tinkercad, the workplanes are the design area and can be rotated using the
  Viewcube."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27738-2
  a curric:KeyLearningPoint ;
  rdfs:label "3D shapes can be moved in different views in Tinkercad."@en ;
  dcterms:modified "2026-06-07T15:30:29.270958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27738-3
  a curric:KeyLearningPoint ;
  rdfs:label "3D shapes can be combined and altered in Tinkercad."@en ;
  dcterms:modified "2026-06-07T15:30:29.270963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27738-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tinkercad can be navigated using a mouse, trackpad or touch screen"@en ;
  dcterms:modified "2026-06-07T15:30:29.270967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27749-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sawing techniques need to be conducted safely."@en ;
  dcterms:modified "2026-06-07T15:30:29.274378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Card triangles can be added to strengthen corner joints."@en ;
  dcterms:modified "2026-06-07T15:30:29.274382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27749-3
  a curric:KeyLearningPoint ;
  rdfs:label "Measuring accurately is essential to creating an effective product."@en ;
  dcterms:modified "2026-06-07T15:30:29.274386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27753-1
  a curric:KeyLearningPoint ;
  rdfs:label "Museum galleries are designed purposefully."@en ;
  dcterms:modified "2026-06-07T15:30:29.274462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Museum gallery layouts consider users and artefacts."@en ;
  dcterms:modified "2026-06-07T15:30:29.274466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27753-3
  a curric:KeyLearningPoint ;
  rdfs:label "Choice of materials have to be considered for their purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.274477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27753-4
  a curric:KeyLearningPoint ;
  rdfs:label "Choice of joining materials have to be considered for their purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.274483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27736-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes can be improved through user feedback."@en ;
  dcterms:modified "2026-06-07T15:30:29.280621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27736-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes can include additional features."@en ;
  dcterms:modified "2026-06-07T15:30:29.280625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27736-3
  a curric:KeyLearningPoint ;
  rdfs:label "Additional features can be added to prototypes using mixed materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.280631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27707-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hook and loop is a system that attaches two fabrics together."@en ;
  dcterms:modified "2026-06-07T15:30:29.285875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27707-2
  a curric:KeyLearningPoint ;
  rdfs:label """Buttons are fasteners that join two pieces of fabric together by sliding through a
  buttonhole."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27707-3
  a curric:KeyLearningPoint ;
  rdfs:label """A zip fastener is a series of interlocking teeth that are brought together and
  pulled apart by a slider."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27728-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data logger prototypes need to be tested and improved before being used in a traffic
  survey."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27728-2
  a curric:KeyLearningPoint ;
  rdfs:label "Traffic survey data can produce patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.285890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding environmental impact of the data can lead to design solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.285894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27697-1
  a curric:KeyLearningPoint ;
  rdfs:label """Critiquing a range of existing products provides valuable insights for future
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27697-2
  a curric:KeyLearningPoint ;
  rdfs:label """Personal taste in design is shaped by expressing likes and dislikes of existing
  products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27697-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ways to make packaging as sustainable as possible: reduce, reuse, and recycle."@en ;
  dcterms:modified "2026-06-07T15:30:29.287264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27709-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fabric patterns are paper shapes that are used to cut fabric for textile
  products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A seam is where two pieces of fabric are sewn together."@en ;
  dcterms:modified "2026-06-07T15:30:29.287272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27709-3
  a curric:KeyLearningPoint ;
  rdfs:label """Seam allowance is the extra fabric between the stitching and the edge, allowing for
  sewing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27792-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practice seams can be sewn on scrap fabric."@en ;
  dcterms:modified "2026-06-07T15:30:29.288553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27792-2
  a curric:KeyLearningPoint ;
  rdfs:label "Seams need to have allowance which is extra fabric, usually 15mm."@en ;
  dcterms:modified "2026-06-07T15:30:29.288557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27792-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practice curved edge seams can be sewn on scrap fabric."@en ;
  dcterms:modified "2026-06-07T15:30:29.288561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27792-4
  a curric:KeyLearningPoint ;
  rdfs:label "To sew curved edges, the template needs to be attached accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.288564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27766-1
  a curric:KeyLearningPoint ;
  rdfs:label "Orthographic projections show side, front and top views."@en ;
  dcterms:modified "2026-06-07T15:30:29.289160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27766-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tinkercad shows orthographic projections."@en ;
  dcterms:modified "2026-06-07T15:30:29.289164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27766-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tinkercad orthographic view can show designs to scale from the front, back, top,
  bottom and side views."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27766-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tinkercad can turn 3D designs into orthographic projections."@en ;
  dcterms:modified "2026-06-07T15:30:29.289171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27767-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ole Kirk Kristiansen started making wooden toys which became LEGO bricks."@en ;
  dcterms:modified "2026-06-07T15:30:29.291403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27767-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plastics are known as polymers."@en ;
  dcterms:modified "2026-06-07T15:30:29.291406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27767-3
  a curric:KeyLearningPoint ;
  rdfs:label "The term polymer is more scientifically accurate when talking about materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.291410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27767-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers can be reformed using injection moulding to create products."@en ;
  dcterms:modified "2026-06-07T15:30:29.291414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27750-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sawing accurately will allow measurements to be accurate."@en ;
  dcterms:modified "2026-06-07T15:30:29.291539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27750-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joining with a selection of techniques will strengthen the box frame."@en ;
  dcterms:modified "2026-06-07T15:30:29.291543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27750-3
  a curric:KeyLearningPoint ;
  rdfs:label "Card side panels can add strength to a box frame."@en ;
  dcterms:modified "2026-06-07T15:30:29.291547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27734-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes can be created from cheaper fabric pattern pieces."@en ;
  dcterms:modified "2026-06-07T15:30:29.291553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27734-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes can be tested for size with client."@en ;
  dcterms:modified "2026-06-07T15:30:29.291558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27734-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prototypes can be adjusted after fitting."@en ;
  dcterms:modified "2026-06-07T15:30:29.291565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27737-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dr Ken Yeang is known for being an eco-architect"@en ;
  dcterms:modified "2026-06-07T15:30:29.292896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27737-2
  a curric:KeyLearningPoint ;
  rdfs:label "Eco-buildings can include nature in their design."@en ;
  dcterms:modified "2026-06-07T15:30:29.292900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27737-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eco-buildings don’t waste materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.292906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27737-4
  a curric:KeyLearningPoint ;
  rdfs:label "Eco-buildings use space wisely and have little impact on the environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.292910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27737-5
  a curric:KeyLearningPoint ;
  rdfs:label "Eco-buildings use natural energy and water carefully."@en ;
