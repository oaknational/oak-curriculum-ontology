  dcterms:modified "2026-06-07T15:30:02.412459Z"^^xsd:dateTime .

oakcurric:keyword-innovate
  a curric:Keyword ;
  schema:name "innovate"@en ;
  schema:description "come up with new or better ideas"@en ;
  dcterms:modified "2026-06-07T15:30:02.412464Z"^^xsd:dateTime .

oakcurric:keyword-utility
  a curric:Keyword ;
  schema:name "utility"@en ;
  schema:description "useful and functional"@en ;
  dcterms:modified "2026-06-07T15:30:02.413176Z"^^xsd:dateTime .

oakcurric:keyword-specifications
  a curric:Keyword ;
  schema:name "specifications"@en ;
  schema:description "a list of things a product must have or do"@en ;
  dcterms:modified "2026-06-07T15:30:02.413181Z"^^xsd:dateTime .

oakcurric:keyword-great-exhibition
  a curric:Keyword ;
  schema:name "Great Exhibition"@en ;
  schema:description "the first international exhibition held in London in 1851"@en ;
  dcterms:modified "2026-06-07T15:30:02.420345Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-shapes-tinkercad-created-scratch
  a curric:Misconception ;
  curric:statement "Shapes in Tinkercad can only be created from scratch."@en ;
  curric:correction """The shape library has a range of prepared objects that can be added to a
  workplane."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091988Z"^^xsd:dateTime .

oakcurric:misconception-tinkercad-paid-software-cost-schools
  a curric:Misconception ;
  curric:statement """Tinkercad is a paid-for software that will cost schools money and is unsafe to
  use."""@en ;
  curric:correction """Tinkercad is free to use and schools can set up their own classrooms for
  pupils to work safely in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092250Z"^^xsd:dateTime .

oakcurric:misconception-force-pressure-needed-saw-wood
  a curric:Misconception ;
  curric:statement "Force and pressure are needed to saw through wood."@en ;
  curric:correction """Correct technique and posture allows the blade to work efficiently without
  force."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093505Z"^^xsd:dateTime .

oakcurric:misconception-museum-galleries-organised-order-artefacts
  a curric:Misconception ;
  curric:statement """Museum galleries are not organised in any order. Artefacts are displayed
  randomly."""@en ;
  curric:correction """Museum galleries are carefully designed and include thought about access and
  display of artefacts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093560Z"^^xsd:dateTime .

oakcurric:misconception-additional-features-need-finished-functional
  a curric:Misconception ;
  curric:statement "Additional features need to be finished and functional."@en ;
  curric:correction """Additional features on prototypes can be shown using mock-ups made from mixed
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095526Z"^^xsd:dateTime .

oakcurric:misconception-fasteners-perform-same-way
  a curric:Misconception ;
  curric:statement "All fasteners perform in the same way."@en ;
  curric:correction """There are positives and negatives with each type of fastener. The use of each
  depends on the product and user."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097156Z"^^xsd:dateTime .

oakcurric:misconception-traffic-surveys-collecting-data
  a curric:Misconception ;
  curric:statement "Traffic surveys are only about collecting data."@en ;
  curric:correction """Data collected from the data loggers can be used to understand what is
  happening in an environment and make suggestions for improvements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097162Z"^^xsd:dateTime .

oakcurric:misconception-critiquing-negative-criticising
  a curric:Misconception ;
  curric:statement "Critiquing is negative and criticising."@en ;
  curric:correction """Critiquing involves looking at the positive and negative aspects of a
  product."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097597Z"^^xsd:dateTime .

oakcurric:misconception-fabric-patterns-same-size-product
  a curric:Misconception ;
  curric:statement "Fabric patterns are the same size as the product dimensions."@en ;
  curric:correction """A seam allowance must be added to allow for joining; retaining the product
  dimesions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097605Z"^^xsd:dateTime .

oakcurric:misconception-curved-seams-require-different-stitches
  a curric:Misconception ;
  curric:statement "Curved seams require different stitches to straight seams."@en ;
  curric:correction """The same stitches can be used on a curved edge as those used on a straight
  seam."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098020Z"^^xsd:dateTime .

oakcurric:misconception-orthographic-projections-plan-view
  a curric:Misconception ;
  curric:statement "Orthographic projections are just a plan view."@en ;
  curric:correction """Orthographic projections have a plan or top view, side view and front view
  and are used for architects to show the different elevations of a building."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098356Z"^^xsd:dateTime .

oakcurric:misconception-polymers-plastics-solid-state
  a curric:Misconception ;
  curric:statement "Polymers (plastics) are always in a solid state."@en ;
  curric:correction """Polymers (plastics) can be heated to a liquid state, as in the process of
  injection moulding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098912Z"^^xsd:dateTime .

oakcurric:misconception-common-mistake-inaccurate-measuring-means
  a curric:Misconception ;
  curric:statement """A common mistake is inaccurate measuring which means the box frame will not be
  square."""@en ;
  curric:correction """It is important to measure accurately to make sure the box frame is
  square."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098947Z"^^xsd:dateTime .

oakcurric:misconception-prototypes-finished-pieces-cant-adjusted
  a curric:Misconception ;
  curric:statement "Prototypes are finished pieces that can't be adjusted."@en ;
  curric:correction "Prototypes can be taken apart and adjusted."@en ;
  dcterms:modified "2026-06-07T15:30:15.098956Z"^^xsd:dateTime .

oakcurric:misconception-sustainable-buildings-buildings-new
  a curric:Misconception ;
  curric:statement "Sustainable buildings have to be buildings that are new."@en ;
  curric:correction """Sustainable buildings can reuse materials from old buildings or be older
  buildings that have been redesigned."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099423Z"^^xsd:dateTime .

oakcurric:misconception-shape-moved-its-own-once
  a curric:Misconception ;
  curric:statement """Every shape must be moved on its own once on the workplane, so it is better to
  not make changes."""@en ;
  curric:correction """By grouping shapes that designers are happy with together, it makes it easier
  to move, rotate or scale them and make changes to the design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101044Z"^^xsd:dateTime .

oakcurric:misconception-designs-drawn-paper-manufactured
  a curric:Misconception ;
  curric:statement "Designs are drawn on paper and then manufactured."@en ;
  curric:correction """Computer Aided Design helps designers accurately draw their ideas before
  manufacturing them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101062Z"^^xsd:dateTime .

oakcurric:misconception-mirror-same-rotate
  a curric:Misconception ;
  curric:statement "Mirror is the same as rotate."@en ;
  curric:correction """Rotating complex or compound shapes will not always have the same outcome as
  when mirroring a shape."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101491Z"^^xsd:dateTime .

oakcurric:misconception-exploded-diagrams-perspective-view
  a curric:Misconception ;
  curric:statement "Exploded diagrams have to be in perspective view."@en ;
  curric:correction """Orthographic view is a better viewpoint for seeing the exploded parts of the
  eco-house."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101682Z"^^xsd:dateTime .

oakcurric:misconception-design-critique-design-evaluation-same
  a curric:Misconception ;
  curric:statement "Design critique and design evaluation are the same."@en ;
  curric:correction """Design critique evaluates a product to improve it, a design evaluation
  evaluates an end product against criteria."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101766Z"^^xsd:dateTime .

oakcurric:misconception-pulleys-work-amount-tension
  a curric:Misconception ;
  curric:statement "Pulleys work under any amount of tension."@en ;
  curric:correction """Pulleys will not work if the band is too tight (struggles to rotate) or too
  loose (falls off)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102628Z"^^xsd:dateTime .

oakcurric:misconception-air-directed-one-place-output
  a curric:Misconception ;
  curric:statement "Air can only be directed to one place (output)."@en ;
  curric:correction """One input can affect multiple outputs by splitting the flow or direction of
  the air."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103490Z"^^xsd:dateTime .

oakcurric:misconception-battery-packs-attached-micro-bits
  a curric:Misconception ;
  curric:statement "Only battery packs can be attached to micro:bits."@en ;
  curric:correction "A variety of inputs and outputs can be attached to a micro:bit."@en ;
  dcterms:modified "2026-06-07T15:30:15.103938Z"^^xsd:dateTime .

oakcurric:misconception-packaging-constructed-lots-separate-pieces
  a curric:Misconception ;
  curric:statement "Packaging is constructed from lots of separate pieces."@en ;
  curric:correction "Packaging is often one piece of material constructed as a net."@en ;
  dcterms:modified "2026-06-07T15:30:15.103943Z"^^xsd:dateTime .

oakcurric:misconception-finished-products-cannot-changed
  a curric:Misconception ;
  curric:statement "Finished products cannot be changed."@en ;
  curric:correction "Finished products can be adapted to ensure they are fit for purpose."@en ;
  dcterms:modified "2026-06-07T15:30:15.103952Z"^^xsd:dateTime .

oakcurric:misconception-cross-section-diagrams-show-vertical
  a curric:Misconception ;
  curric:statement "All cross-section diagrams show the vertical plane."@en ;
  curric:correction """Cross-sections diagrams can show the horizontal or vertical planes and these
  can provide very different views."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103957Z"^^xsd:dateTime .

oakcurric:misconception-fabrics-same-properties
  a curric:Misconception ;
  curric:statement "All fabrics have the same properties."@en ;
  curric:correction """Different fabrics have different properties which must be considered when
  selecting fabrics for designs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104732Z"^^xsd:dateTime .

oakcurric:misconception-doesnt-matter-place-pivots-lazy
  a curric:Misconception ;
  curric:statement "It doesn't matter where you place the pivots on a lazy-tong linkage."@en ;
  curric:correction """Where the pivots are placed is very important on a lazy-tong linkage. If they
  are not placed correctly, the mechanism will not function correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104738Z"^^xsd:dateTime .

oakcurric:misconception-pocket-designs-attached-same-way
  a curric:Misconception ;
  curric:statement "All pocket designs will be attached in the same way."@en ;
  curric:correction """Different techniques, such as of loops and slots, should be chosen to suit
  the pocket type."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105524Z"^^xsd:dateTime .

oakcurric:misconception-pupils-place-pattern-pieces-centre
  a curric:Misconception ;
  curric:statement "Pupils often place pattern pieces in the centre of a piece of fabric."@en ;
  curric:correction """Pattern pieces should be placed close to the edge and arranged so that they
  limit wastage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105538Z"^^xsd:dateTime .

oakcurric:misconception-sensors-micro-bit-work-automatically
  a curric:Misconception ;
  curric:statement "Sensors on a micro:bit work automatically."@en ;
  curric:correction "Micro:bits need a program to control the sensors."@en ;
  dcterms:modified "2026-06-07T15:30:15.106248Z"^^xsd:dateTime .

oakcurric:misconception-pneumatic-systems-fit-neatly-product
  a curric:Misconception ;
  curric:statement "Pneumatic systems will fit neatly into a product."@en ;
  curric:correction """Systems and products will need to be adapted to ensure correct position and
  fit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106256Z"^^xsd:dateTime .

oakcurric:misconception-packaging-same
  a curric:Misconception ;
  curric:statement "Packaging has always been the same."@en ;
  curric:correction """Packaging has developed over time. The rise in plastic use has seen plastic
  replacing glass, increased use of recycled paper/card, less use of wooden crates used in
  the past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110191Z"^^xsd:dateTime .

oakcurric:misconception-cams-create-same-movement
  a curric:Misconception ;
  curric:statement "All cams create the same movement."@en ;
  curric:correction """The size, shape and position of a cam will create different types of
  movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110211Z"^^xsd:dateTime .

oakcurric:misconception-position-axle-holes-axles-doesnt
  a curric:Misconception ;
  curric:statement """The position of axle holes and axles doesn't need to be accurately
  measured."""@en ;
  curric:correction """Axle holes and axles need to be positioned accurately on order for the wheels
  and pulleys to rotate correctly and produce the correct movement. Accurate measuring is
  essential."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110959Z"^^xsd:dateTime .

oakcurric:misconception-products-made-use-around-water
  a curric:Misconception ;
  curric:statement "All products made for use in or around water need to be waterproof."@en ;
  curric:correction """Clothing used for swimming ie, trunks, costumes, shorts and wetsuits, are not
  waterproof."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112060Z"^^xsd:dateTime .

oakcurric:misconception-fabric-fasteners-chosen-aesthetic-qualities
  a curric:Misconception ;
  curric:statement "Fabric and fasteners are chosen for aesthetic qualities alone."@en ;
  curric:correction """Fabric and fasteners need to be selected carefully for their function and
  application."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113034Z"^^xsd:dateTime .

oakcurric:misconception-connected-circuits-work
  a curric:Misconception ;
  curric:statement "Connected circuits will always work."@en ;
  curric:correction """Circuits need to be checked that the connections are accurate and the
  components all work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113040Z"^^xsd:dateTime .

oakcurric:misconception-sewing-used-join-fabric-pieces
  a curric:Misconception ;
  curric:statement "Sewing is only used to join fabric pieces."@en ;
  curric:correction """Sewing can be used to finish raw (cut) edges or add decorative detail to
  single layer fabric pieces."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114236Z"^^xsd:dateTime .

oakcurric:misconception-drilled-pierced-holes-size
  a curric:Misconception ;
  curric:statement "Drilled and pierced holes can be any size."@en ;
  curric:correction """Cam discs need to be tightly fitted to the axle so that they rotate with it.
  Holes for the axle and followers need to be loose to allow free movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114831Z"^^xsd:dateTime .

oakcurric:misconception-cutting-shaping-same
  a curric:Misconception ;
  curric:statement "Cutting and shaping are not the same."@en ;
  curric:correction "Cutting can be a form of shaping."@en ;
  dcterms:modified "2026-06-07T15:30:15.114842Z"^^xsd:dateTime .

oakcurric:misconception-finishing-techniques-decorative-purposes
  a curric:Misconception ;
  curric:statement "Finishing techniques are just for decorative purposes."@en ;
  curric:correction "Finishing techniques can be used to disguise working components."@en ;
  dcterms:modified "2026-06-07T15:30:15.116378Z"^^xsd:dateTime .

oakcurric:misconception-fasteners-accessible-everyone
  a curric:Misconception ;
  curric:statement "All fasteners are accessible to everyone."@en ;
  curric:correction """The user needs should be considered when choosing fasteners so they are
  accesible to the individual."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117478Z"^^xsd:dateTime .

oakcurric:misconception-simple-eletrical-systems-dangerous
  a curric:Misconception ;
  curric:statement "Simple eletrical systems are not dangerous."@en ;
  curric:correction """All exposed electrical wires need to be covered to prevent injury or
  fire."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117947Z"^^xsd:dateTime .

oakcurric:misconception-crocodile-clips-used-connect-components
  a curric:Misconception ;
  curric:statement "Crocodile clips have to be used to connect the components together."@en ;
  curric:correction """Whilst crocodile clips can be used effectively, electrical wire from
  educational stockists can be used as a cheaper alternitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117953Z"^^xsd:dateTime .

oakcurric:misconception-circuits-classroom-safe-use
  a curric:Misconception ;
  curric:statement "Circuits in the classroom are always safe to use."@en ;
  curric:correction """Electricity is dangerous and needs to be carefully worked with. It can't
  always be seen and hazards need to be identified."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119201Z"^^xsd:dateTime .

oakcurric:misconception-cases-boxes-data-logger-fit
  a curric:Misconception ;
  curric:statement "Cases are just boxes for a data logger to fit into."@en ;
  curric:correction """Cases need to display the micro:bit, some of the components and fit the
  battery packs"""@en ;
  dcterms:modified "2026-06-07T15:30:15.119954Z"^^xsd:dateTime .

oakcurric:misconception-one-type-switch
  a curric:Misconception ;
  curric:statement "There is only one type of switch."@en ;
  curric:correction """Switches break the electrical flow of a circuit but they can be activated in
  different ways - they can be pushed, slid, twisted or pulled."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119966Z"^^xsd:dateTime .

oakcurric:misconception-shape-vehicle-effect-its-speed
  a curric:Misconception ;
  curric:statement "The shape of a vehicle has no effect on its speed."@en ;
  curric:correction """Vehicle shape is considered in order to reduce air resistance (less
  drag)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123350Z"^^xsd:dateTime .

oakcurric:misconception-packaging-reinforced-inside
  a curric:Misconception ;
  curric:statement "Packaging can only be reinforced from the inside."@en ;
  curric:correction """Packaging can be reinforced on the inside and/or the outside using different
  methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123379Z"^^xsd:dateTime .

oakcurric:misconception-clothing-alway-made-scratch-using
  a curric:Misconception ;
  curric:statement "Clothing is alway made from scratch using pattern pieces."@en ;
  curric:correction "Existing clothing can be upcycled to make new items of clothing."@en ;
  dcterms:modified "2026-06-07T15:30:15.124090Z"^^xsd:dateTime .

oakcurric:misconception-levers-used-make-things-move
  a curric:Misconception ;
  curric:statement "Levers are always used to make things move easier."@en ;
  curric:correction """Some levers are designed to to move things faster or further, a pair of
  tweezers for example."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124095Z"^^xsd:dateTime .

oakcurric:misconception-fabric-decorative-techniques-involve-stitching
  a curric:Misconception ;
  curric:statement "All fabric decorative techniques involve stitching."@en ;
  curric:correction """Fabrics can be decorated using other techniques such as appliqué, fabric pens
  and paints."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125212Z"^^xsd:dateTime .

oakcurric:misconception-seam-allowance-included-sizing-measurements
  a curric:Misconception ;
  curric:statement "A seam allowance is included in the sizing measurements."@en ;
  curric:correction "A seam allowance needs to be added to the sizing measurements."@en ;
  dcterms:modified "2026-06-07T15:30:15.125218Z"^^xsd:dateTime .

oakcurric:misconception-stitching-size-doesnt-affect-product
  a curric:Misconception ;
  curric:statement "Stitching size doesn't affect product outcome."@en ;
  curric:correction """Large, uneven stitches will create gaps which will make the final product
  less effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125245Z"^^xsd:dateTime .

oakcurric:misconception-prototype-doesnt-need-joined-accurately
  a curric:Misconception ;
  curric:statement "A prototype doesn't need to be joined accurately."@en ;
  curric:correction """Prototypes provide a good opportunity to test accurate joining
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128567Z"^^xsd:dateTime .

oakcurric:misconception-switches-pressed-work
  a curric:Misconception ;
  curric:statement "All switches have to be pressed to work."@en ;
  curric:correction """Switches control the flow of electricity in a circuit and can be pushed,
  slid, twisted or pulled."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128618Z"^^xsd:dateTime .

oakcurric:misconception-automata-create-same-linear-output
  a curric:Misconception ;
  curric:statement "All automata create the same up and down linear output."@en ;
  curric:correction """The position of the follower and the size, shape and number of cams can
  create a range of movements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128723Z"^^xsd:dateTime .

oakcurric:misconception-pneumatic-systems-cause-something-expland
  a curric:Misconception ;
  curric:statement "Pneumatic systems always cause something to expland or inflate."@en ;
  curric:correction """Pneumatic systems can cause directed movement of an object without
  inflation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133795Z"^^xsd:dateTime .

oakcurric:misconception-sewing-consists-one-type-stitch
  a curric:Misconception ;
  curric:statement """Sewing consists of one type of stitch whereby the thread is passed in and out
  of the fabric."""@en ;
  curric:correction """There are different types of stitches, which require different movements of
  the needle and thread."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134275Z"^^xsd:dateTime .

oakcurric:misconception-hats-made-same-way
  a curric:Misconception ;
  curric:statement "All hats are made the same way."@en ;
  curric:correction """Different styles of hats require different patterns. These can also be
  adjusted to change the design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134307Z"^^xsd:dateTime .

oakcurric:misconception-prototypes-finished-pieces-cannot-adapted
  a curric:Misconception ;
  curric:statement "Prototypes are finished pieces that cannot be adapted."@en ;
  curric:correction """Prototypes can help identify problems and prototypes made from card can be
  adapted easily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134950Z"^^xsd:dateTime .

oakcurric:misconception-micro-bits-work-their-own
  a curric:Misconception ;
  curric:statement "Micro:bits can work on their own by being connected in a circuit"@en ;
  curric:correction """Micro:bits have to have a program downloaded before being connected into a
  circuit"""@en ;
  dcterms:modified "2026-06-07T15:30:15.138985Z"^^xsd:dateTime .

oakcurric:misconception-design-drawings-drawn-one-angle
  a curric:Misconception ;
  curric:statement "All design drawings are drawn from one angle, usually a front view."@en ;
  curric:correction "Isometric drawings show three angles at the same time."@en ;
  dcterms:modified "2026-06-07T15:30:15.138991Z"^^xsd:dateTime .

oakcurric:misconception-push-pull-parallel-linkages-made
  a curric:Misconception ;
  curric:statement "Push-pull and parallel linkages are made of more than one lever."@en ;
  curric:correction """Levers can be joined together to form a linkage. A parallel and push-pull
  linkage is made up of multiple levers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139339Z"^^xsd:dateTime .

oakcurric:misconception-size-pulley-effect-speed-rotation
  a curric:Misconception ;
  curric:statement "The size of a pulley does not effect the speed of rotation."@en ;
  curric:correction "Smaller pulleys rotate faster than larger pulleys on the same system."@en ;
  dcterms:modified "2026-06-07T15:30:15.141053Z"^^xsd:dateTime .

oakcurric:misconception-museum-galleries-contain-paintings
  a curric:Misconception ;
  curric:statement "Museum galleries only contain paintings."@en ;
  curric:correction """Museum galleries display a range of artefacts which include paintings and
  other physical objects."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141073Z"^^xsd:dateTime .

oakcurric:misconception-design-drawings-technical-include-detail
  a curric:Misconception ;
  curric:statement "Design drawings must be technical and include detail."@en ;
  curric:correction """Simple drawings can be annotated to add the extra information and detail
  needed to understand the design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150190Z"^^xsd:dateTime .

oakcurric:misconception-open-questions-gather-users-own
  a curric:Misconception ;
  curric:statement """Open questions gather the users own personal views and may offer more ideas.
  Sometimes this leads to the user misunderstanding questions or providing answers which are
  not as expected."""@en ;
  curric:correction "All questions need to be specific and clear."@en ;
  dcterms:modified "2026-06-07T15:30:15.150247Z"^^xsd:dateTime .

oakcurric:misconception-design-drawings-neat-fully-completed
  a curric:Misconception ;
  curric:statement "Design drawings have to be neat, fully completed and accurate."@en ;
  curric:correction """Rapid sketches allows lots of ideas in a short space of time that can be
  developed later."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150253Z"^^xsd:dateTime .

oakcurric:misconception-tally-charts-completed-paper
  a curric:Misconception ;
  curric:statement "Tally charts can only be completed on paper."@en ;
  curric:correction "Data loggers can record tally charts electronically."@en ;
  dcterms:modified "2026-06-07T15:30:15.150285Z"^^xsd:dateTime .

oakcurric:misconception-micro-bits-computers
  a curric:Misconception ;
  curric:statement "Micro:bits are not computers."@en ;
  curric:correction "Micro:bits are small computers that have many different functions."@en ;
  dcterms:modified "2026-06-07T15:30:15.150393Z"^^xsd:dateTime .

oakcurric:misconception-evaluating-design-uses-user-feedback
  a curric:Misconception ;
  curric:statement "Evaluating a design uses only the user feedback."@en ;
  curric:correction """Evaluations should be reflective and allow the designer to consider their
  thoughts as well as the user's."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150509Z"^^xsd:dateTime .

oakcurric:misconception-circuits-multiple-pathways-like-underground
  a curric:Misconception ;
  curric:statement "All circuits have multiple pathways (like the underground map)."@en ;
  curric:correction """A series circuit is a continuous loop where all the components are connected
  one after another along the same path."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150514Z"^^xsd:dateTime .

oakcurric:misconception-action-plans-cannot-changed
  a curric:Misconception ;
  curric:statement "Action plans cannot be changed."@en ;
  curric:correction "Action plans can be changed and adapted throughout the project."@en ;
  dcterms:modified "2026-06-07T15:30:15.150599Z"^^xsd:dateTime .

oakcurric:misconception-bridge-tight-mechanism-reduce-movement
  a curric:Misconception ;
  curric:statement """If the bridge is too tight over the mechanism, it will reduce the
  movement."""@en ;
  curric:correction """Make sure that when you attach the bridge, there is a gap to allow the
  mechanism to freely move underneath."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150725Z"^^xsd:dateTime .

oakcurric:misconception-air-empty-because-cant-see
  a curric:Misconception ;
  curric:statement "Air is empty because we can't see it."@en ;
  curric:correction """Air takes up space and can make things move or change shape, such as when we
  inflate a balloon or a bike tyre."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150742Z"^^xsd:dateTime .

oakcurric:misconception-adverts-way-promote-product
  a curric:Misconception ;
  curric:statement "Adverts are the only way to promote a product."@en ;
  curric:correction """Products can be promoted through presentations, exhibitions, videos, posters
  and competitions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150757Z"^^xsd:dateTime .

oakcurric:misconception-test-simple-circuits-need-create
  a curric:Misconception ;
  curric:statement """To test simple circuits, you need to create a physical representation of the
  circuits."""@en ;
  curric:correction """Like many CAD applications, Tinkercad can simulate circuit operation within
  the circuit workspace."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150829Z"^^xsd:dateTime .

oakcurric:misconception-action-plan-list-instructions
  a curric:Misconception ;
  curric:statement "An action plan is a list of instructions."@en ;
  curric:correction """An action plan is more than a list of insructions; it provides a list of
  stages of making, sometimes in order but can also list the materials and tools needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150924Z"^^xsd:dateTime .

oakcurric:misconception-feedback-isnt-helpful
  a curric:Misconception ;
  curric:statement "Feedback isn't helpful."@en ;
  curric:correction "Feedback can be helpful if guided by questions."@en ;
  dcterms:modified "2026-06-07T15:30:15.151154Z"^^xsd:dateTime .

oakcurric:misconception-brand-logo-needs-contain-lots
  a curric:Misconception ;
  curric:statement "A brand logo needs to contain lots of information, colour and design."@en ;
  curric:correction "Simple logos are often the most effective."@en ;
  dcterms:modified "2026-06-07T15:30:15.151231Z"^^xsd:dateTime .

oakcurric:misconception-ada-lovelace-invented-first-computer
  a curric:Misconception ;
  curric:statement "Ada Lovelace invented the first computer."@en ;
  curric:correction """While Ada Lovelace wrote the first algorithm, she did not invent the first
  computer. Micro:bits demonstate the principles that Ada Lovelace worked on."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151289Z"^^xsd:dateTime .

oakcurric:misconception-designers-architects-engineers-sketch-3d
  a curric:Misconception ;
  curric:statement "All designers, architects and engineers sketch in 3D."@en ;
  curric:correction """Designers, architects and engineers often use elevations to show different 2D
  views of 3D objects from the side, front and plan."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151665Z"^^xsd:dateTime .

oakcurric:misconception-fashion-design-considers-aesthetic-qualities
  a curric:Misconception ;
  curric:statement """Fashion design only considers the aesthetic qualities of clothing and
  accessories."""@en ;
  curric:correction """Fashion designers must balance form and function when designing clothing and
  accessories."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151770Z"^^xsd:dateTime .

oakcurric:misconception-early-engineers-men
  a curric:Misconception ;
  curric:statement "All early engineers were men."@en ;
  curric:correction "Many women have contributed to the development of engineering."@en ;
  dcterms:modified "2026-06-07T15:30:15.151781Z"^^xsd:dateTime .

oakcurric:misconception-linkages-found-interactive-books
  a curric:Misconception ;
  curric:statement "All linkages can be found in interactive books."@en ;
  curric:correction """Not all linkages are suitable for use in an interactive book. Those that are
  used are chosen because they are the simplest, most functional option for the intended
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152230Z"^^xsd:dateTime .

oakcurric:misconception-hat-designs-templates-fit-users
  a curric:Misconception ;
  curric:statement "Hat designs templates will fit all users."@en ;
  curric:correction """Hats, and other items, can be tailored to fit an individual by taking
  measurements before planning a design."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152334Z"^^xsd:dateTime .

oakcurric:misconception-product-design-particulary-functional-furniture
  a curric:Misconception ;
  curric:statement """Product design, particulary functional furniture, does not the impact the
  wellbeing of society."""@en ;
  curric:correction """Design that is uplifting, inclusive and accessible can benefit society in a
  positive way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152340Z"^^xsd:dateTime .

oakcurric:misconception-impact-statements-consider-design-specifications
  a curric:Misconception ;
  curric:statement "Impact statements only consider the design specifications."@en ;
  curric:correction """Impact statements consider the outcome and the impact the product has had on
  the user."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152477Z"^^xsd:dateTime .

oakcurric:misconception-hardwoods-hard-softwoods-soft
  a curric:Misconception ;
  curric:statement "All hardwoods are hard and all softwoods are soft."@en ;
  curric:correction """Balsa is very soft and light but it is a deciduous hardwood. Yew is heavy and
  hard but it is a coniferous softwood."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152547Z"^^xsd:dateTime .

oakcurric:misconception-fabrics-chosen-aesthetic-reasons
  a curric:Misconception ;
  curric:statement "Fabrics are only chosen for aesthetic reasons."@en ;
  curric:correction "Fabric selection can be driven by function and aesthetics."@en ;
  dcterms:modified "2026-06-07T15:30:15.153188Z"^^xsd:dateTime .

oakcurric:misconception-textile-products-designed-fashion
  a curric:Misconception ;
  curric:statement "Textile products are only designed for fashion."@en ;
  curric:correction """Textile products can also serve functional and practical purposes, such as
  accessibility and user needs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153545Z"^^xsd:dateTime .

oakcurric:misconception-fashion-designers-design-clothes
  a curric:Misconception ;
  curric:statement "Fashion designers only design clothes."@en ;
  curric:correction """Fashion designers can also design accessories, such as hats. Some fashion
  designers, such as milliners, specialise in one area."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153735Z"^^xsd:dateTime .

oakcurric:misconception-exhibiting-final-products-produce-positive
  a curric:Misconception ;
  curric:statement "Exhibiting final products should always produce positive feedback."@en ;
  curric:correction """By exhibiting our designs we can find out how to improve the products
  further."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160515Z"^^xsd:dateTime .
