  a curric:Keyword ;
  schema:name "oil"@en ;
  schema:description "a liquid fat pressed from the seeds and nuts of a plant"@en ;
  dcterms:modified "2026-06-07T15:30:02.415714Z"^^xsd:dateTime .

oakcurric:keyword-spreads
  a curric:Keyword ;
  schema:name "spreads"@en ;
  schema:description "a replacement for butter made from vegetable oils"@en ;
  dcterms:modified "2026-06-07T15:30:02.415720Z"^^xsd:dateTime .

