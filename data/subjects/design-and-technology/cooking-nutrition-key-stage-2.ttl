  dcterms:modified "2026-06-07T15:30:02.398476Z"^^xsd:dateTime .

oakcurric:keyword-starter
  a curric:Keyword ;
  schema:name "starter"@en ;
  schema:description "the first course of a meal"@en ;
  dcterms:modified "2026-06-07T15:30:02.398482Z"^^xsd:dateTime .

oakcurric:keyword-wrapper
  a curric:Keyword ;
  schema:name "wrapper"@en ;
  schema:description "the outer layer of a spring roll"@en ;
  dcterms:modified "2026-06-07T15:30:02.398486Z"^^xsd:dateTime .

oakcurric:keyword-filling
  a curric:Keyword ;
  schema:name "filling"@en ;
  schema:description "the inside of a spring roll"@en ;
  dcterms:modified "2026-06-07T15:30:02.398491Z"^^xsd:dateTime .

oakcurric:keyword-herbs
  a curric:Keyword ;
  schema:name "herbs"@en ;
  schema:description "leafy green parts of plants which are used in cooking"@en ;
  dcterms:modified "2026-06-07T15:30:02.400330Z"^^xsd:dateTime .

oakcurric:keyword-aromatic
  a curric:Keyword ;
  schema:name "aromatic"@en ;
  schema:description """other fruit and vegetables that add aroma and flavour to dishes, e.g.
  garlic, fresh ginger"""@en ;
  dcterms:modified "2026-06-07T15:30:02.400335Z"^^xsd:dateTime .

oakcurric:keyword-cutlery
  a curric:Keyword ;
  schema:name "cutlery"@en ;
  schema:description "a knife, fork and spoon for eating food"@en ;
  dcterms:modified "2026-06-07T15:30:02.400543Z"^^xsd:dateTime .

oakcurric:keyword-chopsticks
  a curric:Keyword ;
  schema:name "chopsticks"@en ;
  schema:description "two thin sticks that are used to eat food, held in one hand"@en ;
  dcterms:modified "2026-06-07T15:30:02.400549Z"^^xsd:dateTime .

oakcurric:keyword-utensils
  a curric:Keyword ;
  schema:name "utensils"@en ;
  schema:description "tools used for eating and cooking"@en ;
  dcterms:modified "2026-06-07T15:30:02.400554Z"^^xsd:dateTime .

oakcurric:keyword-large-scale
  a curric:Keyword ;
  schema:name "large scale"@en ;
  schema:description "artworks that are much bigger than usual"@en ;
  dcterms:modified "2026-06-07T15:30:02.401964Z"^^xsd:dateTime .

oakcurric:keyword-frittata
  a curric:Keyword ;
  schema:name "frittata"@en ;
  schema:description "a baked egg dish, with cheese and vegetables, originally from Italy"@en ;
  dcterms:modified "2026-06-07T15:30:02.402666Z"^^xsd:dateTime .

oakcurric:keyword-whisking
  a curric:Keyword ;
  schema:name "whisking"@en ;
  schema:description "to stir rapidly, using a whisk or fork"@en ;
  dcterms:modified "2026-06-07T15:30:02.402674Z"^^xsd:dateTime .

oakcurric:keyword-firm
  a curric:Keyword ;
  schema:name "firm"@en ;
  schema:description "more solid, not liquid"@en ;
  dcterms:modified "2026-06-07T15:30:02.402680Z"^^xsd:dateTime .

oakcurric:keyword-ukraine
  a curric:Keyword ;
  schema:name "Ukraine"@en ;
  schema:description "a country in Eastern Europe"@en ;
  dcterms:modified "2026-06-07T15:30:02.403885Z"^^xsd:dateTime .

oakcurric:keyword-paska
  a curric:Keyword ;
  schema:name "paska"@en ;
  schema:description "a traditional Easter bread from the Ukraine"@en ;
  dcterms:modified "2026-06-07T15:30:02.403890Z"^^xsd:dateTime .

oakcurric:keyword-traffic-light
  a curric:Keyword ;
  schema:name "traffic light"@en ;
  schema:description """in this context, a colour coded nutrition label that shows the amounts of
  energy and nutrients, e.g. low, medium and high"""@en ;
  dcterms:modified "2026-06-07T15:30:02.409822Z"^^xsd:dateTime .

oakcurric:keyword-healthy-eating
  a curric:Keyword ;
  schema:name "healthy eating"@en ;
  schema:description "eating a balance and variety of foods to be healthy"@en ;
  dcterms:modified "2026-06-07T15:30:02.412961Z"^^xsd:dateTime .

oakcurric:keyword-inactive
  a curric:Keyword ;
  schema:name "inactive"@en ;
  schema:description "not engaging in any or much physical activity"@en ;
  dcterms:modified "2026-06-07T15:30:02.412966Z"^^xsd:dateTime .

