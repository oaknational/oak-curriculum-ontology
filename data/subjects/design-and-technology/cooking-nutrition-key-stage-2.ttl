# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-24999-1
  a curric:KeyLearningPoint ;
  rdfs:label """People in our communities have different needs, based on age, nutritional need,
  preferences, culture, faith and belief."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24999-2
  a curric:KeyLearningPoint ;
  rdfs:label """Healthy eating contributes to wellbeing. Access to affordable, healthy food promotes
  better nutrition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24999-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eating a healthy, varied diet is an important part of maintaining good health and
  reducing ill-health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24961-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food is produced all around the world, including the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.273800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24961-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different types of food grown, reared and caught around the
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24961-3
  a curric:KeyLearningPoint ;
  rdfs:label """Countries have different cuisines, based on the food available, cooking techniques,
  traditions and customs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24970-1
  a curric:KeyLearningPoint ;
  rdfs:label """When planning to cook, we should consider current healthy eating advice, the needs
  of different people, and occasion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24970-2
  a curric:KeyLearningPoint ;
  rdfs:label "Meals can be evaluated against the Eatwell Guide for improvements."@en ;
  dcterms:modified "2026-06-07T15:30:29.273815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24970-3
  a curric:KeyLearningPoint ;
  rdfs:label """A food allergy is when the body reacts badly to specific foods, from mild to
  severe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24970-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan a healthy diet (meals) over a day or more."@en ;
  dcterms:modified "2026-06-07T15:30:29.273822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes can be inspired by cuisines around the world. These pockets are inspired by
  the dish Tetelas, from Mexico."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24980-2
  a curric:KeyLearningPoint ;
  rdfs:label "Recipes can be modified to meet the needs and preferences of different people."@en ;
  dcterms:modified "2026-06-07T15:30:29.274288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24980-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spices and herbs can be added to a dish for added flavour and aroma, and enhanced
  taste and appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24980-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make pockets are measuring, grating, slicing, dicing,
  portioning, folding and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Around the world, people use a range of different ingredients, equipment and food
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24964-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to select the most suitable ingredients, equipment and food skills
  for successful results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24964-3
  a curric:KeyLearningPoint ;
  rdfs:label "Salads can include a wide range of ingredients from the UK and around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.276142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24996-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ensuring that our food is safe to eat is vital for health."@en ;
  dcterms:modified "2026-06-07T15:30:29.276180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24996-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some foods need to be washed before being eaten raw, such as fruit and vegetables,
  to remove insects, dirt and bacteria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24996-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some foods need to be prepared and cooked thoroughly to make them safe before being
  eaten, such as meat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24996-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some foods can be preserved to keep them safe to eat in the future, such as freezing
  and canning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cookies date back to 7th century Persia (now Iran), and were used by bakers to test
  the temperature of the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24968-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cookies contain fat (e.g. baking spread) and sugar, so should be eaten in small
  amounts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24968-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make raisin and banana cookies are measuring, mixing,
  mashing, dividing and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24968-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cookies need to be the same size, for even cooking. If smaller, they will burn,
  if bigger, they will be undercooked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24957-1
  a curric:KeyLearningPoint ;
  rdfs:label "A range of factors determine what people eat and drink."@en ;
  dcterms:modified "2026-06-07T15:30:29.284326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24957-2
  a curric:KeyLearningPoint ;
  rdfs:label """When planning to cook, the time of day, person and occasion need to be
  considered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24957-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some people have a reaction to specific foods, known as a food allergy."@en ;
  dcterms:modified "2026-06-07T15:30:29.284333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24957-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dishes and meals eaten around the world often comprise similar ingredients combined
  and cooked in different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24960-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some food is grown, reared or caught locally to where we live."@en ;
  dcterms:modified "2026-06-07T15:30:29.287135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24960-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some food can be grown at home."@en ;
  dcterms:modified "2026-06-07T15:30:29.287139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24960-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food is produced and processed in different ways and locations in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.287143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24966-1
  a curric:KeyLearningPoint ;
  rdfs:label """Irish soda bread originates from Ireland in the 1830s, a time of financial
  hardship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24966-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ensure that a recipe works, it is important to weigh and measure ingredients
  accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24966-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Irish soda bread are measuring, mixing, shaping,
  scoring and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24966-4
  a curric:KeyLearningPoint ;
  rdfs:label """The bread rises due to bicarbonate of soda being added. During cooking, it produces
  gas bubbles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hands should be thoroughly washed to prevent dirt or bacteria contaminating our
  food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24979-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scones are thought to have originated from Scotland in the early 1500s. There are
  many variations around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24979-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make fruit scone wedges are measuring, rubbing-in, mixing,
  shaping, scoring and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24979-3
  a curric:KeyLearningPoint ;
  rdfs:label """Baked recipes can be adapted to use different types of flour, include other
  ingredients and be shaped differently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24979-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heat from the oven will take longer to penetrate and cook the scone/wedge the larger
  it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different community groups have specific food and dishes for special occasions and
  celebrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25000-2
  a curric:KeyLearningPoint ;
  rdfs:label """A dish or meal can be planned and made for the needs of specific community
  groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25000-3
  a curric:KeyLearningPoint ;
  rdfs:label """To feed groups of people, some dishes are more suitable as they can be cooked and
  kept in larger quantities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25000-4
  a curric:KeyLearningPoint ;
  rdfs:label "The act of being and eating together is important socially."@en ;
  dcterms:modified "2026-06-07T15:30:29.293741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24988-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eating habits, traditions, customs, religion, history, and location influence the
  food that is eaten globally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24988-2
  a curric:KeyLearningPoint ;
  rdfs:label """Depending on where you live, the food commonly eaten, as well as served at
  celebrations, is different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24988-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food dishes with significant meaning are often served at special celebrations."@en ;
  dcterms:modified "2026-06-07T15:30:29.294418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24988-4
  a curric:KeyLearningPoint ;
  rdfs:label """Meals and dishes can be planned and prepared to meet the needs of different
  traditions and celebrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24986-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bruschetta can be traced back to ancient Rome. It is grilled bread with toppings,
  such as olive oil, tomato and cheese."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24986-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ingredients for a recipe have been produced and processed so that we can easily use
  them in the home."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24986-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make bruschetta include peeling, slicing, dicing, mixing,
  using the oven, rubbing and spreading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24986-4
  a curric:KeyLearningPoint ;
  rdfs:label "The origin of ingredients in a recipe can be identified and substitutes made."@en ;
  dcterms:modified "2026-06-07T15:30:29.296979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24977-1
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes can be modified to better suit an occasion or person, such as breakfast or a
  party, and friends or grandparents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24977-2
  a curric:KeyLearningPoint ;
  rdfs:label """Breakfast muffins can be sweet (containing fruit) or savoury (containing vegetables
  and/or cheese)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24977-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make breakfast muffins are measuring, grating, mixing,
  dividing (spooning) and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24977-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can rate how we worked by: being hygienic, following the recipe, working tidily
  and using food skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24954-1
  a curric:KeyLearningPoint ;
  rdfs:label """Kebabs originate from the Middle East, with vegetables and/or meat in a marinade
  (which helps soften/flavour the food)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24954-2
  a curric:KeyLearningPoint ;
  rdfs:label """A recipe is a set of instructions for preparing and cooking a dish (name,
  ingredients, equipment and method)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24954-3
  a curric:KeyLearningPoint ;
  rdfs:label "When preparing and cooking food we need to work safely and hygienically."@en ;
  dcterms:modified "2026-06-07T15:30:29.299299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24954-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make veggie kebabs are cutting, threading, making a marinade
  (shaking/whisking) and brushing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24998-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cornish pasties, known as 'Oggy', originate from Cornwall. They were traditionally
  eaten by tin miners."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24998-2
  a curric:KeyLearningPoint ;
  rdfs:label "Care should be taken when handling raw meat to prevent cross-contamination."@en ;
  dcterms:modified "2026-06-07T15:30:29.301423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24998-3
  a curric:KeyLearningPoint ;
  rdfs:label """The filling traditionally includes potato, onion and swede, commonly grown in the
  UK, and meat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24998-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Cornish pasties are rubbing-in, rolling-out, peeling,
  dicing, shaping and using an oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24976-1
  a curric:KeyLearningPoint ;
  rdfs:label """The food and drinks consumed in and outside the home are often different, such as
  breakfast at home or lunch at school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24976-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different foods are eaten depending on our location, who we are with and the
  occasion, such as a picnic with friends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24976-3
  a curric:KeyLearningPoint ;
  rdfs:label """Meals can be planned for different situations, occasions and people, such as a party
  or breakfast for friends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24992-1
  a curric:KeyLearningPoint ;
  rdfs:label """A pizza base is bread dough, which uses yeast. As the dough rests and bakes, yeast
  produces gas, which makes it rise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise cutting, spreading and rolling are important to make eight uniform sized
  pizza rolls which will cook evenly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24992-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills needed to make a pizza include measuring, kneading, grating,
  spreading, rolling and using an oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pizzas can have a wide range of toppings, catering for many food preferences, health
  needs and occasions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24965-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can get inspiration for dishes by looking at food and cuisines around the
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24965-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salads can make healthy meals as they contain lots of fruit and vegetables, as well
  as pasta, noodles, rice or potatoes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24965-3
  a curric:KeyLearningPoint ;
  rdfs:label """A salad dressing is a sauce for salads. It can have many different flavours, as a
  wide range of ingredients can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24965-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask other people to judge our work using their senses."@en ;
  dcterms:modified "2026-06-07T15:30:29.311645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24990-1
  a curric:KeyLearningPoint ;
  rdfs:label """Patatas bravas is a Spanish dish comprising potatoes topped with a spicy sauce, made
  with paprika and chilli."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24990-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different types of potatoes grown in the UK. They were originally
  cultivated in South America."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24990-3
  a curric:KeyLearningPoint ;
  rdfs:label """We must always work hygienically when preparing and cooking food, and use equipment
  safely to prevent accidents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24990-4
  a curric:KeyLearningPoint ;
  rdfs:label "Potatoes are a staple food in the UK, as they make up a large part of the diet."@en ;
  dcterms:modified "2026-06-07T15:30:29.313546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24990-5
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make patatas bravas include dicing, using the oven, peeling,
  mixing and using the hob (frying)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24984-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are a number of different stages involved in producing our food."@en ;
  dcterms:modified "2026-06-07T15:30:29.321818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24984-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food is produced from many different plants, such as growing and harvesting wheat
  for flour and apples for eating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24984-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food is produced from animals, such as rearing dairy cows for milk, pigs for meat,
  and catching fish at sea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24984-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some food can be produced at home, such as growing fruit and vegetables, or keeping
  chickens for eggs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24997-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food labels show us information about how to store the food correctly, and when it
  should be eaten (date marks)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Depending on the food, they can be stored in kitchen cupboards or on the
  worksurface, in the fridge, or in the freezer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24997-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food stored in sealed packets, cartons or cans, or kept cold in the fridge or
  freezer, will keep safe to eat for longer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some foods have labels that tell us more about how they were grown or reared, such
  as Red Tractor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24975-1
  a curric:KeyLearningPoint ;
  rdfs:label "Drink and snack swaps can be made for better healthy eating."@en ;
  dcterms:modified "2026-06-07T15:30:29.324408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24975-2
  a curric:KeyLearningPoint ;
  rdfs:label "Making smart swaps helps us to better follow the Eatwell Guide."@en ;
  dcterms:modified "2026-06-07T15:30:29.324412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Foods like chocolate, crisps, cake and ice cream should be eaten less often and in
  small amounts. They are not needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24972-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four seasons: winter, spring, summer and autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.324439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24972-2
  a curric:KeyLearningPoint ;
  rdfs:label "The climate and conditions affect when and where food is grown."@en ;
  dcterms:modified "2026-06-07T15:30:29.324443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24972-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eating foods that are in season in the UK and produced locally can have benefits for
  the planet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24958-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many special occasions associated with different types of food."@en ;
  dcterms:modified "2026-06-07T15:30:29.326604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24958-2
  a curric:KeyLearningPoint ;
  rdfs:label "We eat different food on special occasions."@en ;
  dcterms:modified "2026-06-07T15:30:29.326608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24958-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different festivals and events that are celebrated with special
  foods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24955-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rock cakes are from Britain and traditionally eaten at teatime. They were promoted
  in World War II due to rationing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24955-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make rock cakes are measuring, rubbing-in, mixing, cracking
  an egg, and portioning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24955-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some mixtures need to be divided into equal sized portions, so that they cook
  evenly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24955-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ovens are very hot. Dishes must be placed in and taken out while wearing oven
  gloves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24962-1
  a curric:KeyLearningPoint ;
  rdfs:label """Flapjacks are a traditional UK baked bar, with its roots going back to the 16th
  Century."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24962-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oats and apples are grown and harvested from around the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.330417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24962-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make flapjacks are measuring, grating, mixing, dividing and
  using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24962-4
  a curric:KeyLearningPoint ;
  rdfs:label "If we have sweet foods, we should have them occasionally and in small amounts."@en ;
  dcterms:modified "2026-06-07T15:30:29.330428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24959-1
  a curric:KeyLearningPoint ;
  rdfs:label """A canapé is a small piece of bread, pastry or cracker, decorated with food,
  originating from France."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24959-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tuna is a type of fish that is caught at sea and one of the five most popular fish
  eaten in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24959-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make tuna canapés are measuring, rolling out, cutting,
  mixing, spooning and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24959-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our work can be judged by specific criteria, such as how we work and the quality of
  what we make."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24974-1
  a curric:KeyLearningPoint ;
  rdfs:label """A salad can be modified to use fruit and/or vegetables that are in season, as well
  as food that is leftover."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24974-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using food that is in season can be cheaper, and better for the planet (local, less
  waste) and you (greater variety)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24974-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a seasonal salad are peeling, grating, cutting and
  mixing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24974-4
  a curric:KeyLearningPoint ;
  rdfs:label "The ingredients used in a recipe can be mapped against the UK seasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.334034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24995-1
  a curric:KeyLearningPoint ;
  rdfs:label """A bean and plantain stew has many variations and can be found in the Caribbean, as
  well as many African countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24995-2
  a curric:KeyLearningPoint ;
  rdfs:label "A plantain is in the banana family, but have thicker skins and are more starchy."@en ;
  dcterms:modified "2026-06-07T15:30:29.340333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24995-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make bean and plantain stew are peeling, chopping, draining,
  stirring and using a hob."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24995-4
  a curric:KeyLearningPoint ;
  rdfs:label "Recipes can be analysed to calculate how much energy and nutrients they provide."@en ;
  dcterms:modified "2026-06-07T15:30:29.340341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Glamorgan sausages originate from Wales and can be dated back centuries. They are
  made using leeks and local cheese."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Leeks are part of the onion family, grown in the UK. Cheese is made from cows' milk,
  with many varieties being made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24967-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vegetables and fruit should be washed before use to remove any dirt and
  bacteria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24967-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Glamorgan sausages are measuring, slicing, grating,
  dividing, coating and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Traditionally, Glamorgan sausages are fried. However, they can be oven baked to be
  healthier (as no oil is added)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24973-1
  a curric:KeyLearningPoint ;
  rdfs:label "A lot of food that could have been eaten is wasted for different reasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.355685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24973-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK, 60% of food waste is from our homes, on average around 8 meals a week are
  thrown away in each home."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24973-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food waste can be reduced by planning ahead, storing correctly, and cooking and
  eating everything."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24973-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food waste can be used for compost, such as fruit and vegetable peelings, egg shells
  and tea bags."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25001-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rice dates back thousands of years to China. There are many types of rice used in
  different international dishes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.357971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25001-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rather than using the hob, the dish is cooked covered in the oven. This keeps the
  heat and liquid in, cooking the dish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.357976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25001-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make baked savoury rice are measuring, peeling, chopping,
  mixing and using the oven (baking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.357980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25001-4
  a curric:KeyLearningPoint ;
  rdfs:label "Formal and informal feedback can help improve work in the future."@en ;
  dcterms:modified "2026-06-07T15:30:29.357985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24991-1
  a curric:KeyLearningPoint ;
  rdfs:label """This cake uses the all-in-one method, where the flour, sugar, fat and eggs are mixed
  together thoroughly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24991-2
  a curric:KeyLearningPoint ;
  rdfs:label """For cakes, accurate weighing and measuring is required to achieve consistent baking
  results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24991-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a fruit traybake include measuring, slicing, mixing,
  pouring, and using an oven (baking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24991-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of seasonal UK fruit can be used and arranged attractively in the
  cake."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24983-1
  a curric:KeyLearningPoint ;
  rdfs:label """Thought to be Indian in origin, however, many countries have their own versions,
  e.g. China, Thailand, Japan, and Korea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24983-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different types of curry, some based on a specific ingredient (e.g.
  spinach) or blend of spices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24983-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills to make a curry are peeling, chopping, opening cans, stirring and
  using the hob (simmering)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24983-4
  a curric:KeyLearningPoint ;
  rdfs:label """The main nutrients provided by a recipe can identified by using the Eatwell Guide
  food groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24978-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poke bowls originate from Hawaii, traditionally using fish. Modern bowls have many
  ingredients, attractively presented."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24978-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes can be modified to use different ingredients, depending on availability,
  cost and sensory attributes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24978-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hands should be washed before and after cooking, after touching the bin, blowing
  your nose and cleaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24978-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills to make a poke bowl are: measuring, grating, slicing, dicing, mixing
  (shaking), juicing and arranging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24978-5
  a curric:KeyLearningPoint ;
  rdfs:label "A dish can be improved by evaluating its appearance, smell, texture and taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.372936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24956-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spring rolls are a starter, associated with China and Southeast Asia. The wrapper
  and fillings can change due to region."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24956-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make spring rolls are grating, snipping, mixing, brushing,
  folding and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24956-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spring rolls cooked in the oven are healthier than those fried in oil. They contain
  less fat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24987-1
  a curric:KeyLearningPoint ;
  rdfs:label """Herbs, spices, fruits and aromatic ingredients have a range of smells and
  flavours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24987-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different cuisines around the world are associated with different smells and
  flavours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24987-3
  a curric:KeyLearningPoint ;
  rdfs:label "The sensory attributes of ingredients can be described and rated (measured)."@en ;
  dcterms:modified "2026-06-07T15:30:29.379999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24963-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is a wide range of dishes and meals cooked and eaten around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.380885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24963-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although some dishes and meals look unfamiliar to me, they are based on food from
  plants and animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different utensils are used to eat food, such as a knife, fork, spoon and
  chopsticks. Sometimes food is eaten by hand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24963-4
  a curric:KeyLearningPoint ;
  rdfs:label """The intensity of sensory attributes can be described, such as mild and strong, or
  soft and chewy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24971-1
  a curric:KeyLearningPoint ;
  rdfs:label "The frittata originates from Italy and was eaten in ancient Rome."@en ;
  dcterms:modified "2026-06-07T15:30:29.392065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24971-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a frittata include cracking eggs, whisking, grating,
  cutting, pouring and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24971-3
  a curric:KeyLearningPoint ;
  rdfs:label """The eggs in the recipe make the egg mixture firm (set) when cooked, similar to
  cooking a fried or boiled egg."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24971-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ingredients used in a recipe can be mapped against the Eatwell Guide food
  groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24989-1
  a curric:KeyLearningPoint ;
  rdfs:label "Paska is a Ukrainian bread eaten at Easter and taken to church."@en ;
  dcterms:modified "2026-06-07T15:30:29.396103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24989-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many foods that are eaten to mark religious events and special
  occasions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24989-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make paska include measuring, zesting, juicing, mixing,
  kneading, shaping and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24981-1
  a curric:KeyLearningPoint ;
  rdfs:label "To be active and healthy, food is needed to provide energy for the body."@en ;
  dcterms:modified "2026-06-07T15:30:29.417199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24981-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different people need different amounts of energy, and different activities use
  different amounts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24981-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food and drinks provide nutrients, fibre and water. They have different functions to
  keep us healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24981-4
  a curric:KeyLearningPoint ;
  rdfs:label """A wide variety of food is needed as different food provides different types and
  amounts of nutrients."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24994-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food labels show us information about pre-packaged food and drinks."@en ;
  dcterms:modified "2026-06-07T15:30:29.421183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24994-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nutrition information labels can help us to make healthier choices."@en ;
  dcterms:modified "2026-06-07T15:30:29.421187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24994-3
  a curric:KeyLearningPoint ;
  rdfs:label """Front of pack nutrition labels are shown as traffic lights. When choosing, go for
  greens and ambers, and fewer reds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24994-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common allergens, when present in a pre-packed food or drink, must be emphasised
  clearly in the ingredients list."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24985-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food is processed at home and on a large scale to make it edible and safe."@en ;
  dcterms:modified "2026-06-07T15:30:29.426761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24985-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food is processed at home or in restaurants to prepare dishes for people, such as
  peeling, filleting, cooking, freezing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24985-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food is processed on a large scale to provide food for many people, and provide
  convenience and variety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Around 40% of food waste is from food production and processing, and 60% from the
  home."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24993-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 8 tips for healthy eating provide simple messages for us to follow."@en ;
  dcterms:modified "2026-06-07T15:30:29.434085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24993-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being active is important for health, making the body fitter and stronger."@en ;
  dcterms:modified "2026-06-07T15:30:29.434090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24993-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are a number of simple healthier ways to plan, prepare and cook food."@en ;
  dcterms:modified "2026-06-07T15:30:29.434096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our diet (the food and drink consumed) can be mapped against the Eatwell Guide food
  groups for improvements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24969-2
  a curric:KeyLearningPoint ;
  rdfs:label "We need a little fat in our diet, such as oil and spreads."@en ;
  dcterms:modified "2026-06-07T15:30:29.589741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24969-3
  a curric:KeyLearningPoint ;
  rdfs:label """Foods such as crisps, ice cream, biscuits, cake and chocolate should be eaten less
  often and in small amounts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24969-4
  a curric:KeyLearningPoint ;
  rdfs:label "Meals and snacks can be sorted into the Eatwell Guide food groups."@en ;
  dcterms:modified "2026-06-07T15:30:29.589749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24982-1
  a curric:KeyLearningPoint ;
