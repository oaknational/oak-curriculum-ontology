oakcurric:keyword-vitamins
  a curric:Keyword ;
  schema:name "vitamins"@en ;
  schema:description "organic micronutrients that are essential for the human body"@en ;
  dcterms:modified "2026-06-07T15:30:02.419605Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-people-different-communities-follow-different
  a curric:Misconception ;
  curric:statement "People in different communities follow different healthy eating advice."@en ;
  curric:correction """Most people in the UK should follow the Eatwell Guide, and 8 tips for healthy
  eating, with the food and meals adapted for the needs of different groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085862Z"^^xsd:dateTime .

oakcurric:misconception-recipes-around-world-cooked-using
  a curric:Misconception ;
  curric:statement """Recipes from around the world can only be cooked using ingredients from those
  countries."""@en ;
  curric:correction """We can prepare and cook recipes from other countries using ingredients grown,
  reared or caught in the UK. Sometimes there are ingredients that are not grown or easily
  made in the UK, so foods from other countries are used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093248Z"^^xsd:dateTime .

oakcurric:misconception-healthy-meal-needs-food-groups
  a curric:Misconception ;
  curric:statement "A healthy meal needs to have all the food groups from the Eatwell Guide."@en ;
  curric:correction """We do not need to eat all the food groups at each meal. We can get all the
  food groups through different meals in the day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093256Z"^^xsd:dateTime .

oakcurric:misconception-extra-flavour-recipe-salt-pepper
  a curric:Misconception ;
  curric:statement "For extra flavour in a recipe, only salt and pepper can be used."@en ;
  curric:correction """There are lots of ingredients that could be used, such as spices, herbs, and
  other aromatic ingredients e.g. lemon grass, harissa."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093407Z"^^xsd:dateTime .

oakcurric:misconception-term-cooking-means-add-heat
  a curric:Misconception ;
  curric:statement """The term 'cooking' only means to add heat to food, such as baking, boiling and
  grilling."""@en ;
  curric:correction """The term 'cooking' includes: (1) the preparation of food, e.g. peel, slice
  and and mix; (2) heating food, e.g. baking, boiling and grilling. It is a term used to
  describe the entire process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094119Z"^^xsd:dateTime .

oakcurric:misconception-mould-fruit-yogurt-bread-cut
  a curric:Misconception ;
  curric:statement """Mould on fruit, yogurt or bread can be cut off, so the remaining food can be
  eaten."""@en ;
  curric:correction """If food has mould, the food should not be eaten, especially with soft foods
  like bread, yogurt or fruit. It is unsafe to eat and can cause illness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094138Z"^^xsd:dateTime .

oakcurric:misconception-bake-cookies-different-sizes-same
  a curric:Misconception ;
  curric:statement """You can bake cookies of different sizes on the same tray, making a bigger one
  for yourself."""@en ;
  curric:correction """The cookies need to be the same size, for even cooking. If smaller, they will
  burn, if bigger, they will be undercooked."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095537Z"^^xsd:dateTime .

oakcurric:misconception-planning-healthy-meals-include-drinks
  a curric:Misconception ;
  curric:statement "When planning healthy meals, you do not have to include drinks."@en ;
  curric:correction "Healthy meals should always include a drink. Water is a great choice."@en ;
  dcterms:modified "2026-06-07T15:30:15.096754Z"^^xsd:dateTime .

oakcurric:misconception-limited-range-foods-produced-made
  a curric:Misconception ;
  curric:statement """There is a limited range of foods produced and made in the UK. This is why
  food from other countries are popular."""@en ;
  curric:correction """There is a huge range of food produced and made in the UK, including many
  traditional dishes. Food from other countries is often eaten to add variety to the diet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097561Z"^^xsd:dateTime .

oakcurric:misconception-people-allergy-cannot-eat-bread
  a curric:Misconception ;
  curric:statement "People with an allergy cannot eat bread."@en ;
  curric:correction """Some people have an allergy to flour made from wheat, which many breads are
  made from. There are other flours that can be used, so they can eat bread."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098336Z"^^xsd:dateTime .

oakcurric:misconception-matter-size-scones-baked-same
  a curric:Misconception ;
  curric:statement """No matter the size of the scones, they are baked for the same length
  of time."""@en ;
  curric:correction """The heat from the oven will take longer to penetrate and cook the scones the
  bigger they are. Therefore smaller scones will cook more quickly than bigger scones."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098344Z"^^xsd:dateTime .

oakcurric:misconception-families-different-cultures-communities-eat
  a curric:Misconception ;
  curric:statement """Families from different cultures and communities only eat specific types of
  food."""@en ;
  curric:correction """Families from different cultures and communities enjoy a range of other
  foods, not just what is traditionally served."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099707Z"^^xsd:dateTime .

oakcurric:misconception-cuisine-ingredients-food-customs-different
  a curric:Misconception ;
  curric:statement """The cuisine, ingredients and food customs in different countries have not
  changed over time."""@en ;
  curric:correction """History has changed the cuisine, ingredients and food customs. This has
  happened because of travel, trade and wars."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101211Z"^^xsd:dateTime .

oakcurric:misconception-cheese-made-milk-dairy-cows
  a curric:Misconception ;
  curric:statement "Cheese is only made with milk from dairy cows."@en ;
  curric:correction """Cheese is made with milk from many animals, including goats, sheep, buffalo,
  reindeer and alpaca, as well as dairy cows."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102049Z"^^xsd:dateTime .

oakcurric:misconception-recipes-cannot-modified
  a curric:Misconception ;
  curric:statement "Recipes cannot be modified."@en ;
  curric:correction """Recipes can be modified, for different occasions and the needs of people.
  Ingredients can be changed and other ingredients added."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102634Z"^^xsd:dateTime .

oakcurric:misconception-cooking-fine-weigh-measure-accurately
  a curric:Misconception ;
  curric:statement """When cooking it is fine not to weigh and measure accurately, approximate
  measurements are fine."""@en ;
  curric:correction """It is important to weigh and measure ingredients accuarely, so that the
  recipe works well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102808Z"^^xsd:dateTime .

oakcurric:misconception-cornish-pasties-made-sold-uk
  a curric:Misconception ;
  curric:statement """Any Cornish pasties made and sold in the UK can use the name ‘Cornish pasty’,
  as it is based on a recipe."""@en ;
  curric:correction """Only pasties made in Cornwall to a specific recipe can be called a ‘Cornish
  pasty’; it is legally protected in the UK by Protected Geographical Indication (PGI)
  status."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103485Z"^^xsd:dateTime .

oakcurric:misconception-affect-eat-drink
  a curric:Misconception ;
  curric:statement "Who we are with does not affect what we eat and drink."@en ;
  curric:correction """Who we are with often does affect what we eat and drink. For example, we
  might eat what our parents cook, or pick foods the same as friends."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104514Z"^^xsd:dateTime .

oakcurric:misconception-base-pizza-covered-sauce-made
  a curric:Misconception ;
  curric:statement "The base of a pizza is always covered in a sauce made from tomatoes."@en ;
  curric:correction """While a sauce made from tomatoes is traditional, the base can also be covered
  in pesto, a cheese sauce, or just garlic and oil."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107006Z"^^xsd:dateTime .

oakcurric:misconception-salad-contain-lettuce-cucumber-tomato
  a curric:Misconception ;
  curric:statement "A salad must contain lettuce, cucumber and tomato."@en ;
  curric:correction """Salads can contain a wide range of different ingredients. We can take
  inspiration from around the world and choose different ingredients."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107034Z"^^xsd:dateTime .

oakcurric:misconception-hands-need-washed-dried-cooking
  a curric:Misconception ;
  curric:statement "Hands only need to be washed and dried before and after cooking."@en ;
  curric:correction """Hands should also be washed and dried well after touching the bin, blowing
  your nose, and cleaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107682Z"^^xsd:dateTime .

oakcurric:misconception-food-produced-farm-field
  a curric:Misconception ;
  curric:statement "Food can only be produced on a farm or in a field."@en ;
  curric:correction """Food can be produced (grown) at home, such as fruit, vegetables and herbs.
  Some food can be foraged."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110148Z"^^xsd:dateTime .

oakcurric:misconception-use-best-date-marks-same
  a curric:Misconception ;
  curric:statement """'Use by' and 'best before' date marks are the same. The food is still safe to
  eat after the date passes."""@en ;
  curric:correction """'Use by' and 'best before' date marks are not the same. After the 'use by'
  date passes, the food is not safe to eat. After the ‘best before’ date passes, the food
  will probably be safe to eat, but may not look or taste as good."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110168Z"^^xsd:dateTime .

oakcurric:misconception-snacks-unhealthy
  a curric:Misconception ;
  curric:statement "All snacks are unhealthy."@en ;
  curric:correction """Not all snacks are unhealthy. We can use the Eatwell Guide to help us choose
  healthier snacks. We can choose snacks from each of the four biggest food groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110976Z"^^xsd:dateTime .

oakcurric:misconception-seasons-matter-buy-lots-different
  a curric:Misconception ;
  curric:statement """Seasons do not matter, as you can always buy lots of different fruit and
  vegetables in any season."""@en ;
  curric:correction """While you can buy different fruit and vegetables, they might have to be
  imported from other countries as they cannot grow in the UK in certain seasons. We should
  also try and eat more seasonal fruit and vegetables from the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110987Z"^^xsd:dateTime .

oakcurric:misconception-everyone-religion-celebrates-festival-same
  a curric:Misconception ;
  curric:statement "Everyone in a religion celebrates a festival in the same way."@en ;
  curric:correction """The way religious festivals are celebrated varies based on where people live,
  their culture and denominational differences. For example, Christmas is widely celebrated
  by non-Christians, focusing on family, giving and joy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111638Z"^^xsd:dateTime .

oakcurric:misconception-dried-fruit-rock-cakes-counts
  a curric:Misconception ;
  curric:statement "The dried fruit in rock cakes counts towards our 5 A DAY."@en ;
  curric:correction """The dried fruit does not count towards our 5 A DAY, as it is in small
  amounts. Rock cakes are sweet foods, containing sugar and fat. We need to eat less of
  these types of foods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112088Z"^^xsd:dateTime .

oakcurric:misconception-flapjack-recipe-contains-apple-sultanas
  a curric:Misconception ;
  curric:statement """The flapjack recipe contains apple and sultanas, so must be part of our 5 A
  DAY."""@en ;
  curric:correction """No, the flapjack does not count towards our 5 A DAY. There is not enough
  fruit, and they are high in sugars and fat (from butter). If we eat these types of foods,
  we should have them occasionally and in small amounts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113028Z"^^xsd:dateTime .

oakcurric:misconception-fish-same
  a curric:Misconception ;
  curric:statement "All fish is the same."@en ;
  curric:correction """There are lots of different types of fish in the world. They look, smell and
  taste different. Tuna is one type of fish."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114056Z"^^xsd:dateTime .

oakcurric:misconception-uk-seasonal-fruit-vegetables-tend
  a curric:Misconception ;
  curric:statement "UK seasonal fruit and vegetables tend to be more expensive."@en ;
  curric:correction """UK seasonal fruit and vegetables tend to be less expensive, as there are lots
  of them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114230Z"^^xsd:dateTime .

oakcurric:misconception-using-hob-boiling-simmering-cooking
  a curric:Misconception ;
  curric:statement "When using the hob, boiling and simmering cooking methods are the same."@en ;
  curric:correction """Boiling is at the boiling point, bubbling rapidly. Simmering is below the
  boiling point, bubbling gently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116372Z"^^xsd:dateTime .

oakcurric:misconception-sasusages-contain-meat-usually-pork
  a curric:Misconception ;
  curric:statement "Sasusages contain meat, usually pork."@en ;
  curric:correction """Many sausages contain meat, but there are many recipes that are vegetarian or
  vegan. Glamorgan sausages are vegetarian (as they contain cheese and egg)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117930Z"^^xsd:dateTime .

oakcurric:misconception-food-waste-happens-mostly-outside
  a curric:Misconception ;
  curric:statement "Food waste happens mostly outside the home."@en ;
  curric:correction "Food waste happens mostly inside the home - around 60%."@en ;
  dcterms:modified "2026-06-07T15:30:15.122807Z"^^xsd:dateTime .

oakcurric:misconception-rice-cooked-saucepan-hob
  a curric:Misconception ;
  curric:statement "Rice can only be cooked in a saucepan on the hob."@en ;
  curric:correction """Rice can be cooked in different ways, such as on the hob, in a rice cooker,
  in the oven, and in a microwave. The hot water and steam help to ‘cook’ the rice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123302Z"^^xsd:dateTime .

oakcurric:misconception-baking-baking-trays-foil-trays
  a curric:Misconception ;
  curric:statement """When baking, the baking trays (or foil trays) do not need to be greased or
  lined."""@en ;
  curric:correction """Baking trays (or foil trays) should be greased with a little oil, or lined
  with greaseproof paper, to create a barrier between the cake and the tray. The barrier
  helps to prevent the cake from sticking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124594Z"^^xsd:dateTime .

oakcurric:misconception-curry-powder-spice-plant
  a curric:Misconception ;
  curric:statement "Curry powder is a spice from a plant."@en ;
  curric:correction """Curry powder is a mixture of different spices blended together, not a single
  spice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125826Z"^^xsd:dateTime .

oakcurric:misconception-fruit-vegetables-peeled-use
  a curric:Misconception ;
  curric:statement "All fruit and vegetables should be peeled before use."@en ;
  curric:correction """Not all fruit and vegetables need to be peeled, such as apples and potatoes.
  The peel, or skin, can be tasty and be good for us. However, they should be washed to
  remove any dirt, insects and bacteria."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128960Z"^^xsd:dateTime .

oakcurric:misconception-spring-rolls-fried
  a curric:Misconception ;
  curric:statement "Spring rolls are always fried."@en ;
  curric:correction """Spring rolls can be oven baked or steamed. There are many different
  varieties."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128974Z"^^xsd:dateTime .

oakcurric:misconception-sensory-evaluation-help-us-decide
  a curric:Misconception ;
  curric:statement "Sensory evaluation can only help us decide whether we like a food or not."@en ;
  curric:correction """Sensory evaluation can help us decide whether we like foods, but also allows
  us to describe and compare foods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132391Z"^^xsd:dateTime .

oakcurric:misconception-unfamiliar-dishes-meals-cannot-made
  a curric:Misconception ;
  curric:statement """Unfamiliar dishes or meals cannot be made in the UK, as they use unusual
  foods."""@en ;
  curric:correction """Although some dishes and meals look unfamiliar, they are all from plants and
  animals and can be made in the UK. They are based on fruit and vegetables; potatoes,
  bread, rice or pasta; dairy and alternatives; beans, eggs, fish or meat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132860Z"^^xsd:dateTime .

oakcurric:misconception-need-wash-your-hands-touching
  a curric:Misconception ;
  curric:statement "You do not need to wash your hands after touching a raw egg."@en ;
  curric:correction """You should always wash your hands after touching a raw egg. This helps to
  prevent the spread of bacteria. Some bacteria can cause food poisoning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137568Z"^^xsd:dateTime .

oakcurric:misconception-bread-dough-need-kneaded
  a curric:Misconception ;
  curric:statement "Bread dough does not need to be kneaded."@en ;
  curric:correction """Bread dough should be kneaded for 10 minutes, as it helps it to become smooth
  and elastic. Kneading helps the dough to rise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139023Z"^^xsd:dateTime .

oakcurric:misconception-activity-sporty-active
  a curric:Misconception ;
  curric:statement "Activity is about being sporty, being active."@en ;
  curric:correction """Activity is all the things we do and movements we make, not only sports. It
  includes sports, but also reading, sleeping and watching TV."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147657Z"^^xsd:dateTime .

oakcurric:misconception-traffic-lights-used-compare-different
  a curric:Misconception ;
  curric:statement """Traffic lights can be used to compare different types of foods for the
  healthiest option."""@en ;
  curric:correction """Traffic lights are designed to help people compare similar foods for the
  healthiest option, so they are comparing foods ‘like for like’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149100Z"^^xsd:dateTime .

oakcurric:misconception-food-processing-happen-home-prepare
  a curric:Misconception ;
  curric:statement """Food processing does not happen at home to prepare and cook food, only at a
  factory."""@en ;
  curric:correction """Food processing steps are used in the home to prepare and cook food, such as
  peeling, slicing, grating, mixing and baking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150763Z"^^xsd:dateTime .

oakcurric:misconception-active-good-my-physical-health
  a curric:Misconception ;
  curric:statement """Being active is only good for my physical health, such as healthy bones,
  muscles and heart."""@en ;
  curric:correction """While being active is good for your bones, muscles and heart, it can also
  make you feel fitter and happier, make new friends and try something new."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153044Z"^^xsd:dateTime .

oakcurric:misconception-diet-means-lose-weight
  a curric:Misconception ;
  curric:statement "A diet means to lose weight."@en ;
  curric:correction "The word ‘diet’ describes all the food and drink we consume."@en ;
  dcterms:modified "2026-06-07T15:30:15.156119Z"^^xsd:dateTime .

oakcurric:misconception-same-foods-day-eatwell-guide
  a curric:Misconception ;
  curric:statement """If I have the same foods every day from the Eatwell Guide I will get all the
  nutrients I need and be healthy."""@en ;
  curric:correction """To be healthy and get all the nutrients we need, we should eat a wide variety
  of food from each of the Eatwell Guide food groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163873Z"^^xsd:dateTime .
