# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-24939-1
  a curric:KeyLearningPoint ;
  rdfs:label "All bread is made from flour, mainly from wheat or corn (maize)."@en ;
  dcterms:modified "2026-06-07T15:30:29.280670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24939-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is a wide range of breads available to purchase (or make) in the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.280674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some people cannot eat wheat, which is milled into flour to make bread. A different
  type of flour is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24939-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of sensory words to describe the appearance, smell, taste and
  texture of bread."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24950-1
  a curric:KeyLearningPoint ;
  rdfs:label """We measure ingredients to ensure success and so that we can make the recipe
  again."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24950-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a potato salad are weighing, measuring, cutting, mixing
  and sprinkling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24950-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ingredients in this recipe come from plants (potatoes) and animals (yogurt
  dressing)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24934-1
  a curric:KeyLearningPoint ;
  rdfs:label "Couscous is a traditional North African dish. There are many variations."@en ;
  dcterms:modified "2026-06-07T15:30:29.304722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24934-2
  a curric:KeyLearningPoint ;
  rdfs:label """Liquids, such as water, are measured in a measuring jug. Dry foods, such as
  couscous, are weighed using weighing scales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24934-3
  a curric:KeyLearningPoint ;
  rdfs:label "The food skills used to make a couscous salad are measuring, cutting and mixing."@en ;
  dcterms:modified "2026-06-07T15:30:29.304730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24934-4
  a curric:KeyLearningPoint ;
  rdfs:label "Food must be stored and prepared safely and hygienically."@en ;
  dcterms:modified "2026-06-07T15:30:29.304734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24933-1
  a curric:KeyLearningPoint ;
  rdfs:label "Crudités, the dippers, comes from the French word meaning 'rawness'."@en ;
  dcterms:modified "2026-06-07T15:30:29.315671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Before preparing and cooking food, we should tie back long hair, put on an apron and
  wash hands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24933-3
  a curric:KeyLearningPoint ;
  rdfs:label """When cutting food with a knife safely, we should use the Bridge Hold and the Claw
  Grip."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24933-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make veggie dips and dippers are measuring, mixing, peeling
  and cutting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24943-1
  a curric:KeyLearningPoint ;
  rdfs:label "Before cooking, we need to get ready to cook to be safe and hygienic."@en ;
  dcterms:modified "2026-06-07T15:30:29.322119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24943-2
  a curric:KeyLearningPoint ;
  rdfs:label "The food skills used to make veggie snacks are cutting with scissors and mixing."@en ;
  dcterms:modified "2026-06-07T15:30:29.322123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24943-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scissors can be used to cut different fruit and vegetables safely."@en ;
  dcterms:modified "2026-06-07T15:30:29.322127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24943-4
  a curric:KeyLearningPoint ;
  rdfs:label "After cooking, we need to wash-up equipment, and clean and tidy work surfaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.322131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24953-1
  a curric:KeyLearningPoint ;
  rdfs:label """A vegetable peeler is used to peel away the skin of carrots and other
  vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24953-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a salad pot are peeling, cutting, measuring, grating
  and layering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24953-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should avoid wasting food during preparation and cooking."@en ;
  dcterms:modified "2026-06-07T15:30:29.340236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24947-1
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make fruit kebabs are peeling (by hand), cutting and
  threading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24947-2
  a curric:KeyLearningPoint ;
  rdfs:label """When cutting food with a knife safely, we should use the Bridge Hold or the fork
  secure technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24947-3
  a curric:KeyLearningPoint ;
  rdfs:label "We all need to have more fruit and vegetables."@en ;
  dcterms:modified "2026-06-07T15:30:29.343562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24947-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can describe the appearance, smell and taste of fruit, and evaluate a recipe
  based on our food preferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24952-1
  a curric:KeyLearningPoint ;
  rdfs:label "We eat different food depending on the time of day, occasion and lifestyle."@en ;
  dcterms:modified "2026-06-07T15:30:29.345751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24952-2
  a curric:KeyLearningPoint ;
  rdfs:label """We eat different foods, depending on where we live, who we live with, our culture
  and customs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24952-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan a dish or meal for our family based on their food preferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.345761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24952-4
  a curric:KeyLearningPoint ;
  rdfs:label "We need lots of different food and drinks to be healthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.345765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24937-1
  a curric:KeyLearningPoint ;
  rdfs:label """The term 'farm to fork' refers to the food chain of a food's origin to
  consumption."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24937-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food is changed from 'farm to fork' to make other foods, such as cheese from milk,
  bread from wheat and ham from pigs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24937-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food is changed from 'farm to fork' to make it edible and safe to eat."@en ;
  dcterms:modified "2026-06-07T15:30:29.345796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20222-1
  a curric:KeyLearningPoint ;
  rdfs:label """We need a variety and balance of foods to stay healthy, as depicted by the Eatwell
  Guide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20222-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Eatwell Guide has four main food groups, each having a variety of food."@en ;
  dcterms:modified "2026-06-07T15:30:29.348472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20222-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of each food group indicates the amount we should consume, e.g.
  lots, some."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24944-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different pieces of equipment have specific jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.349429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24944-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make butter bean hummus are mashing, mixing and
  spreading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24944-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hummus is a dip traditionally made from chickpeas, originating from the
  Middle East."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24938-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pâté is a savoury spread, often made from fish, meat, cheese and vegetables. It can
  be traced back to the Roman Empire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24938-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make mackerel and tomato pâté are measuring, mixing, cutting
  and spreading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24938-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ingredients originate from fish (caught), dairy cows (cream cheese, reared) and
  plants (tomato and celery, grown)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24938-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of words can be used to describe the texture of a dish, such as smooth or
  crunchy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24941-1
  a curric:KeyLearningPoint ;
  rdfs:label """The original recipe, Coronation chicken, was invented for a lunch during the
  coronation of Queen Elizabeth II in 1953."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24941-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a coronation chickpea pocket are draining, measuring,
  cutting, mixing and filling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24941-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can ask other people to evaluate a recipe by tasting it. This can help improve
  work next time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24951-1
  a curric:KeyLearningPoint ;
  rdfs:label "We eat different food according to what we like and dislike."@en ;
  dcterms:modified "2026-06-07T15:30:29.361751Z"^^xsd:dateTime .

