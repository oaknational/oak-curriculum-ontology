# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-bread-complicated-make-buy-bread
  a curric:Misconception ;
  curric:statement """Bread is complicated to make, so we can only buy bread from a bakery
  or shop."""@en ;
  curric:correction """Basic bread is made from flour and water, mixed together (sometimes other
  ingredients are added to make it rise and add flavour). Bread can easily be made at home."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095543Z"^^xsd:dateTime .

oakcurric:misconception-make-recipe-guessing-judging-measures
  a curric:Misconception ;
  curric:statement "We can make a recipe by guessing and judging the measures."@en ;
  curric:correction """We weigh and measure ingredients to make sure the recipe is a success, and so
  we can make it the same again in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102824Z"^^xsd:dateTime .

oakcurric:misconception-couscous-grain
  a curric:Misconception ;
  curric:statement "Couscous is a grain."@en ;
  curric:correction """Couscous is not a grain. However, couscous is made from semolina, which is
  coarsely ground durum wheat which is sprinkled with water and rolled to form small
  granules. It more closely resembles pasta."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104715Z"^^xsd:dateTime .

oakcurric:misconception-need-get-ready-cook-time
  a curric:Misconception ;
  curric:statement "You do not need to get ready to cook every time you prepare and cook food."@en ;
  curric:correction "We should always get ready to cook, so that we are hygienic (clean)."@en ;
  dcterms:modified "2026-06-07T15:30:15.108361Z"^^xsd:dateTime .

oakcurric:misconception-children-use-knives-cut-food
  a curric:Misconception ;
  curric:statement "Children have to use knives to cut food."@en ;
  curric:correction """Kitchen scissors can be used to cut a variety of foods. Scissors are
  generally safer to use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110262Z"^^xsd:dateTime .

oakcurric:misconception-graters-sharp
  a curric:Misconception ;
  curric:statement "Graters are not sharp."@en ;
  curric:correction """Graters are sharp, so we need to be careful. Be aware of your fingers and
  knuckles. Rub the food slowly and gently down the grater. You do not need to grate every
  bit of food."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116338Z"^^xsd:dateTime .

oakcurric:misconception-fresh-fruit-used-fruit-saald
  a curric:Misconception ;
  curric:statement "Only fresh fruit can be used for fruit saald kebabs."@en ;
  curric:correction """A range of fresh, canned and dried fruit can be used for fruit salad kebabs.
  Go for a colourful variety."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117472Z"^^xsd:dateTime .

oakcurric:misconception-people-eat-same-types-food
  a curric:Misconception ;
  curric:statement "People eat the same types of food."@en ;
  curric:correction """People eat different foods for a number of reasons. This includes time of
  day, occasions, likes/dislikes, where we live, who we live with, and tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118095Z"^^xsd:dateTime .

oakcurric:misconception-farm-fork-applies-food-produced
  a curric:Misconception ;
  curric:statement """'Farm to fork' only applies to food produced on a farm and eaten with
  a fork."""@en ;
  curric:correction """'Farm to fork' is a term used to describe the direct connection between food
  production (not just on farms) and its consumption (being eaten, not just with a fork)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118107Z"^^xsd:dateTime .

oakcurric:misconception-eatwell-guide-tells-exactly-foods
  a curric:Misconception ;
  curric:statement "The Eatwell Guide tells you exactly what foods to eat each day."@en ;
  curric:correction """The Eatwell Guide shows that we should eat a wide variety of food from each
  food group."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118916Z"^^xsd:dateTime .

oakcurric:misconception-hummus-made-chickpeas
  a curric:Misconception ;
  curric:statement "Hummus can only be made with chickpeas."@en ;
  curric:correction "Hummus can be made with a variety of beans and legumes."@en ;
  dcterms:modified "2026-06-07T15:30:15.119185Z"^^xsd:dateTime .

oakcurric:misconception-making-p-t-cooked
  a curric:Misconception ;
  curric:statement "When making pâté, they must always be cooked."@en ;
  curric:correction """Not all pâtés must be cooked first, some are non-cook. This pâté uses canned
  mackerel (which is already cooked), soft cheese and vegetables. Vegan and vegetarian pâtés
  can also be made."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122746Z"^^xsd:dateTime .

oakcurric:misconception-recipe-cannot-changed-work
  a curric:Misconception ;
  curric:statement "A recipe cannot be changed, as it will not work."@en ;
  curric:correction """Recipes can be changed, for example swapping chicken for chickpeas, or adding
  extra spices. The new recipe should be tested to make sure it works and tastes good."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124219Z"^^xsd:dateTime .

oakcurric:misconception-people-enough-fruit-vegetables-their
  a curric:Misconception ;
  curric:statement "Most people have enough fruit and vegetables in their diet."@en ;
  curric:correction """Most people need to eat more fruit and vegetables. We need at least 5
  A DAY."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124225Z"^^xsd:dateTime .

oakcurric:misconception-need-six-eight-glasses-water
  a curric:Misconception ;
  curric:statement "We need six - eight glasses of water a day."@en ;
  curric:correction """We need six - eight drinks a day. Water is a great choice, but other drinks
  count too, such as milk and juice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124999Z"^^xsd:dateTime .

oakcurric:misconception-bread-made-wheat-flour
  a curric:Misconception ;
  curric:statement "Bread is only made from wheat (flour)."@en ;
  curric:correction "Other plants can be used to make flour such as maize, rye and chickpeas."@en ;
  dcterms:modified "2026-06-07T15:30:15.126339Z"^^xsd:dateTime .

oakcurric:misconception-sushi-includes-raw-fish
  a curric:Misconception ;
  curric:statement "All sushi includes raw fish."@en ;
  curric:correction """Although raw fish is a common ingredient, not all sushi includes fish. Other
  ingredients are used, such as vegetables, fruit, egg, and cooked fish and meat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131866Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sandwich-uses-sliced
  a curric:Misconception ;
  curric:statement "Pupils may think that a sandwich always uses sliced white bread."@en ;
  curric:correction """Sandwiches can use a range of breads from around the world and are eaten
  often in many countries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135731Z"^^xsd:dateTime .

oakcurric:misconception-hands-washed-cold-water-soap
  a curric:Misconception ;
  curric:statement "Hands can be washed in cold water with soap."@en ;
  curric:correction "Hands must be washed in warm water with soap, then dried well."@en ;
  dcterms:modified "2026-06-07T15:30:15.140248Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-potatoes-count-vegetable
  a curric:Misconception ;
  curric:statement "Pupils may think that potatoes count as a vegetable."@en ;
  curric:correction """In the Eatwell Guide, potatoes do not count as a vegetable. They are in the
  'Potatoes, bread, pasta and rice' group."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142911Z"^^xsd:dateTime .

oakcurric:misconception-honey-made-plant
  a curric:Misconception ;
  curric:statement "Honey is made from a plant."@en ;
  curric:correction "Honey is made by bees in the hive. It is a food made by animals."@en ;
  dcterms:modified "2026-06-07T15:30:15.148560Z"^^xsd:dateTime .

oakcurric:misconception-our-food-comes-shops-supermarkets
  a curric:Misconception ;
  curric:statement "Our food comes from shops and supermarkets."@en ;
  curric:correction """While food is purchased from shops and supermarkets, plants are grown,
  animals are reared and fish is caught for us to eat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148565Z"^^xsd:dateTime .

oakcurric:misconception-misunderstanding-origin-food-lack-awareness
  a curric:Misconception ;
  curric:statement """There is a misunderstanding about the origin of food, and lack of awareness of
  where food comes from."""@en ;
  curric:correction """All food we eat comes from plants and animals. Food from plants includes
  fruit and vegetables. Food from animals includes milk, eggs, fish and meat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149626Z"^^xsd:dateTime .

oakcurric:misconception-people-like-dislike-same-foods
  a curric:Misconception ;
  curric:statement "People like and dislike the same foods."@en ;
  curric:correction """There are no right or wrong foods to like to like or dislike. We all have
  different tastes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160509Z"^^xsd:dateTime .
