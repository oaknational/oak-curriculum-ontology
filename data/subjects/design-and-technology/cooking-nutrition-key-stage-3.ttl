  dcterms:modified "2026-06-07T15:30:02.364888Z"^^xsd:dateTime .

oakcurric:keyword-sichuan
  a curric:Keyword ;
  schema:name "Sichuan"@en ;
  schema:description "a province in Southwestern China"@en ;
  dcterms:modified "2026-06-07T15:30:02.364905Z"^^xsd:dateTime .

oakcurric:keyword-florets
  a curric:Keyword ;
