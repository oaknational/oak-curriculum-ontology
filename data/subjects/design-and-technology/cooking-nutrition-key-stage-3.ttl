    oakcurric:thread-healthy-eating-and-nutrition ,
    oakcurric:thread-food-hygiene-and-safety .

oakcurric:unit-3402
  a curric:Unit ;
  rdfs:label "The Eatwell Guide: meals and diets"@en ;
  curric:slug "the-eatwell-guide-meals-and-diets" ;
  rdfs:comment """In this unit pupils use the Eatwell Guide, the 8 tips for healthy eating, and
  portion guidance to plan healthy meals and evaluate diets. They also use food labels to
  help make better food and drink choices."""@en ;
  curric:whyThisWhyNow """Throughout life, a variety of factors affect the food and drink we choose,
  some of which are personal preferences, while others are cultural, linked to occasion, and
  where we are and who we are with. Building on previous work of Consumer awareness and Food
  culture threads in Year 6, pupils critique food choices and suggest alternatives. Looking
  forward to Year 8, pupils address the influence of ingredient availability, cooking technique
  and equipment on healthy eating, and explore the source and function of nutrients.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3402-1 ,
    oakcurric:priorknowledge-3402-2 ,
    oakcurric:priorknowledge-3402-3 ,
    oakcurric:priorknowledge-3402-4 ,
    oakcurric:priorknowledge-3402-5 ;
  curric:id "3402"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.270518Z"^^xsd:dateTime ;
