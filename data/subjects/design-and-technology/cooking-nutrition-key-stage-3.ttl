  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use the hob and oven, using oven gloves."@en ;
  dcterms:modified "2026-06-07T15:29:25.475071Z"^^xsd:dateTime .

oakcurric:priorknowledge-3403-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can sort foods into plant and animal origin, and name some 'farm to fork'
