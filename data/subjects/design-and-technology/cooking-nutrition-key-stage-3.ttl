oakcurric:priorknowledge-3409-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can maintain high standards of good personal hygiene and food safety,
  explaining its rationale."""@en ;
  dcterms:modified "2026-06-07T15:29:24.900495Z"^^xsd:dateTime .

oakcurric:priorknowledge-3409-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use a wide range of equipment and demonstrate a variety of food
  skills."""@en ;
  dcterms:modified "2026-06-07T15:29:24.900509Z"^^xsd:dateTime .

oakcurric:priorknowledge-3409-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use healthy eating messages to suggest changes to the ingredients and
  cooking method in a recipe."""@en ;
  dcterms:modified "2026-06-07T15:29:24.900515Z"^^xsd:dateTime .

oakcurric:priorknowledge-3409-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can talk about yeast producing carbon dioxide, which helps bread to rise."@en ;
  dcterms:modified "2026-06-07T15:29:24.900520Z"^^xsd:dateTime .

oakcurric:priorknowledge-3409-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that home-cooked dishes can be compared to shop-bought for a number of
  factors."""@en ;
  dcterms:modified "2026-06-07T15:29:24.900525Z"^^xsd:dateTime .

oakcurric:priorknowledge-3411-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupil can identify ways diets can be healthier and more sustainable."@en ;
  dcterms:modified "2026-06-07T15:29:24.902503Z"^^xsd:dateTime .

oakcurric:priorknowledge-3411-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can explain why the Eatwell Guide has a 32% lower environmental footprint
  than the current national diet."""@en ;
  dcterms:modified "2026-06-07T15:29:24.902515Z"^^xsd:dateTime .

oakcurric:priorknowledge-3411-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can modify recipes and diets to be healthier and more sustainable."@en ;
  dcterms:modified "2026-06-07T15:29:24.902521Z"^^xsd:dateTime .

oakcurric:priorknowledge-3411-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that we should all follow the Eatwell Guide, eat more fruit and
  vegetables and diversify sources of protein."""@en ;
  dcterms:modified "2026-06-07T15:29:24.902526Z"^^xsd:dateTime .

oakcurric:priorknowledge-3411-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can talk about the climate and how conditions affect when and where food is
  produced."""@en ;
  dcterms:modified "2026-06-07T15:29:24.902531Z"^^xsd:dateTime .

oakcurric:priorknowledge-3404-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils will know that different people eat different foods."@en ;
  dcterms:modified "2026-06-07T15:29:25.025762Z"^^xsd:dateTime .

oakcurric:priorknowledge-3404-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can list some factors that affect food choice."@en ;
  dcterms:modified "2026-06-07T15:29:25.025778Z"^^xsd:dateTime .

oakcurric:priorknowledge-3404-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils will know that we eat different food on different occasions and
  celebrations."""@en ;
  dcterms:modified "2026-06-07T15:29:25.025786Z"^^xsd:dateTime .

oakcurric:priorknowledge-3404-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify the key nutrients provided by a selection of foods."@en ;
  dcterms:modified "2026-06-07T15:29:25.025795Z"^^xsd:dateTime .

oakcurric:priorknowledge-3407-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can describe the food origins of ingredients in dishes and meals."@en ;
  dcterms:modified "2026-06-07T15:29:25.214360Z"^^xsd:dateTime .

oakcurric:priorknowledge-3407-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can name the origin of foods grown, reared or caught for consumption."@en ;
  dcterms:modified "2026-06-07T15:29:25.214372Z"^^xsd:dateTime .

oakcurric:priorknowledge-3407-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can talk about how food is sourced, processed and sold in different ways,
  helping to ensure it is edible and safe to eat."""@en ;
  dcterms:modified "2026-06-07T15:29:25.216413Z"^^xsd:dateTime .

oakcurric:priorknowledge-3407-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can describe the healthy eating messages of the Eatwell Guide and list its
  food groups."""@en ;
  dcterms:modified "2026-06-07T15:29:25.216428Z"^^xsd:dateTime .

oakcurric:priorknowledge-3410-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can describe the energy and nutrients provided by food and drinks, and their
  important functions for health."""@en ;
  dcterms:modified "2026-06-07T15:29:25.277346Z"^^xsd:dateTime .

oakcurric:priorknowledge-3410-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can modify recipes and cooking methods to help meet current healthy eating
  messages."""@en ;
  dcterms:modified "2026-06-07T15:29:25.277357Z"^^xsd:dateTime .

oakcurric:priorknowledge-3410-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use the Eatwell Guide, food portion and size, and 8 tips to evaluate and
  justify healthier changes to a diet."""@en ;
  dcterms:modified "2026-06-07T15:29:25.277363Z"^^xsd:dateTime .

oakcurric:priorknowledge-3410-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can read food labels, choosing those lower in fat, salt and sugars."@en ;
  dcterms:modified "2026-06-07T15:29:25.277368Z"^^xsd:dateTime .

oakcurric:priorknowledge-3410-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils will know that people have an allergy to specific ingredients, such as wheat
  flour, nuts and milk."""@en ;
  dcterms:modified "2026-06-07T15:29:25.277377Z"^^xsd:dateTime .

