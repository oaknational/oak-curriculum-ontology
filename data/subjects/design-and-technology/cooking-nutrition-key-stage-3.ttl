  dcterms:modified "2026-06-07T15:30:02.364919Z"^^xsd:dateTime .

oakcurric:keyword-membrane
  a curric:Keyword ;
  schema:name "membrane"@en ;
  schema:description "a thin sheet of tissue or layer of cells acting as a lining or partition"@en ;
