  dcterms:modified "2026-06-07T15:30:02.366205Z"^^xsd:dateTime .

oakcurric:keyword-informed
  a curric:Keyword ;
  schema:name "informed"@en ;
  schema:description "to make a decision based on having knowledge of a subject"@en ;
