  schema:name "cultural identity"@en ;
  schema:description """A part of a person’s identity, that can be grounded in their nationality,
  ethnicity, religion, social class or generation."""@en ;
  dcterms:modified "2026-06-07T15:30:02.418008Z"^^xsd:dateTime .

oakcurric:keyword-vitamins
  a curric:Keyword ;
  schema:name "vitamins"@en ;
  schema:description "organic micronutrients that are essential for the human body"@en ;
  dcterms:modified "2026-06-07T15:30:02.419605Z"^^xsd:dateTime .

oakcurric:keyword-food-source
  a curric:Keyword ;
  schema:name "food source"@en ;
  schema:description "food and drinks that provide specifi nutrients"@en ;
  dcterms:modified "2026-06-07T15:30:02.419611Z"^^xsd:dateTime .

oakcurric:keyword-intangible-cultural-heritage
  a curric:Keyword ;
  schema:name "intangible cultural heritage"@en ;
  schema:description "a tradition, practice, or living expression of a group or community"@en ;
  dcterms:modified "2026-06-07T15:30:02.420641Z"^^xsd:dateTime .

oakcurric:keyword-cultural-appropriation
  a curric:Keyword ;
  schema:name "cultural appropriation"@en ;
  schema:description """the unacknowledged or inappropriate adoption or use of elements of a
  minority culture by members of the dominant culture, often in a way that is disrespectful,
  stereotypical, or exploitative"""@en ;
  dcterms:modified "2026-06-07T15:30:02.420646Z"^^xsd:dateTime .

oakcurric:keyword-food-labels
  a curric:Keyword ;
  schema:name "food labels"@en ;
  schema:description "information that is provided on packaged food"@en ;
  dcterms:modified "2026-06-07T15:30:02.423613Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-food-hygiene-clean-preparing-cooking
  a curric:Misconception ;
  curric:statement """Food hygiene is only about being clean when preparing, cooking and storing
  food."""@en ;
  curric:correction """Food hygiene is necessary in order to prepare and cook food which is safe to
  eat. It involves the 4Cs: cleaning (including personal hygiene), cooking, chilling and
  preventing cross-contamination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093413Z"^^xsd:dateTime .

oakcurric:misconception-following-eatwell-guide-eating-healthily
  a curric:Misconception ;
  curric:statement "Following the Eatwell Guide is only about eating more healthily."@en ;
  curric:correction """While following the Eatwell Guide will help people eat more healthily, it
  also has a 32% lower environmental footprint, compared to the current national diet, so
  can help us eat more sustainably too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093497Z"^^xsd:dateTime .

oakcurric:misconception-make-conscious-food-choices-food
  a curric:Misconception ;
  curric:statement """We only make conscious food choices about what food we buy, cook and eat,
  based on a range of factors."""@en ;
  curric:correction """We make conscious and unconscious food choices about the food we buy, cook
  and eat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094146Z"^^xsd:dateTime .

oakcurric:misconception-making-two-recipes-same-time
  a curric:Misconception ;
  curric:statement """When making two recipes at the same time, you should cook them separately in
  order. This takes longer, but the recipes are made well."""@en ;
  curric:correction """When making two dishes at the same time, read both recipes first to decide
  which order to complete the steps in each recipe - this is known as dovetailing.
  Dovetailing results in a better use of time, where tasks fit together easily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095532Z"^^xsd:dateTime .

oakcurric:misconception-one-form-malnutrition-intakes-energy
  a curric:Misconception ;
  curric:statement """There is one form of malnutrition, intakes of energy and/or nutrients being
  below what is required."""@en ;
  curric:correction """There are two forms of malnutrition: undernutrition (intakes below what is
  required) and overnutrition (intakes above what is required)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096100Z"^^xsd:dateTime .

oakcurric:misconception-coeliac-disease-caused-reaction-gluten
  a curric:Misconception ;
  curric:statement "Coeliac disease is caused by a reaction to gluten in wheat flour only."@en ;
  curric:correction """Coeliac disease is caused by a reaction to gluten (a protein), which is found
  in flours from wheat, barley and rye."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097990Z"^^xsd:dateTime .

oakcurric:misconception-think-shortcrust-pastry-works-best
  a curric:Misconception ;
  curric:statement """Some might think that shortcrust pastry works best when the butter (or baking
  fat) and water used are warm, not cold."""@en ;
  curric:correction """Make sure the butter or baking fat is cold, and that pupils use cold water,
  this helps to ensure that the pastry works better. When rubbing-in the fat to the flour,
  use fingertips only, as less heat is passed from the hands to the fat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099737Z"^^xsd:dateTime .

oakcurric:misconception-recipes-cannot-modified-different-budgets
  a curric:Misconception ;
  curric:statement """Recipes cannot be modified for different budgets, as the stated ingredients
  must always be used."""@en ;
  curric:correction """Recipes can be modified for different budgets, using a number of strategies,
  such as comparing costs, buying own-brand items, and using seasonal fruit and vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104726Z"^^xsd:dateTime .

oakcurric:misconception-dishes-cook-eat-serve-along
  a curric:Misconception ;
  curric:statement """The dishes we cook, eat and serve, along with our food experiences, have
  stayed the same over time."""@en ;
  curric:correction """The dishes we cook, eat and serve, along with our food experiences, continue
  to evolve (change over time) due to a variety of factors, such as history, culture, social
  media and health."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107048Z"^^xsd:dateTime .

oakcurric:misconception-flour-used-make-bread-like
  a curric:Misconception ;
  curric:statement "Any flour can be used to make a bread-like dough."@en ;
  curric:correction """Although most flours will produce a dough, a strong flour is recommended as
  it is high in protein (gluten), which is needed to help trap the air and form the bread
  structure when baked."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117942Z"^^xsd:dateTime .

oakcurric:misconception-one-method-produces-poor-results
  a curric:Misconception ;
  curric:statement """The 'all-in-one' method produces poor results, as the ingredients are not
  creamed together and/or whisked."""@en ;
  curric:correction """The 'all-in-one method' is a quicker cake making method, producing good
  results. Using self-raising flour and mixing throughly ensure the cakes rise well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119190Z"^^xsd:dateTime .

oakcurric:misconception-potatoes-form-part-our-5
  a curric:Misconception ;
  curric:statement "Potatoes can form part of our 5 A DAY."@en ;
  curric:correction """Potatoes do not count towards our 5 A DAY. They are a starchy carbohydrate in
  the Eatwell Guide."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119866Z"^^xsd:dateTime .

oakcurric:misconception-vegetables-fruit-need-washed-use
  a curric:Misconception ;
  curric:statement """Vegetables and fruit do not need to be washed before use as they look clean or
  have been taken from a packet."""@en ;
  curric:correction """Vegetables and fruit should be washed thoroughly before use. This removes
  dirt (soil/grit), insects and bacteria which could cause food poisoning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120598Z"^^xsd:dateTime .

oakcurric:misconception-food-lessons-cooking
  a curric:Misconception ;
  curric:statement "Food lessons are just cooking."@en ;
  curric:correction """Food lessons include cooking, which is important, but also applying healthy
  eating, where food comes from, safety (preventing accidents) and hygiene (making sure food
  is safe to eat), science, and consumer and food culture. Food is who we are."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120680Z"^^xsd:dateTime .

oakcurric:misconception-roux-sauce-liquid-milk-added
  a curric:Misconception ;
  curric:statement """A roux sauce can have all the liquid (milk) added at the same time, and
  whisked occasionally."""@en ;
  curric:correction """A roux sauce must have the liquid (milk) added gradually, and the sauce
  should be whisked continually to prevent lumps."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120732Z"^^xsd:dateTime .

oakcurric:misconception-uk-produces-its-own-food
  a curric:Misconception ;
  curric:statement "The UK produces all of its own food."@en ;
  curric:correction """The UK produces 58% of the food it consumes, 42% is imported from other
  countries. This is due to season, cost, climate, and to add variety to the diet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122932Z"^^xsd:dateTime .

oakcurric:misconception-baking-tins-need-greased-lined
  a curric:Misconception ;
  curric:statement "Baking tins do not need to be greased and/or lined."@en ;
  curric:correction """It is important to grease (with oil) or line (with greaseproof paper) a
  baking tin, as this acts as a barrier and prevents the food from sticking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124118Z"^^xsd:dateTime .

oakcurric:misconception-sushi-raw-fish-common-food
  a curric:Misconception ;
  curric:statement "Sushi, raw fish, is the only common food eaten in Japan."@en ;
  curric:correction """Japan has huge range of foods and dishes, of which sushi is one important
  aspect. There is a range of cooked dishes, including yakisoba (noodles), teriyaki (grilled
  with a glaze), yakiniku (grilled meat), and tempura (battered fried foods)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124129Z"^^xsd:dateTime .

oakcurric:misconception-beans-count-many-portions-towards
  a curric:Misconception ;
  curric:statement """Beans can count as many portions towards 5 A DAY, depending on the number of
  portions eaten."""@en ;
  curric:correction """Beans count as a maximum of one portion of 5 A DAY, no matter how much is
  eaten."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124201Z"^^xsd:dateTime .

oakcurric:misconception-eat-less-starchy-foods-fattening
  a curric:Misconception ;
  curric:statement """We should eat less starchy foods, as these are 'fattening' in the diet and
  provide little else."""@en ;
  curric:correction """Starchy foods should make up just over a third of the diet, as they are an
  important source of energy, fibre and micronutrients."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125007Z"^^xsd:dateTime .

oakcurric:misconception-traditional-fried-falafel-healthy-made
  a curric:Misconception ;
  curric:statement "Traditional fried falafel is healthy, as it is made from chickpeas."@en ;
  curric:correction """While the chickpeas are a healthy choice, falafel is usually deep-fried, so
  less healthy. Alternative cooking methods could be used which use less oil, such as
  grilling, baking, or air-frying."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125253Z"^^xsd:dateTime .

oakcurric:misconception-biodiversity-important-growing-food-plants
  a curric:Misconception ;
  curric:statement """Biodiversity is not important in growing food, only the plants growing are
  important."""@en ;
  curric:correction """Biodiversity is important in growing food by promoting a healthy and balanced
  ecosystem, e.g. encouraging insects and birds to live near fields can help keep pests
  under control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125787Z"^^xsd:dateTime .

oakcurric:misconception-eating-limited-range-fish-sustainable
  a curric:Misconception ;
  curric:statement """Eating a limited range of fish is sustainable, as fewer species are
  caught."""@en ;
  curric:correction """80% of the fish we eat comes from five species, which puts pressure on these
  fish stocks. We should eat a wider variety of fish to ensure more sustainable supplies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134244Z"^^xsd:dateTime .

oakcurric:misconception-leftovers-still-safe-eat-3
  a curric:Misconception ;
  curric:statement """Leftovers will still be safe to eat after 3 - 4 days, as they still
  look good."""@en ;
  curric:correction """Leftovers should be used within 48 hours from when it was made (24 hours for
  rice dishes). Longer periods of time increase the risk of food poisoning bacteria
  multiplying."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134956Z"^^xsd:dateTime .

oakcurric:misconception-sponge-cake-same
  a curric:Misconception ;
  curric:statement "A sponge and cake are the same."@en ;
  curric:correction """Often the term ‘sponge’ and ‘cake’ are used interchangeably. However, sponges
  are traditionally made from eggs, flour and sugar (no butter), e.g. Swiss roll, and cakes
  are made from eggs, flour, sugar and butter, e.g. lemon drizzle cake."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138997Z"^^xsd:dateTime .

oakcurric:misconception-rice-stirred-cooked-ensure-covered
  a curric:Misconception ;
  curric:statement "Rice should be stirred when cooked, so ensure it is covered in liquid."@en ;
  curric:correction """It is best not to stir most rice dishes. Stirring breaks the rice and
  releases starch, making the rice feel mushy and ‘over cooked’. Risotto is stirred though,
  as the starch helps the dish have a creamy texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139005Z"^^xsd:dateTime .

oakcurric:misconception-eatwell-guide-recommends-plant-rich
  a curric:Misconception ;
  curric:statement "The Eatwell Guide recommends a plant-rich, non-meat diet."@en ;
  curric:correction """The Eatwell Guide recommends that we should have a plant-rich diet and reduce
  the amount of red and processed meat, if we eat too much."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139017Z"^^xsd:dateTime .

oakcurric:misconception-scotch-eggs-originate-scotland
  a curric:Misconception ;
  curric:statement "Scotch eggs originate from Scotland."@en ;
  curric:correction """While its name may sound Scottish, the Scotch egg has origins in 1738 London
  (a snack for travellers), India (nargisi kofta), and Yorkshire (a fish version)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140567Z"^^xsd:dateTime .

oakcurric:misconception-food-placed-fridge-need-covered
  a curric:Misconception ;
  curric:statement """If a food is placed in the fridge, there is no need for it to be covered or
  placed in a container, as the fridge is a cold and safe storage area."""@en ;
  curric:correction """All food placed in the fridge must be covered or placed in a container to
  prevent cross contamination with other foods, preventing food poisoning. It also helps to
  stop the food drying out."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141032Z"^^xsd:dateTime .

oakcurric:misconception-dietary-reference-values-drvs-nutritional
  a curric:Misconception ;
  curric:statement """Dietary Reference Values (DRVs), nutritional requirements, are intended for
  individual healthy people."""@en ;
  curric:correction """Dietary Reference Values (DRVs), nutritional requirements, are intended for
  different groups of healthy people. They are a series of estimates of the energy and
  nutrients required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147361Z"^^xsd:dateTime .

oakcurric:misconception-everyone-needs-same-amount-portion
  a curric:Misconception ;
  curric:statement "Everyone needs the same amount, or portion, of food."@en ;
  curric:correction """Everyone needs slightly different amounts of food, depending on their age and
  activity levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148225Z"^^xsd:dateTime .

oakcurric:misconception-plant-rich-means-eat-meat
  a curric:Misconception ;
  curric:statement """Plant-rich means that we should not eat meat or dairy foods for healthier and
  more sustainable diets."""@en ;
  curric:correction """It is not necessary to cut out meat or dairy from our diet completely for
  healthier and more sustainable diets. Follow the Eatwell Guide: have plenty of fruit and
  veg; diversify sources of protein; and limit foods high in fat, salt and sugars."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149261Z"^^xsd:dateTime .

oakcurric:misconception-food-eat-produced-uk
  a curric:Misconception ;
  curric:statement "Most of the food we eat is produced in the UK."@en ;
  curric:correction """About 54% of the food on our plates is produced in the UK, the rest is
  imported from other countries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149632Z"^^xsd:dateTime .

oakcurric:misconception-adequate-intake-micronutrients-possible-eating
  a curric:Misconception ;
  curric:statement """An adequate intake of micronutrients is possible by always eating the same
  types of foods."""@en ;
  curric:correction """To ensure an adequate intake of micronutrients, it is important to have a
  varied diet. This is because different foods provide different types and amounts of
  vitamins and minerals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159608Z"^^xsd:dateTime .

oakcurric:misconception-cultural-appropriation-appreciation-admiration-other
  a curric:Misconception ;
  curric:statement """Cultural appropriation is just appreciation and admiration of other
  cultures."""@en ;
  curric:correction """Cultural appropriation can be the unacknowledged or inappropriate adoption or
  use of elements of a minority culture by members of the dominant culture, often in a way
  that is disrespectful, stereotypical, or exploitative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160827Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-name-food-group
  a curric:Misconception ;
  curric:statement """Pupils often believe that the name of a food group from the Eatwell Guide is
  also the name of a nutrient."""@en ;
  curric:correction """A food group from the Eatwell Guide includes foods that contain various
  nutrients."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164274Z"^^xsd:dateTime .
