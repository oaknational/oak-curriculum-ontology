# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-criteria
  a curric:Keyword ;
  schema:name "criteria"@en ;
  schema:description "the rules or guidelines used to judge or decide something"@en ;
  dcterms:modified "2026-06-07T15:30:02.347905Z"^^xsd:dateTime .

oakcurric:keyword-bacteria
  a curric:Keyword ;
  schema:name "bacteria"@en ;
  schema:description "Bacteria are single-celled prokaryotes."@en ;
  dcterms:modified "2026-06-07T15:30:02.349433Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "a long-term change in Earth’s climate patterns"@en ;
  dcterms:modified "2026-06-07T15:30:02.350396Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
  environment or reducing resources for future generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352314Z"^^xsd:dateTime .

oakcurric:keyword-component
  a curric:Keyword ;
  schema:name "component"@en ;
  schema:description "A component refers to a part of something, e.g. a tyre on a car."@en ;
  dcterms:modified "2026-06-07T15:30:02.353929Z"^^xsd:dateTime .

oakcurric:keyword-function
  a curric:Keyword ;
  schema:name "function"@en ;
  schema:description "the purpose of the product"@en ;
  dcterms:modified "2026-06-07T15:30:02.354479Z"^^xsd:dateTime .

oakcurric:keyword-food-security
  a curric:Keyword ;
  schema:name "food security"@en ;
  schema:description """when people lack secure access to sufficient amounts of safe and nutritious
  food for normal growth and development and an active and healthy life"""@en ;
  dcterms:modified "2026-06-07T15:30:02.357146Z"^^xsd:dateTime .

oakcurric:keyword-carbon-dioxide
  a curric:Keyword ;
  schema:name "carbon dioxide"@en ;
  schema:description """a compound with molecules that each contain one carbon atom and two oxygen
  atoms"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358478Z"^^xsd:dateTime .

oakcurric:keyword-energy
  a curric:Keyword ;
  schema:name "energy"@en ;
  schema:description "the ability to perform activities and sustain effort"@en ;
  dcterms:modified "2026-06-07T15:30:02.358670Z"^^xsd:dateTime .

oakcurric:keyword-hydration
  a curric:Keyword ;
  schema:name "hydration"@en ;
  schema:description """having the appropriate level of water in the body for it to function
  optimally, when this level of water falls below optimal levels it is referred to as
  dehydration"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358675Z"^^xsd:dateTime .

oakcurric:keyword-import
  a curric:Keyword ;
  schema:name "import"@en ;
  schema:description "goods and services brought in from another country"@en ;
  dcterms:modified "2026-06-07T15:30:02.361160Z"^^xsd:dateTime .

oakcurric:keyword-export
  a curric:Keyword ;
  schema:name "export"@en ;
  schema:description "goods and services sold to another country"@en ;
  dcterms:modified "2026-06-07T15:30:02.361164Z"^^xsd:dateTime .

oakcurric:keyword-convection
  a curric:Keyword ;
  schema:name "convection"@en ;
  schema:description """the transfer of heat through the movement of fluids: warmer, less dense
  material rises and cooler, denser material sinks, creating a circular flow"""@en ;
  dcterms:modified "2026-06-07T15:30:02.363039Z"^^xsd:dateTime .

oakcurric:keyword-culture
  a curric:Keyword ;
  schema:name "culture"@en ;
  schema:description "the shared ideas, customs, and art of a group of people"@en ;
  dcterms:modified "2026-06-07T15:30:02.364173Z"^^xsd:dateTime .

oakcurric:keyword-cuisine
  a curric:Keyword ;
  schema:name "cuisine"@en ;
  schema:description "a style or method of cooking in a certain country or region"@en ;
  dcterms:modified "2026-06-07T15:30:02.364698Z"^^xsd:dateTime .

oakcurric:keyword-diet
  a curric:Keyword ;
  schema:name "diet"@en ;
  schema:description "all the food and drink we consume"@en ;
  dcterms:modified "2026-06-07T15:30:02.364710Z"^^xsd:dateTime .

oakcurric:keyword-fakeaway
  a curric:Keyword ;
  schema:name "fakeaway"@en ;
  schema:description "a meal that looks and tastes like a takeaway, but is made at home"@en ;
  dcterms:modified "2026-06-07T15:30:02.364874Z"^^xsd:dateTime .

oakcurric:keyword-cornflour
  a curric:Keyword ;
  schema:name "cornflour"@en ;
  schema:description "finely ground maize, used for thickening sauces"@en ;
  dcterms:modified "2026-06-07T15:30:02.364879Z"^^xsd:dateTime .

oakcurric:keyword-4cs
  a curric:Keyword ;
  schema:name "4Cs"@en ;
  schema:description """an acronym that highlights fours areas of food hygiene: cleaning, cooking,
  chilling and cross-contamination"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364884Z"^^xsd:dateTime .

oakcurric:keyword-gelatinisation
  a curric:Keyword ;
  schema:name "gelatinisation"@en ;
