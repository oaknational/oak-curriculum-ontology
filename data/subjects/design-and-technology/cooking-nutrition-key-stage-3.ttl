# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-25028-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sweet and sour dishes originated in China, then the UK. London had its first Chinese
  restaurant in 1907."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25028-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make sweet & sour are measuring, slicing, chopping, peeling,
  mixing and using the hob."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25028-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cornflour, a starch from maize, thickens the sauce through the action of heat and
  liquid (gelatinisation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25028-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 4Cs of food hygiene are cleaning, cooking, chilling, and
  cross-contamination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25028-5
  a curric:KeyLearningPoint ;
  rdfs:label """Compared to takeaways, cooking from scratch is often cheaper and the levels of fat,
  salt and sugars can be controlled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25034-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bang bang chicken originates in the street food of Sichuan. Other types of meat and
  vegetables can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25034-2
  a curric:KeyLearningPoint ;
  rdfs:label """Care should be taken when preparing fresh chillies as the membrane and seeds are hot
  and may burn. Always wash hands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diets should have more, and a wider range of, fruit, vegetables, beans, lentils and
  legumes for more sustainable living."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25034-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make bang bang veg include measuring, slicing, mixing,
  coating, threading and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25034-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are a range of sensory tests; the results can be used to justify changes to a
  recipe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25011-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a range of factors affecting food choice, including preference, religion,
  health, location, culture and money."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25011-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food choice depends on many personal and lifestyle factors, such as body image and
  role models, as well advertising."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25011-3
  a curric:KeyLearningPoint ;
  rdfs:label """The eating occasion and location, as well as who we eat with, can change our food
  choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25011-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food labels can be used to make informed food choices, such as nutrition and allergy
  labelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25011-5
  a curric:KeyLearningPoint ;
  rdfs:label """When planning to cook, the time available, cost of ingredients, and food skill
  experience should be considered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25021-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different types of beans, cultivated around the world. They are a
  source of protein and fibre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25021-2
  a curric:KeyLearningPoint ;
  rdfs:label """When making two dishes, read both recipes to ensure efficient use of time via
  dovetailing tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25021-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used for bean burgers include measuring, mashing, dicing, mixing,
  shaping and using the hob and grill."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25021-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cooking from scratch allows the amount of fat, salt and sugars to be controlled,
  compared to shop bought."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25021-5
  a curric:KeyLearningPoint ;
  rdfs:label """Front and back of pack nutrition information, and ingredient lists, allows consumers
  to make informed food choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Health implications are caused by poor diet (dietary excess or deficiency), e.g.
  obesity, bone health, heart disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25030-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nutrition, ingredient and allergy information on food labels help us to make
  informed food and drink choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25030-3
  a curric:KeyLearningPoint ;
  rdfs:label """Meals and diets can be planned and evaluated for the needs of different groups of
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25015-1
  a curric:KeyLearningPoint ;
  rdfs:label """Focaccia is an Italian bread flavoured with olive oil and herbs, and sometimes
  olives and sundried tomatoes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25015-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many types of bread which can form the basis for other dishes, such as
  pizza bases, Chelsea buns and pretzels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25015-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make focaccia are measuring, mixing, kneading, shaping and
  using the oven (baking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25015-4
  a curric:KeyLearningPoint ;
  rdfs:label """Yeast produces carbon dioxide which helps the bread to rise. The gas is held in the
  dough when baked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25015-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some people have an allergy to specific ingredients, such as wheat flour, nuts and
  milk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25009-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quiches are savoury tarts, comprising a pastry crust and a filling of eggs and milk
  and/or cream, with roots in France."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25009-2
  a curric:KeyLearningPoint ;
  rdfs:label """During cooking, the pastry becomes crisp (due to the fat in the flour) and the egg
  mixture sets (known as coagulation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25009-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eggs that have the British Lion mark have been produced to ensure high levels of
  food safety and traceability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25009-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make tarts are measuring, rubbing-in, rolling-out, forming,
  cutting, lining and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25009-5
  a curric:KeyLearningPoint ;
  rdfs:label "The outcome of a final dish can be judged by a set of criteria."@en ;
  dcterms:modified "2026-06-07T15:30:29.293828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Katsu curry is a traditional Japanese dish of a pork cutlet (tonkatsu), served with
  rice and curry sauce."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25026-2
  a curric:KeyLearningPoint ;
  rdfs:label """In line with the Eatwell Guide, we should have a plant-rich, diverse and balanced
  diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25026-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food skills used to make katsu curry include measuring, mixing, peeling, slicing,
  coating, and using the hob and oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25026-4
  a curric:KeyLearningPoint ;
  rdfs:label """High standards of personal hygiene and safe food handling must be demonstrated at
  all times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25026-5
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes and cooking methods can be modified to help meet current healthy eating
  messages and different budgets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25037-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cooking with jerk spice (jerking) originated from indigenous people from
  Jamaica."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25037-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dishes we cook, eat and serve, along with our food experiences, continues to
  evolve due to a variety of factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a timeplan ensures more efficient use of time when preparaing a dish or
  meal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25037-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make jerk veg curry are measuring, peeling, slicing,
  draining, mixing and using the hob."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25037-5
  a curric:KeyLearningPoint ;
  rdfs:label """Food skills can be assessed for accuracy and precision, highlighting areas of
  further development."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25027-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chelsea buns date back to the 18th century and were created in the Chelsea area of
  London by the Chelsea Bun House."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25027-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gluten, a protein, is formed from flour when liquid is added and the dough is
  kneaded, making it elastic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25027-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Chelsea buns include measuring, mixing, kneading,
  rolling, cutting and using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25027-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are three main forms of heat transfer, which affect food in different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25027-5
  a curric:KeyLearningPoint ;
  rdfs:label """A final dish can be judged by a set of success criteria, including sensory
  attributes, cost and nutrition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25010-1
  a curric:KeyLearningPoint ;
  rdfs:label """The origins of carrot cake are from medieval cooking of puddings. It was revived due
  to rationing in World War II."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25010-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cakes rise due to self-raising flour (chemical raising agent) and beaten eggs, with
  the action of whisking (adding air)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25010-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cakes cook in an oven via convection (circulation of hot air) and conduction (the
  cake mix touching the metal tin)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25010-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make mini carrot cakes are measuring, grating, zesting,
  juicing and using the oven (baking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25010-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ingredients in a recipe can be traced to their origins, such as flour from UK wheat,
  or oranges from Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aloo gobi is a vegetarian dish originating from India, comprising potato,
  cauliflower and spices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25007-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Eatwell Guide recommends to have a plant rich diet."@en ;
  dcterms:modified "2026-06-07T15:30:29.351267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25007-3
  a curric:KeyLearningPoint ;
  rdfs:label """UK cauliflower is grown and harvested all year. Frozen cauliflower could be used, as
  this is often cheaper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25007-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make aloo gobi are measuring, peeling, cutting, stirring,
  and using the hob (heat control)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25007-5
  a curric:KeyLearningPoint ;
  rdfs:label """The results from sensory tests and other feedback helps to justify future changes to
  a recipe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Leeks are the national emblem of Wales, and are in season from September to March.
  The soup is called Cawl Cennin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25003-2
  a curric:KeyLearningPoint ;
  rdfs:label """A recipe gives instructions of how to make a dish. It usually lists title,
  ingredients, equipment and method."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25003-3
  a curric:KeyLearningPoint ;
  rdfs:label """A blender purees the pieces of potato and leek into a smooth soup. Care must be
  taken as the blades are sharp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25003-4
  a curric:KeyLearningPoint ;
  rdfs:label """The potatoes and leeks cook in the soup through the transfer of heat from the
  liquid, known as convection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25003-5
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a leek and potato soup are measuring, peeling, slicing,
  using the hob and blending."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25002-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food is deeply ingrained in our cultural heritage by an ingredient, a national dish,
  or traditions and celebrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25002-2
  a curric:KeyLearningPoint ;
  rdfs:label """In specialist food rooms there are procedures that must be followed to ensure safe
  and hygienic preparation and cooking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25002-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different pieces of equipment available in specialist food rooms.
  Some have specific functions and uses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25002-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a mini deli salad are cutting (bridge hold and claw
  grip techniques), grating and layering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25002-5
  a curric:KeyLearningPoint ;
  rdfs:label """Washing up and wiping work surfaces, prevents bacteria from spreading that could
  cause food poisoning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25016-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different pasta, vegetables and cheeses can be used. Cheese is made from milk, which
  can be from a cow, sheep or goat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes can be modified to help meet healthy eating messages, such as using reduced
  fat cheese and adding extra veg."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25016-3
  a curric:KeyLearningPoint ;
  rdfs:label """Starch granules in flour swell and thicken when in liquid and heated, a process
  called gelatinisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25016-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make mac & cheese are measuring, grating, slicing, using the
  hob and grill and draining."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Home-cooked and shop-bought dishes can be compared, such as cost, food skills,
  convenience, taste and health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25023-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a wide range of cuisines, ingredients, cooking techniques and equipment
  used around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25023-2
  a curric:KeyLearningPoint ;
  rdfs:label """58% of food consumption comes from the UK, 23% from the EU and 19% worldwide, due to
  season, cost, climate and variety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25023-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ingredients produced in the UK can be used to prepare a range of dishes, although
  some ingredients need to be imported."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25023-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages to buying food locally and seasonally in the UK, such as
  reduced environmental impact and cost."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25023-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reducing the amount of food wasted at each stage of the farm to fork journey has
  financial and environmental benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25012-1
  a curric:KeyLearningPoint ;
  rdfs:label """Uniquely, a Chicago pizza has a deep-dish crust, allowing for extra sauce and
  toppings. It appeared in the USA in 1943."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25012-2
  a curric:KeyLearningPoint ;
  rdfs:label """The baking dish or tin should be greased with oil and/or lined, acting as a barrier
  to prevent sticking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25012-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a Chicago style pizza are measuring, rubbing-in,
  forming a dough, and using an oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25012-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make a dish more quickly, ready-made components can be used, e.g. ready grated
  cheese, tomato topping, pizza base."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25012-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can judge independent and confident use of food skills when cooking and suggest
  improvements for the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25004-1
  a curric:KeyLearningPoint ;
  rdfs:label """Originating from China, yakisoba is now a staple in Japan. It is a popular street
  food. 'Yaki' means cooked over heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25004-2
  a curric:KeyLearningPoint ;
  rdfs:label "Good food hygiene is essential to reduce the risk of food poisoning."@en ;
  dcterms:modified "2026-06-07T15:30:29.361614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25004-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills to make yakisoba are measuring, peeling, slicing, mixing and using
  the hob (stir-frying)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25004-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vegetables need to be cut to the same size to ensure even cooking (via conduction in
  the frying pan or wok)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25004-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory evaluation provides feedback about the appearance, odour, taste and texture
  of a final dish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25014-1
  a curric:KeyLearningPoint ;
  rdfs:label """Burritos are from Mexico. Enchiladas are similar, different wrap and covered spicy
  sauce, and chimichangas are fried."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beans form part of 5 A DAY, counting as a maximum of 1 portion, no matter how much
  is eaten. A portion is 3 tablespoons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25014-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make cheesy bean burritos are measuring, grating, cutting,
  mixing, folding and using the hob."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cross-contamination of bacteria, spread between food, surfaces, hands and/or
  equipment, must be avoided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25014-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy and nutrients provided by a recipe can be calculated, and suggestions for
  improvements made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food and drinks provide energy and nutrients in different amounts, and have
  important functions for health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25017-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrate, protein and fat are macronutrients and have different functions and
  sources. They provide energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25017-3
  a curric:KeyLearningPoint ;
  rdfs:label """To maintain body weight we need to balance energy intake (from food and drink) with
  energy expenditure (from activity)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25017-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fibre is needed to keep our digestive system healthy. It is important to eat a
  variety of fibre-containing foods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25017-5
  a curric:KeyLearningPoint ;
  rdfs:label """We need water for a variety of functions, such as regulating body temperature and
  being physically active."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25031-1
  a curric:KeyLearningPoint ;
  rdfs:label """The origins of falafel can be traced back to Egypt. They feature in Middle Eastern
  cuisine and are based on chickpeas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25031-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recipes and cooking methods can be modified to help meet current healthy eating
  messages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25031-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make falafel include measuring, draining, using a food
  processor and grill, and dividing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25031-4
  a curric:KeyLearningPoint ;
  rdfs:label """Any food allergy or intolerances must be considered, with recipes and ingredients
  being adjusted accordingly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25031-5
  a curric:KeyLearningPoint ;
  rdfs:label """Food processors can chop, slice and grate large quantities of food quickly. Care
  must be taken as the blades are sharp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25032-1
  a curric:KeyLearningPoint ;
  rdfs:label """Globally, food production produces around one-third of all greenhouse gas
  emissions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25032-2
  a curric:KeyLearningPoint ;
  rdfs:label """The global population is expected to reach 10 billion by 2050, putting additional
  pressure on food systems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change can cause extreme or unusual weather, which can affect food
  production and impact food security."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25032-4
  a curric:KeyLearningPoint ;
  rdfs:label """The environmental impact of food varies, but there are principles that can be
  followed for more sustainable diets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable diets are good for the planet and health, balancing nutrition,
  environment and socio-economic factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25033-1
  a curric:KeyLearningPoint ;
  rdfs:label """Street foods are world-wide, offering regional and international foods for immediate
  consumption."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25033-2
  a curric:KeyLearningPoint ;
  rdfs:label """80% of the fish consumed in the UK is from five species. We should have a wider
  variety, including fish from UK waters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25033-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are different quality assurance marks to help inform decisions, e.g. MSC."@en ;
  dcterms:modified "2026-06-07T15:30:29.385380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25033-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make fish wraps include measuring, mixing, coating, using
  the oven and presenting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25033-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fish is dipped in flour, egg and breadcrumbs to form a coat. Cooking coagulates the
  egg adhering the crumbs to the fish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25022-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cottage pie is usually made with beef and topped with potato, and dates to the 18th
  century. Shepherd's pie uses lamb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25022-2
  a curric:KeyLearningPoint ;
  rdfs:label """To diversify protein sources, a mix of meat and beans, pulses and/or legumes can be
  used. This also increases fibre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25022-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria can quickly spread betwee raw meat and hands. Before and after handling raw
  meat, hands must be washed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25022-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make cottage pie include measuring, peeling, dicing,
  mashing, piping, and using the hob/grill."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25022-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are a number potential sources of food safety/poisoning contamination when
  storing, preparing and cooking food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25024-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Victoria sponge, also known as cake, was named after Queen Victoria, and was
  popular with afternoon tea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cakes rise due to the action of creaming butter and sugar together, and the use of
  self-raising flour and beaten eggs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25024-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a cake are measuring, creaming, folding, portioning,
  using an oven and spreading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25024-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cakes baked in smaller tins and cases cook more quickly as the heat can transfer
  more easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25024-5
  a curric:KeyLearningPoint ;
  rdfs:label """Discrimination tests rate the intensity of sensory attributes and can be used to
  compare similar dishes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jollof rice is a popular rice dish from West Africa. There are regional variations,
  such as from Nigeria and Ghana."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heat from the stock (water) cooks and softens the rice. The rice grains absorb water
  and swell, making it soft to eat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25013-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Jollof rice include: measuring, peeling, deseeding,
  cutting, blending and using the hob."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25013-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory preference tests are used to evaluate food, highlighting likes and dislikes.
  This can be used to improve work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25019-1
  a curric:KeyLearningPoint ;
  rdfs:label """Toad in the hole is a traditional English dish of sausages in Yorkshire pudding,
  dating back to the 18th Century."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25019-2
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make toad in the hole are measuring, cutting, whisking and
  using the oven."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25019-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell Guide recommends choosing lean cuts of meat and to eat less processed
  meat, like bacon, sausages and salami."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25019-4
  a curric:KeyLearningPoint ;
  rdfs:label """Steam from milk and eggs makes the batter rise. The egg acts as an emulsifier,
  binding the ingredients together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25036-1
  a curric:KeyLearningPoint ;
  rdfs:label """The origin of a Scotch egg are mixed: inspired by Indian koftas; invented for
  travellers; and originating in London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25036-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food is sometimes eaten on specific occasions, such as snacks, starters and picnics.
  This might change over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25036-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should try to choose a range of protein foods, such as beans and pulses, as well
  as meat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25036-4
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make Scotch eggs include measuring, using the hob and oven,
  mixing, forming and coating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers can appraise food labelling information for ingredients used, food
  traceability, and animal welfare."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25025-1
  a curric:KeyLearningPoint ;
  rdfs:label """Thai curry is a dish in Thai cuisine made from curry paste, coconut milk or water,
  meat or fish, and vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25025-2
  a curric:KeyLearningPoint ;
  rdfs:label "Food leftovers can be used in recipes safely, helping to reduce food waste."@en ;
  dcterms:modified "2026-06-07T15:30:29.402280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25025-3
  a curric:KeyLearningPoint ;
  rdfs:label """The food skills used to make a Thai curry are measuring, peeling, slicing, mixing,
  using the hob and presenting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ambient, fresh and frozen foods should be stored, cooked, chilled and/or reheated
  properly to ensure food safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Cooking technique and proficiency can be rated, allowing for improvements in the
  future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25029-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dietary needs change at key age and life stages."@en ;
  dcterms:modified "2026-06-07T15:30:29.416325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some people have an allergy or intolerance to specific foods. 14 major allergens are
  listed on food packaging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25029-3
  a curric:KeyLearningPoint ;
  rdfs:label """Portion sizes change through life. There are consequences of excess (servings of
  food and their portion size)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25029-4
  a curric:KeyLearningPoint ;
  rdfs:label "Recipes and meals can be adapted for different dietary requirements."@en ;
  dcterms:modified "2026-06-07T15:30:29.416337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25006-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diet is the food and drink that a person usually eats over a period of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.418971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25006-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell Guide and the 8 tips for healthy eating set out the principles for a
  varied, balanced diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25006-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a suggested number of daily portions needed from each Eatwell Guide food
  group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25006-4
  a curric:KeyLearningPoint ;
  rdfs:label """Portion size is an amount of food eaten. While the types of food we need are
  similar, the amount we needed varies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25006-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell Guide, 8 tips, and food portion and size, can be used to evaluate and
  justify healthier changes to a diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25020-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell Guide has a 32% lower environmental footprint than the current national
  diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25020-2
  a curric:KeyLearningPoint ;
  rdfs:label "Recipes can be modified to support healthier and more sustainable diets."@en ;
  dcterms:modified "2026-06-07T15:30:29.421892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25020-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should all follow the Eatwell Guide, have a more plant-rich diet, and diversify
  sources of protein."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25020-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should limit foods high in fat, salt and sugar; choose sustainable fish; and
  waste less food and drink."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25020-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reducing the amount of food waste at each stage of the 'farm to fork' journey has
  financial and environmental benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25008-1
  a curric:KeyLearningPoint ;
  rdfs:label """All food produced, processed and consumed around the world must be grown, reared or
  caught."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food is sourced, processed and sold in different ways, helping to ensure it is
  edible and safe to eat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25008-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dishes and meals can be traced back to their food origins, including geographic
  location and season."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25008-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food labels must show where the food originates. Other labels may be added for
  additional assurances, e.g. Red Tractor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25008-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ingredients in a recipe can be modified for origin, such as location, farming
  practice and ethics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25018-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vitamins and minerals are known as micronutrients. They are needed in small amounts
  compared to macronutrients."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Our diet provides vitamins and minerals, except vitamin D, which we make in our skin
  when exposed to sunlight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25018-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vitamins include A, C and D, and the minerals include calcium and iron. They have
  different functions and food sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25018-4
  a curric:KeyLearningPoint ;
  rdfs:label """Energy and nutrients provided by a recipe can be calculated, and changes can be made
  to improve health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25035-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food is deeply ingrained in cultural identity, passing on intangible cultural
  heritage from generation to generation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25035-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food culture is the set of beliefs, attitudes, and practices related to producing
  and consuming food, which can change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25035-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional food, cooking and customs form cultural identity, representing our
  heritage, history and values."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food plays a significant role in social interactions and rituals, often being
  associated to celebrations and gatherings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25035-5
  a curric:KeyLearningPoint ;
  rdfs:label """Chefs and others take inspiration from their own food culture, and others, creating
  dishes and honouring heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25005-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell Guide depicts the food and drinks required for a healthy, balanced diet,
  as well as foods to restrict."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25005-2
  a curric:KeyLearningPoint ;
  rdfs:label """We need a variety of foods in each food group to provide a range of nutrients which
  have different functions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25005-3
  a curric:KeyLearningPoint ;
  rdfs:label """When choosing food and drinks, current healthy eating and drinking guidelines should
  be followed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food labels on packaged foods should be checked, choosing those lower in fat, salt
  and sugars."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616774Z"^^xsd:dateTime .

