  dcterms:modified "2026-06-07T15:29:26.678513Z"^^xsd:dateTime .

oakcurric:priorknowledge-3207-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should be aware of how the internet facilitates online communication and
  collaboration."""@en ;
  dcterms:modified "2026-06-07T15:29:26.678519Z"^^xsd:dateTime .

oakcurric:priorknowledge-3207-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should be able to describe the concept of privacy and how the internet does
  not always afford this."""@en ;
  dcterms:modified "2026-06-07T15:29:26.678524Z"^^xsd:dateTime .

oakcurric:priorknowledge-3224-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand what networks are including the internet."@en ;
  dcterms:modified "2026-06-07T15:29:26.689515Z"^^xsd:dateTime .

oakcurric:priorknowledge-3224-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise ways they should stay safe online."@en ;
  dcterms:modified "2026-06-07T15:29:26.689526Z"^^xsd:dateTime .

oakcurric:priorknowledge-3224-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand what computer systems are and why they need to communicate."@en ;
  dcterms:modified "2026-06-07T15:29:26.689553Z"^^xsd:dateTime .

oakcurric:priorknowledge-3208-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils recognise that content they use might be subject to copyright and its use
  restricted."""@en ;
  dcterms:modified "2026-06-07T15:29:26.775541Z"^^xsd:dateTime .

oakcurric:priorknowledge-3208-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify the audience for content they create."@en ;
  dcterms:modified "2026-06-07T15:29:26.775551Z"^^xsd:dateTime .

oakcurric:priorknowledge-3208-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can combine text and images in a single document."@en ;
  dcterms:modified "2026-06-07T15:29:26.775557Z"^^xsd:dateTime .

oakcurric:priorknowledge-3208-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can adjust properties of text to make the content suitable for an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:29:26.775561Z"^^xsd:dateTime .

oakcurric:priorknowledge-3208-5
