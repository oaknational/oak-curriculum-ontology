  dcterms:modified "2026-06-07T15:30:29.618042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23821-2
  a curric:KeyLearningPoint ;
  rdfs:label """The central processing unit (CPU) executes instructions and controls other parts of
