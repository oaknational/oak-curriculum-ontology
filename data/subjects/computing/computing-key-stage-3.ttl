# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-detailed-renders-produced
  a curric:Misconception ;
  curric:statement "The most detailed renders should always be produced."@en ;
  curric:correction """Render engines and settings should be chosen with consideration to the
  requirements of the project. This may include considering factors such as time constraints
  and hardware limitations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093382Z"^^xsd:dateTime .

oakcurric:misconception-feedback-telling-people-done-wrong
  a curric:Misconception ;
  curric:statement """Feedback is about telling people what has been done wrong and giving
  commands."""@en ;
  curric:correction """Feedback should be supportive and constructive. Feedback should include
  details of what has gone well as well as suggestions to help improve the product."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093387Z"^^xsd:dateTime .

oakcurric:misconception-vector-images-better-bitmap-images
  a curric:Misconception ;
  curric:statement "Vector images are better than bitmap images in every situation."@en ;
  curric:correction """Vector and bitmap images are suited to different tasks. Vectors are best for
  simple, scalable designs like logos, while bitmaps are better for detailed images like
  photos."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094233Z"^^xsd:dateTime .

oakcurric:misconception-selection-statements-check-one-condition
  a curric:Misconception ;
  curric:statement "Selection statements can only check one condition at a time."@en ;
  curric:correction """Complex conditions can be built into selection using a combination of
  comparison and logical operators. Logical operators join separate conditions and provide
  one complete statement that still evaluates to only True or False."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094735Z"^^xsd:dateTime .

oakcurric:misconception-data-important-presenting-findings-support
  a curric:Misconception ;
  curric:statement "Data is not important when presenting findings to support an argument."@en ;
  curric:correction "Data makes your point stronger by showing real evidence."@en ;
  dcterms:modified "2026-06-07T15:30:15.095569Z"^^xsd:dateTime .

oakcurric:misconception-missing-data-cannot-find-original
  a curric:Misconception ;
  curric:statement """If you have missing data and cannot find the original source, there is nothing
  you can do."""@en ;
  curric:correction """You could look at similar data and generate an average value to insert. For
  example, if the zoo is missing a weight for a lion, they could calculate the average
  weight of the other lions and enter this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096041Z"^^xsd:dateTime .

oakcurric:misconception-plans-cannot-change-project-progresses
  a curric:Misconception ;
  curric:statement "Plans cannot change as a project progresses."@en ;
  curric:correction """Initial planning helps focus the purpose, content and layout of a product.
  However, due to feedback or changing needs, plans may need to be changed as a project
  progresses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097128Z"^^xsd:dateTime .

oakcurric:misconception-statement-two-options
  a curric:Misconception ;
  curric:statement "An if statement can only have two options."@en ;
  curric:correction """An if statement can be paired with elif and else statements to create
  multi-path selection. This allows for multiple paths to follow in a program."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097623Z"^^xsd:dateTime .

oakcurric:misconception-computers-screens-user-knows-processing
  a curric:Misconception ;
  curric:statement """Computers always have screens so that the user knows what processing has been
  performed."""@en ;
  curric:correction """Computers can carry actions using a variety of output devices. Physical
  computers are often used to carry out physical actions based on detected inputs so do not
  need a screen to display information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098323Z"^^xsd:dateTime .

oakcurric:misconception-user-interface-app-looks
  a curric:Misconception ;
  curric:statement "The user interface is only about how the app looks."@en ;
  curric:correction """The user interface includes both how the app looks and how users interact
  with it. A good user interface is both visually clear and functionally simple."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099675Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-conditional-formatting-used
  a curric:Misconception ;
  curric:statement """Pupils may think that conditional formatting can only be used to add
  background colour to a cell."""@en ;
  curric:correction """Conditional formatting can be used to apply a range of formatting a cell
  including the text of the cell itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102041Z"^^xsd:dateTime .

oakcurric:misconception-3d-models-made-simple-shapes
  a curric:Misconception ;
  curric:statement """3D models are all made up of simple shapes that are scaled, moved and
  rotated."""@en ;
  curric:correction """Having only previously used object mode, learners may be unaware that
  geometry such as vertices, edges and faces can all be directly modified in edit mode.
  Working in edit mode gives a modeller greater freedom to create more complex models."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103461Z"^^xsd:dateTime .

oakcurric:misconception-search-engines-search-whole-internet
  a curric:Misconception ;
  curric:statement "Search engines search the whole internet live."@en ;
  curric:correction "Search engines use a pre-built index to deliver fast results."@en ;
  dcterms:modified "2026-06-07T15:30:15.105565Z"^^xsd:dateTime .

oakcurric:misconception-boolean-logic-numbers
  a curric:Misconception ;
  curric:statement "Boolean logic is about numbers"@en ;
  curric:correction "Boolean logic is about truth values such as yes/no, true/false or (1/0)."@en ;
  dcterms:modified "2026-06-07T15:30:15.105958Z"^^xsd:dateTime .

oakcurric:misconception-symbol-used-check-variable-equal
  a curric:Misconception ;
  curric:statement """The = symbol is used to check if a variable is equal to a value
  (comparison)."""@en ;
  curric:correction """The = symbol is used in Python for assignment. The == operator is used for
  comparison."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106262Z"^^xsd:dateTime .

oakcurric:misconception-mega-larger-giga
  a curric:Misconception ;
  curric:statement "Mega is larger than giga."@en ;
  curric:correction "The order of prefixes from smallest to largest is kilo, mega, giga, tera."@en ;
  dcterms:modified "2026-06-07T15:30:15.106692Z"^^xsd:dateTime .

oakcurric:misconception-artificial-intelligence-systems-use-machine
  a curric:Misconception ;
  curric:statement "All artificial intelligence systems use machine learning."@en ;
  curric:correction """No, some AI systems, such as rule-based expert systems or symbolic AI, use
  predefined logic and heuristics rather than learning from data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106799Z"^^xsd:dateTime .

oakcurric:misconception-python-automatically-round-numbers-nearest
  a curric:Misconception ;
  curric:statement "Python will automatically round numbers to the nearest whole number."@en ;
  curric:correction """Python will perform calculations based on the values that have been provided
  and generate an answer that can include fractional parts. If you want to reduce the number
  of digits, you can use the round() function."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106805Z"^^xsd:dateTime .

oakcurric:misconception-value-variable-holds-cannot-updated
  a curric:Misconception ;
  curric:statement """The value a variable holds cannot be updated and a computer remembers the
  previous values of variables."""@en ;
  curric:correction """A variable can be updated during a program. Once the value of a variable is
  updated in a program, the previous value is overwritten."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106829Z"^^xsd:dateTime .

oakcurric:misconception-closing-tags-optional-used-make
  a curric:Misconception ;
  curric:statement """Closing tags are optional and are just used to make the code easier to
  read."""@en ;
  curric:correction """Most tags need to be closed and require the use of a forward slash. This
  marks the beginning and the end of the content that the HTML tag should be applied to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108126Z"^^xsd:dateTime .

oakcurric:misconception-changing-shapes-path-doesnt-change
  a curric:Misconception ;
  curric:statement """Changing a shape's path doesn’t change how it behaves — it’s still just a
  shape."""@en ;
  curric:correction """Editing a path changes the shape’s structure. Moving nodes changes the
  outline, allowing for new and more complex designs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108134Z"^^xsd:dateTime .

oakcurric:misconception-building-physical-computing-project-putting
  a curric:Misconception ;
  curric:statement """Building a physical computing project is just about putting the parts
  together. The code is not that important."""@en ;
  curric:correction """The code tells the hardware what to do and how to interact with the world,
  without the code it wouldn't move or do anything interesting!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.108154Z"^^xsd:dateTime .

oakcurric:misconception-strings-mutable-meaning-character-within
  a curric:Misconception ;
  curric:statement """Strings are mutable meaning that any character within the string can be
  changed."""@en ;
  curric:correction """Strings are immutable. The elements of a string cannot be changed. If changes
  to the string are required, the whole string must be rewritten."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108162Z"^^xsd:dateTime .

oakcurric:misconception-representation-length-include-spaces
  a curric:Misconception ;
  curric:statement "The representation length does not include any spaces."@en ;
  curric:correction """The representation length is the total number of symbols in the sequence
  including spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108482Z"^^xsd:dateTime .

oakcurric:misconception-programming-constructs-cannot-combined-same
  a curric:Misconception ;
  curric:statement "Programming constructs cannot be combined in the same code block."@en ;
  curric:correction """The programming constructs of sequence, selection and iteration can be
  combined within the same code block to make more complex programs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113461Z"^^xsd:dateTime .

oakcurric:misconception-screens-run-same-time
  a curric:Misconception ;
  curric:statement "All screens run at the same time."@en ;
  curric:correction """Only one screen is active at a time; users navigate between them when
  needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113590Z"^^xsd:dateTime .

oakcurric:misconception-data-better-means-model-better
  a curric:Misconception ;
  curric:statement """More data is always better as it means the model can be better informed to
  make a prediction."""@en ;
  curric:correction """Poorly labelled or inconsistent data can make a model's predictions
  inaccurate. It is better to use a smaller amount of higher quality data to make more
  accurate predictions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113604Z"^^xsd:dateTime .

oakcurric:misconception-generative-ai-negative-affect-society
  a curric:Misconception ;
  curric:statement "Generative AI always has a negative affect on society."@en ;
  curric:correction """Generative AI isn't always negative; it depends on its use. Generative AI
  tools can help artists, educators and scientists create innovative designs, engaging
  learning materials and advanced simulations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113610Z"^^xsd:dateTime .

oakcurric:misconception-detailed-complex-3d-models-created
  a curric:Misconception ;
  curric:statement """Detailed and complex 3D models are always created from scratch and therefore
  take a long time to create."""@en ;
  curric:correction """3D models usually start off by using, adding and modifying simple 3D shapes.
  Further detail and complexities are then added to increase the realism of the model."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113649Z"^^xsd:dateTime .

oakcurric:misconception-svg-files-made-pictures-code
  a curric:Misconception ;
  curric:statement "SVG files are made of pictures, not code."@en ;
  curric:correction """SVG images are stored as text-based code. Each shape is written with
  instructions that describe its appearance, such as its size, colour and position on the
  canvas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114075Z"^^xsd:dateTime .

oakcurric:misconception-data-information-same-thing
  a curric:Misconception ;
  curric:statement "Data and information are the same thing."@en ;
  curric:correction """Data and information are realted but are different. Data is raw facts and
  figures whilst information is data that has been processed to have meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114155Z"^^xsd:dateTime .

oakcurric:misconception-loop-same-while-loop-designed
  a curric:Misconception ;
  curric:statement """A for loop is the same as a while loop as they are both designed to repeat
  instructions. You should pick one and stick to it for all your programs."""@en ;
  curric:correction """Unlike a while loop, a for loop is count-controlled, meaning it will repeat a
  set number of times when the loop begins. In contrast, a while loop repeats instructions
  for as long as its condition is true. This can vary each time the loop runs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114180Z"^^xsd:dateTime .

oakcurric:misconception-data-include-data-visualisation-better
  a curric:Misconception ;
  curric:statement "The more data you include in a data visualisation, the better."@en ;
  curric:correction """Removing unneccesary data from a visualisation can improve the quality of a
  visualisation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114750Z"^^xsd:dateTime .

oakcurric:misconception-visualiation-tell-information-need-know
  a curric:Misconception ;
  curric:statement "A visualiation will always tell you the information you need to know."@en ;
  curric:correction """You may need to refine or collect more data to create visualisations which
  answer your questions effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115742Z"^^xsd:dateTime .

oakcurric:misconception-planning-physical-computing-project-slows
  a curric:Misconception ;
  curric:statement """Planning a physical computing project slows you down and does not need to be
  thought of before starting what you want to make."""@en ;
  curric:correction """A plan helps you think through the steps, figure out what you need, and make
  sure your project turns out how you want it to. If you don't plan, you could end up making
  mistakes that will mean your project doesn't turn out how you would like."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117435Z"^^xsd:dateTime .

oakcurric:misconception-once-item-added-list-fixed
  a curric:Misconception ;
  curric:statement """Once an item is added to a list it is fixed in to the structure of the list
  and it cannot be altered."""@en ;
  curric:correction """Items can be removed, inserted and amended in a list using list methods.
  These methods change the structure of the list. Values of items can also be updated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117442Z"^^xsd:dateTime .

oakcurric:misconception-once-app-runs-finished
  a curric:Misconception ;
  curric:statement "Once the app runs it is finished."@en ;
  curric:correction """Testing, debugging, and improving based on feedback are essential steps
  before finishing work on an app."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118568Z"^^xsd:dateTime .

oakcurric:misconception-while-loop-appropriate-loop-use
  a curric:Misconception ;
  curric:statement """A while loop is the most appropriate loop to use when you know exactly how
  many iterations will need to be performed."""@en ;
  curric:correction """While loops should be used when the number of iterations can change. Even
  though while loops can be used in this way, for loops are a more appropriate choice as
  they will track the number of iterations as part of their operation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119132Z"^^xsd:dateTime .

oakcurric:misconception-pupils-take-user-input-numerical
  a curric:Misconception ;
  curric:statement """Pupils often take user input for numerical values and then cannot perform
  arithmetic calculations on the data as the value is automatically stored as a string."""@en ;
  curric:correction """The int() function is used to convert a user's input to an integer so that
  calculations can then be performed. For example, age = int(input()) would allow a user to
  input their age in to a program."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120740Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-plan-starting-vector
  a curric:Misconception ;
  curric:statement """You don’t need a plan before starting a vector design — you can just make it
  up as you go."""@en ;
  curric:correction """Planning helps you focus your design and choose the right tools and shapes
  before you start. Without a plan, it's easy to miss the goal or waste time making
  unnecessary changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120753Z"^^xsd:dateTime .

oakcurric:misconception-frame-animation-needs-created-animator
  a curric:Misconception ;
  curric:statement "Every frame of an animation needs to be created by the animator."@en ;
  curric:correction """Most modern animations are created using tweening. Tweening creates the
  frames between keyframes and stitches them together. This reduces the time taken to create
  animations and can improve quality."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120758Z"^^xsd:dateTime .

oakcurric:misconception-list-index-starts-1-first
  a curric:Misconception ;
  curric:statement """A list index starts at 1 as that is the first element in the list and should
  be counted as the first item."""@en ;
  curric:correction """In most programming languages, list indexing is zero-based, which means the
  index starts at 0. The number indicates the position before the value is seen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123230Z"^^xsd:dateTime .

oakcurric:misconception-iteration-means-program-repeat-something
  a curric:Misconception ;
  curric:statement "Iteration means a program will repeat something a set number of times."@en ;
  curric:correction """Count-controlled iteration will repeat a sequence of commands a set number of
  times. Condition-controlled iteration will repeat a sequence of commands until a condition
  is met and so the number of times it will repeat can never be predicted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123236Z"^^xsd:dateTime .

oakcurric:misconception-program-follow-one-sequence-commands
  a curric:Misconception ;
  curric:statement "A program can only follow one sequence of commands."@en ;
  curric:correction """Selection allows for a program to follow alternative paths depending on the
  criteria of the selection statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124267Z"^^xsd:dateTime .

oakcurric:misconception-mathematical-operations-cannot-performed-items
  a curric:Misconception ;
  curric:statement """Mathematical operations cannot be performed on items held in a list; the items
  must first be stored in a new variable."""@en ;
  curric:correction """Mathematical operations can be performed directly on list items by using an
  index value to reference the value used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125264Z"^^xsd:dateTime .

oakcurric:misconception-order-column-row-cell-reference
  a curric:Misconception ;
  curric:statement """The order of column and row in a cell reference are unimportant as columns are
  labelled with letters and rows are labelled as numbers."""@en ;
  curric:correction """Spreadsheet cell references are presented as the combination of the column
  letter followed by the row number, (eg. A1, B2). If the order is interchanged any other
  part of the spreadsheet that references them will not be able to locate them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125303Z"^^xsd:dateTime .

oakcurric:misconception-range-references-spreadsheet-needs-same
  a curric:Misconception ;
  curric:statement """All range references in a spreadsheet needs to be the same as cell references
  in the format of column letter followed by row number (e.g. A1:A4)."""@en ;
  curric:correction """If you want to reference the whole column you can remove the row numbers
  (e.g. A:A). Note that this is the only case where cell references do not have to follow
  the column:row convention."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125320Z"^^xsd:dateTime .

oakcurric:misconception-words-add-search-better-my
  a curric:Misconception ;
  curric:statement "The more words I add to a search, the better my results will be."@en ;
  curric:correction """Adding too many words can make a search too specific, limiting useful
  results. Use search operators like AND, OR, and NOT to refine the search and still find
  good information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129018Z"^^xsd:dateTime .

oakcurric:misconception-data-capture-forms-electronic
  a curric:Misconception ;
  curric:statement "Data capture forms are only electronic."@en ;
  curric:correction """A data capture form can be designed and used on paper and data can be
  collected in person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132885Z"^^xsd:dateTime .

oakcurric:misconception-filter-applied-data-set-data
  a curric:Misconception ;
  curric:statement """When a filter is applied to a data set the data that is filtered is removed
  permanently."""@en ;
  curric:correction """A filter can be applied to data to remove selected data from a data set.
  However, this data is not permanently removed, if the filter is taken off the data will
  still be there."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133661Z"^^xsd:dateTime .

oakcurric:misconception-audacity-project-files-listened-digital
  a curric:Misconception ;
  curric:statement "Audacity project files can be listened to on all digital devices."@en ;
  curric:correction """To listen to the audio on other devices, the file must be exported to a
  common format such as WAV (.wav) or MP3 (.mp3)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133667Z"^^xsd:dateTime .

oakcurric:misconception-micro-bit-understands-movement-like
  a curric:Misconception ;
  curric:statement "The micro:bit understands movement like a human does."@en ;
  curric:correction """The micro:bit records numbers (x, y, z acceleration) that are then
  interpretted using programmed instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134978Z"^^xsd:dateTime .

oakcurric:misconception-vector-graphics-made-pixels-lose
  a curric:Misconception ;
  curric:statement "Vector graphics are made from pixels and can lose quality when resized."@en ;
  curric:correction """Vector graphics are made from lines and shapes. They do not lose quality when
  resized."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134987Z"^^xsd:dateTime .

oakcurric:misconception-logo-brand
  a curric:Misconception ;
  curric:statement "A logo is a brand."@en ;
  curric:correction """A logo is not a brand but a key part of a brand's or organisation's identity.
  A logo is a graphic that represents the visual identity of a brand or organisation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134993Z"^^xsd:dateTime .

oakcurric:misconception-3d-viewport-display-blender-view
  a curric:Misconception ;
  curric:statement "The 3D viewport display in Blender is the view from the scene camera."@en ;
  curric:correction """What is displayed in the 3D viewport in Blender is not what is viewed from
  the camera. The camera view must be enabled to look through the camera and set up
  composition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135080Z"^^xsd:dateTime .

oakcurric:misconception-building-machine-learning-app-means
  a curric:Misconception ;
  curric:statement """Building a machine learning app just means coding as you would do with any
  other programming project."""@en ;
  curric:correction """Building a machine learning app involves data collection, model training and
  coding the application. These facets are integral in developing a machine learning app."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135712Z"^^xsd:dateTime .

oakcurric:misconception-events-happen-automatically
  a curric:Misconception ;
  curric:statement "Events happen automatically."@en ;
  curric:correction """Events only trigger code if an event listener is attached. Without one, the
  app will not respond."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135725Z"^^xsd:dateTime .

oakcurric:misconception-variables-store-numbers
  a curric:Misconception ;
  curric:statement "Variables always store numbers."@en ;
  curric:correction """Variables can store different types of data, including text (strings),
  numbers or Boolean values."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136975Z"^^xsd:dateTime .

oakcurric:misconception-hyperlinks-work-homepage
  a curric:Misconception ;
  curric:statement "Hyperlinks only work on the homepage."@en ;
  curric:correction """Hyperlinks are used across all pages, creating a fully navigable website. Any
  object on any HTML page can be made into a hyperlink."""@en ;
  dcterms:modified "2026-06-07T15:30:15.136986Z"^^xsd:dateTime .

oakcurric:misconception-posters-signs-include-lots-text
  a curric:Misconception ;
  curric:statement """Posters and signs should include lots of text information for the viewer to
  read."""@en ;
  curric:correction """Posters and signs should avoid too much detail when using text and images.
  This helps to clearly get a message across to the viewer at a glance and does not rely on
  them having to spend time looking at the detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137041Z"^^xsd:dateTime .

oakcurric:misconception-format-layout-slide-decks-created
  a curric:Misconception ;
  curric:statement """The format and layout of slide decks must always be created from scratch each
  time you start a new document."""@en ;
  curric:correction """Slide deck templates have pre-designed layouts and formatting that can be
  used as a starting point when creating new slide decks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137557Z"^^xsd:dateTime .

oakcurric:misconception-grouping-objects-permanent
  a curric:Misconception ;
  curric:statement "Grouping objects is permanent."@en ;
  curric:correction """Grouping objects can be reversed using ungroup. Combining objects is harder
  to reverse; only undo fixes combining."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138199Z"^^xsd:dateTime .

oakcurric:misconception-create-smooth-organic-surfaces-models
  a curric:Misconception ;
  curric:statement """To create smooth organic surfaces and models, individual geometry such as
  vertices, edges and faces must be edited individually."""@en ;
  curric:correction """Free-form, organically shaped models can be created by using modelling tools
  such as proportional editing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138205Z"^^xsd:dateTime .

oakcurric:misconception-micro-bit-show-letters-numbers
  a curric:Misconception ;
  curric:statement "The micro:bit can only show letters and numbers."@en ;
  curric:correction """The micro:bit's LED display can show more than letters and numbers. It can
  show shapes, images, and patterns. The display matrix can be programmed to output any
  desired pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139044Z"^^xsd:dateTime .

oakcurric:misconception-learners-get-confused-logic-operators
  a curric:Misconception ;
  curric:statement "Learners often get confused between the logic operators AND and OR."@en ;
  curric:correction """For an AND statement to return True both inputs must be True. For an OR
  statement to return True either input can be True."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139316Z"^^xsd:dateTime .

oakcurric:misconception-sending-receiving-radio-signals-broadcasts
  a curric:Misconception ;
  curric:statement """Sending and receiving radio signals broadcasts to all devices that have radio
  capability."""@en ;
  curric:correction """A radio channel can be set which means that only devices on that same channel
  will receive those broadcasts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140474Z"^^xsd:dateTime .

oakcurric:misconception-pupils-modify-their-code-provide
  a curric:Misconception ;
  curric:statement """Pupils will modify their code to provide input directly in to the input()
  function, for example, user = input(\"Aisha\"), rather than typing when asked as the
  program runs."""@en ;
  curric:correction """The computer follows the instructions of a program. Input that a user has to
  type in should only be entered when the program runs. This allows different users to
  provide different inputs without changing the program in any way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140480Z"^^xsd:dateTime .

oakcurric:misconception-start-creating-app-without-planning
  a curric:Misconception ;
  curric:statement "You should start creating an app without planning."@en ;
  curric:correction """Planning first helps avoid confusion and mistakes and helps you build apps
  more efficiently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140877Z"^^xsd:dateTime .

oakcurric:misconception-training-makes-perfect-model
  a curric:Misconception ;
  curric:statement "More training makes a perfect model."@en ;
  curric:correction """Not neccessarily - models can become too specialised and fail on new
  data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140891Z"^^xsd:dateTime .

oakcurric:misconception-images-stored-inside-html-files
  a curric:Misconception ;
  curric:statement """Images are stored inside HTML files as one document that is downloaded and
  displayed."""@en ;
  curric:correction """HTML only references image files, which are stored separately. When a web
  page is downloaded, the linked images are downloaded separately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140903Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-time-data-changed
  a curric:Misconception ;
  curric:statement """Pupils may believe that each time data is changed in a spreadsheet the
  formulas will also need to be changed."""@en ;
  curric:correction """Using cell references within a formula means that the formula will
  recalculate when the values in those reference cells change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140909Z"^^xsd:dateTime .

oakcurric:misconception-sprite-scratch-one-sequence-code
  a curric:Misconception ;
  curric:statement "A sprite in Scratch can only have one sequence of code blocks."@en ;
  curric:correction """Sequences of code can be separated into subroutines and these subroutines can
  be called multiple times."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141479Z"^^xsd:dateTime .

oakcurric:misconception-internet-same-world-wide-web
  a curric:Misconception ;
  curric:statement "The internet is the same as the World Wide Web."@en ;
  curric:correction """The World Wide Web is a service that is offered over the internet. The
  internet is the network that transfers data whilst the World Wide Web is the system of
  sharing information that people use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143532Z"^^xsd:dateTime .

oakcurric:misconception-network-servers-clients-routers-same
  a curric:Misconception ;
  curric:statement "On a network, servers, clients and routers have the same purpose."@en ;
  curric:correction """Servers, clients and routers have distinct roles and functionalities in a
  network. They are not interchangeable and serve different purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146452Z"^^xsd:dateTime .

oakcurric:misconception-computers-process-types-information-text
  a curric:Misconception ;
  curric:statement "Computers process all types of information (text, images, video, etc.)."@en ;
  curric:correction """Ultimately, computers use sequences of symbols (0s and 1s) to represent all
  types of information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146458Z"^^xsd:dateTime .

oakcurric:misconception-number-bits-per-pixel-represent
  a curric:Misconception ;
  curric:statement """The number of bits per pixel that represent the colour are always individual
  specific colours."""@en ;
  curric:correction """When RGB is used to define the colour of a pixel the bits represent different
  intesities of red, green and blue providing different colour mixes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148452Z"^^xsd:dateTime .

oakcurric:misconception-get-malware-computer-download-file
  a curric:Misconception ;
  curric:statement "You can only get malware on a computer if you download a file."@en ;
  curric:correction """Malware can infect a computer in other ways, like visiting unsafe websites,
  clicking bad links, or through software flaws, not just by downloading files."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149241Z"^^xsd:dateTime .

oakcurric:misconception-artificial-intelligence-machine-learning-same
  a curric:Misconception ;
  curric:statement "Artificial intelligence and machine learning are the same thing."@en ;
  curric:correction """Machine learning is a type of artifical intelligence that helps machines get
  better at tasks by learning from data, not just following pre-written instructions and
  rules."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152058Z"^^xsd:dateTime .

oakcurric:misconception-bandwidth-speed-data-transmitted-across
  a curric:Misconception ;
  curric:statement """Bandwidth is the speed of data being transmitted across a network. The higher
  the bandwidth, the faster data can be transferred between points in a network."""@en ;
  curric:correction """Bandwidth is the maximum amount of data that can be transmitted at a time,
  not the time it takes to reach from one point to another. Higher bandwidth reduces the
  total transfer time of data but this is only noticable when there is a lot to transfer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152465Z"^^xsd:dateTime .

oakcurric:misconception-success-criteria-teacher-use-marking
  a curric:Misconception ;
  curric:statement """Success criteria are only for the teacher to use when marking work. They don't
  help me."""@en ;
  curric:correction """They're not just for marking. Think of them like a checklist or a guide to
  help you create your best work. They tell you exactly what you need to do to succeed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154457Z"^^xsd:dateTime .

oakcurric:misconception-data-packets-complete-message-follow
  a curric:Misconception ;
  curric:statement """Data packets from a complete message always follow the same route to their
  destination. They are then put back together in the order they are received."""@en ;
  curric:correction """Data packets are split and will be sent using the most efficient route at the
  time which often changes. Packets include data parts so they can be reassembled at the
  destination as long as the order of the packets is identified before being sent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154750Z"^^xsd:dateTime .

oakcurric:misconception-operating-system-see-screen
  a curric:Misconception ;
  curric:statement "The operating system is just what you see on the screen."@en ;
  curric:correction """What you see on the screen is the graphical interface, but the operating
  system includes a lot more behind the scenes such as memory management, file systems,
  device control etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154957Z"^^xsd:dateTime .

oakcurric:misconception-social-engineering-involves-technical-skills
  a curric:Misconception ;
  curric:statement """Social engineering involves technical skills and knowledge of computing
  concepts in order to carry out an attack."""@en ;
  curric:correction """Social engineering relies on manipulating a victim to steal their personal
  data. This is done by finding ways to trick the user in to handing over the data
  willingly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156541Z"^^xsd:dateTime .

oakcurric:misconception-rubric-checklist-teacher-doesnt-help
  a curric:Misconception ;
  curric:statement """A rubric is just a checklist for the teacher. It doesn't help me write better
  blogs."""@en ;
  curric:correction """It's a guide to help you understand what makes a good blog post. It shows you
  the specific criteria, like clear writing or effective use of images, so you know what to
  focus on. Use it as a tool to improve your writing before submitting your work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156549Z"^^xsd:dateTime .

oakcurric:misconception-data-science-collecting-loads-data
  a curric:Misconception ;
  curric:statement "Data science is just about collecting loads of data."@en ;
  curric:correction """Data science isn’t just about gathering data, it’s about understanding data
  and using it to make decisions or discoveries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158224Z"^^xsd:dateTime .

oakcurric:misconception-find-image-online-use-however
  a curric:Misconception ;
  curric:statement """If I find an image online, I can use it however I want, as long as I don't say
  I created it."""@en ;
  curric:correction """Just finding an image online doesn't automatically mean you can use it
  freely. Think of it like this: someone created that image, and they have rights to it,
  just like an author has rights to their book."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162103Z"^^xsd:dateTime .

oakcurric:misconception-binary-uses-same-place-value
  a curric:Misconception ;
  curric:statement "Binary uses the same place value system as decimal."@en ;
  curric:correction """Binary is a base-2 number system, whereas decimal is a base-10 number
  system."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163298Z"^^xsd:dateTime .

oakcurric:misconception-cpu-important-part-computer
  a curric:Misconception ;
  curric:statement "The CPU is the only important part of a computer."@en ;
  curric:correction """The CPU is an important part of a computer system but a computer also needs
  memory, input, output, and storage to work properly. All parts must work together as a
  system."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164675Z"^^xsd:dateTime .

oakcurric:misconception-computers-everything-equally-well
  a curric:Misconception ;
  curric:statement "All computers can do everything equally well."@en ;
  curric:correction """General-purpose computers can run many programs, but single-purpose computers
  are designed to do one task very efficiently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164683Z"^^xsd:dateTime .

oakcurric:misconception-hacking-computer-system-someone-know
  a curric:Misconception ;
  curric:statement """Hacking a computer system of someone you know as a joke is considered
  legal."""@en ;
  curric:correction """Even if there is no intention to commit a crime by accessing the computer
  system of someone you know, the fact that the access is unauthorised is considered a
  crime."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165025Z"^^xsd:dateTime .

oakcurric:misconception-long-use-security-measures-computer
  a curric:Misconception ;
  curric:statement """As long as you use all security measures, a computer system connected to a
  network can be totally safe from cyber attack."""@en ;
  curric:correction """No computer system on a network can be completely safe, even with all
  security measures. Cybercriminals can find new ways to attack, so security only reduces
  the risk and doesn't completely eliminate it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165465Z"^^xsd:dateTime .

oakcurric:misconception-compression-reduces-quality-compressed-files
  a curric:Misconception ;
  curric:statement """Compression always reduces quality or that compressed files are always lower
  quality than uncompressed files."""@en ;
  curric:correction """Lossless compression retains all original data by finding and storing
  repeated patterns more efficiently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165828Z"^^xsd:dateTime .

oakcurric:misconception-change-words-website-use-my
  a curric:Misconception ;
  curric:statement """If I change a few words from a website and use it as my own work it's not
  plagiarism."""@en ;
  curric:correction """Changing a few words isn't enough. Plagiarism is using someone's ideas
  without credit. Even if you rephrase, you must reference the original source."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165904Z"^^xsd:dateTime .

oakcurric:misconception-laws-put-place-parliament-stop
  a curric:Misconception ;
  curric:statement "Laws are put in place by Parliament to stop crimes from happening."@en ;
  curric:correction """Laws don't completely stop crime, but act as a deterrent by outlining the
  consequences of committing crimes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165910Z"^^xsd:dateTime .

oakcurric:misconception-content-found-world-wide-web
  a curric:Misconception ;
  curric:statement "All content found on the World Wide Web is free to reuse."@en ;
  curric:correction """Content on the World Wide Web is subject to copyright and can be reused
  subject to licence agreements. Content found on the World Wide Web should be carefully
  chosen to ensure it is trustworthy and accurate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166024Z"^^xsd:dateTime .

oakcurric:misconception-once-encrypted-message-cannot-decrypted
  a curric:Misconception ;
  curric:statement "Once encrypted, a message cannot be decrypted."@en ;
  curric:correction """A message can be encrypted and decrypted multiple times, this happens
  frequently during digital communications."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166032Z"^^xsd:dateTime .

oakcurric:misconception-positive-correlation-means-one-variable
  a curric:Misconception ;
  curric:statement "A positive correlation means one variable has an impact on another."@en ;
  curric:correction """Just because there is a correlation, it doesn’t necessarily mean that one
  things causes another to increase."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166040Z"^^xsd:dateTime .

oakcurric:misconception-internet-things-iot-smart-homes
  a curric:Misconception ;
  curric:statement "The internet of things (IoT) is only about smart homes and appliances."@en ;
  curric:correction """IoT are everyday devices that are connected to the internet and can
  communicate with each other. They might not collect data for the same purpose but they can
  collect information about how people use the devices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166352Z"^^xsd:dateTime .

oakcurric:misconception-computers-need-protocols-sending-emails
  a curric:Misconception ;
  curric:statement "Computers only need protocols when sending emails or accessing websites."@en ;
  curric:correction """Protocols are essential for all sorts of activities, not just email or
  browsing websites. Protocols are also needed for streaming movies, playing online games,
  making video calls, etc. Anything being sent across a network needs to follow a protocol."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166415Z"^^xsd:dateTime .

oakcurric:misconception-blogs-like-other-website-theyre
  a curric:Misconception ;
  curric:statement "Blogs are just like any other website; they're all the same."@en ;
  curric:correction """Blogs are more like online journals or news sites. Blogs are updated
  regularly, while websites might not change as often."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166594Z"^^xsd:dateTime .

oakcurric:misconception-information-found-internet-true
  a curric:Misconception ;
  curric:statement "All information that is found on the internet is true."@en ;
  curric:correction """Anyone can create a website. Check who wrote it, when and if the facts are
  correct. Don't believe everything you see without checking first!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.168732Z"^^xsd:dateTime .

oakcurric:misconception-users-machine-learning-application-need
  a curric:Misconception ;
  curric:statement """Users of a machine learning application do not need to be aware of how
  accurate it is."""@en ;
  curric:correction """Model cards are good practice when developing machine learning applications.
  A model card is a short report on how a machine learning model works, how well the model
  performs and what people should know before using the model."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168909Z"^^xsd:dateTime .

oakcurric:misconception-css-rules-include-like-html
  a curric:Misconception ;
  curric:statement "CSS rules must always include < > like HTML tags."@en ;
  curric:correction "CSS uses just the tag name, without brackets."@en ;
  dcterms:modified "2026-06-07T15:30:15.169182Z"^^xsd:dateTime .

oakcurric:misconception-point-evaluation-once-project-finished
  a curric:Misconception ;
  curric:statement """There is no point in doing an evaluation once a project is finished as you are
  not going to go back and make any more changes."""@en ;
  curric:correction """Evaluations help learning by understanding your creative process and finding
  ways to improve. This often informs projects that you do in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169651Z"^^xsd:dateTime .

oakcurric:misconception-1-bit-used-represent-1
  a curric:Misconception ;
  curric:statement "1 bit is always used to represent 1 pixel."@en ;
  curric:correction """While bits are used to represent the colour of pixels, it's not always a
  one-to-one relationship. The number of bits used can vary depending on the colour depth of
  the image."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170202Z"^^xsd:dateTime .

oakcurric:misconception-single-audio-file-contains-one
  a curric:Misconception ;
  curric:statement "A single audio file contains only one channel of sound."@en ;
  curric:correction """Many formats (e.g., stereo or surround sound) contain multiple channels
  within one file. The information contained in the audio track can be reproduced on
  separate channels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170484Z"^^xsd:dateTime .

oakcurric:misconception-using-security-measures-stop-cyber
  a curric:Misconception ;
  curric:statement "Using security measures will stop every cyber attack."@en ;
  curric:correction """Security measures reduce the risk of cyber attacks but cannot stop all of
  them. New threats and advanced techniques can sometimes bypass even the best defenses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171169Z"^^xsd:dateTime .

oakcurric:misconception-data-processed-organised-structured-information
  a curric:Misconception ;
  curric:statement """Data is processed, organised and structured information that provides context
  and meaning."""@en ;
  curric:correction """Information is processed, organised and structured data that provides context
  and meaning. Data is facts and figures in their raw form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171244Z"^^xsd:dateTime .
