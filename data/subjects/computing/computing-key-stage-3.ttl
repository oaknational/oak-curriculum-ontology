# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-23861-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rendering is the process of generating high-quality images from a 3D scene or
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23861-2
  a curric:KeyLearningPoint ;
  rdfs:label "Render engines should be chosen based on the requirements of the project."@en ;
  dcterms:modified "2026-06-07T15:30:29.274232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23861-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ray tracing simulates the way light interacts with objects and environments."@en ;
  dcterms:modified "2026-06-07T15:30:29.274236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23861-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rendered images and animations can be exported out of Blender."@en ;
  dcterms:modified "2026-06-07T15:30:29.274240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23771-1
  a curric:KeyLearningPoint ;
  rdfs:label """Feedback should be carefully crafted to provide constructive information that
  informs improvement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Criteria can be used to help structure the reviewing process and assess the success
  of a digital product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23771-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comments providing feedback can be left directly in a digital product."@en ;
  dcterms:modified "2026-06-07T15:30:29.274254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23819-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vector images are made from shapes and paths so they stay sharp when resized."@en ;
  dcterms:modified "2026-06-07T15:30:29.276465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23819-2
  a curric:KeyLearningPoint ;
  rdfs:label """This makes them good for logos or icons which need to be presented in different
  sizes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23819-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bitmap images are made from pixels. They can lose quality when resized and are
  better for photos and detailed pictures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23787-1
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison operators can be used to compare values in expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.278371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23787-2
  a curric:KeyLearningPoint ;
  rdfs:label "Logical operators can be used to compare multiple comparison expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.278375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23787-3
  a curric:KeyLearningPoint ;
  rdfs:label """Selection statements can combine comparison and logical operators to build complex
  conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23863-1
  a curric:KeyLearningPoint ;
  rdfs:label """Advances in technology have made it easier to collect, store and analyse data on a
  much larger scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23863-2
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be tested and investigated using large sets of data and
  visualisation tools."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23863-3
  a curric:KeyLearningPoint ;
  rdfs:label "Data and data visualisations can be used to support an argument."@en ;
  dcterms:modified "2026-06-07T15:30:29.280735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23866-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data cleansing involves detecting and correcting, or removing, corrupt or inaccurate
  data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23866-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data cleansing is important because real-world data is often messy, with errors or
  missing information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23866-3
  a curric:KeyLearningPoint ;
  rdfs:label """Once the data is clean, charts or graphs can be created to help understand patterns
  and trends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23767-1
  a curric:KeyLearningPoint ;
  rdfs:label """Planning is a key part of the design process that can help to improve the finished
  product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23767-2
  a curric:KeyLearningPoint ;
  rdfs:label """A planning template can help plan and structure the content and layout of a digital
  product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23767-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching can be used to quickly communicate a visual idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.285832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23847-1
  a curric:KeyLearningPoint ;
  rdfs:label """Multi-path selection checks successive conditions and selects one out of multiple
  paths to follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23847-2
  a curric:KeyLearningPoint ;
  rdfs:label "Selection statements with conditions can be nested inside each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.287299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23847-3
  a curric:KeyLearningPoint ;
  rdfs:label "If selection statements are nested then code blocks must be indented."@en ;
  dcterms:modified "2026-06-07T15:30:29.287303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23790-1
  a curric:KeyLearningPoint ;
  rdfs:label """Physical computers make use of hardware components to carry out actions in the real
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23790-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hardware components can be programmed on the micro:bit to carry out actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.289047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23790-3
  a curric:KeyLearningPoint ;
  rdfs:label """The micro:bit emulator allows you to test block-based code before
  downloading it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23790-4
  a curric:KeyLearningPoint ;
  rdfs:label "Programs for the micro:bit can be transfered to the device using a USB cable."@en ;
  dcterms:modified "2026-06-07T15:30:29.289054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23838-1
  a curric:KeyLearningPoint ;
  rdfs:label "A user interface (UI) is the part of the app that users interact with."@en ;
  dcterms:modified "2026-06-07T15:30:29.293652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23838-2
  a curric:KeyLearningPoint ;
  rdfs:label "User interface elements are used to display and collect information."@en ;
  dcterms:modified "2026-06-07T15:30:29.293656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23838-3
  a curric:KeyLearningPoint ;
  rdfs:label "Apps are built for users and must be easy to navigate and understand."@en ;
  dcterms:modified "2026-06-07T15:30:29.293660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23801-1
  a curric:KeyLearningPoint ;
  rdfs:label """Conditional formatting applies a style or format to a cell based on whether a cell
  matches a certain criteria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23801-2
  a curric:KeyLearningPoint ;
  rdfs:label "Conditional formatting can be applied to specific data in a range of cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.296952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23801-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conditional formatting can be used to highlight or pick out key pieces of data."@en ;
  dcterms:modified "2026-06-07T15:30:29.296956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23801-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spreadsheet tools can be combined to analyse and present data."@en ;
  dcterms:modified "2026-06-07T15:30:29.296961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23858-1
  a curric:KeyLearningPoint ;
  rdfs:label "2D shapes can be extruded to create a 3D object."@en ;
  dcterms:modified "2026-06-07T15:30:29.301300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23858-2
  a curric:KeyLearningPoint ;
  rdfs:label "3D models are composed of faces, edges and vertices."@en ;
  dcterms:modified "2026-06-07T15:30:29.301304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23858-3
  a curric:KeyLearningPoint ;
  rdfs:label "Additional geometry can be added to a model using the loop cut tool."@en ;
  dcterms:modified "2026-06-07T15:30:29.301310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23858-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be applied to individual or groups of faces."@en ;
  dcterms:modified "2026-06-07T15:30:29.301316Z"^^xsd:dateTime .

