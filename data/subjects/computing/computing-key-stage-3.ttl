oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-07T15:30:02.347888Z"^^xsd:dateTime .

oakcurric:keyword-criteria
  a curric:Keyword ;
  schema:name "criteria"@en ;
  schema:description "the rules or guidelines used to judge or decide something"@en ;
  dcterms:modified "2026-06-07T15:30:02.347905Z"^^xsd:dateTime .

oakcurric:keyword-investigate
  a curric:Keyword ;
  schema:name "investigate"@en ;
  schema:description "to look into something carefully to find out the truth or facts"@en ;
  dcterms:modified "2026-06-07T15:30:02.347947Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description "the closing paragraph of a non-fiction text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348234Z"^^xsd:dateTime .

oakcurric:keyword-purpose
  a curric:Keyword ;
  schema:name "purpose"@en ;
  schema:description "the aim of the text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348243Z"^^xsd:dateTime .

oakcurric:keyword-testing
  a curric:Keyword ;
  schema:name "testing"@en ;
  schema:description "trying something out to see if it works well"@en ;
  dcterms:modified "2026-06-07T15:30:02.348277Z"^^xsd:dateTime .

oakcurric:keyword-object
  a curric:Keyword ;
  schema:name "object"@en ;
  schema:description """the noun, noun phrase or pronoun that receives the action of the main verb
  in the active voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348328Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-credibility
  a curric:Keyword ;
  schema:name "credibility"@en ;
  schema:description "the fact that someone can be believed or trusted"@en ;
  dcterms:modified "2026-06-07T15:30:02.348903Z"^^xsd:dateTime .

oakcurric:keyword-prefix
  a curric:Keyword ;
  schema:name "prefix"@en ;
  schema:description """a letter or group of letters added to the start of a root word to change its
  meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348935Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-bandwidth
  a curric:Keyword ;
  schema:name "bandwidth"@en ;
  schema:description """the maximum amount of data that can be transferred over a communication
  channel"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349353Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description """describes something that's based on a person's opinions, individual
  experiences, and biased influences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349519Z"^^xsd:dateTime .

oakcurric:keyword-rule-based
  a curric:Keyword ;
  schema:name "rule-based"@en ;
  schema:description "a way of designing systems using a set of predefined rules"@en ;
  dcterms:modified "2026-06-07T15:30:02.350102Z"^^xsd:dateTime .

oakcurric:keyword-data-driven
  a curric:Keyword ;
  schema:name "data-driven"@en ;
  schema:description """a way of designing systems using data instead of step-by-step instructions
  or rules"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350107Z"^^xsd:dateTime .

oakcurric:keyword-representation
  a curric:Keyword ;
  schema:name "representation"@en ;
  schema:description """ensuring that different groups of people have a voice in the decision-making
