  dcterms:modified "2026-06-07T15:30:29.401878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Classifiers can still make predictions with a high confidence score, even if the
  training data is poor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23882-3
  a curric:KeyLearningPoint ;
  rdfs:label """Causes of poor training data include: outliers, limited training data and poorly
  labelled data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23882-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to test a classifier to make sure the outputs are as expected."@en ;
  dcterms:modified "2026-06-07T15:30:29.401890Z"^^xsd:dateTime .

