  dcterms:modified "2026-06-07T15:30:29.620180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23879-4
  a curric:KeyLearningPoint ;
  rdfs:label """The infection and spread of WannaCry may have been stopped by using a combination of
  security measures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23873-1
