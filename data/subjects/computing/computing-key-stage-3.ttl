oakcurric:keylearningpoint-lesson-23835-1
  a curric:KeyLearningPoint ;
  rdfs:label """Natural numbers (like 1, 2, 3...) can be represented in binary, which uses only 0s
  and 1s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23835-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each binary digit (bit) represents a power of 2, decimal digits represent powers of
  10."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23835-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can convert a decimal number to binary by finding which powers of 2 add up to
  that number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23835-4
  a curric:KeyLearningPoint ;
