oakcurric:keylearningpoint-lesson-23834-1
  a curric:KeyLearningPoint ;
  rdfs:label """Binary digits, or bits, are the smallest unit of data in computing. They can only be
  a 0 or 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23834-2
  a curric:KeyLearningPoint ;
