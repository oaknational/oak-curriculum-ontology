  dcterms:modified "2026-06-07T15:30:29.620174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23879-3
  a curric:KeyLearningPoint ;
  rdfs:label """The WannaCry Ransomware Attack in 2017 affected more than 200 000 computers in 150
