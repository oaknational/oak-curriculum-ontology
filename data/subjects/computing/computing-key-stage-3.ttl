oakcurric:keylearningpoint-lesson-23770-3
  a curric:KeyLearningPoint ;
  rdfs:label "Planning can be used to help structure and focus the creation of content."@en ;
  dcterms:modified "2026-06-07T15:30:29.622035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23770-4
  a curric:KeyLearningPoint ;
  rdfs:label "Content can be added to a template."@en ;
  dcterms:modified "2026-06-07T15:30:29.622041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23837-1
  a curric:KeyLearningPoint ;
  rdfs:label """Encryption is the process of converting a message from plain text into
  cipher text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Encryption is used to protect data."@en ;
  dcterms:modified "2026-06-07T15:30:29.622051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23837-3
  a curric:KeyLearningPoint ;
  rdfs:label """During WWII, German officers used a special device called an Enigma machine to
  encrypt all of their communications."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23837-4
  a curric:KeyLearningPoint ;
  rdfs:label """During World War II, Alan Turing's secret work at Bletchley Park was central to
  decrypting German communications."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23864-1
  a curric:KeyLearningPoint ;
  rdfs:label """The PPDAC cycle is a framework that can be followed when asking and answering
  real-world problems using data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23864-2
  a curric:KeyLearningPoint ;
  rdfs:label "A correlation shows that there is a relationship between two or more variables."@en ;
  dcterms:modified "2026-06-07T15:30:29.622069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23864-3
  a curric:KeyLearningPoint ;
  rdfs:label "A correlation doesn't guarantee that one variable causes the other."@en ;
  dcterms:modified "2026-06-07T15:30:29.622073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23864-4
  a curric:KeyLearningPoint ;
  rdfs:label "Data that sits outside a trend is known as an outlier."@en ;
  dcterms:modified "2026-06-07T15:30:29.622077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23777-1
  a curric:KeyLearningPoint ;
  rdfs:label """The internet of things (IoT) connects everyday objects to the internet, enabling
  them to collect and share data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23777-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personal information is information collected about a person."@en ;
  dcterms:modified "2026-06-07T15:30:29.623199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23777-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understand that connected devices can gather and share your personal information,
  which can impact your privacy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23773-1
  a curric:KeyLearningPoint ;
  rdfs:label """Protocols are sets of rules that are followed to allow communication to take
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23773-2
  a curric:KeyLearningPoint ;
  rdfs:label "IP adresses are given to devices on a local network."@en ;
  dcterms:modified "2026-06-07T15:30:29.623417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23773-3
  a curric:KeyLearningPoint ;
  rdfs:label "IP addresses need to be unique on the same network."@en ;
  dcterms:modified "2026-06-07T15:30:29.623423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23773-4
  a curric:KeyLearningPoint ;
  rdfs:label """The IP addresses of both the receiver and sender need be added to every network
  message."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23778-1
  a curric:KeyLearningPoint ;
  rdfs:label "A blog is a type of website with specific features."@en ;
  dcterms:modified "2026-06-07T15:30:29.623994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23778-2
  a curric:KeyLearningPoint ;
  rdfs:label "Text formatting and styles enhance the appearance and consistency of blog posts."@en ;
  dcterms:modified "2026-06-07T15:30:29.623998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23778-3
  a curric:KeyLearningPoint ;
  rdfs:label "Blog posts have common features that distinguish them from other online content."@en ;
  dcterms:modified "2026-06-07T15:30:29.624002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23780-1
  a curric:KeyLearningPoint ;
  rdfs:label "Digital content should be analysed for credibility"@en ;
  dcterms:modified "2026-06-07T15:30:29.631140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23780-2
  a curric:KeyLearningPoint ;
  rdfs:label """Checking the author, source, purpose, date and facts is used to evaluate the
  credibility of online sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23885-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to evaluate a machine learning model’s accuracy. A confusion matrix
  can be used to visualise this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23885-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reporting a model’s accuracy improves accountability so we can be more open about
  mistakes and issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23885-3
  a curric:KeyLearningPoint ;
  rdfs:label """A model card provides more information, improving accountability and demonstrates
  responsible practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23828-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inline styling is a method of formatting a web page within the HTML file."@en ;
  dcterms:modified "2026-06-07T15:30:29.632869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23828-2
  a curric:KeyLearningPoint ;
  rdfs:label """CSS (Cascading Style Sheets) allows for centralised styling, making web page design
  more efficient and consistent"""@en ;
  dcterms:modified "2026-06-07T15:30:29.632873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23795-1
  a curric:KeyLearningPoint ;
  rdfs:label """A guide is often produced alongside a physical computing project to document how the
  project was created."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23795-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different physical computing devices have different features and capabilities."@en ;
  dcterms:modified "2026-06-07T15:30:29.634269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23795-3
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the correct device for a project depends on the requirements of the
  project."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23869-1
  a curric:KeyLearningPoint ;
  rdfs:label """The colour of each element in a digital image is represented using binary
  digits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23869-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing image quality (resolution) affects file size: higher quality increases
  size, lower quality decreases it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23869-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing colour depth affects file size: higher colour accuracy increases size,
  lower accuracy decreases it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23871-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sounds are represented as sequences of bits."@en ;
  dcterms:modified "2026-06-07T15:30:29.636298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23871-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sample rate is the number of sound samples taken per second."@en ;
  dcterms:modified "2026-06-07T15:30:29.636302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23871-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sample resolution (bit depth) is the number of bits used to represent each
  sample."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23871-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes to sample rate and sample resolution (bit depth) affect the file size and
  quality of a sound file."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23878-1
  a curric:KeyLearningPoint ;
  rdfs:label "Threats to security can be compared by likelihood and impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.638247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protective measures are used to make it difficult for attackers to achieve their
  goals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23878-3
  a curric:KeyLearningPoint ;
  rdfs:label "Combinations of protective measures make computer systems more secure."@en ;
  dcterms:modified "2026-06-07T15:30:29.638256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23878-4
  a curric:KeyLearningPoint ;
  rdfs:label "Training users of a network about risks can help keep a network secure."@en ;
  dcterms:modified "2026-06-07T15:30:29.638260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23832-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many types of representations, such as text, numbers, images, sound and
  symbols."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23832-2
  a curric:KeyLearningPoint ;
  rdfs:label "Representations help us store, share and work with information."@en ;
  dcterms:modified "2026-06-07T15:30:29.638527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23832-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sequences of 0s and 1s are used on computers to represent all types of
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23832-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different representations may be suitable for different situations."@en ;
  dcterms:modified "2026-06-07T15:30:29.638535Z"^^xsd:dateTime .

