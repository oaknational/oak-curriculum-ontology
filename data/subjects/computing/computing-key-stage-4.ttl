  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24013-1
  a curric:KeyLearningPoint ;
  rdfs:label "LLMs are trained on large amounts of text data."@en ;
  dcterms:modified "2026-06-07T15:30:29.282422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24013-2
  a curric:KeyLearningPoint ;
  rdfs:label """The aim of LLMs and chatbot applications is to provide realistic conversations by
  predicting the next word or phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24013-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is no guarantee that data used to train LLMs is accurate, unbiased and
  trustworthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24013-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bias is when the output of an AI model favours some things and deprioritises or
  excludes others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29440-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of possible states of a sequence of n bits is 2 raised to the
  power of n."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29440-2
  a curric:KeyLearningPoint ;
