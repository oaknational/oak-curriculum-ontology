  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe and design a penetration test."@en ;
  dcterms:modified "2026-06-07T15:30:41.064974Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23985
  a curric:PupilLessonOutcome ;
  rdfs:label "I can select and justify a compression method for a given scenario."@en ;
