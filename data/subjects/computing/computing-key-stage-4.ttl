oakcurric:priorknowledge-3236-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can code algorithms that use sequence, selection and iteration."@en ;
  dcterms:modified "2026-06-07T15:29:23.213031Z"^^xsd:dateTime .

oakcurric:priorknowledge-3236-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can compare the features of algorithms that complete the same task."@en ;
  dcterms:modified "2026-06-07T15:29:23.213084Z"^^xsd:dateTime .

oakcurric:priorknowledge-3236-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand how collections of data can be organised and stored in
  programs."""@en ;
  dcterms:modified "2026-06-07T15:29:23.213116Z"^^xsd:dateTime .

oakcurric:priorknowledge-3244-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that computers can be connected together in networks."@en ;
  dcterms:modified "2026-06-07T15:29:23.377053Z"^^xsd:dateTime .

oakcurric:priorknowledge-3244-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that computers on networks follow protocols in order to
  communicate."""@en ;
  dcterms:modified "2026-06-07T15:29:23.377066Z"^^xsd:dateTime .

oakcurric:priorknowledge-3244-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify common applications of computer networks."@en ;
  dcterms:modified "2026-06-07T15:29:23.377072Z"^^xsd:dateTime .

oakcurric:priorknowledge-3238-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils recognise that computer systems are the combination of hardware and software
  working together."""@en ;
  dcterms:modified "2026-06-07T15:29:23.488876Z"^^xsd:dateTime .

oakcurric:priorknowledge-3238-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can describe how instructions in a computer system are executed."@en ;
  dcterms:modified "2026-06-07T15:29:23.488887Z"^^xsd:dateTime .

oakcurric:priorknowledge-3238-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can describe the relationship between planned algorithms and the programs
  that execute them."""@en ;
  dcterms:modified "2026-06-07T15:29:23.488892Z"^^xsd:dateTime .

oakcurric:priorknowledge-3238-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils are aware of the concept of analysing data to help solve a problem."@en ;
  dcterms:modified "2026-06-07T15:29:23.488897Z"^^xsd:dateTime .

oakcurric:priorknowledge-3238-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify some uses of AI and, more specifically, machine learning."@en ;
  dcterms:modified "2026-06-07T15:29:23.488902Z"^^xsd:dateTime .

oakcurric:priorknowledge-3235-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can describe why computers use binary digits to store data and
  instructions."""@en ;
  dcterms:modified "2026-06-07T15:29:23.491327Z"^^xsd:dateTime .

