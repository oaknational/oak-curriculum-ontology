  reliability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24015-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bias is introduced into ML models when the data is unrepresentative or contains
  stereotypes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24015-4
  a curric:KeyLearningPoint ;
