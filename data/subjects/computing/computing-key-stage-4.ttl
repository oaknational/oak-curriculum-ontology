  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils recognise that text, images and sound data are represented by sequencies of
  binary digits."""@en ;
  dcterms:modified "2026-06-07T15:29:23.491344Z"^^xsd:dateTime .

