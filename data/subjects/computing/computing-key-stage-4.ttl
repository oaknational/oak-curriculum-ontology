  dcterms:modified "2026-06-07T15:30:29.349581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24123-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the agile method, smaller parts of the project are completed in priority order
  before quickly moving on to the next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24123-5
  a curric:KeyLearningPoint ;
  rdfs:label "The hybrid approach combines the best of both the waterfall and agile methods."@en ;
  dcterms:modified "2026-06-07T15:30:29.349594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24012-1
  a curric:KeyLearningPoint ;
