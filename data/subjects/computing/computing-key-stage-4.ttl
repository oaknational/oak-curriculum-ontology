  dcterms:modified "2026-06-07T15:30:29.338435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29433-1
  a curric:KeyLearningPoint ;
  rdfs:label """A function is a named block of code that is called to perform a task and will return
