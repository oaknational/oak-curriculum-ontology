oakcurric:keylearningpoint-lesson-24007-3
  a curric:KeyLearningPoint ;
  rdfs:label "Poor physical well-being can cause fatigue, illness and decreased efficiency."@en ;
  dcterms:modified "2026-06-07T15:30:29.340956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24007-4
  a curric:KeyLearningPoint ;
  rdfs:label "Promoting physical health can lead to better morale and lower healthcare costs."@en ;
  dcterms:modified "2026-06-07T15:30:29.340960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24018-1
  a curric:KeyLearningPoint ;
  rdfs:label """AI systems can pose risks such as bias, job displacement, misuse and lack of
