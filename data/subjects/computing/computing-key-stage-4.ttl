# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-linear-search
  a curric:Keyword ;
  schema:name "linear search"@en ;
  schema:description """an algorithm that searches for an item in a list of items by systematically
  examining each item, one after another"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347732Z"^^xsd:dateTime .

oakcurric:keyword-best-case
  a curric:Keyword ;
  schema:name "best-case"@en ;
  schema:description """this scenario occurs when the item you are looking for results in the
  smallest possible number of steps"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347737Z"^^xsd:dateTime .

oakcurric:keyword-worst-case
  a curric:Keyword ;
  schema:name "worst-case"@en ;
  schema:description """this scenario takes place when the item you are looking for results in the
  greatest possible number of steps"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347741Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-07T15:30:02.347888Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-constraints
  a curric:Keyword ;
  schema:name "constraints"@en ;
  schema:description "restrictions that shape a design solution"@en ;
  dcterms:modified "2026-06-07T15:30:02.347984Z"^^xsd:dateTime .

oakcurric:keyword-dynamic
  a curric:Keyword ;
  schema:name "dynamic"@en ;
  schema:description """a lively and engaging performance, full of energy, to keep the audience
  interested"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348037Z"^^xsd:dateTime .

oakcurric:keyword-content
  a curric:Keyword ;
  schema:name "Content"@en ;
  schema:description """Being content means being pleased with your situation and not looking to
  improve it."""@en ;
  dcterms:modified "2026-06-07T15:30:02.348082Z"^^xsd:dateTime .

oakcurric:keyword-purpose
  a curric:Keyword ;
  schema:name "purpose"@en ;
  schema:description "the aim of the text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348243Z"^^xsd:dateTime .

oakcurric:keyword-testing
  a curric:Keyword ;
  schema:name "testing"@en ;
  schema:description "trying something out to see if it works well"@en ;
  dcterms:modified "2026-06-07T15:30:02.348277Z"^^xsd:dateTime .

oakcurric:keyword-join
  a curric:Keyword ;
  schema:name "join"@en ;
  schema:description "how the letters are connected together"@en ;
  dcterms:modified "2026-06-07T15:30:02.348441Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description "a main idea that the writer wants to focus on"@en ;
  dcterms:modified "2026-06-07T15:30:02.348497Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-07T15:30:02.348532Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-layout
  a curric:Keyword ;
  schema:name "layout"@en ;
  schema:description "the way a text is structured"@en ;
  dcterms:modified "2026-06-07T15:30:02.348983Z"^^xsd:dateTime .

oakcurric:keyword-client-server-model
  a curric:Keyword ;
  schema:name "client-server model"@en ;
  schema:description "a network where devices are designated as clients or servers"@en ;
  dcterms:modified "2026-06-07T15:30:02.349073Z"^^xsd:dateTime .

oakcurric:keyword-personal-area-network-pan
  a curric:Keyword ;
  schema:name "personal area network (PAN)"@en ;
  schema:description """a network of personal devices that allows data to be exchanged within their
  immediate vicinity"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349077Z"^^xsd:dateTime .

oakcurric:keyword-local-area-network-lan
  a curric:Keyword ;
  schema:name "local area network (LAN)"@en ;
  schema:description """a single network covering a single site, usually covering a small
  geographical area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349082Z"^^xsd:dateTime .

oakcurric:keyword-wide-area-network-wan
  a curric:Keyword ;
  schema:name "wide area network (WAN)"@en ;
  schema:description """two or more distinct networks connected together, usually covering a large
  geographical area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349087Z"^^xsd:dateTime .

oakcurric:keyword-infrastructure
  a curric:Keyword ;
  schema:name "infrastructure"@en ;
  schema:description """the basic services and facilities needed for a city to function, such as
  water supply, electricity, sewage systems, transport and waste collection"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349268Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-bandwidth
  a curric:Keyword ;
  schema:name "bandwidth"@en ;
  schema:description """the maximum amount of data that can be transferred over a communication
  channel"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349353Z"^^xsd:dateTime .

oakcurric:keyword-routing
  a curric:Keyword ;
  schema:name "routing"@en ;
  schema:description """the process where routers select the best path for data to travel across a
  network, using rules called routing protocols"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349358Z"^^xsd:dateTime .

oakcurric:keyword-entity
  a curric:Keyword ;
  schema:name "entity"@en ;
  schema:description "a thing or existence"@en ;
  dcterms:modified "2026-06-07T15:30:02.349505Z"^^xsd:dateTime .

oakcurric:keyword-technology
  a curric:Keyword ;
  schema:name "technology"@en ;
  schema:description """the use of scientific knowledge and tools to enhance and support various
  aspects of sport and performance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349569Z"^^xsd:dateTime .

oakcurric:keyword-velocity
  a curric:Keyword ;
  schema:name "velocity"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how
  much the velocity changes per second."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349711Z"^^xsd:dateTime .

oakcurric:keyword-key
  a curric:Keyword ;
  schema:name "key"@en ;
  schema:description "the specific set of notes that a piece is based on (e.g. C minor)"@en ;
  dcterms:modified "2026-06-07T15:30:02.350003Z"^^xsd:dateTime .

oakcurric:keyword-machine-learning
  a curric:Keyword ;
  schema:name "machine learning"@en ;
