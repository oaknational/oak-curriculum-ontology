oakcurric:keylearningpoint-lesson-24791-1
  a curric:KeyLearningPoint ;
  rdfs:label "A keyboard is a common way to enter text on a computer."@en ;
  dcterms:modified "2026-06-07T15:30:29.276576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24791-2
  a curric:KeyLearningPoint ;
  rdfs:label "Keys on a keyboard have a special order."@en ;
  dcterms:modified "2026-06-07T15:30:29.276580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24791-3
  a curric:KeyLearningPoint ;
  rdfs:label "A word processor is an application designed for writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.276584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24625-1
  a curric:KeyLearningPoint ;
  rdfs:label "Each sprite has its own programming area."@en ;
  dcterms:modified "2026-06-07T15:30:29.280750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24625-2
  a curric:KeyLearningPoint ;
  rdfs:label "Projects can have multiple sprites."@en ;
  dcterms:modified "2026-06-07T15:30:29.280754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sprites can be added and deleted."@en ;
  dcterms:modified "2026-06-07T15:30:29.280757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24625-4
  a curric:KeyLearningPoint ;
  rdfs:label "An algorithm is a set of instructions, which can be turned into a program."@en ;
  dcterms:modified "2026-06-07T15:30:29.280761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24642-1
  a curric:KeyLearningPoint ;
  rdfs:label "An algorithm is a set of instructions that can be turned into a program."@en ;
  dcterms:modified "2026-06-07T15:30:29.280783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24642-2
  a curric:KeyLearningPoint ;
  rdfs:label "Programs can start with the 'start on tap' event."@en ;
  dcterms:modified "2026-06-07T15:30:29.280787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sequences of blocks must follow an algorithm to create a working program."@en ;
  dcterms:modified "2026-06-07T15:30:29.280791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24642-4
  a curric:KeyLearningPoint ;
  rdfs:label "The say block makes a sprite display text."@en ;
  dcterms:modified "2026-06-07T15:30:29.280794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24624-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some command blocks can have number values on them."@en ;
  dcterms:modified "2026-06-07T15:30:29.281954Z"^^xsd:dateTime .

