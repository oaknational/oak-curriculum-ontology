  a curric:KeyLearningPoint ;
  rdfs:label "Show and hide blocks control if a sprite is visible."@en ;
  dcterms:modified "2026-06-07T15:30:29.287397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24641-1
  a curric:KeyLearningPoint ;
