# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-computer-keyboard-letters
  a curric:Misconception ;
  curric:statement "A computer keyboard only has letters."@en ;
  curric:correction """Keyboards include keys for numbers, a space, and other special
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094287Z"^^xsd:dateTime .

oakcurric:misconception-sprites-share-same-program-commands
  a curric:Misconception ;
  curric:statement """All sprites share the same program so the commands should all be placed in the
  same place in the programming area."""@en ;
  curric:correction """Each sprite has its own programming area. Sprites have different programs and
  the commands for each one are separated to allow them to be followed independently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095584Z"^^xsd:dateTime .

oakcurric:misconception-background-changes-sprite-automatically-know
  a curric:Misconception ;
  curric:statement """When the background changes, the sprite will automatically know what to do
  next."""@en ;
  curric:correction """All of the actions need to be sequenced and tested properly so that the
  sprite's actions match the background changing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095595Z"^^xsd:dateTime .

oakcurric:misconception-value-many-times-command-run
  a curric:Misconception ;
  curric:statement "The value is always how many times the command should run."@en ;
  curric:correction """Different values cause different effects depending on the underlying command.
  These might not always be numerical values either."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095969Z"^^xsd:dateTime .

oakcurric:misconception-erase-tool-correct-tool-fix
  a curric:Misconception ;
  curric:statement "The erase tool is always the correct tool to fix mistakes."@en ;
  curric:correction """Both erase and undo tools will remove marks differently and can be used in
  different ways. The undo tool will remove the whole of a mark made at once but pupils
  might not need to do this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097650Z"^^xsd:dateTime .

oakcurric:misconception-programs-tested-finished
  a curric:Misconception ;
  curric:statement "Programs should only be tested when they are finished."@en ;
  curric:correction """Programs should be tested often to check for mistakes. Fixing mistakes as the
  program develops makes sure that these mistakes don't cause bigger issues later on and
  affect other parts of the program."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097656Z"^^xsd:dateTime .

oakcurric:misconception-programs-outcome-achieved-one-way
  a curric:Misconception ;
  curric:statement "A program’s outcome can only be achieved in one way."@en ;
  curric:correction """Using different combinations or sequences of commands can achieve the same
  outcome even though the finished solution might not have been the best way to produce the
  outcome ."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098311Z"^^xsd:dateTime .

oakcurric:misconception-commands-used-wherever-found-program
  a curric:Misconception ;
  curric:statement "Commands can be used wherever they are found in the program you are using."@en ;
  curric:correction """Commands must be dragged into the programming area so that they can be
  carried out otherwise the program will not know which object they need to be applied to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098317Z"^^xsd:dateTime .

oakcurric:misconception-use-toolbar-change-text-your
  a curric:Misconception ;
  curric:statement """You can use the toolbar to change the text on your screen no matter where you
  are in a document you are working on."""@en ;
  curric:correction """If you don't first select the text that you want to change, nothing will
  happen when you use the toolbar as the software won't know what text to apply the changes
  to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099026Z"^^xsd:dateTime .

oakcurric:misconception-pictures-line-need-counted-looking
  a curric:Misconception ;
  curric:statement "The pictures below the line need to be counted when looking at the totals."@en ;
  curric:correction """We do not count the item below the line as this is a label to see what the
  column is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099619Z"^^xsd:dateTime .

oakcurric:misconception-screen-like-piece-paper-able
  a curric:Misconception ;
  curric:statement """The screen is like a piece of paper, so you should be able to touch it to
  draw."""@en ;
  curric:correction """Digital devices work in different ways. Some devices use a finger but other
  devices can be used with a mouse, a trackpad or in other ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101217Z"^^xsd:dateTime .

oakcurric:misconception-items-background-move
  a curric:Misconception ;
  curric:statement "The items in the background can move."@en ;
  curric:correction """The background is a static image and the parts it shows are part of the same
  picture and therefore cannot move. Only sprites can move as they are separate objects."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101677Z"^^xsd:dateTime .

oakcurric:misconception-quicker-create-pictogram-hand-trying
  a curric:Misconception ;
  curric:statement """It is quicker to create a pictogram by hand than trying to create one on a
  computer."""@en ;
  curric:correction """When creating a pictogram on a computer, it is much quicker and the pictures
  will be uniform in appearance. Working on a computer also has the benefit of being able to
  make changes quickly and easily without having to redo the entire pictogram."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112127Z"^^xsd:dateTime .

oakcurric:misconception-computer-types-capital-letters
  a curric:Misconception ;
  curric:statement "A computer always types in capital letters."@en ;
  curric:correction """The default for a keyboard is lower case letters. You need to use the caps
  lock/shift to type in capital letters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112980Z"^^xsd:dateTime .

oakcurric:misconception-planning-paper-waste-time-slow
  a curric:Misconception ;
  curric:statement """Planning on paper is a waste of time and will slow a project down because
  extra work needs to be completed."""@en ;
  curric:correction """Planning on paper will make a project better because ideas can be made clear
  and possible problems later can be avoided."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113721Z"^^xsd:dateTime .

oakcurric:misconception-selecting-sprite-automatically-assigns-background
  a curric:Misconception ;
  curric:statement """Selecting a sprite automatically assigns it to the background that you want it
  on."""@en ;
  curric:correction """You need to manually place sprites and ensure their code corresponds to the
  intended background."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115699Z"^^xsd:dateTime .

oakcurric:misconception-giving-commands-make-them-long
  a curric:Misconception ;
  curric:statement """When giving commands, you should make them as long as possible so that it is
  really clear what needs to be done."""@en ;
  curric:correction """Commands are easier to understand when they are short. The more details you
  add, the more chance there is for misunderstanding. Commands need to be clear and to the
  point, leaving out any detail that would not be helpful in understanding them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116257Z"^^xsd:dateTime .

oakcurric:misconception-someone-asks-your-personal-information
  a curric:Misconception ;
  curric:statement "If someone asks you for your personal information, you should share it."@en ;
  curric:correction """You should not share your personal information with other people. If you are
  not sure, check with a trusted adult."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116271Z"^^xsd:dateTime .

oakcurric:misconception-dots-colour-appear-click-drag
  a curric:Misconception ;
  curric:statement "Dots of colour only appear when you click and drag."@en ;
  curric:correction "A single click with the paintbrush tool will make a dot of colour."@en ;
  dcterms:modified "2026-06-07T15:30:15.120818Z"^^xsd:dateTime .

oakcurric:misconception-program-works-doesnt-need-evaluating
  a curric:Misconception ;
  curric:statement "If a program works, it doesn’t need evaluating."@en ;
  curric:correction """Even working programs might need improvement to make them better, like adding
  new features, and making the program more efficient."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120824Z"^^xsd:dateTime .

oakcurric:misconception-backspace-removes-whole-sentence
  a curric:Misconception ;
  curric:statement "Backspace removes a whole sentence."@en ;
  curric:correction """Backspace removes one character at a time so that minormistakes can be
  corrected quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124649Z"^^xsd:dateTime .

oakcurric:misconception-program-run-automatically-whenever-require
  a curric:Misconception ;
  curric:statement "A program will run automatically whenever we require it."@en ;
  curric:correction """A program will not run automatically. It needs a specific command or action
  to start (like clicking the green flag or double clicking on an icon)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125372Z"^^xsd:dateTime .

oakcurric:misconception-undo-restart-your-document-beginning
  a curric:Misconception ;
  curric:statement "Undo will restart your document from the very beginning."@en ;
  curric:correction """Undo only removes the most recent change so you only need to go as far back
  as to where you made the mistake you want to correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125798Z"^^xsd:dateTime .

oakcurric:misconception-use-line-shape-tools-make
  a curric:Misconception ;
  curric:statement """I can only use the line and shape tools to make pictures. I can't combine them
  with freehand drawing or other tools."""@en ;
  curric:correction """You can use lots of different tools to make digital artwork. You can use
  different digital tools to draw shapes, colour in and add details."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130130Z"^^xsd:dateTime .

oakcurric:misconception-design-process-important-start-coding
  a curric:Misconception ;
  curric:statement "The design process is not important; you should start coding without one."@en ;
  curric:correction """Without a clear design, the program might not match the intended purpose.
  Whilst it might seem like time well spent at the start it will save time in the long run."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133091Z"^^xsd:dateTime .

oakcurric:misconception-use-certain-colours-other-artists
  a curric:Misconception ;
  curric:statement """You should only use certain colours that other artists use when creating
  artwork."""@en ;
  curric:correction """Art should be created to reflect your own style. Use colours that you think
  will make your artwork look the best."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135691Z"^^xsd:dateTime .

oakcurric:misconception-computers-better-paper
  a curric:Misconception ;
  curric:statement "Computers are always better than paper."@en ;
  curric:correction """Both digital and paper can be better for different tasks. You should choose
  the one that better suits what you need to do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140914Z"^^xsd:dateTime .

oakcurric:misconception-balanced-digital-life-means-using
  a curric:Misconception ;
  curric:statement "A balanced digital life means using IT every day."@en ;
  curric:correction """Balanced means making responsible choices in the way you use IT. It should
  not be seen as something that must be used every day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154937Z"^^xsd:dateTime .

oakcurric:misconception-used-teachers-schools
  a curric:Misconception ;
  curric:statement "IT is only used by teachers in schools."@en ;
  curric:correction """IT is used by everyone in schools, including students (e.g. on tablets or
  computers) and other staff (e.g. librarians using scanners)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164869Z"^^xsd:dateTime .

oakcurric:misconception-tally-marks-look-same-straight
  a curric:Misconception ;
  curric:statement "All tally marks should look the same in a straight line."@en ;
  curric:correction """Every fifth mark in a tally chart should be placed diagonally across a group
  of four. We do this to make it easier to count the total."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165546Z"^^xsd:dateTime .

oakcurric:misconception-found-indoors
  a curric:Misconception ;
  curric:statement "IT can only be found indoors."@en ;
  curric:correction """IT is found in many outdoor settings too, like traffic lights and security
  cameras. IT is used not just by humans sitting at desks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166340Z"^^xsd:dateTime .

oakcurric:misconception-computers-considered
  a curric:Misconception ;
  curric:statement "Only computers are considered IT."@en ;
  curric:correction """IT includes items made to work with computers, such as printers and barcodes,
  not just standalone computers like laptops or tablets."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166403Z"^^xsd:dateTime .

oakcurric:misconception-its-safe-share-passwords-friends
  a curric:Misconception ;
  curric:statement "It’s safe to share passwords with friends because they won’t misuse them."@en ;
  curric:correction """Passwords should always be kept private to protect personal information and
  keep your device safe from others using it without permission."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166409Z"^^xsd:dateTime .

oakcurric:misconception-pictogram-used-collect-different-attributes
  a curric:Misconception ;
  curric:statement """A pictogram could be used to collect different attributes of objects
  at once."""@en ;
  curric:correction """Each set of data is based on one type of attribute to allow direct comparison
  e.g. colour, shape or size."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169928Z"^^xsd:dateTime .

oakcurric:misconception-benefit-allows-us-complete-need
  a curric:Misconception ;
  curric:statement """The only benefit of IT is that it allows us to complete what we need to do in
  less time."""@en ;
  curric:correction """IT has many other benefits, including making tasks more accurate, safer and
  easier to complete. Examples of this might be organising schedules or automating
  repetitive work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170861Z"^^xsd:dateTime .

oakcurric:misconception-attributes-relate-physical-objects
  a curric:Misconception ;
  curric:statement "Attributes always relate to physical objects."@en ;
  curric:correction """Attributes can also be hidden, such as peoples' jobs or preferences. They
  exist but in order to determine what they are you have to ask people."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171264Z"^^xsd:dateTime .
