oakcurric:priorknowledge-3339-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that computer systems can be connected."@en ;
  dcterms:modified "2026-06-07T15:29:24.649375Z"^^xsd:dateTime .

oakcurric:priorknowledge-3339-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that the internet is a large-scale network."@en ;
  dcterms:modified "2026-06-07T15:29:24.649388Z"^^xsd:dateTime .

oakcurric:priorknowledge-3339-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify common networking hardware."@en ;
  dcterms:modified "2026-06-07T15:29:24.649394Z"^^xsd:dateTime .

oakcurric:priorknowledge-3339-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can explain the concept of routing on networks."@en ;
  dcterms:modified "2026-06-07T15:29:24.649398Z"^^xsd:dateTime .

oakcurric:priorknowledge-3339-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can describe why people need to communicate using digital devices."@en ;
  dcterms:modified "2026-06-07T15:29:24.649403Z"^^xsd:dateTime .

oakcurric:priorknowledge-3323-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand that digital devices capture input."@en ;
  dcterms:modified "2026-06-07T15:29:24.659675Z"^^xsd:dateTime .

oakcurric:priorknowledge-3323-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand that digital devices process data into useful outputs."@en ;
  dcterms:modified "2026-06-07T15:29:24.659686Z"^^xsd:dateTime .

oakcurric:priorknowledge-3323-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand that computer systems are the combination of many
  component parts."""@en ;
  dcterms:modified "2026-06-07T15:29:24.659691Z"^^xsd:dateTime .

oakcurric:priorknowledge-3323-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand what data is and how it is collected to summarise information
  about the real world."""@en ;
  dcterms:modified "2026-06-07T15:29:24.659696Z"^^xsd:dateTime .

oakcurric:priorknowledge-3318-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can store and use media content on digital devices."@en ;
  dcterms:modified "2026-06-07T15:29:24.878057Z"^^xsd:dateTime .

oakcurric:priorknowledge-3318-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that content is generated for an audience."@en ;
  dcterms:modified "2026-06-07T15:29:24.878069Z"^^xsd:dateTime .

oakcurric:priorknowledge-3344-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that inputs can be captured and used in computer programs."@en ;
  dcterms:modified "2026-06-07T15:29:24.885622Z"^^xsd:dateTime .

oakcurric:priorknowledge-3344-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can create programs that test conditions to determine paths of action."@en ;
  dcterms:modified "2026-06-07T15:29:24.885636Z"^^xsd:dateTime .

oakcurric:priorknowledge-3344-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can create block-based programs that make use of: sequence, selection,
  iteration and variables."""@en ;
  dcterms:modified "2026-06-07T15:29:24.885643Z"^^xsd:dateTime .

oakcurric:priorknowledge-3344-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils recognise that computer systems process inputs into useful outputs through
  combinations of hardware."""@en ;
  dcterms:modified "2026-06-07T15:29:24.885658Z"^^xsd:dateTime .

oakcurric:priorknowledge-3316-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils should have some prior experience of programming."@en ;
  dcterms:modified "2026-06-07T15:29:25.052090Z"^^xsd:dateTime .

oakcurric:priorknowledge-3316-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils should be aware that instructions can be represented in code."@en ;
  dcterms:modified "2026-06-07T15:29:25.052106Z"^^xsd:dateTime .

oakcurric:priorknowledge-3316-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should be aware that the sequence of commands can affect the outcome of the
  program."""@en ;
  dcterms:modified "2026-06-07T15:29:25.052113Z"^^xsd:dateTime .

oakcurric:priorknowledge-3342-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils understand the representation of numerical information in graphical form."@en ;
  dcterms:modified "2026-06-07T15:29:25.054450Z"^^xsd:dateTime .

oakcurric:priorknowledge-3342-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils recognise that data can take different forms."@en ;
  dcterms:modified "2026-06-07T15:29:25.054464Z"^^xsd:dateTime .

oakcurric:priorknowledge-3342-3
