# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-24756-1
  a curric:KeyLearningPoint ;
  rdfs:label "Data sent across networks is split into smaller parts called packets."@en ;
  dcterms:modified "2026-06-07T15:30:29.268536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24756-2
  a curric:KeyLearningPoint ;
  rdfs:label "Data is transferred over networks in packets."@en ;
  dcterms:modified "2026-06-07T15:30:29.268540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24756-3
  a curric:KeyLearningPoint ;
  rdfs:label "All data transferred over the internet is in packets."@en ;
  dcterms:modified "2026-06-07T15:30:29.268543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24702-1
  a curric:KeyLearningPoint ;
  rdfs:label """A data logger is a digital device that can automatically record data from sensors
  over a period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24702-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data loggers take readings at set intervals (e.g., every 1 second, 5 minutes, or 1
  hour)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The timing of these intervals affects how detailed the collected data will be."@en ;
  dcterms:modified "2026-06-07T15:30:29.268966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24702-4
  a curric:KeyLearningPoint ;
  rdfs:label "Shorter intervals give more detailed data, but require more storage."@en ;
  dcterms:modified "2026-06-07T15:30:29.269001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24702-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using this data, you can identify and explain patterns shown in the data."@en ;
  dcterms:modified "2026-06-07T15:30:29.269005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24701-1
  a curric:KeyLearningPoint ;
  rdfs:label "A data logger is a digital device that records data using sensors."@en ;
  dcterms:modified "2026-06-07T15:30:29.269791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24701-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sensors can collect various types of data, such as temperature, light and
  movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24701-3
  a curric:KeyLearningPoint ;
  rdfs:label "Data from sensors can help answer real-world questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.269799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24705-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data collected from sensors can help answer specific questions by showing what
  happened, when, and how it changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24705-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation involves identifying patterns, spikes, trends, and any unusual
  readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24705-3
  a curric:KeyLearningPoint ;
  rdfs:label "Data loggers provide accurate, reliable, and consistent data."@en ;
  dcterms:modified "2026-06-07T15:30:29.270033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24705-4
  a curric:KeyLearningPoint ;
  rdfs:label "They can record data over long periods, even when people are not present."@en ;
  dcterms:modified "2026-06-07T15:30:29.270037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24704-1
  a curric:KeyLearningPoint ;
  rdfs:label """To answer a question effectively, it’s important to first identify what kind of data
  is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24704-2
  a curric:KeyLearningPoint ;
  rdfs:label """Good questions for data logging are ones that involve change over time or measurable
  patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24704-3
  a curric:KeyLearningPoint ;
  rdfs:label "Effective data collection requires planning."@en ;
  dcterms:modified "2026-06-07T15:30:29.271586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24704-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should consider what sensor to use, how often will data be recorded and where
  will the logger be placed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24703-1
  a curric:KeyLearningPoint ;
  rdfs:label "Computers make it easier and faster to analyse large amounts of data."@en ;
  dcterms:modified "2026-06-07T15:30:29.273155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24703-2
  a curric:KeyLearningPoint ;
  rdfs:label "Data can be displayed in summary form or in more detailed views."@en ;
  dcterms:modified "2026-06-07T15:30:29.273159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24703-3
  a curric:KeyLearningPoint ;
  rdfs:label """Data can be sorted by different fields to make it easier to spot trends or locate
  specific information."""@en ;
