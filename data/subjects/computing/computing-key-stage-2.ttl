  schema:name "instant messaging"@en ;
  schema:description "real time text communication online"@en ;
  dcterms:modified "2026-06-07T15:30:02.425084Z"^^xsd:dateTime .

oakcurric:keyword-video-call
  a curric:Keyword ;
  schema:name "video call"@en ;
  schema:description "a conversation using video and audio over the internet"@en ;
  dcterms:modified "2026-06-07T15:30:02.425090Z"^^xsd:dateTime .

oakcurric:keyword-branching-tree-diagram
  a curric:Keyword ;
  schema:name "branching tree diagram"@en ;
  schema:description """a diagram where data is organised into a structure that is like an
  upside-down tree"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425267Z"^^xsd:dateTime .

oakcurric:keyword-ownership
  a curric:Keyword ;
  schema:name "ownership"@en ;
  schema:description """having control or rights over something, like a piece of digital content or
  a website, means you are the person who owns or is responsible for it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425458Z"^^xsd:dateTime .

oakcurric:keyword-internet-protocol-ip-address
  a curric:Keyword ;
  schema:name "Internet Protocol (IP) address"@en ;
  schema:description """an identifier, such as 192.168.4.8, that is assigned to a networked
  device"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427202Z"^^xsd:dateTime .

oakcurric:keyword-world-wide-web
  a curric:Keyword ;
  schema:name "World Wide Web"@en ;
  schema:description """a service provided via the internet, which allows us to access web pages and
  other shared files"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427461Z"^^xsd:dateTime .

oakcurric:keyword-images
  a curric:Keyword ;
  schema:name "images"@en ;
  schema:description "pictures that pass on a message"@en ;
  dcterms:modified "2026-06-07T15:30:02.428446Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-data-sent-once-one-big
  a curric:Misconception ;
  curric:statement "Data is sent all at once as one big file."@en ;
  curric:correction "Data is split into packets, sent separately and then reassembled."@en ;
  dcterms:modified "2026-06-07T15:30:15.091312Z"^^xsd:dateTime .

oakcurric:misconception-shorter-intervals-give-less-detailed
  a curric:Misconception ;
  curric:statement "Shorter intervals give less detailed data."@en ;
  curric:correction """If you were to take your temperature every minute, you would have more
  detailed data than if you took your temperature every hour because there would be more
  readings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091461Z"^^xsd:dateTime .

oakcurric:misconception-sensor-ouput-device
  a curric:Misconception ;
  curric:statement "A sensor is an ouput device."@en ;
  curric:correction """A sensor is an input device that allows a computer to collect data from the
  physical environment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091765Z"^^xsd:dateTime .

oakcurric:misconception-data-loggers-better-collecting-data
  a curric:Misconception ;
  curric:statement "Data loggers are better at collecting data than humans."@en ;
  curric:correction """There are many advantages for using data loggers but they can’t collect all
  types of data so cannot be thought to be better than humans in all situations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091844Z"^^xsd:dateTime .

oakcurric:misconception-gather-data-minute-two-check
  a curric:Misconception ;
  curric:statement """If you gather data for a minute or two to check that the data collected looks
  ok, your experiment will be successful."""@en ;
  curric:correction """There might be other factors that affect your experiment, which are out of
  your control. For example, someone could unplug your data logger, the batteries might run
  out or the data may be corrupt due to an issue with the hardware or software."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092475Z"^^xsd:dateTime .

oakcurric:misconception-data-collected-data-logger-used
  a curric:Misconception ;
  curric:statement """Data collected by a data logger can only be used in the data logging
  software."""@en ;
  curric:correction """You can export the data from the data logging software into a spreadsheet
  that then allows you to perform lots of operations on the data."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093035Z"^^xsd:dateTime .

oakcurric:misconception-choosing-images-pupils-select-ones
  a curric:Misconception ;
  curric:statement """When choosing images, pupils should select the ones they like best rather than
  the most appropriate images."""@en ;
  curric:correction """When choosing an image, it’s important to select one that best fits the
  purpose and message of the work, rather than just picking one based on personal
  preference."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093347Z"^^xsd:dateTime .

oakcurric:misconception-order-conditions-else-chain-doesnt
  a curric:Misconception ;
  curric:statement "The order of conditions in an if/else if chain doesn't matter."@en ;
  curric:correction "Conditions are checked in order, so earlier ones take priority."@en ;
  dcterms:modified "2026-06-07T15:30:15.093367Z"^^xsd:dateTime .

oakcurric:misconception-parts-else-statement-run-time
  a curric:Misconception ;
  curric:statement "All parts of an if/then/else statement run every time."@en ;
  curric:correction "Only the part that matches the condition will run."@en ;
  dcterms:modified "2026-06-07T15:30:15.094239Z"^^xsd:dateTime .

oakcurric:misconception-order-command-blocks-joined-together
  a curric:Misconception ;
  curric:statement """The order that command blocks are joined together does not make a difference
  to the outcome."""@en ;
  curric:correction """The order of a sequence is important. A program will only follow the commands
  that it is given in the order that they are connected."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094250Z"^^xsd:dateTime .

oakcurric:misconception-spreadsheet-software-good-now-dont
  a curric:Misconception ;
  curric:statement """Spreadsheet software is so good now that you don't need to spend time
  formatting cells for the expected data as it will do it automatically."""@en ;
  curric:correction """Spreadsheet software can help, but you still need to format cells correctly
  to make sure the data will be displayed in the exact way you need it to be. Software
  doesn't always get this right."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094256Z"^^xsd:dateTime .

oakcurric:misconception-charts-made-same-data-equally
  a curric:Misconception ;
  curric:statement "All charts made from the same data are equally useful."@en ;
  curric:correction """Some charts might not help answer a specific question, even if they are
  accurate. Choosing the right chart type and structure matters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094264Z"^^xsd:dateTime .

oakcurric:misconception-new-programmers-bugs-their-programs
  a curric:Misconception ;
  curric:statement "Only new programmers will have bugs in their programs."@en ;
  curric:correction """Every programmer will need to correct errors and debug their code. Part of
  the process of programming is correcting mistakes made as you go along. Regluarly test
  your program does what it needs to as you go along."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094272Z"^^xsd:dateTime .

oakcurric:misconception-write-code-testing
  a curric:Misconception ;
  curric:statement "You should write all the code before testing."@en ;
  curric:correction """Test small parts frequently to catch errors early. It is easier to fix a few
  errors at a time than all of them at once."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094741Z"^^xsd:dateTime .

oakcurric:misconception-selection-used-turning-things
  a curric:Misconception ;
  curric:statement "Selection is only used for turning things on and off."@en ;
  curric:correction """Selection can be used for different actions, such as changing speed, colour,
  or sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095054Z"^^xsd:dateTime .

oakcurric:misconception-using-produces-results-search-single
  a curric:Misconception ;
  curric:statement "Using ‘AND’ produces more results than a search with a single condition."@en ;
  curric:correction """‘AND’ reduces the number of results because it narrows the search to records
  that meet all the given conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095060Z"^^xsd:dateTime .

oakcurric:misconception-wire-connect-component-circuit-work
  a curric:Misconception ;
  curric:statement "Any wire can connect any component and the circuit will work."@en ;
  curric:correction """Specific pads must be connected correctly to complete a circuit. Circuits
  that are not complete will not work as charge will not be able to flow."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095578Z"^^xsd:dateTime .

oakcurric:misconception-appearance-text-made-exciting-possible
  a curric:Misconception ;
  curric:statement """The appearance of text should be made as exciting as possible so that people
  want to read it."""@en ;
  curric:correction """Overly decorative text can be distracting and might put people off reading
  it. Clear, well-structured formatting makes text easier to read and more effective at
  communicating a message."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095974Z"^^xsd:dateTime .

oakcurric:misconception-once-project-programmed-its-finished
  a curric:Misconception ;
  curric:statement "Once the project has been programmed, it's finished."@en ;
  curric:correction """It's important to test and debug to make sure the project works as intended.
  Look back at what was set as to what would make the project a success and consider how
  well the pogram carries out the task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095980Z"^^xsd:dateTime .

oakcurric:misconception-animation-single-picture
  a curric:Misconception ;
  curric:statement "Animation is a single picture."@en ;
  curric:correction """Animation is a way of making pictures or objects look as if they are moving
  by showing a sequence of them quickly one after another."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096016Z"^^xsd:dateTime .

oakcurric:misconception-need-program-one-loop-whole
  a curric:Misconception ;
  curric:statement "You only need to program one loop for a whole game."@en ;
  curric:correction """Each sprite needs its own loop so it can repeat its actions
  independently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096027Z"^^xsd:dateTime .

oakcurric:misconception-good-idea-add-external-links
  a curric:Misconception ;
  curric:statement "It is always a good idea to add external links to your website."@en ;
  curric:correction """Adding external links to your website can have some implications. For
  example, the website could be moved and you can then end up with a broken link on your
  website."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096035Z"^^xsd:dateTime .

oakcurric:misconception-need-test-your-program-finished
  a curric:Misconception ;
  curric:statement "You only need to test your program when you have finished writing it."@en ;
  curric:correction "Test your program often, especially after you finish a section."@en ;
  dcterms:modified "2026-06-07T15:30:15.096842Z"^^xsd:dateTime .

oakcurric:misconception-statements-checked-once-program
  a curric:Misconception ;
  curric:statement "If… then… statements can be checked once in a program."@en ;
  curric:correction """An if... then... statement can be made to repeatedly check a condition by
  using a forever loop."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096852Z"^^xsd:dateTime .

oakcurric:misconception-save-save-same-thing
  a curric:Misconception ;
  curric:statement "Save and save as do the same thing."@en ;
  curric:correction """Pressing save will save the file as the current filename and possibly
  overwrite an existing file. Selecting save as lets you specify a new file name and/or
  location."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097628Z"^^xsd:dateTime .

oakcurric:misconception-shapes-model-seen-one-perspective
  a curric:Misconception ;
  curric:statement "All the shapes of a model can be seen from one perspective."@en ;
  curric:correction """Some shapes may be not able to be seen from one perspective, they may be
  hiding behind other shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097638Z"^^xsd:dateTime .

oakcurric:misconception-shape-inspector-used-change-length
  a curric:Misconception ;
  curric:statement "The shape inspector is only used to change the length or width of a shape."@en ;
  curric:correction """You can use the shape inspector to customise different properties of a shape,
  including recolouring shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097644Z"^^xsd:dateTime .

oakcurric:misconception-data-travels-one-large-piece
  a curric:Misconception ;
  curric:statement "Data travels in one large piece across the network."@en ;
  curric:correction """Data is split into smaller packets, which travel separately and are
  reassembled at the destination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098104Z"^^xsd:dateTime .

oakcurric:misconception-easier-create-document-adding-detail
  a curric:Misconception ;
  curric:statement """It is easier to create a document by adding all the detail first and changing
  the layout later."""@en ;
  curric:correction """It's more efficient to plan the layout first before adding all the details.
  Organising the structure early helps avoid major formatting changes later, making the
  document easier to edit and read."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098995Z"^^xsd:dateTime .

oakcurric:misconception-want-start-coding-my-game
  a curric:Misconception ;
  curric:statement """I want to start coding my game right away! Why do I need to draw pictures and
  write descriptions first?"""@en ;
  curric:correction """By designing first, you're planning out exactly what you want your game to do
  and how it will work before you write any code."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099275Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-code-block-applies
  a curric:Misconception ;
  curric:statement """Some pupils may think that a code block applies to all the sprites in a
  project."""@en ;
  curric:correction """Multiple sprites can be controlled using separate commands and they each need
  their own code blocks to control them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099630Z"^^xsd:dateTime .

oakcurric:misconception-program-runs-correct
  a curric:Misconception ;
  curric:statement "If the program runs, it must be correct."@en ;
  curric:correction """Explain that a program can run but still be wrong if it doesn’t match the
  intended outcome. Debugging ensures accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099655Z"^^xsd:dateTime .

oakcurric:misconception-checking-variable-changes-its-value
  a curric:Misconception ;
  curric:statement "Checking a variable changes its value."@en ;
  curric:correction "Reading a variable's value doesn't change it, only assigning it does."@en ;
  dcterms:modified "2026-06-07T15:30:15.099670Z"^^xsd:dateTime .

oakcurric:misconception-first-question-matters-thinking-ordering
  a curric:Misconception ;
  curric:statement """Only the first question matters when you are thinking about ordering the
  questions in your branching database."""@en ;
  curric:correction """The first question is really important but you also need to think carefully
  about the order of the other questions so that the branching database works properly and
  all objects can be identified."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101351Z"^^xsd:dateTime .

oakcurric:misconception-spreadsheets-make-planning-event-difficult
  a curric:Misconception ;
  curric:statement """Spreadsheets make planning an event more difficult as you have to enter data
  and use formulas."""@en ;
  curric:correction """Spreadsheets make planning an event easier as they have useful tools that
  save you work and allow you to make changes. You can use spreadsheets to model changes to
  the event and instantly recalulate all the important information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101357Z"^^xsd:dateTime .

oakcurric:misconception-grouping-object-turns-objects-blue
  a curric:Misconception ;
  curric:statement "Grouping an object turns all of the objects blue-coloured forever."@en ;
  curric:correction """Objects can be ungrouped, which will return the objects to their original
  colours."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101363Z"^^xsd:dateTime .

oakcurric:misconception-make-letter-start-animating-one
  a curric:Misconception ;
  curric:statement """You have to make each letter start animating one after another after the green
  flag is pressed."""@en ;
  curric:correction """When you press the green flag (or another event block), you can make two or
  more sprites start animating at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102035Z"^^xsd:dateTime .

oakcurric:misconception-graphically-presented-data-easier-understand
  a curric:Misconception ;
  curric:statement """Graphically presented data is always easier to understand than data in
  tables."""@en ;
  curric:correction """Graphical charts help to spot patterns in the data they are based on but they
  are not intended to be able to read actual values. Tables should be used to provide the
  exact values."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102266Z"^^xsd:dateTime .

oakcurric:misconception-object-worked-one-time
  a curric:Misconception ;
  curric:statement "Each object has to be worked on one at a time."@en ;
  curric:correction "Objects can be grouped together to duplicate or edit at the same time."@en ;
  dcterms:modified "2026-06-07T15:30:15.102316Z"^^xsd:dateTime .

oakcurric:misconception-branching-databases-used-identify-objects
  a curric:Misconception ;
  curric:statement "Branching databases can only be used to identify objects."@en ;
  curric:correction """In the real world, branching databases can be used for many reasons such as
  finding faults and diagnosing illnesses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102853Z"^^xsd:dateTime .

oakcurric:misconception-digital-device-play-audio
  a curric:Misconception ;
  curric:statement "Any digital device can play audio."@en ;
  curric:correction """In order for a digital device to play audio it needs to have an appropriate
  output device. These are sometimes in-built in the device but for some devices they may
  need to be attached separately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103447Z"^^xsd:dateTime .

oakcurric:misconception-vector-drawings-cannot-edited
  a curric:Misconception ;
  curric:statement "Vector drawings cannot be edited."@en ;
  curric:correction "Each element added to a vector drawing is an editable object."@en ;
  dcterms:modified "2026-06-07T15:30:15.103455Z"^^xsd:dateTime .

oakcurric:misconception-devices-cameras-microphones-same-location
  a curric:Misconception ;
  curric:statement "All devices have cameras and microphones in the same location."@en ;
  curric:correction """Devices differ, so may have cameras and microphones in different
  locations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104055Z"^^xsd:dateTime .

oakcurric:misconception-sprite-use-one-type-code
  a curric:Misconception ;
  curric:statement "A sprite can only use one type of code block in a sequence."@en ;
  curric:correction """A sprite can have sequences made up from multiple types of code block. For
  example, sound and motion code blocks can be combined."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105576Z"^^xsd:dateTime .

oakcurric:misconception-audio-tracks-need-play-separately
  a curric:Misconception ;
  curric:statement """Audio tracks need to play separately from one another so that the sound is
  clear."""@en ;
  curric:correction """Layering tracks can create new and interesting audio where the sound works
  well together to create something new and interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105587Z"^^xsd:dateTime .

oakcurric:misconception-why-variable-name-matter-cant
  a curric:Misconception ;
  curric:statement """Why does the variable name matter? Can't I just call it \"Number\" or
  \"Variable_A\"?"""@en ;
  curric:correction """You can call a variable anything you like but it's not very helpful for
  someone wanting to understand what your program does. The name of a variable should
  clearly identify what data it will hold as the program runs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106267Z"^^xsd:dateTime .

oakcurric:misconception-vector-drawings-same-paper-based
  a curric:Misconception ;
  curric:statement "Vector drawings are the same as paper-based drawings."@en ;
  curric:correction """Vector drawings are made up of shapes layered together, not single lines
  drawn."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106275Z"^^xsd:dateTime .

oakcurric:misconception-size-sprite-doesnt-matter-programming
  a curric:Misconception ;
  curric:statement "The size of the sprite doesn't matter when programming movement."@en ;
  curric:correction """Sprite size is important, especially in a maze, as if the sprite is too big
  it will touch the walls."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106749Z"^^xsd:dateTime .

oakcurric:misconception-database-tells-best-option-automatically
  a curric:Misconception ;
  curric:statement "The database tells you the 'best' option automatically."@en ;
  curric:correction """The database provides data, but users must decide which option is best by
  comparing data in fields like price, duration and times. The 'best' choice depends on the
  situation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106755Z"^^xsd:dateTime .

oakcurric:misconception-designing-extra-work
  a curric:Misconception ;
  curric:statement "Designing is just extra work."@en ;
  curric:correction """Planning reduces how much you have to think about when you are actually
  coding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106760Z"^^xsd:dateTime .

oakcurric:misconception-vector-drawings-paint-program-drawings
  a curric:Misconception ;
  curric:statement "Vector drawings and paint program drawings are the same."@en ;
  curric:correction """Vector drawings are made out of shapes, paint program drawings are more about
  line drawing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107758Z"^^xsd:dateTime .

oakcurric:misconception-searching-database-changes-records
  a curric:Misconception ;
  curric:statement "Searching a database changes all the records."@en ;
  curric:correction """Searching only shows the records that match the search; it does not change
  the database itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107764Z"^^xsd:dateTime .

oakcurric:misconception-look-record-individually-find-answer
  a curric:Misconception ;
  curric:statement "You must look through every record individually to find an answer."@en ;
  curric:correction """Sorting a computer database by fields allows you to quickly find answers
  without checking each record one at a time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107819Z"^^xsd:dateTime .

oakcurric:misconception-my-quiz-works-perfectly-first
  a curric:Misconception ;
  curric:statement """My quiz works perfectly the first time you run it, and that's all that
  matters."""@en ;
  curric:correction """You need setup code at the beginning of your program to reset everything, so
  that new users have the same experience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110330Z"^^xsd:dateTime .

oakcurric:misconception-order-sequence-program-doesnt-matter
  a curric:Misconception ;
  curric:statement "The order of a sequence in a program doesn't matter."@en ;
  curric:correction """A computer will only follow the directions it is given. A program will follow
  the sequence it is given and the sequence will affect the output, even if this output is
  incorrect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110335Z"^^xsd:dateTime .

oakcurric:misconception-storyboard-include-images-screen-video
  a curric:Misconception ;
  curric:statement "A storyboard should just include the images of each screen of a video."@en ;
  curric:correction """A storyboard can plan the filming techniques and audio that will be on each
  screen of the video as well as the images or video footage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112122Z"^^xsd:dateTime .

oakcurric:misconception-changing-image-colouring-make-everyone
  a curric:Misconception ;
  curric:statement """Changing image colouring will make everyone think and feel the same way about
  the image."""@en ;
  curric:correction """Lots of people might have similar feelings but not everyone will necessarily
  have the same thoughts and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113584Z"^^xsd:dateTime .

oakcurric:misconception-algorithm-cannot-represented-code
  a curric:Misconception ;
  curric:statement "An algorithm cannot be represented in code."@en ;
  curric:correction """An algorithm is a description of the instructions to follow so that a
  specified task can be completed. Therefore, algorithms can be converted and represented in
  to program code to enable a computer to carry out the solution to a task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113598Z"^^xsd:dateTime .

oakcurric:misconception-website-look-same-device-accessed
  a curric:Misconception ;
  curric:statement "A website will look the same on any device that it is accessed from."@en ;
  curric:correction """A website will look different on different devices. This is because they have
  different screen sizes. Checking a website is compatible for multiple devices is
  important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113665Z"^^xsd:dateTime .

oakcurric:misconception-its-ok-your-background-characters
  a curric:Misconception ;
  curric:statement "It’s OK if your background or characters move quite a bit between frames."@en ;
  curric:correction """Even small changes can make the animation look jumpy. Keeping things still is
  key to making it look real."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113673Z"^^xsd:dateTime .

oakcurric:misconception-mistake-audio-recording-need-re
  a curric:Misconception ;
  curric:statement """If there is a mistake in an audio recording, it will need to be
  re-recorded."""@en ;
  curric:correction """Small mistakes in audio can be trimmed without needing to re-record an entire
  vocal track. Small adjustments to audio are difficult to detect and can improve the
  quality of a track."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113693Z"^^xsd:dateTime .

oakcurric:misconception-create-formula-spreadsheet-yourself-even
  a curric:Misconception ;
  curric:statement """You should create a formula in a spreadsheet yourself even if a pre-built
  function already exisits that does what you need your formula to do."""@en ;
  curric:correction """Use pre-built spreadsheet functions whenever possible to save time and avoid
  mistakes. Use of technology should help you find ways to assist in what you need to do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114081Z"^^xsd:dateTime .

oakcurric:misconception-put-change-score-block-my
  a curric:Misconception ;
  curric:statement """I put the \"change score by\" block in my code, but the score isn't changing
  when I expect it to."""@en ;
  curric:correction """The location of your \"change score by\" block dramatically affects when and
  how often the score changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114149Z"^^xsd:dateTime .

oakcurric:misconception-creating-document-likely-get-want
  a curric:Misconception ;
  curric:statement "Creating a document, you will likely get it how you want first time."@en ;
  curric:correction """It is common to take many attempts to create documents and make it the best
  possible. To make the best document, it is likely you will have to make many adjustments
  along the way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114728Z"^^xsd:dateTime .

oakcurric:misconception-ive-finished-my-game-theres
  a curric:Misconception ;
  curric:statement "I've finished my game — there's nothing else to do."@en ;
  curric:correction """A part of being a good programmer is knowing how to evaluate and improve your
  projects. Think about how your game could be even better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115713Z"^^xsd:dateTime .

oakcurric:misconception-question-used-create-branching-database
  a curric:Misconception ;
  curric:statement "Any question can be used to create a branching database successfully."@en ;
  curric:correction """A good question should split the data evenly to make sure the number of
  questions required to reach what is being looked for is minimised."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116280Z"^^xsd:dateTime .

oakcurric:misconception-using-cloning-tool-make-invisible
  a curric:Misconception ;
  curric:statement "Using a cloning tool will always make invisible changes to an image."@en ;
  curric:correction """The cloning tool needs to be used carefully and precisely to make changes
  look realistic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116289Z"^^xsd:dateTime .

oakcurric:misconception-condition-needs-checked-once
  a curric:Misconception ;
  curric:statement "A condition only needs to be checked once."@en ;
  curric:correction """Conditions need to be constantly checked to make sure the program reacts when
  the rule is met."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116306Z"^^xsd:dateTime .

oakcurric:misconception-computers-used-make-imaginary-models
  a curric:Misconception ;
  curric:statement """Computers are only used to make imaginary models that can’t be created in real
  life."""@en ;
  curric:correction """Architects who design real buildings use 3D modelling software to ensure
  their designs are accurate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117422Z"^^xsd:dateTime .

oakcurric:misconception-objects-cannot-reordered-page
  a curric:Misconception ;
  curric:statement "Objects cannot be reordered on the page."@en ;
  curric:correction "Each object added is a new layer and the layers can be reordered."@en ;
  dcterms:modified "2026-06-07T15:30:15.117902Z"^^xsd:dateTime .

oakcurric:misconception-changing-value-repeat-block-changes
  a curric:Misconception ;
  curric:statement "Changing the value in the repeat block changes the shape’s size."@en ;
  curric:correction """The repeat block sets the number of sides (how many times the sprite moves
  and turns). The move x steps value controls the size."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117908Z"^^xsd:dateTime .

oakcurric:misconception-sprites-move-press-key-click
  a curric:Misconception ;
  curric:statement """Sprites will move when you press a key or click the mouse, even if they don’t
  have any code."""@en ;
  curric:correction """Sprites always need code to control their movement. Computers do not guess
  what is required as they need some direction to carry out actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118559Z"^^xsd:dateTime .

oakcurric:misconception-computer-understands-procedure-names-knows
  a curric:Misconception ;
  curric:statement """The computer understands procedure names and knows what to do based on the
  chosen name."""@en ;
  curric:correction """The name is for humans, the computer only follows the instructions inside the
  procedure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119121Z"^^xsd:dateTime .

oakcurric:misconception-write-new-program-time-use
  a curric:Misconception ;
  curric:statement "You must write a new program every time you use the micro:bit."@en ;
  curric:correction """You can reuse and edit programs on the micro:bit once they're
  transferred."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119126Z"^^xsd:dateTime .

oakcurric:misconception-because-computer-connected-network-connected
  a curric:Misconception ;
  curric:statement """Because a computer is connected to a network, it will be connected to the
  internet."""@en ;
  curric:correction """Not necessarily, it still needs a connection to the internet through a
  router. Networks can be created and used for many different purposes and that does not
  always have to involve being connected to the internet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119649Z"^^xsd:dateTime .

oakcurric:misconception-need-email-file-share
  a curric:Misconception ;
  curric:statement "You need to email a file to share it."@en ;
  curric:correction """Shared links and cloud storage allow others to open the same file
  directly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120208Z"^^xsd:dateTime .

oakcurric:misconception-hyperlink-text
  a curric:Misconception ;
  curric:statement "A hyperlink is always text."@en ;
  curric:correction "A hyperlink can be text, images or other media."@en ;
  dcterms:modified "2026-06-07T15:30:15.120764Z"^^xsd:dateTime .

oakcurric:misconception-computer-understand-meant-even-make
  a curric:Misconception ;
  curric:statement "The computer can understand what I meant even if I make a small mistake."@en ;
  curric:correction """Computers follow exact instructions, so even a tiny error (like typing f 100
  instead of fd 100) will cause problems. Programmers need to carefully check the programs
  they make."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120813Z"^^xsd:dateTime .

oakcurric:misconception-write-your-program-designing
  a curric:Misconception ;
  curric:statement "You should write your program before designing it."@en ;
  curric:correction "Designing first helps you plan what the program needs to do."@en ;
  dcterms:modified "2026-06-07T15:30:15.122898Z"^^xsd:dateTime .

oakcurric:misconception-put-placeholder-inside-shape-make
  a curric:Misconception ;
  curric:statement """When you put a placeholder inside a shape, make sure both of them are flat on
  the workspace with no gap."""@en ;
  curric:correction """If you don't raise the placeholder off the workplane so there is a hole at
  the bottom of the shape, the shape will be completely hollow and can't work as a
  container."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123202Z"^^xsd:dateTime .

oakcurric:misconception-variables-numbers
  a curric:Misconception ;
  curric:statement "Variables are only for numbers."@en ;
  curric:correction "Variables aren't just for numbers, they can also hold letters."@en ;
  dcterms:modified "2026-06-07T15:30:15.123207Z"^^xsd:dateTime .

oakcurric:misconception-website-web-page-same
  a curric:Misconception ;
  curric:statement "A website and a web page are the same."@en ;
  curric:correction """A website is a collection of information relating to a particular topic that
  can be accessed on a range of devices. Websites can be made up of lots of different
  interlinked web pages."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123216Z"^^xsd:dateTime .

oakcurric:misconception-count-controlled-loop-repeats-forever
  a curric:Misconception ;
  curric:statement "A count-controlled loop repeats forever."@en ;
  curric:correction "An infinite loop repeats forever, unless the program is stopped."@en ;
  dcterms:modified "2026-06-07T15:30:15.124274Z"^^xsd:dateTime .

oakcurric:misconception-point-direction-turns-sprite-amount
  a curric:Misconception ;
  curric:statement """Point in direction turns the sprite the amount of degrees from which it is
  already facing."""@en ;
  curric:correction """The point in direction block includes numbers which represent the turn in
  degrees from the upward reference point. 90 degrees makes the sprite face right, 180
  degrees faces down, -90 faces left and 0 makes the sprite face the top."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124299Z"^^xsd:dateTime .

oakcurric:misconception-order-blocks-inside-forever-loop
  a curric:Misconception ;
  curric:statement """The order of the blocks inside a 'forever' loop doesn't really matter, as long
  as they are all in there."""@en ;
  curric:correction """The order of the blocks inside a loop can matter, and running them in a
  different sequence may affect the game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125325Z"^^xsd:dateTime .

oakcurric:misconception-way-select-part-image
  a curric:Misconception ;
  curric:statement "There is only way to select part of an image."@en ;
  curric:correction "There are multiple ways to select parts of an image."@en ;
  dcterms:modified "2026-06-07T15:30:15.125806Z"^^xsd:dateTime .

oakcurric:misconception-choices-made-making-sharing-video
  a curric:Misconception ;
  curric:statement """The choices made during making and sharing a video will not impact on the
  quality of the video."""@en ;
  curric:correction """When exporting a video different choices can be made which can afffect the
  quality of the finished video."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125815Z"^^xsd:dateTime .

oakcurric:misconception-once-video-recorded-cannot-changed
  a curric:Misconception ;
  curric:statement "Once a video is recorded it cannot be changed."@en ;
  curric:correction """Video footage can be edited using specialist software. The tools of such
  software allow overlays, adjustments and revmoval of content."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127250Z"^^xsd:dateTime .

oakcurric:misconception-variable-hold-lots-different-scores
  a curric:Misconception ;
  curric:statement """A variable can hold lots of different scores at the same time, like all the
  scores from a whole football match."""@en ;
  curric:correction """A variable can only hold one value at any one time. Variables are always
  changeable, meaning their value can be updated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129031Z"^^xsd:dateTime .

oakcurric:misconception-ask-question-add-item-branching
  a curric:Misconception ;
  curric:statement "You can ask any question to add an item to a branching database."@en ;
  curric:correction """You need to ask yes or no questions to add items to a branching database.
  Open-ended questions are too difficult to represent in a branching database."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129097Z"^^xsd:dateTime .

oakcurric:misconception-repeating-shape-many-times-create
  a curric:Misconception ;
  curric:statement "Repeating a shape many times will always create a pattern."@en ;
  curric:correction """The turn angle must be correct to form a repeating design. With the wrong
  choice of value a pattern might not appear."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130142Z"^^xsd:dateTime .

oakcurric:misconception-make-mistake-video-editing-software
  a curric:Misconception ;
  curric:statement """When you make a mistake in video editing software, you have to start
  again."""@en ;
  curric:correction """There are lots of ways to fix a mistake. You could change the order, undo, or
  delete."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130170Z"^^xsd:dateTime .

oakcurric:misconception-network-devices-connect-other-wirelessly
  a curric:Misconception ;
  curric:statement "All network devices connect to each other wirelessly."@en ;
  curric:correction """Not all network devices use wireless connections. Many devices, like
  switches, routers and servers, are connected using wires to create a stable and fast
  network."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131026Z"^^xsd:dateTime .

oakcurric:misconception-download-copy-images-find-interent
  a curric:Misconception ;
  curric:statement "You can download and copy any images you find on the interent."@en ;
  curric:correction """Some images on the internet are covered by copyright, which means they are
  not free to copy and use. You should check before you use any images you find online."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131936Z"^^xsd:dateTime .

oakcurric:misconception-pen-erase-same-thing
  a curric:Misconception ;
  curric:statement "Pen up and erase all do the same thing."@en ;
  curric:correction """Pen up stops the sprite from drawing a line, erase all clears all lines
  already drawn. Pen up stops new marks being drawn on the screen but keeps what is already
  there whilst erase all clears everything that already exists."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132006Z"^^xsd:dateTime .

oakcurric:misconception-youre-making-animation-need-make
  a curric:Misconception ;
  curric:statement """When you're making an animation, you need to make big changes to the drawing
  in each picture to make it move a lot."""@en ;
  curric:correction """To get smooth movement, you need to only make small changes to your drawing
  in each frame."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132902Z"^^xsd:dateTime .

oakcurric:misconception-testing-your-program-once-enough
  a curric:Misconception ;
  curric:statement "Testing your program once is enough."@en ;
  curric:correction "Programs should be tested many times to find all bugs."@en ;
  dcterms:modified "2026-06-07T15:30:15.132908Z"^^xsd:dateTime .

oakcurric:misconception-feedback-useful-because-people-tell
  a curric:Misconception ;
  curric:statement """Feedback is useful because people can tell you what you have done wrong and
  correct it for you."""@en ;
  curric:correction """Feedback is useful because people might raise your confidence by
  complimenting your hard work and they might be able to highlight improvements that you had
  not thought about."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133641Z"^^xsd:dateTime .

oakcurric:misconception-audio-recordings-need-done-same
  a curric:Misconception ;
  curric:statement "Audio recordings need to be done all at the same time in one go."@en ;
  curric:correction """Audio editing software lets you combine and edit any number of audio tracks.
  This allows separate smaller recordings to be combined in any order required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133647Z"^^xsd:dateTime .

oakcurric:misconception-identifying-ways-improving-something-criticism
  a curric:Misconception ;
  curric:statement "Identifying ways of improving something is a criticism of the creator."@en ;
  curric:correction """All things can be improved and, done in the right way, suggestions for
  improvement can be a positive and a way to make something even better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133655Z"^^xsd:dateTime .

oakcurric:misconception-your-animation-doesnt-look-right
  a curric:Misconception ;
  curric:statement "If your animation doesn't look right, you need to start all over again."@en ;
  curric:correction """You can review and improve your animation, including deleting unwanted
  frames."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134163Z"^^xsd:dateTime .

oakcurric:misconception-header-web-page-title
  a curric:Misconception ;
  curric:statement "The header of a web page is the title."@en ;
  curric:correction """The header is a section of the web page where the title is normally located
  but includes information that describes features of a web page but that is not actually
  part of the web page itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135085Z"^^xsd:dateTime .

oakcurric:misconception-motor-wired-one-specific-way
  a curric:Misconception ;
  curric:statement "The motor must be wired in one specific way to work."@en ;
  curric:correction """It will work in both directions, but reversing connections changes spin
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135697Z"^^xsd:dateTime .

oakcurric:misconception-loop-high-number-makes-big
  a curric:Misconception ;
  curric:statement "A loop with a high number always makes a big shape."@en ;
  curric:correction """The number in the loop affects the number of sides, not the size. The fd
  value controls the size."""@en ;
  dcterms:modified "2026-06-07T15:30:15.135703Z"^^xsd:dateTime .

oakcurric:misconception-using-repeat-1000-block-same
  a curric:Misconception ;
  curric:statement """Using a 'repeat 1000' block is just the same as using a 'forever' block to
  make a character keep doing something in a game."""@en ;
  curric:correction """Even though a repeat 1000 runs many times, a forever loop runs without an end
  point, which is better for actions that need to continue through the entire game."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137061Z"^^xsd:dateTime .

oakcurric:misconception-repetition-numbers-repeated
  a curric:Misconception ;
  curric:statement "Repetition is only about numbers and how they are repeated."@en ;
  curric:correction """Repetition means any repeated action, not just counting (e.g., brushing both
  sides of your teeth)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137069Z"^^xsd:dateTime .

oakcurric:misconception-audio-tracks-set-volume-meaning
  a curric:Misconception ;
  curric:statement """Audio tracks have a set volume, meaning they might not be usuable for certain
  projects."""@en ;
  curric:correction """Even if the volume of a track isn't suitable for your project, audio editing
  software can adjust the volume so that it plays at an appropriate level."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137076Z"^^xsd:dateTime .

oakcurric:misconception-pen-block-turns-pen-function
  a curric:Misconception ;
  curric:statement "The pen down block turns the pen function off."@en ;
  curric:correction """The pen down block makes the pen draw and is required to make marks on the
  stage. Pen up allows the sprite to move without making marks on the stage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137540Z"^^xsd:dateTime .

oakcurric:misconception-program-understands-twelve-same-12
  a curric:Misconception ;
  curric:statement """The program understands that 'twelve' is the same as '12' in the user
  input."""@en ;
  curric:correction """The user's input needs to be an exact match to what you put in the
  condition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137551Z"^^xsd:dateTime .

oakcurric:misconception-condition-keep-checked-its-own
  a curric:Misconception ;
  curric:statement "A condition will keep being checked on its own."@en ;
  curric:correction """Conditions need to be inside forever loops if you want them to be repeatedly
  checked."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138211Z"^^xsd:dateTime .

oakcurric:misconception-editing-creates-perfect-image-first
  a curric:Misconception ;
  curric:statement "Editing always creates the perfect image first time."@en ;
  curric:correction """Editing images can take time. It may take two or three edits before you are
  happy with the final image."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138217Z"^^xsd:dateTime .

oakcurric:misconception-drawings-adjusted-eye-view
  a curric:Misconception ;
  curric:statement "Drawings can only be adjusted by eye view."@en ;
  curric:correction """Using zoom, you can have a much more detailed view and make smaller
  adjustments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138285Z"^^xsd:dateTime .

oakcurric:misconception-data-recorded-person-recording-knows
  a curric:Misconception ;
  curric:statement """When data is being recorded, if the person recording knows what each value
  represents, column labels are not needed."""@en ;
  curric:correction """Column labels are important to make the data clear and easy to understand for
  everyone, even if the person recording it knows what it means."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138291Z"^^xsd:dateTime .

oakcurric:misconception-digital-image-see-originial-version
  a curric:Misconception ;
  curric:statement "The digital image we see is always the originial version."@en ;
  curric:correction """Digital images are often edited for a variety of purposes so we should never
  assume an image is an exact representation of reality."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139055Z"^^xsd:dateTime .

oakcurric:misconception-condition-multiple-possible-answers
  a curric:Misconception ;
  curric:statement "A condition can have multiple possible answers."@en ;
  curric:correction "A condition must always be either True or False in a program."@en ;
  dcterms:modified "2026-06-07T15:30:15.139310Z"^^xsd:dateTime .

oakcurric:misconception-devices-network-connected-directly-other
  a curric:Misconception ;
  curric:statement "All devices on a network are connected directly to each other."@en ;
  curric:correction """Devices are connected through a central switch. The switch makes sure
  messages go to the right device, without needing every device to connect to every other
  one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140486Z"^^xsd:dateTime .

oakcurric:misconception-video-improved-using-editing-tools
  a curric:Misconception ;
  curric:statement "All video can be improved using editing tools."@en ;
  curric:correction """Some video can’t be improved using the editing tools or the process will take
  too long, in this case it might be better to reshoot the video altogether."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141485Z"^^xsd:dateTime .

oakcurric:misconception-spreadsheet-forumlas-need-use-values
  a curric:Misconception ;
  curric:statement """Spreadsheet forumlas need to use values that are typed directly into the
  formula."""@en ;
  curric:correction """A formula in a spreadsheet should use cell references where possible. Whilst
  a forumla can use a typed value, cell references saves having to retype values and also
  benefits from updating the results of the calculation if data changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141490Z"^^xsd:dateTime .

oakcurric:misconception-everything-shared-internet-including-physical
  a curric:Misconception ;
  curric:statement "Everything can be shared over the internet (including physical objects)."@en ;
  curric:correction """You can share digital media and sell physical items on the internet but you
  cannot pass a physical item through the computer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146447Z"^^xsd:dateTime .

oakcurric:misconception-digital-devices-better-non-digital
  a curric:Misconception ;
  curric:statement "Digital devices are always better than non-digital tools."@en ;
  curric:correction """Some tasks like reading a book might still be enjoyable or practical without
  digital devices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148437Z"^^xsd:dateTime .

oakcurric:misconception-animation-show-kind-story
  a curric:Misconception ;
  curric:statement "An animation can show any kind of story."@en ;
  curric:correction """Some story ideas are not suited to animation. Think about what is achievable
  with the materials and time you have."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148443Z"^^xsd:dateTime .

oakcurric:misconception-search-terms-dont-specific-computers
  a curric:Misconception ;
  curric:statement """Search terms don't have to be specific as computers are so advanced now they
  can guess what you want from whatever you enter in a search."""@en ;
  curric:correction """The more specific the search term, the more relevant the search results. A
  search engine might find results with additional keywords but this does mean the results
  could be broad."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151731Z"^^xsd:dateTime .

oakcurric:misconception-objects-grouped-one-way
  a curric:Misconception ;
  curric:statement "Objects can only be grouped in one way."@en ;
  curric:correction """Objects can be grouped in multiple ways using different attributes to create
  groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153249Z"^^xsd:dateTime .

oakcurric:misconception-humans-involvement-computer-systems-run
  a curric:Misconception ;
  curric:statement """Humans have no involvement in computer systems. They are run by computers and
  don't need humans."""@en ;
  curric:correction """Humans are still required for some elements of computer systems otherwise
  they are not providing anything useful that humans can use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153670Z"^^xsd:dateTime .

oakcurric:misconception-use-search-engine-checks-website
  a curric:Misconception ;
  curric:statement """When you use a search engine, it checks every website in the world before
  coming back with a result."""@en ;
  curric:correction "A search engine just searches its index to find the relevant results."@en ;
  dcterms:modified "2026-06-07T15:30:15.153845Z"^^xsd:dateTime .

oakcurric:misconception-search-engines-prioritise-results
  a curric:Misconception ;
  curric:statement "Search engines do not prioritise any results."@en ;
  curric:correction "Search engines order results by ranking them using an algorithm."@en ;
  dcterms:modified "2026-06-07T15:30:15.153899Z"^^xsd:dateTime .

oakcurric:misconception-digital-device-exactly-one-input
  a curric:Misconception ;
  curric:statement "A digital device has to have exactly one input and one output."@en ;
  curric:correction """Digital devices can have more than one input and more than one output. They
  use different devices for different tasks at different times. For some tasks, input or
  output devices might not be required but they might be for different uses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155832Z"^^xsd:dateTime .

oakcurric:misconception-records-filled-text
  a curric:Misconception ;
  curric:statement "All records must be filled in with text."@en ;
  curric:correction "You can use tick boxes, numbers, or other formats to show data."@en ;
  dcterms:modified "2026-06-07T15:30:15.156535Z"^^xsd:dateTime .

oakcurric:misconception-getting-feedback-create-other-people
  a curric:Misconception ;
  curric:statement """Getting feedback on what you create from other people means that they don't
  like what you have done."""@en ;
  curric:correction """Feedback is always useful to make what you create even better. Even the best
  publications can do things in a better way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162711Z"^^xsd:dateTime .

oakcurric:misconception-script-used-people-say-video
  a curric:Misconception ;
  curric:statement "A script is just used for what people will say on a video."@en ;
  curric:correction """A script can be used to plan what people will say or what audio will be used.
  A script has enough detail to understand the range of audio that will be used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164604Z"^^xsd:dateTime .

oakcurric:misconception-digital-devices-need-internet-work
  a curric:Misconception ;
  curric:statement "Digital devices always need the internet to work."@en ;
  curric:correction """Some digital devices work without the internet, such as watches and
  calculators."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164982Z"^^xsd:dateTime .

oakcurric:misconception-read-something-internet-true
  a curric:Misconception ;
  curric:statement "If you read something on the internet, it must be true."@en ;
  curric:correction """Anyone can publish any content on the internet, which means not everything
  can be trusted. When looking at content other people have made, you should always consider
  what you can believe about what has been published."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165919Z"^^xsd:dateTime .

oakcurric:misconception-online-communication-same
  a curric:Misconception ;
  curric:statement "All online communication is the same."@en ;
  curric:correction """Different tools are better for different purposes (e.g. chat for quick
  messages, video for a longer discussion)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166346Z"^^xsd:dateTime .

oakcurric:misconception-messages-sent-online-private
  a curric:Misconception ;
  curric:statement "Messages sent online are always private."@en ;
  curric:correction "Some tools store messages or share them with others."@en ;
  dcterms:modified "2026-06-07T15:30:15.166583Z"^^xsd:dateTime .

oakcurric:misconception-use-data-set-answer-question
  a curric:Misconception ;
  curric:statement "You can use a data set to answer any question."@en ;
  curric:correction """You can use a data set to answer a question, but it needs to be appropriate
  to the data set being used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166588Z"^^xsd:dateTime .

oakcurric:misconception-object-group-neither-group
  a curric:Misconception ;
  curric:statement "An object can be in both the 'yes' and the 'no' group, or neither group."@en ;
  curric:correction """An object can only be in either the 'yes' or the 'no' group, not both or
  neither."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166766Z"^^xsd:dateTime .

oakcurric:misconception-systems-made-one-part
  a curric:Misconception ;
  curric:statement "Systems have to be made up of one part."@en ;
  curric:correction "Systems are made up of many parts or components working together."@en ;
  dcterms:modified "2026-06-07T15:30:15.168276Z"^^xsd:dateTime .

oakcurric:misconception-find-something-web-use-your
  a curric:Misconception ;
  curric:statement "If you find something on the web, you can use it as your own."@en ;
  curric:correction """Most online content is owned by someone and you need permission to use it as
  your own."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168282Z"^^xsd:dateTime .

oakcurric:misconception-certain-qualified-people-add-content
  a curric:Misconception ;
  curric:statement """Only certain 'qualified' people can add content to websites/create
  websites."""@en ;
  curric:correction """Anyone can add content to websites or create their own website. Services have
  developed that make it easy for anyone to upload content that can be shared across the
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168554Z"^^xsd:dateTime .

oakcurric:misconception-internet-knows-website-names-numbers
  a curric:Misconception ;
  curric:statement "The internet knows website names, not numbers."@en ;
  curric:correction """Computers use IP addresses (numbers, and DNS helps match names to those
  numbers)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168904Z"^^xsd:dateTime .

oakcurric:misconception-internet-www-different-words-used
  a curric:Misconception ;
  curric:statement """The internet and WWW are just different words used to decribe the same
  thing."""@en ;
  curric:correction """The World Wide Web is a service that runs on the internet. The internet is a
  network that allows computers to communicate and provide the means for computers to uses
  services such as the WWW."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169507Z"^^xsd:dateTime .

oakcurric:misconception-online-work-private-default
  a curric:Misconception ;
  curric:statement "All online work is private by default."@en ;
  curric:correction "Some tools are public unless settings are changed."@en ;
  dcterms:modified "2026-06-07T15:30:15.170196Z"^^xsd:dateTime .

oakcurric:misconception-order-results-given-search-engine
  a curric:Misconception ;
  curric:statement """There is no order to the results given by a search engine, it is just
  whichever results have been found first."""@en ;
  curric:correction """Search engines order results following algorithms or rules to move some
  results nearer the top of the results list."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170900Z"^^xsd:dateTime .

oakcurric:misconception-important-messages-much-information-them
  a curric:Misconception ;
  curric:statement """It is important that messages have as much information on them as
  possible."""@en ;
  curric:correction """More information isn’t always better in a message. Too much detail can
  overwhelm the reader and make the key points unclear. Effective messages are clear,
  concise and provide only the necessary information for the intended audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171175Z"^^xsd:dateTime .
