# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-form
  a curric:Keyword ;
  schema:name "form"@en ;
  schema:description """the specific type or category of a poem that determines its structure and
  style"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348016Z"^^xsd:dateTime .

oakcurric:keyword-body-language
  a curric:Keyword ;
  schema:name "body language"@en ;
  schema:description """how we use our posture and gestures to communicate meaning, confidence and
  feelings"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348227Z"^^xsd:dateTime .

oakcurric:keyword-subject
  a curric:Keyword ;
  schema:name "subject"@en ;
  schema:description """the noun, noun phrase or pronoun that does or is the main verb in the active
  voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348319Z"^^xsd:dateTime .

oakcurric:keyword-object
  a curric:Keyword ;
  schema:name "object"@en ;
  schema:description """the noun, noun phrase or pronoun that receives the action of the main verb
  in the active voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348328Z"^^xsd:dateTime .

oakcurric:keyword-atmosphere
  a curric:Keyword ;
  schema:name "atmosphere"@en ;
  schema:description "the mood created in a section or whole of a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348363Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-natural
  a curric:Keyword ;
  schema:name "natural"@en ;
  schema:description """the natural symbol is used to show a note in the bar has returned to the
  normal pitch"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348642Z"^^xsd:dateTime .

oakcurric:keyword-symbol
  a curric:Keyword ;
  schema:name "symbol"@en ;
  schema:description """a word, object, or image that represents a bigger idea or meaning beyond
  itself"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350718Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-expression
  a curric:Keyword ;
  schema:name "expression"@en ;
  schema:description "reading with feelings and emotion to bring the poem to life"@en ;
  dcterms:modified "2026-06-07T15:30:02.351044Z"^^xsd:dateTime .

oakcurric:keyword-outline
  a curric:Keyword ;
  schema:name "outline"@en ;
  schema:description """A general description or overview showing the main features of
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351108Z"^^xsd:dateTime .

oakcurric:keyword-textiles
  a curric:Keyword ;
  schema:name "textiles"@en ;
  schema:description "textiles are fabrics made by weaving materials like cotton"@en ;
  dcterms:modified "2026-06-07T15:30:02.351987Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
  environment or reducing resources for future generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352314Z"^^xsd:dateTime .

oakcurric:keyword-border
  a curric:Keyword ;
  schema:name "BORDER"@en ;
  schema:description "extended writing acronym"@en ;
  dcterms:modified "2026-06-07T15:30:02.352515Z"^^xsd:dateTime .

oakcurric:keyword-feedback
  a curric:Keyword ;
  schema:name "feedback"@en ;
  schema:description """information and guidance provided to the athlete to help them improve their
  technique"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352657Z"^^xsd:dateTime .

oakcurric:keyword-movement
  a curric:Keyword ;
  schema:name "movement"@en ;
  schema:description "movement is when you make something go from one place to another"@en ;
  dcterms:modified "2026-06-07T15:30:02.352913Z"^^xsd:dateTime .

oakcurric:keyword-drawing-machine
  a curric:Keyword ;
  schema:name "drawing machine"@en ;
  schema:description "a tool or device that helps make marks by moving in different ways"@en ;
  dcterms:modified "2026-06-07T15:30:02.352918Z"^^xsd:dateTime .

oakcurric:keyword-reflect
  a curric:Keyword ;
  schema:name "reflect"@en ;
  schema:description "when you pause to review your work and process"@en ;
  dcterms:modified "2026-06-07T15:30:02.353145Z"^^xsd:dateTime .

oakcurric:keyword-abstract
  a curric:Keyword ;
  schema:name "abstract"@en ;
  schema:description """theoretical or conceptual; existing in thought or as an idea but not having
  a physical or concrete existence"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353782Z"^^xsd:dateTime .

oakcurric:keyword-stencil
  a curric:Keyword ;
  schema:name "stencil"@en ;
  schema:description """a technique used in street art where a cut-out template is placed on a
  surface to spray or paint a design"""@en ;
  dcterms:modified "2026-06-07T15:30:02.353860Z"^^xsd:dateTime .

oakcurric:keyword-proportion
  a curric:Keyword ;
  schema:name "proportion"@en ;
  schema:description "the size relationship between different elements of a design"@en ;
  dcterms:modified "2026-06-07T15:30:02.353865Z"^^xsd:dateTime .

oakcurric:keyword-sketching
  a curric:Keyword ;
  schema:name "sketching"@en ;
  schema:description "quick, freehand drawing of ideas or concepts, often as a rough outline"@en ;
  dcterms:modified "2026-06-07T15:30:02.354474Z"^^xsd:dateTime .

oakcurric:keyword-construct
  a curric:Keyword ;
  schema:name "construct"@en ;
  schema:description "to create or build an image or understanding of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.354608Z"^^xsd:dateTime .

oakcurric:keyword-observe
  a curric:Keyword ;
  schema:name "observe"@en ;
  schema:description "To observe is to look very closely and use other senses too."@en ;
  dcterms:modified "2026-06-07T15:30:02.354748Z"^^xsd:dateTime .

oakcurric:keyword-emotions
  a curric:Keyword ;
  schema:name "emotions"@en ;
  schema:description """a feeling you experience in response to different situations, people or
  events - these can be positive or negative"""@en ;
  dcterms:modified "2026-06-07T15:30:02.355072Z"^^xsd:dateTime .

oakcurric:keyword-emotion
  a curric:Keyword ;
  schema:name "emotion"@en ;
  schema:description "a feeling you experience - these can be positive or negative"@en ;
  dcterms:modified "2026-06-07T15:30:02.355165Z"^^xsd:dateTime .

oakcurric:keyword-detail
  a curric:Keyword ;
  schema:name "Detail"@en ;
  schema:description "A small part of something that adds to its overall appearance."@en ;
  dcterms:modified "2026-06-07T15:30:02.355330Z"^^xsd:dateTime .

oakcurric:keyword-collaboration
  a curric:Keyword ;
  schema:name "collaboration"@en ;
  schema:description "working together towards an outcome, or to produce something"@en ;
  dcterms:modified "2026-06-07T15:30:02.356105Z"^^xsd:dateTime .

oakcurric:keyword-imagination
  a curric:Keyword ;
  schema:name "imagination"@en ;
  schema:description """the ability to create ideas, pictures or scenarios in your mind that are not
  present or real"""@en ;
  dcterms:modified "2026-06-07T15:30:02.356214Z"^^xsd:dateTime .

oakcurric:keyword-tone
  a curric:Keyword ;
  schema:name "Tone"@en ;
  schema:description "The general mood or feeling of a text."@en ;
  dcterms:modified "2026-06-07T15:30:02.356590Z"^^xsd:dateTime .

oakcurric:keyword-continent
  a curric:Keyword ;
  schema:name "continent"@en ;
  schema:description """A continent is a large land mass on Earth and there are seven: Africa,
  Antarctica, Asia, Europe, North America, South America, Oceania."""@en ;
  dcterms:modified "2026-06-07T15:30:02.357661Z"^^xsd:dateTime .

oakcurric:keyword-composition
  a curric:Keyword ;
  schema:name "composition"@en ;
  schema:description "the arrangement of visual elements within an artwork"@en ;
  dcterms:modified "2026-06-07T15:30:02.357962Z"^^xsd:dateTime .

oakcurric:keyword-mixed-media
  a curric:Keyword ;
  schema:name "mixed-media"@en ;
  schema:description "the use of more than one material or technique in a single piece"@en ;
  dcterms:modified "2026-06-07T15:30:02.357967Z"^^xsd:dateTime .

oakcurric:keyword-sketch
  a curric:Keyword ;
  schema:name "sketch"@en ;
  schema:description "making quick and simple drawings to show ideas or the things we see"@en ;
  dcterms:modified "2026-06-07T15:30:02.358165Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description "moving from one place to another with the intention of staying there"@en ;
  dcterms:modified "2026-06-07T15:30:02.358298Z"^^xsd:dateTime .

oakcurric:keyword-plan
  a curric:Keyword ;
  schema:name "plan"@en ;
  schema:description """a framework that writers create before they write a section or whole
  text"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358429Z"^^xsd:dateTime .

oakcurric:keyword-collaborate
  a curric:Keyword ;
  schema:name "collaborate"@en ;
  schema:description "to work with others to create or achieve something"@en ;
  dcterms:modified "2026-06-07T15:30:02.358523Z"^^xsd:dateTime .

oakcurric:keyword-media
  a curric:Keyword ;
  schema:name "media"@en ;
  schema:description """the different ways we communicate information, lsuch as via TV, newspapers,
  social media, the internet or radio"""@en ;
  dcterms:modified "2026-06-07T15:30:02.358959Z"^^xsd:dateTime .

oakcurric:keyword-silhouette
  a curric:Keyword ;
  schema:name "silhouette"@en ;
  schema:description """a dark shape or outline of something against a lighter background, showing
  only the outline with no internal detail"""@en ;
  dcterms:modified "2026-06-07T15:30:02.360594Z"^^xsd:dateTime .

oakcurric:keyword-light
  a curric:Keyword ;
  schema:name "light"@en ;
  schema:description "often used in art to create contrast, highlight textures, and set moods"@en ;
  dcterms:modified "2026-06-07T15:30:02.360606Z"^^xsd:dateTime .

oakcurric:keyword-materials
  a curric:Keyword ;
  schema:name "materials"@en ;
  schema:description "the physical substances or tools an artist uses to create their work"@en ;
  dcterms:modified "2026-06-07T15:30:02.360914Z"^^xsd:dateTime .

oakcurric:keyword-nocturnal
  a curric:Keyword ;
  schema:name "nocturnal"@en ;
  schema:description """Nocturnal means being active or happening at night rather than during the
  day."""@en ;
  dcterms:modified "2026-06-07T15:30:02.360949Z"^^xsd:dateTime .

oakcurric:keyword-foreground
  a curric:Keyword ;
  schema:name "foreground"@en ;
  schema:description "the part of the scene closest to the viewer"@en ;
  dcterms:modified "2026-06-07T15:30:02.360965Z"^^xsd:dateTime .

oakcurric:keyword-background
  a curric:Keyword ;
  schema:name "background"@en ;
  schema:description "the part of the scene that appears furthest away"@en ;
  dcterms:modified "2026-06-07T15:30:02.360972Z"^^xsd:dateTime .

oakcurric:keyword-connection
  a curric:Keyword ;
  schema:name "connection"@en ;
  schema:description "a similarity or link between two things"@en ;
  dcterms:modified "2026-06-07T15:30:02.361289Z"^^xsd:dateTime .

oakcurric:keyword-identity
  a curric:Keyword ;
  schema:name "identity"@en ;
  schema:description """who a person is, or the qualities of a person or group that make them
  different than others"""@en ;
  dcterms:modified "2026-06-07T15:30:02.361296Z"^^xsd:dateTime .

oakcurric:keyword-hue
