# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-20783-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can create marks holding a drawing tool, but they can also use objects and
  movement to create marks instead."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20783-2
  a curric:KeyLearningPoint ;
  rdfs:label """A drawing machine works by moving in different ways to make lines, shapes and marks
  with moving objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20783-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might experiment with how the movement of the drawing machine creates
  different marks or patterns on the page."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20807-1
  a curric:KeyLearningPoint ;
  rdfs:label """When artists talk about the background of an artwork, they mean everything that is
  behind the main image or images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20807-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating artwork is an important part of the design process."@en ;
  dcterms:modified "2026-06-07T15:30:29.271848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20807-3
  a curric:KeyLearningPoint ;
  rdfs:label "Offering feedback to other artists, helps them improve over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.271852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20853-1
  a curric:KeyLearningPoint ;
  rdfs:label """A moodboard is a visual tool that helps to collect and explore ideas around a chosen
  theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identity means who we are as an individual including our family, culture, age,
  likes, dislikes, interests and hobbies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20853-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can arrange your chosen images and items by layering and overlapping them to
  create interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29615-1
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing favourite words first helps the sculpture speak a personal tale."@en ;
  dcterms:modified "2026-06-07T15:30:29.281135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29615-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cutting continuous lines can help paper to transform into sculpture, while still
  holding its story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29615-3
  a curric:KeyLearningPoint ;
  rdfs:label "A single, unbroken spiral cut turns flat paper into a flowing form."@en ;
  dcterms:modified "2026-06-07T15:30:29.281142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29615-4
  a curric:KeyLearningPoint ;
  rdfs:label "Slow, careful cutting feels calm and mindful, echoing Korean Hanji craft."@en ;
  dcterms:modified "2026-06-07T15:30:29.281146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29615-5
  a curric:KeyLearningPoint ;
  rdfs:label "Placing work together can help a paper sculpture to tell a bigger story."@en ;
  dcterms:modified "2026-06-07T15:30:29.281150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20801-1
  a curric:KeyLearningPoint ;
  rdfs:label "Natural forms have shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.286623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20801-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes can be joined and moulded to create forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.286627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20801-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can show different textures with clay, using clay tools."@en ;
  dcterms:modified "2026-06-07T15:30:29.286633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20801-4
  a curric:KeyLearningPoint ;
  rdfs:label "Curators decide how to display artwork in a wide range of spaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.286637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29616-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maps can tell personal stories and histories of a continent."@en ;
  dcterms:modified "2026-06-07T15:30:29.288678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29616-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists might show that borders can be changed."@en ;
  dcterms:modified "2026-06-07T15:30:29.288682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29616-3
  a curric:KeyLearningPoint ;
  rdfs:label "Covering or layering materials can reflect change, erasure or memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.288686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20854-1
  a curric:KeyLearningPoint ;
  rdfs:label "A print is a picture made by pressing an inked design onto paper."@en ;
  dcterms:modified "2026-06-07T15:30:29.293122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20854-2
  a curric:KeyLearningPoint ;
  rdfs:label """A print is created by pressing your design onto a soft surface like foam or
  rubber."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20854-3
  a curric:KeyLearningPoint ;
  rdfs:label """A profile print is made by rolling ink onto a matrix, pressing it onto paper and
  lifting to reveal the profile print."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20854-4
  a curric:KeyLearningPoint ;
  rdfs:label "Understand that there are different printmaking techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.293138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20685-1
  a curric:KeyLearningPoint ;
  rdfs:label """Know that each panel within a triptych can tell part of a story and should be
  connected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20685-2
  a curric:KeyLearningPoint ;
  rdfs:label "Know that artists can choose from a wide range of painting techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.296057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20685-3
  a curric:KeyLearningPoint ;
  rdfs:label "Know that artists evaluate their artwork to help them improve over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.296063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20799-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can match colours that they observe in the world around them."@en ;
  dcterms:modified "2026-06-07T15:30:29.296226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20799-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wet and dry paint can be mixed to create a range of colours."@en ;
  dcterms:modified "2026-06-07T15:30:29.296230Z"^^xsd:dateTime .

