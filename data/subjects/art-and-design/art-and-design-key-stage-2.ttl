  rdfs:label "Heavy or light pressure is used to achieve different tones with a pencil."@en ;
  dcterms:modified "2026-06-07T15:30:29.632797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20941-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can also show tone by using hatching and cross hatching."@en ;
  dcterms:modified "2026-06-07T15:30:29.632801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20941-3
  a curric:KeyLearningPoint ;
  rdfs:label """The side of the object nearest to the light source will be drawn with
  lighter tones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The side of the object furthest away from the light source will show darker tones
  and shadows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20941-5
  a curric:KeyLearningPoint ;
  rdfs:label """By using shadow, tone and line we can show that something is a three-dimensional
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20924-1
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns and decoration are used in art and design across different cultures."@en ;
  dcterms:modified "2026-06-07T15:30:29.634630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists and designers create patterns using repetition, symmetry, and different
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sketchbooks can be used to record and explore patterns, helping to develop
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20914-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can use a printing block multiple times to create a continuous design."@en ;
  dcterms:modified "2026-06-07T15:30:29.634650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20914-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can explore symmetry, rotation and spacing to develop an effective repeat
  pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20910-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sketching from observation helps you capture the form of an insect by noticing its
  details and shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20910-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning your composition allows you to think about where to place your insect and
  what it might be next to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20910-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using tone (light and dark areas) and colour helps make your drawing look more
  realistic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sketching the main shapes first and simplifying details makes the design clearer for
  printing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20911-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding key details like patterns and textures helps to make the insect design more
  interesting and ready for print."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using rubbing techniques can create different textures on paper."@en ;
  dcterms:modified "2026-06-07T15:30:29.638138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20894-2
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing when to tear or cut helps create the shapes and details needed in a
  collage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20894-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layering and overlapping adds depth and texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.638148Z"^^xsd:dateTime .

