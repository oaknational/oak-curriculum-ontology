  dcterms:modified "2026-06-07T15:30:29.306469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists participate in group critiques to share feedback and ideas, helping improve
  and learn from each other's work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20983-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cakes have cultural significance and unique design elements in different
  traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20983-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching involves using basic shapes to plan a more detailed design."@en ;
  dcterms:modified "2026-06-07T15:30:29.306911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20983-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shading techniques like hatching and stippling create depth and texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.306914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20945-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can digitally manipulate images and photographs using crop, saturation and
