  dcterms:modified "2026-06-07T15:30:29.308070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20997-3
  a curric:KeyLearningPoint ;
  rdfs:label """Samples or testers can be useful to explore mark-making before the artist starts a
  composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20937-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can prepare a drawing to be traced by making the outlines darker."@en ;
  dcterms:modified "2026-06-07T15:30:29.309264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20937-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists might use tracing to make a copy of a full scale design."@en ;
  dcterms:modified "2026-06-07T15:30:29.309268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20937-3
  a curric:KeyLearningPoint ;
  rdfs:label "Guide sticks can be used to ensure clay is a consistent depth."@en ;
  dcterms:modified "2026-06-07T15:30:29.309272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20900-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stop motion is a form of animation involving sequential photography of still
  objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311292Z"^^xsd:dateTime .

