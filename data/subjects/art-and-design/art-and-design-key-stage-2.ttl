  dcterms:modified "2026-06-07T15:30:29.304373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20977-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use facial features to depict different expressions in portraits."@en ;
  dcterms:modified "2026-06-07T15:30:29.304377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20977-3
  a curric:KeyLearningPoint ;
  rdfs:label "Portraits can evoke an emotional response from the viewer."@en ;
  dcterms:modified "2026-06-07T15:30:29.304381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20928-1
  a curric:KeyLearningPoint ;
  rdfs:label "Architects influence how buildings look and function."@en ;
  dcterms:modified "2026-06-07T15:30:29.305181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20928-2
  a curric:KeyLearningPoint ;
  rdfs:label "Architectural styles vary across time, place, and purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.305185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20928-3
  a curric:KeyLearningPoint ;
  rdfs:label "Architects use blueprints to help communicate their ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.305188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20928-4
  a curric:KeyLearningPoint ;
  rdfs:label "Observing details (materials, shapes, and forms) improves visual literacy."@en ;
  dcterms:modified "2026-06-07T15:30:29.305193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20939-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can add layers of material to their clay tile, including paint and
  varnish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Varnishing clay can help it to be more durable and better protected against
