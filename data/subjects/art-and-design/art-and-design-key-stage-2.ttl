oakcurric:keylearningpoint-lesson-20929-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists and architects use perspective to bring realism to their designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.304124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20929-3
  a curric:KeyLearningPoint ;
  rdfs:label "Buildings can be made to look 3D using lines that lead to a vanishing point."@en ;
  dcterms:modified "2026-06-07T15:30:29.304128Z"^^xsd:dateTime .

