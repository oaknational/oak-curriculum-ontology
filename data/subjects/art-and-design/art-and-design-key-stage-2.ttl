  dcterms:modified "2026-06-07T15:30:29.370667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20959-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists might use the colours and textures that they observe in a subject."@en ;
