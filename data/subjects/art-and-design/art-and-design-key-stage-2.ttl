# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-21013-1
  a curric:KeyLearningPoint ;
  rdfs:label "Urban environments offer a rich source of visual inspiration for artists."@en ;
  dcterms:modified "2026-06-07T15:30:29.003747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Visual research involves observing, sketching, and annotating ideas from the world
  around us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21013-3
  a curric:KeyLearningPoint ;
  rdfs:label """Textures, patterns, and shapes can be used to communicate the look and feel of urban
  spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21013-4
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing from observation helps develop attention to detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.003760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21004-1
  a curric:KeyLearningPoint ;
  rdfs:label """Street art has cultural, social, and artistic significance, and is created in both
  traditional and digital formats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21004-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using digital media allows artists to experiment and refine their ideas before
  committing to a large-scale mural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21004-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consideration of the wall space, scale, and public context is crucial when designing
  a mural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20978-1
  a curric:KeyLearningPoint ;
  rdfs:label "The position of the eyebrows, mouth and eyes helps to identify emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.257496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20978-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facial expressions convey emotions and can be captured through art."@en ;
  dcterms:modified "2026-06-07T15:30:29.257500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20978-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding proportions and basic shapes of the face."@en ;
  dcterms:modified "2026-06-07T15:30:29.257504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21010-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pop Art often includes repetition, bold colours, and images from popular
  culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21010-2
  a curric:KeyLearningPoint ;
  rdfs:label """Developing artworks involves sketching, considering composition, and refining ideas
  visually."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21010-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mixed-media techniques can help enhance meaning in Pop art."@en ;
  dcterms:modified "2026-06-07T15:30:29.261052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21018-1
  a curric:KeyLearningPoint ;
  rdfs:label "Character design combines imagination with visual clues for the audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.261450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters can use symbols (colours, shapes, objects) to show personality or
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21018-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists plan and sketch ideas before creating final designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.261457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21018-4
  a curric:KeyLearningPoint ;
  rdfs:label "Colour and shape choices help tell a story or express mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.261460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29692-1
  a curric:KeyLearningPoint ;
  rdfs:label "Art can communicate powerfully without sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.264061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29692-2
  a curric:KeyLearningPoint ;
  rdfs:label "Protest placards combine shape, words, and symbols to share big ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.264065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colour, simplicity, and repetition make messages bold and memorable."@en ;
  dcterms:modified "2026-06-07T15:30:29.264069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29648-1
  a curric:KeyLearningPoint ;
  rdfs:label "Paint can be used to explore place, memory or feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.265962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29648-2
  a curric:KeyLearningPoint ;
  rdfs:label "A colour wash can shape the mood of a portrait."@en ;
  dcterms:modified "2026-06-07T15:30:29.265966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emotional tone can be suggested through restraint, layering and colour."@en ;
  dcterms:modified "2026-06-07T15:30:29.265970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29648-4
  a curric:KeyLearningPoint ;
  rdfs:label "Strong colours can suggest presence, emphasis or absence."@en ;
  dcterms:modified "2026-06-07T15:30:29.265974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scenic compositions create a clear setting for a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.266980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21021-2
  a curric:KeyLearningPoint ;
  rdfs:label "Foreground, middle ground, and background help show depth."@en ;
  dcterms:modified "2026-06-07T15:30:29.266984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21021-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists choose scenery details to add meaning and mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.266988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21021-4
  a curric:KeyLearningPoint ;
  rdfs:label "Planning a strong focal point helps to make the meaning clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.266992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21001-1
  a curric:KeyLearningPoint ;
  rdfs:label """Graffiti letters use exaggerated shapes and styles to express identity and
  creativity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Structure and sketching help develop balanced, bold graffiti lettering."@en ;
  dcterms:modified "2026-06-07T15:30:29.267678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21001-3
  a curric:KeyLearningPoint ;
  rdfs:label """Colour, shadows, shapes and outlines enhance impact and make designs more
  dynamic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21023-1
  a curric:KeyLearningPoint ;
  rdfs:label """Objects can be chosen intentionally to represent personal or story-based
  symbolism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21023-2
  a curric:KeyLearningPoint ;
  rdfs:label """Observational drawing improves when artists focus on shape, detail and
  proportion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21023-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arranging objects thoughtfully supports stronger compositions and storytelling in
  art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Street art is a form of visual communication used to convey social messages and
  political opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21003-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital tools enable the creation of street art that can reach a global audience and
  convey powerful social messages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21003-3
  a curric:KeyLearningPoint ;
  rdfs:label """Symbols and colours play a significant role in communicating ideas in street
  art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21003-4
  a curric:KeyLearningPoint ;
  rdfs:label """Street art's evolution from graffiti to digital art reflects broader cultural shifts
  and technological advancements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understand how to identify and represent emotions in facial expressions through
  observation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20980-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explore techniques to sketch and paint a base portrait capturing key features of
  expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20980-3
  a curric:KeyLearningPoint ;
  rdfs:label """Begin to develop painting skills with a focus on colour mixing to accurately create
  skin tones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21022-1
  a curric:KeyLearningPoint ;
  rdfs:label "Colour choices can strengthen the meaning and mood of a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.270206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21022-2
  a curric:KeyLearningPoint ;
  rdfs:label "Detail makes symbols and characters clearer and more expressive."@en ;
  dcterms:modified "2026-06-07T15:30:29.270210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21022-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use contrast and tone to guide the viewer’s eye and highlight important
  parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20893-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frottage is a technique of rubbing over textures to create art."@en ;
  dcterms:modified "2026-06-07T15:30:29.272655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20893-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different textures can be found in natural objects like leaves."@en ;
  dcterms:modified "2026-06-07T15:30:29.272661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20893-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colours can enhance the visual appeal of frottage art."@en ;
  dcterms:modified "2026-06-07T15:30:29.272665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21015-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how public spaces are designed to serve specific functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.272881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21015-2
  a curric:KeyLearningPoint ;
  rdfs:label "Develop imaginative and practical ideas for urban play spaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.272889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21015-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use drawing techniques to express spatial design and annotate ideas clearly."@en ;
  dcterms:modified "2026-06-07T15:30:29.272893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21011-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sketches, research and planning aid the process of completing a final outcome."@en ;
  dcterms:modified "2026-06-07T15:30:29.272927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21011-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artworks can be refined and evaluated throughout the making process."@en ;
  dcterms:modified "2026-06-07T15:30:29.272932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21011-3
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing appropriate media helps to reflect Pop Art themes and outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.272936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21019-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use symbols to share stories and meanings without words."@en ;
  dcterms:modified "2026-06-07T15:30:29.272940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21019-2
  a curric:KeyLearningPoint ;
  rdfs:label """Symbols often carry layered or multiple meanings, and different cultures use symbols
  for similar or different ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21019-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can analyse artworks by identifying symbols and interpreting their meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.272950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29693-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sculpture can start by unmaking as well as making."@en ;
  dcterms:modified "2026-06-07T15:30:29.273371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29693-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fabric and fibre can express culture, memory and care."@en ;
  dcterms:modified "2026-06-07T15:30:29.273374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29693-3
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition, wrapping and scale can create emotion and meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.273378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21006-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pop Art began in the UK and USA in the mid-20th century and reacted to consumer
  culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21006-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pop Art often uses bold colours, repetition, and everyday imagery."@en ;
  dcterms:modified "2026-06-07T15:30:29.274057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21006-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pop artists use mass production techniques like screen printing to mass produce
  artworks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21016-1
  a curric:KeyLearningPoint ;
  rdfs:label "Urban environments can be designed to support wildlife."@en ;
  dcterms:modified "2026-06-07T15:30:29.277989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists and designers play an important role in solving environmental challenges
  through visual thinking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing is a tool to plan, explore and communicate design ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.278000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21016-4
  a curric:KeyLearningPoint ;
  rdfs:label "Wildlife-friendly features in cities benefit both nature and people."@en ;
  dcterms:modified "2026-06-07T15:30:29.278004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21012-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understand the fundamental elements of urban design and their impact on city
  living.​"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21012-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analyse how artists represent urban environments through various artistic
  techniques.​"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21012-3
  a curric:KeyLearningPoint ;
  rdfs:label """Develop observational drawing skills focusing on architectural features and city
  layouts.​"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists gather and select images and information to support themes and enrich their
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pop artists often use found sources (magazines, adverts, media) to reflect modern
  culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Research helps to develop clearer, more meaningful artistic ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.282033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Thoughtful sourcing leads to stronger and more personal Pop Art outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.282037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21009-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sketchbooks help artists think through drawing and develop multiple versions of an
  idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21009-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artistic thinking involves trial and error, visual notes and self-reflection, which
  can be shown through annotation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21009-3
  a curric:KeyLearningPoint ;
  rdfs:label "Experimentation leads to stronger, more meaningful final outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.283852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21002-1
  a curric:KeyLearningPoint ;
  rdfs:label """Graffiti can be created using digital tools just as it is with traditional spray
  paint on walls."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21002-2
  a curric:KeyLearningPoint ;
  rdfs:label "Typography in graffiti is about bold, stylised letters that express personality."@en ;
  dcterms:modified "2026-06-07T15:30:29.283862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21002-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital tools like gradients, shadows, and layering can help make letters pop and
  appear three-dimensional."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21017-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand what makes a transport system sustainable."@en ;
  dcterms:modified "2026-06-07T15:30:29.284734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21017-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use drawings and annotations to communicate ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.284737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21017-3
  a curric:KeyLearningPoint ;
  rdfs:label "Explore how art and design influence the future of urban life."@en ;
  dcterms:modified "2026-06-07T15:30:29.284741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21017-4
  a curric:KeyLearningPoint ;
  rdfs:label "Consider environmental impact, functionality, and design aesthetics."@en ;
  dcterms:modified "2026-06-07T15:30:29.284745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29800-1
  a curric:KeyLearningPoint ;
  rdfs:label """Medieval artists used geometric, floral, and gilded patterns to express spiritual
  ideas, not just decoration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29800-2
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns were used to communicate meaning, such as harmony, holiness, and the
  connection between heaven and earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29800-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists used patterns as a visual language to communicate ideas, beliefs, and
  stories to people who could not read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21005-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media is used in street art for a range of purposes, including design
  experimentation and applying techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21005-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stencils can be made digitally through filters, or by hand, using bridges and
  islands to create detailed designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21005-3
  a curric:KeyLearningPoint ;
  rdfs:label """Images can be overlayed with digital media, helping artists to consider how their
  art will look in a public space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29654-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sculpture can show feeling, memory or a story without using faces or details."@en ;
  dcterms:modified "2026-06-07T15:30:29.286571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29654-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wrapping a form can protect, hide or express something personal."@en ;
  dcterms:modified "2026-06-07T15:30:29.286577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29654-3
  a curric:KeyLearningPoint ;
  rdfs:label "Simple shapes can be transformed into powerful and symbolic sculpture."@en ;
  dcterms:modified "2026-06-07T15:30:29.286581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29654-4
  a curric:KeyLearningPoint ;
  rdfs:label "Skills in sculpture techniques can be applied to expressive art."@en ;
  dcterms:modified "2026-06-07T15:30:29.286585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pop artists use style and repetition for a purpose - message is as important as
  visual impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21007-2
  a curric:KeyLearningPoint ;
  rdfs:label "Analysing an artwork involves looking at technique, subject, and symbolism."@en ;
  dcterms:modified "2026-06-07T15:30:29.288631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21007-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding an artist’s work helps us plan meaningful artwork of our own."@en ;
  dcterms:modified "2026-06-07T15:30:29.288634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20953-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nature can recover and grow back after damage, showing its resilience."@en ;
  dcterms:modified "2026-06-07T15:30:29.288707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20953-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nature’s changes inspire artists to create artwork that also changes or
  disappears."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20953-3
  a curric:KeyLearningPoint ;
  rdfs:label """Creating art that is ephemeral helps us understand and appreciate the ongoing cycles
  of growth and repair in nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20974-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how letter design can express different emotions or ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.289395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20974-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colours and shapes play a significant role in expressing emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.289399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20974-3
  a curric:KeyLearningPoint ;
  rdfs:label """Learn to design an expressive letter form by focusing on how shape, line, and style
  can communicate mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20974-4
  a curric:KeyLearningPoint ;
  rdfs:label "Explore creative ways to make a single letter a work of art."@en ;
  dcterms:modified "2026-06-07T15:30:29.289406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using tools, paint, or additional materials to refine adds realism, texture, and
  character to a sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20907-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjust and strengthen the sculpture’s structure by securing joints and balancing
  weight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing your final sculpture to your maquette helps to reflect on what worked well
  and what could be improved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20998-1
  a curric:KeyLearningPoint ;
  rdfs:label """While stitches can be used to join textiles, they are also used in a skilled and
  decorative way through embroidery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20998-2
  a curric:KeyLearningPoint ;
  rdfs:label """Embroidery samples can be useful for an artist to remind them of how to achieve a
  particular look or effect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20998-3
  a curric:KeyLearningPoint ;
  rdfs:label """An artist might plan a textile design before beginning their artwork to experiment
  and to solve problems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20966-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might choose to display their works in frames, on plinths or within art
  boxes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20966-2
  a curric:KeyLearningPoint ;
  rdfs:label """A base coat can be used to create an even, smooth background and set an overall tone
  for your artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20966-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use personal materials to tell a story, share a memory, or express
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20895-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using organic and geometric shapes for the basic structure creates a more accurate
  leaf sketch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20895-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different line styles can be used to improve a drawing of a leaf."@en ;
  dcterms:modified "2026-06-07T15:30:29.294549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20895-3
  a curric:KeyLearningPoint ;
  rdfs:label """Applying tone and shading can be used to make an observational drawing more
  realistic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20897-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arranging features of a rainforest in the foreground, middle ground, and background
  creates a balanced composition"""@en ;
  dcterms:modified "2026-06-07T15:30:29.294647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20897-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different painting techniques such as stippling, sponging and blending can create
  texture"""@en ;
  dcterms:modified "2026-06-07T15:30:29.294652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20897-3
  a curric:KeyLearningPoint ;
  rdfs:label """Practicing with different brush sizes (small, medium, large) creates varied
  effects"""@en ;
  dcterms:modified "2026-06-07T15:30:29.294656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learn how graphic designers use typography in posters, advertisements and everyday
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20975-2
  a curric:KeyLearningPoint ;
  rdfs:label "Explore how typography can go beyond functional text to become an art form."@en ;
  dcterms:modified "2026-06-07T15:30:29.295431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Create a piece of expressive typographic art that uses design elements to
  communicate emotion or meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying the shapes in different monster drawings helps us recreate them."@en ;
  dcterms:modified "2026-06-07T15:30:29.296146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20899-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arranging and combining shapes in different ways can create unique monsters."@en ;
  dcterms:modified "2026-06-07T15:30:29.296150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching using light lines helps mistakes to be corrected easily."@en ;
  dcterms:modified "2026-06-07T15:30:29.296154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20899-4
  a curric:KeyLearningPoint ;
  rdfs:label "Line and texture can be used to add details to make drawings more interesting."@en ;
  dcterms:modified "2026-06-07T15:30:29.296158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20976-1
  a curric:KeyLearningPoint ;
  rdfs:label "Understand how facial expressions convey emotion in portraiture."@en ;
  dcterms:modified "2026-06-07T15:30:29.298286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20976-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practise posing and recognising facial expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.298290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20976-3
  a curric:KeyLearningPoint ;
  rdfs:label "Learn basic skills for capturing expressive photographs using digital devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.298294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20976-4
  a curric:KeyLearningPoint ;
  rdfs:label "Create a series of photographs showcasing different facial expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.298298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28496-1
  a curric:KeyLearningPoint ;
  rdfs:label "Surface decoration enhances the visual appeal and meaning of a mask."@en ;
  dcterms:modified "2026-06-07T15:30:29.299638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28496-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different textures and patterns can be created using various tools and materials,
  such as paint, fabric, and beads."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28496-3
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of colours, textures, and patterns should reflect the theme of the mask
  (e.g. cultural or mythical)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28496-4
  a curric:KeyLearningPoint ;
  rdfs:label """Surface decoration techniques include layering, brushing, gluing, and adding 3D
  elements like beads or fabric."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20999-1
  a curric:KeyLearningPoint ;
  rdfs:label """Flexibility, tension and hole preparation should be considered when sewing paper
  pieces together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20999-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pinning a panel together before sewing it can prevent the pieces from moving as well
  as allowing for alterations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20999-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might reflect and evaluate a whole collection of work rather than a single
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20961-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can select a wide range of textures and surfaces with which to create
  monoprints."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20961-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike other printmaking methods that make many copies, a monoprint creates just one
  unique print."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20961-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use monoprinting to create unique, creative works where textures,
  colours and styles can vary greatly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20970-1
  a curric:KeyLearningPoint ;
  rdfs:label "Typography involves the style and appearance of letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.301861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20970-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different styles and techniques can convey various emotions and messages"@en ;
  dcterms:modified "2026-06-07T15:30:29.301865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20970-3
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic design principles can enhance the visual impact of letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.301869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20964-1
  a curric:KeyLearningPoint ;
  rdfs:label """A self-portrait concrete poem is a poem where the writer uses words to describe
  themselves, arranged in visual format."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20964-2
  a curric:KeyLearningPoint ;
  rdfs:label "The arrangement of a concrete poem is as important as the words used within it."@en ;
  dcterms:modified "2026-06-07T15:30:29.302493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20964-3
  a curric:KeyLearningPoint ;
  rdfs:label """An artist might describe both their inner and outer selves using a self-portrait
  poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20929-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective helps artists show space and depth in their drawings."@en ;
