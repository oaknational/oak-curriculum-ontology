# ----------------------------------------------------------------------
# Prior Knowledge Requirements
# ----------------------------------------------------------------------

oakcurric:priorknowledge-2728-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should have basic control of drawing tools (pencil, pen, ruler, colouring
  media)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.627331Z"^^xsd:dateTime .

oakcurric:priorknowledge-2728-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should have basic skills in looking closely at features in the environment
  and recording them through drawing or notes."""@en ;
  dcterms:modified "2026-06-07T15:29:23.627348Z"^^xsd:dateTime .

oakcurric:priorknowledge-2728-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should understand that design is problem-solving: making choices for a
  purpose or audience."""@en ;
