oakcurric:keylearningpoint-lesson-21028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can layer and blend wisps of wool to create different felted effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.304142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20921-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using tools, paint, or additional materials to refine adds realism, texture, and
  character to a sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20921-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjust and strengthen the sculpture’s structure by securing joints and balancing
