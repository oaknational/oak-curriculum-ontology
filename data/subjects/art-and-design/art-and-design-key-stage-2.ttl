  dcterms:modified "2026-06-07T15:30:29.307391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shapes and colour can be used to fill a digital space."@en ;
  dcterms:modified "2026-06-07T15:30:29.307395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20945-3
  a curric:KeyLearningPoint ;
  rdfs:label "An artist can overlap images to add depth to their composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.307399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20987-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learn how to apply finishing touches to clay pieces, using texture, colour, and
  decoration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20987-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of clay are treated differently for drying, firing, glazing and
  painting methods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20987-3
  a curric:KeyLearningPoint ;
  rdfs:label """Develop the ability to evaluate work critically, understanding the importance of
  reflecting on the creative process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21026-1
  a curric:KeyLearningPoint ;
  rdfs:label "Templates can be used to cut the right size and shape of fabric for appliqué."@en ;
  dcterms:modified "2026-06-07T15:30:29.307859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21026-2
  a curric:KeyLearningPoint ;
  rdfs:label "To avoid wasting fabric, an artist can pin templates to the edge of the fabric."@en ;
  dcterms:modified "2026-06-07T15:30:29.307863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21026-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinning the template to fabric helps keep it in place while the artist traces or
  cuts around it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29694-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arranging objects in art (mise en scène) can build settings that carry memory and
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Figures in art express emotion, power, and symbolism through posture and
  placement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Collage, line, colour, and techniques like carbon/paper transfer can be combined to
  create scenes and stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20997-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different cultures might use different traditional tools and methods for creating
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using tools made from natural or found materials creates unique textures, patterns,
