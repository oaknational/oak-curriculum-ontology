  dcterms:modified "2026-06-07T15:30:29.304132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21028-2
  a curric:KeyLearningPoint ;
  rdfs:label "To use a felting tool safely, ensure fingers and eyes are well protected."@en ;
