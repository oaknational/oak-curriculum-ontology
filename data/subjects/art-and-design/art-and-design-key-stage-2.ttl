  dcterms:modified "2026-06-07T15:30:29.314450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20919-2
  a curric:KeyLearningPoint ;
  rdfs:label """Select recyclable materials based on strength and flexibility for different parts of
  a sculpture when assembling it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20919-3
  a curric:KeyLearningPoint ;
  rdfs:label """Securely joining using methods like tape, tabs, slots, and flanges can connect parts
  securely based on their needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20982-1
  a curric:KeyLearningPoint ;
  rdfs:label "Observing carefully before drawing improves accuracy and proportion."@en ;
  dcterms:modified "2026-06-07T15:30:29.314840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20982-2
  a curric:KeyLearningPoint ;
  rdfs:label """Charcoal can create deep contrasts and textures using pressure, blending, and
  erasing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20982-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shading techniques (hatching, cross-hatching, blending) helps bring drawings to
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20982-4
  a curric:KeyLearningPoint ;
  rdfs:label "Light and shadow add depth to make cakes look realistic."@en ;
  dcterms:modified "2026-06-07T15:30:29.314854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20930-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tonal shading helps make 2D drawings look more 3D and realistic."@en ;
  dcterms:modified "2026-06-07T15:30:29.315880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20930-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light source direction affects where highlights and shadows appear."@en ;
  dcterms:modified "2026-06-07T15:30:29.315884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20930-3
  a curric:KeyLearningPoint ;
  rdfs:label """Buildings have surfaces that reflect light differently – shading helps show
  this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20933-1
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting a collaborative architectural model and proposal is an opportunity to
  explain a design and its purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Design ideas are best communicated to an audience by speaking clearly and
  confidently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20933-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on the creative process and group decision-making improves creative
  thinking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20940-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lines can be created with a variety of drawing materials used in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.318877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20940-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geometric and organic shapes are helpful to use when planning a drawing."@en ;
  dcterms:modified "2026-06-07T15:30:29.318881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20940-3
  a curric:KeyLearningPoint ;
  rdfs:label """An outline can be created using a variety of line styles, in a variety of
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20931-1
  a curric:KeyLearningPoint ;
  rdfs:label """Collaboration means sharing ideas respectfully and building on each other’s
  strengths."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20931-2
  a curric:KeyLearningPoint ;
  rdfs:label "A design brief is stronger when it's shaped by input from multiple people."@en ;
  dcterms:modified "2026-06-07T15:30:29.319906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20931-3
  a curric:KeyLearningPoint ;
  rdfs:label "Planning and assigning roles helps a team succeed in a group project."@en ;
  dcterms:modified "2026-06-07T15:30:29.319910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20931-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sketches and models help bring shared ideas to life."@en ;
  dcterms:modified "2026-06-07T15:30:29.319914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20943-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dreams can inspire artists to create artwork, like the Surrealists."@en ;
  dcterms:modified "2026-06-07T15:30:29.320096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20943-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dreamscapes use a combination of the artist’s imagination, ideas from dreams and
  things observed in reality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20943-3
  a curric:KeyLearningPoint ;
  rdfs:label "Texts can describe a dream which the artist can portray using images."@en ;
  dcterms:modified "2026-06-07T15:30:29.320105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20935-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research is a personal process for each artist, and reflects their unique way of
  exploring and creating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20935-2
  a curric:KeyLearningPoint ;
  rdfs:label """Responding to a subject is not just about visually representing it, but about
  expressing a personal reaction to it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20935-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can return to a subject, to approach it in different ways or with different
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23761-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can create tints and shades that they see within a landscape."@en ;
  dcterms:modified "2026-06-07T15:30:29.320576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23761-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tints are made by adding white to a hue of colour, while shades are achieved by
  adding black."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320581Z"^^xsd:dateTime .

