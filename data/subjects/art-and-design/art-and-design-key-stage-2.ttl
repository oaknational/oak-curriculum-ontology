  dcterms:modified "2026-06-07T15:30:29.304204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20962-1
  a curric:KeyLearningPoint ;
  rdfs:label "Collages are made by layering materials on a surface."@en ;
  dcterms:modified "2026-06-07T15:30:29.304208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20962-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can create tones in many ways, including collage."@en ;
  dcterms:modified "2026-06-07T15:30:29.304212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20962-3
  a curric:KeyLearningPoint ;
  rdfs:label """An artwork that incorporates multiple materials is referred to as a mixed media
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Referring to a maquette helps decide the size, shape, and balance of the
