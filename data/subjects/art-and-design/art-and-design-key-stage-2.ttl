  dcterms:modified "2026-06-07T15:30:29.304226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Choose recyclable materials based on their properties to create different features
  like a body, legs or a head."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29649-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thick texture can show emotion and link to a place."@en ;
  dcterms:modified "2026-06-07T15:30:29.304258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personal objects and images can become symbols of identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.304263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29649-3
  a curric:KeyLearningPoint ;
  rdfs:label "Material surfaces and patterns can carry cultural or spiritual meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.304267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20977-1
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions convey emotions such as happiness, sadness, anger, and
