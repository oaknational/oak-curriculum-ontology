oakcurric:keylearningpoint-lesson-28495-2
  a curric:KeyLearningPoint ;
  rdfs:label """Layering modroc is essential for building a strong and durable mask, while allowing
  time for it to dry between layers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28495-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding texture and form is crucial in adding details and uniqueness to each
  mask."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Assemblage is sculpture made by combining everyday objects, photos, text, or
  materials into one artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20968-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might choose to use expressive letterforms and personal materials to create
  elements of their sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20968-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists may choose joining techniques such as gluing, L-braces, flanges and tabs
  within their sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20963-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can combine different media to create a mixed media artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.351161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20963-2
  a curric:KeyLearningPoint ;
  rdfs:label """Looking back at past work can remind an artist of a process or technique they used
  and might want to try again."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can explain their artistic choices to help the viewer get a better
  understanding of their artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29695-1
  a curric:KeyLearningPoint ;
  rdfs:label "Silhouettes and shadows can tell powerful stories without words"@en ;
  dcterms:modified "2026-06-07T15:30:29.354635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Figures and shapes made from clay use storytelling through pose, exaggeration, or
  absence to express meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:29.354639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29695-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light and scale help storytelling by changing the mood of a clay narrative"@en ;
  dcterms:modified "2026-06-07T15:30:29.354645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29695-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different materials, like clay and card, can be combined to create new storytelling
  artworks"""@en ;
  dcterms:modified "2026-06-07T15:30:29.354649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Festivals can celebrate a religious event, a season, a historical moment, or even
  just be a fun tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21030-2
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a festival, it is important to make choices with your target audience
  in mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21030-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can write or draw your ideas on a visual tool, such as a mind map."@en ;
  dcterms:modified "2026-06-07T15:30:29.355991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28492-1
  a curric:KeyLearningPoint ;
  rdfs:label """Masks have cultural, historical and functional significance, often used in rituals,
  performances, or protection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28492-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sources, such as cultural artifacts or historical examples, can inspire creative
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28492-3
  a curric:KeyLearningPoint ;
  rdfs:label "A good design process involves observing, experimenting and refining ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.359630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28492-4
  a curric:KeyLearningPoint ;
  rdfs:label "Labeling a design helps communicate ideas effectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.359634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Select recycled materials for your robot, considering their strength, flexibility,
  and purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20917-2
  a curric:KeyLearningPoint ;
  rdfs:label "Researching artists can inspire unique designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.359642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20917-3
  a curric:KeyLearningPoint ;
  rdfs:label "Role-playing as a robot helps understand its purpose and how its features work."@en ;
  dcterms:modified "2026-06-07T15:30:29.359669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23764-1
  a curric:KeyLearningPoint ;
  rdfs:label """Painting your background first can help your painting to have a smooth foundation,
  before adding your subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23764-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use different painting techniques, and other materials, to add
  interest to their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23764-3
  a curric:KeyLearningPoint ;
  rdfs:label """An artist can reflect on what worked well and what could be better, both while
  making their work and after finishing it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20965-1
  a curric:KeyLearningPoint ;
  rdfs:label "A monoprint results in only one distinct print, making it a unique work of art."@en ;
  dcterms:modified "2026-06-07T15:30:29.359754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20965-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists sometimes choose to use complementary opposite colours to draw the viewer's
  attention to their artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20965-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists may vary text sizes in a concrete poem to highlight specific words or
  phrases they wish to emphasise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29650-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many ways that artists have used dots to create images."@en ;
  dcterms:modified "2026-06-07T15:30:29.359824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29650-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Benin bronzes were made to honour the Oba and record the kingdom’s history and
  culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light and shadow can express status."@en ;
  dcterms:modified "2026-06-07T15:30:29.359857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29650-4
  a curric:KeyLearningPoint ;
  rdfs:label "Representation matters – images tell stories about inclusion and erasure."@en ;
  dcterms:modified "2026-06-07T15:30:29.359861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20942-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some Surrealist artworks are inspired by dreams and the subconscious of the
  artist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20942-2
  a curric:KeyLearningPoint ;
  rdfs:label """Surrealist artworks are distinctive because they often contain images that don’t
  belong together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20942-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strange or unusual things often happen in Surrealist artworks."@en ;
  dcterms:modified "2026-06-07T15:30:29.362112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20942-4
  a curric:KeyLearningPoint ;
  rdfs:label "Opinions about an artwork can be shared with a verbal and a visual response."@en ;
  dcterms:modified "2026-06-07T15:30:29.362116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might reflect and evaluate their artwork before it is complete to make
  improvements to refine their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists evaluate their work to help them reflect on their choices and become better
  artists over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21029-3
  a curric:KeyLearningPoint ;
  rdfs:label """The surface design of an artwork is the process of decorating, altering, or adding
  texture to the surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Assemblage sculptures are made from items which have been found, gathered and
  arranged by an artist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use meaningful objects within their assemblage sculpture which
  represent their self-identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20967-3
  a curric:KeyLearningPoint ;
  rdfs:label """By making intentional choices, the artist can share a message about their
  self-identity effectively with the viewer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29620-1
  a curric:KeyLearningPoint ;
  rdfs:label """Charcoal can be used in many different ways: smudging, shading, erasing and
  layering"""@en ;
  dcterms:modified "2026-06-07T15:30:29.363615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29620-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use marks, shapes and atmosphere to build places and tell stories"@en ;
  dcterms:modified "2026-06-07T15:30:29.363618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29620-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animation or atmosphere can transform a still drawing"@en ;
  dcterms:modified "2026-06-07T15:30:29.363622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21027-1
  a curric:KeyLearningPoint ;
  rdfs:label """While stitches can be used to join textiles, they are also used in a skilled and
