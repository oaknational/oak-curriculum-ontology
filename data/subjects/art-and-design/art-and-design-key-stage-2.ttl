  dcterms:modified "2026-06-07T15:30:29.304200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20921-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing your final sculpture to your maquette helps to reflect on what worked well
