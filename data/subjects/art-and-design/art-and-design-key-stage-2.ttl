  dcterms:modified "2026-06-07T15:30:29.311296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20960-1
  a curric:KeyLearningPoint ;
  rdfs:label """Collages allow artists to creatively combine different materials to make unique,
  interesting pieces of art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20960-2
  a curric:KeyLearningPoint ;
  rdfs:label """Abstract art uses colours and shapes to express feelings and ideas, inviting viewers
  to interpret, not identify objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20960-3
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike other printmaking methods that make many copies, a monoprint creates just one
  unique print."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can look at the same landmark, but choose to take inspiration from different
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20936-2
  a curric:KeyLearningPoint ;
  rdfs:label """A full scale design is a drawing or model that is the same size as the final artwork
  or object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20936-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making a full scale design allows the artist to see all details accurately before
  beginning the actual creation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20919-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a maquette as guidance helps in selecting materials and determining how to
