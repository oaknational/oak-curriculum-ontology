  dcterms:modified "2026-06-07T15:30:29.304223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20908-2
  a curric:KeyLearningPoint ;
  rdfs:label """To assemble means to gather and connect different parts or materials to create a
