  dcterms:modified "2026-06-07T15:30:29.363626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21027-2
  a curric:KeyLearningPoint ;
  rdfs:label """Embroidery samples can be useful for an artist to remind them how to achieve a
  particular look or effect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21027-3
  a curric:KeyLearningPoint ;
  rdfs:label """An artist may begin sewing their arpillera by securing a knot at the end of their
  thread."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21027-4
  a curric:KeyLearningPoint ;
  rdfs:label """To neatly secure the end of a thread, artists may pass it through previous stitches
