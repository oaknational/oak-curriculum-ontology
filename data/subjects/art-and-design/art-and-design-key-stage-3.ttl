oakcurric:keylearningpoint-lesson-20776-3
  a curric:KeyLearningPoint ;
  rdfs:label "By trimming and cutting up prints we can create interesting compositions"@en ;
  dcterms:modified "2026-06-07T15:30:29.273389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20731-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can convey cultural and religious beliefs, and reflect the values of the
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20731-2
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can evoke empathy and resonate with viewers' emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.277562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Animals are often used as symbols and can be a reference to aspects human
  charateristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20731-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use heightened versions of animal colours and patterns to create meaning
  in their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20706-1
  a curric:KeyLearningPoint ;
  rdfs:label """In art, a viewpoint relates to an artist’s personal opinions, experiences and point
  of view."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20706-2
  a curric:KeyLearningPoint ;
  rdfs:label """Art by disabled artists gives the audience powerful ways to think about viewpoints
  as it shows their unique experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20706-3
  a curric:KeyLearningPoint ;
  rdfs:label "Art by disabled artists may use different techniques to share their viewpoint."@en ;
  dcterms:modified "2026-06-07T15:30:29.277599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20706-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mouth and foot painting are techniques where the brush is controlled with the foot
  or mouth to create a painting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21068-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some artists only make art as pure self-expression - there is no intention to share
  with an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some artists intend to make art as pure self-expression, but eventually do share
  their work with an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some artists start by creating art as self-expression and with the intention of
  sharing with others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21068-4
  a curric:KeyLearningPoint ;
  rdfs:label "In many cultures, creative self-expression is woven into daily life."@en ;
  dcterms:modified "2026-06-07T15:30:29.281090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28658-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use food to create sculptures, installations, or paintings, exploring its
  form and visual appeal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28658-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food can reflect cultural identity and personal experiences, prompting discussions
  around our shared identities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28658-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists have often been inspired by food as a tool to bring people together and use
  this connection to create work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28660-1
  a curric:KeyLearningPoint ;
  rdfs:label """Working as individuals, we can make personal pieces that come together as a whole
  art work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28660-2
  a curric:KeyLearningPoint ;
  rdfs:label "By reflecting on our past, we can reinforce our sense of identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.281471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contributing memories to collaborative art projects fosters a sense of community and
  connection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28660-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound can inspire artwork by helping artists express emotion, rhythm and movement
  through visual elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28657-1
  a curric:KeyLearningPoint ;
  rdfs:label "Art can be used as a tool for expressing inner emotions and identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.284783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28657-2
  a curric:KeyLearningPoint ;
  rdfs:label """Assemblage is art that is made by assembling separate elements, often everyday
  objects, together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28657-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identity can be explored through art forms such as assemblage."@en ;
  dcterms:modified "2026-06-07T15:30:29.284791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout history artists often turn to nature as inspiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.286557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20728-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists draw to document ideas, observations, and processes. This can be
  experimental or from direct observation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20728-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists explore nature through representation, as well as literally creating work
  with and in nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20707-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can influence change through creating artworks related to causes."@en ;
  dcterms:modified "2026-06-07T15:30:29.287938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20707-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists make artworks about causes for many reasons, including to bring joy and
  raise awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20707-3
  a curric:KeyLearningPoint ;
  rdfs:label """Slogans are effective ways for artists to communicate their message about a
  cause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20707-4
  a curric:KeyLearningPoint ;
  rdfs:label """Block lettering is a style of text that can have great impact on the viewer as it is
  clear and easy to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20760-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to experiment with different tools to discover the variety of marks
  each one can make"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20760-2
  a curric:KeyLearningPoint ;
  rdfs:label """Trying different approaches can lead to new discoveries, like flicking, smudging,
  smearing"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20760-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can be adventurous with tools, using found objects can create interesting
  marks"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nature can represent themes such as growth, decay, rebirth, and spirituality."@en ;
  dcterms:modified "2026-06-07T15:30:29.293293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20730-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can focus on the moods and ideas that nature evokes, rather than just
  depicting a scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use natural materials like wood, stone, and clay to create their
  works."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21065-1
  a curric:KeyLearningPoint ;
  rdfs:label """Built environment can create a sense of pride in a community through shared
  histories or experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21065-2
  a curric:KeyLearningPoint ;
  rdfs:label "Landmarks and structures can connect us to our communities."@en ;
  dcterms:modified "2026-06-07T15:30:29.293425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21065-3
  a curric:KeyLearningPoint ;
  rdfs:label "Architects play with materials to help inspire interesting designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.293429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20738-1
  a curric:KeyLearningPoint ;
  rdfs:label "Composition is the arrangement of the various art elements"@en ;
  dcterms:modified "2026-06-07T15:30:29.295812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20738-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different compositional rules help to create a focal point and lead a viewer around
  the image"""@en ;
  dcterms:modified "2026-06-07T15:30:29.295816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Magazines use composition to help draw the viewer in to a specific story, and are
  usually mainstream"""@en ;
  dcterms:modified "2026-06-07T15:30:29.295820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20738-4
  a curric:KeyLearningPoint ;
  rdfs:label """A zine is a self-published booklet that is often more experimental with designs and
  layouts"""@en ;
  dcterms:modified "2026-06-07T15:30:29.295824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21069-1
  a curric:KeyLearningPoint ;
  rdfs:label "Art can transcend language, geography and time to communicate ideas or emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.295828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21069-2
  a curric:KeyLearningPoint ;
  rdfs:label """Universal themes can be understood globally, even when expressed in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21069-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists create spaces or artworks to promote shared feelings or experiences creating
  connection among their audiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21069-4
  a curric:KeyLearningPoint ;
  rdfs:label "Discussing an artwork helps us to make connections and deepen our understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.295840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21052-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm is created by repeating elements to create a visual tempo or beat"@en ;
  dcterms:modified "2026-06-07T15:30:29.295930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm can be created through line, colour, shape, pattern and composition"@en ;
  dcterms:modified "2026-06-07T15:30:29.295937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21052-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhythm helps guide the viewer's eye around a piece rather than settling on a
  particular focal point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20747-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spatial design is the practice of creating and organising physical spaces for people
  to use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20747-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spaces and building design are influenced by the time and place you find them."@en ;
  dcterms:modified "2026-06-07T15:30:29.296014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20747-3
  a curric:KeyLearningPoint ;
  rdfs:label """Architects draw from a range of cultural, social and historic inspirations, creating
  innovative and exciting designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21057-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use text in their work as a powerful tool to convey thoughts and
  feelings"""@en ;
  dcterms:modified "2026-06-07T15:30:29.296022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21057-2
  a curric:KeyLearningPoint ;
  rdfs:label "Typography can be added onto an art work, or be an artwork in its own right"@en ;
  dcterms:modified "2026-06-07T15:30:29.296026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21057-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use typography to inform our art work and discuss our identity"@en ;
  dcterms:modified "2026-06-07T15:30:29.296030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20759-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abstract painting uses shapes, colours, and forms to convey emotions or ideas,
  without aiming to represent reality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20759-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can be inspired by different stimuli when creating abstract art."@en ;
  dcterms:modified "2026-06-07T15:30:29.296038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20759-3
  a curric:KeyLearningPoint ;
  rdfs:label """In art, stimuli can be visual, auditory or tactile elements that evoke
  reactions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20759-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expressive artworks use dynamic brushstrokes and bold colours to communicate
  feelings rather than depict reality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dyeing is the process of applying colour to textiles, fibres, or materials using
  natural or synthetic dyes"""@en ;
  dcterms:modified "2026-06-07T15:30:29.296369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20742-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many dyeing traditions, including: Shibori in Japan, Batik in Indonesia
  and Tie-dye in Africa and the US"""@en ;
  dcterms:modified "2026-06-07T15:30:29.296373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20742-3
  a curric:KeyLearningPoint ;
  rdfs:label "By using natural dyes you can achieve a range of colours"@en ;
  dcterms:modified "2026-06-07T15:30:29.296377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20742-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can use resist techniques to create patterns in the materials"@en ;
  dcterms:modified "2026-06-07T15:30:29.296381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20729-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can find amazing architectural structures in nature, such as the bees' nest and
  the snail shell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Architects have used the structure of organic forms from nature in their building
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20729-3
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing from natural forms can inspire architectural designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.299547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20755-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking in 3D is a valuable skill in fields like architecture, design, and art."@en ;
  dcterms:modified "2026-06-07T15:30:29.300003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20755-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sketching 3D objects from different angles helps in understanding depth and
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20755-3
  a curric:KeyLearningPoint ;
  rdfs:label """Breaking down complex forms into simpler shapes makes the object easier to
  understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20755-4
  a curric:KeyLearningPoint ;
  rdfs:label """When carving, removing small amounts at a time helps achieve a more refined and
  detailed result."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20746-1
  a curric:KeyLearningPoint ;
  rdfs:label """Appliqué has been used throughout the centuries, using various techniques for both
  functional and artistic purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20746-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can create varied designs with appliqué using different methods of stitch and
  also by bonding fabric."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20746-3
  a curric:KeyLearningPoint ;
  rdfs:label "A template is often used to help replicate shapes at the correct size."@en ;
  dcterms:modified "2026-06-07T15:30:29.300027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20746-4
  a curric:KeyLearningPoint ;
  rdfs:label """Felt is a popular material for appliqué because it’s thick and easy to work
  with."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20704-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often explore their feelings, experiences and observations of the world and
  communicate meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20704-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can collaborate and work together to communicate common meanings or achieve
  common goals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20704-3
  a curric:KeyLearningPoint ;
  rdfs:label """When artists collaborate, they develop common values and beliefs to enable them to
  form a community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20704-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of hands in art symbolise many things such as emotion, support, affection,
  beliefs and can represent community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20722-1
  a curric:KeyLearningPoint ;
  rdfs:label """Art movements are groups of artists who share common characteristics, themes, ideas
  or techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20722-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artworks tell us a little bit about the world they existed in and the technological
  advances at the time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20722-3
  a curric:KeyLearningPoint ;
  rdfs:label "Technology has impacted the development of art movements throughout history."@en ;
  dcterms:modified "2026-06-07T15:30:29.300957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Street art can bring attention to important social issues such as social justice,
  inequality, and the environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Street art draws on diverse cultural influences, fostering appreciation for various
  traditions and backgrounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21064-3
  a curric:KeyLearningPoint ;
  rdfs:label """When communities engage in street art projects, it can create a sense of ownership
  and pride in local spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28497-1
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns often involve designs made using printing techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.301052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Printed patterns are often seen in everyday items like clothing, furnishings and
  wallpapers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28497-3
  a curric:KeyLearningPoint ;
  rdfs:label """Block printing is a process where a design is transferred from a material onto a
  surface using pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28497-4
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns often use geometric shapes and are built through repeat and print
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20725-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists often make work in response to events."@en ;
  dcterms:modified "2026-06-07T15:30:29.301214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20725-2
  a curric:KeyLearningPoint ;
  rdfs:label """Art is a way for people to express their ideas and opinions about both current and
  historical events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20725-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists sometimes use symbols to give their work deeper meaning and to help tell a
  story or share an idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20726-1
  a curric:KeyLearningPoint ;
  rdfs:label """When an image is iconic it represents a particular idea or thing and can be easily
  and quickly recognised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20726-2
  a curric:KeyLearningPoint ;
  rdfs:label """Iconic images in art often come from art movements in Western art history, often due
  to the innovative techniques used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20726-3
  a curric:KeyLearningPoint ;
  rdfs:label """Iconic images from Western art can mean that our diverse world is often not
  reflected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20726-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contemporary artists are addressing this imbalance by increasing the visibility of
  marginalised groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20717-1
  a curric:KeyLearningPoint ;
  rdfs:label "Set design is the art of designing environments and atmospheric spaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.302449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Colour combinations and different mark- making techniques can be used to represent
  different atmospheres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Card brackets are useful in constructing temporary three dimensional spaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.302459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20717-4
  a curric:KeyLearningPoint ;
  rdfs:label """To test and show the scale of space, silhouettes of actors can be placed in the
  space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20718-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic design is the art of using visual elements to communicate messages."@en ;
  dcterms:modified "2026-06-07T15:30:29.303871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20718-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers often push traditional boundaries of graphic design through ways such as
  using different mediums."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20718-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic designers consider the target audience, the purpose and the message of the
  design piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20718-4
  a curric:KeyLearningPoint ;
  rdfs:label "Designers can use colour, imagery and layout to communicate their message."@en ;
  dcterms:modified "2026-06-07T15:30:29.303883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Depth is the illusion of distance between the foreground and background of a
  composition on a flat surface"""@en ;
  dcterms:modified "2026-06-07T15:30:29.304270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28664-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are several ways of creating depth in an image, such as overlapping
  objects"""@en ;
  dcterms:modified "2026-06-07T15:30:29.304274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28664-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shading and contrast can also be used to create an illusion of depth"@en ;
  dcterms:modified "2026-06-07T15:30:29.304278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20720-1
  a curric:KeyLearningPoint ;
  rdfs:label "Architecture is the art and science of designing and constructing buildings."@en ;
  dcterms:modified "2026-06-07T15:30:29.304339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20720-2
  a curric:KeyLearningPoint ;
  rdfs:label "Architects create a sense of community through their designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.304343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20720-3
  a curric:KeyLearningPoint ;
  rdfs:label """Architects can incorporate patterns in their design both through the structure and
  literal patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20720-4
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns can represent communities in architecture."@en ;
  dcterms:modified "2026-06-07T15:30:29.304351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20705-1
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing can be a range of things, from creating replicas to exploring a variety of
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20705-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can build confidence in drawing by experimenting with different techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.304510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20705-3
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing with machines or objects removes control from the artist and records marks
  which are unexpected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20705-4
  a curric:KeyLearningPoint ;
  rdfs:label "One of the most important aspects of art making and learning is that it is fun!"@en ;
  dcterms:modified "2026-06-07T15:30:29.304517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Design is the process of planning and creating things to solve problems or to meet a
  need."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20716-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers use design principles to help them in their work and to design
  solutions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20716-3
  a curric:KeyLearningPoint ;
  rdfs:label "Design principles include aesthetics, function and interactivity."@en ;
  dcterms:modified "2026-06-07T15:30:29.305204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20716-4
  a curric:KeyLearningPoint ;
  rdfs:label """Curiosity about the world around us is vital in design and designers use this to
  push boundaries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20724-1
  a curric:KeyLearningPoint ;
  rdfs:label """Art movements can use a manifesto to share their artistic principles with the
  public."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20724-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artistic intentions refer to the purpose of an art movement or artwork and the
  themes this is communicated through."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20724-3
  a curric:KeyLearningPoint ;
  rdfs:label "Manifestos can guide the different styles and mediums used."@en ;
  dcterms:modified "2026-06-07T15:30:29.305223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20724-4
  a curric:KeyLearningPoint ;
  rdfs:label "Manifestos can be communicated through many different disciplines."@en ;
  dcterms:modified "2026-06-07T15:30:29.305227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20721-1
  a curric:KeyLearningPoint ;
  rdfs:label """Printed textiles are fabrics with designs or patterns created by printing
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20721-2
  a curric:KeyLearningPoint ;
  rdfs:label """Printed textiles takes many forms and can be found in our homes through furnishings,
  clothing, wallpapers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20721-3
  a curric:KeyLearningPoint ;
  rdfs:label "Incorporting motif designs is a big part of printed textiles"@en ;
  dcterms:modified "2026-06-07T15:30:29.306484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Families are unique and come in all shapes and sizes"@en ;
  dcterms:modified "2026-06-07T15:30:29.307379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Family extends beyond biology, to those who choose to be a part of each other's
  lives and offer unconditional love"""@en ;
  dcterms:modified "2026-06-07T15:30:29.307383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28652-3
  a curric:KeyLearningPoint ;
  rdfs:label "Art can represent both individual families and that of wider society"@en ;
  dcterms:modified "2026-06-07T15:30:29.307387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20769-1
  a curric:KeyLearningPoint ;
  rdfs:label """Playing around with various compositional ideas is helpful in consolidating final
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20769-2
  a curric:KeyLearningPoint ;
  rdfs:label "Refining areas of the collage through a reflective process adds deeper meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.307407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20769-3
  a curric:KeyLearningPoint ;
  rdfs:label """Having confidence to change ideas mid process will lead to more refined
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20765-1
  a curric:KeyLearningPoint ;
  rdfs:label """A collage combines varied materials like photos, paper and textures to build layers
  and create visual depth"""@en ;
  dcterms:modified "2026-06-07T15:30:29.307535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20765-2
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with composition by arranging and rearranging elements until the
  layout feels balanced"""@en ;
  dcterms:modified "2026-06-07T15:30:29.307539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20765-3
  a curric:KeyLearningPoint ;
  rdfs:label "Collage can be used to explore portraiture which discuss social histories"@en ;
  dcterms:modified "2026-06-07T15:30:29.307543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21049-1
  a curric:KeyLearningPoint ;
  rdfs:label """Proportion in Western art is the size and relation of different parts in a piece of
  art to each other"""@en ;
  dcterms:modified "2026-06-07T15:30:29.309659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21049-2
  a curric:KeyLearningPoint ;
  rdfs:label """Western ideas of proportion can aid in drawing mathematically and accurately, but
  they can embed ideas of the 'norm'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.309663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rules of proportion change depending on the culture"@en ;
  dcterms:modified "2026-06-07T15:30:29.309667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21049-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can play with proportion to create new ways of looking at a subject"@en ;
  dcterms:modified "2026-06-07T15:30:29.309671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28661-1
  a curric:KeyLearningPoint ;
  rdfs:label """Balance is the visual weight of each element and how it is distributed to make the
  composition feel stable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28661-2
  a curric:KeyLearningPoint ;
  rdfs:label """Balance in an art work helps to lead the viewer's eye around the artwork and create
  a sense of unity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Creating work that is imbalanced can be used to depict unsettled emotions in an
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20763-1
  a curric:KeyLearningPoint ;
  rdfs:label """Colours are a vehicle for expressing emotion, we can use shapes and marks to
  describe an experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20763-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sound, such as a thunderstorm, provides a stimulus to which we can respond quickly
  and with energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20763-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can apply paint using a variety of tools to create texture in response to natural
  stimuli."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20723-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists make art using many different materials and techniques. We call this an
  artistic discipline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20723-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists and movements can generate work in different disciplines, often using
  similar characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20723-3
  a curric:KeyLearningPoint ;
  rdfs:label """Multidisciplinary artists work across disciplines but often create work that shares
  common characteristics or themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21060-1
  a curric:KeyLearningPoint ;
  rdfs:label """Social action is about coming together to improve lives and solve problems important
  to communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Social action projects encourage discussion, conversation and heightened
  awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21060-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists select materials to communicate more clearly with their audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.314470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20719-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fashion design is the art of designing clothing and accessories."@en ;
  dcterms:modified "2026-06-07T15:30:29.314558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20719-2
  a curric:KeyLearningPoint ;
  rdfs:label "Individual fashion is personal and links to time, place and culture."@en ;
  dcterms:modified "2026-06-07T15:30:29.314562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20719-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fashion designers are challenging our understanding of fashion."@en ;
  dcterms:modified "2026-06-07T15:30:29.314565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20775-1
  a curric:KeyLearningPoint ;
  rdfs:label "An important part of the print process is selecting successful prints."@en ;
  dcterms:modified "2026-06-07T15:30:29.318624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20775-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying good ink coverage, detail, textures, focal point and interesting
  composition are key aspects of selection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20775-3
  a curric:KeyLearningPoint ;
  rdfs:label """After analysing the successes and needed improvements a second print run can be
  attempted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Printing with botanical forms allows artists to create environmentally
  friendly art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Printing techniques create unique textures that are difficult to achieve with other
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20743-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use culturally traditional techniques to connect with the past whilst adding
  their own style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21067-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use mapping through literal geography, map-like work or more
  subjective or abstract representations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21067-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists have long used mapping as a way to tell personal, cultural, and historical
  stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21067-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists might use symbolism and unconventional media in their work."@en ;
  dcterms:modified "2026-06-07T15:30:29.320360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21062-1
  a curric:KeyLearningPoint ;
  rdfs:label "Art can be used to promote or oppose a war, recruit soldiers, or justify a war"@en ;
  dcterms:modified "2026-06-07T15:30:29.320944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Art can show the impact of war, including battles, the impact on soldiers and
  civilians, and city destruction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21062-3
  a curric:KeyLearningPoint ;
  rdfs:label "Art can speak to future conflicts and remind us of our shared humanity"@en ;
  dcterms:modified "2026-06-07T15:30:29.320954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28659-1
  a curric:KeyLearningPoint ;
  rdfs:label """How touch, connection, and communication, reflecting human relationships and
  experiences can be expressed through art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28659-2
  a curric:KeyLearningPoint ;
  rdfs:label """Working with materials like clay or paper can be grounding and physically
  engaging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28659-3
  a curric:KeyLearningPoint ;
  rdfs:label "Malleable materials can be used to express care for one another."@en ;
  dcterms:modified "2026-06-07T15:30:29.320966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Variety is the use of different elements to create visual interest and complexity in
  a work"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21051-2
  a curric:KeyLearningPoint ;
  rdfs:label """Variety can be achieved by using different colours, shapes, sizes, textures, lines
  and materials"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21051-3
  a curric:KeyLearningPoint ;
  rdfs:label """Variety can be created by contrasting elements such as light/dark, rough/smooth, or
  large/small"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20753-1
  a curric:KeyLearningPoint ;
  rdfs:label """A biomorphic sculpture is an art form inspired by organic shapes found in
  nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20753-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use various materials including clay, metal, wood, stone, thread, wire or
  found objects to create organic forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20753-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can sketch from nature and simplify the structure to create an idea for a
  sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20715-1
  a curric:KeyLearningPoint ;
  rdfs:label """A puppet is a hand-made figure, human, animal, or abstract form, that is controlled
  by a person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20715-2
  a curric:KeyLearningPoint ;
  rdfs:label """Puppets come in different forms, they can be 2D or 3D, can be made from different
  materials and come in various sizes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Puppets use human characteristics to convey a type of personality; these can play
  into stereotypes of people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20715-4
  a curric:KeyLearningPoint ;
  rdfs:label "Puppets can tell stories, challenge ideas, and promote political change."@en ;
  dcterms:modified "2026-06-07T15:30:29.324094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20757-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modelling is an additive technique where you shape and mould materials to make a
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20757-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use hand building methods like pinch pot, coil method and or the slab
  method to create clay forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20757-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clay allows details to be added both into the clay as a texture or on top of the
  clay as a surface design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Perspective helps create solid objects on a two-dimensional surface to give an
  illusion of height, width and depth"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28663-2
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective can be used to create realistic or disorientating images"@en ;
  dcterms:modified "2026-06-07T15:30:29.324271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Perspective is rooted in a Western idea of seeing, global communities explore the
  picture space in different ways"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20708-1
  a curric:KeyLearningPoint ;
  rdfs:label """Not all art is representational or permanent, some forms of art push 'traditional'
  boundaries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20708-2
  a curric:KeyLearningPoint ;
  rdfs:label """Abstract art does not depict a recognisable picture, place, person or object in the
  real world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20708-3
  a curric:KeyLearningPoint ;
  rdfs:label "Performance art happens live and is constantly changing."@en ;
  dcterms:modified "2026-06-07T15:30:29.329623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20708-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ephemeral art doesn’t last forever. It is purposefully temporary and will change
  over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20771-1
  a curric:KeyLearningPoint ;
  rdfs:label """Printing allows artists to create multiple copies of an artwork, making it
  accessible and affordable"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Printing techniques create unique textures that are difficult to achieve through
  other media"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20771-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use traditional printing techniques to connect with the past while adding
  their own style"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20735-1
  a curric:KeyLearningPoint ;
  rdfs:label "Line is used in mark-making."@en ;
  dcterms:modified "2026-06-07T15:30:29.331167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20735-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mark-making can be used to create texture."@en ;
  dcterms:modified "2026-06-07T15:30:29.331171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20735-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contour lines focus on the outline, form and shape of a subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.331175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weaving has been used throughout the centuries, using various techniques, for both
  functional and artistic purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20744-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can create patterns and simple designs, like stripes and checks, when
  weaving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20744-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can apply understanding of colour theory in weaving."@en ;
  dcterms:modified "2026-06-07T15:30:29.333020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20744-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can take inspiration from cultural or natural motifs and apply these in
  their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20772-1
  a curric:KeyLearningPoint ;
  rdfs:label """A monoprint is a technique that produces one-of-a-kind images, allowing for creative
  experimentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20772-2
  a curric:KeyLearningPoint ;
  rdfs:label """Monoprinting with ink is more likely to capture textures and marks than printing
  with oil pastel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20772-3
  a curric:KeyLearningPoint ;
  rdfs:label "Understand the monoprint process of ink, press and reveal."@en ;
  dcterms:modified "2026-06-07T15:30:29.333694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21056-1
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits have historically been used to convey power and use composition to
  do this"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21056-2
  a curric:KeyLearningPoint ;
  rdfs:label """The history of the portrait also highlights a lack of representation, artists are
  changing this narrative"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21056-3
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits are personal representations and can include other elements to help tell a
  person's story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28649-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often explore family as a theme in their work, reflecting on relationships
  and connections to others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28649-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists explore wider aspects of what family means, both literally and
  conceptually."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use various creative methods, including portraiture to explore family
  relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28650-1
  a curric:KeyLearningPoint ;
  rdfs:label """Art is often used as a tool to build emotional support, reduce isolation and foster
  connections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28650-2
  a curric:KeyLearningPoint ;
  rdfs:label "Art helps to develop community by providing a welcoming environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.335174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28650-3
  a curric:KeyLearningPoint ;
  rdfs:label """Community murals can be used to bring diverse families together, celebrate cultures
  and strengthen social bonds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20764-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often use dry materials to create definition in their work when responding
  to a stimuli."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20764-2
  a curric:KeyLearningPoint ;
  rdfs:label """When working intuitively, we can work in an abstract way to reflect mood or energy,
  rather than realistic images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20764-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using intuitive mark-making, artists let their materials and feelings guide the
  artwork"""@en ;
  dcterms:modified "2026-06-07T15:30:29.339325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Craft is designing and hand-making unique objects, building creative, intellectual,
  and practical skills with tools."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20710-2
  a curric:KeyLearningPoint ;
  rdfs:label """Craft was seen as lesser than Fine Art because it was functional and often practised
  by women."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20710-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists like William Morris challenged the divide between art and craft, blurring
  the boundaries in their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20773-1
  a curric:KeyLearningPoint ;
  rdfs:label """A press print uses a plate with a design on the surface, pressure is applied to
  transfer ink from plate to paper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20773-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some food packaging can be used to create a plate by drawing designs into the
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20773-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can develop prints using different surfaces, working into prints or rotating
  plates to create more complex designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Volume is the amount of space occupied by an object or figure in three dimensions:
  height, width and depth"""@en ;
  dcterms:modified "2026-06-07T15:30:29.339486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Volume is an element of visual expression that can be appreciated in a real or
  figurative way"""@en ;
  dcterms:modified "2026-06-07T15:30:29.339490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28662-3
  a curric:KeyLearningPoint ;
  rdfs:label "The illusion of volume can be created in a two-dimensional work"@en ;
  dcterms:modified "2026-06-07T15:30:29.339494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20712-1
  a curric:KeyLearningPoint ;
  rdfs:label """Body adornment is the practice of decorating or modifying the body through our hair,
  nails, skin, clothing or jewellery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20712-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body adornment is used widely across the globe in various forms and contexts."@en ;
  dcterms:modified "2026-06-07T15:30:29.340265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20712-3
  a curric:KeyLearningPoint ;
  rdfs:label """Body adornment shows identity, including: gender, religion, family, social status
  and sexuality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28653-1
  a curric:KeyLearningPoint ;
  rdfs:label "Feeling a connection to a place is an important part of our wellbeing"@en ;
  dcterms:modified "2026-06-07T15:30:29.340449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28653-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can create a feeling of belonging through decoration of a space"@en ;
  dcterms:modified "2026-06-07T15:30:29.340452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28653-3
  a curric:KeyLearningPoint ;
  rdfs:label "In our homes, we use objects and images to reflect our identities"@en ;
  dcterms:modified "2026-06-07T15:30:29.340456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20750-1
  a curric:KeyLearningPoint ;
  rdfs:label """Architects use colour to influence mood, making spaces feel calm, vibrant, or
  welcoming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20750-2
  a curric:KeyLearningPoint ;
  rdfs:label """Colour highlights design elements, drawing attention to specific areas or features
  and enhancing spatial perception."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20750-3
  a curric:KeyLearningPoint ;
  rdfs:label """Colour can be incorporated by using different materials, such as glass, paint or
  natural materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Colour can be used to support health and wellbeing."@en ;
  dcterms:modified "2026-06-07T15:30:29.342068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21066-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identity is multifaceted and can change over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.342251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists explore and express identity in their work, and they do not always do this
  through traditional portraits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21066-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists make selections about what to conceal or reveal in their work."@en ;
  dcterms:modified "2026-06-07T15:30:29.342260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21066-4
  a curric:KeyLearningPoint ;
  rdfs:label """You don’t need to share the same identity as an artist to understand and appreciate
  their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29198-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic pollution is one of the biggest threats to the planet."@en ;
  dcterms:modified "2026-06-07T15:30:29.342917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29198-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists transform waste into thought-provoking pieces that inspire
  sustainability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29198-3
  a curric:KeyLearningPoint ;
  rdfs:label """The manipulation of waste materials can add meaning, deepening the thought provoking
  effect of the artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Environmental art raises awareness of the harm we are causing to the planet and
  calls us to action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20733-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use the power of imagery to communicate difficult realities about the
  planet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20733-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use both shock tactics as well as joyful encounters to raise awareness."@en ;
  dcterms:modified "2026-06-07T15:30:29.343333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20739-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texture can be either physical where we can touch and feel it or visual where there
  is the illusion of a surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20739-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can create texture by using mark making and materials in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.343357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20739-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can create texture through using mixed media and layering different materials
  onto a surface to create a composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20767-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use collage techniques to create surreal landscapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.343468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20767-2
  a curric:KeyLearningPoint ;
  rdfs:label "Images from magazines can be used to shape initial story ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.343472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20767-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can use textured surfaces in their designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.343476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20767-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can manipulate 3D materials and skills to add interest and depth to a
  collage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20768-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can find inspiration to develop a personal idea for a collage or assemblage
  from their interests"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20768-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying and planning the key aspects of a collage helps build confidence in the
  process"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20768-3
  a curric:KeyLearningPoint ;
  rdfs:label """Selecting a range of materials means there can be playful experimentation before
  committing to a design"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20774-1
  a curric:KeyLearningPoint ;
  rdfs:label """Printing a plate requires a thick layer of ink. If it is too wet the design will be
  lost."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20774-2
  a curric:KeyLearningPoint ;
  rdfs:label "The process for printing a plate is add ink, apply pressure and reveal."@en ;
  dcterms:modified "2026-06-07T15:30:29.345035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20774-3
  a curric:KeyLearningPoint ;
  rdfs:label """The print process is trial and error. Several prints need to be taken to refine the
  process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20736-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tone indicates how light or dark something is"@en ;
  dcterms:modified "2026-06-07T15:30:29.345042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20736-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tone can be organised into groups of lights, mid tones, darks"@en ;
  dcterms:modified "2026-06-07T15:30:29.345046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20736-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tone is used to create form"@en ;
  dcterms:modified "2026-06-07T15:30:29.345050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20713-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pottery has been around for thousands of years and is a job within the creative
  industries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20713-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pottery can take various forms and has multiple uses and functions from practical
  uses to artistic storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contemporary artists use the pot in different ways to convey ideas and meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.346317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21054-1
  a curric:KeyLearningPoint ;
  rdfs:label """The painted portrait is understood to have originated in Ancient Egypt, over 5,000
  years ago"""@en ;
  dcterms:modified "2026-06-07T15:30:29.346388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21054-2
  a curric:KeyLearningPoint ;
  rdfs:label """Paint allows artists to explore texture, colour, and form, capturing emotion and
  personality"""@en ;
  dcterms:modified "2026-06-07T15:30:29.346392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21054-3
  a curric:KeyLearningPoint ;
  rdfs:label """The versatility of paint enables both realistic and abstract interpretations of a
  subject"""@en ;
  dcterms:modified "2026-06-07T15:30:29.346396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21071-1
  a curric:KeyLearningPoint ;
  rdfs:label """Craftspeople across cultures play essential roles in creating art that holds
  spiritual or symbolic meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Craftspeople have created objects used for rituals or ceremonies, such as
  altarpieces, prayer flags, or ceremonial masks"""@en ;
  dcterms:modified "2026-06-07T15:30:29.349148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21071-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists create spaces or works for meditation, reflection or worship, inviting
  viewers to experience a sense of peace"""@en ;
  dcterms:modified "2026-06-07T15:30:29.349152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21070-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Western art history, the roles of men and women are often depicted in traditional
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21070-2
  a curric:KeyLearningPoint ;
  rdfs:label """There have always been artists who have subverted traditional ideas of gender and
  sexuality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21070-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists often challenge stereotypes around gender and sexuality in their work."@en ;
  dcterms:modified "2026-06-07T15:30:29.349423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20737-1
  a curric:KeyLearningPoint ;
  rdfs:label """Colours can carry different meanings, and these can vary across people, places and
  cultures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20737-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use colour to convey emotion in our work."@en ;
  dcterms:modified "2026-06-07T15:30:29.349474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20737-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists and designers can use colour theory and personal preference in their
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28655-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists explore their own wellbeing as a means of self-expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.351198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28655-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists explore wellbeing in their art to raise awareness, and foster empathy and
  understanding in society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28655-3
  a curric:KeyLearningPoint ;
  rdfs:label "Art practice can promote relaxation providing a calming experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.351207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20754-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists turn to nature to find shapes, textures, and colours which could inspire
  sculptural forms"""@en ;
  dcterms:modified "2026-06-07T15:30:29.351981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20754-2
  a curric:KeyLearningPoint ;
  rdfs:label """By experimenting with various materials, like clay, paper, or fabrics, we can create
  unique shapes and forms"""@en ;
  dcterms:modified "2026-06-07T15:30:29.351985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20754-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use sculptural features and designs to express culture, history and
  emotions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.351989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20758-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can employ a range of shapes and forms to create their sculptural works."@en ;
  dcterms:modified "2026-06-07T15:30:29.354623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20758-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of pedestals, plinths and lighting can enhance sculptural works in a gallery
  setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20758-3
  a curric:KeyLearningPoint ;
  rdfs:label """Curators and artists select the information to accompany artworks to enhance the
  viewer's understanding of the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mass relates to solid matter, but in an artistic sense it refers to visual
  weight"""@en ;
  dcterms:modified "2026-06-07T15:30:29.355800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21053-2
  a curric:KeyLearningPoint ;
  rdfs:label "Objects with more mass are more likely to grab the viewer's attention"@en ;
  dcterms:modified "2026-06-07T15:30:29.355804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic design uses mass to determine what will carry the most significant visual
  weight"""@en ;
  dcterms:modified "2026-06-07T15:30:29.355808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28654-1
  a curric:KeyLearningPoint ;
  rdfs:label """Galleries and archives are a good source for understanding our local and national
  history"""@en ;
  dcterms:modified "2026-06-07T15:30:29.356009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28654-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every area has a story which can be both joyful and/or difficult; art can help us to
  discover this together"""@en ;
  dcterms:modified "2026-06-07T15:30:29.356013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28654-3
  a curric:KeyLearningPoint ;
  rdfs:label """Migration stories help us to question what Britishness is and celebrate the
  diversity of our towns and country"""@en ;
  dcterms:modified "2026-06-07T15:30:29.356017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21048-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scale is the relative size of an object or artwork in relation to its surroundings
  and to itself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21048-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can use scale to create drama or tension, or to emphasise a point."@en ;
  dcterms:modified "2026-06-07T15:30:29.356414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21048-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scale can be used to manipulate how the viewer interacts with the work."@en ;
  dcterms:modified "2026-06-07T15:30:29.356418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21048-4
  a curric:KeyLearningPoint ;
  rdfs:label "Artists can use small components to create enormous art works."@en ;
  dcterms:modified "2026-06-07T15:30:29.356422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20770-1
  a curric:KeyLearningPoint ;
  rdfs:label "By refining our collage we can consolidate the idea or meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.356959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20770-2
  a curric:KeyLearningPoint ;
  rdfs:label """Small additions, like text or embellishments can add interesting details and focus
  attention"""@en ;
  dcterms:modified "2026-06-07T15:30:29.356963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20770-3
  a curric:KeyLearningPoint ;
  rdfs:label "Trimming or creating a frame can pull an artwork together"@en ;
  dcterms:modified "2026-06-07T15:30:29.356967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20752-1
  a curric:KeyLearningPoint ;
  rdfs:label """Architects respond to 'requests for proposals', creating an outline of how they
  would meet the brief for a project."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20752-2
  a curric:KeyLearningPoint ;
  rdfs:label """Architects have to pitch their ideas in a clear and concise way and show how their
  idea is unique to win the job."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20752-3
  a curric:KeyLearningPoint ;
  rdfs:label """When presenting an idea, architects think of it as a story, with a beginning, middle
  and end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20752-4
  a curric:KeyLearningPoint ;
  rdfs:label """Public speaking is a crucial skill and there are techniques we can use to help with
  our nerves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Embroidery has been used throughout the centuries to produce functional and artistic
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20745-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can create designs with embroidery stitches and can also draw with stitch."@en ;
  dcterms:modified "2026-06-07T15:30:29.362224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20745-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colour and colour theory is an important part of embroidery."@en ;
  dcterms:modified "2026-06-07T15:30:29.362228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can take inspiration from many things to produce traditional or contemporary
  embroidery pieces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21050-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists achieve unity through repetition of elements such as colour, shape and
  texture, creating a sense of harmony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unity can enhance the emotional impact and convey the artist's intended ideas or
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use symmetry, pattern, harmony, and proportion to create a sense of
  wholeness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20734-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shape is 2D and flat, whereas form is 3D and relates to the actual or perceived mass
  of an object"""@en ;
  dcterms:modified "2026-06-07T15:30:29.366094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20734-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use shape in our work to create interesting compositions"@en ;
  dcterms:modified "2026-06-07T15:30:29.366098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20734-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sculptures are a 3D form and can be made from a variety of interesting materials"@en ;
  dcterms:modified "2026-06-07T15:30:29.366102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20734-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can build larger forms by using repetition of shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.366108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20741-1
  a curric:KeyLearningPoint ;
  rdfs:label """The creative industry is a broad sector that includes fashion, art, music, film and
  design areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20741-2
  a curric:KeyLearningPoint ;
  rdfs:label """In fashion, designers often begin with a mood board to collect inspiration, colours
  and textures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20741-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fashion silhouettes explore the shape and style of a garment."@en ;
  dcterms:modified "2026-06-07T15:30:29.366428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20741-4
  a curric:KeyLearningPoint ;
  rdfs:label "The fashion industry helps people express identity, culture and style."@en ;
  dcterms:modified "2026-06-07T15:30:29.366432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20741-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fashion can challenge or reinforce stereotypes, especially around gender, body shape
  and culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28651-1
  a curric:KeyLearningPoint ;
  rdfs:label """A refugee is a person who has escaped from their country for political, religious,
  economic reasons or because of war"""@en ;
  dcterms:modified "2026-06-07T15:30:29.366458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28651-2
  a curric:KeyLearningPoint ;
  rdfs:label """By addressing themes of migration, artists discuss issues such as racism and
  inequality"""@en ;
  dcterms:modified "2026-06-07T15:30:29.366462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28651-3
  a curric:KeyLearningPoint ;
  rdfs:label """Art can move us to consider what unites us rather than what divides us through
  exploring people's stories"""@en ;
  dcterms:modified "2026-06-07T15:30:29.366466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21063-1
  a curric:KeyLearningPoint ;
  rdfs:label """Art can bring awareness to social issues from around the world and can be about
  anything."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21063-2
  a curric:KeyLearningPoint ;
  rdfs:label """Art activism can amplify the voices of those who are under represented and anyone
  can be an activist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21063-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition in activism reinforces messages, using techniques and events to amplify
  impact and create change over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20762-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use a range of materials in their painting and this can add layers of
  meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20762-2
  a curric:KeyLearningPoint ;
  rdfs:label """By ripping and collaging we can symbolise memory and the layering of experience in
  paintings"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20762-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using resist techniques with wax or tape can be used as a symbol"@en ;
  dcterms:modified "2026-06-07T15:30:29.371991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20762-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transfer techniques give work a faded, ghostly appearance, evoking themes of memory
  or the passage of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20709-1
  a curric:KeyLearningPoint ;
  rdfs:label """Museums and galleries have a range of artefacts from around the world and often link
  to histories of Empire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20709-2
  a curric:KeyLearningPoint ;
  rdfs:label "Museums are rethinking the ethics behind collections in terms of colonialism."@en ;
  dcterms:modified "2026-06-07T15:30:29.373942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20709-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some indigenous communities are asking for their artefacts to be given back and this
  is known as repatriation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20709-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the original purpose of artefacts is vital as this may differ to how
  they are shown in museum collections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28656-1
  a curric:KeyLearningPoint ;
  rdfs:label "Art can be more powerful than words because it transcends language barriers"@en ;
  dcterms:modified "2026-06-07T15:30:29.385072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28656-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sketching can help process feelings and thoughts, serving as a visual diary"@en ;
  dcterms:modified "2026-06-07T15:30:29.385076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28656-3
  a curric:KeyLearningPoint ;
  rdfs:label """Freeform painting or drawing can provide space to express feelings without judgment
  or expectation"""@en ;
  dcterms:modified "2026-06-07T15:30:29.385080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21061-1
  a curric:KeyLearningPoint ;
  rdfs:label """Collaborative art is when artists and communities working closely together to make
  art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21061-2
  a curric:KeyLearningPoint ;
  rdfs:label "Collaborative art can bring communities together and make connections."@en ;
  dcterms:modified "2026-06-07T15:30:29.385112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21061-3
  a curric:KeyLearningPoint ;
  rdfs:label """Art can be a tool for helping people share experiences, confront challenges, and see
  new possibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20756-1
  a curric:KeyLearningPoint ;
  rdfs:label """Casting is a sculpting process that allow us to create replicas or translate
  modelled sculptures into durable materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20756-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hands-on experimentation with materials fosters a deeper understanding of their
  properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20756-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring different casting methods supports informed choices and more intentional
  outcomes in future projects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21055-1
  a curric:KeyLearningPoint ;
  rdfs:label """Depicting a person in 3D has been done for hundreds of years using materials such as
  marble, clay and stone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21055-2
  a curric:KeyLearningPoint ;
  rdfs:label """Clay is a malleable material and has been used by artists to create portrait
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21055-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clay can be used in many ways and an artist's style can be seen through how they
  manipulate the clay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20751-1
  a curric:KeyLearningPoint ;
  rdfs:label """Perspective is important in technical drawings to show how a building will look from
  a specific viewpoint."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20751-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two key parts of a perspective drawing, the horizon line and vanishing
  point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20751-3
  a curric:KeyLearningPoint ;
  rdfs:label """The key rule is to ensure all parallel lines converge at the correct vanishing
  point(s) on the horizon line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20751-4
  a curric:KeyLearningPoint ;
  rdfs:label "The lines artists use in perspective drawings aren't always tight and precise."@en ;
  dcterms:modified "2026-06-07T15:30:29.393374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29470-1
  a curric:KeyLearningPoint ;
  rdfs:label """A portrait is a representation of a person, usually focusing on their face,
  expression, and identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29470-2
  a curric:KeyLearningPoint ;
  rdfs:label "Portraits are found across art, craft, and design celebrating individuality."@en ;
  dcterms:modified "2026-06-07T15:30:29.393399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29470-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists often use a multidisciplinary approach when creating portraits."@en ;
  dcterms:modified "2026-06-07T15:30:29.393403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20766-1
  a curric:KeyLearningPoint ;
  rdfs:label """Assemblage involves creating a composition by using found materials. It can be seen
  as a 3D collage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20766-2
  a curric:KeyLearningPoint ;
  rdfs:label "Assembling objects together creates a story which can explore our history."@en ;
  dcterms:modified "2026-06-07T15:30:29.393411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20766-3
  a curric:KeyLearningPoint ;
  rdfs:label """By using materials that represent different facets of your life experiences is a
  form of documentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28945-1
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits often reveal how a person looks, but artists can also create portraits
  that conceal their physical appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28945-2
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits can challenge us to look at people from different perspectives rather than
  traditional representations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28945-3
  a curric:KeyLearningPoint ;
  rdfs:label "Negative space portraits can help to reveal other aspects of identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.394466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Playing with materials to express emotions can bring our feelings to the forefront
  of our portraits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20714-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quilting is a method of stitching layers of material together to create a blanket,
  often includes patterns or images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20714-2
  a curric:KeyLearningPoint ;
  rdfs:label """Quilting has been used by artists as a form of activism, to raise awareness about
  social issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20714-3
  a curric:KeyLearningPoint ;
  rdfs:label """Quilting is often collaborative with several people working on a project
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20711-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weaving is a method of making fabric by interlacing two sets of yarns or materials
  at right angles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20711-2
  a curric:KeyLearningPoint ;
  rdfs:label """Weaving is one of the oldest crafts and is practised by various communities
  worldwide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20711-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contemporary artists use different materials to weave, often giving their work
  deeper social or political meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20761-1
  a curric:KeyLearningPoint ;
  rdfs:label """A stimulus is anything that sparks inspiration and helps us to experiment, and
  express concepts or feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20761-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can make different textures and marks, such as drips and splattering, to respond
  to different stimuli."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20761-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can select the technique and medium for an artwork in response to what we aim to
  communicate about a stimulus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20749-1
  a curric:KeyLearningPoint ;
  rdfs:label """Architects gain inspiration from many sources including personal experiences and the
  world around them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Architects play with materials to generate and visualise ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.398766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20749-3
  a curric:KeyLearningPoint ;
  rdfs:label """Architectural designs can be made out of any material that allows the creation of
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20748-1
  a curric:KeyLearningPoint ;
  rdfs:label """Architects make choices about the materials they use and this impacts how a building
  looks and feels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different materials allow architects to create unique designs that push visual and
  structural boundaries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20748-3
  a curric:KeyLearningPoint ;
  rdfs:label """Architectural materials can have eco-friendly properties, enabling sustainable
  building designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20748-4
  a curric:KeyLearningPoint ;
  rdfs:label "Small components can be built up to make larger structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.398970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28498-1
  a curric:KeyLearningPoint ;
  rdfs:label "Western art history can be seperated out into art periods and art movements."@en ;
  dcterms:modified "2026-06-07T15:30:29.423012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28498-2
  a curric:KeyLearningPoint ;
  rdfs:label """Critical thinking is essential in Western art history because of the main issues and
  debates surrounding it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28498-3
  a curric:KeyLearningPoint ;
  rdfs:label """Critical thinking skills can identify connections between artists and artworks such
  as themes, creating shared stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423020Z"^^xsd:dateTime .

