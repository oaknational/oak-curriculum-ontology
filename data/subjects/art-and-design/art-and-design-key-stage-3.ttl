  dcterms:modified "2026-06-07T15:30:02.384602Z"^^xsd:dateTime .

oakcurric:keyword-slab-building
  a curric:Keyword ;
  schema:name "slab building"@en ;
  schema:description """a pottery technique where flat pieces of clay are cut and joined together to
  make shapes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384620Z"^^xsd:dateTime .

oakcurric:keyword-vessel
  a curric:Keyword ;
  schema:name "vessel"@en ;
  schema:description """a container that can hold something, like a bowl, pot, vase or cup. In art,
  vessels can be practical or decorative, and they’re often made using clay in ceramics"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384625Z"^^xsd:dateTime .

oakcurric:keyword-linear-perspective
  a curric:Keyword ;
  schema:name "linear perspective"@en ;
  schema:description """a drawing method used by artists to give the illusion of depth on a 2D
  surface"""@en ;
  dcterms:modified "2026-06-07T15:30:02.384684Z"^^xsd:dateTime .

oakcurric:keyword-construction
  a curric:Keyword ;
  schema:name "construction"@en ;
  schema:description "the act of assembling materials to form a structure or object"@en ;
  dcterms:modified "2026-06-07T15:30:02.385971Z"^^xsd:dateTime .

oakcurric:keyword-cross-hatching
  a curric:Keyword ;
  schema:name "cross-hatching"@en ;
  schema:description "drawing lines that cross over each other and are placed close together"@en ;
  dcterms:modified "2026-06-07T15:30:02.386136Z"^^xsd:dateTime .

oakcurric:keyword-symbolic
  a curric:Keyword ;
  schema:name "symbolic"@en ;
  schema:description """representing something beyond its literal meaning, often used to convey
  deeper or abstract concepts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386467Z"^^xsd:dateTime .

oakcurric:keyword-line-weight
  a curric:Keyword ;
  schema:name "line weight"@en ;
  schema:description "the thickness or thinness of a line"@en ;
  dcterms:modified "2026-06-07T15:30:02.386510Z"^^xsd:dateTime .

oakcurric:keyword-contour
  a curric:Keyword ;
  schema:name "contour"@en ;
  schema:description "the line outlining a shape or form, like an outline"@en ;
  dcterms:modified "2026-06-07T15:30:02.386514Z"^^xsd:dateTime .

oakcurric:keyword-chiaroscuro
  a curric:Keyword ;
  schema:name "chiaroscuro"@en ;
  schema:description """the use of strong contrasts between light and dark to create depth and drama
  in a drawing or painting"""@en ;
  dcterms:modified "2026-06-07T15:30:02.386933Z"^^xsd:dateTime .

oakcurric:keyword-weaveweaving
  a curric:Keyword ;
  schema:name "weave/weaving"@en ;
  schema:description "joining threads by passing them over and under each other"@en ;
  dcterms:modified "2026-06-07T15:30:02.387050Z"^^xsd:dateTime .

oakcurric:keyword-warp-weft
  a curric:Keyword ;
  schema:name "warp & weft"@en ;
  schema:description "warp threads go up and down; weft threads go across"@en ;
  dcterms:modified "2026-06-07T15:30:02.387054Z"^^xsd:dateTime .

oakcurric:keyword-loom
  a curric:Keyword ;
  schema:name "loom"@en ;
  schema:description """a frame that holds threads tight so you can weave them into patterns or
  fabric."""@en ;
  dcterms:modified "2026-06-07T15:30:02.387059Z"^^xsd:dateTime .

oakcurric:keyword-reductive-monoprint
  a curric:Keyword ;
  schema:name "reductive monoprint"@en ;
  schema:description """a one-off printmaking method where ink is rolled on to a surface, then
  removed before paper is placed on top and a print taken"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387273Z"^^xsd:dateTime .

oakcurric:keyword-status
  a curric:Keyword ;
  schema:name "status"@en ;
  schema:description "a person’s level of importance, rank, or social standing"@en ;
  dcterms:modified "2026-06-07T15:30:02.387471Z"^^xsd:dateTime .

oakcurric:keyword-pose
  a curric:Keyword ;
  schema:name "pose"@en ;
  schema:description """the way someone stands or sits, especially in to show a certain feeling,
  attitude, or idea"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387475Z"^^xsd:dateTime .

oakcurric:keyword-gaze
  a curric:Keyword ;
  schema:name "gaze"@en ;
  schema:description """how the subject’s eyes are directed—whether they are looking directly at the
  viewer, or in a different direction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387480Z"^^xsd:dateTime .

oakcurric:keyword-family
  a curric:Keyword ;
  schema:name "family"@en ;
  schema:description """family means the people who care for us, support us, and help us feel safe,
  whether related by blood, by choice, or by circumstance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.387749Z"^^xsd:dateTime .

oakcurric:keyword-intuitive
  a curric:Keyword ;
  schema:name "intuitive"@en ;
  schema:description """creating without a set plan, making choices based on feeling, instinct, or
  the mood of the moment."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389626Z"^^xsd:dateTime .

oakcurric:keyword-define
  a curric:Keyword ;
  schema:name "define"@en ;
  schema:description """to make something clearer or more detailed, often by adding lines, shapes,
  or contrast to show its form."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389630Z"^^xsd:dateTime .

oakcurric:keyword-dry-materials
  a curric:Keyword ;
  schema:name "dry materials"@en ;
  schema:description """art materials that do not need water or liquid to work. They are used for
  drawing, shading and mark-making directly onto a surface."""@en ;
  dcterms:modified "2026-06-07T15:30:02.389635Z"^^xsd:dateTime .

oakcurric:keyword-functional
  a curric:Keyword ;
  schema:name "functional"@en ;
  schema:description "designed to be practical and useful rather than simply attractive"@en ;
  dcterms:modified "2026-06-07T15:30:02.389657Z"^^xsd:dateTime .

oakcurric:keyword-drypoint
  a curric:Keyword ;
  schema:name "drypoint"@en ;
  schema:description "a printing process where a sharp object is used to draw into a plate"@en ;
  dcterms:modified "2026-06-07T15:30:02.389662Z"^^xsd:dateTime .

oakcurric:keyword-mirror-image
  a curric:Keyword ;
  schema:name "mirror image"@en ;
  schema:description """an image or object which is identical in form to another, but with the
  structure reversed"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389666Z"^^xsd:dateTime .

oakcurric:keyword-conceal
  a curric:Keyword ;
  schema:name "Conceal"@en ;
  schema:description "prevent something from being seen"@en ;
  dcterms:modified "2026-06-07T15:30:02.389698Z"^^xsd:dateTime .

oakcurric:keyword-bust
  a curric:Keyword ;
  schema:name "bust"@en ;
  schema:description "a sculpted or cast representation of a human head and neck"@en ;
  dcterms:modified "2026-06-07T15:30:02.389721Z"^^xsd:dateTime .

oakcurric:keyword-adornment
  a curric:Keyword ;
  schema:name "adornment"@en ;
  schema:description "decorating the body to express who we are"@en ;
  dcterms:modified "2026-06-07T15:30:02.389953Z"^^xsd:dateTime .

oakcurric:keyword-interior
  a curric:Keyword ;
  schema:name "interior"@en ;
  schema:description "the inside of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.390002Z"^^xsd:dateTime .

oakcurric:keyword-interior-design
  a curric:Keyword ;
  schema:name "interior design"@en ;
  schema:description """the art or process of designing the interior decoration of a room or
  building."""@en ;
  dcterms:modified "2026-06-07T15:30:02.390618Z"^^xsd:dateTime .

oakcurric:keyword-reveal
  a curric:Keyword ;
  schema:name "Reveal"@en ;
  schema:description """When an artist intentionally shares aspects of identity, history, or
  emotions through choices in their work."""@en ;
  dcterms:modified "2026-06-07T15:30:02.390643Z"^^xsd:dateTime .

oakcurric:keyword-thought-provoking
  a curric:Keyword ;
  schema:name "thought-provoking"@en ;
  schema:description """something that makes you think deeply or consider new ideas. You could hear
  or see something that gets you wondering or asking questions, maybe even challenging what
  you already know or believe."""@en ;
  dcterms:modified "2026-06-07T15:30:02.390827Z"^^xsd:dateTime .

oakcurric:keyword-microplastics
  a curric:Keyword ;
  schema:name "microplastics"@en ;
  schema:description "tiny particles of plastic, made from big plastic things breaking down"@en ;
  dcterms:modified "2026-06-07T15:30:02.390991Z"^^xsd:dateTime .

oakcurric:keyword-implied
  a curric:Keyword ;
  schema:name "implied"@en ;
  schema:description """suggested or shown indirectly, not actually there but made to look like it
  is"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391006Z"^^xsd:dateTime .

oakcurric:keyword-impress
  a curric:Keyword ;
  schema:name "impress"@en ;
  schema:description """in art, to press a tool, object, or texture into a soft material (like clay)
  to leave a mark or pattern"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391010Z"^^xsd:dateTime .

oakcurric:keyword-influences
  a curric:Keyword ;
  schema:name "influences"@en ;
  schema:description """in art refer to the factors that shape and inspire an artist's creative
  choices, style, and overall artistic voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391156Z"^^xsd:dateTime .

oakcurric:keyword-mistakes
  a curric:Keyword ;
  schema:name "mistakes"@en ;
  schema:description """in art can be an opportunity for discovery and growth, often leading to
  unexpected and innovative results"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391161Z"^^xsd:dateTime .

oakcurric:keyword-reduction-print
  a curric:Keyword ;
  schema:name "reduction print"@en ;
  schema:description """a printmaking technique where the plate is carved between each layer,
  reducing the printing surface with each stage"""@en ;
  dcterms:modified "2026-06-07T15:30:02.391371Z"^^xsd:dateTime .

oakcurric:keyword-depict
  a curric:Keyword ;
  schema:name "depict"@en ;
  schema:description "to portray in a picture or to describe in writing."@en ;
  dcterms:modified "2026-06-07T15:30:02.392738Z"^^xsd:dateTime .

oakcurric:keyword-freestanding
  a curric:Keyword ;
  schema:name "freestanding"@en ;
  schema:description """a structure that stays upright without support from walls or other
  objects"""@en ;
  dcterms:modified "2026-06-07T15:30:02.393064Z"^^xsd:dateTime .

oakcurric:keyword-origami
  a curric:Keyword ;
  schema:name "origami"@en ;
  schema:description """the art of folding paper into different shapes or figures, like animals or
  objects, without cutting or using glue"""@en ;
  dcterms:modified "2026-06-07T15:30:02.393700Z"^^xsd:dateTime .

oakcurric:keyword-crest
  a curric:Keyword ;
  schema:name "crest"@en ;
  schema:description "a symbol or design that represents a family, group, or community"@en ;
  dcterms:modified "2026-06-07T15:30:02.394031Z"^^xsd:dateTime .

oakcurric:keyword-photomontage
  a curric:Keyword ;
  schema:name "photomontage"@en ;
  schema:description """an artwork made by combining different photographs into a single
  composition"""@en ;
  dcterms:modified "2026-06-07T15:30:02.394121Z"^^xsd:dateTime .

oakcurric:keyword-diorama
  a curric:Keyword ;
  schema:name "diorama"@en ;
  schema:description "a three-dimensional miniature model or scene"@en ;
  dcterms:modified "2026-06-07T15:30:02.394126Z"^^xsd:dateTime .

oakcurric:keyword-brief
  a curric:Keyword ;
  schema:name "brief"@en ;
  schema:description """a set of instructions or goals for a project that guides the design
  process."""@en ;
  dcterms:modified "2026-06-07T15:30:02.394651Z"^^xsd:dateTime .

oakcurric:keyword-sampler
  a curric:Keyword ;
  schema:name "sampler"@en ;
  schema:description "fabric or material used to practise or demonstrate stitches on"@en ;
  dcterms:modified "2026-06-07T15:30:02.395425Z"^^xsd:dateTime .

oakcurric:keyword-stitch
  a curric:Keyword ;
  schema:name "stitch"@en ;
  schema:description "the basic movement of thread through fabric to make a design or join"@en ;
  dcterms:modified "2026-06-07T15:30:02.395431Z"^^xsd:dateTime .

oakcurric:keyword-block-printing
  a curric:Keyword ;
  schema:name "block printing"@en ;
  schema:description "a method for printing with an inked block, such as a stamp."@en ;
  dcterms:modified "2026-06-07T15:30:02.395786Z"^^xsd:dateTime .

oakcurric:keyword-relief-print
  a curric:Keyword ;
  schema:name "relief print"@en ;
  schema:description """a printmaking technique where the design to be inked is raised above the
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:02.395791Z"^^xsd:dateTime .

oakcurric:keyword-fashion
  a curric:Keyword ;
  schema:name "fashion"@en ;
  schema:description """the popular style of clothing, accessories, or appearance at a particular
  time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396632Z"^^xsd:dateTime .

oakcurric:keyword-amplify
  a curric:Keyword ;
  schema:name "amplify"@en ;
  schema:description """to make something stronger, louder, or more noticeable. For example, if you
  amplify an idea or message, you make it more powerful or easier for people to notice or
  understand."""@en ;
  dcterms:modified "2026-06-07T15:30:02.396650Z"^^xsd:dateTime .

oakcurric:keyword-critical-thinking
  a curric:Keyword ;
  schema:name "critical thinking"@en ;
  schema:description """thinking carefully and logically about something to figure out the best
  solution or answer"""@en ;
  dcterms:modified "2026-06-07T15:30:02.399762Z"^^xsd:dateTime .

oakcurric:keyword-doodle
  a curric:Keyword ;
  schema:name "doodle"@en ;
  schema:description """a casual, aimless drawing or pattern made while thinking about something
  else"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401253Z"^^xsd:dateTime .

oakcurric:keyword-participants
  a curric:Keyword ;
  schema:name "participants"@en ;
  schema:description "people who take part in an activity, event, or competition"@en ;
  dcterms:modified "2026-06-07T15:30:02.401280Z"^^xsd:dateTime .

oakcurric:keyword-undercut
  a curric:Keyword ;
  schema:name "undercut"@en ;
  schema:description """a part of the mould that curves around the object or cast in a way that
  makes it hard to remove the object from the mould. It can trap the cast inside the mould
  if not designed carefully"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402543Z"^^xsd:dateTime .

oakcurric:keyword-perspective-drawing
  a curric:Keyword ;
  schema:name "perspective drawing"@en ;
  schema:description """a technique used to show depth and space by making objects appear smaller as
  they get further away"""@en ;
  dcterms:modified "2026-06-07T15:30:02.402989Z"^^xsd:dateTime .

oakcurric:keyword-found-objects
  a curric:Keyword ;
  schema:name "found objects"@en ;
  schema:description """items that are not designed for the purpose of making art, but have been
  collected from more random sources"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403003Z"^^xsd:dateTime .

oakcurric:keyword-positive-space
  a curric:Keyword ;
  schema:name "positive space"@en ;
  schema:description "the area occupied by the main subject"@en ;
  dcterms:modified "2026-06-07T15:30:02.403413Z"^^xsd:dateTime .

oakcurric:keyword-quilting
  a curric:Keyword ;
  schema:name "quilting"@en ;
  schema:description """is a method of stitching layers of material together to create a blanket,
  often includes patterns or images"""@en ;
  dcterms:modified "2026-06-07T15:30:02.403435Z"^^xsd:dateTime .

oakcurric:keyword-subversive
  a curric:Keyword ;
  schema:name "subversive"@en ;
  schema:description "the practice of challenging traditional ideas or social norms"@en ;
  dcterms:modified "2026-06-07T15:30:02.403440Z"^^xsd:dateTime .

oakcurric:keyword-weaving
  a curric:Keyword ;
  schema:name "weaving"@en ;
  schema:description "the process of making fabric by interlocking two sets of yarn or threads"@en ;
  dcterms:modified "2026-06-07T15:30:02.403483Z"^^xsd:dateTime .

oakcurric:keyword-warp
  a curric:Keyword ;
  schema:name "warp"@en ;
  schema:description "vertical threads that run up and down in weaving"@en ;
  dcterms:modified "2026-06-07T15:30:02.403489Z"^^xsd:dateTime .

oakcurric:keyword-weft
  a curric:Keyword ;
  schema:name "weft"@en ;
  schema:description "horizontal threads that run up and down in weaving"@en ;
  dcterms:modified "2026-06-07T15:30:02.403494Z"^^xsd:dateTime .

oakcurric:keyword-western-art-history
  a curric:Keyword ;
  schema:name "Western art history"@en ;
  schema:description """the study of how art has changed over time in continental Europe and North
  America"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410152Z"^^xsd:dateTime .

oakcurric:keyword-appropriation
  a curric:Keyword ;
  schema:name "appropriation"@en ;
  schema:description """when an artist takes elements from another culture without understanding,
  respecting, or giving credit to it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410157Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-once-print-made-its-finished
  a curric:Misconception ;
  curric:statement "Once a print is made, it’s finished, and no further changes can be made."@en ;
  curric:correction """Prints can be developed further using mixed media and physical alterations
  like cutting. The process of refining a print is an important step to enhance visual
  interest and highlight specific areas, creativity doesn't stop after the initial print!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.093110Z"^^xsd:dateTime .

oakcurric:misconception-animals-universially-known-specific-charatristics
  a curric:Misconception ;
  curric:statement """Animals are universially known for specific charatristics across all
  cultures."""@en ;
  curric:correction """Often how animals are linked to charateristics in the West is very different
  that other cultures across the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094454Z"^^xsd:dateTime .

oakcurric:misconception-art-created-hands
  a curric:Misconception ;
  curric:statement "Art must be created with the hands."@en ;
  curric:correction """Art is for everyone whatever their circumstances and is not always created
  through using hands. Artists can create art in innovative ways without using hands. Art is
  a way for all of humanity to express their viewpoints and diverse experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094465Z"^^xsd:dateTime .

oakcurric:misconception-artists-make-art-intention-sharing
  a curric:Misconception ;
  curric:statement "All artists make art with the intention of sharing with an audience."@en ;
  curric:correction """Some art is made as an act of pure self-expression. Even deeply personal
  works are shaped by history, identity, and society, meaning they can take on wider
  meanings even if the artist did not intend them to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095697Z"^^xsd:dateTime .

oakcurric:misconception-food-eating-cannot-used-art
  a curric:Misconception ;
  curric:statement "Food is only for eating and cannot be used as an art medium."@en ;
  curric:correction """Food can be used as an art medium because it evokes the senses and carries
  deep cultural and emotional meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095776Z"^^xsd:dateTime .

oakcurric:misconception-memories-accurate-unchanging
  a curric:Misconception ;
  curric:statement "Memories are always accurate and unchanging."@en ;
  curric:correction """A common misconception about memories is that they are perfect and unchanging
  when in reality, memories can be inaccurate, influenced by emotions and change over time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095795Z"^^xsd:dateTime .

oakcurric:misconception-memories-cannot-used-express-persons
  a curric:Misconception ;
  curric:statement "Memories cannot be used to express a person's identity"@en ;
  curric:correction """Memories play a key role in shaping who we are as they help us understand our
  past, influence how we view ourselves and guide how we express our identity over time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096897Z"^^xsd:dateTime .

oakcurric:misconception-artists-inspired-nature-look-carefully
  a curric:Misconception ;
  curric:statement """Artists inspired by nature can only look carefully at natural forms and record
  them."""@en ;
  curric:correction "Artists can make art in and with nature as well as recording from nature."@en ;
  dcterms:modified "2026-06-07T15:30:15.097389Z"^^xsd:dateTime .

oakcurric:misconception-artworks-causes-created-warn-audiences
  a curric:Misconception ;
  curric:statement "All artworks about causes are created to warn audiences."@en ;
  curric:correction """There are many reasons why artists make artworks about causes including to
  bring joy, to celebrate and to inspire hope."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097807Z"^^xsd:dateTime .

oakcurric:misconception-paintings-made-paint-brushes
  a curric:Misconception ;
  curric:statement "All paintings are made with paint brushes."@en ;
  curric:correction """Using different types of tools helps abstract artists create lots of
  different types of expressive marks and textures in their work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099508Z"^^xsd:dateTime .

oakcurric:misconception-complex-images-shapes-create-associations
  a curric:Misconception ;
  curric:statement "Only complex images or shapes can create associations."@en ;
  curric:correction "Simple images or shapes can create associations to themes or ideas."@en ;
  dcterms:modified "2026-06-07T15:30:15.099561Z"^^xsd:dateTime .

oakcurric:misconception-architects-consider-one-building-wider
  a curric:Misconception ;
  curric:statement "Architects only consider one building, not the wider area."@en ;
  curric:correction """Architects consider the built environment, the local area's history and needs
  and think outside the box to create connections between communities in their work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099585Z"^^xsd:dateTime .

oakcurric:misconception-composition-used-one-way-express
  a curric:Misconception ;
  curric:statement "Composition is only used in one way to express realistic images."@en ;
  curric:correction """Composition is used by artists in many ways, and how composition is used can
  change across cultures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101665Z"^^xsd:dateTime .

oakcurric:misconception-art-connects-people-everyone-understands
  a curric:Misconception ;
  curric:statement "Art only connects people if everyone understands it the same way."@en ;
  curric:correction """Art connects people because it sparks emotions and ideas, even if everyone
  sees it differently. It’s the shared experience, not exact understanding, that brings
  people together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101671Z"^^xsd:dateTime .

oakcurric:misconception-rhythm-another-way-saying-pattern
  a curric:Misconception ;
  curric:statement "Rhythm is just another way of saying pattern"@en ;
  curric:correction """Rhythm is a visual beat that utilises pattern and repetition across an
  artwork to direct your eye across the work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101713Z"^^xsd:dateTime .

oakcurric:misconception-buildings-rectangular-shape-pitched-roofs
  a curric:Misconception ;
  curric:statement """Buildings are all rectangular in shape with pitched roofs and walls the same
  colour."""@en ;
  curric:correction """Buildings are made in lots of different shapes and sizes, and are often
  decorated in ways that are personal to their communities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101741Z"^^xsd:dateTime .

oakcurric:misconception-words-dont-matter-much-its
  a curric:Misconception ;
  curric:statement "Words don’t matter that much — it’s the drawing that tells the story."@en ;
  curric:correction """Words can express things a face alone might not show — like beliefs,
  experiences, or emotions. The style of the text also adds meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101750Z"^^xsd:dateTime .

oakcurric:misconception-abstract-art-easy-create
  a curric:Misconception ;
  curric:statement "Abstract art is easy to create."@en ;
  curric:correction """Abstract art does not try to show things as they look in real life. Instead,
  it focuses on expressing emotions, ideas, or movement which is not an easy task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101755Z"^^xsd:dateTime .

oakcurric:misconception-tie-dye-modern-european-technique
  a curric:Misconception ;
  curric:statement "Tie-dye is a modern European technique"@en ;
  curric:correction """Tie-dye or similar forms, such as Bandhani from India, originates from many
  different regions around the world and exists in multiple forms and styles. Tie-dye is a
  global textile technique that has existed for thousands of years."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101853Z"^^xsd:dateTime .

oakcurric:misconception-new-ways-inspired-nature
  a curric:Misconception ;
  curric:statement "There are no new ways to be inspired by nature."@en ;
  curric:correction "We can all find new things that inspire us in the world around us."@en ;
  dcterms:modified "2026-06-07T15:30:15.102864Z"^^xsd:dateTime .

oakcurric:misconception-surface-carved-deeply-layers-glued
  a curric:Misconception ;
  curric:statement "If the surface is carved too deeply, layers can be glued back on later."@en ;
  curric:correction """Soap is a soft material, and carving too deeply can cause unintended
  breakage. It’s important to carve in gradual layers, starting with rough shaping before
  adding finer details."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102968Z"^^xsd:dateTime .

oakcurric:misconception-appliqu-form-decorating-fabric-connection
  a curric:Misconception ;
  curric:statement """Appliqué is just a form of decorating fabric and has no connection to colour
  or culture."""@en ;
  curric:correction """Appliqué goes beyond just decorating fabric, it's a powerful form of art that
  can reflect cultural heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102974Z"^^xsd:dateTime .

oakcurric:misconception-art-made-one-artist-working
  a curric:Misconception ;
  curric:statement "Art can only be made by one artist, working alone."@en ;
  curric:correction """Art can be a collaborative process. When artists collaborate, they work
  together to communicate common meanings or achieve common goals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103317Z"^^xsd:dateTime .

oakcurric:misconception-art-movements-came-isolation-world
  a curric:Misconception ;
  curric:statement "Art movements came about in isolation from the world around them."@en ;
  curric:correction "Art movements are often impacted by changes in the world around them."@en ;
  dcterms:modified "2026-06-07T15:30:15.103323Z"^^xsd:dateTime .

oakcurric:misconception-street-art-primarily-illegal-activity
  a curric:Misconception ;
  curric:statement "Street art is primarily an illegal activity or act of vandalism."@en ;
  curric:correction """Street art is a legitimate and powerful form of artistic expression that
  addresses important social issues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103348Z"^^xsd:dateTime .

oakcurric:misconception-repeated-pattern-same-shape-copied
  a curric:Misconception ;
  curric:statement "A repeated pattern is just the same shape copied over and over again."@en ;
  curric:correction """While repeating the same shape is one way to create a pattern, artists and
  designers use a variety of methods to make repeated patterns more dynamic, engaging and
  sophisticated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103354Z"^^xsd:dateTime .

oakcurric:misconception-artists-respond-events-document-point
  a curric:Misconception ;
  curric:statement """When artists respond to events, they always do so to document that point in
  history."""@en ;
  curric:correction """There are many ways and reasons why artists respond to events. One of these
  can be to document that point in history but they can also do so to express their
  opinions, be a powerful voice for marginalised groups and to help fight for justice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103418Z"^^xsd:dateTime .

oakcurric:misconception-iconic-images-come-across-areas
  a curric:Misconception ;
  curric:statement "Iconic images come from across all areas of art history."@en ;
  curric:correction """Iconic images mainly come from Western art history which can mean that the
  diversity of our world is often not reflected."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103602Z"^^xsd:dateTime .

oakcurric:misconception-set-designers-work-theatre-film
  a curric:Misconception ;
  curric:statement "Set designers work only in theatre and film."@en ;
  curric:correction """Set design is used in many different contexts, including theatre, film,
  fashion, art and music."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103826Z"^^xsd:dateTime .

oakcurric:misconception-main-role-graphic-designers-make
  a curric:Misconception ;
  curric:statement """The main role of graphic designers is to make work that is pleasing to the
  viewer’s eye."""@en ;
  curric:correction """Many graphic designers push traditional boundaries and shift the focus from
  creating purely aesthetically pleasing works to communicating messages about social
  justice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104161Z"^^xsd:dateTime .

oakcurric:misconception-depth-created-realistic-scene-realistic
  a curric:Misconception ;
  curric:statement "Depth can only be created in a realistic scene or in a realistic way."@en ;
  curric:correction """Depth can be entirely imaginary or realistic. Artists can manipulate elements
  to create the illusion of shapes, colours and lines standing out or recessing in an image."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104457Z"^^xsd:dateTime .

oakcurric:misconception-architecture-plain-without-details
  a curric:Misconception ;
  curric:statement "Architecture is plain and without details."@en ;
  curric:correction """Architects use many different patterns in their designs, both literal
  patterns and patterns through their use of form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104483Z"^^xsd:dateTime .

oakcurric:misconception-drawing-replica-looked
  a curric:Misconception ;
  curric:statement "Drawing has to be a replica of what is being looked at."@en ;
  curric:correction """Drawing can be detailed and replicate an object, but it can also be many
  other things. Artists often play with techniques and process to try out different ways of
  exploring drawing and this can lead to experimental and exciting discoveries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104563Z"^^xsd:dateTime .

oakcurric:misconception-design-making-things-made
  a curric:Misconception ;
  curric:statement "Design is about making things that have never been made before."@en ;
  curric:correction """Design is about planning and making something. It doesn’t need to be
  something that has never been done before, it can be to improve an existing object to make
  it work or look better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104965Z"^^xsd:dateTime .

oakcurric:misconception-manifestos-communicated-text
  a curric:Misconception ;
  curric:statement "Manifestos are always communicated through text."@en ;
  curric:correction """In art, manifestos don’t need to be written but can be multidisciplinary in
  their approach."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104971Z"^^xsd:dateTime .

oakcurric:misconception-printed-textile-mass-production
  a curric:Misconception ;
  curric:statement "Printed textile is only for mass production."@en ;
  curric:correction """Printed textiles can be produced in limited quantities or even one-of-a-kind
  pieces."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105376Z"^^xsd:dateTime .

oakcurric:misconception-your-future-identity-completely-determined
  a curric:Misconception ;
  curric:statement "Your future identity is completely determined by your family roots."@en ;
  curric:correction """A common misconception is thinking your family roots completely decide who
  you are, without any chance to grow or change. In truth, your identity is shaped by both
  your roots and your own experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105672Z"^^xsd:dateTime .

oakcurric:misconception-collage-set-process-cannot-modified
  a curric:Misconception ;
  curric:statement "Collage is a set process that cannot be modified or refined."@en ;
  curric:correction """Collage is a flexible process. Rearranging elements helps refine ideas and
  create a stronger final piece. Professional artists often make changes mid-process to
  improve composition and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105683Z"^^xsd:dateTime .

oakcurric:misconception-collage-sticking-random-images-together
  a curric:Misconception ;
  curric:statement "Collage is just about sticking random images together."@en ;
  curric:correction """Collage is about careful selection, layering and composition to create
  meaning, tell stories, represent identity and explore social themes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105720Z"^^xsd:dateTime .

oakcurric:misconception-proportions-set-rules-apply
  a curric:Misconception ;
  curric:statement "Proportions are set rules and always apply"@en ;
  curric:correction """Proportions are relative to the unique form you are observing. They relate to
  the different sizes of the different parts but may be different for each person, place or
  object"""@en ;
  dcterms:modified "2026-06-07T15:30:15.106471Z"^^xsd:dateTime .

oakcurric:misconception-asymmetrical-designs-dont-balance
  a curric:Misconception ;
  curric:statement "Asymmetrical designs don't balance."@en ;
  curric:correction """Asymmetrical designs can use visual weight to create a type of balance even
  if the work is different on both sides."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106479Z"^^xsd:dateTime .

oakcurric:misconception-mark-making-needed-abstract-work
  a curric:Misconception ;
  curric:statement "Mark-making is only needed in abstract work."@en ;
  curric:correction """Artists use different marks to express emotions, create mood, and bring their
  artwork to life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106532Z"^^xsd:dateTime .

oakcurric:misconception-artists-work-one-discipline
  a curric:Misconception ;
  curric:statement "Artists work in one discipline."@en ;
  curric:correction "Artists can make art using many different disciplines."@en ;
  dcterms:modified "2026-06-07T15:30:15.107470Z"^^xsd:dateTime .

oakcurric:misconception-social-action-art-make-tangible
  a curric:Misconception ;
  curric:statement "Social action art must always make tangible improvements to an issue."@en ;
  curric:correction """Social action art might make tangible improvements to an issue but might
  focus instead on sparking conversation or raising awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107986Z"^^xsd:dateTime .

oakcurric:misconception-fashion-design-solely-trends-superficial
  a curric:Misconception ;
  curric:statement "Fashion design is solely about trends and superficial appearances."@en ;
  curric:correction """Fashion design is more than trends; it can challenge our understanding of
  fashion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108009Z"^^xsd:dateTime .

oakcurric:misconception-prints-look-exactly-same-time
  a curric:Misconception ;
  curric:statement "Prints look exactly the same each time you repeat them."@en ;
  curric:correction """No two prints are exactly alike, even if they come from the same plate or
  block. Factors like pressure, ink distribution, and the surface it’s printed on can make
  each print slightly different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109052Z"^^xsd:dateTime .

oakcurric:misconception-tataki-zome-hammer-leaves-flowers
  a curric:Misconception ;
  curric:statement """In Tataki-zome, you should hammer the leaves and flowers as hard as possible
  to get the best results."""@en ;
  curric:correction """Hammering too hard can damage the fabric or crush the plant too much, causing
  it to bleed or smudge. In Tataki-zome, it’s important to tap gently and evenly so the
  natural colours and delicate shapes of the plants transfer clearly and beautifully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109452Z"^^xsd:dateTime .

oakcurric:misconception-maps-art-literal
  a curric:Misconception ;
  curric:statement "Maps in art are literal,"@en ;
  curric:correction """Artists might use mapping through literal geography, map-like work or more
  abstract or subjective representations of movement, memory, and relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109631Z"^^xsd:dateTime .

oakcurric:misconception-art-war-mainly-glorifies-violence
  a curric:Misconception ;
  curric:statement "Art about war mainly glorifies violence or heroism."@en ;
  curric:correction """Much art inspired by war actually critiques violence, depicts the horrors of
  war, and emphasises the human cost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109836Z"^^xsd:dateTime .

oakcurric:misconception-artists-work-alone-create-their
  a curric:Misconception ;
  curric:statement "Artists always work alone to create their art."@en ;
  curric:correction """Many artists collaborate with others, work in teams, or invite the community
  to be part of the process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109844Z"^^xsd:dateTime .

oakcurric:misconception-artwork-employ-variety-needs-overwhelming
  a curric:Misconception ;
  curric:statement "For artwork to employ variety, it needs to be overwhelming or not unified."@en ;
  curric:correction """Artwork that employs variety can do so in a unified way to still create work
  that is cohesive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110839Z"^^xsd:dateTime .

oakcurric:misconception-sculptures-heavy-strong-objects-fully
  a curric:Misconception ;
  curric:statement "Sculptures have to be heavy, strong objects which are fully free standing."@en ;
  curric:correction """Some sculptures are delicate and light. Sculptural works can be presented in
  a range of ways including hung, free standing, stacked or in relief."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110846Z"^^xsd:dateTime .

oakcurric:misconception-puppets-used-childrens-entertainment
  a curric:Misconception ;
  curric:statement "Puppets are only used for children's entertainment."@en ;
  curric:correction """Different cultures use puppets to tell important stories, share cultural
  traditions, perform rituals, and even address social or political issues. Puppets can
  express powerful ideas and emotions, not just for fun but also to convey deeper messages."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110866Z"^^xsd:dateTime .

oakcurric:misconception-clay-work-making-vessel-perfectly
  a curric:Misconception ;
  curric:statement """Clay work is only about making a vessel which is perfectly symmetrical and
  with a uniform form."""@en ;
  curric:correction """Clay is expressive! It doesn't have to be perfectly symmetrical or realistic.
  Many artists use bold designs, patterns, and personal storytelling in their work,
  imperfections add character and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110892Z"^^xsd:dateTime .

oakcurric:misconception-two-point-perspective-lines-dont
  a curric:Misconception ;
  curric:statement """In two point perspective, some lines don't need to recede to the vanishing
  point"""@en ;
  curric:correction """All lines recede to one of the vanishing points. Otherwise your drawing won't
  be realistic"""@en ;
  dcterms:modified "2026-06-07T15:30:15.110932Z"^^xsd:dateTime .

oakcurric:misconception-art-something-instantly-recognise-physically
  a curric:Misconception ;
  curric:statement """Art should be something we instantly recognise and physically last a long
  time."""@en ;
  curric:correction """Art may not be a recognisable image and may exist only in a specific
  timeframe."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112912Z"^^xsd:dateTime .

oakcurric:misconception-printmaking-making-copies-creativity
  a curric:Misconception ;
  curric:statement "Printmaking is only about making copies, not about creativity."@en ;
  curric:correction """Printmaking is a form of artistic expression, artists can use printmaking to
  create unique, creative works where textures, colours, and styles can vary greatly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112918Z"^^xsd:dateTime .

oakcurric:misconception-line-used-drawing
  a curric:Misconception ;
  curric:statement "Line is only used for drawing."@en ;
  curric:correction """Artists create and apply lines in a multitude of ways across different
  mediums including sculpture and painting, as well as in drawing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113374Z"^^xsd:dateTime .

oakcurric:misconception-weaving-simply-way-creating-fabric
  a curric:Misconception ;
  curric:statement """Weaving is simply a way of creating fabric for clothing and has no connection
  to colour or culture."""@en ;
  curric:correction """Weaving goes beyond just making fabric; it’s a powerful form of art that can
  reflect cultural heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113896Z"^^xsd:dateTime .

oakcurric:misconception-types-monoprinting-follow-exact-same
  a curric:Misconception ;
  curric:statement "All types of monoprinting follow the exact same process."@en ;
  curric:correction """There are a number of methods for monoprinting that have different steps and
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114110Z"^^xsd:dateTime .

oakcurric:misconception-making-portrait-means-painting-face
  a curric:Misconception ;
  curric:statement "Making a portrait always means painting a face."@en ;
  curric:correction """Artists use paper, cardboard, silhouettes and even walls to create bold,
  powerful and expressive figures. You do not need to only paint a face to create a
  portrait."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114430Z"^^xsd:dateTime .

oakcurric:misconception-pets-part-family-because-animals
  a curric:Misconception ;
  curric:statement "Pets are not part of a family because they are animals."@en ;
  curric:correction """Many people give their pets names, celebrate their birthdays, and care for
  them every day. Pets can be part of the family."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114688Z"^^xsd:dateTime .

oakcurric:misconception-common-misconception-murals-decorative
  a curric:Misconception ;
  curric:statement "A common misconception about murals is that they are only decorative."@en ;
  curric:correction "They often carry powerful social, cultural, or political messages."@en ;
  dcterms:modified "2026-06-07T15:30:15.114697Z"^^xsd:dateTime .

oakcurric:misconception-add-layers-painting-paint
  a curric:Misconception ;
  curric:statement "You should only add layers to a painting with paint."@en ;
  curric:correction """Dry materials can be used in a variety of ways to add detail and shading to
  an art work. Dry materials can be layered over the top of wet materials once dried.
  Examples include pastel over watercolour or pen over dried ink washes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115968Z"^^xsd:dateTime .

oakcurric:misconception-craft-making-functional-objects-less
  a curric:Misconception ;
  curric:statement """Craft is only about making functional objects and is less important than Fine
  Art."""@en ;
  curric:correction """Craft is the creation of objects and artworks requiring both artistry and
  technical skill. It includes both functional and non-functional items and embraces
  contributions from all genders and communities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115980Z"^^xsd:dateTime .

oakcurric:misconception-printmaking-requires-use-specialist-equipment
  a curric:Misconception ;
  curric:statement "Printmaking requires the use of specialist equipment to be successful."@en ;
  curric:correction """High quality printing making can be achieved using a range of domestic
  materials and equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115985Z"^^xsd:dateTime .

oakcurric:misconception-lines-create-edge-dont-create
  a curric:Misconception ;
  curric:statement "Lines create an edge but they don't create volume."@en ;
  curric:correction """Contour lines and directional hatching lines can be used to describe the
  volume of a 3D object in a 2D drawing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116031Z"^^xsd:dateTime .

oakcurric:misconception-body-adornment-appearance-fashion-trends
  a curric:Misconception ;
  curric:statement "Body adornment is only about appearance or fashion trends."@en ;
  curric:correction """Body adornment often holds deep cultural, religious, or personal meaning. It
  can express identity, heritage, beliefs, or social status, connecting individuals to
  family traditions or cultural values— beyond just aesthetic appeal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116350Z"^^xsd:dateTime .

oakcurric:misconception-child-their-own-bedroom
  a curric:Misconception ;
  curric:statement "Every child has their own bedroom."@en ;
  curric:correction """It’s a common misconception that every child has their own bedroom. In
  reality, many children share rooms, sleep in a living area or move around different homes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116417Z"^^xsd:dateTime .

oakcurric:misconception-colour-used-make-space-look
  a curric:Misconception ;
  curric:statement "Colour is just used to make a space look good."@en ;
  curric:correction """Colour in a room can have a big impact on the way a space feels and how we
  feel in that space."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116965Z"^^xsd:dateTime .

oakcurric:misconception-artists-make-work-identity-reveal
  a curric:Misconception ;
  curric:statement """When artists make work about identity, they reveal all aspects of
  themselves."""@en ;
  curric:correction "Artists make selections about what to conceal or reveal in their work."@en ;
  dcterms:modified "2026-06-07T15:30:15.117017Z"^^xsd:dateTime .

oakcurric:misconception-material-artwork-cannot-communicate-meaning
  a curric:Misconception ;
  curric:statement "The material of an artwork cannot communicate meaning."@en ;
  curric:correction """Many artists carefully select materials to deepen the meaning of their work.
  The materials chosen for an artwork can often communicate meaning through common
  associations or contextual connections."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117232Z"^^xsd:dateTime .

oakcurric:misconception-artists-make-work-looks-good
  a curric:Misconception ;
  curric:statement "Artists only make work that looks good and is uplifting."@en ;
  curric:correction """Artists use the power of imagery to communicate difficult realities about the
  planet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117371Z"^^xsd:dateTime .

oakcurric:misconception-texture-something-feels-looks
  a curric:Misconception ;
  curric:statement "Texture is only about how something feels, not how it looks."@en ;
  curric:correction """Texture can mean how something feels, and we call that physical texture. But
  artists can also create the illusion of texture in drawings or paintings — that’s called
  visual texture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117385Z"^^xsd:dateTime .

oakcurric:misconception-collage-landscapes-look-realistic
  a curric:Misconception ;
  curric:statement "Collage landscapes should always look realistic."@en ;
  curric:correction """Collage allows us to create landscapes that don’t have to follow real world
  rules. Surreal landscapes encourage imagination and creativity beyond what we see in
  everyday life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117428Z"^^xsd:dateTime .

oakcurric:misconception-planning-collage-assemblage-takes-creativity
  a curric:Misconception ;
  curric:statement "Planning a collage or assemblage takes away creativity."@en ;
  curric:correction """Planning provides structure but doesn’t mean the design is fixed. Many
  artists start with an idea but adapt it through experimentation. A plan helps build
  confidence, but the best results often come from unexpected discoveries along the way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117625Z"^^xsd:dateTime .

oakcurric:misconception-once-ink-applied-plate-design
  a curric:Misconception ;
  curric:statement """Once ink is applied to the plate, the design is fixed and cannot be
  changed."""@en ;
  curric:correction """The printing process is about trying and adjusting. Artists can refine their
  design through trial and error, removing layers of ink or adding new ones to adjust their
  composition. It’s important to approach the process with flexibility and patience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117846Z"^^xsd:dateTime .

oakcurric:misconception-tone-smooth-blending
  a curric:Misconception ;
  curric:statement "Tone is all about smooth blending"@en ;
  curric:correction "Tone can be captured in a variety of ways and mediums"@en ;
  dcterms:modified "2026-06-07T15:30:15.117852Z"^^xsd:dateTime .

oakcurric:misconception-pottery-used-making-practical-items
  a curric:Misconception ;
  curric:statement """Pottery is only used for making practical items like bowls and pots, and it
  doesn’t have any artistic or cultural significance."""@en ;
  curric:correction """While pottery is often associated with functional items like bowls and vases,
  it has been used throughout history and in contemporary times as a medium for artistic
  expression and storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118256Z"^^xsd:dateTime .

oakcurric:misconception-painted-portrait-focuses-realism-accuracy
  a curric:Misconception ;
  curric:statement """The painted portrait only focuses on realism and accuracy in depicting the
  subject."""@en ;
  curric:correction """While many portraits aim for realism, painting also allows for abstract and
  emotional interpretations, capturing the subject's personality, mood, and deeper meaning
  beyond just physical appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118284Z"^^xsd:dateTime .

oakcurric:misconception-religious-art-includes-paintings-sculptures
  a curric:Misconception ;
  curric:statement "Religious art only includes paintings or sculptures."@en ;
  curric:correction """Religious art isn’t just paintings or sculptures, it includes architecture,
  textiles, calligraphy and even temporary creations like Rangoli and sand mandalas, all
  used to express and connect with the spiritual."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119087Z"^^xsd:dateTime .

oakcurric:misconception-gender-sexuality-same-thing
  a curric:Misconception ;
  curric:statement "That gender and sexuality are the same thing."@en ;
  curric:correction """Gender is about your personal identity, how you see yourself, while sexuality
  is about who you are attracted to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119179Z"^^xsd:dateTime .

oakcurric:misconception-colours-carry-same-meaning-everybody
  a curric:Misconception ;
  curric:statement "Colours carry the same meaning for everybody."@en ;
  curric:correction """Colours can carry different meanings, and these can vary across people,
  places and cultures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119196Z"^^xsd:dateTime .

oakcurric:misconception-thinking-everyone-elses-emotional-state
  a curric:Misconception ;
  curric:statement "Thinking that everyone else's emotional state is as it appear to be."@en ;
  curric:correction """People can’t support you if they don’t know you need it. When someone wears
  an emotional mask, it’s hard to know the real person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119774Z"^^xsd:dateTime .

oakcurric:misconception-aritsts-take-direct-inspiration-nature
  a curric:Misconception ;
  curric:statement "Aritsts can only take direct inspiration from nature, copying it exactly."@en ;
  curric:correction """Artists have always taken inspiration from nature and can use this as a
  starting point to develop into complex works."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120078Z"^^xsd:dateTime .

oakcurric:misconception-sculptures-take-long-time-create
  a curric:Misconception ;
  curric:statement "Sculptures must take a long time to create."@en ;
  curric:correction "Some sculptural works can be quick responsive works."@en ;
  dcterms:modified "2026-06-07T15:30:15.120992Z"^^xsd:dateTime .

oakcurric:misconception-object-same-mass-whether-real
  a curric:Misconception ;
  curric:statement """An object has the same mass whether in real life or in a 2D
  representation."""@en ;
  curric:correction """Whilst an object in real life may have a certain physical mass, if it is
  depicted in an image its visual weight might not represent this physical mass accurately.
  Especially compared to other items. This is due to the use of visual elements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122839Z"^^xsd:dateTime .

oakcurric:misconception-crest-royalty
  a curric:Misconception ;
  curric:statement "A crest is for royalty only."@en ;
  curric:correction """Crests are symbols used by families, groups, or communities to represent
  their identity, values and stories. They are not only for royalty, but for anyone who
  wants to show their heritage or what they stand for."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122907Z"^^xsd:dateTime .

oakcurric:misconception-scale-means-size
  a curric:Misconception ;
  curric:statement "Scale means size."@en ;
  curric:correction "Scale is specifically about relative size."@en ;
  dcterms:modified "2026-06-07T15:30:15.123025Z"^^xsd:dateTime .

oakcurric:misconception-abstract-collages-need-perfect-symmetry
  a curric:Misconception ;
  curric:statement "Abstract collages need to have perfect symmetry or recognisable shapes."@en ;
  curric:correction """Abstract collages don’t need symmetry or recognisable images. The beauty of
  abstraction lies in experimenting to create something visually engaging which can express
  ideas or emotions and finding balance through the arrangement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123179Z"^^xsd:dateTime .

oakcurric:misconception-students-think-pitching-means-reading
  a curric:Misconception ;
  curric:statement """Some students think pitching means just reading out facts about the
  design."""@en ;
  curric:correction """A strong pitch is more than just facts. It’s a story with a clear beginning,
  middle and end that shows your idea solves a problem and stands out from the rest."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123649Z"^^xsd:dateTime .

oakcurric:misconception-embroidery-simple-way-decorating-cloth
  a curric:Misconception ;
  curric:statement """Embroidery is a simple way of decorating cloth and has no cultural
  context."""@en ;
  curric:correction """Embroidery goes beyond just being a decorative process, it is a powerful form
  of art that can reflect cultural heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124360Z"^^xsd:dateTime .

oakcurric:misconception-create-unity-elements-piece-look
  a curric:Misconception ;
  curric:statement """To create unity, all elements in a piece must look exactly the same or be
  repeated in a uniform manner."""@en ;
  curric:correction """Variety can still contribute to a cohesive composition, as does repeating
  elements in a non-uniform way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124812Z"^^xsd:dateTime .

oakcurric:misconception-shape-form-same-thing
  a curric:Misconception ;
  curric:statement "Shape and form are the same thing."@en ;
  curric:correction """Shape is flat and 2D, like a drawing. Form is 3D and has depth — you can see
  or feel it from different angles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125545Z"^^xsd:dateTime .

oakcurric:misconception-fashion-illustrators-make-finished-garments
  a curric:Misconception ;
  curric:statement "Fashion illustrators make finished garments."@en ;
  curric:correction """Fashion illustrators draw designs and ideas. They help fashion designers show
  what clothes will look like before they are made."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125661Z"^^xsd:dateTime .

oakcurric:misconception-refugees-illegal-take-jobs-others
  a curric:Misconception ;
  curric:statement "Refugees are illegal and take jobs away from others."@en ;
  curric:correction """Refugees are protected under international law and have the right to seek
  asylum. While they may need help when they arrive in a new country, many refugees go on to
  contribute positively to their communities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125672Z"^^xsd:dateTime .

oakcurric:misconception-artwork-seen-passive-object-hangs
  a curric:Misconception ;
  curric:statement "Artwork is often seen as a passive object that hangs on a wall."@en ;
  curric:correction """Art can also be used to activate social change and is a process that can
  helps spark conversation and raise awareness. The act of creating and sharing the work is
  powerful in itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125678Z"^^xsd:dateTime .

oakcurric:misconception-artists-start-painting-drawing-plain
  a curric:Misconception ;
  curric:statement "Artists start a painting or drawing on a plain piece of paper"@en ;
  curric:correction """Often artists create surfaces and backgrounds to work on, it makes the piece
  have less gaps and is interesting to work over."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128047Z"^^xsd:dateTime .

oakcurric:misconception-artwork-held-public-institutions-within
  a curric:Misconception ;
  curric:statement """All of the artwork held in public institutions within the United Kingdom
  originates from there."""@en ;
  curric:correction """Some artwork held in the collections of public institutions in the UK were
  created by civilisations that were colonised by the British Empire."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129585Z"^^xsd:dateTime .

oakcurric:misconception-doodling-valid-artform
  a curric:Misconception ;
  curric:statement "Doodling is not a valid artform."@en ;
  curric:correction """Doodling can express emotion, personality and imagination through simple
  lines and shapes. Many professional artists, illustrators, and designers start their ideas
  through doodling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134122Z"^^xsd:dateTime .

oakcurric:misconception-collaborative-art-group-project-leader
  a curric:Misconception ;
  curric:statement "Collaborative art is just a group project with a leader."@en ;
  curric:correction """Collaborative art is a collective process of co-creation where ideas and
  efforts are deeply intertwined."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134134Z"^^xsd:dateTime .

oakcurric:misconception-plaster-paper-behave-same-way
  a curric:Misconception ;
  curric:statement "Plaster and paper will behave the same way in a mould."@en ;
  curric:correction """Plaster and paper have very different properties. Plaster sets quickly and
  picks up fine details. Paper air dries more slowly and shrinks more as it dries. It might
  not show fine texture as clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137325Z"^^xsd:dateTime .

oakcurric:misconception-large-figurative-sculptures-considered-3d
  a curric:Misconception ;
  curric:statement "Only large, figurative sculptures are considered 3D portraits."@en ;
  curric:correction """3D portraits can be created in various sizes and forms, not just large
  figurative sculptures. They can include small, detailed works or abstract representations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137331Z"^^xsd:dateTime .

oakcurric:misconception-students-place-vanishing-point-low
  a curric:Misconception ;
  curric:statement """Students often place the vanishing point too low or high, or forget to use it
  consistently, which causes the drawing to look distorted or unrealistic."""@en ;
  curric:correction """Remember: the vanishing point sits on the horizon line, which is your eye
  level. All diagonal lines must meet at the vanishing point—even if it’s off the paper!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.138021Z"^^xsd:dateTime .

oakcurric:misconception-portraits-show-person-directly
  a curric:Misconception ;
  curric:statement "Portraits must always show the person directly."@en ;
  curric:correction """A portrait can also include symbolic representations, like objects that
  reflect the person’s personality or even something as unique as a sample of their DNA."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138026Z"^^xsd:dateTime .

oakcurric:misconception-assemblage-look-like-recognisable-scene
  a curric:Misconception ;
  curric:statement """Assemblage has to look like a recognisable scene to share meaning with the
  audience."""@en ;
  curric:correction """Meaning can be represented through objects, textures, and symbols. The way
  objects are arranged, and their relationships to each other can all convey emotions,
  experiences, and personality traits. Assemblage is about meaning, not just likeness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138032Z"^^xsd:dateTime .

oakcurric:misconception-negative-space-means-theres-nothing
  a curric:Misconception ;
  curric:statement "Negative space just means there’s nothing there — it’s empty or unfinished"@en ;
  curric:correction """Negative space may look ‘empty,’ but artists use it intentionally to draw
  attention elsewhere — it helps us focus on shape, emotion, or story without showing
  everything. It’s a powerful choice, not a mistake."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138469Z"^^xsd:dateTime .

oakcurric:misconception-quilts-blankets-decorative-items-dont
  a curric:Misconception ;
  curric:statement """Quilts are just blankets or decorative items and don’t have any deeper
  meaning."""@en ;
  curric:correction """While quilts are often used for warmth or decoration, many artists use quilts
  to share powerful stories and messages. Quilts can be a way for artists to speak out about
  important issues and make sure voices are heard."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138497Z"^^xsd:dateTime .

oakcurric:misconception-observing-stimulus-best-respond-using
  a curric:Misconception ;
  curric:statement "When observing a stimulus, it is best to respond using pencil."@en ;
  curric:correction """Different stimuli, call for different methods like, loose washes, impasto,
  detailed line work, collage, etc. Matching technique to stimuli ensures the artwork
  communicates its idea effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138595Z"^^xsd:dateTime .

oakcurric:misconception-buildings-straight-lines-built-box
  a curric:Misconception ;
  curric:statement "All buildings have straight lines and are built out of box like shapes."@en ;
  curric:correction """Buildings can come in many different forms, with influences coming from a
  range of different sources."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139771Z"^^xsd:dateTime .

oakcurric:misconception-buildings-made-solid-materials-brick
  a curric:Misconception ;
  curric:statement "Buildings are all made from solid materials, brick, stone or concrete."@en ;
  curric:correction """Buildings can be constructed from different materials. These may include
  traditional stone and brick or modern sustainable materials."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139840Z"^^xsd:dateTime .

oakcurric:misconception-critical-thinking-focuses-judging-artworks
  a curric:Misconception ;
  curric:statement "Critical thinking focuses on judging artworks as 'good' or 'bad'."@en ;
  curric:correction """Critical thinking helps artists and audiences to think deeply about art and
  respect different viewpoints."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149612Z"^^xsd:dateTime .
