# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-symbolism
  a curric:Keyword ;
  schema:name "symbolism"@en ;
  schema:description """figurative language where something is used to represent something other
  than its literal meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347530Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-form
  a curric:Keyword ;
  schema:name "form"@en ;
  schema:description """the specific type or category of a poem that determines its structure and
  style"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348016Z"^^xsd:dateTime .

oakcurric:keyword-mood
  a curric:Keyword ;
  schema:name "Mood"@en ;
  schema:description "The mood of a poem is the emotional undertone."@en ;
  dcterms:modified "2026-06-07T15:30:02.348077Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-sustainability
  a curric:Keyword ;
  schema:name "sustainability"@en ;
  schema:description "using resources wisely so future generations can also meet their needs"@en ;
  dcterms:modified "2026-06-07T15:30:02.348175Z"^^xsd:dateTime .

oakcurric:keyword-subject
  a curric:Keyword ;
  schema:name "subject"@en ;
  schema:description """the noun, noun phrase or pronoun that does or is the main verb in the active
  voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348319Z"^^xsd:dateTime .

oakcurric:keyword-imagery
  a curric:Keyword ;
  schema:name "imagery"@en ;
  schema:description """the use of vivid and sensory language that appeals to the reader's senses,
  creating vivid mental pictures and enhancing the emotional impact of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348368Z"^^xsd:dateTime .

oakcurric:keyword-perspective
  a curric:Keyword ;
  schema:name "perspective"@en ;
  schema:description "creating depth and distance in a composition"@en ;
  dcterms:modified "2026-06-07T15:30:02.348595Z"^^xsd:dateTime .

oakcurric:keyword-proposal
  a curric:Keyword ;
  schema:name "proposal"@en ;
  schema:description "the action of proposing a plan or suggestion"@en ;
  dcterms:modified "2026-06-07T15:30:02.348763Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-layout
  a curric:Keyword ;
  schema:name "layout"@en ;
  schema:description "the way a text is structured"@en ;
  dcterms:modified "2026-06-07T15:30:02.348983Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-convey
  a curric:Keyword ;
  schema:name "convey"@en ;
  schema:description "to communicate a message to the reader directly or indirectly"@en ;
  dcterms:modified "2026-06-07T15:30:02.349323Z"^^xsd:dateTime .

oakcurric:keyword-subvert
  a curric:Keyword ;
  schema:name "subvert"@en ;
  schema:description """to criticise or undermine the usual way of doing something or common
  values"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349514Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description """describes something that's based on a person's opinions, individual
  experiences, and biased influences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349519Z"^^xsd:dateTime .

oakcurric:keyword-symbolise
  a curric:Keyword ;
  schema:name "symbolise"@en ;
  schema:description """where an image, object, idea or symbol is used to represent something other
  than its literal meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349532Z"^^xsd:dateTime .

oakcurric:keyword-technology
  a curric:Keyword ;
  schema:name "technology"@en ;
  schema:description """the use of scientific knowledge and tools to enhance and support various
  aspects of sport and performance"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349569Z"^^xsd:dateTime .

oakcurric:keyword-ephemeral
  a curric:Keyword ;
  schema:name "ephemeral"@en ;
  schema:description "lasting for a short time"@en ;
  dcterms:modified "2026-06-07T15:30:02.349593Z"^^xsd:dateTime .

oakcurric:keyword-juxtaposition
  a curric:Keyword ;
  schema:name "Juxtaposition"@en ;
  schema:description "when two different things are placed together for contrasting effect"@en ;
  dcterms:modified "2026-06-07T15:30:02.349626Z"^^xsd:dateTime .

oakcurric:keyword-nuanced
  a curric:Keyword ;
  schema:name "nuanced"@en ;
  schema:description "characterised by subtle distinctions or variations"@en ;
  dcterms:modified "2026-06-07T15:30:02.349787Z"^^xsd:dateTime .

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a set idea that people have about what someone or something is like"@en ;
  dcterms:modified "2026-06-07T15:30:02.349897Z"^^xsd:dateTime .

oakcurric:keyword-representation
  a curric:Keyword ;
  schema:name "representation"@en ;
  schema:description """ensuring that different groups of people have a voice in the decision-making
  process and that their views, interests and needs are reflected in government"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350283Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "volume"@en ;
  schema:description """Volume is how much 3D space matter occupies. It is usually measured
  in cm³."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350297Z"^^xsd:dateTime .

oakcurric:keyword-symbol
  a curric:Keyword ;
  schema:name "symbol"@en ;
  schema:description """a word, object, or image that represents a bigger idea or meaning beyond
  itself"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350718Z"^^xsd:dateTime .

oakcurric:keyword-observation
  a curric:Keyword ;
  schema:name "observation"@en ;
  schema:description """the process of looking closely at something to notice details for recording
  in drawing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350847Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-inspiration
  a curric:Keyword ;
  schema:name "inspiration"@en ;
  schema:description """the process of being mentally stimulated by something to create new
  ideas"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350863Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
  flow of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351040Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """someone who has successfully sought asylum in another country and is
  henceforth protected by international law"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351707Z"^^xsd:dateTime .

oakcurric:keyword-community
  a curric:Keyword ;
  schema:name "community"@en ;
  schema:description "a group of people who share something in common"@en ;
  dcterms:modified "2026-06-07T15:30:02.352054Z"^^xsd:dateTime .

oakcurric:keyword-wellbeing
  a curric:Keyword ;
  schema:name "wellbeing"@en ;
  schema:description "the state of being comfortable, healthy, or happy"@en ;
  dcterms:modified "2026-06-07T15:30:02.352059Z"^^xsd:dateTime .

oakcurric:keyword-technique
  a curric:Keyword ;
