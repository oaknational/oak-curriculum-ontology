  dcterms:modified "2026-06-07T15:30:29.332547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28677-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can experiment with using light and shadow to define form, space and focus
