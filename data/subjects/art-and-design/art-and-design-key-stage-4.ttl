  dcterms:modified "2026-06-07T15:30:29.335022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28743-3
  a curric:KeyLearningPoint ;
  rdfs:label """Develop your ability to critique art and design thoughtfully, considering both
