  dcterms:modified "2026-06-07T15:30:29.337959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28564-3
  a curric:KeyLearningPoint ;
  rdfs:label """Showcase a range of styles, techniques, or themes to demonstrate your versatility
