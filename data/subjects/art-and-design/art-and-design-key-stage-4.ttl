  dcterms:modified "2026-06-07T15:30:29.307519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27939-1
  a curric:KeyLearningPoint ;
  rdfs:label """Despite diverse backgrounds and approaches, common threads emerge in how artists
  engage with sketchbooks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27939-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a sketchbook can help you develop your artistic skills and voice"@en ;
  dcterms:modified "2026-06-07T15:30:29.307527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sketchbooks can document the progression of an artist’s skills and style
  over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28835-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unity brings together different elements to create a harmonious whole. It helps us
