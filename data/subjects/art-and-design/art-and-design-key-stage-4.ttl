  dcterms:modified "2026-06-07T15:30:29.307730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28835-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use areas of light and dark or bold colour to bring unity, variety,
