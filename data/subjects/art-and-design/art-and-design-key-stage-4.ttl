oakcurric:keylearningpoint-lesson-28694-1
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes offer a rich tapestry of colours, textures and forms that designers can
  take inspiration from."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes let graphic designers explore scale, perspective and composition from
