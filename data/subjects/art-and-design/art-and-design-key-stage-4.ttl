  dcterms:modified "2026-06-07T15:30:29.309643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29458-1
  a curric:KeyLearningPoint ;
  rdfs:label "Themes can inspire personal and imaginative design responses."@en ;
  dcterms:modified "2026-06-07T15:30:29.309648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29458-2
  a curric:KeyLearningPoint ;
  rdfs:label "A strong response to a theme shows personal thinking and ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.309651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29458-3
  a curric:KeyLearningPoint ;
  rdfs:label "Design choices should connect clearly to the theme and purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.309655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28731-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use motif development to explore, adapt and strengthen design ideas before
