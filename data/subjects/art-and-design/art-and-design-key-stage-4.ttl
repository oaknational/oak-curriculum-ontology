oakcurric:keylearningpoint-lesson-28685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use layering, stitching, and embellishing to add depth and narrative to
  portraits and figures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29456-1
  a curric:KeyLearningPoint ;
  rdfs:label "Techniques help bring your design ideas to life in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.332966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29456-2
  a curric:KeyLearningPoint ;
  rdfs:label "Testing techniques helps you decide what suits your 3D design voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.332969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29456-3
  a curric:KeyLearningPoint ;
  rdfs:label "Refining your use of materials builds skill and creative confidence."@en ;
  dcterms:modified "2026-06-07T15:30:29.332973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital drawing software applications provide different techniques for artists and
