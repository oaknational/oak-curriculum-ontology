  dcterms:modified "2026-06-07T15:30:29.324278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29452-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing an artist’s themes, materials and techniques deepens your understanding
