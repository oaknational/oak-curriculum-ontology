oakcurric:keylearningpoint-lesson-29451-2
  a curric:KeyLearningPoint ;
  rdfs:label "A strong response to a theme shows personal thinking and ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.307810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29451-3
  a curric:KeyLearningPoint ;
  rdfs:label "Design choices should connect clearly to the theme and purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.307816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28726-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists identify strong sources from their research and sketchbooks to inspire
