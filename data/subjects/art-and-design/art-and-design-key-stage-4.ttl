  dcterms:modified "2026-06-07T15:30:29.333074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28560-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base layer sets the tone for your artwork. This could be a colour wash or a
