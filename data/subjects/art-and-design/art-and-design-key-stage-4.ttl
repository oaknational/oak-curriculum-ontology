  dcterms:modified "2026-06-07T15:30:29.332551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28685-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use textiles to celebrate diverse identities, culture, and history through
