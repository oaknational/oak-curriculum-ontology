  dcterms:modified "2026-06-07T15:30:29.334968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Motifs can be developed from a source such as a flower and transformed through
