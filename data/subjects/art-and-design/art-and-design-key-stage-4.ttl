  dcterms:modified "2026-06-07T15:30:29.307726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28835-2
  a curric:KeyLearningPoint ;
  rdfs:label """Balance creates a sense of stability and order, making the artwork feel grounded. It
