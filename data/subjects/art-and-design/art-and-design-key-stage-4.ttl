oakcurric:keylearningpoint-lesson-28748-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different mediums can enhance an artwork’s message."@en ;
  dcterms:modified "2026-06-07T15:30:29.307326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Experimenting with media can lead to new discoveries."@en ;
