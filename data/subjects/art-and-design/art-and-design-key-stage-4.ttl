  dcterms:modified "2026-06-07T15:30:29.321743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Designers can use landscapes to celebrate nature’s beauty and foster appreciation
