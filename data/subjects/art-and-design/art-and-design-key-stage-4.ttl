  dcterms:modified "2026-06-07T15:30:29.335004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28725-2
  a curric:KeyLearningPoint ;
  rdfs:label """The principles of textile design balance, contrast, repetition, and emphasis guide
