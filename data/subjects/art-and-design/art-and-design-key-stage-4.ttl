  dcterms:modified "2026-06-07T15:30:29.334964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Introducing shapes, patterns, or images that relate to your theme can help express
