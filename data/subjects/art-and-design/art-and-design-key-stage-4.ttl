oakcurric:keylearningpoint-lesson-29630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brush settings and pressure sensitivity can affect mark-making capabilities."@en ;
  dcterms:modified "2026-06-07T15:30:29.333070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artistic principles such as composition and proportion can be applied in a digital
