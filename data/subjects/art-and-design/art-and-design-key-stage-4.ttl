oakcurric:keylearningpoint-lesson-28268-2
  a curric:KeyLearningPoint ;
  rdfs:label """European and American photographers began using motion photography to analyse and
  capture motion scientifically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28268-3
  a curric:KeyLearningPoint ;
