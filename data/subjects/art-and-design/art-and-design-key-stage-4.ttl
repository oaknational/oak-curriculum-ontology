  dcterms:modified "2026-06-07T15:30:29.324252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25405-2
  a curric:KeyLearningPoint ;
  rdfs:label """Promotional content uses images, words, and designs that catch attention and share
  key information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25405-3
  a curric:KeyLearningPoint ;
