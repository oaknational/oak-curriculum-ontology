  rdfs:label "Sources in art can be found in multiple places."@en ;
  dcterms:modified "2026-06-07T15:30:29.307360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21084-2
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of sources such as art pieces, photographs, or patterns can inspire
