# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-28670-1
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes offer a rich tapestry of colours, textures and forms that photographers
  can take inspiration from."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28670-2
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes let photographers explore scale, perspective and composition from vast
  vistas to intimate details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers can use landscapes to celebrate nature’s beauty and foster
  appreciation for ecological diversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28567-1
  a curric:KeyLearningPoint ;
  rdfs:label """Questions help us evaluate: ‘What worked well?’ and ‘What aspects of the materials
  or techniques enhanced the piece?’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28567-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists consider how creative decisions impact the overall effect of a piece."@en ;
  dcterms:modified "2026-06-07T15:30:29.254008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28567-3
  a curric:KeyLearningPoint ;
  rdfs:label "Planning for future projects is based on reflective thinking."@en ;
  dcterms:modified "2026-06-07T15:30:29.254013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24141-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quick sketches or diagrams can be used to illustrate concepts visually, making
  complex ideas more accessible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24141-2
  a curric:KeyLearningPoint ;
  rdfs:label """Annotations can explain thoughts, processes, or decisions related to specific
  elements of a design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24141-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital software tools can be used to annotate directly on images, documents, or
  presentations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24141-4
  a curric:KeyLearningPoint ;
  rdfs:label """Videos, audio clips, or interactive slideshows help to engage the audience and
  present ideas dynamically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24139-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often reflect on their personal experiences, emotions and memories as a
  foundation for their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24139-2
  a curric:KeyLearningPoint ;
  rdfs:label """Studying the works of other artists and historical movements can inspire new
  concepts and techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24139-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying central themes or questions that intrigue them can provide a clear
  direction for their projects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging with contemporary issues or events can provide a relevant and timely
  context for artistic expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28565-1
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a cohesive narrative for a portfolio involves structuring content for
  clarity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Capturing high-resolution images with good lighting and a clean background to
  present artwork clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Including sketches, notes, or step-by-step images help to show your development as
  an artist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28689-1
  a curric:KeyLearningPoint ;
  rdfs:label """Textile artists use light and dark to create mood, contrast, and atmosphere through
  fabric, texture, and tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28689-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light and dark in textiles can carry symbolic meanings across cultures, styles, and
  design traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28689-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use shadows, highlights, and tone in textiles to shape form, suggest depth,
  and direct focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28690-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists explore the theme of inside and outside in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.266404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28690-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use thresholds, barriers, and liminal spaces to express ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.266408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28690-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists make choices about materials, techniques, and design elements to communicate
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28690-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can reflect on your own connections and ideas through textile art."@en ;
  dcterms:modified "2026-06-07T15:30:29.266415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28669-1
  a curric:KeyLearningPoint ;
  rdfs:label """The inherent beauty of natural forms provides photographers with endless
  inspiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28669-2
  a curric:KeyLearningPoint ;
  rdfs:label """The diversity of colours, textures, and shapes found in nature can lead to visually
  striking photographs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural forms often use flowing, asymmetrical elements that contrast geometric
  rigidity, enabling dynamic compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28566-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on the impact of materials on artwork helps artists create informed
  creative decisions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28566-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing the characteristics of materials encourages material choices to support
  conceptual or thematic communication"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28566-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating and documenting the challenges encountered with materials leads to
  purposeful making"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24144-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing the principles of art in artworks provides a framework for understanding
  how visual elements are organised"""@en ;
  dcterms:modified "2026-06-07T15:30:29.269150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24144-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gain a deeper understanding of the artist's creative choices and the impact of those
  choices on the viewer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28686-1
  a curric:KeyLearningPoint ;
  rdfs:label """Textiles offer rich textures, colours and patterns that evoke touch and emotional
  engagement in artworks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fabric’s flexibility allows techniques like weaving, dyeing and quilting, inspiring
  creative reinterpretations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using traditional objects in textile art connects artists to heritage, preserving
  and celebrating cultural history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28719-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animation is created by sequencing images over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.273405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28719-2
  a curric:KeyLearningPoint ;
  rdfs:label "Frames and keyframes are the building blocks of digital animation."@en ;
  dcterms:modified "2026-06-07T15:30:29.273409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28719-3
  a curric:KeyLearningPoint ;
  rdfs:label "Timelines help animators to create the structure and sequence of an animation."@en ;
  dcterms:modified "2026-06-07T15:30:29.273413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28736-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different casting materials offer various textures, finishes, weights and
  durability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28736-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stages in model making: mouldmaking, casting, curing and finishing all require focus
  to ensure accuracy and quality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28736-3
  a curric:KeyLearningPoint ;
  rdfs:label """Casting enables the creation of multiple copies or editions of a sculpture, making
  art more accessible and versatile."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Working with multiple parts needs a strong composition, the elements relate
  spatially, rhythmically and aesthetically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28733-2
  a curric:KeyLearningPoint ;
  rdfs:label """Assembling invites experimentation with different materials, objects and
  reconfigurable forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28733-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists must plan how parts fit together and support one another, ensuring the
  sculpture is stable and durable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28774-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists may curate exhibitions to maintain control over work and engage audiences in
  new ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28774-2
  a curric:KeyLearningPoint ;
  rdfs:label "Self-curation can challenge traditional power structures in the art world."@en ;
  dcterms:modified "2026-06-07T15:30:29.276059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28774-3
  a curric:KeyLearningPoint ;
  rdfs:label "In some cases, curation itself becomes part of the artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.276063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28245-1
  a curric:KeyLearningPoint ;
  rdfs:label """Watercolour is transparent, so artists paint the lightest areas first and build up
  gradually to darker tones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28245-2
  a curric:KeyLearningPoint ;
  rdfs:label """Watercolour allows you to blend colours and tones softly to create smooth gradients
  and natural-looking colour shifts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28245-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use masking fluid to mask and protect areas of their work to protect or
  preserve lighter areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Glazing involves painting thin, transparent layers over dry paint. It adds depth or
  shadow without covering the details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28740-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modelling is a process, where forms are built up by gradually adding and shaping
  material like clay, wax, or plaster."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28740-2
  a curric:KeyLearningPoint ;
  rdfs:label """Developing sensitivity to moisture levels, structural support, drying times is
  essential, especially working with clay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28740-3
  a curric:KeyLearningPoint ;
  rdfs:label """Expressing movement, emotion and narrative through gesture, posture and detail makes
  work compelling and communicative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28185-1
  a curric:KeyLearningPoint ;
  rdfs:label """The key elements of 2D design are the elements of art and these are important in
  creating 3D form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28185-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining how 2D elements relate to 3D space uses concepts of depth, volume, and
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28185-3
  a curric:KeyLearningPoint ;
  rdfs:label """When drawing in 3D start with basic geometric shapes to establish structure, then
  build complexity in your 3D drawing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28749-1
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with layering techniques and textural effects adds depth and interest
  to your practical response."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sharing your work with peers helps to gather constructive feedback."@en ;
  dcterms:modified "2026-06-07T15:30:29.281050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28749-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considering different perspectives can help broaden your thinking and aid the
  refinement of your practical response."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28749-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on the process and outcome is an essential part of the creative
  process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28749-5
  a curric:KeyLearningPoint ;
  rdfs:label """Considering what worked well and what could be improved guides further
  refinement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29459-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artist research helps you discover techniques and ideas to explore."@en ;
  dcterms:modified "2026-06-07T15:30:29.281068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29459-2
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting research visually helps you understand the artist’s voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.281071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29459-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reflecting on artists’ work helps shape your own creative thinking."@en ;
  dcterms:modified "2026-06-07T15:30:29.281075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28205-1
  a curric:KeyLearningPoint ;
  rdfs:label """When photographing for resources, whether for inspiration, documentation, or
  research, what makes a good photograph?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.281485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28205-2
  a curric:KeyLearningPoint ;
  rdfs:label """Try different angles and perspectives to find the most dynamic view of your
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28205-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consider notes about each photograph, including the context, location and any
  relevant information about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28241-1
  a curric:KeyLearningPoint ;
  rdfs:label """Each monotype is singular rather than a reproducible copy, which creates a unique
  artwork with only one edition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28241-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use mark-making to express tone and texture in monotype."@en ;
  dcterms:modified "2026-06-07T15:30:29.281622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28241-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use less formal tools like cotton buds and wooden forks to experiment in
  monotype."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28244-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inks are excellent for creating precise lines, making them ideal for illustrations,
  comic art, and detailed drawings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28244-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inks can be diluted with water to create washes and gradients, adding dimension to
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28244-3
  a curric:KeyLearningPoint ;
  rdfs:label """For a more expressive style, splattering or dripping ink or adding bleach can create
  dynamic textures and effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28693-1
  a curric:KeyLearningPoint ;
  rdfs:label """The inherent beauty of natural forms provides graphic designers with endless
  inspiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28693-2
  a curric:KeyLearningPoint ;
  rdfs:label """The diversity of colours, textures, and shapes found in nature can lead to visually
  striking designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28693-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural forms often use flowing, asymmetrical elements that contrast geometric
  rigidity, enabling dynamic compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28274-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials affect aesthetics and tactile qualities."@en ;
  dcterms:modified "2026-06-07T15:30:29.284949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28274-2
  a curric:KeyLearningPoint ;
  rdfs:label "Techniques vary with each material: carving, modeling, casting, assembling."@en ;
  dcterms:modified "2026-06-07T15:30:29.284953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21087-1
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing with purpose and intention supports the development of creative ideas and
  concepts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21087-2
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with unconventional surfaces and materials can lead to surprising,
  creative outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21087-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using unusual materials challenges traditional notions of drawing and encourages
  thinking outside the box."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28259-1
  a curric:KeyLearningPoint ;
  rdfs:label """Batik has deep cultural roots, and artists use batik to honour and preserve these
  traditional techniques and motifs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28259-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dyeing process in batik produces rich, vibrant colours that can be layered and
  blended."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28259-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wax is applied to fabric before dyeing, preventing dye from reaching certain areas
  and creating patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28715-1
  a curric:KeyLearningPoint ;
  rdfs:label "Digital technology can expand traditional printmaking methods."@en ;
  dcterms:modified "2026-06-07T15:30:29.287832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28715-2
  a curric:KeyLearningPoint ;
  rdfs:label "Image file types (vector vs raster) affect print quality."@en ;
  dcterms:modified "2026-06-07T15:30:29.287836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28715-3
  a curric:KeyLearningPoint ;
  rdfs:label "Preparing digital files correctly ensures successful transfer to substrates."@en ;
  dcterms:modified "2026-06-07T15:30:29.287839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28715-4
  a curric:KeyLearningPoint ;
  rdfs:label "Print resolution and scale impact clarity of final outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.287843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24140-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflect upon personal experiences, emotions and memories as sources of
  inspiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24140-2
  a curric:KeyLearningPoint ;
  rdfs:label """Draw from personal or fictional narratives to create a strong foundation for
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24140-3
  a curric:KeyLearningPoint ;
  rdfs:label "Incorporate found objects to inspire and add layers of meaning to artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.287855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24140-4
  a curric:KeyLearningPoint ;
  rdfs:label "Combine resources to create rich mixed media outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.287858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can reproduce their work through prints, postcards, and limited edition
  prints."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25404-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many examples of artist's reproducing their work in different ways and
  across different times and places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A curatorial experiment explores not just which artworks are shown, but how they are
  arranged, displayed, and framed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Curators and artists might use reproductions to experiment with how art is displayed
  and experienced"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29448-1
  a curric:KeyLearningPoint ;
  rdfs:label "A textile designer's voice is shaped by influences, materials and ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.288818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29448-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists develop their style through experimentation, repetition and reflection."@en ;
  dcterms:modified "2026-06-07T15:30:29.288822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29448-3
  a curric:KeyLearningPoint ;
  rdfs:label "A personal style is not fixed — it can grow and change over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.288826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28708-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different paints have unique properties and behaviours that influence how they can
  be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28708-2
  a curric:KeyLearningPoint ;
  rdfs:label """How you apply paint — through techniques like blending, layering, or washes, changes
  the final effect of the painting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28708-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different paint types can be blended and layered in different ways to create tone
  and texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28708-4
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can combine and layer different materials and media to create new
  effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consider how the choice of materials (e.g. paint, clay, fabric) affects the
  aesthetic and emotional impact of the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding and analysing an artist's process can illuminate the artist's skill
  and intent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28744-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observe how artists experiment with materials and methods to create unique effects
  or push creative boundaries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28754-1
  a curric:KeyLearningPoint ;
  rdfs:label """A well presented piece communicates professionalism and adds to its perceived value,
  making it more appealing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28754-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting your work gives you a sense of achievement and recognition, making you
  feel proud of your efforts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28754-3
  a curric:KeyLearningPoint ;
  rdfs:label """A well thought out display can enhance the viewer experience; pay attention to the
  visual aspects of your presentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28754-4
  a curric:KeyLearningPoint ;
  rdfs:label "A strong narrative can engage viewers and enhance their understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.288867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28240-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relief printing is a technique where the raised surfaces of a plate are inked and
  pressed onto paper, creating an image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28240-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relief printing dates back to ancient times and was essential for reproducing images
  before modern printing existed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28240-3
  a curric:KeyLearningPoint ;
  rdfs:label "Printing gives opportunity for a wide range of experimentation and discovery."@en ;
  dcterms:modified "2026-06-07T15:30:29.292190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28238-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acrylic or oil paints can produce vibrant, opaque colours that enhance visual impact
  and depth in artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28238-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acrylic paints can be blended quickly before drying to create gradients and smooth
  transitions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28238-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the properties of different paint (thickness, opacity, drying time)
  helps you choose techniques & surfaces"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28238-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding colour theory supports successful mixing to create a balanced and
  harmonious palette with any paint"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28242-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combining different materials and techniques can allow artists to convey complex
  ideas and emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28242-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mixing media creates interesting textures and dimensions that can enhance the visual
  and tactile experience of a piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28242-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can break away from traditional boundaries by experimenting with
  unconventional combinations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21086-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis helps viewers appreciate the historical, cultural, and social contexts of
  artwork, deepening understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21086-2
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging with art fosters critical thinking by evaluating art elements, leading to
  more informed interpretations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21086-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use alternatives to writing when annotating and analysing work."@en ;
  dcterms:modified "2026-06-07T15:30:29.295419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21086-4
  a curric:KeyLearningPoint ;
  rdfs:label """A 'crit' is a place for discussing ideas about our own work and that of others in a
  supportive way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21085-1
  a curric:KeyLearningPoint ;
  rdfs:label """Observation helps artists capture nuances in subjects, whether through detailed
  forms or more playful, exploratory ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21085-2
  a curric:KeyLearningPoint ;
  rdfs:label """Perspective shapes how we see the world, both in our physical position and in how we
  approach drawing tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21085-3
  a curric:KeyLearningPoint ;
  rdfs:label """Recording from observation allows artists to explore different perspectives through
  the materials used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21089-1
  a curric:KeyLearningPoint ;
  rdfs:label """Old photos can be repurposed to create interesting artworks that are relevant to
  today."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21089-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use photos to express ideas about identity and contemporary society."@en ;
  dcterms:modified "2026-06-07T15:30:29.295513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21089-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stitching into photos and manipulating them can add another layer of meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.295516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital art is built on key visual principles, including composition, contrast,
  layering and resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28718-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding how these principles interact strengthens technical and creative
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28718-3
  a curric:KeyLearningPoint ;
  rdfs:label """Layer control and editing decisions affect the mood, clarity and effectiveness of
  digital artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28721-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cyanotype is an early photographic process using UV light to create blue toned
  images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28721-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light exposure and object placement affect the final result of a cyanotype."@en ;
  dcterms:modified "2026-06-07T15:30:29.295636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28721-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photograms explore composition through shape, light, and shadow."@en ;
  dcterms:modified "2026-06-07T15:30:29.295640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28721-4
  a curric:KeyLearningPoint ;
  rdfs:label "Contrast can be manipulated by exposure time and material transparency."@en ;
  dcterms:modified "2026-06-07T15:30:29.295644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28722-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photo manipulation can be used to adjust and enhance the original image."@en ;
  dcterms:modified "2026-06-07T15:30:29.295648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28722-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contrast, brightness, and saturation can be used to enhance photographs
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Selection and clone tools can be used for targeted layer editing and specific
  elements in a photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28709-1
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies such as the rule of thirds, negative space, framing and cropping help
  organise a picture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28709-2
  a curric:KeyLearningPoint ;
  rdfs:label "Composition directs attention and creates a visual journey through the artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.295706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28709-3
  a curric:KeyLearningPoint ;
  rdfs:label "Planning where elements go helps create effective and purposeful designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.295710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28709-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using compositional techniques deliberately strengthens the meaning and impact of
  the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28258-1
  a curric:KeyLearningPoint ;
  rdfs:label """Painting onto the silkcreen will only produce one, singular print not multiple
  prints."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28258-2
  a curric:KeyLearningPoint ;
  rdfs:label """The silkscreen technique allows versatility to produce an art piece or a wearable
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28258-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use other techniques, like hand stitch embroidery, to develop their
  design or artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28692-1
  a curric:KeyLearningPoint ;
  rdfs:label """Everyday objects can be used to convey meaning, messages, emotions and ideas in
  graphic communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28692-2
  a curric:KeyLearningPoint ;
  rdfs:label "Designers use composition and layout techniques to guide the viewer’s attention."@en ;
  dcterms:modified "2026-06-07T15:30:29.295804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contrast enhances visual communication by emphasising key elements."@en ;
  dcterms:modified "2026-06-07T15:30:29.295808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29631-1
  a curric:KeyLearningPoint ;
  rdfs:label "Light can be used as a drawing tool in photography."@en ;
  dcterms:modified "2026-06-07T15:30:29.296407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Long exposure allows movement of light to be captured as lines and shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.296411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composition and planning are key to effective light drawings."@en ;
  dcterms:modified "2026-06-07T15:30:29.296415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29631-4
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to consider light sources and plan a light drawing to create an
  effective image that shows contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28674-1
  a curric:KeyLearningPoint ;
  rdfs:label """Objects often carry symbolic weight, allowing artists to convey complex themes and
  narratives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can choose objects that hold personal significance, creating works that
  resonate emotionally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28674-3
  a curric:KeyLearningPoint ;
  rdfs:label """By arranging objects thoughtfully, artists can guide viewers through a
  visual story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28717-1
  a curric:KeyLearningPoint ;
  rdfs:label "Monoprinting creates unique, non-repeatable artworks."@en ;
  dcterms:modified "2026-06-07T15:30:29.299936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Expressive marks can be developed deliberately through line, pressure, and
  texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Techniques include direct drawing, subtractive methods, and textured surfaces."@en ;
  dcterms:modified "2026-06-07T15:30:29.299944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28278-1
  a curric:KeyLearningPoint ;
  rdfs:label """Forming clay by pinching and shaping it with fingers is typically used for small
  bowls or decorative objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28278-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rolling out, stacking and joining coils (long strands of clay) can be used to build
  up the walls of pots and sculptures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28278-3
  a curric:KeyLearningPoint ;
