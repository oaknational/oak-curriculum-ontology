  dcterms:modified "2026-06-07T15:30:29.321748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28266-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lighting is one of the most important elements in photography."@en ;
  dcterms:modified "2026-06-07T15:30:29.322826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28266-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photography can be in a studio or outdoors, and a major difference between these two
  strands is the light source."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28266-3
  a curric:KeyLearningPoint ;
  rdfs:label "The direction of light plays a big role in how an image looks and feels."@en ;
  dcterms:modified "2026-06-07T15:30:29.322837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28266-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subject, composition and lighting in a photograph can have a big impact on
  the mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28266-5
  a curric:KeyLearningPoint ;
  rdfs:label """In early photography, artists relied entirely on light, shadow, contrast,
  and tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28265-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cameras work by allowing light to pass into a camera and onto a light sensitive
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28265-2
  a curric:KeyLearningPoint ;
  rdfs:label "The f-stop or aperture controls allow us to change the size of the opening."@en ;
  dcterms:modified "2026-06-07T15:30:29.323982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28265-3
  a curric:KeyLearningPoint ;
  rdfs:label "The shutter speed allows us to control how long the aperture is open."@en ;
  dcterms:modified "2026-06-07T15:30:29.323986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28265-4
  a curric:KeyLearningPoint ;
  rdfs:label """By using both of these, we can control how light or dark our photographs are, and
  can reduce or manipulate blur."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25405-1
  a curric:KeyLearningPoint ;
