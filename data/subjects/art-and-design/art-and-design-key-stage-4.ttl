  dcterms:modified "2026-06-07T15:30:29.307364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21084-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use different methods to map thoughts and concepts visually, aiding the
