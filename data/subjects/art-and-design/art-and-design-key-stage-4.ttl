oakcurric:keylearningpoint-lesson-29457-3
  a curric:KeyLearningPoint ;
  rdfs:label "Experimental sketchbooks help you take creative risks and reflect."@en ;
  dcterms:modified "2026-06-07T15:30:29.336522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29445-1
  a curric:KeyLearningPoint ;
