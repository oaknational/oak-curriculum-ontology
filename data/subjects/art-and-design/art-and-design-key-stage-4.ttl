  dcterms:modified "2026-06-07T15:30:29.333062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29630-2
  a curric:KeyLearningPoint ;
  rdfs:label "Layers can be used to organise, edit and refine sections of a digital artwork."@en ;
