oakcurric:keylearningpoint-lesson-25443-1
  a curric:KeyLearningPoint ;
  rdfs:label """Collaboration allows artists to bring their unique perspectives and styles,
  resulting in more varied compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25443-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can experiment with different materials, techniques, and arrangements,
  leading to innovative results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25443-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can learn from each other’s techniques and approaches, broadening their own
  skills and artistic vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28248-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ensuring that text is easy to read at various sizes. Choosing appropriate typefaces
  and sizes is crucial for legibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28248-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjusting the space between lines of text for readability. Proper leading can
  improve the overall flow of text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28248-3
  a curric:KeyLearningPoint ;
  rdfs:label """A well-balanced logo feels visually stable and pleasing. Proportion helps maintain
  harmony among design elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28248-4
  a curric:KeyLearningPoint ;
  rdfs:label """The logo should be effective in both small and large formats, maintaining clarity
  and recognition at any size."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Idea development is iterative. Each trial can lead to new insights, refining the
  original concept."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Keeping thorough records of trials, including outcomes and reflections helps you
  track progress and identify successes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28745-3
  a curric:KeyLearningPoint ;
  rdfs:label "Taking risks can lead to unexpected and innovative results."@en ;
  dcterms:modified "2026-06-07T15:30:29.340973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25445-1
  a curric:KeyLearningPoint ;
  rdfs:label """Defining what you want to achieve with your annotations is a useful starting
  point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25445-2
  a curric:KeyLearningPoint ;
  rdfs:label """Annotations can be used for different purposes including summarising a text,
  highlighting key themes or reflecting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25445-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital platforms can be used for real-time collaboration when annotating, allowing
  multiple people to contribute."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25445-4
  a curric:KeyLearningPoint ;
  rdfs:label """Annotations should be regularly discussed either through group meetings or online
  chats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28267-1
  a curric:KeyLearningPoint ;
  rdfs:label "Subjects at different distances from the camera appear at different depths."@en ;
  dcterms:modified "2026-06-07T15:30:29.341360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28267-2
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the f-stop, the greater depth of field, meaning more of our picture is in
  focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28267-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lower f stop settings produce a narrower depth of field, meaning more of the picture
  appears out of focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28264-1
  a curric:KeyLearningPoint ;
  rdfs:label "Photography is a powerful way to tell stories without words."@en ;
  dcterms:modified "2026-06-07T15:30:29.341372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28264-2
  a curric:KeyLearningPoint ;
  rdfs:label "Photography is the practice of using light to create images."@en ;
  dcterms:modified "2026-06-07T15:30:29.341376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28264-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are six key principles of photographic composition."@en ;
  dcterms:modified "2026-06-07T15:30:29.341380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29442-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lighting plays a crucial role in setting the mood and atmosphere of a
  photograph."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29442-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers use post-production adjustments and editing to refine their
  images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29442-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lighting and editing can enhance visual impact, and better communicate artistic
  intent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29204-1
  a curric:KeyLearningPoint ;
  rdfs:label "Design concepts reflect personal identity, values, and influences."@en ;
  dcterms:modified "2026-06-07T15:30:29.341783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29204-2
  a curric:KeyLearningPoint ;
  rdfs:label """A unique design concept begins with self-reflection and intentional visual
  choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29204-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personal experiences can inspire original and meaningful graphic design."@en ;
  dcterms:modified "2026-06-07T15:30:29.341792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28271-1
  a curric:KeyLearningPoint ;
  rdfs:label """In digital editing, layers are used to give greater control and flexibility when
  editing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28271-2
  a curric:KeyLearningPoint ;
  rdfs:label """When different images are layered together to make a single image, we call this a
  composite image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28271-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using adjustment layers and layer masks are examples of non-destructive editing"@en ;
  dcterms:modified "2026-06-07T15:30:29.341921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Your photographic voice is the distinctive way you see and capture the world through
  images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29441-2
  a curric:KeyLearningPoint ;
  rdfs:label """A photographic voice is shaped by a mixture of things such as experimentation and
  internal and external influences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29441-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many aspects in photography to experiment with in order to find your
  photographic voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28251-1
  a curric:KeyLearningPoint ;
  rdfs:label """Image manipulation allows designers to adjust colours, contrast and brightness for
  visually striking compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28251-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tools like layers, filters and cropping can drastically change image tone and
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28251-3
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulated images can convey complex ideas that resonate with the audience,
  enhancing the message of a design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28253-1
  a curric:KeyLearningPoint ;
  rdfs:label """Layout and composition help to create effective, engaging and visually appealing
  designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28253-2
  a curric:KeyLearningPoint ;
  rdfs:label """A well-structured layout helps guide the viewer’s eye through the design, making it
  easier to understand information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28253-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considered composition ensures a pleasing arrangement of elements, enhancing the
  overall attractiveness of the design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28260-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use sewing machines to draw with thread, creating expressive portraits by
  layering line, tone, and texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28260-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understand how to set up and control a sewing machine for freehand stitching, using
  the correct tool and techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28260-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experiment with thread, colour, and layering to develop stitched, thread drawings in
  response to a project theme"""@en ;
  dcterms:modified "2026-06-07T15:30:29.342495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28727-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists simplify designs into bold motifs so they can be cut and used as
  stencils."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28727-2
  a curric:KeyLearningPoint ;
  rdfs:label """Combining dyed backgrounds with stencil printing allows artists to create layered,
  textured effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Combining printing with resist techniques helps control where dye or ink is
  absorbed, adding contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28842-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use compositions to organise elements within their work."@en ;
  dcterms:modified "2026-06-07T15:30:29.343303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28842-2
  a curric:KeyLearningPoint ;
  rdfs:label """Good composition can enhance balance, contrast and focus, helping to tell a story or
  evoke emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28842-3
  a curric:KeyLearningPoint ;
  rdfs:label """Composition allows artists to highlight important features, create depth and
  establish a visual rhythm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28842-4
  a curric:KeyLearningPoint ;
  rdfs:label """Compositional techniques help create a structured arrangement that guides the
  viewer's eye and conveys meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28842-5
  a curric:KeyLearningPoint ;
  rdfs:label """A successful composition activates the visual language for effective communication
  of ideas and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25402-1
  a curric:KeyLearningPoint ;
  rdfs:label "Every artwork in an exhibition must reinforce the central theme or concept."@en ;
  dcterms:modified "2026-06-07T15:30:29.343525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25402-2
  a curric:KeyLearningPoint ;
  rdfs:label "The best selections engage the audience and communicate something meaningful."@en ;
  dcterms:modified "2026-06-07T15:30:29.343529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25402-3
  a curric:KeyLearningPoint ;
  rdfs:label "A strong exhibition feels unified because each piece complements the others."@en ;
  dcterms:modified "2026-06-07T15:30:29.343533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28254-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sources of inspiration play a key role in shaping the direction of creative work as
  it develops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28254-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sources allows graphic designers to create more dynamic, relevant,
  and compelling designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28254-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring a range of sources introduces designers to various styles, concepts, and
  cultural influences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29203-1
  a curric:KeyLearningPoint ;
  rdfs:label """A research page is a curated, creative presentation of a designer’s work and
  aesthetic, not just a collection of images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29203-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective layout and annotation help communicate analysis and personal
  interpretation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29203-3
  a curric:KeyLearningPoint ;
  rdfs:label """Design choices on the page may reflect the influence of another artist, designer, or
  style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25442-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often collaborate and generate ideas, enriching their creative processes and
  expanding their perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25442-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists engage in informal meetings to share thoughts, inspirations and concepts,
  fostering a free flow of ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25442-3
  a curric:KeyLearningPoint ;
  rdfs:label """Participating in workshops or residencies provides space for experimentation and
  collaboration with diverse creatives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25442-4
  a curric:KeyLearningPoint ;
  rdfs:label """Working on community projects encourages collaboration, where multiple artists
  contribute to a unified theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28683-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists and designers use light and dark to create mood, atmosphere and visual
  contrast in 3D design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light and shadow can be used to define form, space and focal points, helping guide
  the viewer’s attention in a design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28683-3
  a curric:KeyLearningPoint ;
  rdfs:label """The interaction between materials and light, such as transparency, reflection and
  texture, can affect the outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28256-1
  a curric:KeyLearningPoint ;
  rdfs:label "Appliqué is a way of drawing with fabric and stitch techniques."@en ;
  dcterms:modified "2026-06-07T15:30:29.344651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28256-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to choose the correct fabric for the appliqué to help describe the
  surface textures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stitch can be turned into a design feature, for example using a bold colour which
  will stand out against the fabric."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28728-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use fabric manipulation to transform flat textiles into sculptural surfaces
  with depth and movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28728-2
  a curric:KeyLearningPoint ;
  rdfs:label """Techniques such as ruching, layering, and folding create different textures that can
  change the look of the piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28728-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fashion designers and textile artists use these methods to explore ideas, add
  expression & how fabric is used in design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28747-1
  a curric:KeyLearningPoint ;
  rdfs:label """A meaningful source that connects to your ideas or experiences adds emotional or
  conceptual significance to your work"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28747-2
  a curric:KeyLearningPoint ;
  rdfs:label "Resources can become more meaningful when grouped or juxtaposed,"@en ;
  dcterms:modified "2026-06-07T15:30:29.344695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28747-3
  a curric:KeyLearningPoint ;
  rdfs:label """Critically reflecting on resources, can ensure they communicate your message, your
  artistic voice, and your idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28747-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relationships between resources can create new ideas, evoke emotion, or highlight
  contrasts that deepen the message"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29444-1
  a curric:KeyLearningPoint ;
  rdfs:label "Themes act as a springboard for photographers to develop ideas and make work."@en ;
  dcterms:modified "2026-06-07T15:30:29.345074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29444-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes can be interpreted in different ways by different photographers."@en ;
  dcterms:modified "2026-06-07T15:30:29.345078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29444-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mind maps or idea showers are a useful way to record interpretation and exploration
  aspects of themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both artists and graphic designers use sketchbooks for creative exploration."@en ;
  dcterms:modified "2026-06-07T15:30:29.345086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29201-2
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic design is often based on themes and concepts rather than just
  aesthetics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimental media play is a process where graphic designers push beyond their usual
  media or conventional tools."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28704-1
  a curric:KeyLearningPoint ;
  rdfs:label """The elements and principles of art are used by artists to convey ideas, emotions,
  and narratives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28704-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists make choices deliberately by select principles rather than using them
  randomly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28704-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting improves practice as refining decisions can lead to creating stronger,
  more purposeful outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27937-1
  a curric:KeyLearningPoint ;
  rdfs:label """An artist’s voice is distinctive and shaped by influences and ongoing
  experimentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27937-2
  a curric:KeyLearningPoint ;
  rdfs:label "An artistic voice is not fixed."@en ;
  dcterms:modified "2026-06-07T15:30:29.347226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27937-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists develop their style through experimentation, repetition, and refinement."@en ;
  dcterms:modified "2026-06-07T15:30:29.347230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Curators organise and manage art exhibitions to enhance viewer understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.347234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Curators use space and flow to shape how viewers experience art."@en ;
  dcterms:modified "2026-06-07T15:30:29.347238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Curation involves selecting, arranging, and presenting artworks."@en ;
  dcterms:modified "2026-06-07T15:30:29.347242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Curators impact how art is perceived and interpreted by the public."@en ;
  dcterms:modified "2026-06-07T15:30:29.347246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28729-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use constructed textiles in diverse ways, from functional design to
  large-scale installations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cultural background and personal identity often influence an artist’s choice of
  materials, colours and techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28729-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimentation with texture and form allows artists to push the boundaries of
  traditional weaving and tapestry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29455-1
  a curric:KeyLearningPoint ;
  rdfs:label "A 3D design style is shaped by influences, materials, and ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.349289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29455-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists develop their style through experimentation, repetition, and reflection."@en ;
  dcterms:modified "2026-06-07T15:30:29.349293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29455-3
  a curric:KeyLearningPoint ;
  rdfs:label "A personal style is not fixed—it can grow and change over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.349297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29460-1
  a curric:KeyLearningPoint ;
  rdfs:label "Strong ideas grow from combining research, experimentation and reflection."@en ;
  dcterms:modified "2026-06-07T15:30:29.349382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29460-2
  a curric:KeyLearningPoint ;
  rdfs:label "Making links between artists, materials and themes strengthens ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.349386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29460-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clear creative intention helps guide your design decisions."@en ;
  dcterms:modified "2026-06-07T15:30:29.349390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29205-1
  a curric:KeyLearningPoint ;
  rdfs:label """Researching and analysing key visual features used by other designers is key to
  developing final ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29205-2
  a curric:KeyLearningPoint ;
  rdfs:label """Familiarity with basic graphic design principles like balance and alignment is
  needed to develop a final idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29205-3
  a curric:KeyLearningPoint ;
  rdfs:label """Articulating how a final idea communicates design choices is an important part of
  the process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29449-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists refine their style through experimentation with materials, techniques and
  composition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29449-2
  a curric:KeyLearningPoint ;
  rdfs:label "Deconstructing and reconstructing materials can reveal new design possibilities."@en ;
  dcterms:modified "2026-06-07T15:30:29.349565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29449-3
  a curric:KeyLearningPoint ;
  rdfs:label """A personal textile voice is developed by making bold creative choices and reflecting
  on outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28841-1
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns create a sense of rhythm and movement, drawing the viewer's eye across the
  artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Repeated motifs can enhance the quality of an artwork, giving it a richer, more
  complex appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns can have historical or cultural significance, allowing artists to connect
  with tradition or convey narratives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28841-4
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns can evoke feelings or memories, influencing how a viewer interacts with the
  piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24142-1
  a curric:KeyLearningPoint ;
  rdfs:label """An artist's selection of materials used in an artwork, contribute to the overall
  effect and meaning of the work"""@en ;
  dcterms:modified "2026-06-07T15:30:29.350776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24142-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials have various qualities and textures"@en ;
  dcterms:modified "2026-06-07T15:30:29.350780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24142-3
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can have symbolic meaning or cultural significance which can enhance the
  narrative of an artwork"""@en ;
  dcterms:modified "2026-06-07T15:30:29.350784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28751-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arranging an artwork in a logical sequence guides the viewer through your
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28751-2
  a curric:KeyLearningPoint ;
  rdfs:label """Providing context for each piece, such as titles, dates etc helps viewers understand
  your artistic intention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28751-3
  a curric:KeyLearningPoint ;
  rdfs:label """Paying attention to the visual layout ensures an engaging and harmonious
  presentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28751-4
  a curric:KeyLearningPoint ;
  rdfs:label """Consideration of visual flow, contrast and thematic progression ensure a clear and
  cohesive narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29446-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use personal experiences, inspiration, interests, and emotions to shape
  creative concepts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29446-2
  a curric:KeyLearningPoint ;
  rdfs:label "A strong concept forms the foundation of a successful photography project."@en ;
  dcterms:modified "2026-06-07T15:30:29.351217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29446-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moodboards can help develop and refine creative ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.351221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28203-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often spend time experimenting with the physical properties of materials,
  such as texture and malleability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28203-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mixing different materials (e.g. paint and objects, or fabric with metal) allows
  artists to discover new visual effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28203-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists may develop techniques specific to the materials they are using, including
  pouring, dripping, or layering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28246-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic communication involves the use of visual elements to convey messages."@en ;
  dcterms:modified "2026-06-07T15:30:29.353004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28246-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key principles include balance, contrast, hierarchy, emphasis, unity, variety and
  movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28246-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding how different elements can be arranged to create effective
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28246-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ability to critique and improve designs based on principles of graphic
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28735-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme needs intentional choices in form, material, and symbol to communicate
  meaning and resonate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28735-2
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition, contrast, and rhythm reinforce the theme and connect all parts of a
  sculpture intentionally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28735-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sculpture reflects the artist’s intent but must also consider how viewers
  interpret and respond emotionally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28834-1
  a curric:KeyLearningPoint ;
  rdfs:label "Artists use proportion, scale and perspective to emphasise parts of the artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.354142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28834-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use proportion, scale and perspective to manipulate how the viewer interacts
  with the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28834-3
  a curric:KeyLearningPoint ;
  rdfs:label "Artists change the proportion, scale or perspective to develop new ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.354152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28667-1
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits can show a person’s identity, including culture, gender, age, social
  status and background."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits can tell stories about people’s lives and experiences, suggesting
  relationships, emotions or history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers often use their work to share views on society, culture, or important
  issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28667-4
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits can go beyond what someone looks like; they can show who they are and what
  they stand for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28272-1
  a curric:KeyLearningPoint ;
  rdfs:label """Researching photographers helps us understand their ideas, style, techniques, and
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28272-2
  a curric:KeyLearningPoint ;
  rdfs:label """Context can include cultural, historical, material, and social influences on a
  photographer’s work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28272-3
  a curric:KeyLearningPoint ;
  rdfs:label """Annotation means describing, analysing, interpreting, and making a personal response
  to images."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28272-4
  a curric:KeyLearningPoint ;
  rdfs:label """Research should inspire our own photography, not by copying, by adapting techniques
  and linking them to our themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29453-1
  a curric:KeyLearningPoint ;
  rdfs:label """A strong concept uses imagery and techniques from your research in new, personal
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29453-2
  a curric:KeyLearningPoint ;
  rdfs:label "Visual experimentation helps develop complex design ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.356478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29453-3
  a curric:KeyLearningPoint ;
  rdfs:label "Visual experimentation can be digital or physical."@en ;
  dcterms:modified "2026-06-07T15:30:29.356482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29453-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining motifs, materials and surface manipulation can generate a unique textile
  outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28273-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sculpture is a three-dimensional art form."@en ;
  dcterms:modified "2026-06-07T15:30:29.356565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28273-2
  a curric:KeyLearningPoint ;
  rdfs:label "Principles include form, space, balance, texture, proportion, and movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.356569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28273-3
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional and modern sculpture transform materials into expressive forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.356573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29202-1
  a curric:KeyLearningPoint ;
  rdfs:label """Designers respond creatively to a given theme through research and
  experimentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.357173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29202-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mood boards and thumbnail sketches help develop and refine visual ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.357178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29202-3
  a curric:KeyLearningPoint ;
  rdfs:label "A successful graphic design communicates a concept clearly and creatively."@en ;
  dcterms:modified "2026-06-07T15:30:29.357182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29202-4
  a curric:KeyLearningPoint ;
  rdfs:label "The creative process involves multiple iterations and decision-making."@en ;
  dcterms:modified "2026-06-07T15:30:29.357186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29461-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning helps ensure your final piece reflects your ideas and style."@en ;
  dcterms:modified "2026-06-07T15:30:29.358232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29461-2
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing techniques and materials should support your design voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.358237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29461-3
  a curric:KeyLearningPoint ;
  rdfs:label "A final piece should show thought, skill, and a personal response."@en ;
  dcterms:modified "2026-06-07T15:30:29.358243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Feedback provides a broader range of interpretations and helps identify issues that
  might otherwise be missed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28753-2
  a curric:KeyLearningPoint ;
  rdfs:label """Critiques offer insight into how an audience might perceive your work, revealing
  what is communicated effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28753-3
  a curric:KeyLearningPoint ;
  rdfs:label """The process helps creatives learn what makes work successful and develops their
  ability to assess and self-assess."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28753-4
  a curric:KeyLearningPoint ;
  rdfs:label """Group critiques foster connections leading to potential collaborations, mentorships
  and a supportive community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28753-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can learn from the critiques given to others, absorbing insights and vocabulary
  that can inform your own work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28250-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dry media techniques such as hatching, cross-hatching and smudging can be used to
  create varied textures and tones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different dry materials such as pencils, pens, markers and pastels can be used to
  convey texture and mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28250-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dry materials are ready to use immediately, making them beneficial for quick
  sketches and on-the-go work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28276-1
  a curric:KeyLearningPoint ;
  rdfs:label """Found materials let artists explore new forms, textures and ideas not possible with
  traditional sculpture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28276-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using found objects supports recycling, sustainability and an eco-friendly approach
  to making art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28276-3
  a curric:KeyLearningPoint ;
  rdfs:label """Found materials bring history and meaning, letting artists comment on culture,
  history, or social issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knives or scissors to cut cardboard into desired shapes. Pieces can be bent or
  folded to create dimensional forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stacking multiple layers of cardboard adds depth and dimension. Layers can be cut
  differently creating unique profiles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Roll cardboard into cylinders or fold into angular shapes; origami techniques can
  also be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28520-1
  a curric:KeyLearningPoint ;
  rdfs:label """Clarify the theme or concept you want to explore. This could be personal
  experiences, social issues or emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28520-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gather inspiration from various sources, such as existing artworks, literature,
  nature, or personal experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28520-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decide on the material for your surface, including canvas, wood, paper, or textiles,
  to align with your concept"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29454-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning helps ensure your final piece reflects your ideas and style."@en ;
  dcterms:modified "2026-06-07T15:30:29.362206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29454-2
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing techniques and materials should support your design voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.362210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29454-3
  a curric:KeyLearningPoint ;
  rdfs:label "A final piece should show thought, skill and a personal response."@en ;
  dcterms:modified "2026-06-07T15:30:29.362214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28739-1
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of materials becomes part of the message; each one can evoke different
  emotions, histories, or associations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28739-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful mixed media sculpture depends on understanding how to physically and
  visually integrate different materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28739-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mixed media expands creative boundaries, encouraging experimentation, recycled
  elements, or unconventional techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28280-1
  a curric:KeyLearningPoint ;
  rdfs:label "When casting, plaster is poured directly over a model to create a mould."@en ;
  dcterms:modified "2026-06-07T15:30:29.363548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28280-2
  a curric:KeyLearningPoint ;
  rdfs:label "When casting, the model is coated with a release agent to prevent sticking."@en ;
  dcterms:modified "2026-06-07T15:30:29.363552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28280-3
  a curric:KeyLearningPoint ;
  rdfs:label "A mould can be created in two halves, allowing for more complex shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.363555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28280-4
  a curric:KeyLearningPoint ;
  rdfs:label """Applying a thin layer of plaster (poured or brushed) to a model and building up
  several layers creates a solid shell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28204-1
  a curric:KeyLearningPoint ;
  rdfs:label """First-hand resources allow artists to draw from their own experiences, lending
  authenticity to their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28204-2
  a curric:KeyLearningPoint ;
  rdfs:label """By exploring subjects directly, artists can offer unique viewpoints that are
  informed by their individual insights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28204-3
  a curric:KeyLearningPoint ;
  rdfs:label """First-hand experiences immerse artists in specific environments, which can spark
  inspiration and influence their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28204-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engaging directly with subjects encourages playfulness and experimentation."@en ;
  dcterms:modified "2026-06-07T15:30:29.363768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28712-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relief printing can be advanced using layering, reduction techniques, and texture
  plate applications."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28712-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precision in registration is vital to produce professional multi-layered prints."@en ;
  dcterms:modified "2026-06-07T15:30:29.363797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28712-3
  a curric:KeyLearningPoint ;
  rdfs:label "Experimentation with texture plates and surfaces enhances creative outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.363801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28711-1
  a curric:KeyLearningPoint ;
  rdfs:label "Printing methods share core principles but create different effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.365985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Registration and layering add complexity and precision to designs."@en ;
  dcterms:modified "2026-06-07T15:30:29.365989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28711-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compositional choices affect clarity and visual impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.365993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28262-1
  a curric:KeyLearningPoint ;
  rdfs:label """Repeat patterns create a sense of rhythm and continuity, making the fabric visually
  appealing and harmonious."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28262-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers often scale the motif up or down to change its size and add variety in a
  repeat pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28262-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many textile traditions repeat patterns, allowing artists to connect their work to
  cultural heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28706-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use composition and perspective to create expression, conveying emotion and
  mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28706-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different tools change mark-making, which alters the expressive quality of a
  painting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28706-3
  a curric:KeyLearningPoint ;
  rdfs:label """Choice in expression, perspective, composition, and mark-making shape how the viewer
  emotionally responds to an artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28682-1
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes offer a diverse array of colours, textures, and forms that inspire
  artists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28682-2
  a curric:KeyLearningPoint ;
  rdfs:label """Working in 3D allows artists to play with scale and perspective, creating immersive
  environments that engage viewers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28682-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often reflect on historical events or changes in landscapes over time, their
  work can engage with deeper themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27945-1
  a curric:KeyLearningPoint ;
  rdfs:label """The journey to a finished artwork is shaped by experiments, changes, and thoughtful
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Artists often share ideas and work to receive constructive feedback."@en ;
  dcterms:modified "2026-06-07T15:30:29.370417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27945-3
  a curric:KeyLearningPoint ;
  rdfs:label """Critiques are about giving different perspectives. The artist decides which
  suggestions align with their artistic voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27945-4
  a curric:KeyLearningPoint ;
  rdfs:label """The iterative refers to the process of refining and developing ideas through
  experimentation, reflection, and revision."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28252-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating images, or combining them with type, allows designers to create unique
  visuals that capture interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28252-2
  a curric:KeyLearningPoint ;
  rdfs:label """Images and type may need to be resized or reformatted for various media to ensure
  they look good across all platforms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28252-3
  a curric:KeyLearningPoint ;
  rdfs:label """Image and text manipulation allows designers to experiment with different styles,
  colours and layouts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28746-1
  a curric:KeyLearningPoint ;
  rdfs:label """Resources influence your understanding and interpretation so you should think
  critically when making selections"""@en ;
  dcterms:modified "2026-06-07T15:30:29.373916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28746-2
  a curric:KeyLearningPoint ;
  rdfs:label """Incorporating visual elements related to your experiences can enhance your response
  and provide additional context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Your background shapes your perspective, be mindful of this when making work."@en ;
  dcterms:modified "2026-06-07T15:30:29.373927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28746-4
  a curric:KeyLearningPoint ;
  rdfs:label """New insights may emerge that enrich your narrative, revise your response as you
  reflect on your experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28282-1
  a curric:KeyLearningPoint ;
  rdfs:label """By utilising a wide range of source materials, sculptors enrich their creative
  processes, resulting in dynamic designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28282-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring sources introduces sculptors to various styles, concepts, and cultural
  influences, fostering creativity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28688-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists translate nature’s colours, textures, and forms into textiles that capture
  the feel of landscapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Textiles can reflect cultural ties to place, exploring history, tradition, and
  people’s links to the land."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28688-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many artists use eco materials and methods to highlight the need to protect
  landscapes and work sustainably."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28263-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists analyse sources and identify shapes, patterns, textures, and meanings that
  can inspire textile designs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28263-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the cultural, historical, and social context of a source adds depth
  and relevance to a design."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28263-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sources can be reinterpreted and transformed into original textile outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.376838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28279-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carving into the surface of a leather hard piece to create designs, often reveals a
  contrasting colour underneath."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28279-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scoring the surfaces of clay pieces and applying slip (liquid clay) helps to bond
  them when joining."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28279-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using pre-made molds to shape clay, allows for intricate designs and uniformity."@en ;
  dcterms:modified "2026-06-07T15:30:29.376873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28724-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital brushes can mimic traditional media whilst offering flexibility and
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28724-2
  a curric:KeyLearningPoint ;
  rdfs:label "Opacity and flow settings control subtlety and intensity of brushstrokes."@en ;
  dcterms:modified "2026-06-07T15:30:29.377052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28724-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brush customisation can be used to express a personal artistic style."@en ;
  dcterms:modified "2026-06-07T15:30:29.377057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28724-4
  a curric:KeyLearningPoint ;
  rdfs:label """Layering and blending allows digital artists to gradually build up elements and
  create smooth transitions between them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27941-1
  a curric:KeyLearningPoint ;
  rdfs:label "Themes act as a springboard for artists to develop ideas and make art"@en ;
  dcterms:modified "2026-06-07T15:30:29.378570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27941-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes can be interpreted in different ways by different artists"@en ;
  dcterms:modified "2026-06-07T15:30:29.378574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mind maps or ideas showers are a useful way to record interpretation and explore
  aspects of themes"""@en ;
  dcterms:modified "2026-06-07T15:30:29.378577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28773-1
  a curric:KeyLearningPoint ;
  rdfs:label """Talking about artwork helps the artist and the audience understand ideas, process,
  and intention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28773-2
  a curric:KeyLearningPoint ;
  rdfs:label "Verbal explanations can occur in informal conversations or formal presentations."@en ;
  dcterms:modified "2026-06-07T15:30:29.379863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28773-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on and discussing artwork helps develop critical thinking and clarity of
  expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28773-4
  a curric:KeyLearningPoint ;
  rdfs:label """Linking materials, techniques, and artistic choices to ideas deepens understanding
  of the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28684-1
  a curric:KeyLearningPoint ;
  rdfs:label """Designers think about their 3D designs form and function so that it could protect,
  contain, or display."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28684-2
  a curric:KeyLearningPoint ;
  rdfs:label """Design elements such as structure, surface, and material can define, obscure, or
  connect interior and exterior space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28684-3
  a curric:KeyLearningPoint ;
  rdfs:label """3D design can express emotion, or narrative by contrasting the outside appearance
  with what’s hidden or revealed inside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28696-1
  a curric:KeyLearningPoint ;
  rdfs:label """Designers can represent physical and psychological boundaries through interior and
  exterior spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28696-2
  a curric:KeyLearningPoint ;
  rdfs:label """Designers might use framing, perspective and scale to connect or separate inside and
  outside spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Designs can explore the relationship between personal, private spaces and wider,
  public or natural settings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some graphic designers explore the boundary between external appearance and internal
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28675-1
  a curric:KeyLearningPoint ;
  rdfs:label "The inherent beauty of natural forms provides artists with endless inspiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.381712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28675-2
  a curric:KeyLearningPoint ;
  rdfs:label """The diversity of colours, textures, and shapes found in nature can lead to visually
  striking works of art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28675-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural forms often use flowing, asymmetrical elements that contrast geometric
  rigidity, enabling dynamic compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28206-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists may select from existing first-hand resources to develop and explore new
  creative outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28206-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photos can be developed in ways, such as collage, stitching, drawing, or digital
  editing, to create new visual ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28206-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with various materials and techniques helps develop drawings with
  richer textures and deeper expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24143-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consider the emotional impact of the colour scheme and how it contributes to the
  work's mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24143-2
  a curric:KeyLearningPoint ;
  rdfs:label "Examine the arrangement of elements within the artwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.382511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24143-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analyse how the materials and techniques serve the themes or concepts of the
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28734-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists typically begin with sketches, maquettes, or 3D references to guide the
  process and avoid costly mistakes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28734-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skilled carvers learn how to read the grain, texture, or fault lines in the material
  to avoid cracking or chipping."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28734-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carving typically moves from blocking out large forms to gradually refining shapes,
  adding surface details and textures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28839-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shape and form are fundamental elements of design that help artists communicate
  ideas and emotions visually."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28839-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different shapes can evoke specific associations or emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.382547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28839-3
  a curric:KeyLearningPoint ;
  rdfs:label """Form gives depth and volume to a piece, making it more dynamic and realistic,
  especially in sculpture and painting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29200-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphic designers might use a combination of traditional and digital approaches."@en ;
  dcterms:modified "2026-06-07T15:30:29.383822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29200-2
  a curric:KeyLearningPoint ;
  rdfs:label """By experimenting with ways of working and the design elements, designers can develop
  their graphic design style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29200-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nothing is 100% original! Every artist and designer is influenced by something."@en ;
  dcterms:modified "2026-06-07T15:30:29.383830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29200-4
  a curric:KeyLearningPoint ;
  rdfs:label """Designers often take inspiration from other work and places and remix them adding
  their own twist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional and digital methods can be combined in art to create a range of visual
  outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analogue and digital media can be merged effectively by using composition
  principles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28720-3
  a curric:KeyLearningPoint ;
  rdfs:label """Textures and surfaces can be used in digital media to create images which look
  handmade."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28752-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials have distinct qualities which influence the creation and impact of your
  final outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28752-2
  a curric:KeyLearningPoint ;
  rdfs:label """Materials and techniques should be assessed to establish if they align with an
  artwork's intended message or concept."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28752-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating your proficiency with different techniques helps to identify areas
  requiring further practice or exploration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28752-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using suitable vocabulary will help you communicate your ideas clearly and show that
  you understand the subject well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28186-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different ways to document work: filming discussions, and recording
  voices, using transcription software."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28186-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to find connections between the artists and sources you have
  chosen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Collaborating with peers, sharing insights and techniques fosters a supportive
  creative environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28237-1
  a curric:KeyLearningPoint ;
  rdfs:label """Charcoal can create expressive, bold lines and rich blacks which is effective for
  dramatic contrasts and blending."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28237-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dry media, like charcoal, allows for loose and expressive marks, making it ideal for
  capturing movement and emotion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28237-3
  a curric:KeyLearningPoint ;
  rdfs:label """Techniques such as smudging (with fingers or tools) can create smooth gradients and
  depth, particularly with charcoal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28257-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weaving can be expressive and exciting when interesting materials are used to weave
  with."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28257-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tapestry weaving techniques are not difficult and using a fringe effect is a easy
  technique to create texture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using fibre to build tone and texture, different thicknesses and types of
  weaves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28837-1
  a curric:KeyLearningPoint ;
  rdfs:label """Line is used in different ways within each endorsement, including light drawings in
  photography and drawing with stitch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28837-2
  a curric:KeyLearningPoint ;
  rdfs:label """The quality of a line can convey mood e.g. jagged lines might evoke tension, while
  smooth lines can feel calm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28837-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lines can also carry symbolic meanings, such as the use of horizontal lines for
  stability or vertical lines for growth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28187-1
  a curric:KeyLearningPoint ;
  rdfs:label """Experimentation allows artists to explore new themes and concepts that may not
  emerge through traditional methods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28187-2
  a curric:KeyLearningPoint ;
  rdfs:label """Experimentation encourages artists to embrace uncertainty and failure, leading to
  discoveries that enhance their work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28187-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimentation allows artists to refine their ideas through repeated
  investigations, leading to more innovative work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28840-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texture can make an artwork more engaging by providing a tactile quality that draws
  viewers in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28840-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different textures can evoke different feelings. For example, rough textures might
  convey rawness or chaos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28840-3
  a curric:KeyLearningPoint ;
  rdfs:label """Texture can create contrast, emphasising certain areas or elements and adding a
  sense of three-dimensions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28840-4
  a curric:KeyLearningPoint ;
  rdfs:label """Textures can carry meaning, reflecting concepts like decay, growth or
  transformation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27938-1
  a curric:KeyLearningPoint ;
  rdfs:label "Experimenting with new techniques expands artistic possibilities."@en ;
  dcterms:modified "2026-06-07T15:30:29.400116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27938-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many artists experiment. They rule-break and turn mistakes into opportunities for
  developing their artistic voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27938-3
  a curric:KeyLearningPoint ;
  rdfs:label """Open-ended experimentation allows artists to make mistakes that could lead to
  unexpected ideas and new techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28676-1
  a curric:KeyLearningPoint ;
  rdfs:label "Landscapes offer a rich tapestry of colours, textures and forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.400733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Landscapes let artists explore scale, perspective and composition from vast vistas
  to intimate details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28676-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use landscapes to celebrate nature’s beauty and foster appreciation for
  ecological diversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28705-1
  a curric:KeyLearningPoint ;
  rdfs:label """Painters us a range of brushwork techniques including: dry brush, impasto feathering
  and stipping."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28705-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brush choice and handling affect texture and precision."@en ;
  dcterms:modified "2026-06-07T15:30:29.400749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28705-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brushwork effects contribute to mood, form, and surface."@en ;
  dcterms:modified "2026-06-07T15:30:29.400753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28261-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hand stitch techniques are a creative way to decorate fabric by designing unique
  motifs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28261-2
  a curric:KeyLearningPoint ;
  rdfs:label """Running stitch is a versatile stitch that allows you to create a lot of detail in
  your work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28261-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hand stitching is not only for making clothes – you can make art with stitch"@en ;
  dcterms:modified "2026-06-07T15:30:29.400801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28562-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consider how the top layer contributes to the overall visual appeal of the artwork.
  Does it create a strong focal point?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.400807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28562-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate whether the top layer integrates well with the underlying layers."@en ;
  dcterms:modified "2026-06-07T15:30:29.400811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Are the brushstrokes, patterns, or materials used effectively to include detail and
  convey your intended message."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29443-1
  a curric:KeyLearningPoint ;
  rdfs:label """Despite diverse backgrounds and approaches, common threads emerge in how
  photographers develop a journal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29443-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers use journals to think through ideas and develop concepts for future
  projects or photoshoots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29443-3
  a curric:KeyLearningPoint ;
  rdfs:label """Journals are a space for practising techniques, experimenting with styles, and
  testing materials without pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28681-1
  a curric:KeyLearningPoint ;
  rdfs:label """Natural forms offer organic shapes and lines that can contrast with rigid
  geometry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use biomimicry to design functional, efficient and sustainable objects
  inspired by nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28681-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nature inspired design can raise awareness of climate change, deforestation and
  biodiversity loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28681-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sculpture based on natural forms can inspire action by highlighting environmental
  issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28838-1
  a curric:KeyLearningPoint ;
  rdfs:label """Variations in tone create the illusion of 3D space, makes objects more lifelike, and
  attracts attention"""@en ;
  dcterms:modified "2026-06-07T15:30:29.407561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28838-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colour is a powerful tool in the communication of a thought, idea or emotion"@en ;
  dcterms:modified "2026-06-07T15:30:29.407565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28838-3
  a curric:KeyLearningPoint ;
  rdfs:label """Colour encompasses both hue and tone, and its combination can influence how viewers
  perceive and react to the artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28838-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different colours can symbolise various ideas or emotions, allowing artists to
  communicate more than just the visual."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27946-1
  a curric:KeyLearningPoint ;
  rdfs:label "An artist's final piece or outcome is often a culmination of ideas and work."@en ;
  dcterms:modified "2026-06-07T15:30:29.415927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27946-2
  a curric:KeyLearningPoint ;
  rdfs:label """When studying art, there are specific requirements about how to plan and demonstrate
  planning for a final piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27946-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artists often identify recurring themes, materials and techniques as they look back
  at their developing ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28687-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists use nature’s beauty and patterns to create textile works that reflect its
  structure and complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28687-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nature’s colours and patterns inspire textile designs that connect with viewers both
  visually and emotionally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural forms in textiles can express emotion or memory, deepening the viewer's
  connection to the work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28235-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditionally, an artist statement is a piece of writing where artists explain their
  work, methods, and intentions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28235-2
  a curric:KeyLearningPoint ;
  rdfs:label """Across history and cultures, artists have explained their work in many different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28235-3
  a curric:KeyLearningPoint ;
  rdfs:label """The statement is part of how art is experienced, it helps the audience engage more
  deeply."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28235-4
  a curric:KeyLearningPoint ;
  rdfs:label "While traditionally written, it can also take other forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.422017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28691-1
  a curric:KeyLearningPoint ;
  rdfs:label """Portraits and figures can be powerful tools in graphic design to express messages,
  emotion, or identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28691-2
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic designers often stylise figures to enhance meaning and create a signature
  visual style."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28691-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deconstructing design helps us understand how the elements of art contribute to
  visual impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28691-4
  a curric:KeyLearningPoint ;
  rdfs:label "Personal identity can inform meaningful visual design choices."@en ;
  dcterms:modified "2026-06-07T15:30:29.422063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27942-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing key themes and techniques used by an artist deepens our understanding of
  their art."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27942-2
  a curric:KeyLearningPoint ;
  rdfs:label """By studying the work of other artists, artists enrich their art and develop their
  own artistic voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27942-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inspirational art can be found in many places offering diverse opportunities for
  research and discovery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27942-4
  a curric:KeyLearningPoint ;
  rdfs:label "Artist research can be recorded visually and with annotations."@en ;
  dcterms:modified "2026-06-07T15:30:29.422399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28249-1
  a curric:KeyLearningPoint ;
  rdfs:label """Develop an understanding of the properties and behaviour of wet media by exploring a
  range of wet media techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28249-2
  a curric:KeyLearningPoint ;
  rdfs:label """Develop control over brush handling and water-to-paint ratios to create different
  effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28249-3
  a curric:KeyLearningPoint ;
  rdfs:label """Create graphic outcomes that communicate moods or themes through wet media
  techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28247-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple design is easily recognisable and memorable. Complex logos can be difficult
  to reproduce and may lose clarity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28247-2
  a curric:KeyLearningPoint ;
  rdfs:label """Organising text in a way that creates a clean, professional look. Consistent
  alignment helps guide the reader's eye."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28247-3
  a curric:KeyLearningPoint ;
  rdfs:label """The design should reflect the brand's identity and values, resonating with its
  target audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28247-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong logo should be distinctive and easy to recall, helping to create brand
  recognition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28671-1
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers can use light and dark to create mood, atmosphere and contrast in
  photography."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28671-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can find symbolic meanings of light and darkness across different cultures and
  art movements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28671-3
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers can experiment with using light and shadow to define form, space and
  focus in their photographs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28678-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can represent physical and psychological boundaries through interior and
  exterior spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28678-2
  a curric:KeyLearningPoint ;
  rdfs:label """Artists might use framing, perspective, and scale to connect or separate inside and
  outside spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Artwork can explore the relationship between personal, private spaces and wider,
  public or natural settings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28678-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some artists explore the boundary between external appearance and internal
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28723-1
  a curric:KeyLearningPoint ;
  rdfs:label "Transformation goes beyond enhancement; it creates entirely new visual outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.584682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28723-2
  a curric:KeyLearningPoint ;
  rdfs:label "Masks and blending modes enable complex, non-destructive edits."@en ;
  dcterms:modified "2026-06-07T15:30:29.584687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28723-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composite images can communicate imaginative or surreal concepts."@en ;
  dcterms:modified "2026-06-07T15:30:29.584691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28723-4
  a curric:KeyLearningPoint ;
  rdfs:label "Opacity adjustments allow subtle control over transformations."@en ;
  dcterms:modified "2026-06-07T15:30:29.584696Z"^^xsd:dateTime .

