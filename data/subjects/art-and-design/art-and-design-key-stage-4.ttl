  dcterms:modified "2026-06-07T15:30:29.307767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28741-1
  a curric:KeyLearningPoint ;
  rdfs:label "Collaborations often showcase innovative techniques and approaches."@en ;
  dcterms:modified "2026-06-07T15:30:29.307794Z"^^xsd:dateTime .

