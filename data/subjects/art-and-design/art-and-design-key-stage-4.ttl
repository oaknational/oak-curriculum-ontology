  dcterms:modified "2026-06-07T15:30:29.331112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28269-1
  a curric:KeyLearningPoint ;
  rdfs:label """In film photography, darkrooms are used to develop pictures that are taken on a
  physical roll of film."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28269-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographs are produced using light-sensitive paper that is exposed to light that
  passes through the negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28269-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chemicals are then used to develop the image."@en ;
  dcterms:modified "2026-06-07T15:30:29.331155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28269-4
  a curric:KeyLearningPoint ;
  rdfs:label "Contact sheets can be used to easily see all of the pictures on a roll of film."@en ;
  dcterms:modified "2026-06-07T15:30:29.331159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28269-5
  a curric:KeyLearningPoint ;
  rdfs:label "Test strips are used to measure how much exposure each picture should have."@en ;
  dcterms:modified "2026-06-07T15:30:29.331163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artists can use light and dark to create mood, atmosphere and contrast in
  artworks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28677-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can find symbolic meanings of light and darkness across different cultures and
