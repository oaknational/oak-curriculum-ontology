  dcterms:modified "2026-06-07T15:30:29.335112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28268-1
  a curric:KeyLearningPoint ;
  rdfs:label "Motion in photography refers to the way movement is captured or conveyed."@en ;
