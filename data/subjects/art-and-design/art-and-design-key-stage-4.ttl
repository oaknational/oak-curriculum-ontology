oakcurric:keylearningpoint-lesson-28680-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aesthetic choices in 3D design, like material, can contribute to how objects are
  perceived emotionally and culturally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28680-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prototypes and sketched mockups help designers evaluate how a design performs in
  real space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28668-1
  a curric:KeyLearningPoint ;
  rdfs:label """Objects often carry symbolic weight, allowing artists to convey complex themes and
  narratives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28668-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photographers can choose objects that hold personal significance, creating works
  that resonate emotionally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28668-3
  a curric:KeyLearningPoint ;
  rdfs:label """By arranging objects thoughtfully, photographers can guide viewers through a visual
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Layering and blending techniques such as wet on wet, dry brush, glazing, scumbling
  and sgraffito create depth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring multiple ways of blending helps achieve varied effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.331101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layering adds tonal variation and helps create mood or a sense of space."@en ;
  dcterms:modified "2026-06-07T15:30:29.331107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28710-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blending and layering choices affect how the artwork feels and the response it
