# ----------------------------------------------------------------------
# Units
# ----------------------------------------------------------------------

oakcurric:unit-3746
  a curric:Unit ;
  rdfs:label "Responding to themes and genres"@en ;
  curric:slug "responding-to-themes-and-genres" ;
  rdfs:comment """Pupils can select or rotate through these units that feature diverse and inclusive
  artist references, consider application of their skill strengths and encourage critical
  thinking and personal connections."""@en ;
  curric:whyThisWhyNow """Pupils have begun to establish their own artistic identity and are able to
  investigate different sources and present a personal response. In this unit they extend their
  knowledge, understanding and skills through engagement with a given theme. Pupils will learn
  how to select sources that are most appropriate to the theme, and to inform their creative
  journey.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3746-1 ,
    oakcurric:priorknowledge-3746-2 ,
    oakcurric:priorknowledge-3746-3 ;
  curric:id "3746"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.326070Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-sculpt ,
    oakcurric:thread-draw ,
    oakcurric:thread-paint ,
    oakcurric:thread-digital ,
    oakcurric:thread-print ,
    oakcurric:thread-collage ,
    oakcurric:thread-textiles ,
    oakcurric:thread-design .

oakcurric:unit-3257
  a curric:Unit ;
  rdfs:label "First sustained project: working from a theme"@en ;
  curric:slug "first-sustained-project-working-from-a-theme" ;
  rdfs:comment """This is an independent, pupil-led unit where pupils develop their own creative
  process. Having learned the key components of shaping an artistic voice, they will now
  make choices about themes, techniques, and processes, articulating and evaluating their
  artistic journey."""@en ;
  curric:whyThisWhyNow """This teacher led unit builds on the previous learning in the curriculum in
  which pupils have widened their understanding of art, craft and design. They have developed
  an appreciation of its cultural and historical contexts and have developed their critical
  thinking, innovation, and taken responsibility for their creative decisions. This is the
  right point for students to become more independent and make connections with their process
  and the world around them.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3257-1 ,
    oakcurric:priorknowledge-3257-2 ,
    oakcurric:priorknowledge-3257-3 ,
    oakcurric:priorknowledge-3257-4 ,
    oakcurric:priorknowledge-3257-5 ;
  curric:id "3257"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.958009Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-paint ,
    oakcurric:thread-digital ,
    oakcurric:thread-print ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-textiles ,
    oakcurric:thread-draw ,
    oakcurric:thread-collage ,
    oakcurric:thread-design .

oakcurric:unit-3747
  a curric:Unit ;
  rdfs:label "Foundation workshops: developing skills"@en ;
  curric:slug "foundation-workshops-developing-skills" ;
  rdfs:comment """This teacher-led unit deepens pupils' skills within endorsements. Through short
  workshop activities, pupils further explore a range of materials and techniques. They
  develop studies focused on the elements and principles of art in practice."""@en ;
  curric:whyThisWhyNow """Pupils have made progress in developing their creative practice, learning
  about their strengths. This unit which breaks up the two independent units with a more
  teacher led one, deepens the pupils skills within their endorsements. Through a series of
  short workshop activities, students explore further with a range of materials and techniques.
  They see how the different endorsements can use drawing for purpose in addition to their own
  specialist skills.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3747-1 ,
    oakcurric:priorknowledge-3747-2 ,
    oakcurric:priorknowledge-3747-3 ,
    oakcurric:priorknowledge-3747-4 ,
    oakcurric:priorknowledge-3747-5 ,
    oakcurric:priorknowledge-3747-6 ,
    oakcurric:priorknowledge-3747-7 ;
  curric:id "3747"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.828435Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-textiles ,
    oakcurric:thread-print ,
    oakcurric:thread-digital ,
    oakcurric:thread-paint ,
    oakcurric:thread-draw ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-collage ,
    oakcurric:thread-design .

oakcurric:unit-3480
  a curric:Unit ;
  rdfs:label "Curating an exhibition"@en ;
  curric:slug "curating-an-exhibition" ;
  rdfs:comment """This teacher-led unit concludes the course with a physical or virtual exhibition.
  Pupils, having been introduced to curating, will select work based on quality and
  criteria, explore presentation, and mount and frame their pieces."""@en ;
  curric:whyThisWhyNow """At this final stage of the course, the focus is on celebrating pupils'
  work and achievements. Pupils will select their best pieces and learn how to present them for
  exhibition. They will connect their work with the practices of artists preparing for
  exhibitions, giving them real-life experience in showcasing their art.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3480-1 ,
    oakcurric:priorknowledge-3480-2 ,
    oakcurric:priorknowledge-3480-3 ;
  curric:id "3480"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.995849Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-collage ,
    oakcurric:thread-digital .

oakcurric:unit-3715
  a curric:Unit ;
  rdfs:label "Foundation workshops: an introduction to the areas of study"@en ;
  curric:slug "foundation-workshops-an-introduction-to-the-areas-of-study" ;
  rdfs:comment """This is a teacher led unit which introduces to pupils to the skills within their
  endorsements. Through a series of workshop activities, students experiment with a range of
  materials and techniques. They develop a range of studies exploring mark making media,
  print and mixed media."""@en ;
  curric:whyThisWhyNow """This unit builds on pupils' foundational knowledge and skills from
  previous years, introducing more advanced techniques and processes. By exploring different
  media, materials, and methods, pupils gain versatility and confidence in their creative
  abilities. This unit prepares pupils for the diverse challenges of higher-level art projects
  and encourages them to experiment and innovate. It also emphasises the importance of refining
  and controlling artistic processes, essential for producing high-quality work.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3715-1 ;
  curric:id "3715"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.081873Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-digital ,
    oakcurric:thread-paint ,
    oakcurric:thread-draw ,
    oakcurric:thread-collage ,
    oakcurric:thread-textiles ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-print ,
    oakcurric:thread-design .

oakcurric:unit-2739
  a curric:Unit ;
  rdfs:label "Foundation workshops: selecting primary sources and recording observations"@en ;
  curric:slug "foundation-workshops-selecting-primary-sources-and-recording-observations" ;
  rdfs:comment """This teacher-led unit introduces key principles and four assessment objectives
  through various drawing activities in the studio and on-site. Pupils will explore diverse
  sources, inspired by themes from a museum or site visit."""@en ;
  curric:whyThisWhyNow """This unit is useful for pupils as they move into GCSE or alternative
  courses, where they will encounter more complex and diverse ideas. Pupils will become more
  independent in their practice, chosing themes and processes inspired by their own interests
  and strengths. This unit encourages students to make their own creative decisions, find and
  create their resources. This empowers the students to judge critically both the quality and
  relevence of their chosen materials.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2739-1 ,
    oakcurric:priorknowledge-2739-2 ,
    oakcurric:priorknowledge-2739-3 ;
  curric:id "2739"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.136260Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-paint ,
    oakcurric:thread-digital ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-textiles ,
    oakcurric:thread-collage ,
    oakcurric:thread-draw ,
    oakcurric:thread-print ,
    oakcurric:thread-design .

oakcurric:unit-3489
  a curric:Unit ;
  rdfs:label "Second sustained project: working from a theme changing perspectives"@en ;
  curric:slug "sustained-project-working-from-a-theme-changing-perspectives" ;
  rdfs:comment """This unit introduces collaborative working methods, even when assessed
  individually. Pupils will work together to respond to a theme, creating first-hand
  sources, then respond individually. They’ll learn to contribute to larger projects while
  maintaining their own identity."""@en ;
  curric:whyThisWhyNow """At this stage, pupils have an increasing awareness of their own developing
  practice and creative intentions. This unit provides the opportunity for pupils to engage in
  targeted, intensive practice and experimentation with materials, techniques, and processes.
  They are beginning to identify key areas for development, focusing on improving technical
  skills to better realise their intentions. The unit encourages refinement of their ideas and
  practice, allowing them to explore more advanced approaches to their work while developing
  greater control over their chosen media and processes.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3489-1 ,
    oakcurric:priorknowledge-3489-2 ;
  curric:id "3489"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.238624Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-digital ,
    oakcurric:thread-paint ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-collage ,
    oakcurric:thread-textiles ,
    oakcurric:thread-print ,
    oakcurric:thread-draw ,
    oakcurric:thread-design .

oakcurric:unit-3688
  a curric:Unit ;
  rdfs:label "Finding your artistic voice: an introduction to the creative process"@en ;
  curric:slug "finding-your-artistic-voice-an-introduction-to-the-creative-process" ;
  rdfs:comment """This unit introduces pupils to developing their own voice. They will learn about
  key components in shaping their artistic voice, including research, reflection and
  refining ideas. The unit takes them on a journey of discovery leading to planning a final
  piece."""@en ;
  curric:whyThisWhyNow """This teacher led unit builds on the previous learning in the curriculum in
  which pupils have widened their understanding of art craft and design. They have developed an
  appreciation of its cultural and historical contexts and have developed their critical
  thinking, innovation, and taken responsibility for their creative decisions. This is the
  point in which the pupils are exploring possibilities for communication, how they want to
  communicate and what they want to say through their art work. The are making decisions about
  thier technical strengths and weaknesses and choosing.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3688-1 ,
    oakcurric:priorknowledge-3688-2 ,
    oakcurric:priorknowledge-3688-3 ,
    oakcurric:priorknowledge-3688-4 ;
  curric:id "3688"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.242580Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-draw ,
    oakcurric:thread-print ,
    oakcurric:thread-paint ,
    oakcurric:thread-collage ,
    oakcurric:thread-textiles ,
    oakcurric:thread-sculpt .

oakcurric:unit-3748
  a curric:Unit ;
  rdfs:label "Foundation workshops: revisiting elements of art and principles of art"@en ;
  curric:slug "foundation-workshops-revisiting-elements-of-art-and-principles-of-art" ;
  rdfs:comment """This unit revisits and reframes the key principles and elements of art. Pupils
  will study how artists use these elements with greater sophistication. They will carefully
  examine and analyse the elements and principles, applying them to their chosen art forms
  and endorsements."""@en ;
  curric:whyThisWhyNow """This unit is important for pupils at the beginning of the GCSE course to
  build on their understanding of the building blocks for making art. They will have explored
  what defines art and examined its role across various contexts, pupils have developed
  critical thinking and analytical skills. This unit encourages students to make the necessary
  links between the underyling elements and principles and the work that they, and other
  artists are making.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3748-1 ,
    oakcurric:priorknowledge-3748-2 ,
    oakcurric:priorknowledge-3748-3 ;
  curric:id "3748"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.734845Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-art-and-design-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-digital ,
    oakcurric:thread-draw ,
    oakcurric:thread-paint ,
    oakcurric:thread-print ,
    oakcurric:thread-sculpt ,
    oakcurric:thread-collage ,
    oakcurric:thread-textiles ,
    oakcurric:thread-design .

