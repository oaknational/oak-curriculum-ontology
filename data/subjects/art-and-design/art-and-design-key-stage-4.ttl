# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-symbolism
  a curric:Keyword ;
  schema:name "symbolism"@en ;
  schema:description """figurative language where something is used to represent something other
  than its literal meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347530Z"^^xsd:dateTime .

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-present
  a curric:Keyword ;
  schema:name "present"@en ;
  schema:description "describes habitual events in the present, e.g. ‘I do’"@en ;
  dcterms:modified "2026-06-07T15:30:02.347769Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-07T15:30:02.347888Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-form
  a curric:Keyword ;
  schema:name "form"@en ;
  schema:description """the specific type or category of a poem that determines its structure and
  style"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348016Z"^^xsd:dateTime .

oakcurric:keyword-emulate
  a curric:Keyword ;
  schema:name "emulate"@en ;
  schema:description """to imitate or match something or someone, often with the intention of
  achieving the same success or quality"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348023Z"^^xsd:dateTime .

oakcurric:keyword-mood
  a curric:Keyword ;
  schema:name "Mood"@en ;
  schema:description "The mood of a poem is the emotional undertone."@en ;
  dcterms:modified "2026-06-07T15:30:02.348077Z"^^xsd:dateTime .

oakcurric:keyword-scale
  a curric:Keyword ;
  schema:name "Scale"@en ;
  schema:description "a set of notes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348130Z"^^xsd:dateTime .

oakcurric:keyword-editing
  a curric:Keyword ;
  schema:name "editing"@en ;
  schema:description """the process of improving writing to improve text flow and overall
  quality"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348149Z"^^xsd:dateTime .

oakcurric:keyword-purpose
  a curric:Keyword ;
  schema:name "purpose"@en ;
  schema:description "the aim of the text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348243Z"^^xsd:dateTime .

oakcurric:keyword-development
  a curric:Keyword ;
  schema:name "development"@en ;
  schema:description "improving and building on design ideas to make them better"@en ;
  dcterms:modified "2026-06-07T15:30:02.348273Z"^^xsd:dateTime .

oakcurric:keyword-subject
  a curric:Keyword ;
  schema:name "subject"@en ;
  schema:description """the noun, noun phrase or pronoun that does or is the main verb in the active
  voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348319Z"^^xsd:dateTime .

oakcurric:keyword-object
  a curric:Keyword ;
  schema:name "object"@en ;
  schema:description """the noun, noun phrase or pronoun that receives the action of the main verb
  in the active voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348328Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description "a main idea that the writer wants to focus on"@en ;
  dcterms:modified "2026-06-07T15:30:02.348497Z"^^xsd:dateTime .

oakcurric:keyword-landscape
  a curric:Keyword ;
  schema:name "landscape"@en ;
  schema:description """all the visible features of an area of land, often considered in terms of
  their visual appeal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348586Z"^^xsd:dateTime .

oakcurric:keyword-vista
  a curric:Keyword ;
  schema:name "vista"@en ;
  schema:description """a broad view, often used to create dramatic scenes in landscape
  photography"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348591Z"^^xsd:dateTime .

oakcurric:keyword-perspective
  a curric:Keyword ;
  schema:name "perspective"@en ;
  schema:description "creating depth and distance in a composition"@en ;
  dcterms:modified "2026-06-07T15:30:02.348595Z"^^xsd:dateTime .

oakcurric:keyword-describe
  a curric:Keyword ;
  schema:name "describe"@en ;
  schema:description "add detail to"@en ;
  dcterms:modified "2026-06-07T15:30:02.348678Z"^^xsd:dateTime .

oakcurric:keyword-motion
  a curric:Keyword ;
  schema:name "motion"@en ;
  schema:description "the name for the belief or proposal that is being debated"@en ;
  dcterms:modified "2026-06-07T15:30:02.348759Z"^^xsd:dateTime .

oakcurric:keyword-audience
  a curric:Keyword ;
  schema:name "audience"@en ;
  schema:description "the person or people who read a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348971Z"^^xsd:dateTime .

oakcurric:keyword-layout
  a curric:Keyword ;
  schema:name "layout"@en ;
  schema:description "the way a text is structured"@en ;
  dcterms:modified "2026-06-07T15:30:02.348983Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-recurring
  a curric:Keyword ;
  schema:name "recurring"@en ;
  schema:description "something that appears repeatedly"@en ;
  dcterms:modified "2026-06-07T15:30:02.349316Z"^^xsd:dateTime .

oakcurric:keyword-convey
  a curric:Keyword ;
  schema:name "convey"@en ;
  schema:description "to communicate a message to the reader directly or indirectly"@en ;
  dcterms:modified "2026-06-07T15:30:02.349323Z"^^xsd:dateTime .

oakcurric:keyword-juxtaposition
  a curric:Keyword ;
  schema:name "Juxtaposition"@en ;
  schema:description "when two different things are placed together for contrasting effect"@en ;
  dcterms:modified "2026-06-07T15:30:02.349626Z"^^xsd:dateTime .

oakcurric:keyword-impact
  a curric:Keyword ;
  schema:name "impact"@en ;
  schema:description "have a strong effect on someone or something"@en ;
  dcterms:modified "2026-06-07T15:30:02.349836Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "volume"@en ;
  schema:description """Volume is how much 3D space matter occupies. It is usually measured
  in cm³."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350297Z"^^xsd:dateTime .

oakcurric:keyword-precise
  a curric:Keyword ;
  schema:name "precise"@en ;
  schema:description """Precise measurements have very little spread from the mean value. They are
  values that lie close to each other."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350309Z"^^xsd:dateTime .

oakcurric:keyword-starting-point
  a curric:Keyword ;
  schema:name "starting point"@en ;
  schema:description "the starting point is the place where we begin to write a letter"@en ;
  dcterms:modified "2026-06-07T15:30:02.350772Z"^^xsd:dateTime .

oakcurric:keyword-observation
  a curric:Keyword ;
  schema:name "observation"@en ;
  schema:description """the process of looking closely at something to notice details for recording
  in drawing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350847Z"^^xsd:dateTime .

oakcurric:keyword-texture
  a curric:Keyword ;
  schema:name "texture"@en ;
  schema:description "how something feels when it is touched"@en ;
  dcterms:modified "2026-06-07T15:30:02.350854Z"^^xsd:dateTime .

oakcurric:keyword-annotation
  a curric:Keyword ;
  schema:name "annotation"@en ;
  schema:description """notes added to sketches to explain ideas, describe textures, or record
  thoughts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350859Z"^^xsd:dateTime .

oakcurric:keyword-inspiration
  a curric:Keyword ;
  schema:name "inspiration"@en ;
  schema:description """the process of being mentally stimulated by something to create new
  ideas"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350863Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description """the pattern of stressed and unstressed syllables that creates the beat or
