  dcterms:modified "2026-06-07T15:30:29.314577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25444-1
  a curric:KeyLearningPoint ;
  rdfs:label """Collaboration brings together individuals with different backgrounds, experiences,
