oakcurric:keyword-cattle
  a curric:Keyword ;
  schema:name "cattle"@en ;
  schema:description """Cattle are a group of animals that includes cows, that are often kept for their milk or meat."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183702Z"^^xsd:dateTime .

oakcurric:keyword-plant-based-protein
  a curric:Keyword ;
  schema:name "plant-based protein"@en ;
  schema:description "Plant-based proteins come from plants like beans, nuts, seeds, and grains."@en ;
  dcterms:modified "2026-02-19T08:26:07.183707Z"^^xsd:dateTime .

oakcurric:keyword-waterlogged
  a curric:Keyword ;
  schema:name "waterlogged"@en ;
  schema:description """Land which is waterlogged is full of water or almost covered by a layer of water."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183711Z"^^xsd:dateTime .

oakcurric:keyword-terminal
  a curric:Keyword ;
  schema:name "terminal"@en ;
  schema:description "Cells and batteries have a negative and positive terminal."@en ;
  dcterms:modified "2026-02-19T08:26:07.183745Z"^^xsd:dateTime .

oakcurric:keyword-life-skill
  a curric:Keyword ;
  schema:name "life skill"@en ;
  schema:description "A life skill is a skill that is useful or important in life, such as cooking."@en ;
  dcterms:modified "2026-02-19T08:26:07.183750Z"^^xsd:dateTime .

oakcurric:keyword-taut
  a curric:Keyword ;
  schema:name "taut"@en ;
  schema:description "Taut means to be stretched firmly or tightly."@en ;
  dcterms:modified "2026-02-19T08:26:07.183754Z"^^xsd:dateTime .

oakcurric:keyword-athlete
  a curric:Keyword ;
  schema:name "athlete"@en ;
  schema:description """An athlete is a person who is good at sports or physical exercise, especially one who competes in organised events."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183759Z"^^xsd:dateTime .

oakcurric:keyword-exercises
  a curric:Keyword ;
  schema:name "exercises"@en ;
  schema:description """Exercises involve using effort to move our bodies so that they are fit and healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183763Z"^^xsd:dateTime .

oakcurric:keyword-stretches
  a curric:Keyword ;
  schema:name "stretches"@en ;
  schema:description """Stretches are when you extend your body, or a part of your body, in order to stretch your muscles."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183768Z"^^xsd:dateTime .

oakcurric:keyword-depend
  a curric:Keyword ;
  schema:name "depend"@en ;
  schema:description "To depend on is to rely upon."@en ;
  dcterms:modified "2026-02-19T08:26:07.183790Z"^^xsd:dateTime .

oakcurric:keyword-sound-insulator
  a curric:Keyword ;
  schema:name "sound insulator"@en ;
  schema:description "A sound insulator does not allow sound to pass through it easily."@en ;
  dcterms:modified "2026-02-19T08:26:07.183810Z"^^xsd:dateTime .

oakcurric:keyword-groups
  a curric:Keyword ;
  schema:name "Groups"@en ;
  schema:description "We put similar things together in groups."@en ;
  dcterms:modified "2026-02-19T08:26:07.183824Z"^^xsd:dateTime .

oakcurric:keyword-yesno-questions
  a curric:Keyword ;
  schema:name "yes/no questions"@en ;
  schema:description """A yes/no question is a type of sentence that asks something and is answered with only yes or no."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183837Z"^^xsd:dateTime .

oakcurric:keyword-positive-impact
  a curric:Keyword ;
  schema:name "positive impact"@en ;
  schema:description """A positive impact is when people’s actions help other living things and their environment."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183887Z"^^xsd:dateTime .

oakcurric:keyword-nature-reserve
  a curric:Keyword ;
  schema:name "nature reserve"@en ;
  schema:description """A nature reserve is a protected area of land set aside to conserve wildlife, plants, and natural habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183892Z"^^xsd:dateTime .

oakcurric:keyword-ecology
  a curric:Keyword ;
  schema:name "ecology"@en ;
  schema:description """Ecology is the study of how living things interact with each other and their environment."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183896Z"^^xsd:dateTime .

oakcurric:keyword-hibernate
  a curric:Keyword ;
  schema:name "hibernate"@en ;
  schema:description """To hibernate, an animal goes into a deep sleep; usually in winter when food is scarce."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183901Z"^^xsd:dateTime .

oakcurric:keyword-egg
  a curric:Keyword ;
  schema:name "egg"@en ;
  schema:description "An egg is a roundish object with a developing animal inside."@en ;
  dcterms:modified "2026-02-19T08:26:07.183905Z"^^xsd:dateTime .

oakcurric:keyword-hatchling
  a curric:Keyword ;
  schema:name "hatchling"@en ;
  schema:description "A hatchling is a very young animal that has just hatched from an egg."@en ;
  dcterms:modified "2026-02-19T08:26:07.183909Z"^^xsd:dateTime .

oakcurric:keyword-gravity
  a curric:Keyword ;
  schema:name "gravity"@en ;
  schema:description "Gravity is the force that attracts objects to Earth."@en ;
  dcterms:modified "2026-02-19T08:26:07.183927Z"^^xsd:dateTime .

oakcurric:keyword-unsupported
  a curric:Keyword ;
  schema:name "unsupported"@en ;
  schema:description "If something is unsupported, it is not held up by anything."@en ;
  dcterms:modified "2026-02-19T08:26:07.183932Z"^^xsd:dateTime .

oakcurric:keyword-dietician
  a curric:Keyword ;
  schema:name "dietician"@en ;
  schema:description """A dietician is a person who scientifically studies and gives advice about food and eating."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183936Z"^^xsd:dateTime .

oakcurric:keyword-nutrition
  a curric:Keyword ;
  schema:name "nutrition"@en ;
  schema:description """Nutrition is what you take into your body as food and the way that it influences your health."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183941Z"^^xsd:dateTime .

oakcurric:keyword-adulthood
  a curric:Keyword ;
  schema:name "adulthood"@en ;
  schema:description "Adulthood is the time that a human spends as an adult."@en ;
  dcterms:modified "2026-02-19T08:26:07.183945Z"^^xsd:dateTime .

oakcurric:keyword-device
  a curric:Keyword ;
  schema:name "device"@en ;
  schema:description """In a circuit, a device is a component that needs electricity for a particular purpose."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183952Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-sources
  a curric:Keyword ;
  schema:name "sustainable sources"@en ;
  schema:description """Sustainable sources of electricity are those which do not need to be replaced because they will never run out."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183956Z"^^xsd:dateTime .

oakcurric:keyword-gestation-period
  a curric:Keyword ;
  schema:name "gestation period"@en ;
  schema:description """A gestation period is the amount of time an animal carries its offspring inside its body before giving birth."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183961Z"^^xsd:dateTime .

oakcurric:keyword-exposed
  a curric:Keyword ;
  schema:name "exposed"@en ;
  schema:description "To put or leave something in an unprotected place."@en ;
  dcterms:modified "2026-02-19T08:26:07.183966Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-pupils-assume-thinness-automatically-equates
  a curric:Misconception ;
  curric:statement """Pupils may assume that thinness automatically equates to fitness, good health and having a healthy heart."""@en ;
  curric:correction """Explain that having a thin body does not necessarily mean that you also have good heart health. Whatever shape your body is, it is important to exercise and keep active in order to keep your heart healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347770Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-pollination-seed-dispersal
  a curric:Misconception ;
  curric:statement """Pupils may confuse pollination and seed dispersal, as both involve something from the flower being moved from one place to another."""@en ;
  curric:correction """Explain that each of these processes happen at different times and have different purposes. Pollination happens before seeds have formed and leads to fertilisation, whereas seed dispersal spreads the fully formed seeds away from the parent plant."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348265Z"^^xsd:dateTime .

oakcurric:misconception-voltage-cell-proportional-size-cell
  a curric:Misconception ;
  curric:statement """The voltage of a cell is proportional to the size of the cell. Voltage is a tangible substance rather than a measure of electrical “push”."""@en ;
  curric:correction """Teaching slides and CfUs will clarify that voltage is a measure of the size of the push provided by a cell or other source of electricity and that cell size is not proportional to voltage."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348756Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-balanced-diet-include
  a curric:Misconception ;
  curric:statement """Pupils may think that a ‘balanced’ diet should include equal-sized proportions of the different food groups (rather than appropriate amounts of each food group)."""@en ;
  curric:correction """Explanation that humans need to eat different amounts of foods, depending on how healthy or unhealthy they are for us. Explanation of the importance of eating different types of food."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349753Z"^^xsd:dateTime .

oakcurric:misconception-rusting-happens-immediately-correct-conditions
  a curric:Misconception ;
  curric:statement """Rusting happens immediately when the correct conditions are present and it only happens in water."""@en ;
  curric:correction """Teaching slides explain that rusting is not instant and that moisture from the air provides enough water for the process to take place."""@en ;
  dcterms:modified "2026-02-19T08:26:10.354739Z"^^xsd:dateTime .

oakcurric:misconception-believe-diet-drinks-good-teeth
  a curric:Misconception ;
  curric:statement "May believe diet drinks are good for teeth as they don't have sugar in them."@en ;
  curric:correction """As children observe the eggshells left in different drinks, they will see that diet drinks can still cause tooth decay and discolouration."""@en ;
  dcterms:modified "2026-02-19T08:26:10.354944Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-sweet-food-bad
  a curric:Misconception ;
  curric:statement """Pupils may believe that sweet food is bad for the teeth and savoury food is good for the teeth. Also, that drinks do not contain sugar and therefore cannot be harmful to teeth."""@en ;
  curric:correction """As you look at the effect of different drinks on teeth, children will be able to see that it depends on the sugar content of the drink. High levels of sugar cause damage to teeth."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358619Z"^^xsd:dateTime .

oakcurric:misconception-interpreting-results-pupils-think-greatest
  a curric:Misconception ;
  curric:statement """When interpreting results, pupils may think that the greatest loss of heat has occurred in the cup which has the lowest temperature at the end."""@en ;
  curric:correction """Pupils will be taught they need to consider the change in temperature rather than just using the lowest end temperature to find which cup has led to the greatest heat loss."""@en ;
  dcterms:modified "2026-02-19T08:26:10.360070Z"^^xsd:dateTime .

oakcurric:misconception-light-reflect-shiny-surface-light
  a curric:Misconception ;
  curric:statement """Light can only reflect off shiny surface;  light does not always travel in straight lines when it bounces off a mirror."""@en ;
  curric:correction "Diagrams and investigations will be used to address the misconceptions."@en ;
  dcterms:modified "2026-02-19T08:26:10.361204Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-micro-organisms-harmful
  a curric:Misconception ;
  curric:statement """Pupils may think that all micro-organisms are harmful and will cause us to become ill."""@en ;
  curric:correction """Explain that, while some micro-organisms can cause us harm, there are also many that are beneficial, such as those used in food production, water treatment or those living inside our digestive system."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361509Z"^^xsd:dateTime .

oakcurric:misconception-shadows-form-bright-light
  a curric:Misconception ;
  curric:statement "Shadows only form in bright light."@en ;
  curric:correction """Children will explore shadow making and images and examples will be used to show how shadows are formed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362630Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-members-family-tree
  a curric:Misconception ;
  curric:statement "Pupils may think that all members on a family tree are related by blood."@en ;
  curric:correction """Use the examples in the slide deck to illustrate how some members of family trees are related by blood and some have joined the family through partnership."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362821Z"^^xsd:dateTime .

oakcurric:misconception-children-think-light-reflectors-actually
  a curric:Misconception ;
  curric:statement """Children often think that light reflectors are actually light sources because they 'shine'."""@en ;
  curric:correction """Provide opportunities for children to investigate a range of real objects for themselves. They need to know that light reflectors appear to shine because they are reflecting light from a light source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362918Z"^^xsd:dateTime .

oakcurric:misconception-one-object-cast-one-shadow
  a curric:Misconception ;
  curric:statement "One object can only cast one shadow."@en ;
  curric:correction """Children will investigate how the number of light sources affects the number of shadows cast by an object."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362930Z"^^xsd:dateTime .

oakcurric:misconception-solids-poured-take-shape-their
  a curric:Misconception ;
  curric:statement """Some solids can be poured and take the shape of their containers and therefore are liquids. A material is not the same material after it has been crushed."""@en ;
  curric:correction """Teaching slides and investigation will help children consider the difference between one solid particle of a material and a pile of particles which behaves together like a liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475347Z"^^xsd:dateTime .

oakcurric:misconception-friction-doesnt-direction-force-needed
  a curric:Misconception ;
  curric:statement """Friction doesn’t have a direction; a force is needed to keep an object moving at a constant speed."""@en ;
  curric:correction """Provide examples, with images, to demonstrate the effects of friction on moving objects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475386Z"^^xsd:dateTime .

oakcurric:misconception-children-become-confused-word-permanent
  a curric:Misconception ;
  curric:statement "Children can become confused with the word permanent and permeable."@en ;
  curric:correction """Be clear on your definition of permeable, perhaps use some actions to help them remember. Clear up at the start that although permeable sounds rather like permanent it is completely different and explain the difference using examples."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475398Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-leaves-collection
  a curric:Misconception ;
  curric:statement """Pupils may think that a plant’s leaves are for the collection of water, due to their shape and the way we often appear to pour water over the leaves when we water plants."""@en ;
  curric:correction """Use the lesson resources to explain that the function of the leaves is to make food for the plant."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475482Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-organisms-their-own
  a curric:Misconception ;
  curric:statement """Pupils may think that organisms have, and always have had, their own names, rather than them being named by scientists and others."""@en ;
  curric:correction """Use the lesson resources to explain the naming process for living things used by taxonomists and other scientists."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475586Z"^^xsd:dateTime .

oakcurric:misconception-pupils-experience-solid-material-changing
  a curric:Misconception ;
  curric:statement """Pupils may not have experience of a solid material changing to its liquid state then back to its solid state again."""@en ;
  curric:correction """Pupils will explore melting solid wax then watching it change back from a liquid to a solid again as it cools. The lesson provides many examples of where changing state is useful to humans in industry and every day life."""@en ;
  dcterms:modified "2026-02-19T08:26:10.476848Z"^^xsd:dateTime .

oakcurric:misconception-shiny-surfaces-reflect-light-light
  a curric:Misconception ;
  curric:statement """Only shiny surfaces reflect light. Light does not always travel in straight lines when it bounces off a mirror."""@en ;
  curric:correction """The lesson gives the children a chance to explore reflection of light in mirrors to see for themselves that it does reflect in a straight line."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477175Z"^^xsd:dateTime .

oakcurric:misconception-magnets-exert-force-paper-wood
  a curric:Misconception ;
  curric:statement """Magnets can exert a force through paper, but not wood, a table, or other thick materials."""@en ;
  curric:correction """Explicit teaching and investigation will clarify that magnetic force can act through a range of materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477498Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-their-carbon-footprint
  a curric:Misconception ;
  curric:statement """Pupils may think their carbon footprint relates only to air pollution that can be seen, such as smoke or soot."""@en ;
  curric:correction """Explain that greenhouse gases cannot be seen, smelled or tasted; just because we cannot see them, it doesn’t mean they are not in the air around us."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477643Z"^^xsd:dateTime .

oakcurric:misconception-measure-angle-light-hits-surface
  a curric:Misconception ;
  curric:statement """To measure the angle where light hits a surface, measure in between the beam of light and the surface."""@en ;
  curric:correction """The lesson gives children an opportunity to explore a new concept: the normal line. They should become familiar with measuring between the beam of light and the normal line drawn at a right angle to the surface."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477758Z"^^xsd:dateTime .

oakcurric:misconception-water-cannot-exist-gas-form
  a curric:Misconception ;
  curric:statement "Water cannot exist in a gas form."@en ;
  curric:correction """Teaching slides explain that water can exist as gaseous water vapour and the process of evaporation."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478271Z"^^xsd:dateTime .

oakcurric:misconception-shadows-form-bright-light-shadows
  a curric:Misconception ;
  curric:statement """Shadows only form in bright light; shadows and reflections are the same thing; a shadow shows the features of an object."""@en ;
  curric:correction """Children will explore shadow making and images/examples will be used to highlight the key features of shadows and reflections."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478721Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-condensation-droplets-water
  a curric:Misconception ;
  curric:statement """Pupils might think of "condensation" as the droplets of water that form through the process of condensation, rather than the change of state from gas to liquid."""@en ;
  curric:correction """Teaching slides use the term "droplets of water" instead of referring to them as "condensation"."""@en ;
  dcterms:modified "2026-02-19T08:26:10.479015Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-need-exactly
  a curric:Misconception ;
  curric:statement """Pupils may think that all plants need exactly the same things, in the same quantities, in order to survive and grow."""@en ;
  curric:correction """Use the lesson resources to explain how plant requirements differ from plant to plant."""@en ;
  dcterms:modified "2026-02-19T08:26:10.479048Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fair-test-one
  a curric:Misconception ;
  curric:statement """Pupils may think that a ‘fair test’ is one in which they all get an equal share in the roles or everyone gets to take a turn."""@en ;
  curric:correction """Explain that both a comparative and fair test are ones in which all variables are kept the same except for the one that is being investigated. This helps to ensure that our results show the effect of just the variable we are investigating."""@en ;
  dcterms:modified "2026-02-19T08:26:10.479073Z"^^xsd:dateTime .

oakcurric:misconception-children-think-bones-continue-grow
  a curric:Misconception ;
  curric:statement "Children may think that bones continue to grow throughout their lives."@en ;
  curric:correction """Spend time looking at the data they have collected and reinforcing the fact that our bones stop growing when we reach early adulthood."""@en ;
  dcterms:modified "2026-02-19T08:26:10.479696Z"^^xsd:dateTime .

oakcurric:misconception-objects-experience-same-amount-water
  a curric:Misconception ;
  curric:statement """All objects experience the same amount of water resistance, regardless of their size or shape."""@en ;
  curric:correction """Discussion and explicit teaching. The investigation they carry out will show them that this is not true."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480288Z"^^xsd:dateTime .

oakcurric:misconception-friction-hinders-motion-therefore-want
  a curric:Misconception ;
  curric:statement "Friction always hinders motion therefore you always want to eliminate friction."@en ;
  curric:correction """Multiple examples of positive uses of friction, including to help start motion by pushing off, are included."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480738Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-water-cycle-takes
  a curric:Misconception ;
  curric:statement """Pupils may think that the water cycle only takes place when it is hot or sunny; that when water evaporates, it disappears or that precipitation only refers to rain; water in its liquid form."""@en ;
  curric:correction """Teaching slides explain the process of the water cycle including the different forms of precipitation. The practical task addresses the misconception that the water cycle only takes place in hot or sunny weather."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480839Z"^^xsd:dateTime .

oakcurric:misconception-engineers-design-buildings-fix-things
  a curric:Misconception ;
  curric:statement "Engineers only design buildings or fix things that are broken."@en ;
  curric:correction "A range of examples of how and where engineers work will be given."@en ;
  dcterms:modified "2026-02-19T08:26:10.481737Z"^^xsd:dateTime .

oakcurric:misconception-children-use-word-weathering-erosion
  a curric:Misconception ;
  curric:statement """Children use the word weathering and erosion interchangeably to mean the same thing."""@en ;
  curric:correction """Explain the difference between these two processes, that are closely linked, through clear definitions, images and examples of where they are happening."""@en ;
  dcterms:modified "2026-02-19T08:26:10.481746Z"^^xsd:dateTime .

oakcurric:misconception-dissolving-same-melting
  a curric:Misconception ;
  curric:statement "Dissolving is the same as melting."@en ;
  curric:correction "Teaching slides explain the difference between melting and dissolving."@en ;
  dcterms:modified "2026-02-19T08:26:10.481770Z"^^xsd:dateTime .

oakcurric:misconception-cannot-use-electricity-solar-cells
  a curric:Misconception ;
  curric:statement "We cannot use electricity from solar cells when it is cloudy or at night."@en ;
  curric:correction """Explanation of how energy can be stored in batteries to be used when it is needed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482272Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-water-taken-plant
  a curric:Misconception ;
  curric:statement """Pupils may think that water is taken into the plant through the leaves or flowers, due to the way water can sometimes be seen pooling there after rain."""@en ;
  curric:correction """Use the slide deck and lesson activities to support pupils’ understanding that water is absorbed by the roots of a plant, then transported via the stem, and that the flowers and leaves are not able to take in water."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482281Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-mould-living-thing
  a curric:Misconception ;
  curric:statement """Pupils may not consider mould to be a living thing because it does not move in the ways we are familiar with animals moving."""@en ;
  curric:correction """Remind pupils that all living things grow, reproduce and move, and that mould can do all of these things. It is a type of fungus. Which is a living thing that is part of the micro-organisms group."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482798Z"^^xsd:dateTime .

oakcurric:misconception-children-think-common-materials-such
  a curric:Misconception ;
  curric:statement """Children may think that only common materials such as ice melt at room temperature or that when something melts, the liquid is a different substance to the original solid."""@en ;
  curric:correction """Children are shown a range of materials with different melting temperatures which range from below to above room temperature. They are taught to refer to materials in a way that highlights the fact that the material is still the same substance."""@en ;
  dcterms:modified "2026-02-19T08:26:10.483549Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-bendy-animals-spine
  a curric:Misconception ;
  curric:statement """Children often believe 'bendy' animals do not have a spine so classify them as invertebrates."""@en ;
  curric:correction """Use images of X-rays/ skeletons of snakes and eels will illustrate that they have spines and are therefore vertebrates."""@en ;
  dcterms:modified "2026-02-19T08:26:10.483614Z"^^xsd:dateTime .

oakcurric:misconception-engineers-men-like-repair-fix
  a curric:Misconception ;
  curric:statement "Engineers are only men and just like to repair or fix things."@en ;
  curric:correction """Explicit teaching and discussion of the range of engineers and the different skills engineers need."""@en ;
  dcterms:modified "2026-02-19T08:26:10.483927Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-carbon-dioxide-inherently
  a curric:Misconception ;
  curric:statement """Pupils may think that carbon dioxide is inherently harmful due to the way information about climate change is often presented."""@en ;
  curric:correction """Explain that carbon dioxide is not necessarily harmful; it is in the air we breathe and it is vital for the survival of plants. It can, however, become problematic as levels in the atmosphere increase and cause a warming effect."""@en ;
  dcterms:modified "2026-02-19T08:26:10.483945Z"^^xsd:dateTime .

oakcurric:misconception-children-think-rocks-called-rock
  a curric:Misconception ;
  curric:statement """Children may think that rocks are all just called 'rock' and they don't have different appearances and different names."""@en ;
  curric:correction """Make sure the rock samples you give them are not actual objects, e.g. an ornament, so they are not able to use usage as a way to classify. Use a wide range of rocks that are very different so the children can identify them correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484199Z"^^xsd:dateTime .

oakcurric:misconception-endless-supply-fossil-fuels-earth
  a curric:Misconception ;
  curric:statement """There is an endless supply of fossil fuels on Earth. There are no downsides to biofuels."""@en ;
  curric:correction """Teaching slides will explain that fossil fuel is a finite resource and will introduce the pros and cons of electric cars. Children will have a chance to discuss this in task B."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484527Z"^^xsd:dateTime .

oakcurric:misconception-earth-sun-moon-same-size
  a curric:Misconception ;
  curric:statement """The Earth, Sun and Moon are the same size, or that the Sun is much smaller than it actually is."""@en ;
  curric:correction """Provide opportunities for children to explore diagrams and 3D models of the Earth, Sun and Moon which clearly show the differences in size."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485046Z"^^xsd:dateTime .

oakcurric:misconception-children-think-common-materials-melt
  a curric:Misconception ;
  curric:statement """Children may think that only common materials melt at room temperature or that when something melts, the liquid is a different substance to the original solid."""@en ;
  curric:correction """Children are shown a range of materials with different melting temperatures, ranging from below to above room temperature. They are taught to refer to materials in a way that highlights the fact that the material is still the same substance."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485055Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-global-warming-means
  a curric:Misconception ;
  curric:statement """Pupils often think that global warming means that the weather is getting warmer everywhere."""@en ;
  curric:correction """Emphasise that not everywhere gets warmer all the time. Some places might experience colder weather, more storms, or other changes in climate."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485064Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fossil-fuels-made
  a curric:Misconception ;
  curric:statement """Pupils may think that fossil fuels have been made from fossils, such as the ones they may see in the classroom or museums."""@en ;
  curric:correction """Explain that fossil fuels are the remains of living things that have been changed over millions of years by heat and pressure."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485971Z"^^xsd:dateTime .

oakcurric:misconception-eco-anxiety-caused-news-coverage
  a curric:Misconception ;
  curric:statement """Eco-anxiety can be caused by news coverage of rising greenhouse gases and global temperatures, and pupils may feel like little is being done to prevent this."""@en ;
  curric:correction """Use the slides to look at the many ways that scientists and engineers are working to create new technologies to capture, remove and reduce the amount of carbon dioxide in the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:10.486056Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-objects-space-flat
  a curric:Misconception ;
  curric:statement """Pupils may think that objects in space are flat, circular shapes rather than spherical"""@en ;
  curric:correction """Provide plenty of opportunities for children to use 3D models to represent the Earth, Sun and Moon, and look at images and simulations"""@en ;
  dcterms:modified "2026-02-19T08:26:10.488569Z"^^xsd:dateTime .

oakcurric:misconception-levers-work-same-way
  a curric:Misconception ;
  curric:statement "All levers work in the same way."@en ;
  curric:correction """Teaching that the position of the pivot (fulcrum) and the effort compared to load can vary."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488844Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-theory-guess-prediction
  a curric:Misconception ;
  curric:statement """Pupils may think that a theory is just a guess or prediction that has not yet or cannot be proven."""@en ;
  curric:correction """Explain that theories are always based on scientific evidence and these are either strengthened or disproved as more evidence is gathered."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488897Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-animal-head-extremities
  a curric:Misconception ;
  curric:statement """Pupils may believe if an animal has a head, extremities and an external skeleton it is a vertebrate."""@en ;
  curric:correction """Share images of lots of animals with exoskeletons and compare them to a knight that puts on armour to protect themselves from injury."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488905Z"^^xsd:dateTime .

oakcurric:misconception-children-think-light-necessarily-think
  a curric:Misconception ;
  curric:statement """When children think of light, they do not necessarily think of it as travelling. Also that light is found only in bright areas and not in the space between."""@en ;
  curric:correction """Provide opportunities for children to think of different ways to model and record travelling light so it is seen as a continuous straight line."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488927Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-moon-changes-shape
  a curric:Misconception ;
  curric:statement "Pupils often think that the Moon changes shape."@en ;
  curric:correction """Provide opportunities for pupils to observe the Moon over time, and record observations, including how it appears to change shape."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489588Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-function-flowers-make
  a curric:Misconception ;
  curric:statement """Pupils may think the function of flowers is to make plants look nice or that they are there for the benefit of humans."""@en ;
  curric:correction """Explain that flowers are the reproductive parts of a plant that allow it to make more seeds."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489697Z"^^xsd:dateTime .

oakcurric:misconception-changes-state-dissolving-mixing-reversible
  a curric:Misconception ;
  curric:statement "Changes in state and dissolving and mixing are not reversible processes."@en ;
  curric:correction """Teaching slides will show which processes can be used to reverse state changes and dissolving.  This will be explored and embedded during the practice tasks."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489993Z"^^xsd:dateTime .

oakcurric:misconception-graphs-used-present-types-data
  a curric:Misconception ;
  curric:statement "All graphs can be used to present all types of data."@en ;
  curric:correction "Examples given of different types of graph and sample data."@en ;
  dcterms:modified "2026-02-19T08:26:10.491611Z"^^xsd:dateTime .

oakcurric:misconception-children-think-water-wheels-water
  a curric:Misconception ;
  curric:statement """Children may think that water wheels and water turbines cause water to move when they spin."""@en ;
  curric:correction """Teaching slides explain that water wheels and water turbines harness the energy of water to do work for us or to generate electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:10.491823Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-sun-appears-move
  a curric:Misconception ;
  curric:statement """Children may believe that the Sun appears to move across the sky because the Sun moves around Earth"""@en ;
  curric:correction """Provide plenty of opportunities for children to use models to see that it is Earth rotating that makes it look like the Sun is moving."""@en ;
  dcterms:modified "2026-02-19T08:26:10.492049Z"^^xsd:dateTime .

oakcurric:misconception-children-think-shadow-cast-object
  a curric:Misconception ;
  curric:statement """Children may think that a shadow is cast in between the object and the light source."""@en ;
  curric:correction """Children need to explore shadows cast by different light sources in different positions and with different objects. They should note the position of the light source in relation to the object and the shadow each time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.492418Z"^^xsd:dateTime .

oakcurric:misconception-surfaces-2-dimensional-surfaces-made
  a curric:Misconception ;
  curric:statement """All surfaces are only 2-dimensional. All surfaces are made by people (human-made)."""@en ;
  curric:correction """Provide many examples, with images, of different types of surface including natural surfaces and 3-dimensional surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:10.492587Z"^^xsd:dateTime .

oakcurric:misconception-magnetic-poles-exist-singly-pairs
  a curric:Misconception ;
  curric:statement "Magnetic poles may exist singly, not just in pairs."@en ;
  curric:correction "Explicit teaching and examples will be used to address misconceptions."@en ;
  dcterms:modified "2026-02-19T08:26:10.492847Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-animals-characteristics-observable
  a curric:Misconception ;
  curric:statement """Pupils may only consider animals' characteristics to be observable if we can see them in a photo, rather than us also being able to observe their behaviour over time."""@en ;
  curric:correction """Explain that when scientists classify living things they make many observations of how that living thing moves, behaves and reproduces, as these are all characteristics we can observe to help us identify and classify things."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494454Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-evaluate-their-investigation
  a curric:Misconception ;
  curric:statement """Pupils may think they should evaluate their investigation based on things like the neatness of their writing or how quickly they finished, rather than how they planned and carried out the enquiry."""@en ;
  curric:correction """Explain that scientists evaluate their investigations based on how they planned and carried them out, not on how neatly they presented their work or how quick they were to finish because this helps them to plan better investigations in the future."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497210Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-support-themselves
  a curric:Misconception ;
  curric:statement """Pupils may think that plants can support themselves and stay upright without roots as the stem provides support."""@en ;
  curric:correction """The task carried out in Learning Cycle 1 will demonstrate to pupils that plants need roots anchoring them in the soil in order to stay upright."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497229Z"^^xsd:dateTime .

oakcurric:misconception-metals-silver-coloured-objects-magnetic
  a curric:Misconception ;
  curric:statement """All metals and silver coloured objects are magnetic and are attracted to a magnet."""@en ;
  curric:correction """Pupils test items in classroom and explicit explanation is given that magnets attract some, but not all metals."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497243Z"^^xsd:dateTime .

oakcurric:misconception-children-think-bone-living-thing
  a curric:Misconception ;
  curric:statement "Children may think that bone is not a living thing and therefore does not grow."@en ;
  curric:correction """This lesson is all about children finding out for themselves. They will find answers to the enquiry question: Do bones grow as we get older?"""@en ;
  dcterms:modified "2026-02-19T08:26:10.497251Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-time-mary-anning
  a curric:Misconception ;
  curric:statement """Pupils may believe that during the time that Mary Anning lived women did not work in science."""@en ;
  curric:correction """Explaining to the pupils that Mary Anning was a trail blazer and, although it was difficult for her to work in the field of science, she continued to prove new theories and develop knowledge of fossils."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497258Z"^^xsd:dateTime .

oakcurric:misconception-children-think-animals-teeth-same
  a curric:Misconception ;
  curric:statement """Some children may think that all animals' teeth are the same. They may also think that all herbivores only have molars, and all carnivores only have canines and incisors."""@en ;
  curric:correction """By showing images of the teeth of carnivores and herbivores, children will see how animals have different types of teeth, depending on their diet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497280Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-pollen-seeds-think
  a curric:Misconception ;
  curric:statement """Pupils may confuse pollen and seeds or think that pollen that is dispersed by the wind can grow into a new plant if it lands on soil."""@en ;
  curric:correction """Explain that pollen is different from seeds as pollen cannot grow into a new plant. It plays a part in fertilisation, which leads to seed formation, but is not a seed and cannot turn into seeds."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497287Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-thermometers-heat-sources
  a curric:Misconception ;
  curric:statement """Pupils may think that thermometers are heat sources.  They may also think that they must touch an object to measure its temperature."""@en ;
  curric:correction """Teaching slides explain how to use a thermometer and show that you can use them to measure ambient temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497295Z"^^xsd:dateTime .

oakcurric:misconception-material-exist-solid-liquid-gas
  a curric:Misconception ;
  curric:statement """A material can only exist as a solid, liquid or gas, rather than having different forms at different temperatures.  Gases have no mass or volume."""@en ;
  curric:correction """Teaching slides explain that most materials can exist in different states and that gases have a mass and volume.  Investigations help children explore the properties of materials in different states."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497302Z"^^xsd:dateTime .

oakcurric:misconception-children-think-soil-dirt-ground
  a curric:Misconception ;
  curric:statement """Children may think that soil is any dirt on the ground, or that soil was created when Earth was created. They may also think that plants make soil."""@en ;
  curric:correction """The activity to separate layers of soil in water allows children to make their own observations of what soil is made from."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497310Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-one-huge-muscle
  a curric:Misconception ;
  curric:statement "Pupils may think that there is just one huge muscle that moves the body."@en ;
  curric:correction """Use diagrams that explain how muscles work in pairs and that muscles are different sizes throughout the body."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497317Z"^^xsd:dateTime .

oakcurric:misconception-students-think-big-muscles-strong
  a curric:Misconception ;
  curric:statement """Students may think if you have big muscles you are strong, if you have small muscles you are weak."""@en ;
  curric:correction """Show images to illustrate a runner may be very lean and a weightlifter may have huge muscles, but both are strong, just in different ways."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497324Z"^^xsd:dateTime .

oakcurric:misconception-children-use-range-observational-methods
  a curric:Misconception ;
  curric:statement """Children may use a range of observational methods to assess hardness, e.g. “heaviness” of the object, and if it breaks on impact (test for brittleness), neither of which are a test for hardness."""@en ;
  curric:correction """Be aware of using the correct vocabulary around testing for hardness. Explain that hardness is the ability to withstand pressure."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497339Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-materials-heated-placed
  a curric:Misconception ;
  curric:statement """Pupils think that materials can only be heated by being placed on a warm radiator or on a stove or over a candle and don’t think of being “in the room’ as being heated."""@en ;
  curric:correction """Teaching slides and observations show that items which have been stored below room temperature are “being heated” when moved to room temperature. Defrosting is explained in teaching slides."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497351Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-results-children-measured
  a curric:Misconception ;
  curric:statement """Pupils may believe that the results from a few children they measured can be applied to all humans."""@en ;
  curric:correction """Share each group's results and see how they are different. Explain that a much larger sample may provide different results."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497362Z"^^xsd:dateTime .

oakcurric:misconception-children-think-their-bones-connected
  a curric:Misconception ;
  curric:statement "Children may think their bones are not connected to each other."@en ;
  curric:correction """Show the children how bones are connected to form a skeleton that supports their body."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497370Z"^^xsd:dateTime .

oakcurric:misconception-geologists-look-rocks-soils-collected
  a curric:Misconception ;
  curric:statement "Geologists only look at rocks and soils collected on Earth."@en ;
  curric:correction "Geologists also work with data from space."@en ;
  dcterms:modified "2026-02-19T08:26:10.497384Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-soils-same-therefore
  a curric:Misconception ;
  curric:statement """Children may believe all soils are the same, therefore water flows through them all at the same rate."""@en ;
  curric:correction """As the children carry out the practical investigation with different soil types, they will see how water flows through them at different speeds."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497391Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-able-grow
  a curric:Misconception ;
  curric:statement """Pupils may think that plants are able to grow in any conditions and will simply adapt to their surroundings."""@en ;
  curric:correction """Explain that plants have certain requirements to survive and grow well, and will be unhealthy and likely die without these requirements. Results from pupils' enquiries will back this up and help them to see this first-hand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497399Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-food-eat-used
  a curric:Misconception ;
  curric:statement "Pupils may think that all the food we eat is used by the body."@en ;
  curric:correction """When pupils model the lower part of the digestive system they will see some of the food is absorbed as nutrients and other parts form waste which leaves the body."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497410Z"^^xsd:dateTime .

oakcurric:misconception-fossils-pieces-dead-animals-plants
  a curric:Misconception ;
  curric:statement """Fossils are pieces of dead animals and plants and children often think that only dinosaurs make fossils."""@en ;
  curric:correction """By modelling and discussing fossil formation in various ways, children will understand how fossils are formed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497471Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-water-cannot-exist
  a curric:Misconception ;
  curric:statement """Children may believe that water cannot exist in a gas state because they cannot see it.  They may also think that evaporation only occurs at high temperatures."""@en ;
  curric:correction """Teaching slides explain the existence of water vapour, even though it is invisible.  By investigation, children observe and measure that evaporation occurs at all temperatures."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497484Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-rocks-hard-rock
  a curric:Misconception ;
  curric:statement """Pupils may believe that all rocks are hard. Also that if a rock is heavy it is therefore hard."""@en ;
  curric:correction """Share a wide range of rocks the children can handle to explore the property of hardness so they realise some rocks are much softer than others."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497492Z"^^xsd:dateTime .

oakcurric:misconception-children-heard-glaciers-think-year
  a curric:Misconception ;
  curric:statement """Children may not have heard of glaciers and may think that the only year-round ice is at the poles. Melting ice caps and glaciers do not affect sea level."""@en ;
  curric:correction """Teaching slides introduce ice caps and glaciers and note that they are found all over the world. The effect of melting ice caps and glaciers on sea level is explained and children have a chance to model it."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497500Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-need-use-second
  a curric:Misconception ;
  curric:statement """Pupils may not see the need to use a second plant in their investigation that has all of its needs met, as they will be able to observe changes in the plant from which they are removing a requirement."""@en ;
  curric:correction """Explain that we need an additional plant with all of its needs met so that we can make direct comparisons between this plant and the one we are depriving of something."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497507Z"^^xsd:dateTime .

oakcurric:misconception-pupils-consider-plants-living-things
  a curric:Misconception ;
  curric:statement """Pupils may not consider plants to be living things because they do not move from place to place or have ‘babies’ in the way that many animals do."""@en ;
  curric:correction """Explain that plants are living things; we know this because they can move, grow and reproduce like other living things can."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497514Z"^^xsd:dateTime .

oakcurric:misconception-pupils-realise-continuous-system-mouth
  a curric:Misconception ;
  curric:statement """Pupils may not realise that there is a continuous system from mouth to anus that is part of a digestive system for food. Also that food goes to the tummy rather than the stomach."""@en ;
  curric:correction """When the pupils sketch the digestive system within the body outline, check the different parts join up to each other so food can pass all the way through. The word 'tummy' is used early on in the slide deck to highlight common misconceptions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497532Z"^^xsd:dateTime .

oakcurric:misconception-confusion-around-classification-rock-thinking
  a curric:Misconception ;
  curric:statement """May have confusion around classification of rock – thinking rocks in the ground and materials such as concrete, tarmac and bricks are a type of rock."""@en ;
  curric:correction """Help children to understand the material ‘rock’ is a natural material and not an object, and that materials like brick, tarmac and concrete are human-made and therefore not the same as natural rock material."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497548Z"^^xsd:dateTime .

oakcurric:misconception-pupils-realise-many-ways-present
  a curric:Misconception ;
  curric:statement """Pupils may not realise there are many ways to present information as well as writing."""@en ;
  curric:correction """By sharing many ways that information is communicated throughout the lesson, pupils will have a variety of ways that they can choose to present what they have learned about the digestive system."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497555Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-bees-other-pollinators
  a curric:Misconception ;
  curric:statement """Pupils may think that bees and other pollinators pollinate flowers to help them out, rather than it being a by-product of them getting food from the flower."""@en ;
  curric:correction """Explain that pollinators visit flowers to get something for themselves (nectar and/or pollen), not to intentionally pollinate flowers."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497577Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fertiliser-added-plants
  a curric:Misconception ;
  curric:statement """Pupils may think that fertiliser added to plants is their ‘food’ and so is necessary for their survival."""@en ;
  curric:correction """Explain that plants do not eat food in the same way that we do but they do need nutrients to survive, grow and stay healthy. They get these nutrients from soil and we can add fertiliser to soil to increase the nutrients within it."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497618Z"^^xsd:dateTime .

oakcurric:misconception-magnetic-force-contact-force
  a curric:Misconception ;
  curric:statement "Magnetic force is a contact force."@en ;
  curric:correction """Through their own investigation, children will demonstrate magnetic force acting at a distance."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497628Z"^^xsd:dateTime .

oakcurric:misconception-soils-same-comes-permeability-wet
  a curric:Misconception ;
  curric:statement """All soils are the same when it comes to permeability, how wet/dry a soil is depends how much it rains."""@en ;
  curric:correction """By planning a practical activity, pupils will be able to measure and observe how permeable different types of soils are."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497636Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-old-discovered-objects
  a curric:Misconception ;
  curric:statement """Pupils may believe that old discovered objects, like bits of pottery, coins and jewellery are fossils.  They also may believe that the fossil is always the actual plant or animal itself."""@en ;
  curric:correction """Being clear that only things that have been alive may become fossils, and not all living things are fossilised."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497662Z"^^xsd:dateTime .

oakcurric:misconception-think-rocks-same-used-interchangeably
  a curric:Misconception ;
  curric:statement """May think that rocks are all the same and can be used interchangeably for any object made from rock. Often don't know that many everyday objects are partly made from rock in its broken down form."""@en ;
  curric:correction """Encourage the children to research the many ways that rock is used even in objects which don't appear on first look to contain any rock material."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497669Z"^^xsd:dateTime .

oakcurric:misconception-children-think-teeth-same-perform
  a curric:Misconception ;
  curric:statement """Children may think that all teeth are the same and that they perform the same job to break down food in exactly the same way."""@en ;
  curric:correction """Eating a few different types of food (Task A) will help children to see for themselves which teeth they are using and what they are actually doing to break down food in different ways."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497695Z"^^xsd:dateTime .

oakcurric:misconception-children-think-materials-change-liquid
  a curric:Misconception ;
  curric:statement """Children think that materials can only change from a liquid to solid state at temperatures below 0°C. They also believe that the change is irreversible."""@en ;
  curric:correction """Teaching slides give examples of materials which change from their liquid to solid state at temperatures higher than room temperature. Through investigation, children will observe that the change between solid state and liquid state is reversible."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497702Z"^^xsd:dateTime .

oakcurric:misconception-children-confused-difference-words-weather
  a curric:Misconception ;
  curric:statement """Children may be confused by the difference between the words weather and climate."""@en ;
  curric:correction """By identifying types of weather in the early part of the lesson, you can then help pupils to understand climate by discussing how typical types of weather remain over a long period."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497727Z"^^xsd:dateTime .

oakcurric:misconception-children-think-teeth-same-shape
  a curric:Misconception ;
  curric:statement """Children may think that all teeth are the same shape and size, and that different teeth do not have different names. They often do not know that our teeth are already in our jaw when we are born."""@en ;
  curric:correction """Allow opportunities for children to feel and look at their own teeth for differences in shape and size."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497735Z"^^xsd:dateTime .

oakcurric:misconception-larger-magnets-stronger-smaller-magnets
  a curric:Misconception ;
  curric:statement "Larger magnets are always stronger than smaller magnets."@en ;
  curric:correction """Explicit teaching  as well as opportunities for children to explore different size magnets and their strengths."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497742Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-toothpastes-same
  a curric:Misconception ;
  curric:statement "Children may believe all toothpastes are the same."@en ;
  curric:correction """By investigating the effectiveness of a variety of toothpastes, children will realise there are a range of different toothpastes for different jobs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497756Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-roots-like-drinking
  a curric:Misconception ;
  curric:statement """Pupils may think that roots are like drinking straws that suck up water through their tips, rather than absorbing it across their whole length."""@en ;
  curric:correction """Share the model used in the lesson of a paper towel absorbing water to help pupils understand that water is absorbed, not sucked up, by the roots. Pupils could experience this for themselves in the classroom to help them understand and remember."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497774Z"^^xsd:dateTime .

oakcurric:misconception-magnets-look-same-poles-magnets
  a curric:Misconception ;
  curric:statement "All magnets look the same. The poles of all magnets are the ends."@en ;
  curric:correction "Real examples and diagrams of different magnets and their poles will be given."@en ;
  dcterms:modified "2026-02-19T08:26:10.497785Z"^^xsd:dateTime .

oakcurric:misconception-soils-same-earth
  a curric:Misconception ;
  curric:statement "All soils are the same, they are just earth."@en ;
  curric:correction """Through exploring different soil types  and their properties with the digital microscope, children will realise that soils differ depending on where and how they are formed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497807Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-purpose-flowers-make
  a curric:Misconception ;
  curric:statement """Pupils may think the purpose of flowers is to make the plant look nice or to provide food for bees, rather than them having a function for the sake of the plant."""@en ;
  curric:correction """Explain that the function of flowers is to allow the plant to reproduce and create more plants."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497840Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-know-them
  a curric:Misconception ;
  curric:statement """Pupils may think that humans as we know them have always looked the same as they do now."""@en ;
  curric:correction """Use the images of skulls in the slide deck to clearly show how humans’ appearance has changed over many thousands of years."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497850Z"^^xsd:dateTime .

oakcurric:misconception-dissolved-solid-ceases-present-solution
  a curric:Misconception ;
  curric:statement """A dissolved solid ceases to be present in the solution it forms – it turns into water. When you pass salt water through a filter paper, the salt is removed."""@en ;
  curric:correction """Children carry out practical activities to discover which methods can and cannot be used to recover salt from a solution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497858Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-mould-type-plant
  a curric:Misconception ;
  curric:statement """Pupils may think that mould is a type of plant because of its colour or the way it grows."""@en ;
  curric:correction """Explain that plants make their own food using photosynthesis and mould does not, so it cannot be a plant. Instead, it gets its nutrients from the organic matter that it is growing on. Also, unlike plants, mould does not need light to survive or grow."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497888Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-types-salt-cause
  a curric:Misconception ;
  curric:statement "Pupils may think that all types of salt cause ice to melt at the same rate."@en ;
  curric:correction """Opportunity to explore different types of salt and observe firsthand the effect that each type of salt has on the ice. Pupils should use the plans they created in lesson 2 to investigate this themselves."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497946Z"^^xsd:dateTime .

oakcurric:misconception-children-think-lungs-part-human
  a curric:Misconception ;
  curric:statement "Children may think that the lungs are part of the human circulatory system."@en ;
  curric:correction """Explain how the circulatory system works to support the respiratory system by bringing blood to and from the lungs. Note: children will learn more about this in key stage 3."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497968Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-environmental-variation-such
  a curric:Misconception ;
  curric:statement """Pupils may think that environmental variation, such as scars, piercings or muscle size and tone, can be passed on to offspring in the same way that inherited characteristics can."""@en ;
  curric:correction """Use the examples in the lesson to make clear the difference between characteristics that we are born with and those that are acquired, and how only those we are born with can be passed on to offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497979Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fittest-survival-fittest
  a curric:Misconception ;
  curric:statement """Pupils may think that the ‘fittest’, as in ‘survival of the fittest’, means the most physically fit or healthy, rather than the most suited to the environment and conditions."""@en ;
  curric:correction """Using the examples in the slide deck, clearly explain that when we refer to the ‘fittest’ living things surviving, we mean those that are best suited to the conditions they are living in."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497986Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-yeast-living-thing
  a curric:Misconception ;
  curric:statement """Pupils may think yeast is not a living thing because it doesn’t appear to have any of the characteristics of living things when we look at it dry straight from the packet."""@en ;
  curric:correction """Explain that yeast is a type of fungus so it is a living thing in the micro-organisms group. Throughout the lesson, reinforce the characteristics it has that makes it a living thing, such as its ability to grow and reproduce."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498005Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-able-adapt
  a curric:Misconception ;
  curric:statement """Pupils may think that animals are able to adapt during their lifetime, for example that they can change the colour of their fur to better blend in with new surroundings."""@en ;
  curric:correction "Explain that animals adapt slowly, over many years and generations."@en ;
  dcterms:modified "2026-02-19T08:26:10.498012Z"^^xsd:dateTime .

oakcurric:misconception-materials-given-type-such-wood
  a curric:Misconception ;
  curric:statement """All materials of a given type, such as wood, metal and plastic have the same properties."""@en ;
  curric:correction """Children will consider examples of different objects made from different types of wood, metal and plastic to promote discussion of the properties of materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498035Z"^^xsd:dateTime .

oakcurric:misconception-machines-involve-engines-need-power
  a curric:Misconception ;
  curric:statement "Machines all involve engines and need a power source."@en ;
  curric:correction """Explicit teaching and explanation that simple machines do not often have moving parts and do not need a power source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498045Z"^^xsd:dateTime .

oakcurric:misconception-children-think-thermal-insulators-keep
  a curric:Misconception ;
  curric:statement "Children may think that thermal insulators only keep things warm."@en ;
  curric:correction """Task A specifically addresses this misconception. Children will have opportunities to investigate which cup has the best thermal insulation properties for keeping drinks cold in lesson 5 of this unit."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498087Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-moulds-fungi-harmful
  a curric:Misconception ;
  curric:statement """Pupils may think that all moulds and fungi are harmful and no useful products can be extracted from them."""@en ;
  curric:correction """Explain that, while many moulds and fungi can be harmful to humans and other animals, many have uses in medicine such as penicillin, once they have been properly processed by scientists."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498101Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-night-earth-facing
  a curric:Misconception ;
  curric:statement """Pupils may think that we have night when the Earth is facing the Moon or the Sun goes behind clouds."""@en ;
  curric:correction """Provide plenty of opportunities for pupils to use models to show the Earth rotating on its axis, next to a bright torch or lamp for the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498120Z"^^xsd:dateTime .

oakcurric:misconception-children-think-everyone-access-safe
  a curric:Misconception ;
  curric:statement """Children may think that everyone has access to safe drinking water, and that water just 'appears' clean from a tap."""@en ;
  curric:correction """This lesson explains how approximately 1.6 billion people in the world today do not have access to water that is safe to drink. Also, that water is usually filtered and treated to make it safe to drink."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498143Z"^^xsd:dateTime .

oakcurric:misconception-children-think-function-heart-make
  a curric:Misconception ;
  curric:statement """Children often think that the function of the heart is to make or clean blood. Also that the heart is 'love heart' shaped."""@en ;
  curric:correction """The model making in this lesson helps children to think about which objects and materials they can use to represent the heart and demonstrate how it pumps blood around the body."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498150Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-micro-organisms-tiny
  a curric:Misconception ;
  curric:statement """Pupils may think that micro-organisms are very tiny animals or that they are not living things. Pupils may think that all micro-organisms are harmful germs."""@en ;
  curric:correction """Explain that micro-organisms are living things as they carry out the same processes as other living things, but they aren't animals because they have a simpler structure than animals. Explain that some helpful micro-organisms live inside our bodies."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498157Z"^^xsd:dateTime .

oakcurric:misconception-bubbles-produced-contain-air-reversible
  a curric:Misconception ;
  curric:statement "All bubbles produced contain air and that it is a reversible change."@en ;
  curric:correction """Teaching slides explain that the bubbles produced when acids react with bicarbonate of soda contain carbon dioxide and that this change is irreversible as a new material is produced."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498168Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-blood-sloshes-around
  a curric:Misconception ;
  curric:statement """Pupils often think that blood sloshes around inside the body rather than travelling through different types of blood vessels. Pupils may also think that blood can be red or blue."""@en ;
  curric:correction """The learning cycle focusing on representing blood vessels in the human body helps pupils to understand that blood vessels are often drawn in different colours merely to help us distinguish between them and understand their different functions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498175Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-evolution-one-possible
  a curric:Misconception ;
  curric:statement """Pupils may think evolution is just one possible suggestion or an unproved idea about how living things change over time, due to the common use of the word ‘theory’ for an initial idea or suggestion."""@en ;
  curric:correction """Use the examples in the lesson to explain there is enough evidence supporting the theory of evolution for us to be certain that it is scientific fact, rather than an idea we are still unsure about."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498183Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-while-animals-need
  a curric:Misconception ;
  curric:statement """Pupils may think that, while animals need to be well adapted to survive, plants do not and they simply grow where and how they can."""@en ;
  curric:correction """Use the examples in the slide deck to exemplify the various ways plants are adapted to survive in different environments, just like animals are."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498190Z"^^xsd:dateTime .

oakcurric:misconception-earth-lies-centre-solar-system
  a curric:Misconception ;
  curric:statement """Earth lies at the centre of the solar system, with the Sun and planets orbiting around it."""@en ;
  curric:correction """Provide opportunities for the children to explore both diagrams and 3D models of the solar system which clearly show the Sun and planets."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498238Z"^^xsd:dateTime .

oakcurric:misconception-friction-unhelpful
  a curric:Misconception ;
  curric:statement "Friction is always unhelpful."@en ;
  curric:correction "Examples given of positive uses of friction for braking and turning."@en ;
  dcterms:modified "2026-02-19T08:26:10.498294Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-soft-flexible
  a curric:Misconception ;
  curric:statement """Pupils may think that animals with soft, flexible bodies such as snakes or fish are invertebrates, or that any animal with a hard shell is a vertebrate."""@en ;
  curric:correction """Explain that the external appearance of an animal does not always give us enough information to classify it as a vertebrate or an invertebrate; the presence or absence of a backbone and internal skeleton is the only characteristic that matters."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498305Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-air-pollution-seen
  a curric:Misconception ;
  curric:statement """Pupils may think that air pollution can be seen, and that there are no pollutants in the air if it looks ‘clean’."""@en ;
  curric:correction """Explain that many things that can pollute the air cannot be seen by the naked eye and air pollution can exist even when we can’t see it around us."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498313Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-male-animals-get
  a curric:Misconception ;
  curric:statement """Pupils may think that male animals get their characteristics from their father, and female animals from their mother, with no characteristics shared between offspring and parents of different sexes."""@en ;
  curric:correction """Use the images and examples in the lesson to make it clear that offspring share a combination of characteristics of both of their parents, regardless of sex."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498320Z"^^xsd:dateTime .

oakcurric:misconception-thermal-insulators-keep-warm-things
  a curric:Misconception ;
  curric:statement "Thermal insulators only keep warm things warm."@en ;
  curric:correction """One of the learning cycles, and Practice Task B, focuses on the use of thermal insulators to keep cold things cold."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498327Z"^^xsd:dateTime .

oakcurric:misconception-insoluble-soluble-solids-separated-liquids
  a curric:Misconception ;
  curric:statement """Insoluble and soluble solids are separated from liquids using the same methods: dissolved solids, like salt and sugar, can be removed from solution by filtering."""@en ;
  curric:correction """Methods specific to the separation of insoluble solids are taught and applied in this lesson. Task A will help pupils understand that filtering does not separate dissolved solids, like salt and sugar, from a solution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498357Z"^^xsd:dateTime .

oakcurric:misconception-our-eyes-produce-light-allows
  a curric:Misconception ;
  curric:statement "Our eyes produce light, which allows us to see."@en ;
  curric:correction """Pupils will be taught that we see when light enters our eyes and will model and draw this themselves."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498386Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-need-eat-food
  a curric:Misconception ;
  curric:statement """Pupils may not know that we need to eat food to obtain essential nutrients to keep us healthy and alive."""@en ;
  curric:correction """Learning about different types of nutrients found in food, such as vitamins, proteins, carbohydrates and fats will help children to remember previous learning; that we get nutrition from what we eat."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498393Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-decide-choose
  a curric:Misconception ;
  curric:statement """Pupils may think that plants can decide or choose to grow in whatever way they think is best."""@en ;
  curric:correction """Explain that plant adaptations are inherited characteristics and the plant does not have any choice or understanding of its adaptations."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498401Z"^^xsd:dateTime .

oakcurric:misconception-children-think-ice-water-steam
  a curric:Misconception ;
  curric:statement """Children often think that ice, water and steam are three different substances and not water in different states, and that changes in state are not reversible processes."""@en ;
  curric:correction """Teaching slides will reinforce that ice (solid state), water (liquid state), and water vapour (gas state) are all water and show which processes can be used to reverse state changes.  This will be further explored and embedded during practice tasks."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498408Z"^^xsd:dateTime .

oakcurric:misconception-children-think-scientists-present-information
  a curric:Misconception ;
  curric:statement """Children may think that scientists only present information in written, formal reports."""@en ;
  curric:correction """This lesson encourages lots of different forms of reporting scientific information, including verbal, pictorial and written."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498415Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-such-finches
  a curric:Misconception ;
  curric:statement """Pupils may think that animals, such as finches with differently shaped beaks, have been able to change or adapt during their lifetime based on the conditions they live in."""@en ;
  curric:correction """Explain that adaptations take many years and generations of animals to happen and it is not possible for an animal or plant to change like this during its lifetime."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498426Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-compost-dirt-mud
  a curric:Misconception ;
  curric:statement "Pupils may think that compost is just dirt or mud, or is no different from soil."@en ;
  curric:correction """Explain that compost has a different composition to soil, and is full of nutrients that are beneficial to growing plants."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498434Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fossils-found-anywhere
  a curric:Misconception ;
  curric:statement """Pupils may think that fossils can be found anywhere on Earth and in any type of rock."""@en ;
  curric:correction """Use the lesson resources to explain how and why fossils are mainly found in sedimentary rock and the common locations these tend to be, such as cliffs, hillsides and quarries."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498441Z"^^xsd:dateTime .

oakcurric:misconception-gears-exist-bicycles-cars
  a curric:Misconception ;
  curric:statement "Gears only exist in bicycles and cars."@en ;
  curric:correction "Explicit teaching of what gears are and where they are found."@en ;
  dcterms:modified "2026-02-19T08:26:10.498449Z"^^xsd:dateTime .

oakcurric:misconception-children-think-windmills-wind-turbines
  a curric:Misconception ;
  curric:statement """Children may think that windmills and wind turbines create wind when the sails or blades spin."""@en ;
  curric:correction """Teaching slide explain that windmills and wind turbines harness the energy of the wind to do work for us or to generate electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498496Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-one-type-salt
  a curric:Misconception ;
  curric:statement "Pupils may think that there is only one type of salt."@en ;
  curric:correction "Explanation that rock salt is one type of salt."@en ;
  dcterms:modified "2026-02-19T08:26:10.498504Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-moon-produces-its
  a curric:Misconception ;
  curric:statement """Pupils often think that the Moon produces its own light, or that the Moon only comes out at night"""@en ;
  curric:correction """Explore common reflectors of light, to enable pupils to observe how some objects, including the Moon, appear to shine as they reflect light"""@en ;
  dcterms:modified "2026-02-19T08:26:10.498537Z"^^xsd:dateTime .

oakcurric:misconception-bioplastics-cause-environmental-problems
  a curric:Misconception ;
  curric:statement "Bioplastics do not cause any environmental problems."@en ;
  curric:correction """Teaching slides explain what the limitations of current bioplastics are, and that scientists are still working on their development."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498562Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-green-anything
  a curric:Misconception ;
  curric:statement """Pupils may think that all plants are green or that anything without a flower is not a plant."""@en ;
  curric:correction """Highlight the many examples of plants with different shapes, sizes and colours that are included in the lesson resources, reminding children that all of these are plants because they are living things that use the Sun’s light to make food."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498592Z"^^xsd:dateTime .

oakcurric:misconception-earth-lies-centre-our-solar
  a curric:Misconception ;
  curric:statement """Earth lies at the centre of our solar system, with the Sun and planets orbiting around it."""@en ;
  curric:correction """Provide opportunities for the children to explore both diagrams and 3D models of the solar system which clearly show the Sun and planets."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498599Z"^^xsd:dateTime .

oakcurric:misconception-light-shines-our-eyes-light
  a curric:Misconception ;
  curric:statement """Light shines out of our eyes; a light ray is a long thin piece of light; light is made of light rays added together; light can only be reflected off shiny surfaces."""@en ;
  curric:correction """Explicit teaching about sources of light, what a light ray is; plenty of demonstrations and practice of drawing diagrams."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498607Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-classified-according
  a curric:Misconception ;
  curric:statement """Pupils may think that animals are classified according to their habitat, for example aquatic animals, or by their method of movement, for example creeping animals."""@en ;
  curric:correction """Explain that Aristotle classified animals into water, air and land groups, but there are problems with this method, e.g. this would put birds, bees and bats in the same group. Use the examples in the lesson to make clear the correct groupings."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498614Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-moon-actually-change
  a curric:Misconception ;
  curric:statement """Pupils will think that the Moon actually does change shape, or that it becomes covered with clouds."""@en ;
  curric:correction """Pupils should use models to see and feel for themselves what is actually moving and how this affects the apparent shape of the Moon."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498624Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-complicated-verbose-explanations
  a curric:Misconception ;
  curric:statement """Pupils may think that more complicated and verbose explanations are better, regardless of target audience, as this will make them seem cleverer."""@en ;
  curric:correction """Explain that, when sharing information with lots of people with different levels of background knowledge, it is much better to make explanations clear and simple so it can be understood by as many people as possible."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498632Z"^^xsd:dateTime .

oakcurric:misconception-forces-act-moving-objects
  a curric:Misconception ;
  curric:statement "Forces only act on moving objects."@en ;
  curric:correction "Examples of forces being used to move stationary objects will be included."@en ;
  dcterms:modified "2026-02-19T08:26:10.498639Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-blood-made-heart
  a curric:Misconception ;
  curric:statement """Pupils may think that blood is made in the heart and the function of blood is to clean the heart."""@en ;
  curric:correction """This lesson provides plenty of opportunities for pupils to learn about the different functions of blood."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498646Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-prehistoric-living-things
  a curric:Misconception ;
  curric:statement """Pupils may think that all prehistoric living things were on Earth at the same time, rather than understanding that life on Earth changed over millions of years."""@en ;
  curric:correction """Use the models and information in the lesson to explain that the different layers of rock beneath our feet were formed at different times, and there are fossils of different living things buried within each."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498654Z"^^xsd:dateTime .

oakcurric:misconception-insulation-used-keep-houses-other
  a curric:Misconception ;
  curric:statement "Insulation is used only to keep houses and other buildings warm."@en ;
  curric:correction """Pupils will learn that insulation is designed to slow down heat exchange between buildings and the outside, keeping buildings warm in cold seasons or climates, or cool in warm seasons or climates."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498664Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sun-planet
  a curric:Misconception ;
  curric:statement "Pupils may think that the Sun is a planet."@en ;
  curric:correction """Explain that the Sun is a star because, like other stars, it is a huge ball of glowing gas which has planets travelling around it."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498675Z"^^xsd:dateTime .

oakcurric:misconception-air-resistance-exist-works-vertically
  a curric:Misconception ;
  curric:statement "Air resistance does not exist or it only works vertically."@en ;
  curric:correction """Explicit teaching including diagrams and examples of air resistance working in all directions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498705Z"^^xsd:dateTime .

oakcurric:misconception-children-think-possible-replace-vital
  a curric:Misconception ;
  curric:statement """Children may not think it possible to replace a vital organ such as the heart with one from another person, let alone an animal bred specifically for this purpose!"""@en ;
  curric:correction """It is important to portray a balanced argument for children to consider and debate, and for them to appreciate that no-one specifically is right or wrong."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498712Z"^^xsd:dateTime .

oakcurric:misconception-burning-heating-melting-same-smoke
  a curric:Misconception ;
  curric:statement "Burning, heating and melting are the same. Smoke and water vapour are the same."@en ;
  curric:correction """Slides teach that heating and melting are reversible changes because the original materials can be recovered but that, with burning, the original materials cannot be recovered.  The difference between smoke and water vapour is also taught."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498719Z"^^xsd:dateTime .

oakcurric:misconception-pulleys-wheel-attached-ceiling
  a curric:Misconception ;
  curric:statement "All pulleys have the wheel attached to a ceiling."@en ;
  curric:correction "Examples will be given of different types of simple pulleys."@en ;
  dcterms:modified "2026-02-19T08:26:10.498737Z"^^xsd:dateTime .

oakcurric:misconception-pupils-limited-view-constitutes-fossil
  a curric:Misconception ;
  curric:statement """Pupils may have a limited view of what constitutes a fossil, such as only things that resemble skeletons or ammonite shells, and not recognise things like coprolites or plant imprints as fossils too."""@en ;
  curric:correction """Use the range of examples used in the lesson to make it clear to pupils that there are a wide range of different types of fossil and different types of organisms that become fossils."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498745Z"^^xsd:dateTime .

oakcurric:misconception-objects-experience-same-amount-air
  a curric:Misconception ;
  curric:statement """All objects experience the same amount of air resistance, regardless of their size or shape."""@en ;
  curric:correction "Discussion and practical exploration will address this misconception."@en ;
  dcterms:modified "2026-02-19T08:26:10.498756Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-arrow-food-chain
  a curric:Misconception ;
  curric:statement """Pupils often think the arrow in a food chain means “eats” or "depends on" and also that arrows should be drawn from predator to prey (rather than prey to predator)."""@en ;
  curric:correction """This lesson reinforces the fact the the arrow in a food chain can be interpreted to mean 'is food for'."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502366Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unaware-provenance-their-food
  a curric:Misconception ;
  curric:statement """Pupils may be unaware of the provenance of their food and the possible environmental effect of eating foods from different countries."""@en ;
  curric:correction """Explanation of how some foods are grown in England and how eating local, seasonal food can minimise the impact on the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502401Z"^^xsd:dateTime .

oakcurric:misconception-humans-see-without-light
  a curric:Misconception ;
  curric:statement "Humans can see without light."@en ;
  curric:correction """Explanation of how humans can see with a little light but cannot see when no light is present."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502408Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sea-dwelling-animals
  a curric:Misconception ;
  curric:statement """Pupils may think that all sea-dwelling animals are fish or that only birds can fly."""@en ;
  curric:correction """Explain, with examples from the lesson, that animals are classified based on their physical features, not where they live or how they move."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502414Z"^^xsd:dateTime .

oakcurric:misconception-metals-electrical-conductors-non-metals
  a curric:Misconception ;
  curric:statement """Only metals are electrical conductors.  All non-metals are electrical insulators."""@en ;
  curric:correction """Pupils will be taught that some non-metals are poor insulators, for example, water, as it can contain dissolved minerals that act as electrical conductors."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502434Z"^^xsd:dateTime .

oakcurric:misconception-materials-let-light-them-transparent
  a curric:Misconception ;
  curric:statement "All materials that let light through them are transparent."@en ;
  curric:correction """Explanation of the difference between materials that are transparent and those that are translucent."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502444Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-different-parts-food
  a curric:Misconception ;
  curric:statement """Pupils may think that different parts of a food chain are independent of each other and are not impacted by changes elsewhere in the food chain."""@en ;
  curric:correction """Clear explanation of how each part of a food chain is linked to other parts of the chain and how even small changes can have a big impact throughout a food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502453Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-either-grow
  a curric:Misconception ;
  curric:statement """Pupils may think that humans either grow at a steady rate throughout their lives or only grow on milestones such as their birthdays."""@en ;
  curric:correction """When pupils have completed their line graphs showing human height data, discuss the changes in height between different ages."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502467Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-volume-sounds-same
  a curric:Misconception ;
  curric:statement """Pupils may think that the volume of sounds are the same no matter how far away from them you are."""@en ;
  curric:correction """Pupils will carry out a fair test to find out for themselves how the volume of a sound decreases with distance from the sound source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502473Z"^^xsd:dateTime .

oakcurric:misconception-scientists-communicate-directly-public
  a curric:Misconception ;
  curric:statement "Scientists do not communicate directly with the public."@en ;
  curric:correction """Explanation of the different ways in which scientists can communicate with the public."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502480Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-metamorphosis-animal-result
  a curric:Misconception ;
  curric:statement "Pupils may think that metamorphosis of an animal is the result of evolution."@en ;
  curric:correction """Explain that metamorphosis is the change in form of a single animal; it’s still the same animal after metamorphosis."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502504Z"^^xsd:dateTime .

oakcurric:misconception-foods-either-good-bad
  a curric:Misconception ;
  curric:statement "Foods are either 'good' or 'bad' for you."@en ;
  curric:correction """Explanation of different nutrients in foods and how they can be beneficial to our health."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502520Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-vocabulary-needed-animal
  a curric:Misconception ;
  curric:statement """Pupils may struggle with some of the vocabulary needed for animal classification that is not used in everyday language. They may try to use an animal's habitat as an observable characteristic."""@en ;
  curric:correction """Model the correct classification language throughout the lesson using animals they are confident with. Although there sometimes are observable clues, you cannot be certain of an animal's habitat by looking at it out of context."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502527Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-food-chain
  a curric:Misconception ;
  curric:statement """Pupils often think that all animals in a food chain are predators, or that all carnivores are predators."""@en ;
  curric:correction """Some animals can be carnivores but not predators. These animals are scavengers because they eat meat from animals they have found or that have been killed by other animals."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502533Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-grow-their
  a curric:Misconception ;
  curric:statement """Pupils may think that humans only grow on their birthdays or in short, intermittent spurts rather than growth being continuous throughout childhood and adolescence."""@en ;
  curric:correction """Using the lesson resources to support, explain that growth is continuous throughout youth until adulthood."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502554Z"^^xsd:dateTime .

oakcurric:misconception-safety-reasons-electrical-circuits-used
  a curric:Misconception ;
  curric:statement """For safety reasons, electrical circuits are never used in systems or appliances which involve or are used near water."""@en ;
  curric:correction """Slides will discuss how engineers plan for the safe use of some electrical appliances near or with water. Children will design their own circuit to be used near water."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502597Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-predator-identified-its
  a curric:Misconception ;
  curric:statement """Pupils may think that a predator can always be identified by its size and ferocity in comparison to its prey."""@en ;
  curric:correction """This lesson gives examples of some predators that are smaller in size than their prey."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502604Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-species-plants-become
  a curric:Misconception ;
  curric:statement """Pupils may not think that species of plants can become extinct in the same way that animals can."""@en ;
  curric:correction """Explain that if all of a particular species of plant, and its seeds, were destroyed then that plant would be extinct and none would ever live or reproduce again in the future."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502611Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-pollinating-flowers
  a curric:Misconception ;
  curric:statement """Pupils may think that animals are pollinating flowers to intentionally help them."""@en ;
  curric:correction """Explain that pollinators are visiting flowers to find food for themselves, rather than to help the plant; they do not pollinate flowers on purpose."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502620Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-human-development-milestones
  a curric:Misconception ;
  curric:statement """Pupils may think that human development milestones happen at the same time for everyone."""@en ;
  curric:correction """Using the lesson resources to support, explain that humans are all different and so grow and develop at different rates. This is why we need surveys to find out more information, as one rule cannot be applied to all humans."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502646Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-population-size-affected
  a curric:Misconception ;
  curric:statement """Pupils may think that population size is only affected by the number of people being born."""@en ;
  curric:correction """Use the lesson resources to explain that many factors have an impact on population size, with the main contributing factor currently being the increase in life expectancy."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502656Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-light-pollution-exists
  a curric:Misconception ;
  curric:statement """Pupils may not know that light pollution exists nor its impact on humans and other living things."""@en ;
  curric:correction """An explanation of light pollution and its potential negative effects on humans and other living things."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502664Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-larger-objects-make
  a curric:Misconception ;
  curric:statement """Pupils may only think that larger objects make louder sounds. They may not link the size of vibrations to the volume of sound."""@en ;
  curric:correction """Ensure plenty of opportunities for pupils to strike, tap, blow and shake objects to see how this affects the volume of sound produced."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502670Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-observations-enquiries-written
  a curric:Misconception ;
  curric:statement """Pupils may think that observations from enquiries should only be in written or numerical form."""@en ;
  curric:correction """Explain that there are many ways to represent the information we gathered during enquiries, including with diagrams, writing or even video recordings."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502694Z"^^xsd:dateTime .

oakcurric:misconception-electricity-invented-humans
  a curric:Misconception ;
  curric:statement "Electricity was invented by humans."@en ;
  curric:correction """Lesson content will teach children about early observations and explanations of natural electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502701Z"^^xsd:dateTime .

oakcurric:misconception-children-think-larger-longer-objects
  a curric:Misconception ;
  curric:statement """Children may think that larger and longer objects vibrating produce louder sounds, without linking this to the pitch of sounds."""@en ;
  curric:correction """If working at school, empty the cupboard of as many musical instruments you can find to explore and demonstrate with. Encourage children who play musical instruments to share their experiences too."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502708Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-need-eat
  a curric:Misconception ;
  curric:statement """Pupils may think that humans need to eat the same amounts of different types of food to stay healthy."""@en ;
  curric:correction """Emphasise that humans need to eat different amounts of different foods as part of a healthy diet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502728Z"^^xsd:dateTime .

oakcurric:misconception-children-think-sound-classified-noise
  a curric:Misconception ;
  curric:statement """Children may think that any sound is classified as noise, or that only very loud sounds are considered to be noise pollution."""@en ;
  curric:correction """Explain that unpleasant or unwanted sounds are classified as noise. Noise pollution does not have to be loud, it can be an intermittent or continuous quieter noise that becomes a problem."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502738Z"^^xsd:dateTime .

oakcurric:misconception-size-shadow-change
  a curric:Misconception ;
  curric:statement "The size of a shadow does not change."@en ;
  curric:correction """Explanation of how the size of shadows change depending on the distance of the object from the light source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502751Z"^^xsd:dateTime .

oakcurric:misconception-effects-human-impact-environment-negative
  a curric:Misconception ;
  curric:statement "All effects of human impact on the environment are negative."@en ;
  curric:correction "Examples of positive effects of human impact on the environment."@en ;
  dcterms:modified "2026-02-19T08:26:10.502758Z"^^xsd:dateTime .

oakcurric:misconception-electrical-insulators-cannot-conduct-electricity
  a curric:Misconception ;
  curric:statement "Electrical insulators cannot conduct electricity at all."@en ;
  curric:correction """Children will be taught that electrical insulators are materials that do not allow electricity to pass through them easily."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502788Z"^^xsd:dateTime .

oakcurric:misconception-shadows-contain-details-object-such
  a curric:Misconception ;
  curric:statement """Shadows contain details of the object, such as facial features of a human’s shadow. Also that a shadow can be a different shape to the object, and formed in between the light source and the object."""@en ;
  curric:correction "Explanation of how shadows are formed."@en ;
  dcterms:modified "2026-02-19T08:26:10.502797Z"^^xsd:dateTime .

oakcurric:misconception-electricity-comes-plug-sockets-our
  a curric:Misconception ;
  curric:statement """Electricity comes from the plug sockets in our homes. When electrical appliances are used, the electricity goes into them but is not part of a complete circuit."""@en ;
  curric:correction """Pupils will be taught where and how electricity is generated and how it is transported to our homes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502804Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-information-written-published
  a curric:Misconception ;
  curric:statement """Pupils may think than any information written down or published online is automatically reliable and trustworthy, purely because of its appearance in the public sphere."""@en ;
  curric:correction """Use the lesson resources to explain how information sources, particularly those online, can vary in terms of reliability and that there are things we can do to help determine how much we can trust the information we find."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502841Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-healthy-achieved-physical
  a curric:Misconception ;
  curric:statement """Pupils may think that being healthy can be achieved through physical fitness, not taking into account anything else."""@en ;
  curric:correction """Explain that a range of different factors contribute to a healthy lifestyle, including eating a balanced diet, getting a good amount of sleep and taking part in activities that help our mental well being."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502861Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-word-diet-refers
  a curric:Misconception ;
  curric:statement """Pupils may think that the word ‘diet’ refers to ‘going on a diet’ and lowering calorie intake or restricting intake of fats or sugars, and in turn think that this constitutes a ‘healthy’ diet."""@en ;
  curric:correction """Explain that the word ‘diet’ means the things that we eat regularly, and that a balanced diet is made up of a balanced intake of different types of foods."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502878Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-mushroom-plant
  a curric:Misconception ;
  curric:statement "Pupils often think that a mushroom is a plant."@en ;
  curric:correction """Explain to pupils that mushrooms are not plants (or animals), rather they are the fruit bodies of a group of micro-organisms called fungi (singular fungus)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502916Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-vaping-safe-healthy
  a curric:Misconception ;
  curric:statement """Pupils may think that vaping is a safe and healthy practice, or a ‘cleaner’ version of smoking."""@en ;
  curric:correction """Explain that, although vaping is less harmful to the body than smoking, it still has an impact on the body and, as a new practice, we are not yet fully aware of the long term effects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502923Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-changes-environment-negative
  a curric:Misconception ;
  curric:statement "Pupils may think that changes to the environment are negative."@en ;
  curric:correction "Examples of both positive and negative changes to the environment."@en ;
  dcterms:modified "2026-02-19T08:26:10.502930Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-animals-decline-found
  a curric:Misconception ;
  curric:statement """Children often believe that animals in decline are only found in faraway places like rain forests. They might not realise that the UK has its own species in decline, such as the red squirrel."""@en ;
  curric:correction """Through the use of the slides and doing further secondary research about their own local environment, children will become aware that there are animals in the UK that are in decline too."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502939Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-personally-cant-anything
  a curric:Misconception ;
  curric:statement """Pupils may think they personally can't do anything to prevent animals becoming endangered/extinct."""@en ;
  curric:correction """Use the resources to explain the things pupils can do to help, and encourage them to think specifically about which are possible for them."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502949Z"^^xsd:dateTime .

oakcurric:misconception-scientists-electricians-careers-associated-electricity
  a curric:Misconception ;
  curric:statement """Only scientists and electricians have careers which are associated with electricity."""@en ;
  curric:correction """Children will be introduced to a wide variety of careers which involve electricity and electrical technology."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502968Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-heart-pumps-air
  a curric:Misconception ;
  curric:statement """Pupils may think that the heart pumps air through the body, rather than blood, as part of a pneumatic-style system that powers the muscles."""@en ;
  curric:correction """Explain that the heart pumps blood around the body, beating faster when we exercise because it is transporting more oxygen within blood to keep the muscles working."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502975Z"^^xsd:dateTime .

oakcurric:misconception-children-dont-realise-plants-danger
  a curric:Misconception ;
  curric:statement "Children sometimes don't realise plants can be in danger as well as animals."@en ;
  curric:correction """Share the examples in the slide deck and give pupils time to research other plants to discover there are lots of different plants in different environments that are in danger. If time, find out if any plants in your local area are in danger."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502981Z"^^xsd:dateTime .

oakcurric:misconception-scientific-enquiry-valid-variables-controlled
  a curric:Misconception ;
  curric:statement "Scientific enquiry is only valid if variables can be controlled and changed."@en ;
  curric:correction """Teaching slides will explain how some scientist cannot control variables and look for patterns in data and observations instead."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503004Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-human-actions-impact
  a curric:Misconception ;
  curric:statement """Some pupils may think that human actions can have an impact on animals and plants but that these actions do not affect food chains."""@en ;
  curric:correction """Explanation of different ways in which humans can protect plants and animals in their habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503010Z"^^xsd:dateTime .

oakcurric:misconception-children-think-volume-sound-pitch
  a curric:Misconception ;
  curric:statement """Children may think that the volume of sound and the pitch of sound is the same thing, or that high sounds are loud and low sounds are quiet."""@en ;
  curric:correction """It is important to expose children to a wide range of high and low pitched sounds. Continue to make the distinction between volume and pitch throughout this lesson."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503023Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rely-upon-organisms-habitat
  a curric:Misconception ;
  curric:statement """Pupils sometimes rely upon an organism’s habitat to classify it, rather than its physical features; this can lead to misunderstandings and misclassification."""@en ;
  curric:correction """As you model groupings, be clear to use observable features of the objects you are grouping - focus on what you can observe as a characteristic of being human."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503029Z"^^xsd:dateTime .

oakcurric:misconception-pupils-narrow-definition-exercise-limiting
  a curric:Misconception ;
  curric:statement """Pupils may have a very narrow definition of exercise, limiting it to activities such as running or weightlifting and not including more ‘fun’ types of exercise such as dancing or trampolining."""@en ;
  curric:correction """Explain that any physical activity where we intentionally use a lot of effort to move our bodies is exercise, backing this up with all the examples in the slide deck."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503036Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-baby-grows-inside
  a curric:Misconception ;
  curric:statement "Pupils may think that the baby grows inside its mother's stomach."@en ;
  curric:correction "Using the resources, explain that babies develop in an organ called a womb."@en ;
  dcterms:modified "2026-02-19T08:26:10.503052Z"^^xsd:dateTime .

oakcurric:misconception-jobs-use-results-science-science
  a curric:Misconception ;
  curric:statement """Jobs which use the results of science are science jobs.  Electrical engineers and electricians are both scientists because they use the results of science in their work."""@en ;
  curric:correction """Children will be taught the difference between doing and using science within the context of a range of jobs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503058Z"^^xsd:dateTime .

oakcurric:misconception-animal-life-cycles-same-stages
  a curric:Misconception ;
  curric:statement """All animal life cycles have the same stages; anything different to mammals is not an 'animal'."""@en ;
  curric:correction """Use the examples in the slide deck to make it clear that different types of animals have different life cycles."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503081Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-questions-need-full
  a curric:Misconception ;
  curric:statement "Pupils may believe that all questions need a full explanation to answer."@en ;
  curric:correction """By working through the examples on the slide deck and completing the tasks, pupils will see that some questions can be answered with a simple yes or no. This is an important skill when using and creating identification keys for classification."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503088Z"^^xsd:dateTime .

oakcurric:misconception-mirrors-shiny-materials-reflect-light
  a curric:Misconception ;
  curric:statement "Only mirrors and very shiny materials reflect light."@en ;
  curric:correction "Explanation that lots of different materials reflect different amounts of light."@en ;
  dcterms:modified "2026-02-19T08:26:10.503095Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-elders-like-their
  a curric:Misconception ;
  curric:statement """Pupils may think that all elders are like their grandparents or other older people they know, whether they are fit and active or more frail and sedentary."""@en ;
  curric:correction """Using the resources to support, explain that all humans are different and so there'll be differences in how they age. Also make it clear that old age can span up to 40 years so there'll be differences between someone who is 65 and someone who is 95."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503104Z"^^xsd:dateTime .

oakcurric:misconception-children-understand-variables-interact-within
  a curric:Misconception ;
  curric:statement """Children may not understand how variables interact within a circuit and how changes in one variable can affect others."""@en ;
  curric:correction """Teaching slides will relate the need to control variables in a fair test to the need to do so with circuits in order to be able to relate a given variable to a measured outcome."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503111Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-plants-same-species
  a curric:Misconception ;
  curric:statement """Pupils may not understand how plants of the same species can vary from one another and assume they are all the same because the differences are not obvious."""@en ;
  curric:correction """Explain that plants can have different characteristic within a species, such as size and shape of fruit or colour of flowers."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503117Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-way-plants-reproduce
  a curric:Misconception ;
  curric:statement "Pupils may think that the only way for plants to reproduce is by creating seeds."@en ;
  curric:correction """Explain that, as well as making seeds, plants can also reproduce asexually in a range of ways, including form cuttings taken from a plant by humans."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503149Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-food-produced-same
  a curric:Misconception ;
  curric:statement "Pupils may think that all food is produced in the same way."@en ;
  curric:correction """Explanation of how foods can be produced and harvested in different ways with differing environmental impacts."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503156Z"^^xsd:dateTime .

oakcurric:misconception-safe-look-sun-cloudy-day
  a curric:Misconception ;
  curric:statement "It is safe to look at the Sun on a cloudy day or when wearing sunglasses."@en ;
  curric:correction """Clear explanation that pupils should never look at the Sun, even if wearing sunglasses or if the weather is cloudy."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503165Z"^^xsd:dateTime .

oakcurric:misconception-people-eat-same-foods-same
  a curric:Misconception ;
  curric:statement "All people eat the same foods and have the same diet."@en ;
  curric:correction """Explanation that different people have different diets for a variety of different reasons, such as allergies, intolerances or their own choice."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503178Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-small-creatures-minibeasts
  a curric:Misconception ;
  curric:statement "Pupils may think that all small creatures, or ‘minibeasts’, are insects."@en ;
  curric:correction """Explain that an animal is only an insect if it has the characteristics of insects. Use lots of examples and non-examples to make this clear."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503983Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-animals-something
  a curric:Misconception ;
  curric:statement "Pupils may think that humans are not animals, but something different."@en ;
  curric:correction """When mammals are discussed in the lesson, remind pupils that humans are animals and mammals because of their shared characteristics."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503993Z"^^xsd:dateTime .

oakcurric:misconception-electrical-appliances-circuits-use-same
  a curric:Misconception ;
  curric:statement "All electrical appliances and circuits use the same type of switch."@en ;
  curric:correction "Children will be introduced to a wide range of switches."@en ;
  dcterms:modified "2026-02-19T08:26:10.504000Z"^^xsd:dateTime .

oakcurric:misconception-misconceptions-associated-incomplete-circuits-one
  a curric:Misconception ;
  curric:statement """Misconceptions associated with incomplete circuits: one wire to battery; connections to the same end of the battery; wires the wrong way round; not connecting clips to metal."""@en ;
  curric:correction """Children will be taught how to troubleshoot circuits which are not working to address these misconceptions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504009Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-identify-plants-using
  a curric:Misconception ;
  curric:statement """Pupils may try to identify plants using the habitat they are found in as opposed to their observable features."""@en ;
  curric:correction """Reinforce that where a plant lives is not an observable characteristic and cannot be used to identify it."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504016Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-impact-increased-human
  a curric:Misconception ;
  curric:statement """Some pupils may not understand the impact of an increased human population on plants and animals."""@en ;
  curric:correction """Discuss, using examples on the slide deck, all the repercussions of increased population. If possible, include an example relevant to their location to help them see it first hand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504051Z"^^xsd:dateTime .

oakcurric:misconception-metals-electrical-conductors
  a curric:Misconception ;
  curric:statement "Not all metals are electrical conductors."@en ;
  curric:correction """Pupils will test materials for conductivity, but teaching slides will emphasise that all metals are electrical conductors."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504065Z"^^xsd:dateTime .

oakcurric:misconception-children-think-plant-animal-part
  a curric:Misconception ;
  curric:statement "Children may think that a plant or animal can only be part of one food chain."@en ;
  curric:correction """This lesson shows a number of examples of how plants and animals can be part of many different food chains. Children are encouraged to research and create different food chains for the same plant or animal."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504107Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-scientific-information-communicated
  a curric:Misconception ;
  curric:statement """Pupils may think that scientific information communicated with the public should be presented in a complicated and ‘wordy’ way to make it more seem more intelligent or ‘official’."""@en ;
  curric:correction """Explain that information intended to help people make healthy lifestyle choices is best presented in a way that will allow as many people as possible to engage with it, so that they can make informed choices."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504116Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-heatwaves-hot-day
  a curric:Misconception ;
  curric:statement """Pupils may believe that heatwaves are just a ‘hot’ day and that wildfires are always caused by humans."""@en ;
  curric:correction """Discuss with pupils the length and severity needed for an event to become a heatwave. Share with the pupils how the weather and conditions contribute to increased risk of wildfires occurring."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504123Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-words-pictures-food
  a curric:Misconception ;
  curric:statement """Pupils often think that the words and pictures in a food chain represent an individual plant or animal rather than populations of living things within a habitat."""@en ;
  curric:correction """It is made explicit within the examples in this lesson that each living thing named in a food chain represents a population of that type, or species, of plant or animal within a habitat."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504132Z"^^xsd:dateTime .

oakcurric:misconception-food-groups-e-g-fats
  a curric:Misconception ;
  curric:statement "Some food groups, e.g. fats, are 'bad' for you."@en ;
  curric:correction """Explanation of how using nutritional information can help us to make informed decisions about the foods that we eat."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504139Z"^^xsd:dateTime .

oakcurric:misconception-children-think-sound-travels-person
  a curric:Misconception ;
  curric:statement """Children may think that sound travels only to the person that hear it, directly from the sound source to their ear."""@en ;
  curric:correction """Ensure opportunities for children to draw diagrams of how they think sound travels, and then revisit the diagrams to make improvements or amendments with further learning."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504146Z"^^xsd:dateTime .

oakcurric:misconception-changes-environment-directly-affect-us
  a curric:Misconception ;
  curric:statement "Changes in the environment will not directly affect us."@en ;
  curric:correction """Encourage the children to become aware of many different habitats and start to see how they are all interconnected and how when one thing is changed, it can impact other living things."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504152Z"^^xsd:dateTime .

oakcurric:misconception-saltwater-safe-drink
  a curric:Misconception ;
  curric:statement "Saltwater is safe to drink."@en ;
  curric:correction """Teaching slides will explain that drinking saltwater can make us ill and will explain the process of desalination."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504159Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-insect-dead-inside
  a curric:Misconception ;
  curric:statement """Pupils may think that the insect is dead inside the pupa, or that the pupa is not a living thing."""@en ;
  curric:correction """Using the lesson resources to support, explain that the insect is alive and changing inside the pupa, even if the pupa itself doesn't move."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504188Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sounds-inside-sound
  a curric:Misconception ;
  curric:statement """Pupils often think that sounds are inside the sound source waiting to come out. They may also think that the volume of sounds are the same no matter how far away from them you are."""@en ;
  curric:correction """Recap how sounds are made when an object vibrates. Pupils will plan an investigation to find out for themselves by measuring the volume of sounds as they move further away from the sound source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504201Z"^^xsd:dateTime .

oakcurric:misconception-children-believe-sound-produced-without
  a curric:Misconception ;
  curric:statement "Children often believe that sound can be produced without using any materials."@en ;
  curric:correction """Ensure opportunities for children to learn about objects vibrating in order to produce sounds."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504207Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-make-seeds
  a curric:Misconception ;
  curric:statement """Pupils may think that plants make seeds automatically as a part of their life cycle, rather than needing pollination to take place."""@en ;
  curric:correction """Explain that flowers can only make seeds once pollination and fertilisation has happened."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504216Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-value-representing-data
  a curric:Misconception ;
  curric:statement """Pupils may not recognise the value of representing data on graphs or charts and might view it as just another task to complete."""@en ;
  curric:correction """Using the lesson resources, clearly explain the value of presenting data in a chart or graph and how it makes information easier to understand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504236Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-grow-their-birthday
  a curric:Misconception ;
  curric:statement """Pupils may think that they grow on their birthday, rather than growth being gradual and continuous."""@en ;
  curric:correction """Using the lesson resources to support, explain to children that during childhood they are slowly and continuously changing and growing."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504245Z"^^xsd:dateTime .

oakcurric:misconception-children-think-bones-unbreakable
  a curric:Misconception ;
  curric:statement "Children may think that bones are unbreakable."@en ;
  curric:correction """Show children X-rays of broken bones and give them examples of where we wear extra protection to protect our bones."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504252Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-word-drug-refers
  a curric:Misconception ;
  curric:statement """Pupils may think that the word ‘drug’ only refers to illegal drugs due to its common usage and that taking any drug will have a negative impact on their body."""@en ;
  curric:correction """Using the examples in the lesson, explain that a drug is any substance which changes the way our bodies work and that they can be helpful or harmful."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504264Z"^^xsd:dateTime .

oakcurric:misconception-plants-animals-eat-food
  a curric:Misconception ;
  curric:statement "All plants and animals 'eat' food."@en ;
  curric:correction "Explanation of how plants can make their own food and that animals cannot."@en ;
  dcterms:modified "2026-02-19T08:26:10.504276Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-everyone-goes-go
  a curric:Misconception ;
  curric:statement """Pupils may think that everyone goes through, or should go through puberty, at the same time."""@en ;
  curric:correction """Using the lesson resources to support, explain that everybody is different and will go through puberty at different times."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504309Z"^^xsd:dateTime .

oakcurric:misconception-humans-separate-ecosystem-human-actions
  a curric:Misconception ;
  curric:statement """Humans are separate from an ecosystem and human actions cannot affect an ecosystem."""@en ;
  curric:correction """Using the slides and secondary sources, share with pupils the many different ways that human actions can negatively impact on animals' environments and endanger the animals that live there."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504315Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-volume-sound-cannot
  a curric:Misconception ;
  curric:statement """Pupils may think that volume of sound cannot be measured, as they may not have encountered equipment or the units of measurement for doing so."""@en ;
  curric:correction """Allow opportunities to measure the volume of a range of everyday sounds so that pupils become familiar with decibel levels."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504321Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-circuit-diagrams-drawn
  a curric:Misconception ;
  curric:statement """Pupils may think circuit diagrams should be drawn in 3D or that they are maps of circuits, drawn to scale with wobbly lines like roads on a map."""@en ;
  curric:correction """Pupils will be taught to draw and interpret circuit symbols and diagrams and will practice doing so."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504337Z"^^xsd:dateTime .

oakcurric:misconception-foods-containing-fats-bad-us
  a curric:Misconception ;
  curric:statement "All foods containing fats are 'bad' for us and we should not eat them."@en ;
  curric:correction """Humans need some fat as part of a balanced diet but a diet that is very high in fat is not healthy for humans."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504344Z"^^xsd:dateTime .

oakcurric:misconception-children-think-appliance-requires-batteries
  a curric:Misconception ;
  curric:statement """Children may think that an appliance requires batteries and is not an electrical appliance as it is not 'plugged in' for use."""@en ;
  curric:correction """Ensure opportunities for children to consider a range of appliances and how they are powered by electricity to perform a function."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504351Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-variables-interact-within
  a curric:Misconception ;
  curric:statement """Pupils may not understand how variables interact within a circuit and how changes in one variable can affect others."""@en ;
  curric:correction """Teaching slides will explain that variables are controlled in comparative and fair tests, and that the same can be done in circuits when adjusting variables like voltage to see how they affect things like brightness of bulbs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504388Z"^^xsd:dateTime .

oakcurric:misconception-children-think-protein-provided-foods
  a curric:Misconception ;
  curric:statement """Children may think that protein can only be provided by foods that come from animal sources."""@en ;
  curric:correction """Explain to children that the protein we eat can often come from both plants and animals."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504399Z"^^xsd:dateTime .

oakcurric:misconception-children-think-doesnt-rain-much
  a curric:Misconception ;
  curric:statement """Children may think that it doesn't rain very much in countries with warmer climates."""@en ;
  curric:correction """Through the lesson, and drawing on children from other countries in your class, discuss the rainfall and weather to illustrate this is not the case. The data within the slides will help illustrate this."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504410Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-consumers-food-chain
  a curric:Misconception ;
  curric:statement """Pupils may think that the consumers in a food chain are organised in order of importance."""@en ;
  curric:correction """This lesson focuses on food chains showing how living things depend on each other for food. Individual living things in a food chain are just as important as each other."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504417Z"^^xsd:dateTime .

oakcurric:misconception-electricity-stored-within-cell-battery
  a curric:Misconception ;
  curric:statement "Electricity is stored within a cell or battery."@en ;
  curric:correction """Children will model and learn that the battery provides the push to start the flow of electricity rather than being the store of it."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504458Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-ready-meals-contain
  a curric:Misconception ;
  curric:statement """Pupils may think that 'ready meals' contain the same nutrients as meals we have prepared and cooked ourselves."""@en ;
  curric:correction "Explanation of how processed foods can contain added salt, sugar and fat."@en ;
  dcterms:modified "2026-02-19T08:26:10.504465Z"^^xsd:dateTime .

oakcurric:misconception-children-think-sounds-quieter-muffled
  a curric:Misconception ;
  curric:statement """Children often think that sounds will be quieter and more muffled when travelling through a solid medium."""@en ;
  curric:correction """It is important for children to try string telephones out for themselves to hear how sounds can be louder and clearer travelling through a solid medium."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504471Z"^^xsd:dateTime .

oakcurric:misconception-believe-small-weak-muscles-cant
  a curric:Misconception ;
  curric:statement """May believe that if you have small, weak muscles you can’t make them bigger and stronger."""@en ;
  curric:correction """Show the children that through using certain exercises most people can make their muscles stronger."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504478Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plant-start-food
  a curric:Misconception ;
  curric:statement """Pupils may think that a plant is at the start of the food chain because it is the smallest organism or because it cannot eat an animal."""@en ;
  curric:correction """This lesson makes reference to the fact that the plant is the producer in a food chain because it makes, or produces, its own food."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504484Z"^^xsd:dateTime .

oakcurric:misconception-children-think-sound-travels-solid
  a curric:Misconception ;
  curric:statement """Children may think that sound  travels through all solid materials in the same way."""@en ;
  curric:correction """The investigation in this lesson allows children to find out for themselves, first-hand, that sound does not travel through all solid materials in the same way and that some materials are better sound insulators than others."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504529Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-plants-green-flowers
  a curric:Misconception ;
  curric:statement "Pupils may believe that all plants are green and have flowers."@en ;
  curric:correction """Clarify with a range of examples that some plants have flowers and some don't. Discuss with the pupils if they think even flowering plants will always have a flower on them all year round."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504554Z"^^xsd:dateTime .

oakcurric:misconception-children-ask-questions-dont-answer
  a curric:Misconception ;
  curric:statement "Children may ask questions that don't have a yes or no answer."@en ;
  curric:correction """Keep reminding the children that their questions need to have a yes/no answer and that this is how a classification key works to help us to group and identify unknown objects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504643Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-plants-adapt
  a curric:Misconception ;
  curric:statement """Pupils may think that animals and plants can adapt to their habitats, no matter how they change."""@en ;
  curric:correction """Use the lesson resources to make it clear that adaptations take a very long time and sometimes habitats change too fast for this to happen."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504713Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-alcohol-safe-adults
  a curric:Misconception ;
  curric:statement """Pupils may think that alcohol is safe for adults to drink because it is not illegal."""@en ;
  curric:correction """Explain that, although it is legal for adults to drink alcohol, it can still be harmful. This can be supported with examples of the impact alcohol has on the body (shared in the slide deck)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504736Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-life-expectancy-prediction
  a curric:Misconception ;
  curric:statement """Pupils may think that life expectancy is a prediction for individuals or a guarantee."""@en ;
  curric:correction """Using the lesson resources to support, explain that life expectancy is a measurement we can make using data that we have about human lifespans. We cannot use it to predict how long an individual or group’s life will be."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504743Z"^^xsd:dateTime .

oakcurric:misconception-children-lack-awareness-way-living
  a curric:Misconception ;
  curric:statement """Children can lack awareness of the way in which living things within an environment depend upon each other. They may think that they are dependent on humans to supply them with their needs."""@en ;
  curric:correction """Through the lesson, children will see examples of how nature reserves and the animals and plants within it support each other."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504866Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-environment-another-word
  a curric:Misconception ;
  curric:statement "Pupils may think that the environment is just another word for nature."@en ;
  curric:correction """Encourage pupils to become aware of many different environments and refer to the surroundings that an animal or plant lives in."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504873Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-bird-inside-egg
  a curric:Misconception ;
  curric:statement """Pupils may think the bird inside the egg is not living or that it is a small but fully formed bird."""@en ;
  curric:correction """Explain, using the slides, that the living bird inside the egg grows and forms until it is ready to hatch."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504928Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-bees-animals-pollinate
  a curric:Misconception ;
  curric:statement """Pupils may think that bees are the only animals that pollinate plants or that bees are the only pollinators currently in decline."""@en ;
  curric:correction """Explain that many types of insects, as well as some birds and mammals, can be pollinators and that many of these animal species are also in decline."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504952Z"^^xsd:dateTime .

oakcurric:misconception-heavy-objects-fall-faster-light
  a curric:Misconception ;
  curric:statement "Heavy objects fall faster than light objects."@en ;
  curric:correction """The activity of dropping two plastic bottles (one filled and one half-filled with water) will help children see what happens."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504979Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-height-dependent-age
  a curric:Misconception ;
  curric:statement """Pupils may think that height is dependent on age, so taller adults must be older than shorter ones."""@en ;
  curric:correction """Explain that by the time humans reach adulthood they have stopped growing. At this point, their height is not related to their age. Use examples of familiar adults such as staff members to make this clear."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504986Z"^^xsd:dateTime .

oakcurric:misconception-words-different-meanings-day-day
  a curric:Misconception ;
  curric:statement """Some words have different meanings in day-to-day life compared to their meaning in science (cell, battery and circuit)."""@en ;
  curric:correction "Teachings slides will discuss confusion with words circuit, cell and battery."@en ;
  dcterms:modified "2026-02-19T08:26:10.504992Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-light-sources-made
  a curric:Misconception ;
  curric:statement """Pupils may think that all light sources are made by humans. Pupils may think that the Moon is a light source."""@en ;
  curric:correction """Explanation that light sources can be natural or made by humans - use examples within the lesson slides. Explanation that the Moon does not produce its own light and is not a light source."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504999Z"^^xsd:dateTime .

oakcurric:misconception-pupils-limited-view-animal-mammal
  a curric:Misconception ;
  curric:statement """Pupils may have a limited view of what an animal is: mammal with fur and four legs. This can affect the way they classify animals. Also, that its habitat is an observable characteristic."""@en ;
  curric:correction """Use a wide range of animals including invertebrates and vertebrates, and those that live on land and in the sea, to help them look at observable characteristics when grouping."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505005Z"^^xsd:dateTime .

oakcurric:misconception-kicks-throws-catches-pushes-pulls
  a curric:Misconception ;
  curric:statement "Kicks/throws and catches are not pushes and pulls."@en ;
  curric:correction """Explicit explanation that kicks and throws are pushes, and catches are pulls; that pushes and pulls can involve short term contact."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505012Z"^^xsd:dateTime .

oakcurric:misconception-problem-using-fossil-fuels-generate
  a curric:Misconception ;
  curric:statement """The only problem with using fossil fuels to generate electricity is that burning them produces greenhouse gases."""@en ;
  curric:correction """The lesson will explore additional concerns including the finite supply of fossil fuels and the fact that burning them causes air pollution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505018Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-foods-containing-fats
  a curric:Misconception ;
  curric:statement """Pupils may think that foods containing fats are 'bad' for humans and we should not eat them."""@en ;
  curric:correction """Emphasise to pupils that humans need some fat as part of a balanced diet and it is a diet that is very high in fat that is not healthy for humans. The foods themselves are ok to eat as part of a balanced diet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505025Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-birds-lay-eggs
  a curric:Misconception ;
  curric:statement "Pupils may think that only birds lay eggs."@en ;
  curric:correction """Use the lesson resources to make it clear that other animals, including amphibians, lay eggs and these can look different to bird eggs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505034Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-humans-animals
  a curric:Misconception ;
  curric:statement "Pupils may think that humans are not animals."@en ;
  curric:correction """Explain that humans are animals and are part of the mammal group. Make clear the characteristics we have that mean we fit into this group."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505041Z"^^xsd:dateTime .

oakcurric:misconception-children-think-appliance-powered-batteries
  a curric:Misconception ;
  curric:statement """Children may think that an appliance powered by batteries is not an electrical appliance as it is not 'plugged in' for use."""@en ;
  curric:correction """Ensure opportunities for children to consider a range of appliances and how they are powered by electricity to perform a function."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505049Z"^^xsd:dateTime .

oakcurric:misconception-materials-reflect-same-amount-light
  a curric:Misconception ;
  curric:statement "All materials reflect the same amount of light."@en ;
  curric:correction """Explanation that we can measure the differing amounts of light reflected by different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505070Z"^^xsd:dateTime .

oakcurric:misconception-children-make-link-types-teeth
  a curric:Misconception ;
  curric:statement "Children may not make the link between types of teeth and types of food we eat."@en ;
  curric:correction """Show the children, through images and practical investigation, that humans all have the same variety of teeth to eat a variety of food. It might be useful to discuss how non-meat eating humans do still have canine and incisor teeth."""@en ;
  dcterms:modified "2026-02-19T08:26:10.506236Z"^^xsd:dateTime .
