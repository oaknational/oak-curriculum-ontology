# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-3373-1
  a curric:KeyLearningPoint ;
  rdfs:label "A healthy, balanced diet helps to improve heart health."@en ;
  dcterms:modified "2026-02-19T08:26:13.515800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3373-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being physically active is a major step toward strengthening the heart muscle and improving heart health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heart-pumping aerobic exercise is recommended for at least an hour a day for children."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3373-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of aerobic exercise are brisk walking, running, swimming and cycling."@en ;
  dcterms:modified "2026-02-19T08:26:13.515812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3357-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are living things that grow and reproduce"@en ;
  dcterms:modified "2026-02-19T08:26:13.517388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3357-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flowering plant life cycle stages include: germination, growing, pollination, seed formation and seed dispersal"""@en ;
  dcterms:modified "2026-02-19T08:26:13.517392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3357-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams are used to show the stages in a life cycle"@en ;
  dcterms:modified "2026-02-19T08:26:13.517396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Life cycles of different plants can be observed over time and/or researched using secondary sources of information"""@en ;
  dcterms:modified "2026-02-19T08:26:13.517400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2669-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equipment such as a light sensor and data logger can be used to measure and record bulb brightness in lux."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2669-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the voltage of batteries can affect the brightness of a bulb in a simple circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2669-3
  a curric:KeyLearningPoint ;
  rdfs:label """A lower voltage leads to a dimmer bulb and a higher voltage leads to a brighter bulb."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2669-4
  a curric:KeyLearningPoint ;
  rdfs:label """A higher voltage can cause the bulb to burn out or blow due to excess heat generated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2669-5
  a curric:KeyLearningPoint ;
  rdfs:label """The results of an investigation can be recorded in a table and presented using verbal and written forms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2668-1
  a curric:KeyLearningPoint ;
  rdfs:label """A cell is a single unit that is needed for electricity to flow around a circuit and a battery is a group of cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2668-2
  a curric:KeyLearningPoint ;
  rdfs:label """The V on a cell stands for volts, and is a measure of the size of electrical push it provides to a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2668-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cells or batteries with a higher voltage provide a stronger electrical push to a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2668-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding more cells produces a higher voltage and a stronger electrical push to a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2668-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists plan different types of enquiries to find answers to questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.521782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3368-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rust is reddish brown in colour and has a rough texture."@en ;
  dcterms:modified "2026-02-19T08:26:13.542617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3368-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rust is a new material that is formed when iron or steel is exposed to oxygen in the air and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.542623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3368-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting is an irreversible change whereby the original material cannot easily be recovered."""@en ;
  dcterms:modified "2026-02-19T08:26:13.542627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3368-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting materials can be looked at closely as they change over time, using observation skills."""@en ;
  dcterms:modified "2026-02-19T08:26:13.542631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make careful observations to investigate which drinks are harmful to teeth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3334-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists review data collected from observations and write conclusions."@en ;
  dcterms:modified "2026-02-19T08:26:13.543335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3334-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a conclusion, scientists often refer to earlier predictions of what they thought was going to happen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3334-4
  a curric:KeyLearningPoint ;
  rdfs:label """Too much sugar in food or drink can damage teeth. Information about sugar content in drinks can be found on packaging."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3334-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists often present data in a graph to help explain their conclusions to other people."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1264-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans have two sets of teeth in their lifetime; the teeth you have as a child are replaced by adult teeth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.557510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1264-2
  a curric:KeyLearningPoint ;
  rdfs:label "A build up of plaque can lead to tooth decay."@en ;
  dcterms:modified "2026-02-19T08:26:13.557514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1264-3
  a curric:KeyLearningPoint ;
  rdfs:label """To look after your teeth, visit the dentist for regular check-ups and brush twice a day with fluoride toothpaste."""@en ;
  dcterms:modified "2026-02-19T08:26:13.557518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1264-4
  a curric:KeyLearningPoint ;
  rdfs:label "Food and drink that contains lots of sugar can cause tooth decay."@en ;
  dcterms:modified "2026-02-19T08:26:13.557522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1264-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists investigate which drinks are harmful to teeth."@en ;
  dcterms:modified "2026-02-19T08:26:13.557525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2633-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists carry out different types of enquiries to answer questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.561679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2633-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists take accurate measurements using a range of scientific equipment."@en ;
  dcterms:modified "2026-02-19T08:26:13.561683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2633-3
  a curric:KeyLearningPoint ;
  rdfs:label "The findings from an investigation can be summarised into a conclusion."@en ;
  dcterms:modified "2026-02-19T08:26:13.561687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2680-1
  a curric:KeyLearningPoint ;
  rdfs:label "When light is reflected off the surface of an object, it changes direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.562184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2680-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific diagrams and models can be used to show how light changes direction when it is reflected off surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2680-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mirrors are sometimes used to deliberately change the direction of a beam of light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2680-4
  a curric:KeyLearningPoint ;
  rdfs:label """A periscope has angled mirrors to enable you to see over walls or around corners."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists group micro-organisms to make it easier to identify, name and learn about them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2662-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different groups of micro-organisms such as viruses, bacteria and fungi, with different structures and shapes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2662-3
  a curric:KeyLearningPoint ;
  rdfs:label "Micro-organisms can be harmful or helpful."@en ;
  dcterms:modified "2026-02-19T08:26:13.563116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2662-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to classify and group micro-organisms so that we can understand their uses and treatments."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2764-1
  a curric:KeyLearningPoint ;
  rdfs:label "Germination is when a seed first starts to grow into a plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.563192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2764-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a seed to germinate, the conditions must be right; including access to water, air and warmth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2764-3
  a curric:KeyLearningPoint ;
  rdfs:label """The life cycle of a flowering plant includes germination, growing, pollination, seed formation and seed dispersal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2764-4
  a curric:KeyLearningPoint ;
  rdfs:label "Life cycles can be presented in different ways including oral and written forms."@en ;
  dcterms:modified "2026-02-19T08:26:13.563207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3397-1
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow is formed when an object blocks light travelling from a light source."@en ;
  dcterms:modified "2026-02-19T08:26:13.564653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3397-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams can help us to understand shadows."@en ;
  dcterms:modified "2026-02-19T08:26:13.564657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3397-3
  a curric:KeyLearningPoint ;
  rdfs:label "The shape of a shadow depends on the shape of the object blocking the light."@en ;
  dcterms:modified "2026-02-19T08:26:13.564661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because light travels in straight lines, the shape of the shadow will be the same as the outline shape of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2654-1
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree is a diagram that shows the relationships between all the people in a family over many generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2654-2
  a curric:KeyLearningPoint ;
  rdfs:label """The top level of a family tree is the earliest generation, followed by their children and so on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2654-3
  a curric:KeyLearningPoint ;
  rdfs:label "Similarities and differences can be identified using observation skills."@en ;
  dcterms:modified "2026-02-19T08:26:13.565053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light can come from many different sources, such as the Sun, stars, torches, lamps and candles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2677-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some objects appear to shine but they are reflecting light from a light source."@en ;
  dcterms:modified "2026-02-19T08:26:13.565380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2677-3
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be identified and grouped as light sources and light reflectors."@en ;
  dcterms:modified "2026-02-19T08:26:13.565402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9181-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans have used light sources to make their lives easier since ancient times."@en ;
  dcterms:modified "2026-02-19T08:26:13.565423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9181-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers invent and design ways for us to use light to achieve different effects."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9181-3
  a curric:KeyLearningPoint ;
  rdfs:label """When more than one light is used, more than one shadow can be cast by one object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9181-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists gather evidence to answer questions and support their ideas."@en ;
  dcterms:modified "2026-02-19T08:26:13.565435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1271-1
  a curric:KeyLearningPoint ;
  rdfs:label "Solids, liquids and gases have different properties"@en ;
  dcterms:modified "2026-02-19T08:26:13.567248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1271-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can observe and classify materials as solid, liquid or gas state"@en ;
  dcterms:modified "2026-02-19T08:26:13.567252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1271-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some objects are made from different materials, so can have properties of more than one state"""@en ;
  dcterms:modified "2026-02-19T08:26:13.567256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1271-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials are difficult to classify because they appear to have properties of both solids and liquids"""@en ;
  dcterms:modified "2026-02-19T08:26:13.567260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1220-1
  a curric:KeyLearningPoint ;
  rdfs:label "Objects move differently over different surfaces."@en ;
  dcterms:modified "2026-02-19T08:26:13.567341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1220-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can carry out comparative test investigations to compare different surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1220-3
  a curric:KeyLearningPoint ;
  rdfs:label "Friction forces slow down moving objects."@en ;
  dcterms:modified "2026-02-19T08:26:13.567350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1220-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rough surface will create a greater friction force against a moving object than a smooth surface."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1220-5
  a curric:KeyLearningPoint ;
  rdfs:label "In a conclusion, scientists explain what the results show or mean."@en ;
  dcterms:modified "2026-02-19T08:26:13.567358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1206-1
  a curric:KeyLearningPoint ;
  rdfs:label """Geologists test different rocks for permeability. This tells them which rocks allow liquid, e.g. water, to pass through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1206-2
  a curric:KeyLearningPoint ;
  rdfs:label "Permeable rocks, such as sandstone, let water pass through them."@en ;
  dcterms:modified "2026-02-19T08:26:13.567366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1206-3
  a curric:KeyLearningPoint ;
  rdfs:label "Impermeable rocks, such as marble, do not let water pass through them."@en ;
  dcterms:modified "2026-02-19T08:26:13.567370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1206-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rocks can be compared and grouped by their permeability."@en ;
  dcterms:modified "2026-02-19T08:26:13.567374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1237-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many plants have roots, stems, leaves and flowers."@en ;
  dcterms:modified "2026-02-19T08:26:13.567477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1237-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can make their own food. This happens in the leaves of a plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.567482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1237-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants make food in their leaves, using sunlight, carbon dioxide and water."@en ;
  dcterms:modified "2026-02-19T08:26:13.567486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1237-4
  a curric:KeyLearningPoint ;
  rdfs:label """To investigate why plants have leaves, a plant with leaves removed can be observed over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3389-1
  a curric:KeyLearningPoint ;
  rdfs:label "Taxonomists describe thousands and thousands of new living species every year."@en ;
  dcterms:modified "2026-02-19T08:26:13.567611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3389-2
  a curric:KeyLearningPoint ;
  rdfs:label """New species must be described in detail, including which features make it similar and different to close relatives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3389-3
  a curric:KeyLearningPoint ;
  rdfs:label "Species are always identified by both a generic name and a species name."@en ;
  dcterms:modified "2026-02-19T08:26:13.567621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3389-4
  a curric:KeyLearningPoint ;
  rdfs:label """Species names are written in Latin, but many species names are based on words from other languages, and are Latinized."""@en ;
  dcterms:modified "2026-02-19T08:26:13.567625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1274-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are lots of examples of solids and liquids changing state in real life."@en ;
  dcterms:modified "2026-02-19T08:26:13.569218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1274-2
  a curric:KeyLearningPoint ;
  rdfs:label """Everyday examples of materials changing between solid state and liquid state include butter, chocolate and candle wax."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1274-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many people use their understanding of solids and liquids changing state in their work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1274-4
  a curric:KeyLearningPoint ;
  rdfs:label """Everyday examples of materials changing from liquid state to solid state include liquid lava changing to solid rock."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2682-1
  a curric:KeyLearningPoint ;
  rdfs:label """If you change the angle that light hits a surface, the angle of reflection will also change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2682-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mirrors are highly reflective. They are sometimes used to deliberately change the direction that light travels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2682-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reflected light bounces off the surface at the same angle as it hits it."@en ;
  dcterms:modified "2026-02-19T08:26:13.569822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2682-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you measure angles, it is acceptable for results to vary slightly because it is difficult to measure perfectly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2755-1
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic forces can act at a distance when some materials are placed between the magnet and the magnetic material"""@en ;
  dcterms:modified "2026-02-19T08:26:13.570274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2755-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can carry out investigations to test which materials allow magnetic force to pass through"""@en ;
  dcterms:modified "2026-02-19T08:26:13.570278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2755-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes the results of an investigation are different to what was expected or predicted"""@en ;
  dcterms:modified "2026-02-19T08:26:13.570282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9035-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide and other greenhouse gases trap heat in the atmosphere, leading to warmer temperatures on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9035-2
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon footprint is a measure of the amount of greenhouse gases that are released when we do everyday things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9035-3
  a curric:KeyLearningPoint ;
  rdfs:label """The measure of a carbon footprint includes what we eat, how we travel, how often we buy new things, and much more."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9035-4
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone can take action to reduce their carbon footprint."@en ;
  dcterms:modified "2026-02-19T08:26:13.570478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2681-1
  a curric:KeyLearningPoint ;
  rdfs:label """An angle is the space between two straight lines which join at a vertex or point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2681-2
  a curric:KeyLearningPoint ;
  rdfs:label "A protractor is a piece of equipment used to measure and draw angles."@en ;
  dcterms:modified "2026-02-19T08:26:13.570644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2681-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we measure the angle of light hitting a surface, we measure the angle between that light and the normal line."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2681-4
  a curric:KeyLearningPoint ;
  rdfs:label "The normal line is an imaginary line that is at a right angle to the surface."@en ;
  dcterms:modified "2026-02-19T08:26:13.570656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1279-1
  a curric:KeyLearningPoint ;
  rdfs:label "Water in the liquid state can change into water in the gas state (water vapour)."@en ;
  dcterms:modified "2026-02-19T08:26:13.571226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1279-2
  a curric:KeyLearningPoint ;
  rdfs:label """In its gas state, water is invisible, can flow, has no fixed volume and takes the shape of the whole of its container."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1279-3
  a curric:KeyLearningPoint ;
  rdfs:label "The process in which a liquid changes to a gas is called evaporation."@en ;
  dcterms:modified "2026-02-19T08:26:13.571234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1279-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be observed changing from liquid to gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.571263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1279-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the state of a liquid to a gas by heating."@en ;
  dcterms:modified "2026-02-19T08:26:13.571267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3396-1
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow is a dark shape formed when light is stopped or blocked by an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.572008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3396-2
  a curric:KeyLearningPoint ;
  rdfs:label """Opaque objects do not allow light to travel through them. Translucent objects let some light through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3396-3
  a curric:KeyLearningPoint ;
  rdfs:label """A shadow can be different sizes depending on the distance of the object from the light source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3396-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shadows are dark where the light has been blocked and they do not show the features of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3396-5
  a curric:KeyLearningPoint ;
  rdfs:label "Shadows of objects are not the same as reflections of them."@en ;
  dcterms:modified "2026-02-19T08:26:13.572025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Everyday examples of evaporation can include puddles disappearing and wet clothing drying."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Everyday examples of condensation can include foggy mirrors, windows and glasses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists learn about evaporation and condensation using observation and investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2766-1
  a curric:KeyLearningPoint ;
  rdfs:label """A good habitat for a plant provides a combination of air, light, water, nutrients from the soil and room to grow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2766-2
  a curric:KeyLearningPoint ;
  rdfs:label "The requirements of plants for life and growth vary from plant to plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.572598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2766-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different habitats provide different conditions that plants need to survive."@en ;
  dcterms:modified "2026-02-19T08:26:13.572602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2766-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plant which grows well in the desert would not survive in the Arctic."@en ;
  dcterms:modified "2026-02-19T08:26:13.572606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2766-5
  a curric:KeyLearningPoint ;
  rdfs:label "A plant which thrives in wetlands would not survive in dry climates."@en ;
  dcterms:modified "2026-02-19T08:26:13.572610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3386-1
  a curric:KeyLearningPoint ;
  rdfs:label """Yeast consumes sugar and releases carbon dioxide gas as a result. This is called fermentation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3386-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists control variables to see the effect of changing one variable."@en ;
  dcterms:modified "2026-02-19T08:26:13.572638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3386-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fermentation can be observed over time and recorded using scientific diagrams, tables and charts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3386-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use the results of their enquiries to make a conclusion that addresses their investigation question."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3386-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists evaluate their investigations by thinking about how well they went and how reliable their results are."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1280-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water vapour (water in the gas state) turns into a water in the liquid state when it is cooled."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1280-2
  a curric:KeyLearningPoint ;
  rdfs:label """The process in which water changes from the gas to the liquid state is called condensation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1280-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the state of a gas to a liquid by cooling."@en ;
  dcterms:modified "2026-02-19T08:26:13.572665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1280-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be observed changing from gas state to liquid state when cooled."@en ;
  dcterms:modified "2026-02-19T08:26:13.572669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1250-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists look for patterns in data, to tell them how one thing affects another thing."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1250-2
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion of an investigation is when scientists explain what the results show or mean."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1250-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our bones grow in length as we age, until we become an adult."@en ;
  dcterms:modified "2026-02-19T08:26:13.573675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1250-4
  a curric:KeyLearningPoint ;
  rdfs:label """The length of some bones can be used to estimate the length of other bones, and our body height."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2628-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists take, repeat and compare measurements using a range of scientific equipment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2628-2
  a curric:KeyLearningPoint ;
  rdfs:label """The evaluation of an investigation can include an explanation of, and degree of trust in, the results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2628-3
  a curric:KeyLearningPoint ;
  rdfs:label "Greater surface area on a moving object can increase water resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.574689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1221-1
  a curric:KeyLearningPoint ;
  rdfs:label "Friction can be a useful force."@en ;
  dcterms:modified "2026-02-19T08:26:13.575324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1221-2
  a curric:KeyLearningPoint ;
  rdfs:label "Friction can be an unhelpful force."@en ;
  dcterms:modified "2026-02-19T08:26:13.575328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1221-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists, designers and engineers need to choose materials with properties suitable for their work or products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1221-4
  a curric:KeyLearningPoint ;
  rdfs:label "Large amounts of friction can create heat"@en ;
  dcterms:modified "2026-02-19T08:26:13.575336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3344-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water doesn’t leave Earth’s atmosphere.  It moves around in what is called the water cycle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water evaporates from sources such as seas and rivers, as well as from Earth's surface."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3344-3
  a curric:KeyLearningPoint ;
  rdfs:label """As it moves through the water cycle, water can be in the liquid state, gas state (water vapour), or solid state (ice)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3344-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water vapour rises into the atmosphere then cools and condenses into clouds."@en ;
  dcterms:modified "2026-02-19T08:26:13.575377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3344-5
  a curric:KeyLearningPoint ;
  rdfs:label """Water falls to the surface as precipitation (rain, snow, sleet) to continue the process."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9178-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists share their test results and conclusions with engineers to help in the design of new products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9178-2
  a curric:KeyLearningPoint ;
  rdfs:label "Good quality communication is needed to make sure new problems don't arise."@en ;
  dcterms:modified "2026-02-19T08:26:13.576984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9178-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers understand their role in a project to make sure it runs smoothly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9178-4
  a curric:KeyLearningPoint ;
  rdfs:label "Teams are resilient and think of solutions to problems they find."@en ;
  dcterms:modified "2026-02-19T08:26:13.576992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1207-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weathering is the breaking down of rocks on Earth’s surface, over time, by natural forces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1207-2
  a curric:KeyLearningPoint ;
  rdfs:label """Erosion is when land is worn away by natural forces, such as water or wind, and transported to another location."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1207-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weathering and erosion of rock can cause habitat loss and natural disasters."@en ;
  dcterms:modified "2026-02-19T08:26:13.577005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1207-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of scientists, including geologists, work to eliminate the negative effects of weathering and erosion."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2635-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some solids dissolve in liquids to form a solution."@en ;
  dcterms:modified "2026-02-19T08:26:13.577051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2635-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solutions are always clear, though they may or may not have a colour."@en ;
  dcterms:modified "2026-02-19T08:26:13.577055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2635-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a solid dissolves, it is broken down to become so tiny we can no longer see it, but it is still there."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2635-4
  a curric:KeyLearningPoint ;
  rdfs:label "A substance that dissolves is said to be soluble."@en ;
  dcterms:modified "2026-02-19T08:26:13.577063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2635-5
  a curric:KeyLearningPoint ;
  rdfs:label "A substance that does not dissolve is said to be insoluble."@en ;
  dcterms:modified "2026-02-19T08:26:13.577069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9037-1
  a curric:KeyLearningPoint ;
  rdfs:label """A solar panel is a collection of many solar cells, with each solar cell converting light from the Sun into electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9037-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity generated using solar panels is renewable, as the Sun will always be there as an energy source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solar panels can be fitted onto houses and schools and are a renewable energy source for generating electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9037-4
  a curric:KeyLearningPoint ;
  rdfs:label """A solar farm is an area of land that is covered with up to thousands of solar panels to generate lots of electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1239-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants use their roots to absorb the water they need from the soil."@en ;
  dcterms:modified "2026-02-19T08:26:13.577907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1239-2
  a curric:KeyLearningPoint ;
  rdfs:label """The functions of a stem are to provide support for the plant and to transport water and nutrients."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1239-3
  a curric:KeyLearningPoint ;
  rdfs:label "Water travels from the roots, up the stem to the leaves and flowers."@en ;
  dcterms:modified "2026-02-19T08:26:13.577915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1239-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in plants can be observed over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.577921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3387-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mould is a type of fungus and can be grouped with other fungi including yeast, mushrooms, lichens, and truffles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mould can be observed and measured growing on food over time, following strict safety rules."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3387-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists present data in a variety of ways to help them form conclusions."@en ;
  dcterms:modified "2026-02-19T08:26:13.578814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mould growth can be slowed or prevented in different ways, such as dehydration, refrigeration and adding preservatives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1277-1
  a curric:KeyLearningPoint ;
  rdfs:label """The melting temperature is the temperature at which a material in its solid state changes to its liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1277-2
  a curric:KeyLearningPoint ;
  rdfs:label "Thermometers can be used to measure temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.580400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1277-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists take accurate measurements of temperature in units of degrees Celsius."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1277-4
  a curric:KeyLearningPoint ;
  rdfs:label """The results of an investigation can often be recorded in a table, chart or graph."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1277-5
  a curric:KeyLearningPoint ;
  rdfs:label "Results can be used to draw simple conclusions and suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.580415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1251-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different animals have different skeletons, including its size, shape and number of bones"""@en ;
  dcterms:modified "2026-02-19T08:26:13.580535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1251-2
  a curric:KeyLearningPoint ;
  rdfs:label "A skeleton that is inside of the body is called an endoskeleton"@en ;
  dcterms:modified "2026-02-19T08:26:13.580540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1251-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals that have a spine inside their bodies are classed as vertebrates"@en ;
  dcterms:modified "2026-02-19T08:26:13.580544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9174-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans have found magnets to be useful in their everyday lives"@en ;
  dcterms:modified "2026-02-19T08:26:13.581116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9174-2
  a curric:KeyLearningPoint ;
  rdfs:label "Everyday uses of magnets include compasses, electronic devices and games"@en ;
  dcterms:modified "2026-02-19T08:26:13.581120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9174-3
  a curric:KeyLearningPoint ;
  rdfs:label """Maglev trains do not use an engine because they move forwards using magnets, similar to some roller coasters"""@en ;
  dcterms:modified "2026-02-19T08:26:13.581124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9174-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engineers design and build things, using their knowledge of maths and science"@en ;
  dcterms:modified "2026-02-19T08:26:13.581128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9174-5
  a curric:KeyLearningPoint ;
  rdfs:label """Men and women can become different types of engineer. They need to be curious, creative and observant"""@en ;
  dcterms:modified "2026-02-19T08:26:13.581132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9034-1
  a curric:KeyLearningPoint ;
  rdfs:label """Diamonds and the graphite used in pencil leads are both made of carbon, and these forms are harmless."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon is in the fossil fuels natural gas, crude oil and coal."@en ;
  dcterms:modified "2026-02-19T08:26:13.581190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is not dangerous; it is in the air we breathe and we add it to fizzy drinks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9034-4
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon is in carbon dioxide gas, which is produced when we burn fossil fuels."@en ;
  dcterms:modified "2026-02-19T08:26:13.581198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9034-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is causing problems as it builds up to high levels in a greenhouse gas 'blanket' around Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1203-1
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance of rocks can be observed more closely using a hand lens or microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1203-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rocks can be compared and grouped by appearance, by looking for similarities and differences."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1203-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different rocks have different names."@en ;
  dcterms:modified "2026-02-19T08:26:13.581628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1203-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rocks can be identified and named using simple secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.581634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9025-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fuel is something that can be used to produce heat or light."@en ;
  dcterms:modified "2026-02-19T08:26:13.582276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9025-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fossil fuels are found deep under Earth's surface and there is a limited amount left."""@en ;
  dcterms:modified "2026-02-19T08:26:13.582280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are a sustainable source of fuel as we can keep growing more."@en ;
  dcterms:modified "2026-02-19T08:26:13.582283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9025-4
  a curric:KeyLearningPoint ;
  rdfs:label "Like fossil fuels, biofuels release carbon dioxide on burning."@en ;
  dcterms:modified "2026-02-19T08:26:13.582290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers investigate which plants are the best ones to grow for biofuels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.582296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2641-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is much bigger than Earth and the Moon"@en ;
  dcterms:modified "2026-02-19T08:26:13.583154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2641-2
  a curric:KeyLearningPoint ;
  rdfs:label "More than one million Earths would fit into the Sun"@en ;
  dcterms:modified "2026-02-19T08:26:13.583158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2641-3
  a curric:KeyLearningPoint ;
  rdfs:label "Earth is much smaller than the Sun, but bigger that the Moon"@en ;
  dcterms:modified "2026-02-19T08:26:13.583162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2641-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Moon is approximately one quarter of the size of Earth"@en ;
  dcterms:modified "2026-02-19T08:26:13.583168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2641-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can find out about the size of objects in space by carrying out research"@en ;
  dcterms:modified "2026-02-19T08:26:13.583173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1276-1
  a curric:KeyLearningPoint ;
  rdfs:label """The process in which a material in the solid state changes to the liquid state is called melting."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1276-2
  a curric:KeyLearningPoint ;
  rdfs:label "The melting temperature is the temperature at which a solid changes to a liquid."@en ;
  dcterms:modified "2026-02-19T08:26:13.583181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1276-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials have different melting temperatures."@en ;
  dcterms:modified "2026-02-19T08:26:13.583185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1276-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions about the melting temperature of different materials and plan how to answer them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9026-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere is a mixture of gases around Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.583193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9026-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is a greenhouse gas that makes up about 0.04% of the atmosphere and is released when we burn fuels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9026-3
  a curric:KeyLearningPoint ;
  rdfs:label "Greenhouse gases in the atmosphere trap heat that warms Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.583203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9026-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing carbon dioxide levels in the atmosphere raises average temperatures on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9026-5
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature data shows evidence of Earth warming up more quickly in the last 50 years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9032-1
  a curric:KeyLearningPoint ;
  rdfs:label """A fossil fuel is a natural fuel formed from the remains of living things over millions of years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9032-2
  a curric:KeyLearningPoint ;
  rdfs:label """The type of fossil depends on the original living thing and the amounts of heat and pressure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fossil fuels have been used increasingly since the 1800s for heating, transport and generating electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9032-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fossil fuels are non-renewable, as they cannot be replaced once they have been used up."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Burning fossil fuels creates carbon dioxide and tiny pieces of solid matter, such as soot."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9036-1
  a curric:KeyLearningPoint ;
  rdfs:label "Removing carbon dioxide from the atmosphere reduces greenhouse gases."@en ;
  dcterms:modified "2026-02-19T08:26:13.584741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9036-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers are creating new ways to store carbon dioxide underground."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9036-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compressing (squeezing) carbon dioxide gas turns it into a liquid and take up less space for storage."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9036-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers are creating ways to store carbon dioxide under the North Sea."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1278-1
  a curric:KeyLearningPoint ;
  rdfs:label """The melting temperature of a material is the temperature at which it changes from solid state to liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1278-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials have different melting temperatures."@en ;
  dcterms:modified "2026-02-19T08:26:13.586933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1278-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is hard for scientists to create temperatures high enough to make some materials melt."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1278-4
  a curric:KeyLearningPoint ;
  rdfs:label "Melting temperatures can be researched using secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.586941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1278-5
  a curric:KeyLearningPoint ;
  rdfs:label """When carrying out research, more than one source should be used to check that the information is accurate and reliable."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2640-1
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout history, people have disagreed about the shape of the Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.589409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the past has helped us to understand the shape of the Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.589415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2640-3
  a curric:KeyLearningPoint ;
