  dcterms:modified "2026-02-19T08:26:13.589419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2629-1
  a curric:KeyLearningPoint ;
  rdfs:label "A lever is a simple mechanism or machine which is useful for lifting things."@en ;
  dcterms:modified "2026-02-19T08:26:13.589982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2629-2
  a curric:KeyLearningPoint ;
  rdfs:label "A lever allows a smaller force to have a greater effect."@en ;
  dcterms:modified "2026-02-19T08:26:13.589986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2629-3
  a curric:KeyLearningPoint ;
