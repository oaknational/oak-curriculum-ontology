  dcterms:modified "2026-02-19T08:26:13.589998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2648-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ideas about the solar system have developed over time"@en ;
  dcterms:modified "2026-02-19T08:26:13.590063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2648-2
  a curric:KeyLearningPoint ;
  rdfs:label """The geocentric model is the idea that the Earth is the centre of the universe and other objects go around it"""@en ;
  dcterms:modified "2026-02-19T08:26:13.590067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2648-3
  a curric:KeyLearningPoint ;
  rdfs:label """The heliocentric model is the idea that Earth and other planets move around the fixed Sun"""@en ;
  dcterms:modified "2026-02-19T08:26:13.590071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2775-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals do not have any bones."@en ;
  dcterms:modified "2026-02-19T08:26:13.590075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2775-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals that do not have bones, including a spine, inside their bodies are called invertebrates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2775-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some invertebrate animals have a hard layer or shell for protection on the outside of their bodies called an exoskeleton"""@en ;
  dcterms:modified "2026-02-19T08:26:13.590083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2775-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some invertebrate animals' bodies are filled with fluid, such as worms and jellyfish."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2676-1
  a curric:KeyLearningPoint ;
  rdfs:label "We need light to be able to see things."@en ;
  dcterms:modified "2026-02-19T08:26:13.590114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2676-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light travels out from a source of light in all directions."@en ;
  dcterms:modified "2026-02-19T08:26:13.590118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2676-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light travels in straight lines."@en ;
  dcterms:modified "2026-02-19T08:26:13.590124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2676-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use diagrams to show light travelling in straight lines ."@en ;
  dcterms:modified "2026-02-19T08:26:13.590128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2627-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water Resistance is a force which acts to slow down or stop objects that are moving through liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2627-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water resistance acts in the opposite direction to a moving object."@en ;
  dcterms:modified "2026-02-19T08:26:13.590700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions about water resistance to help them to find out more about it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2627-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists control variables and plan tests to investigate water resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.590708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3513-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon is made mostly of rock. The surface has dark spots and thousands of holes called craters."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3513-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon is far away from the Earth, and can be observed more closely using telescopes and binoculars."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3513-3
  a curric:KeyLearningPoint ;
  rdfs:label "A scientist who observes the night sky is called an astronomer."@en ;
  dcterms:modified "2026-02-19T08:26:13.591394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3513-4
  a curric:KeyLearningPoint ;
  rdfs:label "The shape of the moon appears to change throughout each month."@en ;
  dcterms:modified "2026-02-19T08:26:13.591398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3513-5
  a curric:KeyLearningPoint ;
  rdfs:label "Observations of the moon can be recorded in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.591402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2761-1
  a curric:KeyLearningPoint ;
  rdfs:label "Flowers play an important part in the life cycle of a flowering plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.591603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2761-2
  a curric:KeyLearningPoint ;
  rdfs:label """The anther is a part of the stamen that produces and holds the dusty pollen. Anthers are male parts of the flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2761-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stigma is a female part of the flower and is sticky."@en ;
  dcterms:modified "2026-02-19T08:26:13.591611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2761-4
  a curric:KeyLearningPoint ;
  rdfs:label "The ovary is where seeds are formed."@en ;
  dcterms:modified "2026-02-19T08:26:13.591615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2761-5
  a curric:KeyLearningPoint ;
  rdfs:label """Petals are brightly coloured to attract animals, such as insects and birds, to carry pollen to another flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26970-1
  a curric:KeyLearningPoint ;
  rdfs:label """If a change is reversible, it can be undone or changed back to its original state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26970-2
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture is material that contains two or more different substances, which can be physically separated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26970-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a soluble solid dissolves, it is broken down to become so tiny we can no longer see it, but it is still there."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26970-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dissolving is a reversible process. Evaporation can be used to recover soluble solids from solutions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2624-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists carry out investigations to measure and compare the amount of friction created between different surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results from an investigation can be recorded in different ways, including tables and graphs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2624-3
  a curric:KeyLearningPoint ;
  rdfs:label "The findings from an investigation can be summarised into a conclusion."@en ;
  dcterms:modified "2026-02-19T08:26:13.595534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2624-4
  a curric:KeyLearningPoint ;
  rdfs:label """Objects experience more friction when moving across rough surfaces compared to smooth surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2624-5
  a curric:KeyLearningPoint ;
  rdfs:label "Test results can be used to make predictions to set up further investigations."@en ;
  dcterms:modified "2026-02-19T08:26:13.595542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9039-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists investigate alternative energy sources to fossil fuels."@en ;
  dcterms:modified "2026-02-19T08:26:13.595967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9039-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water turbines are built below dams. Water flows down from the reservoir and turns the turbine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9039-3
  a curric:KeyLearningPoint ;
  rdfs:label "The movement of the turbine is used to generate electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.595975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Moving water is a renewable energy source as there will always be water on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9039-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists investigate how moving water in oceans can be used to generate electricity"""@en ;
  dcterms:modified "2026-02-19T08:26:13.595983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2645-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is dangerous to look directly at the Sun"@en ;
  dcterms:modified "2026-02-19T08:26:13.596386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2645-2
  a curric:KeyLearningPoint ;
  rdfs:label "From Earth, the Sun looks like it moves across the sky in the daytime"@en ;
  dcterms:modified "2026-02-19T08:26:13.596399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2645-3
  a curric:KeyLearningPoint ;
  rdfs:label "From Earth, the Sun looks like it disappears at night"@en ;
  dcterms:modified "2026-02-19T08:26:13.596404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2645-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun does not actually move around Earth, rather it is Earth that rotates on its axis"""@en ;
  dcterms:modified "2026-02-19T08:26:13.596409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2645-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can observe shadows changing throughout the day because Earth is rotating"@en ;
  dcterms:modified "2026-02-19T08:26:13.596413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3398-1
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow is a dark shape made when light is stopped or blocked by an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.597196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3398-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use drawings and diagrams to help share their ideas with other people."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3398-3
  a curric:KeyLearningPoint ;
  rdfs:label """A shadow will be cast on the opposite side of an object where the light source cannot shine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3398-4
  a curric:KeyLearningPoint ;
  rdfs:label """The position of a shadow depends upon the position of the light source, i.e. the direction of light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3398-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use test results to make predictions and set up further enquiries."@en ;
  dcterms:modified "2026-02-19T08:26:13.597215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1219-1
  a curric:KeyLearningPoint ;
  rdfs:label "Surfaces can be different, ranging from very smooth to very rough."@en ;
  dcterms:modified "2026-02-19T08:26:13.597581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1219-2
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative test investigation can be carried out to find out how different surfaces can affect how things move."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1219-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists make decisions about how to set up and carry out investigations."@en ;
  dcterms:modified "2026-02-19T08:26:13.597589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magnets have two poles: north-seeking and south-seeking"@en ;
  dcterms:modified "2026-02-19T08:26:13.598073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2754-2
  a curric:KeyLearningPoint ;
  rdfs:label "Opposite poles on a magnet attract each other"@en ;
  dcterms:modified "2026-02-19T08:26:13.598077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2754-3
  a curric:KeyLearningPoint ;
  rdfs:label "Like poles on a magnet repel each other"@en ;
  dcterms:modified "2026-02-19T08:26:13.598081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2754-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists make predictions based on results from previous investigations"@en ;
  dcterms:modified "2026-02-19T08:26:13.598087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2658-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anything can be observed and compared to another thing, based on similarities and differences."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2658-2
  a curric:KeyLearningPoint ;
  rdfs:label """Observable characteristics are properties about things that we can describe using five senses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2658-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing and grouping living things can help us to identify them."@en ;
  dcterms:modified "2026-02-19T08:26:13.601451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2765-1
  a curric:KeyLearningPoint ;
  rdfs:label """The requirements of plants for life and growth include air, light, water, nutrients from soil and room to grow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2765-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a conclusion, scientists explain what the results show or mean."@en ;
  dcterms:modified "2026-02-19T08:26:13.608694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2765-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often evaluate a completed investigation and suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.608698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26611-1
  a curric:KeyLearningPoint ;
  rdfs:label "Roots anchor the plant in soil and provide it with the support it needs."@en ;
  dcterms:modified "2026-02-19T08:26:13.608725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26611-2
  a curric:KeyLearningPoint ;
  rdfs:label """Roots absorb water and nutrients from soil to provide the plant with what it needs to grow and stay healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26611-3
  a curric:KeyLearningPoint ;
  rdfs:label """To investigate why plants have roots, a plant with roots removed can be observed over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1223-1
  a curric:KeyLearningPoint ;
  rdfs:label "A magnet is a metal that attracts some other metals"@en ;
  dcterms:modified "2026-02-19T08:26:13.608800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1223-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all metals are magnets, but all magnets are metallic"@en ;
  dcterms:modified "2026-02-19T08:26:13.608804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1223-3
  a curric:KeyLearningPoint ;
  rdfs:label "Magnetic forces are forces caused by magnets"@en ;
  dcterms:modified "2026-02-19T08:26:13.608808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1223-4
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic force was first discovered by people in ancient civilisations, when they observed a mineral called lodestone"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1223-5
  a curric:KeyLearningPoint ;
  rdfs:label """People have made discoveries about magnets, and used magnetic force to build and invent useful things"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1249-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bone is a living thing. Our bones change throughout our lives."@en ;
  dcterms:modified "2026-02-19T08:26:13.608862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1249-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions and then plan how to carry out the right type of investigation to find answers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1249-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists choose the correct equipment to be able to measure accurately."@en ;
  dcterms:modified "2026-02-19T08:26:13.608870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1249-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists gather and record data using tables and charts."@en ;
  dcterms:modified "2026-02-19T08:26:13.608874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mary Anning was a famous palaeontologist, known as one of the greatest fossil hunters to have ever lived."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2753-2
  a curric:KeyLearningPoint ;
  rdfs:label """Male scientists at the time often did not credit her discoveries because she was a woman from a poor background."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2753-3
  a curric:KeyLearningPoint ;
  rdfs:label """Today the Natural History Museum in London showcases several of Mary Anning's spectacular finds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2753-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are still fossils to discover. Anyone could become a fossil hunter!"@en ;
  dcterms:modified "2026-02-19T08:26:13.608890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1263-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different animals have different types of teeth dependent on the types of food they eat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1263-2
  a curric:KeyLearningPoint ;
  rdfs:label "Most omnivores have both flat bumpy teeth and sharp pointed teeth."@en ;
  dcterms:modified "2026-02-19T08:26:13.608922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1263-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most carnivores have hard, sharp, pointed teeth to bite, rip and tear their food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1263-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most herbivores have large, wide, bumpy teeth to chew and grind their food."@en ;
  dcterms:modified "2026-02-19T08:26:13.608930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1263-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make observations to compare animals' teeth and understand what diet an animal may have."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2763-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisation occurs when pollen reaches the ovary of a flower."@en ;
  dcterms:modified "2026-02-19T08:26:13.608938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2763-2
  a curric:KeyLearningPoint ;
  rdfs:label "A seed is formed once a plant has been fertilised."@en ;
  dcterms:modified "2026-02-19T08:26:13.608942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2763-3
  a curric:KeyLearningPoint ;
  rdfs:label """Seed dispersal allows plants to spread out and avoid competing with one another for the same resources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2763-4
  a curric:KeyLearningPoint ;
  rdfs:label """Seeds can be scattered by wind, water, animals or explosion. This is called seed dispersal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1275-1
  a curric:KeyLearningPoint ;
  rdfs:label "Temperature is a measure of the heat of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.608954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1275-2
  a curric:KeyLearningPoint ;
  rdfs:label "A thermometer is a device used to measure temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.608958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1275-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK, the unit of temperature measurement is degrees Celsius, represented by the symbol °C."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1275-4
  a curric:KeyLearningPoint ;
  rdfs:label """Data loggers can be used to monitor and record changes in the environment such as light, sound and temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1270-1
  a curric:KeyLearningPoint ;
  rdfs:label "Substances can exist as different states of matter: solid, liquid and gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.608971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1270-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solids, liquids and gases have different properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.608975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1270-3
  a curric:KeyLearningPoint ;
  rdfs:label """A solid has a fixed shape and volume but some solids can change shape when a force is applied."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1270-4
  a curric:KeyLearningPoint ;
  rdfs:label """Liquids can be poured easily and take the shape of the bottom of the container that they are in."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Gases are often invisible. They escape from an unsealed container and have no fixed shape or volume."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2749-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soil is the loose surface material that covers most land. The creation of soils occurs over many, many years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2749-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can make predictions to share our scientific ideas about what we think will happen or how something might work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2749-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists make careful observations to answer questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.609004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2749-4
  a curric:KeyLearningPoint ;
  rdfs:label """Soils are a combination of different things, including rock, organic matter and air."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2772-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans and most other animals have muscles throughout their bodies that help them to move and balance"""@en ;
  dcterms:modified "2026-02-19T08:26:13.609012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2772-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different muscles move different parts of the body"@en ;
  dcterms:modified "2026-02-19T08:26:13.609040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2772-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles work in pairs around our joints to help us move"@en ;
  dcterms:modified "2026-02-19T08:26:13.609045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2772-4
  a curric:KeyLearningPoint ;
  rdfs:label "One muscle pulls in one direction, and another pulls in the opposite direction"@en ;
  dcterms:modified "2026-02-19T08:26:13.609049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2773-1
  a curric:KeyLearningPoint ;
  rdfs:label "Muscle strength is often different in different people"@en ;
  dcterms:modified "2026-02-19T08:26:13.609053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2773-2
  a curric:KeyLearningPoint ;
  rdfs:label "Muscle strength can be measured in different ways"@en ;
  dcterms:modified "2026-02-19T08:26:13.609057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2773-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists plan how to carry out the right type of investigation to find answers to their questions"""@en ;
  dcterms:modified "2026-02-19T08:26:13.609061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1205-1
  a curric:KeyLearningPoint ;
  rdfs:label """A geologist is a type of scientist that studies what the Earth is made of. They help us to understand more about rocks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1205-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists from the past, today and in the future help us to learn more about the properties and uses of rocks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1205-3
  a curric:KeyLearningPoint ;
  rdfs:label """The results from a scientific investigation can be compared to other investigations that have already been carried out."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1272-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the state of a solid to a liquid by changing its temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.609081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1272-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water is a solid (ice) at 0°C but becomes a liquid when it is heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.609086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1272-3
  a curric:KeyLearningPoint ;
  rdfs:label "The process in which a solid changes to a liquid is called melting."@en ;
  dcterms:modified "2026-02-19T08:26:13.609092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1272-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials can be observed changing from solid to liquid when heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.609096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2774-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists carry out the investigations they have planned to find answers to their questions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2774-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists look for patterns in the data they have collected and make conclusions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists review their investigations. Sometimes the data they collect are unexpected."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1247-1
  a curric:KeyLearningPoint ;
  rdfs:label "All humans have a skeleton made up of many bones."@en ;
  dcterms:modified "2026-02-19T08:26:13.609133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1247-2
  a curric:KeyLearningPoint ;
  rdfs:label "The bones of the human skeleton are solid, strong and are various shapes."@en ;
  dcterms:modified "2026-02-19T08:26:13.609137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1247-3
  a curric:KeyLearningPoint ;
  rdfs:label "X-rays show us what our bones look like."@en ;
  dcterms:modified "2026-02-19T08:26:13.609141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1247-4
  a curric:KeyLearningPoint ;
  rdfs:label "The skeleton supports our body which would be ‘floppy’ without it."@en ;
  dcterms:modified "2026-02-19T08:26:13.609145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9175-1
  a curric:KeyLearningPoint ;
  rdfs:label "Geologists learn about the Earth by observing different rocks and soils."@en ;
  dcterms:modified "2026-02-19T08:26:13.609169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9175-2
  a curric:KeyLearningPoint ;
  rdfs:label "Geologists use different methods to study the Earth including fieldwork."@en ;
  dcterms:modified "2026-02-19T08:26:13.609173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9175-3
  a curric:KeyLearningPoint ;
  rdfs:label "Geologists help us understand how Earth and other planets formed."@en ;
  dcterms:modified "2026-02-19T08:26:13.609177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2752-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists investigate how water moves easily through permeable soils and slowly through soils with low permeability."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2752-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often evaluate a completed investigation and suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.609187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2752-3
  a curric:KeyLearningPoint ;
  rdfs:label "The size of particles in a soil affects its permeability."@en ;
  dcterms:modified "2026-02-19T08:26:13.609191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2752-4
  a curric:KeyLearningPoint ;
  rdfs:label """Soils with high permeability, such as sandy soil, allow water through easily, so decrease the risk of flooding."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2752-5
  a curric:KeyLearningPoint ;
  rdfs:label """Soils with low permeability, such as clay soil, don't allow water through easily, so may be prone to flooding."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2760-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists gather and record data in a variety of ways to help in answering questions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2760-2
  a curric:KeyLearningPoint ;
  rdfs:label "Findings can be recorded using labelled diagrams."@en ;
  dcterms:modified "2026-02-19T08:26:13.609207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2760-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use what they already know and the evidence they have gathered to make predictions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1227-1
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic materials will be attracted to a magnet and non-magnetic materials will not be attracted to a magnet"""@en ;
  dcterms:modified "2026-02-19T08:26:13.609215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1227-2
  a curric:KeyLearningPoint ;
  rdfs:label "Magnetic materials always contain metal, but not all metals are magnetic"@en ;
  dcterms:modified "2026-02-19T08:26:13.609219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1227-3
  a curric:KeyLearningPoint ;
  rdfs:label "Iron is magnetic, so is steel because it contains iron"@en ;
  dcterms:modified "2026-02-19T08:26:13.609223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1227-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most other metals are not magnetic"@en ;
  dcterms:modified "2026-02-19T08:26:13.609227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1227-5
  a curric:KeyLearningPoint ;
  rdfs:label """Magnets are used to separate magnetic materials from non-magnetic materials at recycling centres and scrap yards"""@en ;
  dcterms:modified "2026-02-19T08:26:13.609231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3337-1
  a curric:KeyLearningPoint ;
  rdfs:label """From the stomach, food moves through the small intestine where digested nutrients are absorbed through the walls."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3337-2
  a curric:KeyLearningPoint ;
  rdfs:label """Undigested food travels through the large intestine, where remaining water is removed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3337-3
  a curric:KeyLearningPoint ;
  rdfs:label """Waste food is stored as faeces in the rectum and leaves the body through the anus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3337-4
  a curric:KeyLearningPoint ;
  rdfs:label """Models can be used to demonstrate and explain things that we are not able to see or experience for ourselves."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1209-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils tell us about things that lived over 10,000 years ago."@en ;
  dcterms:modified "2026-02-19T08:26:13.609254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1209-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils can be formed from different plants and animals."@en ;
  dcterms:modified "2026-02-19T08:26:13.609258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1209-3
  a curric:KeyLearningPoint ;
  rdfs:label "Not every living thing that dies becomes a fossil."@en ;
  dcterms:modified "2026-02-19T08:26:13.609264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1209-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some fossils are formed by an imprint of parts of living things, like bones, feathers, shells or leaves."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1209-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to show how fossils are formed in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.609272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3346-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation can take place at any temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.609276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists investigate how temperature affects how quickly a liquid evaporates to a gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3346-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair test investigation involves controlling variables so that only one thing is changed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1204-1
  a curric:KeyLearningPoint ;
  rdfs:label """The physical properties of a material are its features that can be observed or measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1204-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hardness is a  physical property of rocks."@en ;
  dcterms:modified "2026-02-19T08:26:13.609292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1204-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rocks can be compared and grouped on the basis of their hardness."@en ;
  dcterms:modified "2026-02-19T08:26:13.609296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9020-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ice caps and glaciers are found in the coldest parts of the world, and mostly at the North and South Poles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9020-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ice caps and glaciers are melting as the world has warmed up a lot in the last 50 years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9020-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ice caps and glaciers play important roles in regulating Earth’s sea levels and temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9020-4
  a curric:KeyLearningPoint ;
  rdfs:label "When ice caps and glaciers melt, sea levels rise."@en ;
  dcterms:modified "2026-02-19T08:26:13.609336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1235-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can investigate what plants need by observing plant growth when requirements are removed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1235-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a comparative test investigation, variables must be kept the same so only one thing is changed and one is measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1235-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists create a schedule for observations and choose a method to record change, such as a diary or photograph log."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1234-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are living things and need the right conditions to grow and stay healthy."@en ;
  dcterms:modified "2026-02-19T08:26:13.609355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1234-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plants need air, light, water, nutrients from soil, and room to grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.609359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can investigate what plants need by observing plant growth when requirements are removed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1234-4
  a curric:KeyLearningPoint ;
  rdfs:label "A comparative test investigation can be carried out to investigate plant growth."@en ;
  dcterms:modified "2026-02-19T08:26:13.609367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1234-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a comparative test investigation, variables must be controlled so only one thing is changed and another is measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3336-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans need food and water to survive and stay healthy."@en ;
  dcterms:modified "2026-02-19T08:26:13.609452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3336-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the mouth, the tongue moves food around, the teeth chop it, and saliva makes it easier to swallow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3336-3
  a curric:KeyLearningPoint ;
  rdfs:label """Food is pushed down the oesophagus into the stomach, where stomach acid helps to break it down."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3336-4
  a curric:KeyLearningPoint ;
  rdfs:label """Models can be used to demonstrate and explain things that we are not able to see or experience directly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1202-1
  a curric:KeyLearningPoint ;
  rdfs:label "A material is a substance from which something is made."@en ;
  dcterms:modified "2026-02-19T08:26:13.609483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1202-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rock is a solid material that occurs naturally in Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.609487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1202-3
  a curric:KeyLearningPoint ;
  rdfs:label """Materials such as concrete, tarmac and brick are made by humans and are not rock."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1202-4
  a curric:KeyLearningPoint ;
  rdfs:label "We use different rocks for different purposes."@en ;
  dcterms:modified "2026-02-19T08:26:13.609497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3338-1
  a curric:KeyLearningPoint ;
  rdfs:label """When humans eat food, it travels from the mouth to the toilet through the digestive system."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3338-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important for scientists to communicate their findings to other people."@en ;
  dcterms:modified "2026-02-19T08:26:13.609505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3338-3
  a curric:KeyLearningPoint ;
  rdfs:label """A flowchart is a diagram, using boxes, lines and arrows, that shows the steps of a process from beginning to end."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3338-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use scientific vocabulary in their explanations."@en ;
  dcterms:modified "2026-02-19T08:26:13.609515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3338-5
  a curric:KeyLearningPoint ;
  rdfs:label "Presentations can vary in format, including verbal and written explanations."@en ;
  dcterms:modified "2026-02-19T08:26:13.609519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2762-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination is when pollen is transferred from an anther to the stigma of a flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2762-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pollinators are animals that pollinate plants by carrying pollen on their bodies when they take nectar from a flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2762-3
  a curric:KeyLearningPoint ;
  rdfs:label """Flowers pollinated by animals are usually brightly coloured and have a pleasant smell."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2762-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pollen can also be transferred by the wind."@en ;
  dcterms:modified "2026-02-19T08:26:13.609569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2762-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wind-pollinated flowers usually have small, dull coloured flowers and no smell."@en ;
  dcterms:modified "2026-02-19T08:26:13.609575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1236-1
  a curric:KeyLearningPoint ;
  rdfs:label "Soil is an important source of nutrients for plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.609683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1236-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some plants may struggle to grow and survive in certain types of soil."@en ;
  dcterms:modified "2026-02-19T08:26:13.609687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1236-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nutrients can be added to soil using fertilisers."@en ;
  dcterms:modified "2026-02-19T08:26:13.609691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1236-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisers added to soil make plants grow bigger and be more healthy."@en ;
  dcterms:modified "2026-02-19T08:26:13.609695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1236-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisers can be organic, such as compost and manure, or human-made."@en ;
  dcterms:modified "2026-02-19T08:26:13.609699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1224-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magnetic forces are forces caused by magnets."@en ;
  dcterms:modified "2026-02-19T08:26:13.609703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1224-2
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic forces are non-contact forces. A magnet can act at a distance so it does not have to be touching the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1224-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make observations and measurements about the world to help them to find out more about things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1224-4
  a curric:KeyLearningPoint ;
  rdfs:label "Magnetic force can be observed and measured acting at a distance."@en ;
  dcterms:modified "2026-02-19T08:26:13.609715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2751-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soil scientists ask questions about which type of soil is best for different purposes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2751-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water moves very easily through permeable soils and very slowly through soils with low permeability."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2751-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a comparative test investigation, variables must be controlled so that only one thing is changed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2751-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make plans that include what they will do and what equipment they will need."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1210-1
  a curric:KeyLearningPoint ;
  rdfs:label "Palaeontology is the study of fossils."@en ;
  dcterms:modified "2026-02-19T08:26:13.609761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1210-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some fossils are formed when tree resin hardens into amber, with living things trapped inside."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1210-3
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to show how fossils are formed in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.609769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1210-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some fossils are formed when sediment and minerals fill the hard parts of living things that have died."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3347-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make careful observations and measurements, using a range of equipment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3347-2
  a curric:KeyLearningPoint ;
  rdfs:label "The results of an investigation can be recorded in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.609785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3347-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use data they have collected to answer questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.609790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although water can evaporate at low temperatures, the speed of evaporation increases as the temperature increases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1208-1
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance and physical properties of rocks make them suitable for different jobs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1208-2
  a curric:KeyLearningPoint ;
  rdfs:label """People have used rocks for millions of years to build things that are useful to our lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1261-1
  a curric:KeyLearningPoint ;
  rdfs:label "Teeth are part of the human digestive system."@en ;
  dcterms:modified "2026-02-19T08:26:13.609842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1261-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of teeth have different functions, but work together to break down food to travel through the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1261-3
  a curric:KeyLearningPoint ;
  rdfs:label "Incisors are sharp and flat, and are used to cut and bite food."@en ;
  dcterms:modified "2026-02-19T08:26:13.609850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1261-4
  a curric:KeyLearningPoint ;
  rdfs:label "Canines are sharp and more pointed, and are used to rip and tear food."@en ;
  dcterms:modified "2026-02-19T08:26:13.609854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1261-5
  a curric:KeyLearningPoint ;
  rdfs:label "Molars are wide and bumpy, and are used to chew and grind food."@en ;
  dcterms:modified "2026-02-19T08:26:13.609858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1273-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can change the state of a liquid to a solid by changing its temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.609862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1273-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water is a liquid at room temperature but becomes a solid (ice) when it is cooled down."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1273-3
  a curric:KeyLearningPoint ;
  rdfs:label "The process in which a liquid changes to a solid is called freezing."@en ;
  dcterms:modified "2026-02-19T08:26:13.609873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1273-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials can be observed changing from liquid to solid when cooled."@en ;
  dcterms:modified "2026-02-19T08:26:13.609877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9017-1
  a curric:KeyLearningPoint ;
  rdfs:label """The weather describes outside conditions over a few weeks and the climate describes conditions over many years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9017-2
  a curric:KeyLearningPoint ;
  rdfs:label """Earth’s climate is gradually changing. The climate is getting warmer more quickly now than a hundred years ago."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9017-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the climate can affect how much water, nutrients and air are in soil and how well plants can grow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9017-4
  a curric:KeyLearningPoint ;
  rdfs:label "Too much rain (flooding) or not enough rain can affect how well crops grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.609925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9017-5
  a curric:KeyLearningPoint ;
  rdfs:label """If soil is too wet or dry this can affect how well animals help mix soil and break down organic matter to add nutrients."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1260-1
  a curric:KeyLearningPoint ;
  rdfs:label "Teeth can be observed in the mouth using a mirror."@en ;
  dcterms:modified "2026-02-19T08:26:13.609933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1260-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dentists and dental hygienists use special mirrors to observe teeth more closely."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1260-3
  a curric:KeyLearningPoint ;
  rdfs:label "At the front of the jaw, incisor teeth look flat and smooth."@en ;
  dcterms:modified "2026-02-19T08:26:13.609941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1260-4
  a curric:KeyLearningPoint ;
  rdfs:label "Near the front of the jaw, canine teeth look sharp and pointed."@en ;
  dcterms:modified "2026-02-19T08:26:13.609945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1260-5
  a curric:KeyLearningPoint ;
  rdfs:label "At the back of the jaw, molar teeth look wide, flat but bumpy."@en ;
  dcterms:modified "2026-02-19T08:26:13.609949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1226-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magnets vary in strength, with strong magnets creating larger magnetic forces"@en ;
  dcterms:modified "2026-02-19T08:26:13.609992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1226-2
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic forces can act at a distance, so magnets do not need to be touching to exert a force"""@en ;
  dcterms:modified "2026-02-19T08:26:13.609997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1226-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions and then plan how to carry out the right type of investigation to find answers"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1226-4
  a curric:KeyLearningPoint ;
  rdfs:label """The results of a scientific investigation can be compared to other investigations that have been carried out"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3335-1
  a curric:KeyLearningPoint ;
  rdfs:label """Toothpaste is a key part of your daily hygiene routine. It helps to remove food and plaque from your teeth and gums."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3335-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different diets and lifestyle choices, like eating sugary foods and smoking, can affect tooth health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3335-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists from the past developed toothbrushes and toothpaste to help reduce tooth decay."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3335-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different toothpaste contains different ingredients to support healthy teeth and gums."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3335-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists test different ingredients in toothpaste to compare how effective they are."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1238-1
  a curric:KeyLearningPoint ;
  rdfs:label "The roots of a plant usually sit below the surface of the soil."@en ;
  dcterms:modified "2026-02-19T08:26:13.610094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1238-2
  a curric:KeyLearningPoint ;
  rdfs:label """Roots provide support for the plant by holding the plant upright, especially in windy conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1238-3
  a curric:KeyLearningPoint ;
  rdfs:label """Roots absorb water and nutrients from soil to provide the plant with what it needs to grow and stay healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1225-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magnets can be different sizes and shapes."@en ;
  dcterms:modified "2026-02-19T08:26:13.610107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1225-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of magnets, including bar, ring, button and horseshoe."@en ;
  dcterms:modified "2026-02-19T08:26:13.610111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1225-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists refer to the poles of a magnet as a north-seeking (N) pole and a south-seeking (S) pole."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1225-4
  a curric:KeyLearningPoint ;
  rdfs:label """Magnets always point north because Earth acts like a giant magnet. Its core contains iron, which is magnetic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2750-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of soils have different properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.610154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2750-2
  a curric:KeyLearningPoint ;
  rdfs:label """How and where soils are formed will affect their properties, such as colour and size of particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2750-3
  a curric:KeyLearningPoint ;
  rdfs:label """Soils can be compared using observation skills, with a hand lens or a microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Common types of soils, based on their texture, are sandy, silt, clay and loam."@en ;
  dcterms:modified "2026-02-19T08:26:13.610168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2750-5
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing soil type can help you choose the right plants for your garden and keep them healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1240-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different types of plants. Some plants have flowers and these are called flowering plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1240-2
  a curric:KeyLearningPoint ;
  rdfs:label """In flowering plants, flowers hold the parts needed to produce new plants. This is called reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1240-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination occurs when pollen from the male parts of a flower are transferred to a female part."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1240-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flowers are often scented and brightly coloured to attract animals, such as insects and birds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1240-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can carry out a survey to explore which colours are most common for flowers."@en ;
  dcterms:modified "2026-02-19T08:26:13.610248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2652-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists who study humans depend on fossil evidence to help them learn about how our ancestors have changed over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Human skulls can show changes in characteristics such as: skull shape, brain and jaw size."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2652-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modern day skulls show differences, suggested by scientists, linked to humans chewing softer, processed food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout history, people have disagreed about the shape of objects in space, such as planets, moons and stars."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2642-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Earth, Sun and Moon are approximately spherical in shape."@en ;
  dcterms:modified "2026-02-19T08:26:13.610268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2642-3
  a curric:KeyLearningPoint ;
  rdfs:label """Images and measurements taken from space provide evidence to help us understand the shape of objects in space."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2637-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid that dissolves in a liquid is called soluble. This makes a solution."@en ;
  dcterms:modified "2026-02-19T08:26:13.610276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2637-2
  a curric:KeyLearningPoint ;
  rdfs:label "Soluble solids can not be recovered using filtering."@en ;
  dcterms:modified "2026-02-19T08:26:13.610280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2637-3
  a curric:KeyLearningPoint ;
  rdfs:label "Soluble solids can be recovered from a liquid using evaporation."@en ;
  dcterms:modified "2026-02-19T08:26:13.610284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2637-4
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation is when a liquid changes to invisible water vapour (gas) in the air."@en ;
  dcterms:modified "2026-02-19T08:26:13.610288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mould is a micro-organism. It is a type of fungus and can be grouped with other fungi including yeast and mushrooms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mould is common in moist materials and food, such as fruit, bread, cheese and meat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2663-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mould needs moisture, warmth and nutrients to grow well."@en ;
  dcterms:modified "2026-02-19T08:26:13.610351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2663-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mould can be observed growing on food over time, following strict safety rules."@en ;
  dcterms:modified "2026-02-19T08:26:13.610357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2663-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make predictions about what will happen based on the evidence they already have."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2695-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rock salt is often used to melt the ice on roads and pavements."@en ;
  dcterms:modified "2026-02-19T08:26:13.610460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding salt to ice (frozen water) lowers the melting temperature and speeds up the rate of melting."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use a range of equipment to observe, measure and compare when they investigate to find answers to questions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2695-4
  a curric:KeyLearningPoint ;
  rdfs:label "The results of an investigation are used to make conclusions."@en ;
  dcterms:modified "2026-02-19T08:26:13.610475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2695-5
  a curric:KeyLearningPoint ;
  rdfs:label """When scientists review an investigation, they look again at what they have done and consider if it could be improved."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2687-1
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system consists of the heart, blood vessels and blood working together in the human body"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2687-2
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system supplies the body with nutrients and oxygen, and removes waste products that it doesn't need"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2687-3
  a curric:KeyLearningPoint ;
  rdfs:label """A flowchart is a diagram, using boxes, lines and arrows, that shows the steps of a process from beginning to end"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2687-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writing a draft plan gives you an opportunity to find ways of improving your work"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2655-1
  a curric:KeyLearningPoint ;
  rdfs:label """When living things reproduce they pass on characteristics to their offspring. This is known as inheritance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2655-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inherited characteristics are passed from one generation to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.610539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2655-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inherited characteristics include eye colour, height, skin colour, hair colour etc."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2655-4
  a curric:KeyLearningPoint ;
  rdfs:label """Environmental characteristics are ones which are not passed down from parent to child."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Charles Darwin suggested that all the kinds of living things that exist today developed from earlier types."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3383-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals and plants are more likely to survive than others."@en ;
  dcterms:modified "2026-02-19T08:26:13.610556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3383-3
  a curric:KeyLearningPoint ;
  rdfs:label """Living things that survive can reproduce to pass on characteristics to their offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3383-4
  a curric:KeyLearningPoint ;
  rdfs:label """The most useful and strongest adaptations are passed on to enable the next generation of plants or animals to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3383-5
  a curric:KeyLearningPoint ;
  rdfs:label """Survival of the fittest means organisms that are better adapted to their habitat are most likely to survive & reproduce."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2665-1
  a curric:KeyLearningPoint ;
  rdfs:label """Yeast is a type of fungus and can be grouped with other fungi including mould, mushrooms and truffles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Yeast is living and must get food from the surrounding environment to grow and reproduce."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2665-3
  a curric:KeyLearningPoint ;
  rdfs:label "Yeast takes in nutrition from food and produces carbon dioxide gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.610602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Yeast is a useful micro-organism used in beer and wine making, and baking."@en ;
  dcterms:modified "2026-02-19T08:26:13.610608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2665-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists control variables during comparative test investigations to see the effect of changing one variable."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2656-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals have special features, or adaptations, that help them to survive in their habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2656-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations are passed from one generation of a species to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.610621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2656-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many different animals have adaptations that protect them from predators."@en ;
  dcterms:modified "2026-02-19T08:26:13.610625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2656-4
  a curric:KeyLearningPoint ;
  rdfs:label """An environment can change dramatically due to a natural disaster, or slowly over hundreds of years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2630-1
  a curric:KeyLearningPoint ;
  rdfs:label "A material is the substance from which something is made."@en ;
  dcterms:modified "2026-02-19T08:26:13.610665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2630-2
  a curric:KeyLearningPoint ;
  rdfs:label """The physical properties of a material are the features that can be observed or measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials have different physical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.610673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2630-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists test materials to investigate their physical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.610677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2630-5
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be compared and grouped on the basis of their physical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.610683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3366-1
  a curric:KeyLearningPoint ;
  rdfs:label """Simple machines are useful because they make it easier for people to perform tasks beyond their normal capabilities."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3366-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of simple machine: the wheel and axle, pulley, inclined plane, screw, wedge and lever."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inventions using simple machines help us in our everyday lives."@en ;
  dcterms:modified "2026-02-19T08:26:13.610697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2632-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials have different physical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.610781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2632-2
  a curric:KeyLearningPoint ;
  rdfs:label """A thermal insulator is a material that does not allow heat to pass through easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2632-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different materials can be suitable or unsuitable for thermal insulation depending on their properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2632-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a comparative test, the variable that is being changed has names or labels, such as the names of plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2632-5
  a curric:KeyLearningPoint ;
  rdfs:label """When we control variables, it means we keep them the same throughout an investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Antibiotics are medicines that fight infections caused by micro-organisms called bacteria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2664-2
  a curric:KeyLearningPoint ;
  rdfs:label "Penicillin belongs to a group of medical drugs called antibiotics."@en ;
  dcterms:modified "2026-02-19T08:26:13.610821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2664-3
  a curric:KeyLearningPoint ;
  rdfs:label "Penicillin is made from a type of mould."@en ;
  dcterms:modified "2026-02-19T08:26:13.610825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2664-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1928, Scottish doctor, Alexander Fleming, discovered the effects of penicillin."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2664-5
  a curric:KeyLearningPoint ;
  rdfs:label """The discovery of penicillin was one of the greatest scientific achievements of the 1900s."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2644-1
  a curric:KeyLearningPoint ;
  rdfs:label """The axis is an imaginary straight line which goes through the centre of the Earth from the North to the South Pole"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2644-2
  a curric:KeyLearningPoint ;
  rdfs:label "Day and night are due to the Earth rotating on its axis"@en ;
  dcterms:modified "2026-02-19T08:26:13.610864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2644-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is daytime when the Earth is facing the Sun and night time when the Earth is facing away from the Sun"""@en ;
  dcterms:modified "2026-02-19T08:26:13.610868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2644-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Earth takes 24 hours to rotate on its axis"@en ;
  dcterms:modified "2026-02-19T08:26:13.610872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2644-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to demonstrate how the Earth's rotation causes day and night"@en ;
  dcterms:modified "2026-02-19T08:26:13.610876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2638-1
  a curric:KeyLearningPoint ;
  rdfs:label """Around 80% of the world's population have access to safe drinking water at home, leaving 1.6 billion without."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unsafe water is one of the world’s largest health and environmental problems, particularly for the poorest in the world."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2638-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers take inspiration from nature to create filtering systems to clean water for drinking."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2683-1
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is a hollow, muscular organ located behind the breastbone and slightly to the left of your chest."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2683-2
  a curric:KeyLearningPoint ;
  rdfs:label """The average heart is approximately the size of a human fist and some say its shape is similar to an upside down pear."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2683-3
  a curric:KeyLearningPoint ;
  rdfs:label "The function of the heart is to pump blood to all parts of your body."@en ;
  dcterms:modified "2026-02-19T08:26:13.610940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2683-4
  a curric:KeyLearningPoint ;
  rdfs:label "Your heart will beat around 115,000 times each day."@en ;
  dcterms:modified "2026-02-19T08:26:13.610944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2683-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to help us to learn about the human heart."@en ;
  dcterms:modified "2026-02-19T08:26:13.610948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2661-1
  a curric:KeyLearningPoint ;
  rdfs:label """Micro-organisms are tiny living things that are too small to be seen with the naked eye."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2661-2
  a curric:KeyLearningPoint ;
  rdfs:label "Micro-organisms are commonly known as germs, bugs or microbes."@en ;
  dcterms:modified "2026-02-19T08:26:13.610956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2661-3
  a curric:KeyLearningPoint ;
  rdfs:label "Micro-organisms can be viewed using a microscope."@en ;
  dcterms:modified "2026-02-19T08:26:13.610962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2661-4
  a curric:KeyLearningPoint ;
  rdfs:label """Micro-organisms are found everywhere, in soil, air, water, on your skin and in your digestive system."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3369-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vinegar is an example of an acid that we find in our homes."@en ;
  dcterms:modified "2026-02-19T08:26:13.610970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3369-2
  a curric:KeyLearningPoint ;
  rdfs:label """Bicarbonate of soda is a white powder used in baking to make bread, batter and cakes rise when baked."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3369-3
  a curric:KeyLearningPoint ;
  rdfs:label """When vinegar and bicarbonate of soda are mixed, this produces a new material in the form of carbon dioxide gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3369-4
  a curric:KeyLearningPoint ;
  rdfs:label "The action of acid with bicarbonate of soda is an irreversible change."@en ;
  dcterms:modified "2026-02-19T08:26:13.610982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3369-5
  a curric:KeyLearningPoint ;
  rdfs:label """During an irreversible change, the material that has been changed cannot return to its original state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2685-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blood vessels transport blood all around the body, to and from your heart."@en ;
  dcterms:modified "2026-02-19T08:26:13.610990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2685-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries are blood vessels. Most arteries deliver blood rich in oxygen to all the parts of the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2685-3
  a curric:KeyLearningPoint ;
  rdfs:label "Veins are blood vessels. Most veins return blood low in oxygen to the heart."@en ;
  dcterms:modified "2026-02-19T08:26:13.611002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2685-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blood is always red. Blood travelling through veins may appear blue because of how light travels through our skin."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2685-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use scientific diagrams to describe different systems in the human body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3384-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evolution is the process by which living things can gradually change over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.611015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3384-2
  a curric:KeyLearningPoint ;
  rdfs:label """The huge variety of living things in the world today is the result of evolution over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3384-3
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of evolution has been proven through evidence from fossils as well as living animals and plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3384-4
  a curric:KeyLearningPoint ;
  rdfs:label """The evolution of living things can be researched using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3381-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants have special features, or adaptations, that help them to survive, live and grow in their habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3381-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations are passed from one generation of a species to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.611035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3381-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many plants have adaptations to help them successfully reproduce."@en ;
  dcterms:modified "2026-02-19T08:26:13.611039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3381-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some plants have adaptations that protect them from being eaten."@en ;
  dcterms:modified "2026-02-19T08:26:13.611044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2647-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is the centre of the solar system"@en ;
  dcterms:modified "2026-02-19T08:26:13.611154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2647-2
  a curric:KeyLearningPoint ;
  rdfs:label """Earth, and other planets in the solar system, move around or orbit the Sun in an anticlockwise direction"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2647-3
  a curric:KeyLearningPoint ;
  rdfs:label """It takes different planets different amounts of time to orbit the Sun, depending on their distance from the Sun"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2647-4
  a curric:KeyLearningPoint ;
  rdfs:label "It takes 365 1/4  days, or one year, for Earth to complete one orbit of the Sun"@en ;
  dcterms:modified "2026-02-19T08:26:13.611166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2623-1
  a curric:KeyLearningPoint ;
  rdfs:label """Friction is the force between two surfaces that are moving, or trying to move, across each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2623-2
  a curric:KeyLearningPoint ;
  rdfs:label "Friction always acts in the opposite direction to the movement of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.611306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2623-3
  a curric:KeyLearningPoint ;
  rdfs:label """Only changing one variable ensures that no other factor affects the test results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2659-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists group animals to make it easier to identify, name and learn about them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2659-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be divided into groups or 'classified' by looking at the similarities and differences between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Animals are divided into two main groups: vertebrates (with a spine) and invertebrates (without a spine)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2659-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vertebrate and invertebrate groups can be divided further."@en ;
  dcterms:modified "2026-02-19T08:26:13.611325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2659-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create classification keys by asking a series of yes/no questions about the observable characteristics of things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9033-1
  a curric:KeyLearningPoint ;
  rdfs:label """Burning fossil fuels at home, in our cars, and in industry all cause air pollution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9033-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whenever we burn fossil fuels, harmful gases and small solid particles are produced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some substances produced when we burn fossil fuels can harm living things or add to greenhouse gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9033-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers are always investigating ways to use renewable fuel resources and reduce air pollution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9033-5
  a curric:KeyLearningPoint ;
  rdfs:label """Air pollution can be reduced by our actions, such as walking or cycling more and using less electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2653-1
  a curric:KeyLearningPoint ;
  rdfs:label "Living things produce offspring of the same kind."@en ;
  dcterms:modified "2026-02-19T08:26:13.611360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Offspring share some characteristics of their parents."@en ;
  dcterms:modified "2026-02-19T08:26:13.611364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2653-3
  a curric:KeyLearningPoint ;
  rdfs:label "Normally offspring vary and are not identical to their parents."@en ;
  dcterms:modified "2026-02-19T08:26:13.611368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2634-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thermal insulators are used for different purposes in everyday life."@en ;
  dcterms:modified "2026-02-19T08:26:13.611372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal insulators are used to stop us burning ourselves or surfaces when using hot objects in the kitchen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2634-3
  a curric:KeyLearningPoint ;
  rdfs:label "Materials that contain trapped pockets of air make good thermal insulators."@en ;
  dcterms:modified "2026-02-19T08:26:13.611383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2634-4
  a curric:KeyLearningPoint ;
  rdfs:label "Thermal insulators can be used to keep cold things cold."@en ;
  dcterms:modified "2026-02-19T08:26:13.611387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2634-5
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative test can be used to investigate which cup is most suitable for keeping cold drinks cold."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2631-1
  a curric:KeyLearningPoint ;
  rdfs:label """The physical properties of a material are the features that can be observed or measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2631-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results of investigations enable us to explain why materials are suitable for particular uses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials come in different types which have different properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.611403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2631-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers choose materials for different uses based on their physical properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2636-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some solids do not dissolve in liquids; these are called insoluble solids."@en ;
  dcterms:modified "2026-02-19T08:26:13.611462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2636-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sieve is a type of filter that can be used to separate larger insoluble solids from a liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of filters can be used to separate insoluble solids from liquids or gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2636-4
  a curric:KeyLearningPoint ;
  rdfs:label "We use filters in everyday life to separate mixtures of solids and liquids."@en ;
  dcterms:modified "2026-02-19T08:26:13.611474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2678-1
  a curric:KeyLearningPoint ;
  rdfs:label "We need light to see things."@en ;
  dcterms:modified "2026-02-19T08:26:13.611522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2678-2
  a curric:KeyLearningPoint ;
  rdfs:label "We see things when light enters the eye."@en ;
  dcterms:modified "2026-02-19T08:26:13.611526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2678-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pupil of the eye is an opening that allows light to enter the eye."@en ;
  dcterms:modified "2026-02-19T08:26:13.611530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2678-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific diagrams and models can be used to show how light travels in straight lines and enters the eye."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nutrients have different purposes and come from different foods."@en ;
  dcterms:modified "2026-02-19T08:26:13.611558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2686-2
  a curric:KeyLearningPoint ;
  rdfs:label """A healthy diet is essential for maintaining the nutrients our body needs to function properly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2686-3
  a curric:KeyLearningPoint ;
  rdfs:label """During digestion, your small intestine absorbs the nutrients from your food and passes them into the bloodstream."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2686-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water and nutrients from food are transported in blood around the body to where they are needed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2686-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to help us to learn about how science works."@en ;
  dcterms:modified "2026-02-19T08:26:13.611578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants have special features, or adaptations, that help them to survive, live and grow in their habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3382-2
  a curric:KeyLearningPoint ;
  rdfs:label "Leaf shape is an adaptation that can help plants to survive in their habitats."@en ;
  dcterms:modified "2026-02-19T08:26:13.611586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3382-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists can record their ideas using labelled scientific diagrams."@en ;
  dcterms:modified "2026-02-19T08:26:13.611592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2639-1
  a curric:KeyLearningPoint ;
  rdfs:label "The three states of matter are: solid state, liquid state and gas state."@en ;
  dcterms:modified "2026-02-19T08:26:13.611597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2639-2
  a curric:KeyLearningPoint ;
  rdfs:label "A change of state is when one state of matter changes to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.611601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes of state are reversible changes whereby the material that has been changed can return to its original state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2639-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting, freezing, evaporation and condensation are examples of reversible changes of state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2688-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific information should be presented in an informative and interesting way suitable for the audience."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2688-2
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system can be explained in verbal, pictorial and written presentations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2688-3
  a curric:KeyLearningPoint ;
  rdfs:label """Models can be used to present scientific information that cannot be experienced directly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2657-1
  a curric:KeyLearningPoint ;
  rdfs:label "Charles Darwin was an English scientist who studied nature."@en ;
  dcterms:modified "2026-02-19T08:26:13.611627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2657-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1831, Darwin set sail to study the plants and animals living on the coasts of South America."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2657-3
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin observed that the beak shape of finches was best suited to the food sources found on different Galapagos Islands."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2657-4
  a curric:KeyLearningPoint ;
  rdfs:label "Darwin’s observations led him to wonder how new species developed."@en ;
  dcterms:modified "2026-02-19T08:26:13.611639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2657-5
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin’s ideas about how living things adapt to suit their environments would eventually change people’s ideas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9029-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 5Rs are Refuse, Reduce, Reuse, Recycle and Rot."@en ;
  dcterms:modified "2026-02-19T08:26:13.611650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Compost is made by allowing certain types of food waste and other materials to decompose over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9029-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compost provides nutrients to help plants grow and be healthy."@en ;
  dcterms:modified "2026-02-19T08:26:13.611658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9029-4
  a curric:KeyLearningPoint ;
  rdfs:label "Compost needs air, moisture and the right mix of waste food and materials."@en ;
  dcterms:modified "2026-02-19T08:26:13.611662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9029-5
  a curric:KeyLearningPoint ;
  rdfs:label "Compost can be used in the school grounds to help plants and animals grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.611666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2649-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fossil is any evidence of prehistoric life from millions of years ago."@en ;
  dcterms:modified "2026-02-19T08:26:13.611670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2649-2
  a curric:KeyLearningPoint ;
  rdfs:label """Palaeontologists tell us that the most common fossils are bones, teeth and shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fossils are mainly found within sedimentary rocks, such as cliffs and river valleys, formed over thousands of years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2649-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fossil discoveries can be researched using secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.611682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gears are simple mechanisms or machines which are useful for turning things."@en ;
  dcterms:modified "2026-02-19T08:26:13.611686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3365-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gears are wheels with teeth that slot together and turn on an axle."@en ;
  dcterms:modified "2026-02-19T08:26:13.611690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3365-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gears can change the direction of a force. When one gear is turned, the other gear turns in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gears of different sizes working together can be used to change the size of a force and reduce the effort required."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3365-5
  a curric:KeyLearningPoint ;
  rdfs:label """A smaller gear will turn rapidly with less force, whereas a larger gear will turn more slowly with a greater force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9038-1
  a curric:KeyLearningPoint ;
  rdfs:label "Moving air (wind) can turn the blades of windmills or turbines."@en ;
  dcterms:modified "2026-02-19T08:26:13.611794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9038-2
  a curric:KeyLearningPoint ;
  rdfs:label """Windmills have been used for many years to help us do work like pumping water or grinding wheat for flour."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9038-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wind turbines are now used to generate electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.611804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9038-4
  a curric:KeyLearningPoint ;
  rdfs:label "The wind is a renewable energy source as there will always be wind."@en ;
  dcterms:modified "2026-02-19T08:26:13.611809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2694-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rock salt is often stored in a public grit bin and used to melt ice on roads and pavements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2694-2
  a curric:KeyLearningPoint ;
  rdfs:label """After being extracted, rock salt usually undergoes processing and crushing before it is transported to grit bins."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2694-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists plan investigations to make comparisons and answer questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.611862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2694-4
  a curric:KeyLearningPoint ;
  rdfs:label "Variables can be changed, measured or kept the same in a comparative test."@en ;
  dcterms:modified "2026-02-19T08:26:13.611866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3512-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon is nearly 240,000 miles away from the Earth, yet we can see it without binoculars and telescopes"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3512-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Moon is a dusty ball of rock, it does not produce its own light"@en ;
  dcterms:modified "2026-02-19T08:26:13.611953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3512-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light is reflected when it hits a surface and bounces off in a different direction"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3512-4
  a curric:KeyLearningPoint ;
  rdfs:label "We see the Moon because it reflects light from the Sun"@en ;
  dcterms:modified "2026-02-19T08:26:13.611963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2693-1
  a curric:KeyLearningPoint ;
  rdfs:label """The salt people put on their food or in their cooking is usually a type of salt called table salt."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2693-2
  a curric:KeyLearningPoint ;
  rdfs:label "Table salt has a wide range of uses."@en ;
  dcterms:modified "2026-02-19T08:26:13.611991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2693-3
  a curric:KeyLearningPoint ;
  rdfs:label """Table salt can be obtained through two main methods: mining underground salt deposits and evaporating seawater."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2693-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of salt can be observed and compared using a hand lens or microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9027-1
  a curric:KeyLearningPoint ;
  rdfs:label "It takes up to 500 years for plastics to decompose."@en ;
  dcterms:modified "2026-02-19T08:26:13.612019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9027-2
  a curric:KeyLearningPoint ;
  rdfs:label """Discarded plastics are causing problems in our seas and on our land, for animals including humans."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9027-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists have discovered ways to make bioplastics or biodegradable plastics."@en ;
  dcterms:modified "2026-02-19T08:26:13.612031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9027-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bioplastics can be made from starch."@en ;
  dcterms:modified "2026-02-19T08:26:13.612037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9027-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can observe bioplastics over time to find out how long it takes them to decompose."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2660-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists group plants to make it easier to identify, name and learn about them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2660-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants can be divided into groups or 'classified' by looking at the similarities and differences between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Generally, plant life can be broken up into flowering plants and non-flowering plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can be grouped according to if they do or do not produce seeds."@en ;
  dcterms:modified "2026-02-19T08:26:13.612114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2660-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create classification keys by asking a series of yes/no questions about the observable characteristics of plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2646-1
  a curric:KeyLearningPoint ;
  rdfs:label """The solar system consists of the Sun and all other objects in space travelling around it, such as planets."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2646-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is the centre of the solar system"@en ;
  dcterms:modified "2026-02-19T08:26:13.612139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2646-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are eight planets in the solar system"@en ;
  dcterms:modified "2026-02-19T08:26:13.612143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2646-4
  a curric:KeyLearningPoint ;
  rdfs:label """The planets in order from the Sun are: Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus and Neptune"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2646-5
  a curric:KeyLearningPoint ;
  rdfs:label "Planets can be researched using secondary sources of information"@en ;
  dcterms:modified "2026-02-19T08:26:13.612151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2679-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reflection involves a source of light and a surface."@en ;
  dcterms:modified "2026-02-19T08:26:13.612178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2679-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light travels towards a surface and bounces off it."@en ;
  dcterms:modified "2026-02-19T08:26:13.612183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2679-3
  a curric:KeyLearningPoint ;
  rdfs:label """We often see things because light travels from light sources to objects and then to our eyes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2679-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams and models can be used to show how we see reflected light."@en ;
  dcterms:modified "2026-02-19T08:26:13.612191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3388-1
  a curric:KeyLearningPoint ;
  rdfs:label "Taxonomy is the science of naming, describing and grouping all living things."@en ;
  dcterms:modified "2026-02-19T08:26:13.612195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have improved classification of organisms over time as they've been able to make more accurate observations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3388-3
  a curric:KeyLearningPoint ;
  rdfs:label "Carl Linnaeus is most famous for creating a system of naming living things."@en ;
  dcterms:modified "2026-02-19T08:26:13.612206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3388-4
  a curric:KeyLearningPoint ;
  rdfs:label """His ideas on classification have influenced generations of biologists during, and after, his own lifetime."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3388-5
  a curric:KeyLearningPoint ;
  rdfs:label "His system for naming and classifying living things is still used today."@en ;
  dcterms:modified "2026-02-19T08:26:13.612214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3515-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon moves around the Earth. It takes approximately 28 days for the Moon to complete its orbit of the Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3515-2
  a curric:KeyLearningPoint ;
  rdfs:label "As the Moon orbits the Earth, the same side of the Moon is always facing us."@en ;
  dcterms:modified "2026-02-19T08:26:13.612222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3515-3
  a curric:KeyLearningPoint ;
  rdfs:label """We see the Moon because light from the Sun shines on the Moon and this light is reflected to Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3515-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon appears to change shape depending on the amount we see from Earth being lit by the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3385-1
  a curric:KeyLearningPoint ;
  rdfs:label "The variety of living things is the result of evolution over time"@en ;
  dcterms:modified "2026-02-19T08:26:13.612236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3385-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evolution is the process by which living things can gradually change over time"@en ;
  dcterms:modified "2026-02-19T08:26:13.612240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3385-3
  a curric:KeyLearningPoint ;
  rdfs:label """Science communicators share scientific information with the public in an interesting and accessible way"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3385-4
  a curric:KeyLearningPoint ;
  rdfs:label """Information from research can be presented in different ways, including oral and written forms"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2622-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pushes and pulls are forces. Different types of forces can be contact or non-contact forces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2622-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces can change an object's speed, direction, and/or shape."@en ;
  dcterms:modified "2026-02-19T08:26:13.612256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2622-3
  a curric:KeyLearningPoint ;
  rdfs:label "Forces can be measured using a force meter, also known as a newton meter."@en ;
  dcterms:modified "2026-02-19T08:26:13.612260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2622-4
  a curric:KeyLearningPoint ;
  rdfs:label """A force meter works by stretching a spring – as the downward force due to gravity increases, the spring stretches."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2622-5
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are measured in newtons (N), named after Sir Isaac Newton."@en ;
  dcterms:modified "2026-02-19T08:26:13.612268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2684-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is needed by humans to keep them alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.612272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2684-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blood transports oxygen and nutrients to all the parts of the body so they can keep working."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2684-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blood transports carbon dioxide and other waste materials to be removed from the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2684-4
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is made of different parts. Each part has a special function within blood."@en ;
  dcterms:modified "2026-02-19T08:26:13.612284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to describe what blood is and its functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.612290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2651-1
  a curric:KeyLearningPoint ;
  rdfs:label """The layers at the bottom of sedimentary rock are the oldest and the layers at the top are the newest"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2651-2
  a curric:KeyLearningPoint ;
  rdfs:label """By looking at different layers of rock, geologists can learn about what was happening on Earth at different times"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2651-3
  a curric:KeyLearningPoint ;
  rdfs:label """Where a fossil is found can tell us about which animals or plants lived in each time period in the history of our Earth"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fossils of the simplest organisms are found in the oldest rocks, and more complex organisms in the newest rocks"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2651-5
  a curric:KeyLearningPoint ;
  rdfs:label "Models can be used to represent different layers of fossils in rock over time"@en ;
  dcterms:modified "2026-02-19T08:26:13.612312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9028-1
  a curric:KeyLearningPoint ;
  rdfs:label """Insulating buildings reduces the amount of fuel we need to keep them warm in winter and cold in summer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9028-2
  a curric:KeyLearningPoint ;
  rdfs:label """Other measures can reduce fuel costs, such as reducing the temperature we expect of our rooms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Temperature data can be collected around the school to reveal heat losses."@en ;
  dcterms:modified "2026-02-19T08:26:13.612324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9028-4
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature data analysis can result in costed actions for children and adults to take to reduce heat losses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9028-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fuel cost data comparisons will show whether actions have an impact."@en ;
  dcterms:modified "2026-02-19T08:26:13.612332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2643-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is a bright, hot ball of gas at the centre of our solar system"@en ;
  dcterms:modified "2026-02-19T08:26:13.612350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2643-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is the closest star to Earth"@en ;
  dcterms:modified "2026-02-19T08:26:13.612354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2643-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is the primary source of all the heat and light on Earth"@en ;
  dcterms:modified "2026-02-19T08:26:13.612358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2643-4
  a curric:KeyLearningPoint ;
  rdfs:label "The surface of the Sun can reach 5505°C"@en ;
  dcterms:modified "2026-02-19T08:26:13.612362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2643-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can find out more about the Sun by carrying out research"@en ;
  dcterms:modified "2026-02-19T08:26:13.612366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2626-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists often repeat tests in order to gather more information and make sure their results did not happen by chance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2626-2
  a curric:KeyLearningPoint ;
  rdfs:label "The findings from an investigation can be summarised in a conclusion."@en ;
  dcterms:modified "2026-02-19T08:26:13.612431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2626-3
  a curric:KeyLearningPoint ;
  rdfs:label "A greater surface area on a moving object can increase air resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.612435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2689-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to live a healthy lifestyle to help your heart to perform its many functions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2689-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some people are born with heart problems. Others may develop disease of the heart or blood vessels later in life."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2689-3
  a curric:KeyLearningPoint ;
  rdfs:label """A heart transplant is a treatment when a heart condition hasn't improved enough with medications or other surgeries."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2689-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using animal organs for human transplantation has led to disagreements and debate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2689-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both sides of any argument must be researched and considered fully."@en ;
  dcterms:modified "2026-02-19T08:26:13.612458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3367-1
  a curric:KeyLearningPoint ;
  rdfs:label "When a substance burns, it produces a flame."@en ;
  dcterms:modified "2026-02-19T08:26:13.612462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3367-2
  a curric:KeyLearningPoint ;
  rdfs:label """For burning to take place there has to be fuel, oxygen and a high enough temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3367-3
  a curric:KeyLearningPoint ;
  rdfs:label "When things burn, new materials are usually formed."@en ;
  dcterms:modified "2026-02-19T08:26:13.612470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3367-4
  a curric:KeyLearningPoint ;
  rdfs:label "Burning is a change that cannot be reversed."@en ;
  dcterms:modified "2026-02-19T08:26:13.612476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3367-5
  a curric:KeyLearningPoint ;
  rdfs:label "Burning materials can be observed closely as they change over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.612480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3364-1
  a curric:KeyLearningPoint ;
  rdfs:label """A pulley is a simple mechanism or machine, used in everyday life, which is useful for lifting things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3364-2
  a curric:KeyLearningPoint ;
  rdfs:label """A pulley often consists of a wheel with a groove, through which a string or rope runs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3364-3
  a curric:KeyLearningPoint ;
  rdfs:label """The object you are lifting is called the load, and the force you apply to make an object move is called the effort."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some pulleys make it easier because they change the direction of the force needed to lift an object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3364-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some pulleys make it easier to lift an object because they decrease the effort or force needed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2650-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fossils are our best form of evidence about Earth's history, including the history of life"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2650-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fossils can give us clues about living things that inhabited the Earth millions of years ago"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2650-3
  a curric:KeyLearningPoint ;
  rdfs:label "By studying the fossil record, we can tell how long life has existed on Earth"@en ;
  dcterms:modified "2026-02-19T08:26:13.612539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2650-4
  a curric:KeyLearningPoint ;
  rdfs:label """Palaeontologists use the fossils they find to propose theories about living things from the past"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2650-5
  a curric:KeyLearningPoint ;
  rdfs:label """Theories about prehistoric living things change over time as we gather more evidence"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2625-1
  a curric:KeyLearningPoint ;
  rdfs:label "Air resistance is a force caused by air moving against the surface of an object"@en ;
  dcterms:modified "2026-02-19T08:26:13.612551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2625-2
  a curric:KeyLearningPoint ;
  rdfs:label """Air resistance is a force that acts in the opposite direction to the movement of an object"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Air resistance can be helpful and unhelpful in different real-life situations"@en ;
  dcterms:modified "2026-02-19T08:26:13.612559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2625-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists control variables when planning fair tests to investigate air resistance"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1269-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information about how living things depend on each other for food can be used to create food chains."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1269-2
  a curric:KeyLearningPoint ;
  rdfs:label "The arrows in a food chain represent 'is food for'."@en ;
  dcterms:modified "2026-02-19T08:26:13.622947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1269-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food chains consist of a producer and consumers, including predators and prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.622959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1269-4
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary sources of information help us to research what food different animals eat to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2771-1
  a curric:KeyLearningPoint ;
  rdfs:label "Much of the food we eat can be grown to meet our demands."@en ;
  dcterms:modified "2026-02-19T08:26:13.623023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food miles is the distance food travels from the place it is grown to our plates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2771-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Food miles' provides one way to measure how the way we get our food can impact the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1211-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use our eyes to see objects."@en ;
  dcterms:modified "2026-02-19T08:26:13.623037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1211-2
  a curric:KeyLearningPoint ;
  rdfs:label "We need light to be able to see."@en ;
  dcterms:modified "2026-02-19T08:26:13.623041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1211-3
  a curric:KeyLearningPoint ;
  rdfs:label "Darkness is when there is there no light."@en ;
  dcterms:modified "2026-02-19T08:26:13.623045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1211-4
  a curric:KeyLearningPoint ;
  rdfs:label "We often need to rely on other senses when there is no light."@en ;
  dcterms:modified "2026-02-19T08:26:13.623049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different animals have different characteristics and these can be used to group them into broad categories"""@en ;
  dcterms:modified "2026-02-19T08:26:13.623055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2600-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some common animal groups are fish, amphibians, reptiles, birds and mammals"@en ;
  dcterms:modified "2026-02-19T08:26:13.623059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2600-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can be identified and grouped using classification skills"@en ;
  dcterms:modified "2026-02-19T08:26:13.623063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3390-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electrical conductor is a material that allows electricity to pass through it easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3390-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electrical insulator is a material that does not allow electricity to pass through it easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3390-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electrical insulators help keep us safe from the dangerous effects of electricity flowing through conductors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3390-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers choose different materials that are electrical conductors and insulators to solve problems."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1215-1
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be compared and classified according to how much light can pass through them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1215-2
  a curric:KeyLearningPoint ;
  rdfs:label "Opaque materials do not let light pass through them."@en ;
  dcterms:modified "2026-02-19T08:26:13.623172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1215-3
  a curric:KeyLearningPoint ;
  rdfs:label """Transparent materials allow light through so objects can clearly be seen through them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1215-4
  a curric:KeyLearningPoint ;
  rdfs:label """Translucent materials allow some light to pass through but are not completely see-through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some plants and animals in different food chains are in danger."@en ;
  dcterms:modified "2026-02-19T08:26:13.623185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can cause the habitats of plants and animals to change by cutting down trees or hunting."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3342-3
  a curric:KeyLearningPoint ;
  rdfs:label """When habitats change, the number of plants and animals living there may also change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3359-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans grow continuously and at changing rates from birth until the end of puberty."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mean averages can be used to help us analyse large data sets."@en ;
  dcterms:modified "2026-02-19T08:26:13.623224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3359-3
  a curric:KeyLearningPoint ;
  rdfs:label """Human height can be measured and plotted on a line graph to show how height varies with age."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1290-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often record data from observations and measurements in tables."@en ;
  dcterms:modified "2026-02-19T08:26:13.623234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1290-2
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of a sound depends on the distance from the sound source."@en ;
  dcterms:modified "2026-02-19T08:26:13.623240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1290-3
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the distance from the sound source, the quieter the sound."@en ;
  dcterms:modified "2026-02-19T08:26:13.623247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1290-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often evaluate a completed investigation and suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.623251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists communicate via TV news programmes, newspapers and social media."@en ;
  dcterms:modified "2026-02-19T08:26:13.623255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9176-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use simple language, photos, tables, drawings and charts to help the public to understand their results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9176-3
  a curric:KeyLearningPoint ;
  rdfs:label """The results of scientists' tests can be used to help the public to lead healthier, safer lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9176-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists appeared on TV every day to help the public to understand how to keep safe during the COVID–19 pandemic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9176-5
  a curric:KeyLearningPoint ;
  rdfs:label """Science experts and communicators help the public to understand the world by writing books and presenting TV programmes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3352-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different life cycles can be compared to find similarities and differences"@en ;
  dcterms:modified "2026-02-19T08:26:13.623319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3352-2
  a curric:KeyLearningPoint ;
  rdfs:label """Amphibians and insects have some similarities and some differences in their life cycles"""@en ;
  dcterms:modified "2026-02-19T08:26:13.623324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Differences in life cycles can be communicated using different types of scientific diagrams"""@en ;
  dcterms:modified "2026-02-19T08:26:13.623328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1242-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fruits and vegetables provide vitamins and fibre for good health."@en ;
  dcterms:modified "2026-02-19T08:26:13.623352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1242-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbohydrates give us the energy we need to be active."@en ;
  dcterms:modified "2026-02-19T08:26:13.623356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1242-3
  a curric:KeyLearningPoint ;
  rdfs:label "Proteins help our bones and muscles to grow, be healthy and repair."@en ;
  dcterms:modified "2026-02-19T08:26:13.623360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1242-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dairy, and alternatives, provides calcium for bone health."@en ;
  dcterms:modified "2026-02-19T08:26:13.623364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1242-5
  a curric:KeyLearningPoint ;
  rdfs:label """A small amount of fat, such as oils and spreads, is an essential part of a healthy, balanced diet."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1257-1
  a curric:KeyLearningPoint ;
  rdfs:label """A classification key is a series of yes/no questions about the observable characteristics of living things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1257-2
  a curric:KeyLearningPoint ;
  rdfs:label "Knowing the structure of an animal is useful when using classification keys."@en ;
  dcterms:modified "2026-02-19T08:26:13.623376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Zoologists discover, identify and study animals in the local and wider environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1257-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists, including zoologists and naturalists, use classification keys to identify and group animals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1268-1
  a curric:KeyLearningPoint ;
  rdfs:label "An animal that eats mostly meat or the flesh of other animals is a carnivore."@en ;
  dcterms:modified "2026-02-19T08:26:13.623392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1268-2
  a curric:KeyLearningPoint ;
  rdfs:label "A predator is an animal that hunts, kills and eats other animals."@en ;
  dcterms:modified "2026-02-19T08:26:13.623397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1268-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some animals do not have any predators of their own. These animals are at the top of a food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1268-4
  a curric:KeyLearningPoint ;
  rdfs:label "An animal that is hunted and eaten by another animal is called prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.623404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1268-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many animals are both predator and prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.623409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans continuously grow taller from birth through to the end of puberty."@en ;
  dcterms:modified "2026-02-19T08:26:13.623453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2620-2
  a curric:KeyLearningPoint ;
  rdfs:label "Growth rate is maximum during infancy and adolescence."@en ;
  dcterms:modified "2026-02-19T08:26:13.623457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Girls are often taller than boys at 12 to 14 years, but men are generally taller than women as adults."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2620-4
  a curric:KeyLearningPoint ;
  rdfs:label "Humans are taller now than in the past, due to improved nutrition and health."@en ;
  dcterms:modified "2026-02-19T08:26:13.623467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2620-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can find out about changes in height by measuring humans of different ages."@en ;
  dcterms:modified "2026-02-19T08:26:13.623471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9018-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food grown in this country does not travel far to reach your plate compared with food from other countries."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9018-2
  a curric:KeyLearningPoint ;
  rdfs:label "Eating local foods which are in season helps the environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.623561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9018-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some foods grown in other countries need lots of water to grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.623565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9018-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some foods grown in other countries take up a lot of land to grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.623569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1298-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electrical conductor is a material that allows electricity to pass through it easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1298-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electrical insulator is a material that does not allow electricity to pass through it easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1298-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metals are the best materials for conducting electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.623581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1298-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are minerals that can conduct electricity when dissolved in water."@en ;
  dcterms:modified "2026-02-19T08:26:13.623585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1298-5
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of electrical insulators are plastic, rubber, wood, glass and air."@en ;
  dcterms:modified "2026-02-19T08:26:13.623589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2675-1
  a curric:KeyLearningPoint ;
  rdfs:label """Engineers generate ideas to invent, design, and build objects that matter to improve our lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2675-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strict safety rules must be followed when using electrical components near to water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2675-3
  a curric:KeyLearningPoint ;
  rdfs:label "Science is about thinking creatively to try to explain how things work."@en ;
  dcterms:modified "2026-02-19T08:26:13.623639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2675-4
  a curric:KeyLearningPoint ;
  rdfs:label """Trial and error is when you try different ways to solve a problem and learn from your mistakes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3340-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare the producers and consumers, including predators and prey, in different food chains."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3340-2
  a curric:KeyLearningPoint ;
  rdfs:label "A predator is not always larger in size when compared to its prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.623651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most food chains are presented with an arrow in between each living thing to represent ‘is food for’."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3340-4
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain can be presented in different ways, including using writing, pictures, or both."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2613-1
  a curric:KeyLearningPoint ;
  rdfs:label """Seeds contain a tiny plant and a store of food to allow the plant to start growing."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2613-2
  a curric:KeyLearningPoint ;
  rdfs:label "Germination is when a seed first starts to grow into a plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.623673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2613-3
  a curric:KeyLearningPoint ;
  rdfs:label "Seeds require warmth, water and air to germinate."@en ;
  dcterms:modified "2026-02-19T08:26:13.623677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2613-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conservation is the act of protecting Earth's natural resources for current and future generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2613-5
  a curric:KeyLearningPoint ;
  rdfs:label """A seed bank is a place where seeds are kept safely to conserve different species of plants for the future."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2611-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination is the transfer of pollen from the anther of one flower to the stigma of another flower of the same species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2611-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pollinator is an animal involved in the pollination of plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.623693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2611-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination is mostly done by insects, although some birds, bats and other small mammals can be pollinators."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2611-4
  a curric:KeyLearningPoint ;
  rdfs:label """Features such as wings, hairy bodies and long noses mean pollinators can move around flowers, taking pollen with them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3361-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists ask relevant questions in order to find out more about the world."@en ;
  dcterms:modified "2026-02-19T08:26:13.623740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3361-2
  a curric:KeyLearningPoint ;
  rdfs:label "A survey is a method of gathering information using relevant questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.623744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3361-3
  a curric:KeyLearningPoint ;
  rdfs:label """A survey is usually taken from a sample of people with the aim of understanding populations as a whole."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3361-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of questions can be used in a survey and they must be planned carefully."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3363-1
  a curric:KeyLearningPoint ;
  rdfs:label "Population growth is the increase in the number of humans on Earth over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.623757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3363-2
  a curric:KeyLearningPoint ;
  rdfs:label """The growing population has been driven largely by the increase in human life expectancy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3363-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plotting data into a line graph can help to make predictions of population growth for the future."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Population growth can lead to increased demand for food, loss of habitats and more production of greenhouse gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2759-1
  a curric:KeyLearningPoint ;
  rdfs:label "Light pollution is the presence of too much or unnecessary light made by humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.623778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2759-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light pollution can disrupt human sleep and wildlife patterns."@en ;
  dcterms:modified "2026-02-19T08:26:13.623783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2759-3
  a curric:KeyLearningPoint ;
  rdfs:label "Urban areas with greater populations create more light pollution."@en ;
  dcterms:modified "2026-02-19T08:26:13.623787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2759-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some rural areas in the UK are named ‘Dark Sky’ sites, where their light pollution is low."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2759-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some organisations are campaigning to tackle light pollution and improve the night sky for people and wildlife."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1285-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sounds are made when an object vibrates."@en ;
  dcterms:modified "2026-02-19T08:26:13.623804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1285-2
  a curric:KeyLearningPoint ;
  rdfs:label "Large vibrations create loud sounds and small vibrations create quiet sounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.623808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1285-3
  a curric:KeyLearningPoint ;
  rdfs:label "Volume describes how loud or quiet a sound is."@en ;
  dcterms:modified "2026-02-19T08:26:13.623812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1285-4
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of a sound can be changed."@en ;
  dcterms:modified "2026-02-19T08:26:13.623816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3358-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants reproduce to make new plants, or offspring, in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.623852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3358-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plants that have been grown from cuttings can be observed changing over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.623859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations can be recorded in different ways, including annotated photographs, diagrams and tables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3393-1
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout history, pioneers in electrical engineering have largely shaped how we live today."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3393-2
  a curric:KeyLearningPoint ;
  rdfs:label "Science is about thinking creatively to try to explain how things work."@en ;
  dcterms:modified "2026-02-19T08:26:13.623871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3393-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ancient Greeks made observations about static electricity which is different to the electricity used in our appliances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3393-4
  a curric:KeyLearningPoint ;
  rdfs:label "Electrical pioneers learned how to harness electricity and use it to help us."@en ;
  dcterms:modified "2026-02-19T08:26:13.623879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3393-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrical inventions make some everyday tasks easier."@en ;
  dcterms:modified "2026-02-19T08:26:13.623883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3349-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many musical instruments can make different pitched sounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.623887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3349-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the length of the vibrating object can affect the pitch of the sound it produces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3349-3
  a curric:KeyLearningPoint ;
  rdfs:label """Larger vibrating objects make lower pitched sounds. Smaller vibrating objects make higher pitched sounds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2767-1
  a curric:KeyLearningPoint ;
  rdfs:label "A healthy diet is essential for good health."@en ;
  dcterms:modified "2026-02-19T08:26:13.623941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2767-2
  a curric:KeyLearningPoint ;
  rdfs:label "A meal plan gives your body the nutrients it needs every day."@en ;
  dcterms:modified "2026-02-19T08:26:13.623945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2767-3
  a curric:KeyLearningPoint ;
  rdfs:label "Secondary sources can help you to plan a nutrient-rich meal."@en ;
  dcterms:modified "2026-02-19T08:26:13.623949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1288-1
  a curric:KeyLearningPoint ;
  rdfs:label "Noise is unwanted or unpleasant sound."@en ;
  dcterms:modified "2026-02-19T08:26:13.623953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Noise pollution describes levels of noise in an environment that are unwanted or harmful."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1288-3
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of sound is measured in decibels (dB)."@en ;
  dcterms:modified "2026-02-19T08:26:13.623961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1288-4
  a curric:KeyLearningPoint ;
  rdfs:label "Normal conversation is approximately 60 dB."@en ;
  dcterms:modified "2026-02-19T08:26:13.623965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1288-5
  a curric:KeyLearningPoint ;
  rdfs:label """A decibel scale can be used to find out if sounds should be classified as noise pollution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1218-1
  a curric:KeyLearningPoint ;
  rdfs:label """The size of a shadow changes depending on the distance of an object from the light source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1218-2
  a curric:KeyLearningPoint ;
  rdfs:label "Height and distance can be measured using a ruler or tape measure."@en ;
  dcterms:modified "2026-02-19T08:26:13.623996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1218-3
  a curric:KeyLearningPoint ;
  rdfs:label "The results of an investigation can be recorded in a table."@en ;
  dcterms:modified "2026-02-19T08:26:13.624000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1218-4
  a curric:KeyLearningPoint ;
  rdfs:label """A table of results needs headings for each column. This helps other people to understand the information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3332-1
  a curric:KeyLearningPoint ;
  rdfs:label "Positive impacts on environments can include reforestation and recycling."@en ;
  dcterms:modified "2026-02-19T08:26:13.624008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3332-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reforestation is when forests are re-grown in areas that used to be populated by trees."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3332-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we recycle, we collect and sort rubbish instead of throwing it away. These items get changed into something new."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3332-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recycling and reusing objects can prevent rubbish going to landfill and having a negative effect on the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3332-5
  a curric:KeyLearningPoint ;
  rdfs:label """Environmental scientists are constantly studying and finding ways to protect changing environments."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3392-1
  a curric:KeyLearningPoint ;
  rdfs:label "People who work in some jobs risk exposure to high voltage electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.624097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3392-2
  a curric:KeyLearningPoint ;
  rdfs:label """People who work with electricity have a variety of safety wear or PPE, that they put on to work in certain places."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3392-3
  a curric:KeyLearningPoint ;
  rdfs:label """Insulators are used in many places in our daily lives to protect us from the dangers of electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers in industry test, design and make new and improved materials and products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3392-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lightning rods can be used to protect buildings from lightning strikes."@en ;
  dcterms:modified "2026-02-19T08:26:13.624113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1216-1
  a curric:KeyLearningPoint ;
  rdfs:label """When light falls on some objects, a dark shape is formed on the other side of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1216-2
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow is a dark shape that is formed when an object blocks light."@en ;
  dcterms:modified "2026-02-19T08:26:13.624121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1216-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opaque objects do not allow light to travel through them."@en ;
  dcterms:modified "2026-02-19T08:26:13.624125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1216-4
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow does not show the features of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.624129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1216-5
  a curric:KeyLearningPoint ;
  rdfs:label "The shape of a shadow depends on the shape of the object blocking the light."@en ;
  dcterms:modified "2026-02-19T08:26:13.624133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1300-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional power stations burn coal or gas to generate electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.624137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1300-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity is generated when the blades of a turbine turn causing a magnet to spin inside a coil of wire."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1300-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity is generated at traditional power stations or using the wind, water or the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1300-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity is transported around the country and to our homes through metal cables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists collect evidence from research that helps us to make informed choices about healthy lifestyles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3380-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can determine the reliability of a source by looking at who wrote it, for what purpose and using what evidence."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3380-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to examine information from a range of reliable sources."@en ;
  dcterms:modified "2026-02-19T08:26:13.624271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lots of factors contribute towards a healthy lifestyle, including diet, physical activity levels and sleep patterns."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3378-2
  a curric:KeyLearningPoint ;
  rdfs:label """A lifestyle journal is similar to a diary and can be used to track daily habits and activities."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3378-3
  a curric:KeyLearningPoint ;
  rdfs:label """A lifestyle journal can be used to log physical activity, diet and sleep patterns."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3378-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing the data collected in a lifestyle journal can highlight areas for improved health goals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3370-1
  a curric:KeyLearningPoint ;
  rdfs:label "Diet is the type and range of food that you eat regularly."@en ;
  dcterms:modified "2026-02-19T08:26:13.624331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3370-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eating food with essential nutrients is important for good health, growth and development."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3370-3
  a curric:KeyLearningPoint ;
  rdfs:label "The foods we choose to eat can have an impact on how our bodies function."@en ;
  dcterms:modified "2026-02-19T08:26:13.624339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3370-4
  a curric:KeyLearningPoint ;
  rdfs:label "Balanced diets can lower chances of developing chronic diseases."@en ;
  dcterms:modified "2026-02-19T08:26:13.624343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9031-1
  a curric:KeyLearningPoint ;
  rdfs:label "A mushroom is not a plant; it is a fungus."@en ;
  dcterms:modified "2026-02-19T08:26:13.624382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9031-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mushrooms are high in protein and are one of the most sustainable foods to grow and eat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mushrooms grow best in dark, moist conditions and continue to provide food over several weeks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9031-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mycoprotein is a sustainable protein made from fermented fungus."@en ;
  dcterms:modified "2026-02-19T08:26:13.624394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9031-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mycoprotein is made into 'meatless' foods such as burgers, mincemeat and 'chicken'."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nicotine is a highly addictive drug found in tobacco."@en ;
  dcterms:modified "2026-02-19T08:26:13.624402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smoking can make it more difficult for blood to move around the body and deliver oxygen to the muscles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3376-3
  a curric:KeyLearningPoint ;
  rdfs:label "Smoking can lead to a number of diseases, including heart and lung disease."@en ;
  dcterms:modified "2026-02-19T08:26:13.624410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3376-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vaping is considered to be less harmful than smoking, but still not safe."@en ;
  dcterms:modified "2026-02-19T08:26:13.624414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3376-5
  a curric:KeyLearningPoint ;
  rdfs:label """Information about the dangers of smoking can be researched using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3333-1
  a curric:KeyLearningPoint ;
  rdfs:label "News reports can take many different forms, and can be written or verbal."@en ;
  dcterms:modified "2026-02-19T08:26:13.624422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3333-2
  a curric:KeyLearningPoint ;
  rdfs:label """News reports provide information to a wide audience where scientists can share their findings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3333-3
  a curric:KeyLearningPoint ;
  rdfs:label """A news report has specific features, including a headline, factual information and quotes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3333-4
  a curric:KeyLearningPoint ;
  rdfs:label """News reports often include facts or statistics, and avoid using the reporter's own opinion."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3333-5
  a curric:KeyLearningPoint ;
  rdfs:label """Having access to information in the news allows people to make informed choices about their own actions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9023-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals are often in decline due to changes in their environment, including habitat loss."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9023-2
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers of many types of animals living in the UK are in decline."@en ;
  dcterms:modified "2026-02-19T08:26:13.624451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9023-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some animals in decline in the UK include, red squirrels, hedgehogs, natterjack toads and greater mouse-eared bats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9023-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are ways to protect animals in decline, including providing sources of food and places for them to shelter."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3355-1
  a curric:KeyLearningPoint ;
  rdfs:label "Endangered animals are animals that are in danger of becoming extinct."@en ;
  dcterms:modified "2026-02-19T08:26:13.624466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3355-2
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone can take action to help prevent animals from becoming extinct."@en ;
  dcterms:modified "2026-02-19T08:26:13.624470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists communicate information in clear and interesting ways to make it easy to understand."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some careers, such as electrician, are linked to the installation and maintenance of electrical systems."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3391-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are a wide variety of careers available to young people today involving electrical technology."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some careers, such as power plant operators and line workers, involve generating and transporting electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careers in electronics involve designing and using electrical circuits found in everyday devices and systems."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3391-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrical careers can be researched using secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.624535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3371-1
  a curric:KeyLearningPoint ;
  rdfs:label "Your heart rate is how many times your heart beats each minute."@en ;
  dcterms:modified "2026-02-19T08:26:13.624539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3371-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stethoscopes, smartwatches and pulse oximeters can measure heart rate."@en ;
  dcterms:modified "2026-02-19T08:26:13.624543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3371-3
  a curric:KeyLearningPoint ;
  rdfs:label """Your pulse can be felt at the wrist and other places where an artery is close to the skin."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3371-4
  a curric:KeyLearningPoint ;
  rdfs:label """During exercise, your heart beats faster so that more blood circulates around your body delivering oxygen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3371-5
  a curric:KeyLearningPoint ;
  rdfs:label "Exercise strengthens your heart and improves your circulation."@en ;
  dcterms:modified "2026-02-19T08:26:13.624555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3330-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants depend on their environment to provide what they need to grow and survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3330-2
  a curric:KeyLearningPoint ;
  rdfs:label "Changes to environments can cause danger to the plants within them."@en ;
  dcterms:modified "2026-02-19T08:26:13.624563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3330-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use several methods to count and study the number of plants in an environment including surveys and sampling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3330-4
  a curric:KeyLearningPoint ;
  rdfs:label """A quadrat can be used in different locations to help get an accurate estimate of plant numbers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9179-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists who investigate materials often control, measure and change variables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9179-2
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are variables that are kept the same throughout an investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9179-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are some types of investigations where some, but not all, variables can be controlled."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9179-4
  a curric:KeyLearningPoint ;
  rdfs:label """Astronomers make observations and look for patterns in their data, however, they cannot control variables in space."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9179-5
  a curric:KeyLearningPoint ;
  rdfs:label """The 21st century astronomer Maggie Aderin–Pocock makes her observations using instruments on satellites in space."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3343-1
  a curric:KeyLearningPoint ;
  rdfs:label """A change to one living thing can affect other living things in the same food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans should be encouraged to behave in ways that help to protect plants and animals in their habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3343-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information about protecting food chains can be researched using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3348-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pitch describes how low or high a sound is, and can be measured using a sound meter to detect pitch."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3348-2
  a curric:KeyLearningPoint ;
  rdfs:label "The unit for measuring pitch is hertz (Hz)."@en ;
  dcterms:modified "2026-02-19T08:26:13.624754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists look for patterns in sets of results to tell them how one thing affects another thing."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the length of the vibrating object can affect the pitch of the sound it produces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1253-1
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be organised into groups based on what they have in common."@en ;
  dcterms:modified "2026-02-19T08:26:13.624765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1253-2
  a curric:KeyLearningPoint ;
  rdfs:label """Observable characteristics can include information about colour, size, shape or structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1253-3
  a curric:KeyLearningPoint ;
  rdfs:label "Observable characteristics help us to sort objects into common groups."@en ;
  dcterms:modified "2026-02-19T08:26:13.624773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1253-4
  a curric:KeyLearningPoint ;
  rdfs:label """A Venn diagram and a Carroll diagram are both ways of presenting objects belonging to more than one common group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3372-1
  a curric:KeyLearningPoint ;
  rdfs:label """Your pulse can be felt at the wrist and other places where an artery is close to the skin."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3372-2
  a curric:KeyLearningPoint ;
  rdfs:label """A healthy resting heart rate for adults is between 50 and 90 beats per minute (bpm)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3372-3
  a curric:KeyLearningPoint ;
  rdfs:label """Recovery time is the amount of time it takes your heart to return to its resting rate after being active."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3372-4
  a curric:KeyLearningPoint ;
  rdfs:label "Regular exercise can improve recovery time and overall heart health."@en ;
  dcterms:modified "2026-02-19T08:26:13.624796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are mammals, they grow and develop inside the mother's womb for nine months until they are born."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2615-2
  a curric:KeyLearningPoint ;
  rdfs:label "When human babies are born they cannot survive by themselves."@en ;
  dcterms:modified "2026-02-19T08:26:13.624837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2615-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are considered as babies up to 12 months of age, as they learn to focus their vision, reach out and explore."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Up until they are six months old, babies don't eat normal food, they only drink milk."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2615-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stages of human development as a baby can be recorded in a variety of ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.624849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9177-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many jobs that use the results of scientists and engineers to help them carry out their work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9177-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electrical engineers carry out tests to design new circuits for electrical appliances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9177-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electricians solve wiring problems, check if circuits have been built incorrectly and repair broken appliances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2605-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different life cycles can be compared to find similarities and differences"@en ;
  dcterms:modified "2026-02-19T08:26:13.624904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mammals and birds have some similarities and some differences in their life cycles"""@en ;
  dcterms:modified "2026-02-19T08:26:13.624908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2605-3
  a curric:KeyLearningPoint ;
  rdfs:label """Differences in life cycles can be communicated using scientific diagrams and tables"""@en ;
  dcterms:modified "2026-02-19T08:26:13.624912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1252-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans ask questions to help them to understand the world, including how things work and why things happen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1252-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some questions require an answer of only yes or no."@en ;
  dcterms:modified "2026-02-19T08:26:13.624920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1252-3
  a curric:KeyLearningPoint ;
  rdfs:label "Yes/no questions often begin with ‘Do’, ‘Are’, ‘Is’, ‘Have’ or 'Can'."@en ;
  dcterms:modified "2026-02-19T08:26:13.624924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1252-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use answers to yes/no questions to help us to identify and name unknown things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2757-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reflection involves a source of light and a surface."@en ;
  dcterms:modified "2026-02-19T08:26:13.624935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2757-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light reflected from a surface is called reflected light."@en ;
  dcterms:modified "2026-02-19T08:26:13.624940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2757-3
  a curric:KeyLearningPoint ;
  rdfs:label """Data loggers are electronic devices which monitor and record changes in the environment over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2757-4
  a curric:KeyLearningPoint ;
  rdfs:label "Light is measured in lux (lx) and can be recorded using a data logger."@en ;
  dcterms:modified "2026-02-19T08:26:13.624948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2619-1
  a curric:KeyLearningPoint ;
  rdfs:label "Old age is the last period of human life."@en ;
  dcterms:modified "2026-02-19T08:26:13.624952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2619-2
  a curric:KeyLearningPoint ;
  rdfs:label "Old age in adulthood is believed to begin at about 65 years."@en ;
  dcterms:modified "2026-02-19T08:26:13.624956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2619-3
  a curric:KeyLearningPoint ;
  rdfs:label """During old age, hair can become more grey and hearing and vision can deteriorate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2619-4
  a curric:KeyLearningPoint ;
  rdfs:label """During old age, bones can shrink in size, and muscles generally lose strength and flexibility."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2619-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can find answers to questions about human development in old age by speaking to elderly people."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2672-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the number and voltage of batteries increases the electrical push they provide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2672-2
  a curric:KeyLearningPoint ;
  rdfs:label "Test results help scientists to make predictions for further investigations."@en ;
  dcterms:modified "2026-02-19T08:26:13.624975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2672-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sensors and data loggers can be used to make and record accurate measurements of light and sound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2672-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists evaluate results to compare what was expected to what actually happened."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3356-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination is the transfer of pollen from one flower to the stigma of another flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plant offspring grown from seeds will have a combination of characteristics of their two parent plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Selective breeding involves producing offspring from parents that have desirable characteristics."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3356-4
  a curric:KeyLearningPoint ;
  rdfs:label """Selective breeding can create new varieties of good crops, with higher resistance to pests and disease."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3356-5
  a curric:KeyLearningPoint ;
  rdfs:label """Artificial pollination can be done by hand to produce offspring with desired characteristics."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2609-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants reproduce to make new plants, or offspring, in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.625064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some plants reproduce when part of a single plant is used to generate a new plant."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2609-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cuttings produce clones of the parent plant; they are exactly the same."@en ;
  dcterms:modified "2026-02-19T08:26:13.625074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2609-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plant growth can be observed and recorded over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.625079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2770-1
  a curric:KeyLearningPoint ;
  rdfs:label "As the human population size on Earth increases, more food will be needed."@en ;
  dcterms:modified "2026-02-19T08:26:13.625083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2770-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make sure there will be enough food to meet the increasing demand, we should produce food in more sustainable ways."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2770-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is better for the environment to buy local food in season."@en ;
  dcterms:modified "2026-02-19T08:26:13.625091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2770-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should buy what you plan to consume, to avoid unnecessary food waste."@en ;
  dcterms:modified "2026-02-19T08:26:13.625095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1213-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun provides heat and light and is necessary for living things to survive on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1213-2
  a curric:KeyLearningPoint ;
  rdfs:label "Too much ultra violet (UV) light from the Sun can be dangerous."@en ;
  dcterms:modified "2026-02-19T08:26:13.625103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1213-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are ways to protect our eyes from the Sun."@en ;
  dcterms:modified "2026-02-19T08:26:13.625107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1213-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is not safe to look directly at the Sun, even when wearing sunglasses."@en ;
  dcterms:modified "2026-02-19T08:26:13.625111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1213-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists ask questions and plan different types of enquiries."@en ;
  dcterms:modified "2026-02-19T08:26:13.625117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2608-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants reproduce to make new plants, or offspring, in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.625121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2608-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants can reproduce asexually, which means a single parent plant can reproduce on its own."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2608-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants produced asexually are identical to their parent plant; they are clones."@en ;
  dcterms:modified "2026-02-19T08:26:13.625130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2608-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bulbs, runners and tubers are examples of asexual plant reproduction."@en ;
  dcterms:modified "2026-02-19T08:26:13.625136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2756-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists make observations and measurements to help them to learn more about the world and how things work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2756-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists review the results they have collected to decide what happened and explain what they have found out."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2756-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use words ending in -er to explain how one thing affects another thing."@en ;
  dcterms:modified "2026-02-19T08:26:13.625168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2756-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the object is closer to the light source, it blocks more light and this makes the shadow appear bigger."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2769-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some people choose to remove meat from their diets for religious, environmental or personal reasons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2769-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some people are allergic to individual ingredients."@en ;
  dcterms:modified "2026-02-19T08:26:13.625183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2769-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some people have lifelong health conditions where they need to monitor their diet more closely."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2769-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some people follow alternative diets for sport and fitness purposes."@en ;
  dcterms:modified "2026-02-19T08:26:13.625191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2769-5
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the ingredients of the food you eat allows you to make choices based on your diet."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1291-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch and volume are different things."@en ;
  dcterms:modified "2026-02-19T08:26:13.625292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1291-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pitch describes how high or low a sound is."@en ;
  dcterms:modified "2026-02-19T08:26:13.625296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1291-3
  a curric:KeyLearningPoint ;
  rdfs:label """Amusia, or tone deafness, is the inability to detect pitch, and only affects around 4% of the population."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1291-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound is made when an object vibrates. Different objects produce different pitch sounds when they vibrate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1291-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some objects vibrate to produce more than one pitched sound."@en ;
  dcterms:modified "2026-02-19T08:26:13.625308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2601-1
  a curric:KeyLearningPoint ;
  rdfs:label """An insect is a small animal that has six jointed legs, and typically one or two pairs of wings"""@en ;
  dcterms:modified "2026-02-19T08:26:13.625312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Insects have three parts to their segmented bodies (head, thorax, and abdomen) and a pair of antennae"""@en ;
  dcterms:modified "2026-02-19T08:26:13.625318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Insects are invertebrates (have no backbone) and have an external shell (exoskeleton)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.625328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2601-4
  a curric:KeyLearningPoint ;
  rdfs:label "Common insects are ants, flies, butterflies, and beetles"@en ;
  dcterms:modified "2026-02-19T08:26:13.625332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2603-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mammals are animals, they are living things that grow and reproduce"@en ;
  dcterms:modified "2026-02-19T08:26:13.625336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Life cycles of different mammals can be observed over time and/or researched using secondary sources of information"""@en ;
  dcterms:modified "2026-02-19T08:26:13.625340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2603-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams are used to show the stages in a mammal’s life cycle"@en ;
  dcterms:modified "2026-02-19T08:26:13.625344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2603-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mammals are born alive from their mother"@en ;
  dcterms:modified "2026-02-19T08:26:13.625348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2603-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stages of a mammal’s life cycle are baby, young and adult"@en ;
  dcterms:modified "2026-02-19T08:26:13.625352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1297-1
  a curric:KeyLearningPoint ;
  rdfs:label "Switches are used to control circuits."@en ;
  dcterms:modified "2026-02-19T08:26:13.625356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1297-2
  a curric:KeyLearningPoint ;
  rdfs:label """Switches can break a circuit by making a space between components where the electricity cannot flow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1297-3
  a curric:KeyLearningPoint ;
  rdfs:label "Switches are used to turn bulbs, buzzers and motors on and off."@en ;
  dcterms:modified "2026-02-19T08:26:13.625364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1297-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of switches are used to control many electrical appliances we use everyday."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1296-1
  a curric:KeyLearningPoint ;
  rdfs:label "A circuit will not work if it is not part of a complete loop with a battery."@en ;
  dcterms:modified "2026-02-19T08:26:13.625377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1296-2
  a curric:KeyLearningPoint ;
  rdfs:label "Buzzers only work if they are connected in the correct direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.625404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1296-3
  a curric:KeyLearningPoint ;
  rdfs:label """To solve problems with circuits, scientists test whether they are connected correctly and whether the components work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1296-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electricians check if circuits have been built incorrectly and with improper wiring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1296-5
  a curric:KeyLearningPoint ;
  rdfs:label """When we use electricity and electrical appliances, we need to follow rules to stay safe."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1258-1
  a curric:KeyLearningPoint ;
  rdfs:label """A classification key is a series of yes/no questions about the observable characteristics of living things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1258-2
  a curric:KeyLearningPoint ;
  rdfs:label "Knowing the structure of plants is useful when using classification keys."@en ;
  dcterms:modified "2026-02-19T08:26:13.625464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1258-3
  a curric:KeyLearningPoint ;
  rdfs:label """Botanists discover, identify and study plants in the local and wider environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1258-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists including botanists, use classification keys to identify and group plants in the local and wider environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional cars use petrol and diesel to make them move, whereas electric cars move using electricity from a battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide, emitted from petrol and diesel cars, is a greenhouse gas which contributes to global warming."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3394-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pure electric cars produce no carbon dioxide emissions when driving."@en ;
  dcterms:modified "2026-02-19T08:26:13.625594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some cities have all electric public transport in order to lower carbon dioxide emissions and reduce air pollution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3394-5
  a curric:KeyLearningPoint ;
  rdfs:label """There has been public debate about the use electric of vehicles, with people on different sides citing pros and cons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3328-1
  a curric:KeyLearningPoint ;
  rdfs:label "Environments can change in a negative way as a result of the actions of humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.625606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3328-2
  a curric:KeyLearningPoint ;
  rdfs:label "Larger populations can create greater amounts of waste and pollution."@en ;
  dcterms:modified "2026-02-19T08:26:13.625610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3328-3
  a curric:KeyLearningPoint ;
  rdfs:label """The cars we drive, the products we use and the crops we eat can all contribute to pollution in the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3328-4
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals can change the way they live to reduce the impact of waste creation and pollution on the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3328-5
  a curric:KeyLearningPoint ;
  rdfs:label "Industries can change the way they work to help create less waste and pollution."@en ;
  dcterms:modified "2026-02-19T08:26:13.625644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1299-1
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are very useful materials, with properties such as strength, stiffness and electrical conductivity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1299-2
  a curric:KeyLearningPoint ;
  rdfs:label """Results of scientific enquiries can be recorded in different ways including charts and tables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1299-3
  a curric:KeyLearningPoint ;
  rdfs:label """All metals conduct electricity, but some metals are better electrical conductors than others."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1299-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials are chosen for particular jobs based on their properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.625740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3339-1
  a curric:KeyLearningPoint ;
  rdfs:label "A food chain includes a producer and consumers, including predators and prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.625864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3339-2
  a curric:KeyLearningPoint ;
  rdfs:label "Food chains can be compared by looking at what is similar and what is different."@en ;
  dcterms:modified "2026-02-19T08:26:13.625870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3339-3
  a curric:KeyLearningPoint ;
  rdfs:label "A plant or animal can be part of many different food chains."@en ;
  dcterms:modified "2026-02-19T08:26:13.625873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3339-4
  a curric:KeyLearningPoint ;
  rdfs:label """People who work with and study animals can be used as secondary sources of information about what animals eat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2673-1
  a curric:KeyLearningPoint ;
  rdfs:label """Switches play an important role in our lives because they allow us to control the flow of electricity to appliances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2673-2
  a curric:KeyLearningPoint ;
  rdfs:label "Switches can turn a circuit off by making a gap so electricity cannot flow."@en ;
  dcterms:modified "2026-02-19T08:26:13.625885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2673-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional switches work by making a pair of conductors touch each other or separate from each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2673-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engineers have created innovative switches which are sensitive to human touch."@en ;
  dcterms:modified "2026-02-19T08:26:13.625893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2673-5
  a curric:KeyLearningPoint ;
  rdfs:label """Switches for simple circuits can be created from a range of everyday conductors and insulators."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3867-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists collect evidence from research that helps us to make informed choices about healthy lifestyles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3867-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to examine information from a range of reliable sources."@en ;
  dcterms:modified "2026-02-19T08:26:13.625908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3867-3
  a curric:KeyLearningPoint ;
  rdfs:label "Findings can be presented in a range of ways including oral and written forms."@en ;
  dcterms:modified "2026-02-19T08:26:13.625912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3867-4
  a curric:KeyLearningPoint ;
  rdfs:label """Information for the general public should be communicated in a clear and accessible way."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9022-1
  a curric:KeyLearningPoint ;
  rdfs:label """The air around our planet is warming up, this can lead to heatwaves in some countries of the world."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9022-2
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature for a 'heatwave' is different in different countries."@en ;
  dcterms:modified "2026-02-19T08:26:13.625923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9022-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extreme weather, including heatwaves, are dangerous for animals including humans."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9022-4
  a curric:KeyLearningPoint ;
  rdfs:label "Wildfires are dangerous as they spread quickly and are difficult to put out."@en ;
  dcterms:modified "2026-02-19T08:26:13.625931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9022-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wildfires can harm plants and animals and can damage the soil."@en ;
  dcterms:modified "2026-02-19T08:26:13.625935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3341-1
  a curric:KeyLearningPoint ;
  rdfs:label """The name or picture of each living thing in a food chain represents the whole population of that plant or animal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3341-2
  a curric:KeyLearningPoint ;
  rdfs:label """A change to one living thing can affect other living things in the same food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3341-3
  a curric:KeyLearningPoint ;
  rdfs:label """An increase or decrease in the population of a plant or animal can have an effect on the food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in food chains may lead to animals and plants becoming endangered or even extinct."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1244-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the nutritional information of what we eat is important so we can make informed decisions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1244-2
  a curric:KeyLearningPoint ;
  rdfs:label """The nutritional information of most pre-packed food in the UK can be found on the label."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1244-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some nutritional information is colour-coded to make it simple to understand quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1244-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nutritional information is provided per 100 grams or per 100 millilitres and sometimes per portion of the food or drink."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1244-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nutrition information helps us compare foods in a fair way and be aware of foods that are high in fat, salt and sugar."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sounds are heard when vibrations travel from the object through a medium to our ear."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1283-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vibrations create sound waves which are not visible in the air, but we can use diagrams to show how they travel."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1283-3
  a curric:KeyLearningPoint ;
  rdfs:label "A medium can be a solid, a liquid, or a gas, such as a wall, water, or the air."@en ;
  dcterms:modified "2026-02-19T08:26:13.625989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1283-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound cannot be heard in outer space as there is no air, therefore no medium for sound to travel through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3327-1
  a curric:KeyLearningPoint ;
  rdfs:label "The actions of humans can have a negative impact on the environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.625999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3327-2
  a curric:KeyLearningPoint ;
  rdfs:label """A negative impact happens when changes cause harm to an environment or the living things within it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3327-3
  a curric:KeyLearningPoint ;
  rdfs:label """A growing human population can mean that towns and cities are often developed on land where there was once countryside."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3327-4
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation is when forests are removed by humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.626012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3327-5
  a curric:KeyLearningPoint ;
  rdfs:label """Developments in an environment take requirements away from the living things already living there."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27592-1
  a curric:KeyLearningPoint ;
  rdfs:label """The water in our seas and oceans contains salt. This water is not safe for drinking."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27592-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation can be used to remove the water from a salt solution."@en ;
  dcterms:modified "2026-02-19T08:26:13.626024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27592-3
  a curric:KeyLearningPoint ;
  rdfs:label """Condensation is when a water in the gas state (water vapour) is cooled so that it changes to water in the liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27592-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers investigate ways of making seawater safe to drink using evaporation and condensation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27592-5
  a curric:KeyLearningPoint ;
  rdfs:label "Microorganisms must also be removed from water to make it safe to drink."@en ;
  dcterms:modified "2026-02-19T08:26:13.626035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2607-1
  a curric:KeyLearningPoint ;
  rdfs:label "Insects are animals, they are living things that grow and reproduce"@en ;
  dcterms:modified "2026-02-19T08:26:13.626094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2607-2
  a curric:KeyLearningPoint ;
  rdfs:label "The life cycles of different insects can be observed over time and/or researched"@en ;
  dcterms:modified "2026-02-19T08:26:13.626098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2607-3
  a curric:KeyLearningPoint ;
  rdfs:label """The life cycle of an insect is commonly: egg, larva (young stage), pupa (inactive) and adult stage"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many insects undergo the greatest changes of all animals, they undergo a complete metamorphosis"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2607-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams are used to show the stages in an insect’s life cycle"@en ;
  dcterms:modified "2026-02-19T08:26:13.626112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1289-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sound source is an object that vibrates to produce a sound."@en ;
  dcterms:modified "2026-02-19T08:26:13.626140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1289-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions about how the volume of a sound depends on the distance from the sound source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1289-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair test helps us to understand how one thing depends on or affects something else."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1289-4
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of a sound can be recorded using a data logger."@en ;
  dcterms:modified "2026-02-19T08:26:13.626152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1282-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sounds are made when an object vibrates."@en ;
  dcterms:modified "2026-02-19T08:26:13.626156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1282-2
  a curric:KeyLearningPoint ;
  rdfs:label "If an object is not vibrating, it will not make a sound."@en ;
  dcterms:modified "2026-02-19T08:26:13.626160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1282-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different objects produce different sounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.626163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1282-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vibrations and sounds can be made in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.626167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2610-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants reproduce to make new plants (offspring) in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.626172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2610-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flowering plants can reproduce by making seeds, which grow into new plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.626176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2610-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pollination is the transfer of pollen from  the anther of one flower to the stigma of another flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2610-4
  a curric:KeyLearningPoint ;
  rdfs:label "After pollination, pollen travels to the ovary and fertilises the flower."@en ;
  dcterms:modified "2026-02-19T08:26:13.626184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2610-5
  a curric:KeyLearningPoint ;
  rdfs:label "Seed formation happens after fertilisation."@en ;
  dcterms:modified "2026-02-19T08:26:13.626187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3360-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can use graphs to represent data visually and make it easier to understand."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3360-2
  a curric:KeyLearningPoint ;
  rdfs:label """Human height can be measured and plotted on a line graph to show how height varies with age."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3360-3
  a curric:KeyLearningPoint ;
  rdfs:label "Findings from enquiries can be used to make further predictions."@en ;
  dcterms:modified "2026-02-19T08:26:13.626239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2616-1
  a curric:KeyLearningPoint ;
  rdfs:label """By the time children reach 12 months of age, they are toddlers as they begin to walk."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2616-2
  a curric:KeyLearningPoint ;
  rdfs:label "Once a human reaches the age of three years old, they are classed as a child."@en ;
  dcterms:modified "2026-02-19T08:26:13.626251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Children reach a variety of important milestones in how they play, learn, speak, behave, and move."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2616-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stages of human development through childhood can be recorded using a timeline."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1248-1
  a curric:KeyLearningPoint ;
  rdfs:label """The bones of the human skeleton are solid, strong and are various shapes with different functions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1248-2
  a curric:KeyLearningPoint ;
  rdfs:label "The skull protects the brain."@en ;
  dcterms:modified "2026-02-19T08:26:13.626277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1248-3
  a curric:KeyLearningPoint ;
  rdfs:label "The rib cage protects organs such as the heart and lungs."@en ;
  dcterms:modified "2026-02-19T08:26:13.626280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1248-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spine protects the spinal cord."@en ;
  dcterms:modified "2026-02-19T08:26:13.626284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1248-5
  a curric:KeyLearningPoint ;
  rdfs:label "Despite being strong and solid, anyone can break a bone."@en ;
  dcterms:modified "2026-02-19T08:26:13.626288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1295-1
  a curric:KeyLearningPoint ;
  rdfs:label """A complete electrical circuit is made when all components are connected together correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1295-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wires must be connected to the positive and negative end of the battery in a complete loop."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1295-3
  a curric:KeyLearningPoint ;
  rdfs:label "A series circuit is when all the components are in the same loop."@en ;
  dcterms:modified "2026-02-19T08:26:13.626322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1295-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists try out different ideas in order to solve problems."@en ;
  dcterms:modified "2026-02-19T08:26:13.626326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3375-1
  a curric:KeyLearningPoint ;
  rdfs:label "Drugs are substances that change the way our bodies work."@en ;
  dcterms:modified "2026-02-19T08:26:13.626330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3375-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some drugs are prescribed by a doctor."@en ;
  dcterms:modified "2026-02-19T08:26:13.626334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information about drugs and their impact on the body can be researched using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3375-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some drugs are illegal because of the negative impact they have on our bodies. It is not safe to take illegal drugs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1217-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shadows are formed when the light from a light source is blocked by an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.626346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1217-2
  a curric:KeyLearningPoint ;
  rdfs:label """The size of a shadow changes depending on the distance of an object from the light source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1217-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists ask questions and then plan how to carry out the right type of investigation to find answers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1217-4
  a curric:KeyLearningPoint ;
  rdfs:label """A fair test investigation is when only one thing is changed and another is measured. All other things are kept the same."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1241-1
  a curric:KeyLearningPoint ;
  rdfs:label "All living things need food to stay alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.626362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1241-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can make their own food using sunlight, carbon dioxide and water."@en ;
  dcterms:modified "2026-02-19T08:26:13.626368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1241-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals, including humans, cannot make their own food."@en ;
  dcterms:modified "2026-02-19T08:26:13.626372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1241-4
  a curric:KeyLearningPoint ;
  rdfs:label "Wild animals find their sources of food within the habitats they live in."@en ;
  dcterms:modified "2026-02-19T08:26:13.626376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1241-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pets, or animals in captivity, rely on humans to replicate their natural diets."@en ;
  dcterms:modified "2026-02-19T08:26:13.626380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2617-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adolescence is the stage of growth and development between childhood and adulthood"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2617-2
  a curric:KeyLearningPoint ;
  rdfs:label """Puberty is when a child's body begins to develop and change as they become an adult and are able to reproduce"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2617-3
  a curric:KeyLearningPoint ;
  rdfs:label """Puberty usually happens between ages 10 and 14 for girls, and ages 12 and 16 for boys"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2617-4
  a curric:KeyLearningPoint ;
  rdfs:label """Signs of puberty for girls include changing body shape, additional body hair and starting periods"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2617-5
  a curric:KeyLearningPoint ;
  rdfs:label """Signs of puberty for boys include changing body shape, additional body hair and a deeper voice"""@en ;
  dcterms:modified "2026-02-19T08:26:13.626505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3329-1
  a curric:KeyLearningPoint ;
  rdfs:label """An animal's environment must contain all the things required for living things to survive and grow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3329-2
  a curric:KeyLearningPoint ;
  rdfs:label "Changes to environments can cause danger to the animals within them."@en ;
  dcterms:modified "2026-02-19T08:26:13.626516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3329-3
  a curric:KeyLearningPoint ;
  rdfs:label """Estimating the number of animals in an environment can be a challenging task and can be done in different ways."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3329-4
  a curric:KeyLearningPoint ;
  rdfs:label """Researchers may directly observe animals in the wild, and also use technology such as drones to survey large areas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1286-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can compare different sounds by measuring their volume."@en ;
  dcterms:modified "2026-02-19T08:26:13.626528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data loggers are electronic devices which monitor and record changes in the environment over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1286-3
  a curric:KeyLearningPoint ;
  rdfs:label "The volume of a sound in decibels (dB) can be measured using a data logger."@en ;
  dcterms:modified "2026-02-19T08:26:13.626536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers take accurate measurements to compare and control the volume of sounds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2667-1
  a curric:KeyLearningPoint ;
  rdfs:label "Circuit symbols are small images that represent different electrical components."@en ;
  dcterms:modified "2026-02-19T08:26:13.626548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Circuit symbols allow everybody in the world to understand how a circuit is made."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2667-3
  a curric:KeyLearningPoint ;
  rdfs:label "Circuit diagrams show how the components in a circuit are connected together."@en ;
  dcterms:modified "2026-02-19T08:26:13.626558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2674-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are sensors all around us to detect changes in things like temperature, motion, moisture, light, distance etc."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sensors are used in everyday appliances such as washing machines, lights, burglar and fire alarms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2674-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strict safety rules must be followed when planning to use electrical components near water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2674-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engineers generate ideas to invent, design, and build objects that matter."@en ;
  dcterms:modified "2026-02-19T08:26:13.626574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1245-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fats are a type of nutrient that you get from your diet, that give your body energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1245-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is essential to eat some fats, though it is also harmful to eat too much."@en ;
  dcterms:modified "2026-02-19T08:26:13.626582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1245-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fats in foods produce a greasy mark that is not easily removed."@en ;
  dcterms:modified "2026-02-19T08:26:13.626586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fats in food, absorbed by paper, are easily visible and make it easy to identify which foods contain fats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1245-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists ask questions, then plan investigations to find answers."@en ;
  dcterms:modified "2026-02-19T08:26:13.626594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1293-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers invent and design electrical appliances to help improve our lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1293-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific ideas can be presented using labelled scientific drawings and diagrams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2671-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equipment such as a light sensor and data logger can be used to measure bulb brightness in lux."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use the results from investigations to support or reject scientific ideas and theories."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2671-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding bulbs means that voltage is equally distributed among them all, so bulbs will be dimmer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2671-4
  a curric:KeyLearningPoint ;
  rdfs:label "A bulb will be the same brightness wherever you place it in a circuit."@en ;
  dcterms:modified "2026-02-19T08:26:13.626687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Protein is an important nutrient in food as part of a balanced diet to build and repair bones and muscles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9030-2
  a curric:KeyLearningPoint ;
  rdfs:label """Forests are often cut down to create space for animals including cattle to graze and for growing their food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9030-3
  a curric:KeyLearningPoint ;
  rdfs:label """Replacing red meat with other proteins is not only good for the planet but also good for our health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9030-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plant-based proteins are healthy and can be grown and produced sustainably."@en ;
  dcterms:modified "2026-02-19T08:26:13.626706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9021-1
  a curric:KeyLearningPoint ;
  rdfs:label """Flooding occurs when an area of land is covered with water, especially from rain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9021-2
  a curric:KeyLearningPoint ;
  rdfs:label """Floods can cause damage to crops, when air cannot get the the roots and they rot."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9021-3
  a curric:KeyLearningPoint ;
  rdfs:label "Floods affect some parts of the world more than others."@en ;
  dcterms:modified "2026-02-19T08:26:13.626718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9021-4
  a curric:KeyLearningPoint ;
  rdfs:label "The air all around our planet is warming up, and warmer air can hold more water."@en ;
  dcterms:modified "2026-02-19T08:26:13.626722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9021-5
  a curric:KeyLearningPoint ;
  rdfs:label "The extra water in the air  falls as extra rain, and can cause flooding."@en ;
  dcterms:modified "2026-02-19T08:26:13.626726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1267-1
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain shows how living things depend on each other for food. The arrows in a food chain represent 'is food for'."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1267-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals do not make their own food. They need to hunt or find plants or other animals to eat to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1267-3
  a curric:KeyLearningPoint ;
  rdfs:label """Animals are called consumers in a food chain because they eat plants or other animals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1267-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first consumer in a food chain (primary consumer) can be a herbivore or an omnivore."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1267-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers are not arranged in order of importance, rather they all depend on each other for survival."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2666-1
  a curric:KeyLearningPoint ;
  rdfs:label "The basic elements of an electrical circuit are called components."@en ;
  dcterms:modified "2026-02-19T08:26:13.626857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2666-2
  a curric:KeyLearningPoint ;
  rdfs:label """A complete electrical circuit is made when all components are connected together correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2666-3
  a curric:KeyLearningPoint ;
  rdfs:label """A flow of electricity moves from the positive terminal to the negative terminal of the cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2666-4
  a curric:KeyLearningPoint ;
  rdfs:label """The flow of electricity is pushed by the cell or battery, through the wires to the other components in the circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2768-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to plan healthy meals to make sure that your body is getting the nutrients it needs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2768-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some processed food may have added salt, sugar and fat."@en ;
  dcterms:modified "2026-02-19T08:26:13.626877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2768-3
  a curric:KeyLearningPoint ;
  rdfs:label "Being able to make and cook healthy food is an important life skill."@en ;
  dcterms:modified "2026-02-19T08:26:13.626884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2768-4
  a curric:KeyLearningPoint ;
  rdfs:label "A nutrient-rich meal can be reviewed and improved."@en ;
  dcterms:modified "2026-02-19T08:26:13.626888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1284-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sound travels from an object through a medium to our ears."@en ;
  dcterms:modified "2026-02-19T08:26:13.626892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1284-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vibrations can be heard when travelling through some solids, such as taut string and cups."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1284-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use results to make simple conclusions and raise further questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.626902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1284-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vibrations travel through a solid medium more quickly. We can hear these sounds louder and more clearly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2776-1
  a curric:KeyLearningPoint ;
  rdfs:label """Muscles that are found close together on your body often help you to perform similar movements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2776-2
  a curric:KeyLearningPoint ;
  rdfs:label "Athletes focus their training on different muscles depending on their sport ."@en ;
  dcterms:modified "2026-02-19T08:26:13.626914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2776-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can improve the strength of their muscles through exercise, such as lifting weights."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2776-4
  a curric:KeyLearningPoint ;
  rdfs:label """A complete fitness circuit should aim to improve the strength of different muscles in the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1266-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants are living things that cannot move around to hunt for food. They must make their own food to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1266-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants use water, sunlight, and carbon dioxide to make a sugar that it can use as food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1266-3
  a curric:KeyLearningPoint ;
  rdfs:label "A food chain begins with a plant; this is the producer in the food chain."@en ;
  dcterms:modified "2026-02-19T08:26:13.626936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1266-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are called producers because they make, or produce, their own food."@en ;
  dcterms:modified "2026-02-19T08:26:13.626940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1265-1
  a curric:KeyLearningPoint ;
  rdfs:label "The basic needs of animals for survival are water, food and air."@en ;
  dcterms:modified "2026-02-19T08:26:13.627021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1265-2
  a curric:KeyLearningPoint ;
  rdfs:label "Animals need food from plants and other animals to survive."@en ;
  dcterms:modified "2026-02-19T08:26:13.627025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1265-3
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other for food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1265-4
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain can be drawn as a simple scientific diagram. The arrows represent 'is food for'."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1287-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials do not allow sound to pass through them easily. They are better at absorbing sound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1287-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials that are better at absorbing sound waves are called sound insulators."@en ;
  dcterms:modified "2026-02-19T08:26:13.627082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists carry out investigations to find out which materials are good sound insulators."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound insulators are often soft materials with empty spaces in them, so sound does not pass through them easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1287-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists and engineers use their knowledge of sound to design rooms and buildings to reduce the volume of sound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2670-1
  a curric:KeyLearningPoint ;
  rdfs:label "A variable is any one thing in an investigation which could be changed."@en ;
  dcterms:modified "2026-02-19T08:26:13.627166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2670-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding other components to the circuit may affect the brightness of a bulb."@en ;
  dcterms:modified "2026-02-19T08:26:13.627170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the position of the bulb in the circuit may affect how brightly it shines."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1255-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many plants have similar features that allow us to sort them into groups."@en ;
  dcterms:modified "2026-02-19T08:26:13.627178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1255-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can be grouped by their observable characteristics."@en ;
  dcterms:modified "2026-02-19T08:26:13.627182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1255-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observable characteristics can include information about colour, size, shape and structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1255-4
  a curric:KeyLearningPoint ;
  rdfs:label """The process of grouping plants based on their similarities and differences is called classification."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1255-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plants can be classified into categories such as flowering plants and non-flowering plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1256-1
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be classified based on their similarities and differences."@en ;
  dcterms:modified "2026-02-19T08:26:13.627217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1256-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can use a classification key to help decide which group something belongs to."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1256-3
  a curric:KeyLearningPoint ;
  rdfs:label """The questions on a classification key are layered, each answer leads to a new question."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use observable characteristics to identify unknown objects through a series of yes/no questions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1256-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use classification keys based on observable characteristics."@en ;
  dcterms:modified "2026-02-19T08:26:13.627237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3354-1
  a curric:KeyLearningPoint ;
  rdfs:label """If an animal is endangered, it may not be able to reproduce, and the species can become extinct"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3354-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many reasons that animals can become endangered, such as deforestation or changing climate"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3354-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can find out more about endangered animals by observing them and carrying out research"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3377-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohol is an addictive drug that can be found in drinks such as beer, cider and wine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohol changes a person's ability to think, speak, and see things as they really are."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3377-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohol can cause damage to your liver, heart and brain and cause illnesses including cancer and strokes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3377-4
  a curric:KeyLearningPoint ;
  rdfs:label """Information about the impact of alcohol on the body can be researched using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3362-1
  a curric:KeyLearningPoint ;
  rdfs:label "Life expectancy is the measure of how long a person is expected to live."@en ;
  dcterms:modified "2026-02-19T08:26:13.627292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3362-2
  a curric:KeyLearningPoint ;
  rdfs:label "Life expectancy varies worldwide and involves many factors."@en ;
  dcterms:modified "2026-02-19T08:26:13.627296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3362-3
  a curric:KeyLearningPoint ;
  rdfs:label """The average life expectancy in the UK is around 79 years for males and 83 years for females."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3362-4
  a curric:KeyLearningPoint ;
  rdfs:label "Life expectancy can be researched using secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.627303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3362-5
  a curric:KeyLearningPoint ;
  rdfs:label "Life expectancy can be plotted on a line graph to show changes over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.627307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3331-1
  a curric:KeyLearningPoint ;
  rdfs:label """A positive impact happens when changes help the environment and the living things within it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3331-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can take action to correct negative impacts, such as creating nature reserves among urban developments."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3331-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nature reserves are areas of natural land or water set aside for the protection of living things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3331-4
  a curric:KeyLearningPoint ;
  rdfs:label """Urban planners have designed new towns with areas of land and water set aside for the protection of living things."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3331-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nature reserves can help to restore areas that have been damaged by human activity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1259-1
  a curric:KeyLearningPoint ;
  rdfs:label "An environment is the surroundings of any living thing."@en ;
  dcterms:modified "2026-02-19T08:26:13.627418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1259-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different environments provide the requirements for the life and growth of the living things within them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1259-3
  a curric:KeyLearningPoint ;
  rdfs:label """Seasons are a natural pattern of change. Environments can change naturally as the seasons change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1259-4
  a curric:KeyLearningPoint ;
  rdfs:label "Seasonal changes to environments can be observed throughout the year."@en ;
  dcterms:modified "2026-02-19T08:26:13.627430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1259-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some living things need to make changes in order to survive in changing environments."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2604-1
  a curric:KeyLearningPoint ;
  rdfs:label "Birds are animals, they are living things that grow and reproduce"@en ;
  dcterms:modified "2026-02-19T08:26:13.627438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2604-2
  a curric:KeyLearningPoint ;
  rdfs:label "The life cycles of different birds can be observed over time and/or researched"@en ;
  dcterms:modified "2026-02-19T08:26:13.627442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2604-3
  a curric:KeyLearningPoint ;
  rdfs:label "Birds are hatched from eggs"@en ;
  dcterms:modified "2026-02-19T08:26:13.627446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2604-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a fledgling or juvenile bird has grown, it becomes a mature or adult bird"@en ;
  dcterms:modified "2026-02-19T08:26:13.627450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists communicate information about life cycles in interesting ways, including life cycle diagrams"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2612-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most types of flowering plant species are pollinated by animals including many we use as food sources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2612-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some crops grown in the UK rely on pollinators including apples, strawberries, raspberries and cucumbers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2612-3
  a curric:KeyLearningPoint ;
  rdfs:label """Habitat loss, often due to human development, can lead to a declining number of pollinators."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2612-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many pesticides can cause harm to pollinators."@en ;
  dcterms:modified "2026-02-19T08:26:13.627469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2612-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can research ways to help pollinators using secondary sources of information."@en ;
  dcterms:modified "2026-02-19T08:26:13.627475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gravity is an invisible pulling force that makes unsupported objects fall towards Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2621-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists in the past have helped us to understand and learn more about gravity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1243-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dietician is a scientist who studies food and advises people on their food and nutrition choices."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1243-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eating too much, or not enough, of certain types of food can be harmful to our health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1243-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information about amounts of food can be found by using secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1243-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Eatwell plate is a guide based on how much you should eat from each food group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2618-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adulthood, the period in a human’s life whereby full physical and intellectual maturity have been attained"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2618-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adulthood is commonly thought of as beginning at around 20 years"@en ;
  dcterms:modified "2026-02-19T08:26:13.627566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2618-3
  a curric:KeyLearningPoint ;
  rdfs:label """Physical changes in early adulthood include reaching full height and gaining muscle"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2618-4
  a curric:KeyLearningPoint ;
  rdfs:label "Middle age, a stage of adulthood, begins at around 40 years of age"@en ;
  dcterms:modified "2026-02-19T08:26:13.627576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2618-5
  a curric:KeyLearningPoint ;
  rdfs:label """The stages of human development in adulthood can be recorded in a variety of ways"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity and circuits are just about everywhere and a part of most of our daily lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1294-2
  a curric:KeyLearningPoint ;
  rdfs:label "The basic elements of an electrical circuit are called components."@en ;
  dcterms:modified "2026-02-19T08:26:13.627591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1294-3
  a curric:KeyLearningPoint ;
  rdfs:label "A simple electrical circuit has to have an electrical source, such as a battery."@en ;
  dcterms:modified "2026-02-19T08:26:13.627595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1294-4
  a curric:KeyLearningPoint ;
  rdfs:label """A simple electrical circuit has to have wires for the electricity to flow through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1294-5
  a curric:KeyLearningPoint ;
  rdfs:label """A simple electrical circuit has to have a device, such as a bulb, buzzer or motor, that requires electricity to work."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1212-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light source is something that produces and gives out light."@en ;
  dcterms:modified "2026-02-19T08:26:13.627607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1212-2
  a curric:KeyLearningPoint ;
  rdfs:label "Light sources can be natural or made by humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.627611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1212-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is our main natural light source."@en ;
  dcterms:modified "2026-02-19T08:26:13.627615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1212-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Moon is not a light source, it does not produce its own light."@en ;
  dcterms:modified "2026-02-19T08:26:13.627619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1254-1
  a curric:KeyLearningPoint ;
  rdfs:label """Although animals can be very different from each other many have similar features that allow us to put them into groups."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1254-2
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can be grouped by their observable characteristics."@en ;
  dcterms:modified "2026-02-19T08:26:13.627627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1254-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observable characteristics can include information about colour, size, shape and structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1254-4
  a curric:KeyLearningPoint ;
  rdfs:label """The process of grouping animals based on their similarities and differences is called classification."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1254-5
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be classified into mammals, reptiles, amphibians, fish and birds by observing body covering and structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1222-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pushes and pulls are forces"@en ;
  dcterms:modified "2026-02-19T08:26:13.627645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1222-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces are contact forces"@en ;
  dcterms:modified "2026-02-19T08:26:13.627649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1222-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contact forces are forces that act between two objects that are physically touching each other"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1222-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pushing a car up a hill and kicking a ball are examples of contact forces"@en ;
  dcterms:modified "2026-02-19T08:26:13.627659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3395-1
  a curric:KeyLearningPoint ;
  rdfs:label """Generating electricity by burning fossil fuels (coal, oil, or gas) produces greenhouse gases that trap the Sun's heat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3395-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are alternative ways of generating electricity that can be less harmful to the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3395-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity can be produced from sustainable sources that won’t run out, such as sunlight and wind."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3395-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hydroelectricity is a sustainable source that is generated by the power of moving water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3395-5
  a curric:KeyLearningPoint ;
  rdfs:label "Other sustainable sources of electricity are biomass and geothermal."@en ;
  dcterms:modified "2026-02-19T08:26:13.627684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1246-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fats in food, absorbed by paper, are easily visible and make it easy to identify which foods contain fats."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1246-2
  a curric:KeyLearningPoint ;
  rdfs:label """The size of greasy stains from food on paper can be observed and/or measured and compared."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1246-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often evaluate a completed investigation and suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.627696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1246-4
  a curric:KeyLearningPoint ;
  rdfs:label """The results of a scientific investigation can be compared to secondary sources that already exist."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2606-1
  a curric:KeyLearningPoint ;
  rdfs:label "Amphibians are animals, they are living things that grow and reproduce"@en ;
  dcterms:modified "2026-02-19T08:26:13.627703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2606-2
  a curric:KeyLearningPoint ;
  rdfs:label """Amphibians are usually hatched from eggs, then live under water before moving onto land"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2606-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most amphibians go through big changes (metamorphosis), but not all amphibians go through the same process"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2606-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific diagrams are used to show the stages in an amphibian’s life cycle"@en ;
  dcterms:modified "2026-02-19T08:26:13.627715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2606-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use simple language and images to help different audiences understand their results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.627719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3353-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gestation is the period of time that an animal carries its offspring inside its body before giving birth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3353-2
  a curric:KeyLearningPoint ;
  rdfs:label "Patterns can be found in the gestation periods of different animals."@en ;
  dcterms:modified "2026-02-19T08:26:13.627727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Larger animals tend to have longer gestation periods (as they tend to produce larger offspring)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can use patterns in their results to make predictions for further investigations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3353-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gestation periods of different animals can be found out by observing them or by carrying out research."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1292-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electricity is an essential part of modern life."@en ;
  dcterms:modified "2026-02-19T08:26:13.627745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1292-2
  a curric:KeyLearningPoint ;
  rdfs:label "An electric appliance is a device that uses electricity to perform a function."@en ;
  dcterms:modified "2026-02-19T08:26:13.627749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1292-3
  a curric:KeyLearningPoint ;
  rdfs:label """The first electrical appliances, such as the iron, kettle and light bulb, were invented in the 1800s."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1292-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some electrical appliances use batteries and some are powered by mains electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1292-5
  a curric:KeyLearningPoint ;
  rdfs:label "Appliances can be compared and sorted into different groups."@en ;
  dcterms:modified "2026-02-19T08:26:13.627760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1214-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun is always giving out light, but there are higher levels of ultraviolet light in the summer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1214-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UV index tells us how strong the Sun's damaging ultraviolet rays are."@en ;
  dcterms:modified "2026-02-19T08:26:13.627798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1214-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ultraviolet-sensitive beads change colour when exposed to UV light from the Sun."@en ;
  dcterms:modified "2026-02-19T08:26:13.627804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1214-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful observations should be made when comparing UV beads before and after they have been exposed to the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1214-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists often review a completed enquiry and write a conclusion."@en ;
  dcterms:modified "2026-02-19T08:26:13.627814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2758-1
  a curric:KeyLearningPoint ;
  rdfs:label """When light travels towards a surface and bounces off it, this is called reflected light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2758-2
  a curric:KeyLearningPoint ;
  rdfs:label """A data logger can be used to record the amount of light reflected from different surfaces in lux."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2758-3
  a curric:KeyLearningPoint ;
  rdfs:label """The results of an investigation can be recorded in a table and used to make decisions about different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2758-4
  a curric:KeyLearningPoint ;
  rdfs:label """The best surfaces for reflecting light are very smooth, such as a glass mirror or polished metal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2758-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists evaluate every stage of an investigation to suggest improvements."@en ;
  dcterms:modified "2026-02-19T08:26:13.627834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1262-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of teeth are shaped differently for different functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.630937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1262-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are mostly omnivores and therefore have different types of teeth for eating food from animals and plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.630941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1262-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of teeth can be used to eat the same piece of food."@en ;
  dcterms:modified "2026-02-19T08:26:13.630945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1262-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food can be classified according to which teeth are used to eat different foods, using sorting hoops and Venn diagrams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.630949Z"^^xsd:dateTime .

