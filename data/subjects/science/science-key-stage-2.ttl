# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-fledgling
  a curric:Keyword ;
  schema:name "fledgling"@en ;
  schema:description "a new, inexperienced or immature person or animal; a bird that has left the nest"@en ;
  dcterms:modified "2026-02-19T08:26:07.146502Z"^^xsd:dateTime .

oakcurric:keyword-climate
  a curric:Keyword ;
  schema:name "climate"@en ;
  schema:description """the average weather conditions (such as rainfall and temperature) recorded over a 30-year period"""@en ;
  dcterms:modified "2026-02-19T08:26:07.146678Z"^^xsd:dateTime .

oakcurric:keyword-nicotine
  a curric:Keyword ;
  schema:name "nicotine"@en ;
  schema:description "Highly addictive drug found in tobacco leaves."@en ;
  dcterms:modified "2026-02-19T08:26:07.146761Z"^^xsd:dateTime .

oakcurric:keyword-enquiry
  a curric:Keyword ;
  schema:name "enquiry"@en ;
  schema:description """a way of learning new information about a place by following a set course of activities or tasks"""@en ;
  dcterms:modified "2026-02-19T08:26:07.146900Z"^^xsd:dateTime .

oakcurric:keyword-drug
  a curric:Keyword ;
  schema:name "drug"@en ;
  schema:description """A drug is a medicine or other substances that has a physiological effect when introduced into the body."""@en ;
  dcterms:modified "2026-02-19T08:26:07.146913Z"^^xsd:dateTime .

oakcurric:keyword-illegal
  a curric:Keyword ;
  schema:name "illegal"@en ;
  schema:description "If something is illegal it is not allowed by the law."@en ;
  dcterms:modified "2026-02-19T08:26:07.146930Z"^^xsd:dateTime .

oakcurric:keyword-friction
  a curric:Keyword ;
  schema:name "friction"@en ;
  schema:description "Friction is the force of one surface gripping or rubbing on another."@en ;
  dcterms:modified "2026-02-19T08:26:07.147162Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description """A conclusion states what you found out in an experiment and explains how you know."""@en ;
  dcterms:modified "2026-02-19T08:26:07.147175Z"^^xsd:dateTime .

oakcurric:keyword-observe
  a curric:Keyword ;
  schema:name "observe"@en ;
  schema:description "To observe is to look very closely and use other senses too."@en ;
  dcterms:modified "2026-02-19T08:26:07.147280Z"^^xsd:dateTime .

oakcurric:keyword-prediction
  a curric:Keyword ;
  schema:name "prediction"@en ;
  schema:description "making a guess using what we already know"@en ;
  dcterms:modified "2026-02-19T08:26:07.147287Z"^^xsd:dateTime .

oakcurric:keyword-plot
  a curric:Keyword ;
  schema:name "plot"@en ;
  schema:description "what happens in the story"@en ;
  dcterms:modified "2026-02-19T08:26:07.147307Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description "to consider something carefully and make a judgement about it"@en ;
  dcterms:modified "2026-02-19T08:26:07.147405Z"^^xsd:dateTime .

oakcurric:keyword-generation
  a curric:Keyword ;
  schema:name "generation"@en ;
  schema:description """refers to people of about the same age: grandparents, parents and children are all different generations"""@en ;
  dcterms:modified "2026-02-19T08:26:07.147565Z"^^xsd:dateTime .

oakcurric:keyword-mixture
  a curric:Keyword ;
  schema:name "mixture"@en ;
  schema:description """A mixture is a material that contains two or more different substances that can be physically separated."""@en ;
  dcterms:modified "2026-02-19T08:26:07.147641Z"^^xsd:dateTime .

oakcurric:keyword-separate
  a curric:Keyword ;
  schema:name "separate"@en ;
  schema:description """In chemistry, to separate something is to extract and isolate a substance from a mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:07.147647Z"^^xsd:dateTime .

oakcurric:keyword-compare
  a curric:Keyword ;
  schema:name "Compare"@en ;
  schema:description """involves identifying similarities between two or more things, ideas, concepts or texts"""@en ;
  dcterms:modified "2026-02-19T08:26:07.147665Z"^^xsd:dateTime .

oakcurric:keyword-resilient
  a curric:Keyword ;
  schema:name "resilient"@en ;
  schema:description """being able to cope, withstand and recover from difficult physical or mental challenges"""@en ;
  dcterms:modified "2026-02-19T08:26:07.147674Z"^^xsd:dateTime .

oakcurric:keyword-challenge
  a curric:Keyword ;
  schema:name "challenge"@en ;
