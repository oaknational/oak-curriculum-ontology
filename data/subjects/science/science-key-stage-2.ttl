  schema:description """Drugs that have been prescribed by a doctor are safe for you to take if you follow the doctor’s instructions exactly."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183643Z"^^xsd:dateTime .

oakcurric:keyword-wild
  a curric:Keyword ;
  schema:name "wild"@en ;
  schema:description """Wild animals or plants live or grow in natural surroundings and are not looked after by people."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183648Z"^^xsd:dateTime .

oakcurric:keyword-adolescence
  a curric:Keyword ;
  schema:name "adolescence"@en ;
  schema:description """Adolescence is the stage of the human life cycle that occurs between childhood and adulthood."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183666Z"^^xsd:dateTime .

oakcurric:keyword-adolescent
  a curric:Keyword ;
  schema:name "adolescent"@en ;
  schema:description """An adolescent is a human in the process of developing from a child into an adult."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183670Z"^^xsd:dateTime .

oakcurric:keyword-researcher
  a curric:Keyword ;
  schema:name "researcher"@en ;
  schema:description """A researcher is someone who studies a subject, especially in order to discover new information or reach a new understanding."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183675Z"^^xsd:dateTime .

oakcurric:keyword-decibels
  a curric:Keyword ;
