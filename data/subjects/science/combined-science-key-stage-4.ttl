  vann:preferredNamespacePrefix "oakcurric" ; 
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/oakcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ,
