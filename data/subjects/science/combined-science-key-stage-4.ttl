  dcterms:modified "2026-02-19T08:26:07.163021Z"^^xsd:dateTime .

oakcurric:keyword-vernier-callipers
  a curric:Keyword ;
  schema:name "Vernier callipers"@en ;
  schema:description "A device used to measure length precisely."@en ;
  dcterms:modified "2026-02-19T08:26:07.163025Z"^^xsd:dateTime .

oakcurric:keyword-micrometer
  a curric:Keyword ;
  schema:name "micrometer"@en ;
  schema:description "A device to measure length to very high precision."@en ;
  dcterms:modified "2026-02-19T08:26:07.163030Z"^^xsd:dateTime .

oakcurric:keyword-sustainability
  a curric:Keyword ;
  schema:name "sustainability"@en ;
  schema:description """Sustainability means using resources wisely without depleting them for future generations."""@en ;
  dcterms:modified "2026-02-19T08:26:07.163488Z"^^xsd:dateTime .

oakcurric:keyword-glacier
  a curric:Keyword ;
  schema:name "glacier"@en ;
