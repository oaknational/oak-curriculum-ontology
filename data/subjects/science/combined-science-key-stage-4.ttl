  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cell cytoplasm and does not involve mitochondria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration transfers less energy than aerobic cellular respiration, but more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-5
  a curric:KeyLearningPoint ;
  rdfs:label "Uses of anaerobic cellular respiration (fermentation) in yeast."@en ;
