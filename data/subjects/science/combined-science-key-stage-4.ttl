  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.645870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.645874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.646967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.646972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the RFM of the reactants equals the sum of the RFM of the products, taking account of balancing coefficients."""@en ;
  dcterms:modified "2026-02-19T08:26:13.646976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.648582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.648586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-19T08:26:13.648590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-02-19T08:26:13.648594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-02-19T08:26:13.649393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-02-19T08:26:13.649397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-02-19T08:26:13.649401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the equation v² – u² = 2ax"""@en ;
  dcterms:modified "2026-02-19T08:26:13.649405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information provided."""@en ;
  dcterms:modified "2026-02-19T08:26:13.649409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-02-19T08:26:13.650878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-02-19T08:26:13.650883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in kinetic energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.650887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every atom of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.656046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus of the atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.656050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons in atoms of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.656056Z"^^xsd:dateTime .

