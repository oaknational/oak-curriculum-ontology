  dcterms:modified "2026-02-19T08:26:07.175365Z"^^xsd:dateTime .

oakcurric:keyword-decelerate
  a curric:Keyword ;
  schema:name "decelerate"@en ;
  schema:description "a decrease in the speed of an object"@en ;
  dcterms:modified "2026-02-19T08:26:07.175369Z"^^xsd:dateTime .

oakcurric:keyword-centripetal-force
