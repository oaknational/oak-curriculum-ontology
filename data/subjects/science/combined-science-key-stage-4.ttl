oakcurric:keylearningpoint-lesson-9929-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.635566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9929-3
  a curric:KeyLearningPoint ;
