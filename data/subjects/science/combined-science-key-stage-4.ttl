  schema:description "Reactants are the elements or compounds before a reaction takes place."@en ;
  dcterms:modified "2026-02-19T08:26:07.175312Z"^^xsd:dateTime .

oakcurric:keyword-mobile-phase
  a curric:Keyword ;
