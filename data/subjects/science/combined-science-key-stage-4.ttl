oakcurric:keylearningpoint-lesson-9186-4
  a curric:KeyLearningPoint ;
  rdfs:label """HIV as an example of a common sexually transmitted infection caused by a virus, and ways to prevent the spread."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533259Z"^^xsd:dateTime .

