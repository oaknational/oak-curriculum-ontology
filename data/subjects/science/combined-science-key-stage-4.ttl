  dcterms:modified "2026-02-19T08:26:07.177516Z"^^xsd:dateTime .

oakcurric:keyword-proton
  a curric:Keyword ;
  schema:name "proton"@en ;
  schema:description """A subatomic particle found in the nucleus with a relative mass of 1 and a positive charge (+1)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.177523Z"^^xsd:dateTime .

oakcurric:keyword-neutron
  a curric:Keyword ;
