oakcurric:keylearningpoint-lesson-9929-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation Ek = ½ mv²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.635576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9930-1
