  dcterms:modified "2026-02-19T08:26:07.178810Z"^^xsd:dateTime .

oakcurric:keyword-renewable-resources
  a curric:Keyword ;
  schema:name "renewable resources"@en ;
  schema:description """an energy resource that can be replenished as quickly as it is used so will not run out"""@en ;
  dcterms:modified "2026-02-19T08:26:07.178952Z"^^xsd:dateTime .

oakcurric:keyword-renewable-energy-resource
  a curric:Keyword ;
  schema:name "renewable energy resource"@en ;
  schema:description """an energy resource that can be replenished as quickly as it is used or will not run out"""@en ;
  dcterms:modified "2026-02-19T08:26:07.178961Z"^^xsd:dateTime .

oakcurric:keyword-non-renewable-energy-resource
  a curric:Keyword ;
  schema:name "non-renewable energy resource"@en ;
  schema:description """an energy resource that cannot be replenished as quickly as it is used and will eventually run out"""@en ;
  dcterms:modified "2026-02-19T08:26:07.178965Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-energy
  a curric:Keyword ;
  schema:name "sustainable energy"@en ;
  schema:description """using energy resources so that, in the future, there will be enough for people's needs"""@en ;
  dcterms:modified "2026-02-19T08:26:07.178969Z"^^xsd:dateTime .

oakcurric:keyword-reversible-reaction
  a curric:Keyword ;
  schema:name "reversible reaction"@en ;
  schema:description """A chemical reaction where the reactants form products that, in turn, react together to reform the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:07.178987Z"^^xsd:dateTime .

oakcurric:keyword-hydrated-salt
  a curric:Keyword ;
  schema:name "hydrated (salt)"@en ;
