  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.572069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-02-19T08:26:13.572077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.572083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-1
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is ordered by increasing atomic number (proton number)."@en ;
  dcterms:modified "2026-02-19T08:26:13.572087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-2
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is split into periods and groups."@en ;
  dcterms:modified "2026-02-19T08:26:13.572091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-3
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an element in the periodic table is linked to its atomic number and the arrangement of its electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elements can be classed as metals or non-metals according to their position on the periodic table."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-5
  a curric:KeyLearningPoint ;
  rdfs:label "A useful model for atoms arranges electrons in shells around the nucleus."@en ;
  dcterms:modified "2026-02-19T08:26:13.572105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-1
  a curric:KeyLearningPoint ;
  rdfs:label """After exposure to a pathogen, memory cells remain in the body to provide immunity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccination creates immunity by injecting a small amount of a dead or inactivated pathogen in a vaccine into the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-3
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells mount an immune response by producing antibodies against the pathogen in the vaccine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the white blood cells stay in the body as memory cells to provide immunity to the pathogen in the vaccine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-5
  a curric:KeyLearningPoint ;
  rdfs:label """Upon reinfection by the pathogen, memory cells respond by rapidly making antibodies against the pathogen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-1
  a curric:KeyLearningPoint ;
  rdfs:label "The water cycle shows how water is recycled on planet Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.572733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water is continuously being evaporated and precipitated."@en ;
  dcterms:modified "2026-02-19T08:26:13.572737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants lose water through transpiration."@en ;
  dcterms:modified "2026-02-19T08:26:13.572741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water availability impacts upon a species' ability to survive in a habitat."@en ;
  dcterms:modified "2026-02-19T08:26:13.572745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.573143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.573148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object"@en ;
  dcterms:modified "2026-02-19T08:26:13.573160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a vector diagram"""@en ;
  dcterms:modified "2026-02-19T08:26:13.573164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of these forces"""@en ;
  dcterms:modified "2026-02-19T08:26:13.573168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single force can be resolved into two components acting at right angles to each other"""@en ;
  dcterms:modified "2026-02-19T08:26:13.573172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-5
  a curric:KeyLearningPoint ;
  rdfs:label "The two component forces together have the same effect as the single force"@en ;
  dcterms:modified "2026-02-19T08:26:13.573176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need to be applied to find a second."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in  I = V ÷ R is shown for a component, circuit rules need to be applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.573658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a type of biological molecule called a nucleic acid."@en ;
  dcterms:modified "2026-02-19T08:26:13.573683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-2
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is made of two strands, each a long polymer of nucleotides."@en ;
  dcterms:modified "2026-02-19T08:26:13.573689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-3
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-02-19T08:26:13.573693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-4
  a curric:KeyLearningPoint ;
  rdfs:label "The two strands in DNA are wound together in a double helix shape."@en ;
  dcterms:modified "2026-02-19T08:26:13.573697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-5
  a curric:KeyLearningPoint ;
  rdfs:label "Making a physical, representational model of DNA."@en ;
  dcterms:modified "2026-02-19T08:26:13.573703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.574099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.574103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-19T08:26:13.574107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-19T08:26:13.574111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-19T08:26:13.574115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data to calculate the volume of gas collected in the measuring cylinder, and the mean of repeat measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate the rate of respiration by dividing the volume of gas collected in the measuring cylinder by the time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use appropriate units for the rate of cellular respiration."@en ;
  dcterms:modified "2026-02-19T08:26:13.574149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Compare the rate of respiration in yeast given different substrates, and describe trends in the data."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use ideas about enzymes and active sites to explain the effect of different substrates on the rate of respiration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from another organism."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-02-19T08:26:13.574168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.574173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical questions."@en ;
  dcterms:modified "2026-02-19T08:26:13.574178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone adrenaline is secreted by the adrenal gland during stress; it causes the body to prepare for rapid action."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone thyroxine is secreted by the thyroid gland; it controls growth and the rates of chemical reactions in cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pituitary gland secretes hormones that can control other glands."@en ;
  dcterms:modified "2026-02-19T08:26:13.574190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pituitary gland secretes TSH, which causes the thyroid gland to secrete thyroxine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thyroxine causes the pituitary gland to stop secreting TSH; this is an example of negative feedback."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-19T08:26:13.574646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time period."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat readings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or product made) per unit of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme rate decreases as temperature increases above the optimum as bonds break and the active site becomes denatured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature on enzyme reaction rate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.575648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.575652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-19T08:26:13.575656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-19T08:26:13.575660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-19T08:26:13.575666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules), giant covalent, ionic and metallic"""@en ;
  dcterms:modified "2026-02-19T08:26:13.576010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it can only hold 2 electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-02-19T08:26:13.576024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or anions, respectively."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-19T08:26:13.576380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is stretched, by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-02-19T08:26:13.577554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of that element measured in grams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.578784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.578788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-19T08:26:13.578791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-19T08:26:13.578795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-19T08:26:13.578801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.579194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.579198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.579202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-02-19T08:26:13.579206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.579210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe plant root hair cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.579902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.579908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.579912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line drawing."""@en ;
  dcterms:modified "2026-02-19T08:26:13.579918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-5
  a curric:KeyLearningPoint ;
  rdfs:label """Total magnification = magnification of the eyepiece lens × magnification of the objective lens"""@en ;
  dcterms:modified "2026-02-19T08:26:13.579923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-1
  a curric:KeyLearningPoint ;
  rdfs:label """All the atoms in the reactants of a chemical reaction are reorganised to form all the products of the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-2
  a curric:KeyLearningPoint ;
  rdfs:label """There must be an equal number of each type of atom on both the reactant and product side of the equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical formulae cannot be altered to balance a reaction equation; only coefficients can change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms cannot be created or destroyed. During a chemical reaction, atoms are simply rearranged into products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a fair test, only the (independent) variable being investigated is changed"@en ;
  dcterms:modified "2026-02-19T08:26:13.583539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dependent variable is measured to investigate the effect of changing the independent variable"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are other factors that could be changed, but are kept the same in order not to affect the results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the intensity of black ink, the more easily a surface absorbs infrared"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.583691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.583699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon monoxide gas is toxic."@en ;
  dcterms:modified "2026-02-19T08:26:13.583898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon particulates contribute to health issues and global dimming."@en ;
  dcterms:modified "2026-02-19T08:26:13.583903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfur dioxide and nitrogen oxides are formed through burning fuels, and form acids in water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-4
  a curric:KeyLearningPoint ;
  rdfs:label """Catalytic converters help complete combustion reactions and the removal of nitrogen monoxide from exhaust gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen can be used as a fuel in cars and this has advantages and disadvantages."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data can be analysed to assess the purity of water samples containing dissolved solids."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation set-ups can be used to collect dissolved solids from a water sample."@en ;
  dcterms:modified "2026-02-19T08:26:13.583956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes usually occur near to the edges of tectonic plates"@en ;
  dcterms:modified "2026-02-19T08:26:13.583960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-2
  a curric:KeyLearningPoint ;
  rdfs:label """P waves and S waves are produced deep underground where tectonic plates slip and cause vibrations in rock"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-3
  a curric:KeyLearningPoint ;
  rdfs:label "P waves are longitudinal waves and travel through liquid"@en ;
  dcterms:modified "2026-02-19T08:26:13.583970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-4
  a curric:KeyLearningPoint ;
  rdfs:label """S waves are transverse waves and cannot travel through liquid layers inside Earth"""@en ;
  dcterms:modified "2026-02-19T08:26:13.583975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-5
  a curric:KeyLearningPoint ;
  rdfs:label "P waves and S waves provide evidence for the internal structure of Earth"@en ;
  dcterms:modified "2026-02-19T08:26:13.583979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive contamination is the presence of unwanted radioactive atoms."@en ;
  dcterms:modified "2026-02-19T08:26:13.583999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-2
  a curric:KeyLearningPoint ;
  rdfs:label """A material being exposed to iodising radiation is being irradiated and does not become radioactive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-1
  a curric:KeyLearningPoint ;
  rdfs:label """A random error is a chance difference between an observed value and the true value."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Random errors can be caused by mistakes in taking readings, or by taking a reading at the wrong time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-3
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a melting solid does not change as it heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.584296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-4
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a boiling liquid does not change as it is heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.584302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.584525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all suggested atomic models."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom and the nuclear model are two important models in the history of the atom's discovery"""@en ;
  dcterms:modified "2026-02-19T08:26:13.584533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-02-19T08:26:13.584539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric and magnetic fields."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more than red as it slows more in glass."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio, microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact differently with different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature generally increases rate by boosting the energy and frequency of collisions between particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cooling a reactant decreases its reaction rate by reducing collision energy and frequency."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-1
  a curric:KeyLearningPoint ;
  rdfs:label """An experiment can be planned to measure the temperature change through continuous heating of a substance"""@en ;
  dcterms:modified "2026-02-19T08:26:13.584594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is needed to overcome forces of attraction between particles so temperature does not change when changing state"""@en ;
  dcterms:modified "2026-02-19T08:26:13.584598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-3
  a curric:KeyLearningPoint ;
  rdfs:label """The change in state of pure substances can be seen on a heating/cooling curve as a horizontal line"""@en ;
  dcterms:modified "2026-02-19T08:26:13.584602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is a change of energy, arrangement, and organisation of particles of a pure substance at each stage"""@en ;
  dcterms:modified "2026-02-19T08:26:13.584606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-1
  a curric:KeyLearningPoint ;
  rdfs:label """A reaction profile compares the amount of energy the products of a reaction have compared to the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exothermic chemical reactions transfer energy from reactants to the surroundings causing an increase in temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Endothermic chemical reactions transfer energy from the surroundings to the products causing a decrease in temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Activation energy is the minimum amount of energy transferred to reactants that allows a chemical reaction to start."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-02-19T08:26:13.584665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated similar properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into groups of similar properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were later found."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by atomic weight was not always correct."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant health can be affected by pathogens."@en ;
  dcterms:modified "2026-02-19T08:26:13.584684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chalara ash dieback is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-19T08:26:13.584689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-4
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of ash dieback on biodiversity, including through habitat destruction."@en ;
  dcterms:modified "2026-02-19T08:26:13.584699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Salts form ionic structures because they contain metal and non-metal ions."@en ;
  dcterms:modified "2026-02-19T08:26:13.584703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-2
  a curric:KeyLearningPoint ;
  rdfs:label """In an ionic structure each positive ion attracts the negative ions and vice-versa."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metal ions attract all non-metal ions and vice-versa, they bond to the opposite charged ions that are closest."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-4
  a curric:KeyLearningPoint ;
  rdfs:label """An ionic bond is the electrostatic force of attraction between oppositely-charged ions acting in all directions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic substances are 3D lattices with regular arrangements of ions ( in a repeating pattern of +ve and -ve charge)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring volume of gas produced throughout a reaction allows the changing rate of reaction to be calculated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring volumes of gas over time include timing, reading volumes in real time and gas displaced by the bung."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring an end-point in a reaction allows direct and simple comparison of reaction rates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-4
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring end-points include subjectivity of observations, measuring times and volumes, and contamination."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive decay is a random process."@en ;
  dcterms:modified "2026-02-19T08:26:13.584796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to predict the moment that a particular unstable nucleus will decay."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to predict how long it will take for half of a sample of a radioactive isotope to decay."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive half-life is the time taken for half of a radioactive isotope to decay (or for its activity to halve)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each radioactive isotope has its own half-life that is always the same."@en ;
  dcterms:modified "2026-02-19T08:26:13.584812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different types of bonding (covalent, ionic, metallic)."@en ;
  dcterms:modified "2026-02-19T08:26:13.584928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are only two types of structure (simple and giant)."@en ;
  dcterms:modified "2026-02-19T08:26:13.584932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-3
  a curric:KeyLearningPoint ;
  rdfs:label "The type of bonding and structure are what lead to properties of substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.584936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting/boiling points are linked to intermolecular forces (simple) and bond strength (giant)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conductivity is linked to whether there are free moving charge carriers."@en ;
  dcterms:modified "2026-02-19T08:26:13.584946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals that are made and secreted by groups of specialised cells called glands."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are transported around the body in the blood plasma, and detected by receptors on cells and tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-3
  a curric:KeyLearningPoint ;
  rdfs:label """During puberty, hormones cause maturation of the sex organs and development of secondary sexual characteristics."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones control the menstrual cycle in adult human females, by causing ovulation and menstruation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-5
  a curric:KeyLearningPoint ;
  rdfs:label """Decreases in hormone levels in older human females cause the menopause, after which the menstrual cycle stops."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis involves the decomposition / break-down of a substance by passing an electric current."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of positive ions are in competition at the negative electrode"@en ;
  dcterms:modified "2026-02-19T08:26:13.585453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of negative ions are in competition at the positive electrode"@en ;
  dcterms:modified "2026-02-19T08:26:13.585457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode"@en ;
  dcterms:modified "2026-02-19T08:26:13.585461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested"@en ;
  dcterms:modified "2026-02-19T08:26:13.585465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from another organism."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-02-19T08:26:13.585510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.585514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical issues."@en ;
  dcterms:modified "2026-02-19T08:26:13.585518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main steps in the process of genetic engineering."@en ;
  dcterms:modified "2026-02-19T08:26:13.585522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-1
  a curric:KeyLearningPoint ;
  rdfs:label "Infertility is the inability to become pregnant (conceive)."@en ;
  dcterms:modified "2026-02-19T08:26:13.585525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-2
  a curric:KeyLearningPoint ;
  rdfs:label """In adult human females, some types of infertility are caused by problems with hormones that control the menstrual cycle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hormones can be used as a treatment for these types of infertility."@en ;
  dcterms:modified "2026-02-19T08:26:13.585533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of hormones in IVF treatment."@en ;
  dcterms:modified "2026-02-19T08:26:13.585538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement reactions involve a more reactive element replacing another in a compound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-02-19T08:26:13.585735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to calculate energy change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hypotheses guide predictions about the effect of variables in experiments."@en ;
  dcterms:modified "2026-02-19T08:26:13.585745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts can visually represent collected results to help analyse data."@en ;
  dcterms:modified "2026-02-19T08:26:13.585750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars, amino acids and other organic substances (nutrients) are transported in phloem."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-2
  a curric:KeyLearningPoint ;
  rdfs:label "Translocation starts at a source, such as a leaf where sugars are made."@en ;
  dcterms:modified "2026-02-19T08:26:13.585788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported into phloem by active transport across the membranes of the living phloem cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water moves into the phloem cells by osmosis, which increases the pressure and pushes the sugars along the phloem tube."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported out of the phloem by active transport at a sink, such as a developing root, stem or flower."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base is a substance that neutralises an acid to make salt and water only (this is a neutralisation reaction)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroxides are generally soluble bases (they contain OH⁻ ions)."@en ;
  dcterms:modified "2026-02-19T08:26:13.585810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases that are generally insoluble."@en ;
  dcterms:modified "2026-02-19T08:26:13.585815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides are soluble and form acidic solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.585819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Purification of copper involves using copper electrodes in an electrolyte."@en ;
  dcterms:modified "2026-02-19T08:26:13.585839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The electrolyte must contain the same ions, in solution,  as the metal being purified by electrolysis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring the mass change in the copper electrodes demonstrates the transfer of copper."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-4
  a curric:KeyLearningPoint ;
  rdfs:label """Impurities in the anode do not transfer to the cathode, leading to pure copper deposition."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other uses for this technique include electroplating, where you would use multiple metals e.g. gold."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many sources of wastewater and each introduces different types of contaminants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are sequential steps involved in making wastewater safe before disposal into the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple types of waste need to be removed from different kinds of wastewater."@en ;
  dcterms:modified "2026-02-19T08:26:13.585870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Releasing untreated wastewater into the environment could impact an ecosystem's health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sludge can be anaerobically treated, producing materials that can be used as a fertiliser or fuel."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple particle model explains melting, boiling, freezing, and condensing processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Boiling is when a liquid becomes a gas throughout, forming bubbles. Condensation is when gas turns into liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Melting is when a solid turns into a liquid with added energy. Freezing is the reverse: liquid to solid, losing energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particles remain the same size and shape as they do not have bulk properties like melting and boiling points."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil have different properties and uses, affecting the demand for these molecules."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-2
  a curric:KeyLearningPoint ;
  rdfs:label """Larger hydrocarbons can be broken down (cracked) to produce smaller, more useful molecules."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cracking can be done by various methods including catalytic cracking and steam cracking."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-4
  a curric:KeyLearningPoint ;
  rdfs:label """The products of cracking include alkanes and alkenes, which have a double bond between two carbon atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bromine water changes from orange/brown to colourless in the presence of an alkene."""@en ;
  dcterms:modified "2026-02-19T08:26:13.585953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practical demonstration of the use of a simple potometer to measure water uptake by a leafy shoot."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of a light source to vary light intensity."@en ;
  dcterms:modified "2026-02-19T08:26:13.586034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of appropriate apparatus to control temperature (e.g. a water tank as a heat shield between light and plant)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of a simple potometer to measure water uptake by a plant at a range of light intensities."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of water uptake = change in volume of water ÷ time taken for volume to change"""@en ;
  dcterms:modified "2026-02-19T08:26:13.586049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of volume of gas produced against time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid, the same volume of gas is produced for equal amounts of magnesium."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-3
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling the concentration doubles the rate of reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.586095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction the desired product needs to be continuously removed from the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Natural gas is a feedstock for industrial production of ammonia."@en ;
  dcterms:modified "2026-02-19T08:26:13.586148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen, one of the raw materials in ammonia production, is produced from natural gas and steam."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-4
  a curric:KeyLearningPoint ;
  rdfs:label """In industry, the Haber process is typically performed at 150-300 atmospheres, 400-450°C, with an iron catalyst."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia production is energy-intensive and releases large amounts of carbon dioxide, contributing to global emissions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms are the building blocks that can be combined in different ways to form different substances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible for any atom to be changed into a different type of atom by a chemical reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-3
  a curric:KeyLearningPoint ;
  rdfs:label """All of the atoms in the reactants of a chemical reaction are reorganised to form all of the products of the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to make a particular product without all the atoms that it needs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-5
  a curric:KeyLearningPoint ;
  rdfs:label """The law of conservation of mass can be applied to a closed system, or a non-enclosed system that takes in/gives out gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatography has two phases, stationary and mobile, and separation depends on the distribution between these phases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-2
  a curric:KeyLearningPoint ;
  rdfs:label "Both aqueous and non-aqueous solvents can be used in chromatography."@en ;
  dcterms:modified "2026-02-19T08:26:13.586385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.586389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation is the change from solid to gas; deposition is the change from gas to solid, both bypass the liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation and deposition occur at specific conditions of temperature and pressure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy changes in sublimation/deposition are similar to melting/freezing but happen directly between solid and gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaporation is when a liquid changes to gas at the surface as particles gain enough energy to overcome forces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a"@en ;
  dcterms:modified "2026-02-19T08:26:13.586450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through"@en ;
  dcterms:modified "2026-02-19T08:26:13.586551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave does not depend on its frequency"@en ;
  dcterms:modified "2026-02-19T08:26:13.586555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-3
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength"@en ;
  dcterms:modified "2026-02-19T08:26:13.586559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the longer the wavelength, the lower the frequency"@en ;
  dcterms:modified "2026-02-19T08:26:13.586563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wave speed = frequency x wavelength"@en ;
  dcterms:modified "2026-02-19T08:26:13.586567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-1
  a curric:KeyLearningPoint ;
  rdfs:label """A single resultant force has the same effect as several forces acting on an object"""@en ;
  dcterms:modified "2026-02-19T08:26:13.586571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is no resultant force on an object, it remains still or continues to move at a steady speed in a straight line"""@en ;
  dcterms:modified "2026-02-19T08:26:13.586575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is a resultant force on an object, it will accelerate in the direction of the force"""@en ;
  dcterms:modified "2026-02-19T08:26:13.586579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-4
  a curric:KeyLearningPoint ;
  rdfs:label """A resultant force acting in the opposite direction to movement will decelerate (slow down) an object"""@en ;
  dcterms:modified "2026-02-19T08:26:13.586583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-02-19T08:26:13.586610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a vector diagram."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of these forces."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.586624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-19T08:26:13.586632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-5
  a curric:KeyLearningPoint ;
  rdfs:label """Motion in a circle involves a centripetal force which constantly changes the velocity of an object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation separates a soluble substance from its solvent based on differences in boiling points."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-2
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation requires multiple pieces of apparatus which work in conjunction with each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-3
  a curric:KeyLearningPoint ;
  rdfs:label """The processes of boiling and condensing are involved in the process of distillation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-4
  a curric:KeyLearningPoint ;
  rdfs:label """Simple distillation is used primarily to separate mixtures of only two components."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-1
  a curric:KeyLearningPoint ;
  rdfs:label "Growth is part of the life cycle of all living organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.586661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms grow by making new cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.586665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms need to repair tissue through cell division."@en ;
  dcterms:modified "2026-02-19T08:26:13.586669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-4
  a curric:KeyLearningPoint ;
  rdfs:label """All new cells are made when existing cells copy their genetic material and then divide in two."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-1
  a curric:KeyLearningPoint ;
  rdfs:label "Metals are good electrical conductors and good thermal conductors."@en ;
  dcterms:modified "2026-02-19T08:26:13.586677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metals can be stretched into wires, or bent/hammered into different shapes."@en ;
  dcterms:modified "2026-02-19T08:26:13.586681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Individual atoms do not have the physical properties of the substances that contain them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metallic structures consist of positive ions and free–moving outer shell electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electrostatic forces of attraction between ions and free electrons bind them all together in a giant metallic structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-1
  a curric:KeyLearningPoint ;
  rdfs:label """The energy needed to break bonds and the energy released when bonds are formed can be calculated from bond energies."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the energy needed to break bonds and the energy released is the overall energy change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-1
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in heat energy accompany salts dissolving in water."@en ;
  dcterms:modified "2026-02-19T08:26:13.586796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in heat energy accompany neutralisation, displacement and precipitation reactions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic and endothermic reactions have everyday uses."@en ;
  dcterms:modified "2026-02-19T08:26:13.586804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reactions take place in solution, temperature changes can be measured to reflect the energy changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paper, thin layer (TLC), and gas chromatography (GC) can all distinguish between pure and impure substances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatographic processes use a mobile and stationary phase. TLC and GC both use silica/alumina as a stationary phase."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thin layer chromatography (TLC) uses locating agents to develop chromatograms and aid analysis of them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms from gas chromatography (GC) also provide details about the amount of each component in a sample."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-5
  a curric:KeyLearningPoint ;
  rdfs:label """Retention factors (Rf) and retention times both provide quantitative information about a sample's components."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-1
  a curric:KeyLearningPoint ;
  rdfs:label """The faster the particles of a substance are vibrating or moving, the higher the substance's temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-2
  a curric:KeyLearningPoint ;
  rdfs:label """In solids, energy is transferred by vibrating particles colliding with nearby particles, causing them to vibrate more."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good conductors as their free electrons move through them more quickly when heated and transfer energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal conductors can feel cold because they transfer energy quickly away from their surface."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal insulators can feel warm because they do not transfer energy quickly from their surface."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-time graph of a wave is a representation of a wave."@en ;
  dcterms:modified "2026-02-19T08:26:13.587304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-2
  a curric:KeyLearningPoint ;
  rdfs:label """A displacement-time graph of a wave shows how the displacement at one point varies as the wave passes"""@en ;
  dcterms:modified "2026-02-19T08:26:13.587312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-time graph is equal to the period of the wave"""@en ;
  dcterms:modified "2026-02-19T08:26:13.587316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-4
  a curric:KeyLearningPoint ;
  rdfs:label "The period of a wave, T, is equal to the time of one complete oscillation"@en ;
  dcterms:modified "2026-02-19T08:26:13.587320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-5
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency is equal to 1 / period"@en ;
  dcterms:modified "2026-02-19T08:26:13.587324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-1
  a curric:KeyLearningPoint ;
  rdfs:label """The reaction between sodium thiosulfate solution and hydrochloric acid produces a cloudy precipitate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, each reaction has produced the same amount of product."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, the chemical reaction may not be complete."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most chemical reactions start more quickly and slow down as they progress."@en ;
  dcterms:modified "2026-02-19T08:26:13.587366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a chemical reaction is equal to the amount of product formed per unit time (or reactant used per unit time)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mean rate of a chemical reaction is different to the instantaneous rate that changes throughout the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphs of mass, volume, or concentration vs. time can all represent the changing rate of a chemical reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the correct equipment is crucial for obtaining accurate and reliable results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-2
  a curric:KeyLearningPoint ;
  rdfs:label """An upturned measuring cylinder is suitable for reactions producing large volumes of gas at moderate rates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gas syringes are ideal for measuring small volumes of gas with high precision."@en ;
  dcterms:modified "2026-02-19T08:26:13.587416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of the measuring equipment should be close to the expected volume of gas produced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Light sensors can be used to measure the percentage of light transmitted through a reaction producing a precipitate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some mutations cause genetic variants that cause advantageous adaptations in phenotype."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-2
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals with these genetic variants are better adapted to compete, survive, reproduce and pass them on to offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes advantageous genetic variants to become more common in the population over generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-4
  a curric:KeyLearningPoint ;
  rdfs:label """This causes advantageous adaptations in phenotype to become more common in the population over generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-5
  a curric:KeyLearningPoint ;
  rdfs:label """Examples explained at the genetic level using ideas about mutation, genetic variants and natural selection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles affect health (e.g. increase the risk of non-communicable diseases or adverse reactions to treatments)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-2
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic testing and genome sequencing can identify the presence of these alleles in a person’s genome."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-3
  a curric:KeyLearningPoint ;
  rdfs:label """Healthcare can be personalised and lifestyle changes can be implemented to decrease risk and improve health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-4
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic test data could be misused, and its use must be regulated."@en ;
  dcterms:modified "2026-02-19T08:26:13.587477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-1
  a curric:KeyLearningPoint ;
  rdfs:label """To find standing wave frequencies, increase the frequency of the oscillator until a standing wave pattern is seen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wavelength of the waves can be found from the length of the oscillating string and the standing wave pattern"""@en ;
  dcterms:modified "2026-02-19T08:26:13.587606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of waves on a string only depends on the properties of the wave medium (the string)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-4
  a curric:KeyLearningPoint ;
  rdfs:label "For waves on a string, frequency and wavelength are inversely proportional"@en ;
  dcterms:modified "2026-02-19T08:26:13.587614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-5
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are the quantities that must be kept the same during experiments so they don’t affect results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.587891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.587899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field strength × change in height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.587903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the device)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.587915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human hearing involves the transmission of sound waves through different parts of the ear."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wave transmission to a new medium can be limited by the wave amplitude or the wave frequency."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-3
  a curric:KeyLearningPoint ;
  rdfs:label """The range of human hearing is 20 Hz to 20 000 Hz. Frequencies above and below this are called ultrasound and infrasound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-4
  a curric:KeyLearningPoint ;
  rdfs:label """The highest frequency you can hear reduces with age as cells of the cochlea and auditory nerve become damaged over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-1
  a curric:KeyLearningPoint ;
  rdfs:label """In diamond each carbon atom is bonded to four others with strong covalent bonds to form a giant covalent structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct electricity (makes it good for cutting tools)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-3
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite, each carbon atom is covalently bonded to three others to form layers of hexagonal rings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are only weak forces between the layers in graphite which can easily be rubbed apart (makes it a good lubricant)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-5
  a curric:KeyLearningPoint ;
  rdfs:label """Graphite conducts electricity because it has delocalised electrons which can move and carry charge/current."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing average global temperatures leads to an increase in sea levels."@en ;
  dcterms:modified "2026-02-19T08:26:13.588304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures cause more powerful convection currents, increasing the number and severity of storms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures can affect atmospheric air streams and change weather patterns."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes of human behaviour can lead to smaller increases in global temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.588315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate engineering may enable humans to reduce global temperatures through the application of technologies."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the lab."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density and particles is fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-02-19T08:26:13.588594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce uncertainty."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation in phenotype is caused only by the environment and is not heritable."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused by genetic material; this can be passed on to offspring via gametes or asexual reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the sequence of bases in an organism's DNA is called a mutation and creates a genetic variant."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations happen at random (caused by carcinogens, or by ionising radiation, or by errors when DNA is copied)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most mutations have no effect on phenotype, some influence phenotype, and a few determine phenotype."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of a solution is the mass of solute dissolved in 1 dm³ of distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more solute that is dissolved, the more concentrated the solution."@en ;
  dcterms:modified "2026-02-19T08:26:13.588681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solutions can be diluted (i.e. made less concentrated) by increasing the volume of distilled water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-4
  a curric:KeyLearningPoint ;
  rdfs:label """Diluting solutions with distilled water ensures no other substances are present in the solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-02-19T08:26:13.588695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three states of matter: solid state, liquid state, and gas state."@en ;
  dcterms:modified "2026-02-19T08:26:13.588700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-2
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas state can be compressed because there is empty space between the particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-3
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the liquid or solid state cannot be compressed because the particles are already touching."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-4
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas or liquid state has no fixed shape as the particles can move past each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-5
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the solid state will not flow because the particles vibrate in a fixed position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation is an extension of simple distillation, and is mostly used to separate mixtures of liquids."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-2
  a curric:KeyLearningPoint ;
  rdfs:label """A main distinction between fractional and simple distillation is that the former uses a fractionating column."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation has multiple real-world examples, including the fractional distillation of air."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation produces fractions; these can be pure or mixtures of chemicals with very similar boiling points."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid ionic compound cannot conduct electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.589339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are ionic compounds which can be electrolysed when they are in the molten state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gases may be formed at the electrodes."@en ;
  dcterms:modified "2026-02-19T08:26:13.589347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-4
  a curric:KeyLearningPoint ;
  rdfs:label "Freely moving ions can reach the electrodes and undergo oxidation or reduction."@en ;
  dcterms:modified "2026-02-19T08:26:13.589352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-5
  a curric:KeyLearningPoint ;
  rdfs:label """A non-metal always forms at the positive electrode, and a metal forms at the negative electrode."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-1
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.589359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-2
  a curric:KeyLearningPoint ;
  rdfs:label """The method for using a light microscope to observe xylem and phloem, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light microscopy can be used to observe xylem and phloem in a cross-section of a plant shoot, root or leaf."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-4
  a curric:KeyLearningPoint ;
  rdfs:label """The magnification and actual size of structures observed with a microscope can be calculated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Background radiation is caused by unstable nuclei that are around us all of the time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are very small with a radius of about 1 × 10⁻¹⁰ m."@en ;
  dcterms:modified "2026-02-19T08:26:13.589446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-3
  a curric:KeyLearningPoint ;
  rdfs:label """The alpha particle scattering experiment (Rutherford, 1909) provides evidence for the size and nature of atomic nuclei."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-4
  a curric:KeyLearningPoint ;
  rdfs:label "An atomic nucleus has a radius about 10 000 times smaller than that of an atom."@en ;
  dcterms:modified "2026-02-19T08:26:13.589454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the mass of an atom is in its nucleus."@en ;
  dcterms:modified "2026-02-19T08:26:13.589458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-1
  a curric:KeyLearningPoint ;
  rdfs:label """A short circuit happens when a wire becomes loose and touches the wrong part of a circuit, or makes a new circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a live wire touches the inside of a metal case, the metal case may become live."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is too much current in an appliance, a fuse on the live wire in its plug melts and turns it off."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-4
  a curric:KeyLearningPoint ;
  rdfs:label """From a live metal case, current flows along an earth and live wire, melts a fuse and turns the electricity off."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-5
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic circuits with excessive current are turned off by circuit breakers in a consumer box to prevent fire."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cells in all parts of a multicellular plant need water and nutrients, such as mineral ions, to stay alive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Xylem and phloem transport substances around the plant and minimise the distance they have to diffuse to reach cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-3
  a curric:KeyLearningPoint ;
  rdfs:label "Root hair cells are an example of an exchange surface in plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.589840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The root hair cell membrane is adapted to maximise the surface area for osmosis of water and active transport of ions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same material."@en ;
  dcterms:modified "2026-02-19T08:26:13.589848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-02-19T08:26:13.589852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-02-19T08:26:13.589856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration and sterilisation are used to obtain potable water from groundwater and fresh water sources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of sea water creates potable water by distillation or reverse osmosis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pH of water samples can be determined using appropriate methods and/or instruments e.g pH meter."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH data can be analysed to assess if water contains impurities."@en ;
  dcterms:modified "2026-02-19T08:26:13.590006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different substances dissolve in different types of water."@en ;
  dcterms:modified "2026-02-19T08:26:13.590010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-4
  a curric:KeyLearningPoint ;
  rdfs:label """The substances that dissolve in different waters can affect the water's acidity or alkalinity (i.e. its pH)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water is necessary for laboratory tests; it must be neutral (i.e. pH 7)."@en ;
  dcterms:modified "2026-02-19T08:26:13.590018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation is a technique that is used to separate a soluble solute from a solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation involves the formation of a saturated solution and temperature differences."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Crystallisation results in the loss of the solvent to the surroundings."@en ;
  dcterms:modified "2026-02-19T08:26:13.590047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction the + symbol can be read as ‘and’ and the arrow as ‘changes into’."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an oxidation reaction a reactant combines with oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.590620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a decomposition reaction a reactant splits into two or more new substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.590624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-4
  a curric:KeyLearningPoint ;
  rdfs:label "In a precipitation reaction an insoluble salt is formed."@en ;
  dcterms:modified "2026-02-19T08:26:13.590628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a."@en ;
  dcterms:modified "2026-02-19T08:26:13.590634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force towards the centre of the Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of the Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inertial mass is a measure of how hard it is to change the velocity of an object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Inertial mass = force ÷ acceleration, m = F ÷ a."@en ;
  dcterms:modified "2026-02-19T08:26:13.590650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-1
  a curric:KeyLearningPoint ;
  rdfs:label "Unreactive metals are often found in the earth as pure metal."@en ;
  dcterms:modified "2026-02-19T08:26:13.590680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metals that are less reactive than carbon can be extracted by heating their oxides with carbon."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide is said to be reduced by carbon because the metal oxide loses oxygen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is oxidised when it reacts with a metal oxide because it gains oxygen to form carbon dioxide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.590712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.590724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.590728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can identify unknown substances through comparison or Rf values."@en ;
  dcterms:modified "2026-02-19T08:26:13.590732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used during comparisons, and calculations should consider significant figures."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair comparison of chromatograms depends on stationary and mobile phase choices, sample concentration and temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-4
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.590746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-1
  a curric:KeyLearningPoint ;
  rdfs:label "To make a product, raw materials need to be obtained and processed."@en ;
  dcterms:modified "2026-02-19T08:26:13.590848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-2
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the people who benefit from each stage of a product’s life."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-3
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the costs to individuals or the environment at each stage of a product’s life."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of its useful life a product can be repaired, recycled, incinerated or thrown away."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-5
  a curric:KeyLearningPoint ;
  rdfs:label """LCAs are often subjective, so it is important to consider the vested interests of those reporting on their findings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-19T08:26:13.591160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.591164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-19T08:26:13.591168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-19T08:26:13.591172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-1
  a curric:KeyLearningPoint ;
  rdfs:label "All magnets have a north–seeking pole and a south–seeking pole."@en ;
  dcterms:modified "2026-02-19T08:26:13.591442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike magnetic poles attract each other, and like magnetic poles repel each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Just three metal elements (iron, cobalt and nickel) are magnetic; other metals and non–metals are not magnetic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-4
  a curric:KeyLearningPoint ;
  rdfs:label "The needle of a plotting compass lines up with the magnetic field of a magnet."@en ;
  dcterms:modified "2026-02-19T08:26:13.591470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north–seeking pole of another magnet would be forced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.591493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.591497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.591511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force × distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-19T08:26:13.591515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.591519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of water waves can be measured using measurements of distance travelled and time taken."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Random errors are made when the method limits how accurate a measurement can be."@en ;
  dcterms:modified "2026-02-19T08:26:13.591592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-3
  a curric:KeyLearningPoint ;
  rdfs:label """The effect of random errors can be reduced by repeating readings and calculating a mean."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty in a mean result is calculated from half the range of the repeat measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.591637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point ."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.591652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.591656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists discovered and isolated fullerenes accidentally, which led to exciting new possibilities in chemistry."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-2
  a curric:KeyLearningPoint ;
  rdfs:label """Research into the allotropes of carbon is an important part of chemistry's history, earning multiple Nobel Prizes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphene is so thin that it's nearly transparent, allowing most light to pass through."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fullerenes, nanotubes, and graphene have a wide range of real-world uses in fields like electronics and medicine."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific discoveries have the power to change the world, even if their significance takes time to be fully understood."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytomining, metal is extracted from a crop of plants that absorb metal ions through their roots."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-02-19T08:26:13.591683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.591687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting metals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH scale ranges from 0 to 14, indicating how acidic or basic a substance is."@en ;
  dcterms:modified "2026-02-19T08:26:13.591812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-2
  a curric:KeyLearningPoint ;
  rdfs:label """Universal indicator provides a full range of colours corresponding to different pH levels, and this can be a limitation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Phenolphthalein changes from colourless to pink in alkaline conditions."@en ;
  dcterms:modified "2026-02-19T08:26:13.591819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Methyl orange shifts from red in acidic conditions to yellow in basic conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-5
  a curric:KeyLearningPoint ;
  rdfs:label """Litmus paper turns red in acidic conditions and blue in basic conditions, the solution will be purple when neutral."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base is a substance that neutralises an acid to make salt and water only (this is a neutralisation reaction)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroxides are generally soluble bases (they contain OH⁻ ions)."@en ;
  dcterms:modified "2026-02-19T08:26:13.591994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases that are generally insoluble."@en ;
  dcterms:modified "2026-02-19T08:26:13.591998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides are soluble and form acidic solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.592002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-1
  a curric:KeyLearningPoint ;
  rdfs:label "Typical atomic radii, and bond length, are in the order of 10⁻¹⁰m."@en ;
  dcterms:modified "2026-02-19T08:26:13.593006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal elements and non-metal compounds form covalent structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.593010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple covalent substances have no free moving charge carriers so cannot conduct electricity (some giant covalent can)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Small molecules are usually gases or liquids with relatively low melting and boiling points."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-5
  a curric:KeyLearningPoint ;
  rdfs:label """Giant covalent structures have high melting/boiling points because strong covalent bonds need to be broken."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-1
  a curric:KeyLearningPoint ;
  rdfs:label "A salt is formed when an acid neutralises a base."@en ;
  dcterms:modified "2026-02-19T08:26:13.593246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are giant, 3D ionic structures that form crystals with regular arrangements of ions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-3
  a curric:KeyLearningPoint ;
  rdfs:label """The empirical chemical formula of a salt provides the ratio of metal to non-metal ions it contains."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acids contain aqueous hydrogen ions, H⁺(aq) and alkalis contain aqueous hydroxide ions, OH⁻(aq)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-5
  a curric:KeyLearningPoint ;
  rdfs:label "During a neutralisation reaction: H⁺(aq) + OH⁻(aq) → H₂O(l)."@en ;
  dcterms:modified "2026-02-19T08:26:13.593262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using a stopwatch and ruler."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-02-19T08:26:13.593281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-02-19T08:26:13.593725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of that element measured in grams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-1
  a curric:KeyLearningPoint ;
  rdfs:label "Crude oil is a non-renewable mixture of different hydrocarbons and impurities."@en ;
  dcterms:modified "2026-02-19T08:26:13.593807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crude oil can be separated into groups of hydrocarbon molecules of similar size, called fractions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the hydrocarbon molecules in crude oil are alkanes."@en ;
  dcterms:modified "2026-02-19T08:26:13.593815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller hydrocarbon molecules have lower boiling points, are more flammable, and are less viscous."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil include petroleum gases, petrol, kerosene, diesel oil, heavy fuel oil, and bitumen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of positive ions are in competition at the negative electrode (cathode)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of negative ions are in competition at the positive electrode (anode)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode."@en ;
  dcterms:modified "2026-02-19T08:26:13.594176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested."@en ;
  dcterms:modified "2026-02-19T08:26:13.594180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrogen may be formed at the cathode"@en ;
  dcterms:modified "2026-02-19T08:26:13.594184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-1
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that could be helpful to humans (e.g. ability to digest man-made waste)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-2
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that is dangerous to humans (e.g. antibiotic resistance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations of examples at the genetic level using ideas about mutation, natural selection and asexual reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations to include why advantageous genetic variants become more common in the bacteria over generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms are classified into groups within larger groups, from species up to kingdoms and domains"""@en ;
  dcterms:modified "2026-02-19T08:26:13.594229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are domains of eukaryotes (animals, plants, fungi and protists), bacteria and archaea (both prokaryotic)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.594233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their macroscopic features (phenotype)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.594238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their and microscopic cell structures"""@en ;
  dcterms:modified "2026-02-19T08:26:13.594244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-1
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms can now be classified using evidence from sequencing their genes"@en ;
  dcterms:modified "2026-02-19T08:26:13.594249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing gene sequences provides evidence of evolutionary relationships"@en ;
  dcterms:modified "2026-02-19T08:26:13.594253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes organisms are reclassified into a different group if new evidence is discovered"""@en ;
  dcterms:modified "2026-02-19T08:26:13.594257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in a gas move very quickly in random directions and have empty space between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heating a fluid increases the speed of particles and they push each other further apart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a fluid is heated, it becomes less dense."@en ;
  dcterms:modified "2026-02-19T08:26:13.594395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hotter fluid rises through cooler fluid because it is less dense."@en ;
  dcterms:modified "2026-02-19T08:26:13.594399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.594793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.594797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move further apart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move fast enough to get even further apart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the mass of the solid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional to its specific latent heat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-1
  a curric:KeyLearningPoint ;
  rdfs:label "The common features of animal and plant cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.594885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals, plants, fungi and protists are made up of cells with a nucleus in which their genome is stored."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-3
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms made of cells with a nucleus are classified as eukaryotic organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.594917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common features of bacteria cells, including cell membrane, cell wall, plasmids and storing the genome in the cytoplasm."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-5
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms made of cells without a nucleus are classified as prokaryotic organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones can be used as a contraceptive to prevent pregnancy by disrupting the menstrual cycle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some oral hormone contraceptive pills prevent ovulation. If no egg is released, fertilisation cannot take place."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reasons why hormone pills may not be 100% effective (e.g. missing/late dose, taking after ovulation)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-hormonal contraceptives act as a barrier to prevent sperm from reaching the egg, so fertilisation cannot occur."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating benefits and risks of hormonal and non-hormonal (barrier) methods of contraception (including STIs)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much this can be dangerous to our health."@en ;
  dcterms:modified "2026-02-19T08:26:13.594975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in body temperature affect the rate of chemical reactions and can impact enzyme activity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in body temperature can lead to hypo- or hyperthermia and death."@en ;
  dcterms:modified "2026-02-19T08:26:13.594983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in water balance in the body can lead to dehydration and death."@en ;
  dcterms:modified "2026-02-19T08:26:13.594987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use of antagonistic effects to maintain a constant environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.594991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants and microorganisms provide new medicines; many others are synthesised in labs to target pathogens and host cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Preclinical trials: the medicine is tested for safety and effectiveness on cultured human cells and on live animals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.594999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety in people without the disease."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-4
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety and effectiveness in people with the disease."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of placebos in clinical trials, and use of blind and double blind trials prevent to bias in the results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis depends on factors including light, chlorophyll, water, temperature and carbon dioxide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-2
  a curric:KeyLearningPoint ;
  rdfs:label """A factor that when in short supply slows down or limits the rate of photosynthesis is called a limiting factor."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increased temperature increases photosynthesis rate up to the optimum (due to increased enzyme-substrate collisions)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Above the optimum temperature, enzymes are denatured and rate of photosynthesis decreases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increased CO2 concentration increases rate of photosynthesis up to the optimum, when all enzyme active sites are full."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hazard symbols provide vital safety information about chemical substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.595053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Correct identification of hazard symbols is crucial for laboratory safety."@en ;
  dcterms:modified "2026-02-19T08:26:13.595057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correctly choosing and using appropriate lab equipment is essential for conducting experiments safely and accurately."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-4
  a curric:KeyLearningPoint ;
  rdfs:label """Risk assessments identify potential hazards & outline how to minimise risk; these can be general & specific precautions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-5
  a curric:KeyLearningPoint ;
  rdfs:label """Safety protocols, like wearing eye protection and ensuring good ventilation, are essential when working with hazards."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of photosynthesis increases as CO₂ concentration, temperature and light intensity increase from low levels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis can be limited by one of these factors even if the others continue to increase."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis increases until one of more factors becomes limiting, then does not increase further."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation and explanation of graphs depicting effect of interacting limiting factors on the rate of photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the mass of gas produced as the reaction progresses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller marble chips have a larger surface area than larger chips of the same mass."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-3
  a curric:KeyLearningPoint ;
  rdfs:label "The larger the surface area, the faster the rate of reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.595466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphene is a single layer of graphite, is very strong and conducts electricity."@en ;
  dcterms:modified "2026-02-19T08:26:13.595472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fullerenes are molecules of carbon with hollow shapes."@en ;
  dcterms:modified "2026-02-19T08:26:13.595476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of fullerenes is based on hexagonal rings of carbon atoms, or on carbon rings of five or seven atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-4
  a curric:KeyLearningPoint ;
  rdfs:label "A Buckminsterfullerene is a spherical fullerene of sixty carbon atoms (C₆₀)."@en ;
  dcterms:modified "2026-02-19T08:26:13.595484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-5
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon nanotube is a tube of graphene that is very long compared to its diameter and has a high tensile strength."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aluminium is above carbon in the reactivity series and can therefore not be extracted with carbon."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Impurities are removed from the bauxite ore at the start."@en ;
  dcterms:modified "2026-02-19T08:26:13.595496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cryolite acts as a solvent and allows the electrolysis to take place at a lower temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon electrodes need to be continuously replaced as they react with oxygen as it is produced, forming carbon dioxide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is an expensive process as it requires large amounts of energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.595510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations are most correctly interpreted in terms of molar ratios (i.e. 1 mole of A reacts with 2 moles of B)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The molar ratios of the substances in a chemical reaction is known as stoichiometry, which means ‘measuring elements’."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a reaction is shown by coefficients in a balanced equation. These molar relationships don't change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-5
  a curric:KeyLearningPoint ;
  rdfs:label """The moles of substance in a reaction can be determined using: mass(g) = Mr  × moles (& the stoichiometry of reaction)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrocarbons are simple covalent compounds made of hydrogen and carbon atoms only."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrocarbons are found in crude oil, and are used as fuels and feedstock."@en ;
  dcterms:modified "2026-02-19T08:26:13.595787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes consist of chains, or rings, of carbon atoms that are each also bonded to hydrogen atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes are a homologous series of hydrocarbons, with the same general formula with a trend in properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-5
  a curric:KeyLearningPoint ;
  rdfs:label "The general formula for an alkane is CnH2n+2."@en ;
  dcterms:modified "2026-02-19T08:26:13.595799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of reactants in a chemical reaction can react together if they collide with sufficient energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing surface area of a solid lets more reacting particles in a solution collide with its particles each second."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature of reactants increases the speed of particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing pressure of reacting gases pushes reactant particles closer together, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change; physical and chemical, and the physical state of a substance can be predicted."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-3
  a curric:KeyLearningPoint ;
  rdfs:label """The attraction between particles has a role in determining the amount of energy needed for state changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particle model has limitations, for example by showing particles as same sized, inelastic spheres."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-5
  a curric:KeyLearningPoint ;
  rdfs:label """The model does not show the attraction between the particles which affects the amount of energy needed to change state."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric charge and mass number of each one."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and charge of +2."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-02-19T08:26:13.596182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-02-19T08:26:13.596188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is close to zero and charge of –1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-1
  a curric:KeyLearningPoint ;
  rdfs:label "All EM waves can transfer energy, from a source to an absorber."@en ;
  dcterms:modified "2026-02-19T08:26:13.596196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Only UV, X-ray and gamma frequencies of EM wave cause ionisation. The higher the frequency, the more ionising."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation can damage cells, cause genes to mutate and increase the risk of cancer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-4
  a curric:KeyLearningPoint ;
  rdfs:label """UV is used in lighting and to disinfect water. It causes tanning/sunburn. It increases the risk of skin cancer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-5
  a curric:KeyLearningPoint ;
  rdfs:label """X- and gamma rays are used in medical imaging. Gamma rays are used to kill cancer cells and to sterilise food/equipment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal amounts of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive isotope plotted against time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼ as much."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½ = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They can harm cells by heating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves are produced by oscillations of current. When absorbed, they may produce oscillations of current."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting and data transmission."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-5
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data transmission in optical fibres."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-19T08:26:13.596453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity - initial velocity"""@en ;
  dcterms:modified "2026-02-19T08:26:13.596457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time intervals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-19T08:26:13.596480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-3
  a curric:KeyLearningPoint ;
  rdfs:label "Taking measurements by reading the timing lines at eye level improves accuracy."@en ;
  dcterms:modified "2026-02-19T08:26:13.596484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-02-19T08:26:13.596488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points increase."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just full electron shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance of each shell from the nucleus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-02-19T08:26:13.597098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-1
  a curric:KeyLearningPoint ;
  rdfs:label """Neutralisation reactions involve an acid reacting with a base to form salt and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-02-19T08:26:13.597106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methods must be detailed and replicable for reliable data collection."@en ;
  dcterms:modified "2026-02-19T08:26:13.597110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-4
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to calculate energy change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-5
  a curric:KeyLearningPoint ;
  rdfs:label """Line graphs can illustrate relationships between continuous variables in experiments."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the lab."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density & particles is fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-02-19T08:26:13.597132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce uncertainty."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-1
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst affects the reaction rate without being used up."@en ;
  dcterms:modified "2026-02-19T08:26:13.597140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-2
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst reduces the activation energy needed for a reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.597147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-3
  a curric:KeyLearningPoint ;
  rdfs:label """With a catalyst present, more collisions between reactants result in the formation of product(s)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are biological catalysts."@en ;
  dcterms:modified "2026-02-19T08:26:13.597155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-5
  a curric:KeyLearningPoint ;
  rdfs:label "Catalysts vary in efficiency; qualitative data helps evaluate effectiveness."@en ;
  dcterms:modified "2026-02-19T08:26:13.597159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance measured in grams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating the number of moles in a substance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is an average value that takes account of the abundance of the isotopes of the element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-02-19T08:26:13.597541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated similar properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into groups of similar properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were later found."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by atomic weight was not always correct."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-02-19T08:26:13.597864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-02-19T08:26:13.597868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity / time (a = Δv/t)"@en ;
  dcterms:modified "2026-02-19T08:26:13.597872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-02-19T08:26:13.597876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-02-19T08:26:13.597880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-19T08:26:13.598119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because it is stretched by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early volcanic activity is thought to have made an atmosphere of carbon dioxide and nitrogen billions of years ago."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can dissolve in oceans and form carbonates that, over millions of years, can form sedimentary rock."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-3
  a curric:KeyLearningPoint ;
  rdfs:label """The amount of carbon dioxide was reduced by the formation of sedimentary rocks and photosynthesis by algae and plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-4
  a curric:KeyLearningPoint ;
  rdfs:label """Algae and plants produced the oxygen that is now in the atmosphere by photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-5
  a curric:KeyLearningPoint ;
  rdfs:label """Phytoplankton in the oceans are responsible for roughly half of all oxygen production that takes place today."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-1
  a curric:KeyLearningPoint ;
  rdfs:label """In pure metals, ions are arranged in a regular structure with delocalised electrons between them"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a metal is stretched or forced out of shape, its ions are able to move position without the metallic bonds breaking"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-3
  a curric:KeyLearningPoint ;
  rdfs:label """An alloy is a mixture of different metal elements or of metals with non metal elements (i.e. carbon)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ions of different metal elements may be different sizes and have different electrical charges"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-5
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of an alloy is not as regular as a pure metal and this affects its properties"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-1
  a curric:KeyLearningPoint ;
  rdfs:label """When powdered hydroxide/oxide (base) is added to an acidic solution there is an increase in pH."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH changes quickly around the neutralisation point."@en ;
  dcterms:modified "2026-02-19T08:26:13.598339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indicators, such as Universal Indicator paper, can be used to collect quantitative data on pH."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-4
  a curric:KeyLearningPoint ;
  rdfs:label """pH can be plotted on a graph to find the quantity of base required to neutralise an acid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative atomic mass of 1/1835 (negligible)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-19T08:26:13.598709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles are associated with conditions that affect people’s health (e.g. cystic fibrosis)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prospective parents can be tested for these alleles, as can embryos (embryo screening)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fetus can be tested for these alleles (e.g. by chorionic villus sampling or amniocentesis)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tests can have false negative or false positive results, and risks of miscarriage or infection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parents must be supported to interpret test results, consider ethical questions and make difficult personal decisions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-1
  a curric:KeyLearningPoint ;
  rdfs:label """pH is a logarithmic scale (as hydrogen ion concentration increases by a factor of 10, the pH decreases by 1)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-2
  a curric:KeyLearningPoint ;
  rdfs:label "For a given concentration, a stronger acid contains more H⁺ ions."@en ;
  dcterms:modified "2026-02-19T08:26:13.598842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-3
  a curric:KeyLearningPoint ;
  rdfs:label """Titration curves can be used to show the change in pH to allow chemists to pinpoint a more accurate end point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong acid is completely ionised in aqueous solution, a weak acid only partially ionises."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Titration curves show how the pH changes throughout a neutralisation reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.598854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every atom of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus of the atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons in atoms of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-02-19T08:26:13.599417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-02-19T08:26:13.599423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free body diagram shows all of the individual forces acting on a single object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.599431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type and act in opposite directions between two objects."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.599482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.599486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.599494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnetic door lock uses an electromagnet to pull a magnetic bolt to unlock a door."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric bell often contains an electromagnet that attracts and moves the striker, making it hit the bell."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an electromagnet moves the striker in an electric bell, it breaks its own circuit to let the striker spring back."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motor contains a spinning coil of wire that is an electromagnet."@en ;
  dcterms:modified "2026-02-19T08:26:13.599630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is a current in the spinning coil of wire in a motor, other magnets around it will push it round."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-1
  a curric:KeyLearningPoint ;
  rdfs:label """Antibiotics are medicines that can only be used to treat bacterial infections; they do not work against viruses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some antibiotics work by stopping bacteria developing a cell wall."@en ;
  dcterms:modified "2026-02-19T08:26:13.599856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria can become resistant to antibiotics, and resistance can spread if antibiotics are not used correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Antibiotics must only be taken when they are prescribed by a doctor."@en ;
  dcterms:modified "2026-02-19T08:26:13.599864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-5
  a curric:KeyLearningPoint ;
  rdfs:label """Do not take antibiotics for the wrong reasons and always complete the prescribed course."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.600055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.600059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.600213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-19T08:26:13.600221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Whenever a measurement is made, there is always some uncertainty about the result obtained."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-2
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of an individual measurement is equal to half the resolution of the device used to take the measurement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-3
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the resolution, the lower the uncertainty of an individual measurement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-4
  a curric:KeyLearningPoint ;
  rdfs:label "Half the range of repeated measurements equals the uncertainty of a mean value."@en ;
  dcterms:modified "2026-02-19T08:26:13.600337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-5
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of a measurement provides a range within which the actual value can be found."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-02-19T08:26:13.600382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-02-19T08:26:13.600386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in kinetic energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the amount of gas produced as the reaction progresses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles, so they collide more frequently."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-3
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid with equal amounts of magnesium, the same volume is produced for all concentrations of acid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stretching or compressing an object requires more than one force."@en ;
  dcterms:modified "2026-02-19T08:26:13.600929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Below the limit of proportionality, a stretched spring is not stretched permanently out of shape."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Above the limit of proportionality, a stretched spring is stretched permanently out of shape."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above pushes particles closer together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it and causes upthrust."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-02-19T08:26:13.600954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness of its particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further apart than they are in water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-1
  a curric:KeyLearningPoint ;
  rdfs:label "FSH causes follicle maturation and secretion of oestrogen by the ovaries."@en ;
  dcterms:modified "2026-02-19T08:26:13.602173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oestrogen causes thickening of uterus wall, secretion of LH by the pituitary gland and inhibits the release of FSH."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-3
  a curric:KeyLearningPoint ;
  rdfs:label """LH causes ovulation; FSH and LH cause the mature follicle to break down and secrete progesterone."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Progesterone prepares uterus lining for implantation of fertilised egg; stops secretion of LH & FSH by pituitary gland."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fall in progesterone causes menstruation."@en ;
  dcterms:modified "2026-02-19T08:26:13.602191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive with other elements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 0 elements density and boiling points increase."@en ;
  dcterms:modified "2026-02-19T08:26:13.602599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they do not decompose."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points increase."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just full electron shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance of each shell from the nucleus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-02-19T08:26:13.602623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Distillation can be used to purify water samples."@en ;
  dcterms:modified "2026-02-19T08:26:13.602989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Boiling point data can be analysed to assess the purity of water samples."@en ;
  dcterms:modified "2026-02-19T08:26:13.602993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-3
  a curric:KeyLearningPoint ;
  rdfs:label """The more impurities present in a sample, the larger the temperature range over which the water will boil."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water boils at 100°C."@en ;
  dcterms:modified "2026-02-19T08:26:13.603000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a change in direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle of refraction)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle of refraction)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-5
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the angle of incidence, the greater the angle of refraction."@en ;
  dcterms:modified "2026-02-19T08:26:13.603054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-02-19T08:26:13.603061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of the sizes of cells and cell structures in µm, nm, and in mm in standard form."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-02-19T08:26:13.603069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.603077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis: the process in which an electrolyte is broken down by electricity; it's not a physical separation method."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cathode is the negative electrode, where positive particles gain electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.603129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-3
  a curric:KeyLearningPoint ;
  rdfs:label "The anode is the positive electrode, where negative particles lose electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.603133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electrolyte contains freely moving ions, and these are attracted to the charged electrodes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis allowed Davy and Faraday to make their scientific discoveries."@en ;
  dcterms:modified "2026-02-19T08:26:13.603143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-1
  a curric:KeyLearningPoint ;
  rdfs:label """A chemical equation is used to represent the chemical reaction that occurs during the formation of a compound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic equations can be used to show only the chemical species that are changing within a reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-3
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols (s), (l), (g) and (aq), are used in ionic equations to show which substances change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ionic equation for water formation (neutralisation) is H⁺(aq) + OH⁻(aq) → H2O(l)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a correlation between increasing amounts of atmospheric carbon dioxide and a rising average global temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increases in atmospheric carbon dioxide have been caused by human activity."@en ;
  dcterms:modified "2026-02-19T08:26:13.603914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Overwhelming evidence shows human activity is responsible for the rapid global warming of the last 200 years."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Global warming measurements and conclusions are reliable despite some unavoidable uncertainty in measured values."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon footprints measure the annual greenhouse gas emissions of individuals, industry and nations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different hot metals, of the same mass and starting temperature, heat a fixed amount of water by different amounts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-2
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a material has because its particles are moving with forces between them can be labelled internal energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more energy transferred to increase its temperature by 1ºC."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more heating it does as its temperature falls by 1ºC."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-02-19T08:26:13.604453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison of the sizes of cells and cell structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.604457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-02-19T08:26:13.604461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.604465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.604468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a list of general rules which describe the solubility of common types of substances in water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reactions that form insoluble products are called precipitation reactions; the solids formed are called the precipitate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-3
  a curric:KeyLearningPoint ;
  rdfs:label """When two soluble salts are mixed together, sometimes they will rearrange to create an insoluble salt."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-4
  a curric:KeyLearningPoint ;
  rdfs:label """Solubility rules can be used to identify which two solutions are needed to mix in order to create an insoluble salt."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non–renewable energy resource cannot be replenished as it is used."@en ;
  dcterms:modified "2026-02-19T08:26:13.605258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy resources include fossil fuels (coal, oil and gas) and nuclear fuels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-3
  a curric:KeyLearningPoint ;
  rdfs:label "A renewable energy resource can be replenished as it is used."@en ;
  dcterms:modified "2026-02-19T08:26:13.605266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-4
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources include biofuels, wind, hydroelectricity, geothermal, tidal, solar and water waves."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Science can identify environmental issues, but political, social, ethical and economic considerations determine action."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of arrows (→, ⇌) are used in chemical equations to indicate the nature of the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reversible reactions are symbolised using the double-headed arrow (⇌) in chemical equations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction, both the forward and reverse reactions can occur under the right conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.605829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-4
  a curric:KeyLearningPoint ;
  rdfs:label "hydrated copper sulfate (blue) ⇌ anhydrous copper sulfate (white) + water"@en ;
  dcterms:modified "2026-02-19T08:26:13.605833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-5
  a curric:KeyLearningPoint ;
  rdfs:label "ammonium chloride ⇌ ammonia + hydrogen chloride"@en ;
  dcterms:modified "2026-02-19T08:26:13.605837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.606220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-19T08:26:13.606231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.606456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation E = ½ mv²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-19T08:26:13.606518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.606523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-19T08:26:13.606527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-19T08:26:13.606531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-02-19T08:26:13.606624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along the length of a ruler."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten, than measuring one wavelength."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a timer in the frame."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow motion, to track one wave crest."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gently heating the acid speeds up the reaction, ensuring all acid reacts."@en ;
  dcterms:modified "2026-02-19T08:26:13.606775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The salt should be dried using an appropriate method (using filter paper, or in the oven)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-3
  a curric:KeyLearningPoint ;
  rdfs:label """A pure sample should be prepared with equipment washed with distilled water to avoid contamination."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reacting a metal hydroxide with an acid also produces a salt and water."@en ;
  dcterms:modified "2026-02-19T08:26:13.606813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal carbonate with an acid can produce a desired salt with water, as well as carbon dioxide gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.606922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation E = ½ mv²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation & relevant mathematical relationships."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added in excess, not all of it will react and some will be found in the final product mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from the available particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-1
  a curric:KeyLearningPoint ;
  rdfs:label """metal + acid ⭢ salt + hydrogen; metal carbonate + acid → salt + water + carbon dioxide"""@en ;
  dcterms:modified "2026-02-19T08:26:13.607675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-2
  a curric:KeyLearningPoint ;
  rdfs:label """The test for hydrogen gas is to introduce a lighted splint, which will make a squeaky pop in hydrogen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-3
  a curric:KeyLearningPoint ;
  rdfs:label "The name of a salt formed is dependent on the acid used."@en ;
  dcterms:modified "2026-02-19T08:26:13.607683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-4
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g), (aq) in chemical equations identify the state of substances as solid, liquid, gas or in aqueous solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be bubbled through limewater, which turns cloudy (test for CO₂)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-1
  a curric:KeyLearningPoint ;
  rdfs:label """A 'pure substance' in chemistry is a single element or compound not mixed with any other substance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-2
  a curric:KeyLearningPoint ;
  rdfs:label "The definition of 'pure' means something different in its everyday usage."@en ;
  dcterms:modified "2026-02-19T08:26:13.607735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pure elements and compounds have specific melting and boiling points."@en ;
  dcterms:modified "2026-02-19T08:26:13.607739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to recognise substances with specific melting points as pure substances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-1
  a curric:KeyLearningPoint ;
  rdfs:label """All bodies (objects) of all temperatures emit and absorb infrared radiation. Hotter bodies emit more IR in a set time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-2
  a curric:KeyLearningPoint ;
  rdfs:label """The range of wavelengths emitted, and their intensities, depend on an object’s temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-3
  a curric:KeyLearningPoint ;
  rdfs:label """Good absorbers (e.g. dark and dull surfaces) are also good emitters. Shiny metal surfaces are poor absorbers/emitters."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-02-19T08:26:13.607947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving full electron shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic nucleus with less force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.607960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four ions present in a solution of brine: H⁺, OH⁻, Na⁺ and Cl⁻."@en ;
  dcterms:modified "2026-02-19T08:26:13.608289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the negative electrode is hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.608293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-3
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the positive electrode is chlorine gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.608299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sodium hydroxide solution forms in the electrolyte solution, making it alkaline."@en ;
  dcterms:modified "2026-02-19T08:26:13.608305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of ions are in competition at each electrode."@en ;
  dcterms:modified "2026-02-19T08:26:13.608309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-1
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens can be dissolved in water to form acidic solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.608354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A more reactive halogen can displace a less reactive one from a compound."@en ;
  dcterms:modified "2026-02-19T08:26:13.608358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-3
  a curric:KeyLearningPoint ;
  rdfs:label "Group 7 elements react with Group 1 and 2 metals to form salts."@en ;
  dcterms:modified "2026-02-19T08:26:13.608364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-4
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for chlorine involves passing the gas over damp blue litmus paper."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combustion is the chemical combination of a substance with oxygen, involving the production of heat and light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Complete combustion of fuels (like hydrocarbons) involve the production of carbon dioxide and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-3
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for oxygen is a combustion reaction, involving relighting a glowing splint."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Incomplete combustion produces carbon particulates (soot) and carbon monoxide due to reduced oxygen levels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a giant ionic structure there are strong electrostatic forces in all directions between oppositely charged particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds have high melting points and high boiling points because strong ionic bonds need to be broken."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most ionic substances can dissolve in water."@en ;
  dcterms:modified "2026-02-19T08:26:13.608640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds dissolved in water are free to move around and the solution can conduct electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds that are in the liquid state are free to move around and the liquid can conduct electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans use Earth’s natural resources for most of our material needs."@en ;
  dcterms:modified "2026-02-19T08:26:13.608705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Finite resources exist in limited quantities and will run out because we use them quicker than they can be regenerated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Synthetic products such as plastic and glass are made by humans using natural resources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable development meets our needs without compromising the ability of future generations to meet their own needs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of renewable resources, and the reuse and recycling of products, are sustainable development strategies."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.608842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.608853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solution is a type of mixture made of a solvent and a solute."@en ;
  dcterms:modified "2026-02-19T08:26:13.608894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solutions form due to a solute dissolving in the solvent."@en ;
  dcterms:modified "2026-02-19T08:26:13.608898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Solubility is a measure of how well a chemical dissolves (soluble/insoluble)."@en ;
  dcterms:modified "2026-02-19T08:26:13.608902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many substances can act as a solvent; however, water is the most common."@en ;
  dcterms:modified "2026-02-19T08:26:13.608908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-5
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols are used to identify the three states of matter and aqueous solutions in chemical equations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-19T08:26:13.609419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.609424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-19T08:26:13.609428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-19T08:26:13.609432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-02-19T08:26:13.609957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving full electron shells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic nucleus with less force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.609972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change, physical and chemical, and these can be explained in terms of the particle model."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-3
  a curric:KeyLearningPoint ;
  rdfs:label "The physical state of a substance can be predicted at specified temperatures."@en ;
  dcterms:modified "2026-02-19T08:26:13.609984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-4
  a curric:KeyLearningPoint ;
  rdfs:label """Forces of attraction between particles have a role in determining the amount of energy needed for state changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions about effects of factors such as temperature and availability of water and CO2 on rate of photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis in producers creates the biomass for food chains, which all consumers (including humans) depend on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change and global warming affect the temperature and the availability of water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rising temperatures, droughts and floods will reduce the yields of crop plants that feed farm animals and humans."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different regions of the world and the people living there will be affected in different ways."""@en ;
  dcterms:modified "2026-02-19T08:26:13.610590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere comprises ~80% nitrogen and ~20% oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.611478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains small proportions of various other gases, including CO₂, water vapour and noble gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid) state in clouds and precipitation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-5
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-02-19T08:26:13.611498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms that are in the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation & relevant mathematical relationships."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added excess, not all of it will react and some will be found in the final product mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from the available particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-19T08:26:13.611823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-02-19T08:26:13.611827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-5
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-02-19T08:26:13.611831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-19T08:26:13.611839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is stretched, by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need to be applied to find a second."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.612338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.612342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-19T08:26:13.612421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the device)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.612640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-02-19T08:26:13.612644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-19T08:26:13.612676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels"@en ;
  dcterms:modified "2026-02-19T08:26:13.612680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.612753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation KE = ½ mv²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Small masses of a substance, including magnesium, can be easily heated in a crucible."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible needs to be opened periodically to allow air (i.e. oxygen) to enter the apparatus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lifting a crucible lid too often or for too long may lead to loss of product (i.e. lower final mass recorded)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using practical data and conservation of mass, chemists can calculate unknown reactant masses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reactant masses can determine the empirical formula of a substance, including the ionic molar ratio of a metal & oxygen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They can harm cells by heating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting and data transmission."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-4
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data transmission in optical fibres."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.612864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is distance in a particular direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.612868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are vectors."@en ;
  dcterms:modified "2026-02-19T08:26:13.612872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-4
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity is positive in one direction and negative in the opposite direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.612876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-5
  a curric:KeyLearningPoint ;
  rdfs:label "Movement around a circle at a steady speed involves a changing velocity."@en ;
  dcterms:modified "2026-02-19T08:26:13.612880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-19T08:26:13.612886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.612890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-19T08:26:13.612894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-19T08:26:13.612898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.612905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-02-19T08:26:13.612913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright light produced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-19T08:26:13.612921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is always the same."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance measured in grams."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating the number of moles in a substance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-02-19T08:26:13.613091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-02-19T08:26:13.613095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-19T08:26:13.613099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed throughout the heating process."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.613462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.613472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.613476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use a light microscope to observe effects of osmosis in plant cells (including: shrinking/crenation,  swelling/bursting)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.613695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.613699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including changing magnification and focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about osmosis and net movement of water into/out of cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.613733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-19T08:26:13.613737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.613743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-02-19T08:26:13.613768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-02-19T08:26:13.613772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-3
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-02-19T08:26:13.613775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-02-19T08:26:13.613779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type, and act in opposite directions between two objects."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move further apart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move fast enough to get even further apart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the mass of the solid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional to it’s specific latent heat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Titration is a method used to completely neutralise an acid with a soluble base (alkali)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-2
  a curric:KeyLearningPoint ;
  rdfs:label """Titrations are performed using strong acids and strong alkalis to accurately determine reacting volumes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strong acids and alkalis are completely ionised in an aqueous solution."@en ;
  dcterms:modified "2026-02-19T08:26:13.614517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each piece of apparatus in a titration has a specific and essential function."@en ;
  dcterms:modified "2026-02-19T08:26:13.614521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-5
  a curric:KeyLearningPoint ;
  rdfs:label """A suitable indicator (not universal indicator) is used to identify the end point of the titration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-1
  a curric:KeyLearningPoint ;
  rdfs:label """The momentum of an object is changed by a resultant force acting over a period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Force = rate of change of momentum, F = Δp ÷ t = (mv – mu) ÷ t"@en ;
  dcterms:modified "2026-02-19T08:26:13.614812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of an impact force can be changed when the duration of the impact changes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere comprises 78% nitrogen, 21% oxygen, 1% argon and trace gases including 0.04% carbon dioxide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid) state in clouds and precipitation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-4
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-02-19T08:26:13.614890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and each version is called an isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being whole numbers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic number of the isotope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric and magnetic fields."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more than red."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio, microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact differently with different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same substance."@en ;
  dcterms:modified "2026-02-19T08:26:13.615420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-02-19T08:26:13.615424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-02-19T08:26:13.615428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentation, filtration and chlorination are used to obtain potable water from groundwater and fresh water sources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.615432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of seawater creates potable water by distillation or reverse osmosis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.615436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-02-19T08:26:13.616440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series electric circuit adds up to the p.d. of the battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the resistance in a series circuit, the lower the current (current is inversely proportional to resistance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the battery p.d. in series circuit, the larger the current (current is directly proportional to p.d.)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Current, p.d. or resistance can be calculated with the equation: current = p.d./resistance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 340 m/s."@en ;
  dcterms:modified "2026-02-19T08:26:13.616463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in air can be measured using an echo method and using speed = distance/time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in a metal rod can be found by measuring the length and the frequency produced when struck."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-4
  a curric:KeyLearningPoint ;
  rdfs:label "A result is accurate if it is close to the true value."@en ;
  dcterms:modified "2026-02-19T08:26:13.616475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-5
  a curric:KeyLearningPoint ;
  rdfs:label """A result can be considered accurate if it is repeatable, reproducible and if systematic errors have been checked for."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the wire."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and turned off."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-3
  a curric:KeyLearningPoint ;
  rdfs:label """The magnetic field of an electromagnet is similar to the field around a bar magnet."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-4
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core in an electromagnet becomes magnetised and adds to the strength of field when the electromagnet is on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed amount is proportional to mass."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the increase in temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to/by 1 kg of a material when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius (J/kg ºC)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.616874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-19T08:26:13.616878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.616886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.617082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all suggested atomic models."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom & the nuclear model are two important models in the history of the atom's discovery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-02-19T08:26:13.617097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.617148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.617156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.617435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.617440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal amounts of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive isotope plotted against time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼ as much."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½ = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-1
  a curric:KeyLearningPoint ;
  rdfs:label """A joulemeter measures a total amount of energy transferred to an electric circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-2
  a curric:KeyLearningPoint ;
  rdfs:label """At equilibrium, a metal block is at the same temperature as the water bath it is in."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.618839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-02-19T08:26:13.618847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright light produced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-19T08:26:13.618856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-1
  a curric:KeyLearningPoint ;
  rdfs:label """A more reactive element will replace a less reactive element in a compound (displacement)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more easily a metal atom forms a positive ion, the more reactive it is."@en ;
  dcterms:modified "2026-02-19T08:26:13.618864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with acid to produce a metal salt and hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.618868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with water to produce a metal hydroxide and hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.618872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is a non-metal element often included in the reactivity series between aluminium and zinc."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.618982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation Ek = ½ mv²."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytoextraction, metal is extracted from a crop of plants that absorb metal ions through their roots."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-02-19T08:26:13.619577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.619581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting metals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a compound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions, calculate the empirical formula."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula, calculate the molecular formula."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Know that we are using moles, and molar ratios to calculate formulae"@en ;
  dcterms:modified "2026-02-19T08:26:13.619732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mains electricity has a p.d. of 230 V between a live wire connection (230 V) and a neutral wire connection (0 V)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mains electricity has alternating current at a frequency of 50 Hz."@en ;
  dcterms:modified "2026-02-19T08:26:13.619891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current passing through a person’s body can damage living tissue and/or stop their heart pumping blood."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of current from a shock depends on the p.d. across the person and the resistance of their skin (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wet skin has a much lower resistance than dry skin, and a smaller p.d. can cause a bigger current from a shock."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-1
  a curric:KeyLearningPoint ;
  rdfs:label """A half–equation describes what happens to one reactant in a reaction, such as the process at an individual electrode."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-2
  a curric:KeyLearningPoint ;
  rdfs:label "Half–equations show balanced charges as well as balanced atoms."@en ;
  dcterms:modified "2026-02-19T08:26:13.619911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-3
  a curric:KeyLearningPoint ;
  rdfs:label "A balanced ionic equation shows all reacting ions involved in a reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.619915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions not involved in a reaction do not appear in a balanced ionic equation."@en ;
  dcterms:modified "2026-02-19T08:26:13.619919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oxidation is the loss of electrons and reduction is the gain of electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.619925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Half equations can be written to show which species are oxidised and which are reduced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic equations can be written for displacement reactions."@en ;
  dcterms:modified "2026-02-19T08:26:13.619934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of a carbon-12 atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of compound) × 100"""@en ;
  dcterms:modified "2026-02-19T08:26:13.619949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a chemical reaction is the molar ratio of each substance in a balanced symbol equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoichiometric values can be calculated using masses found by experiment."@en ;
  dcterms:modified "2026-02-19T08:26:13.619977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subscript values in chemical formula indicate the ratio of atoms/ions in a molecule/formula unit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of mass of gas produced against time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess marble chips with acid, the same mass of gas is produced for all surface areas of chips."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mean rate of reaction = total mass of gas produced ÷ total time of reaction"@en ;
  dcterms:modified "2026-02-19T08:26:13.620032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-4
  a curric:KeyLearningPoint ;
  rdfs:label "The instantaneous rate of reaction is equal to the gradient of the graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.620036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a point on the curve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a covalent bond, two non-metal atoms share a pair of electrons (from their outer shells)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-2
  a curric:KeyLearningPoint ;
  rdfs:label """For every one electron needed to complete the outer shell of an atom, one covalent bond will form."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-3
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms can share multiple pairs of electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.620052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Displayed formulae of covalent substances are a model, showing lines to represent shared pairs of electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compare data on rate of water uptake by a plant at a range of light intensities."@en ;
  dcterms:modified "2026-02-19T08:26:13.620103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-2
  a curric:KeyLearningPoint ;
  rdfs:label "Identify a pattern or trend in the data."@en ;
  dcterms:modified "2026-02-19T08:26:13.620107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Higher light intensity increases transpiration rate as stomata open wider to increase gas exchange for photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-4
  a curric:KeyLearningPoint ;
  rdfs:label "Increased temperature and air movement also increase the rate of water uptake."@en ;
  dcterms:modified "2026-02-19T08:26:13.620115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-5
  a curric:KeyLearningPoint ;
  rdfs:label """Higher temperature and air movement increase transpiration due to increased diffusion of water out through stomata."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon dioxide and methane are common greenhouse gases."@en ;
  dcterms:modified "2026-02-19T08:26:13.620956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases reduce the amount of lower-energy IR that can escape from Earth’s atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-3
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases do not reduce the amount of higher-energy IR radiation entering the atmosphere from the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the rate energy is transferred into the atmosphere exceeds the rate it is transferred out, average temperatures rise."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-5
  a curric:KeyLearningPoint ;
  rdfs:label """An increasing average temperature of Earth’s atmosphere is called global warming."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-19T08:26:13.621127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-19T08:26:13.621136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field strength × change in height"""@en ;
  dcterms:modified "2026-02-19T08:26:13.621140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or the mass of gas increases, or the volume decreases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the temperature increases the average speed of the particles in a gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the speed of the particles in a gas at a fixed volume increases its pressure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.621204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.621208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-19T08:26:13.622292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-19T08:26:13.622296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-02-19T08:26:13.622300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed amount is proportional to mass."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the increase in temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to or by 1 kg of a material when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius (J/kg ºC)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-19T08:26:13.622333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-19T08:26:13.622337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-02-19T08:26:13.622341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using a stopwatch and ruler."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-02-19T08:26:13.622357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-02-19T08:26:13.622614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-02-19T08:26:13.622618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in kinetic energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-02-19T08:26:13.622689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along the length of a ruler."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten, than measuring one wavelength."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a timer in the frame."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow motion, to track one wave crest."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use models to represent parts of the natural world that are too difficult to observe or explain directly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple ways (models) of drawing/showing bonding."@en ;
  dcterms:modified "2026-02-19T08:26:13.622713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are multiple advantages and limitations of particular representations and models."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-02-19T08:26:13.622723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining the element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their own, or in compound form."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical compositions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-02-19T08:26:13.622751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-02-19T08:26:13.622755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-02-19T08:26:13.622759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-02-19T08:26:13.622763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-02-19T08:26:13.622767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-19T08:26:13.624575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity - initial velocity"""@en ;
  dcterms:modified "2026-02-19T08:26:13.624579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time intervals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.628262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.628276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.628280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-02-19T08:26:13.628515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-02-19T08:26:13.628519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-02-19T08:26:13.628523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed throughout the heating process."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The combustion of fossil fuels adds more carbon dioxide to the atmosphere."@en ;
  dcterms:modified "2026-02-19T08:26:13.628660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide added to the atmosphere in one place will, over time, spread throughout Earth’s atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plants act as carbon sinks because, as they grow, they remove carbon dioxide from the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-4
  a curric:KeyLearningPoint ;
  rdfs:label """The decomposition or combustion of plants returns the carbon they are storing into the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-5
  a curric:KeyLearningPoint ;
  rdfs:label """Human activity is adding carbon dioxide to the atmosphere more quickly than it is being removed by natural processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms can identify unknown substances by qualitative visual comparison or quantitatively by Rf value comparison."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be employed when using chromatograms to identify unknown substances in a mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:13.628750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-3
  a curric:KeyLearningPoint ;
  rdfs:label "An appropriate number of significant figures should be used in calculations."@en ;
  dcterms:modified "2026-02-19T08:26:13.628756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-02-19T08:26:13.630976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-02-19T08:26:13.630980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in kinetic energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.630984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative mass of 0.0005 (very small)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.631107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.631111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.631115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-19T08:26:13.631119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.631123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is transferred by electricity from power stations to consumers using the National Grid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-2
  a curric:KeyLearningPoint ;
  rdfs:label """Step-up transformers increase the transmission voltage from a power station to the transmission line."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-3
  a curric:KeyLearningPoint ;
  rdfs:label """Step-down transformers decrease the transmission voltage from a transmission line to the consumer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-4
  a curric:KeyLearningPoint ;
  rdfs:label "Transmission lines dissipate some energy by heating (P = I²R)."@en ;
  dcterms:modified "2026-02-19T08:26:13.632593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-5
  a curric:KeyLearningPoint ;
  rdfs:label """A very high transmission voltage reduces transmission current and the heating of transmission lines."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-02-19T08:26:13.632641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell, and become positive ions (cations)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.632656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the number (e.g. 2+, not +2)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-02-19T08:26:13.632710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell, and become positive ions (cations)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.632721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the number (e.g. 2+, not +2)."""@en ;
