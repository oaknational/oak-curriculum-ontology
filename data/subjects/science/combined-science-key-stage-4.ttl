  dcterms:modified "2026-02-19T08:26:07.163572Z"^^xsd:dateTime .

oakcurric:keyword-excess
  a curric:Keyword ;
  schema:name "excess"@en ;
  schema:description "If you have an excess of something, you have more than is necessary."@en ;
  dcterms:modified "2026-02-19T08:26:07.163742Z"^^xsd:dateTime .

oakcurric:keyword-transect
  a curric:Keyword ;
  schema:name "transect"@en ;
  schema:description "an imaginary line along which samples of data are collected"@en ;
  dcterms:modified "2026-02-19T08:26:07.163921Z"^^xsd:dateTime .

oakcurric:keyword-quadrat
  a curric:Keyword ;
  schema:name "quadrat"@en ;
  schema:description "a square frame used at ground level to show the limits of a sample area"@en ;
  dcterms:modified "2026-02-19T08:26:07.163937Z"^^xsd:dateTime .

oakcurric:keyword-raw-material
  a curric:Keyword ;
  schema:name "raw material"@en ;
  schema:description """Raw materials are things that can be grown or dug out of the ground and processed or used in the manufacture of goods."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164052Z"^^xsd:dateTime .

oakcurric:keyword-sampling
  a curric:Keyword ;
  schema:name "sampling"@en ;
  schema:description """the process of selecting a sample of data to study from a much larger population of data"""@en ;
  dcterms:modified "2026-02-19T08:26:07.164439Z"^^xsd:dateTime .

oakcurric:keyword-sample
  a curric:Keyword ;
  schema:name "sample"@en ;
  schema:description "a selection of data from a much bigger data population"@en ;
  dcterms:modified "2026-02-19T08:26:07.164444Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description "an unfair favouritism for or against something"@en ;
  dcterms:modified "2026-02-19T08:26:07.164453Z"^^xsd:dateTime .

oakcurric:keyword-specialised-cell
  a curric:Keyword ;
  schema:name "specialised cell"@en ;
  schema:description """Cells with adaptations to carry out a particular function in a multicellular organism."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164553Z"^^xsd:dateTime .

oakcurric:keyword-unspecialised-cell
  a curric:Keyword ;
  schema:name "unspecialised cell"@en ;
  schema:description """Cell with no specific function, but has the capability to turn into different types of cells."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164558Z"^^xsd:dateTime .

oakcurric:keyword-differentiation
  a curric:Keyword ;
  schema:name "differentiation"@en ;
  schema:description """The process of an unspecialised cell becoming a specialised one through the mechanism of turning genes on and off."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164562Z"^^xsd:dateTime .

oakcurric:keyword-nucleotides
  a curric:Keyword ;
  schema:name "nucleotides"@en ;
  schema:description "Individual subunits that make up DNA."@en ;
  dcterms:modified "2026-02-19T08:26:07.164571Z"^^xsd:dateTime .

oakcurric:keyword-complementary-base-pairing
  a curric:Keyword ;
  schema:name "complementary base pairing"@en ;
  schema:description "Bases form pairs with one other base: A pairs with T, and C pairs with G."@en ;
  dcterms:modified "2026-02-19T08:26:07.164575Z"^^xsd:dateTime .

oakcurric:keyword-abiotic-factor
  a curric:Keyword ;
  schema:name "abiotic factor"@en ;
  schema:description "Abiotic factors are the non-living components of an ecosystem."@en ;
  dcterms:modified "2026-02-19T08:26:07.164582Z"^^xsd:dateTime .

oakcurric:keyword-mutation
  a curric:Keyword ;
  schema:name "mutation"@en ;
  schema:description "A change in the nucleotide sequence of DNA that can cause mutated genes."@en ;
  dcterms:modified "2026-02-19T08:26:07.164600Z"^^xsd:dateTime .

oakcurric:keyword-genes
  a curric:Keyword ;
  schema:name "genes"@en ;
  schema:description "Short sections of DNA that code for a specific characteristic or protein."@en ;
  dcterms:modified "2026-02-19T08:26:07.164604Z"^^xsd:dateTime .

oakcurric:keyword-competition
  a curric:Keyword ;
  schema:name "competition"@en ;
  schema:description """Competition is when organisms in a community or population are seeking the same limited resource (e.g. food, mates)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164611Z"^^xsd:dateTime .

oakcurric:keyword-physiological
  a curric:Keyword ;
  schema:name "physiological"@en ;
  schema:description """Physiological adaptations are body processes that help an organism to survive and reproduce."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164616Z"^^xsd:dateTime .

oakcurric:keyword-microorganism
  a curric:Keyword ;
  schema:name "microorganism"@en ;
  schema:description "A microorganism is an organism that can only be seen using a microscope."@en ;
  dcterms:modified "2026-02-19T08:26:07.164620Z"^^xsd:dateTime .

oakcurric:keyword-extremophile
  a curric:Keyword ;
  schema:name "extremophile"@en ;
  schema:description """Extremophiles are organisms that are able to successfully survive and reproduce in extreme environments (e.g. very hot/very cold)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164625Z"^^xsd:dateTime .

oakcurric:keyword-embryo
  a curric:Keyword ;
  schema:name "embryo"@en ;
  schema:description "Formed from a zygote by cell division; it is the early stages of development."@en ;
  dcterms:modified "2026-02-19T08:26:07.164660Z"^^xsd:dateTime .

oakcurric:keyword-embryonic-stem-cell
  a curric:Keyword ;
  schema:name "embryonic stem cell"@en ;
  schema:description "A cell from an embryo which can differentiate into any type of cell."@en ;
  dcterms:modified "2026-02-19T08:26:07.164665Z"^^xsd:dateTime .

oakcurric:keyword-adult-stem-cell
  a curric:Keyword ;
  schema:name "adult stem cell"@en ;
  schema:description "Can differentiate into related cells."@en ;
  dcterms:modified "2026-02-19T08:26:07.164669Z"^^xsd:dateTime .

oakcurric:keyword-selective-breeding
  a curric:Keyword ;
  schema:name "Selective breeding"@en ;
  schema:description """The process in which humans choose individuals with desirable traits and mate them in order to make offspring with these desirable traits."""@en ;
  dcterms:modified "2026-02-19T08:26:07.164758Z"^^xsd:dateTime .

oakcurric:keyword-crop
  a curric:Keyword ;
  schema:name "Crop"@en ;
  schema:description "Plants grown on a large scale for food or profit."@en ;
  dcterms:modified "2026-02-19T08:26:07.164762Z"^^xsd:dateTime .

oakcurric:keyword-farm-animal
  a curric:Keyword ;
  schema:name "Farm animal"@en ;
  schema:description "Animals that are kept on farms for food or work."@en ;
  dcterms:modified "2026-02-19T08:26:07.164769Z"^^xsd:dateTime .

oakcurric:keyword-decomposer
  a curric:Keyword ;
  schema:name "decomposer"@en ;
  schema:description """A decomposer is an organism that feeds on the remains of other living organisms (organic matter)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165109Z"^^xsd:dateTime .

oakcurric:keyword-detritus
  a curric:Keyword ;
  schema:name "detritus"@en ;
  schema:description "Detritus is the remains of living organisms."@en ;
  dcterms:modified "2026-02-19T08:26:07.165113Z"^^xsd:dateTime .

oakcurric:keyword-evolution
  a curric:Keyword ;
  schema:name "evolution"@en ;
  schema:description """The process in which the characteristics of species change over many generations, sometimes becoming new species."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165118Z"^^xsd:dateTime .

oakcurric:keyword-natural-selection
  a curric:Keyword ;
  schema:name "natural selection"@en ;
  schema:description """Organisms that are better adapted to their environment are more likely to survive, reproduce and pass on their genes to their offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165122Z"^^xsd:dateTime .

oakcurric:keyword-fossil-record
  a curric:Keyword ;
  schema:name "fossil record"@en ;
  schema:description """All the fossils ever found, and their ages, provide a body of evidence called the fossil record."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165300Z"^^xsd:dateTime .

oakcurric:keyword-common-ancestor
  a curric:Keyword ;
  schema:name "common ancestor"@en ;
  schema:description """A species that several other species evolved from. For example, tigers and lions share a common ancestor."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165305Z"^^xsd:dateTime .

oakcurric:keyword-evolutionary-tree
  a curric:Keyword ;
  schema:name "evolutionary tree"@en ;
  schema:description """A diagram that shows the evolutionary relationships between different groups of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165309Z"^^xsd:dateTime .

oakcurric:keyword-transitional-species
  a curric:Keyword ;
  schema:name "transitional species"@en ;
  schema:description """A species that shows intermediate characteristics from evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-19T08:26:07.165314Z"^^xsd:dateTime .

oakcurric:keyword-antagonistic
  a curric:Keyword ;
  schema:name "antagonistic"@en ;
  schema:description "showing or feeling active opposition or hostility towards someone or something"@en ;
  dcterms:modified "2026-02-19T08:26:07.165327Z"^^xsd:dateTime .

oakcurric:keyword-speciation
  a curric:Keyword ;
  schema:name "speciation"@en ;
  schema:description "When natural selection causes new species to form."@en ;
  dcterms:modified "2026-02-19T08:26:07.165361Z"^^xsd:dateTime .

oakcurric:keyword-parallel
  a curric:Keyword ;
  schema:name "parallel"@en ;
  schema:description "describing something that is similar to something else."@en ;
  dcterms:modified "2026-02-19T08:26:07.165456Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "being exact and precise"@en ;
  dcterms:modified "2026-02-19T08:26:07.165627Z"^^xsd:dateTime .

oakcurric:keyword-extinct
  a curric:Keyword ;
  schema:name "extinct"@en ;
  schema:description "An extinct species has no living members."@en ;
  dcterms:modified "2026-02-19T08:26:07.165654Z"^^xsd:dateTime .

oakcurric:keyword-immune-rejection
  a curric:Keyword ;
  schema:name "immune rejection"@en ;
  schema:description "When a patient’s immune system attacks non-self cells (e.g. transplants)."@en ;
  dcterms:modified "2026-02-19T08:26:07.165671Z"^^xsd:dateTime .

oakcurric:keyword-gametes
  a curric:Keyword ;
  schema:name "gametes"@en ;
  schema:description "An organism's sex cells that contain half the number of chromosomes."@en ;
  dcterms:modified "2026-02-19T08:26:07.166069Z"^^xsd:dateTime .

oakcurric:keyword-meiosis
  a curric:Keyword ;
  schema:name "meiosis"@en ;
  schema:description "A type of cell division that forms the gametes."@en ;
  dcterms:modified "2026-02-19T08:26:07.166073Z"^^xsd:dateTime .

oakcurric:keyword-haploid
  a curric:Keyword ;
  schema:name "haploid"@en ;
  schema:description "A cell with half the number of chromosomes."@en ;
  dcterms:modified "2026-02-19T08:26:07.166078Z"^^xsd:dateTime .

oakcurric:keyword-meristem
  a curric:Keyword ;
  schema:name "meristem"@en ;
  schema:description """unspecialised cells that undergo mitosis and can differentiate into any type of plant cell"""@en ;
  dcterms:modified "2026-02-19T08:26:07.166111Z"^^xsd:dateTime .

oakcurric:keyword-shoot
  a curric:Keyword ;
  schema:name "shoot"@en ;
  schema:description "where new plant growth occurs above the ground"@en ;
  dcterms:modified "2026-02-19T08:26:07.166116Z"^^xsd:dateTime .

oakcurric:keyword-root
  a curric:Keyword ;
  schema:name "root"@en ;
  schema:description "where new plant growth occurs underground"@en ;
  dcterms:modified "2026-02-19T08:26:07.166120Z"^^xsd:dateTime .

oakcurric:keyword-xylem
  a curric:Keyword ;
  schema:name "xylem"@en ;
  schema:description "a plant tissue that transports water upwards through the plant"@en ;
  dcterms:modified "2026-02-19T08:26:07.166125Z"^^xsd:dateTime .

oakcurric:keyword-phloem
  a curric:Keyword ;
  schema:name "phloem"@en ;
  schema:description "a plant tissue that transports sugars through the plant"@en ;
  dcterms:modified "2026-02-19T08:26:07.166129Z"^^xsd:dateTime .

oakcurric:keyword-sterilisation
  a curric:Keyword ;
  schema:name "sterilisation"@en ;
  schema:description "the process of having a medical operation to make it impossible to have children"@en ;
  dcterms:modified "2026-02-19T08:26:07.166618Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description "the action of moving something from its place or position"@en ;
  dcterms:modified "2026-02-19T08:26:07.166779Z"^^xsd:dateTime .

oakcurric:keyword-carbon-sink
  a curric:Keyword ;
  schema:name "carbon sink"@en ;
  schema:description "a natural or artificial system that absorbs more carbon dioxide than it releases"@en ;
  dcterms:modified "2026-02-19T08:26:07.167384Z"^^xsd:dateTime .

oakcurric:keyword-light-source
  a curric:Keyword ;
  schema:name "light source"@en ;
  schema:description "an object that emits light"@en ;
  dcterms:modified "2026-02-19T08:26:07.167397Z"^^xsd:dateTime .

oakcurric:keyword-light-waves
  a curric:Keyword ;
  schema:name "light waves"@en ;
  schema:description "oscillations/ripples in electric and magnetic fields"@en ;
  dcterms:modified "2026-02-19T08:26:07.167401Z"^^xsd:dateTime .

oakcurric:keyword-inversely-proportional
  a curric:Keyword ;
  schema:name "inversely proportional"@en ;
  schema:description """variables are inversely proportional when one increases and the other decreases at the same (proportional) rate, e.g. as one variable doubles, the other variable halves"""@en ;
  dcterms:modified "2026-02-19T08:26:07.167406Z"^^xsd:dateTime .

oakcurric:keyword-inverse-square-law
  a curric:Keyword ;
  schema:name "inverse square law"@en ;
  schema:description """light intensity is inversely proportional to the square of the distance from the light source"""@en ;
  dcterms:modified "2026-02-19T08:26:07.167410Z"^^xsd:dateTime .

oakcurric:keyword-drag
  a curric:Keyword ;
  schema:name "drag"@en ;
  schema:description """When an object moves through a liquid or a gas (a fluid), a drag force acts on it as it pushes particles out of its way."""@en ;
  dcterms:modified "2026-02-19T08:26:07.167546Z"^^xsd:dateTime .

oakcurric:keyword-fertiliser
  a curric:Keyword ;
  schema:name "fertiliser"@en ;
  schema:description "Fertiliser are minerals that are added to the soil to help plants to grow."@en ;
  dcterms:modified "2026-02-19T08:26:07.167817Z"^^xsd:dateTime .

oakcurric:keyword-eutrophication
  a curric:Keyword ;
  schema:name "eutrophication"@en ;
  schema:description """Eutrophication is the process in which a body of water is overly enriched with plant nutrients. This leads to excessive growth of simple plants such as algae."""@en ;
  dcterms:modified "2026-02-19T08:26:07.167823Z"^^xsd:dateTime .

oakcurric:keyword-indigenous-species
  a curric:Keyword ;
  schema:name "indigenous species"@en ;
  schema:description """Indigenous species are a species that occurs naturally in an ecosystem. They are sometimes referred to as native species."""@en ;
  dcterms:modified "2026-02-19T08:26:07.167828Z"^^xsd:dateTime .

oakcurric:keyword-contact-force
  a curric:Keyword ;
  schema:name "contact force"@en ;
  schema:description "Contact forces only act when objects are touching."@en ;
  dcterms:modified "2026-02-19T08:26:07.167922Z"^^xsd:dateTime .

oakcurric:keyword-non-contact-force
  a curric:Keyword ;
  schema:name "non-contact force"@en ;
  schema:description "Non-contact forces can act with or without objects touching."@en ;
  dcterms:modified "2026-02-19T08:26:07.167927Z"^^xsd:dateTime .

oakcurric:keyword-period
  a curric:Keyword ;
  schema:name "period"@en ;
  schema:description """A period is a row on the periodic table that corresponds to the number of electron shells in an atom."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168049Z"^^xsd:dateTime .

oakcurric:keyword-fair-test
  a curric:Keyword ;
  schema:name "fair test"@en ;
  schema:description """In a fair test, only the variable being tested is changed, so any differences in results can only be due to that variable."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168247Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-result
  a curric:Keyword ;
  schema:name "anomalous result"@en ;
  schema:description """Anomalous results are ones that do not fit the pattern we see for other measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168252Z"^^xsd:dateTime .

oakcurric:keyword-pure-substance
  a curric:Keyword ;
  schema:name "pure substance"@en ;
  schema:description "A pure substance contains only one type of chemical"@en ;
  dcterms:modified "2026-02-19T08:26:07.168544Z"^^xsd:dateTime .

oakcurric:keyword-impurity
  a curric:Keyword ;
  schema:name "impurity"@en ;
  schema:description """An impurity is a chemical that is found in a material in very small amounts, but can change the material's properties"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168549Z"^^xsd:dateTime .

oakcurric:keyword-saturated-solution
  a curric:Keyword ;
  schema:name "saturated solution"@en ;
  schema:description """A saturated solution is one in which no more solute can dissolve in the solvent at a given temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168554Z"^^xsd:dateTime .

oakcurric:keyword-solubility
  a curric:Keyword ;
  schema:name "solubility"@en ;
  schema:description """Solubility refers to how well a solute is able to dissolve in a solvent to create a solution."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168558Z"^^xsd:dateTime .

oakcurric:keyword-random
  a curric:Keyword ;
  schema:name "random"@en ;
  schema:description "Happens without a clear pattern, making it unpredictable."@en ;
  dcterms:modified "2026-02-19T08:26:07.168570Z"^^xsd:dateTime .

oakcurric:keyword-particles
  a curric:Keyword ;
  schema:name "particles"@en ;
  schema:description "What solids, liquids and gases are made up from."@en ;
  dcterms:modified "2026-02-19T08:26:07.168583Z"^^xsd:dateTime .

oakcurric:keyword-solute
  a curric:Keyword ;
  schema:name "solute"@en ;
  schema:description "A solute is a substance that has dissolved into a solvent."@en ;
  dcterms:modified "2026-02-19T08:26:07.168599Z"^^xsd:dateTime .

oakcurric:keyword-soluble
  a curric:Keyword ;
  schema:name "soluble"@en ;
  schema:description "When a solute dissolves, it is described as soluble."@en ;
  dcterms:modified "2026-02-19T08:26:07.168604Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-mass
  a curric:Keyword ;
  schema:name "conservation of mass"@en ;
  schema:description """The combined mass of starting materials equals the combined mass of the end products."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168608Z"^^xsd:dateTime .

oakcurric:keyword-dissolve
  a curric:Keyword ;
  schema:name "dissolve"@en ;
  schema:description """Occurs when a substance's particles separate and spread throughout the particles of a solvent resulting in it no longer being seen."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168613Z"^^xsd:dateTime .

oakcurric:keyword-insoluble
  a curric:Keyword ;
  schema:name "insoluble"@en ;
  schema:description """If a substance does not dissolve in a particular solvent, it is described as insoluble."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168617Z"^^xsd:dateTime .

oakcurric:keyword-melting
  a curric:Keyword ;
  schema:name "melting"@en ;
  schema:description """Melting occurs when a substance in the solid state is heated and its particles move into the arrangement of a substance in the liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168622Z"^^xsd:dateTime .

oakcurric:keyword-force-of-attraction
  a curric:Keyword ;
  schema:name "force of attraction"@en ;
  schema:description """A force of attraction is a pulling force that keeps things, such as particles, close together."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168626Z"^^xsd:dateTime .

oakcurric:keyword-amplitude
  a curric:Keyword ;
  schema:name "amplitude"@en ;
  schema:description "Measures the size of a vibration, i.e. how far an object vibrates."@en ;
  dcterms:modified "2026-02-19T08:26:07.168642Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description """The independent variable is the variable that is changed during an investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168646Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description """The dependent variable is the variable that is measured or observed during an investigation; it changes as a result of varying the independent variable."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168651Z"^^xsd:dateTime .

oakcurric:keyword-cooling-curve
  a curric:Keyword ;
  schema:name "cooling curve"@en ;
  schema:description "a line graph that shows how a cooling object’s temperature changes with time"@en ;
  dcterms:modified "2026-02-19T08:26:07.168674Z"^^xsd:dateTime .

oakcurric:keyword-dissipate
  a curric:Keyword ;
  schema:name "dissipate"@en ;
  schema:description "to spread out"@en ;
  dcterms:modified "2026-02-19T08:26:07.168680Z"^^xsd:dateTime .

oakcurric:keyword-chromatography
  a curric:Keyword ;
  schema:name "chromatography"@en ;
  schema:description """Chromatography is a technique that separates a mixture into its different parts and the results can be analysed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168708Z"^^xsd:dateTime .

oakcurric:keyword-chromatogram
  a curric:Keyword ;
  schema:name "chromatogram"@en ;
  schema:description """A chromatogram is the resultant pattern on the stationary phase after chromatography has been carried out."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168712Z"^^xsd:dateTime .

oakcurric:keyword-filtration
  a curric:Keyword ;
  schema:name "filtration"@en ;
  schema:description "The process of separating an insoluble substance from a liquid using a filter."@en ;
  dcterms:modified "2026-02-19T08:26:07.168724Z"^^xsd:dateTime .

oakcurric:keyword-residue
  a curric:Keyword ;
  schema:name "residue"@en ;
  schema:description "The insoluble solid that remains in the filter paper."@en ;
  dcterms:modified "2026-02-19T08:26:07.168740Z"^^xsd:dateTime .

oakcurric:keyword-filtrate
  a curric:Keyword ;
  schema:name "filtrate"@en ;
  schema:description """The liquid that passes through the filter paper, separating from the insoluble solid."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168745Z"^^xsd:dateTime .

oakcurric:keyword-distillation
  a curric:Keyword ;
  schema:name "distillation"@en ;
  schema:description """Distillation is a separation technique that uses boiling and condensation to remove and isolate the liquid part of a mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168767Z"^^xsd:dateTime .

oakcurric:keyword-boiling
  a curric:Keyword ;
  schema:name "boiling"@en ;
  schema:description """Boiling occurs when a substance in the liquid state is heated and changes to the gas state with gas bubbles formed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168772Z"^^xsd:dateTime .

oakcurric:keyword-condensation
  a curric:Keyword ;
  schema:name "condensation"@en ;
  schema:description """Condensation is the process by which a substance in the gas state is cooled and changes to a liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168777Z"^^xsd:dateTime .

oakcurric:keyword-particle-model
  a curric:Keyword ;
  schema:name "particle model"@en ;
  schema:description "the idea that all objects are made of tiny particles that are in constant motion"@en ;
  dcterms:modified "2026-02-19T08:26:07.168840Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conduction
  a curric:Keyword ;
  schema:name "thermal conduction"@en ;
  schema:description """a change in temperature due to particles passing on their motion through their bonds or by particle collisions"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168849Z"^^xsd:dateTime .

oakcurric:keyword-forces-of-attraction
  a curric:Keyword ;
  schema:name "forces of attraction"@en ;
  schema:description """hold together the neighbouring particles in a solid or liquid; these forces are weaker the further apart the particles are"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168863Z"^^xsd:dateTime .

oakcurric:keyword-delivery-tube
  a curric:Keyword ;
  schema:name "delivery tube"@en ;
  schema:description """A delivery tube is a thin tube used to transfer (i.e. "deliver") a substance (usually in the gas state) from one container to another."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168872Z"^^xsd:dateTime .

oakcurric:keyword-condenser
  a curric:Keyword ;
  schema:name "condenser"@en ;
  schema:description """A condenser is a piece of apparatus composed of a tube surrounded by a cold layer, usually cold water."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168876Z"^^xsd:dateTime .

oakcurric:keyword-distillate
  a curric:Keyword ;
  schema:name "distillate"@en ;
  schema:description """The liquid that is condensed from the gas state during distillation is called the distillate."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168881Z"^^xsd:dateTime .

oakcurric:keyword-radiation
  a curric:Keyword ;
  schema:name "radiation"@en ;
  schema:description """a form of energy that, when it comes from a nuclear explosion, can be very dangerous to health"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168908Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-force
  a curric:Keyword ;
  schema:name "gravitational force"@en ;
  schema:description """Gravitational forces pull objects towards large objects like planets, moons and stars."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169049Z"^^xsd:dateTime .

oakcurric:keyword-concentration
  a curric:Keyword ;
  schema:name "concentration"@en ;
  schema:description "Concentration is the number of particles in a volume of liquid or gas."@en ;
  dcterms:modified "2026-02-19T08:26:07.169119Z"^^xsd:dateTime .

oakcurric:keyword-melting-point
  a curric:Keyword ;
  schema:name "melting point"@en ;
  schema:description """The melting point of a substance is the temperature at which it changes from a solid state to a liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169132Z"^^xsd:dateTime .

oakcurric:keyword-absorption
  a curric:Keyword ;
  schema:name "absorption"@en ;
  schema:description """Absorption is the process of moving nutrients from the digestive system into the blood."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169205Z"^^xsd:dateTime .

oakcurric:keyword-magnitude
  a curric:Keyword ;
  schema:name "magnitude"@en ;
  schema:description """how much energy is released during an earthquake, often measured in Mw (moment magnitude)"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169288Z"^^xsd:dateTime .

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "Range"@en ;
  schema:description """The range is a measure of spread. It is found by finding the difference between the highest and lowest values."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169345Z"^^xsd:dateTime .

oakcurric:keyword-excess-reactant
  a curric:Keyword ;
  schema:name "excess reactant"@en ;
  schema:description """any reactant present in a greater amount than is necessary to completely react with the limiting reactant"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169558Z"^^xsd:dateTime .

oakcurric:keyword-crystallisation
  a curric:Keyword ;
  schema:name "crystallisation"@en ;
  schema:description """a process that forms solid crystals from a saturated solution by evaporating the solvent"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169562Z"^^xsd:dateTime .

oakcurric:keyword-resultant-force
  a curric:Keyword ;
  schema:name "resultant force"@en ;
  schema:description "is the overall effect of the forces acting on an object"@en ;
  dcterms:modified "2026-02-19T08:26:07.169566Z"^^xsd:dateTime .

oakcurric:keyword-terminal-velocity
  a curric:Keyword ;
  schema:name "terminal velocity"@en ;
  schema:description """is the velocity of an object falling through a fluid, when there is zero resultant force"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169571Z"^^xsd:dateTime .

oakcurric:keyword-binary-ionic-substance
  a curric:Keyword ;
  schema:name "binary ionic substance"@en ;
  schema:description """is made up of two different elements, one of which is a metal and the other a non-metal element."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169575Z"^^xsd:dateTime .

oakcurric:keyword-dot-and-cross-diagram
  a curric:Keyword ;
  schema:name "dot-and-cross diagram"@en ;
  schema:description """is used to show how chemical bonds are formed between atoms. The electrons from one atom are shown as dots and the electrons from the other atom are shown as crosses."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169580Z"^^xsd:dateTime .

oakcurric:keyword-ray
  a curric:Keyword ;
  schema:name "Ray"@en ;
  schema:description """A ray is a straight line drawn to represent the direction that a light wave travels."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169584Z"^^xsd:dateTime .

oakcurric:keyword-normal
  a curric:Keyword ;
  schema:name "normal"@en ;
  schema:description "The normal is an imaginary line drawn at 90° to a surface."@en ;
  dcterms:modified "2026-02-19T08:26:07.169589Z"^^xsd:dateTime .

oakcurric:keyword-wavefront
  a curric:Keyword ;
  schema:name "wavefront"@en ;
  schema:description "Wavefronts are lines drawn to represent peaks of a wave."@en ;
  dcterms:modified "2026-02-19T08:26:07.169593Z"^^xsd:dateTime .

oakcurric:keyword-control
  a curric:Keyword ;
  schema:name "control"@en ;
  schema:description "a variable which is kept constant between all experiments"@en ;
  dcterms:modified "2026-02-19T08:26:07.169598Z"^^xsd:dateTime .

oakcurric:keyword-filament-lamp
  a curric:Keyword ;
  schema:name "filament lamp"@en ;
  schema:description "a type of lamp that uses a hot wire to emit light"@en ;
  dcterms:modified "2026-02-19T08:26:07.169602Z"^^xsd:dateTime .

oakcurric:keyword-ohmic-conductor
  a curric:Keyword ;
  schema:name "ohmic conductor"@en ;
  schema:description "a conductor for which the current is directly proportional to the p.d."@en ;
  dcterms:modified "2026-02-19T08:26:07.169606Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional
  a curric:Keyword ;
  schema:name "directly proportional"@en ;
  schema:description "a relationship between variables in which one is a multiple of the other"@en ;
  dcterms:modified "2026-02-19T08:26:07.169611Z"^^xsd:dateTime .

oakcurric:keyword-free-electron
  a curric:Keyword ;
  schema:name "free electron"@en ;
  schema:description """an electron from the outer shell of an atom that is free to move from ion to ion through a metal"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169617Z"^^xsd:dateTime .

oakcurric:keyword-optimum
  a curric:Keyword ;
  schema:name "optimum"@en ;
  schema:description "The conditions under which the maximum rate of reaction occurs."@en ;
  dcterms:modified "2026-02-19T08:26:07.169622Z"^^xsd:dateTime .

oakcurric:keyword-denatured
  a curric:Keyword ;
  schema:name "denatured"@en ;
  schema:description """A permanent change in the shape of an enzyme that stops it from working properly."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169629Z"^^xsd:dateTime .

oakcurric:keyword-nucleon
  a curric:Keyword ;
  schema:name "nucleon"@en ;
  schema:description "the term for particles in a nucleus (protons and neutrons)"@en ;
  dcterms:modified "2026-02-19T08:26:07.169634Z"^^xsd:dateTime .

oakcurric:keyword-atomic-proton-number
  a curric:Keyword ;
  schema:name "atomic (proton) number"@en ;
  schema:description "the number of protons within a particular nucleus"@en ;
  dcterms:modified "2026-02-19T08:26:07.169638Z"^^xsd:dateTime .

oakcurric:keyword-mass-nucleon-number
  a curric:Keyword ;
  schema:name "mass (nucleon) number"@en ;
  schema:description "the total number of nucleons within a particular nucleus (protons + neutrons)"@en ;
  dcterms:modified "2026-02-19T08:26:07.169643Z"^^xsd:dateTime .

oakcurric:keyword-isotopes
  a curric:Keyword ;
  schema:name "isotopes"@en ;
  schema:description "atoms of the same element with differing numbers of neutrons"@en ;
  dcterms:modified "2026-02-19T08:26:07.169647Z"^^xsd:dateTime .

oakcurric:keyword-dynamic-equilibrium
  a curric:Keyword ;
  schema:name "dynamic equilibrium"@en ;
  schema:description """occurs in a closed system when the forward and backward reactions of a reversible chemical reaction occur at the same rate; and the concentrations of reactants and products remain constant."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169652Z"^^xsd:dateTime .

oakcurric:keyword-reaction-rate
  a curric:Keyword ;
  schema:name "reaction rate"@en ;
  schema:description """is the speed with which a chemical reaction takes place, measured by the amount of a reactant used or amount of product formed in a given time."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169656Z"^^xsd:dateTime .

oakcurric:keyword-closed-system
  a curric:Keyword ;
  schema:name "closed system"@en ;
  schema:description """is one in which matter cannot enter or leave the observed environment, allowing only energy transfer between the system and its surrounding environment."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169660Z"^^xsd:dateTime .

oakcurric:keyword-cell-wall
  a curric:Keyword ;
  schema:name "cell wall"@en ;
  schema:description """A subcellular structure made from cellulose fibres that strengthens the cell and supports the plant."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169665Z"^^xsd:dateTime .

oakcurric:keyword-permanent-vacuole
  a curric:Keyword ;
  schema:name "permanent vacuole"@en ;
  schema:description "A subcellular structure filled with cell sap that helps keep the cell turgid."@en ;
  dcterms:modified "2026-02-19T08:26:07.169670Z"^^xsd:dateTime .

oakcurric:keyword-repeating-unit
  a curric:Keyword ;
  schema:name "repeating unit"@en ;
  schema:description "The section of a polymer that repeats is known as the repeating unit."@en ;
  dcterms:modified "2026-02-19T08:26:07.169692Z"^^xsd:dateTime .

oakcurric:keyword-simple-molecular
  a curric:Keyword ;
  schema:name "simple molecular"@en ;
  schema:description """Simple molecular substances are made up of two or more atoms covalently bonded together to form a distinct unit."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169697Z"^^xsd:dateTime .

oakcurric:keyword-intermolecular-force
  a curric:Keyword ;
  schema:name "intermolecular force"@en ;
  schema:description """Intermolecular forces are weak forces of attraction between molecules and molecular substances."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169704Z"^^xsd:dateTime .

oakcurric:keyword-giant-covalent
  a curric:Keyword ;
  schema:name "giant covalent"@en ;
  schema:description """A giant covalent substance has a large regular arrangement of atoms all joined together by covalent bonds."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169708Z"^^xsd:dateTime .

oakcurric:keyword-reversebias
  a curric:Keyword ;
  schema:name "reverse–bias"@en ;
  schema:description "When a diode is reverse–biased, it prevents current from flowing."@en ;
  dcterms:modified "2026-02-19T08:26:07.169713Z"^^xsd:dateTime .

oakcurric:keyword-forwardbias
  a curric:Keyword ;
  schema:name "forward–bias"@en ;
  schema:description "When a diode is forward–biased, it allows current to flow."@en ;
  dcterms:modified "2026-02-19T08:26:07.169717Z"^^xsd:dateTime .

oakcurric:keyword-threshold-pd
  a curric:Keyword ;
  schema:name "threshold p.d."@en ;
  schema:description """The threshold p.d. is the potential difference at which a diode allows current to flow."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169721Z"^^xsd:dateTime .

oakcurric:keyword-fuse
  a curric:Keyword ;
  schema:name "fuse"@en ;
  schema:description "A fuse is a component that has a wire that melts if the current is too high."@en ;
  dcterms:modified "2026-02-19T08:26:07.169726Z"^^xsd:dateTime .

oakcurric:keyword-ion-lattice
  a curric:Keyword ;
  schema:name "ion lattice"@en ;
  schema:description """In a solid metal, the regular and repeating pattern that metal ions are arranged in is known as an ion lattice."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169730Z"^^xsd:dateTime .

oakcurric:keyword-classification-key
  a curric:Keyword ;
  schema:name "classification key"@en ;
  schema:description """A classification key is a series of questions about the features of organisms that help us to classify them correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169735Z"^^xsd:dateTime .

oakcurric:keyword-component
  a curric:Keyword ;
  schema:name "component"@en ;
  schema:description "A component refers to a part of something, e.g. a tyre on a car."@en ;
  dcterms:modified "2026-02-19T08:26:07.169739Z"^^xsd:dateTime .

oakcurric:keyword-electrical-insulator
  a curric:Keyword ;
  schema:name "electrical insulator"@en ;
  schema:description "is a material that does not conduct electric current"@en ;
  dcterms:modified "2026-02-19T08:26:07.169746Z"^^xsd:dateTime .

oakcurric:keyword-motor-coil
  a curric:Keyword ;
  schema:name "motor coil"@en ;
  schema:description """a coil of insulated wire that spins inside an electric motor when a current flows through it"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169751Z"^^xsd:dateTime .

oakcurric:keyword-axle
  a curric:Keyword ;
  schema:name "axle"@en ;
  schema:description "a rod at the centre of wheels and gears around which they turn"@en ;
  dcterms:modified "2026-02-19T08:26:07.169755Z"^^xsd:dateTime .

oakcurric:keyword-yoke
  a curric:Keyword ;
  schema:name "yoke"@en ;
  schema:description """in a motor kit, a U–shaped piece of iron that holds two magnets in place to create a uniform magnetic field"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169760Z"^^xsd:dateTime .

oakcurric:keyword-base
  a curric:Keyword ;
  schema:name "Base"@en ;
  schema:description "The base is the side which is perpendicular to the shape’s height."@en ;
  dcterms:modified "2026-02-19T08:26:07.169779Z"^^xsd:dateTime .

oakcurric:keyword-series-circuit
  a curric:Keyword ;
  schema:name "series circuit"@en ;
  schema:description "an electrical circuit with a single loop"@en ;
  dcterms:modified "2026-02-19T08:26:07.169838Z"^^xsd:dateTime .

oakcurric:keyword-potential-difference-pd
  a curric:Keyword ;
  schema:name "potential difference (p.d.)"@en ;
  schema:description "a measure of the push an electric field gives to charges"@en ;
  dcterms:modified "2026-02-19T08:26:07.169843Z"^^xsd:dateTime .

oakcurric:keyword-potential-divider
  a curric:Keyword ;
  schema:name "potential divider"@en ;
  schema:description """a series circuit that divides the p.d. across a power supply into two or more smaller voltages"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169847Z"^^xsd:dateTime .

oakcurric:keyword-dynamics-trolley
  a curric:Keyword ;
  schema:name "dynamics trolley"@en ;
  schema:description """A dynamics trolley is a wheeled device used in experiments to study motion, designed to move smoothly over flat surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169852Z"^^xsd:dateTime .

oakcurric:keyword-average-speed
  a curric:Keyword ;
  schema:name "average speed"@en ;
  schema:description """The average speed of an object is the total distance travelled divided by the total time taken for a journey."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169858Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-speed
  a curric:Keyword ;
  schema:name "instantaneous speed"@en ;
  schema:description "The instantaneous speed of an object is its speed at a specific moment in time."@en ;
  dcterms:modified "2026-02-19T08:26:07.169863Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-reading
  a curric:Keyword ;
  schema:name "anomalous reading"@en ;
  schema:description """An anomalous reading is a result that is significantly outside the expected pattern in a set of results."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169867Z"^^xsd:dateTime .

oakcurric:keyword-displacement-time-graph
  a curric:Keyword ;
  schema:name "displacement-time graph"@en ;
  schema:description """A displacement-time graph shows the change in displacement over a time period. The displacement along a straight line can be positive or negative."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169872Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description "The gradient on a displacement-time graph gives the instantaneous velocity."@en ;
  dcterms:modified "2026-02-19T08:26:07.169878Z"^^xsd:dateTime .

oakcurric:keyword-tangent
  a curric:Keyword ;
  schema:name "tangent"@en ;
  schema:description """A tangent drawn to the gradient on a curving displacement-time graph will give the instantaneous velocity."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169883Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-velocity
  a curric:Keyword ;
  schema:name "instantaneous velocity"@en ;
  schema:description """The instantaneous velocity is the velocity of an object at a particular moment in time."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169887Z"^^xsd:dateTime .

oakcurric:keyword-oscilloscope
  a curric:Keyword ;
  schema:name "oscilloscope"@en ;
  schema:description "A piece of equipment that can display a representation of a sound wave."@en ;
  dcterms:modified "2026-02-19T08:26:07.169892Z"^^xsd:dateTime .

oakcurric:keyword-molecule
  a curric:Keyword ;
  schema:name "molecule"@en ;
  schema:description """A molecule is a particle consisting of a fixed number of (two or more) non-metal atoms covalently bonded together."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169972Z"^^xsd:dateTime .

oakcurric:keyword-noble-gas-configuration
  a curric:Keyword ;
  schema:name "noble gas configuration"@en ;
  schema:description """When an atom has a full outer shell of electrons, it has a noble gas electron configuration."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169977Z"^^xsd:dateTime .

oakcurric:keyword-outer-shell
  a curric:Keyword ;
  schema:name "outer shell"@en ;
  schema:description """The outer shell is the highest energy level in an atom and is usually the furthest from the nucleus."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169981Z"^^xsd:dateTime .

oakcurric:keyword-cation
  a curric:Keyword ;
  schema:name "cation"@en ;
  schema:description "A particle with a positive charge."@en ;
  dcterms:modified "2026-02-19T08:26:07.169986Z"^^xsd:dateTime .

oakcurric:keyword-anion
  a curric:Keyword ;
  schema:name "anion"@en ;
  schema:description "A particle with a negative charge."@en ;
  dcterms:modified "2026-02-19T08:26:07.169990Z"^^xsd:dateTime .

oakcurric:keyword-random-error
  a curric:Keyword ;
  schema:name "random error"@en ;
  schema:description """causes results to differ by different amounts due to a factor other than the independent variable (the factor we changed)"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170015Z"^^xsd:dateTime .

oakcurric:keyword-van-de-graaff-generator
  a curric:Keyword ;
  schema:name "Van de Graaff generator"@en ;
  schema:description "A device that produces electric charge and is used in electrostatic experiments."@en ;
  dcterms:modified "2026-02-19T08:26:07.170020Z"^^xsd:dateTime .

oakcurric:keyword-charge
  a curric:Keyword ;
  schema:name "charge"@en ;
  schema:description "An electrical property; it can either be positive or negative."@en ;
  dcterms:modified "2026-02-19T08:26:07.170024Z"^^xsd:dateTime .

oakcurric:keyword-electric-field
  a curric:Keyword ;
  schema:name "electric field"@en ;
  schema:description """The invisible field around a charged object that causes another charged object to experience a force."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170028Z"^^xsd:dateTime .

oakcurric:keyword-coulomb
  a curric:Keyword ;
  schema:name "coulomb"@en ;
  schema:description "The unit of electric charge."@en ;
  dcterms:modified "2026-02-19T08:26:07.170033Z"^^xsd:dateTime .

oakcurric:keyword-ampere
  a curric:Keyword ;
  schema:name "ampere"@en ;
  schema:description "The unit of electric current."@en ;
  dcterms:modified "2026-02-19T08:26:07.170037Z"^^xsd:dateTime .

oakcurric:keyword-scalar-quantity
  a curric:Keyword ;
  schema:name "scalar quantity"@en ;
  schema:description """Some quantities only have magnitude (size), and not direction. This includes distance and speed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170042Z"^^xsd:dateTime .

oakcurric:keyword-relative-speed
  a curric:Keyword ;
  schema:name "relative speed"@en ;
  schema:description """The relative speed of objects is the difference in their speeds taking into account direction of movement."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170048Z"^^xsd:dateTime .

oakcurric:keyword-composition
  a curric:Keyword ;
  schema:name "Composition"@en ;
  schema:description """The composition of a whole number is the way in which the whole number is made up. For example, ten is composed of seven and three."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170138Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-incidence
  a curric:Keyword ;
  schema:name "angle of incidence"@en ;
  schema:description "the angle between the incident ray and the normal when light hits a mirror"@en ;
  dcterms:modified "2026-02-19T08:26:07.170181Z"^^xsd:dateTime .

oakcurric:keyword-electric-charge
  a curric:Keyword ;
  schema:name "electric charge"@en ;
  schema:description "an electrical property; it can either be positive or negative"@en ;
  dcterms:modified "2026-02-19T08:26:07.170228Z"^^xsd:dateTime .

oakcurric:keyword-parallel-circuit
  a curric:Keyword ;
  schema:name "parallel circuit"@en ;
  schema:description "a circuit with separate branches connected to the battery"@en ;
  dcterms:modified "2026-02-19T08:26:07.170238Z"^^xsd:dateTime .

oakcurric:keyword-electric-current
  a curric:Keyword ;
  schema:name "electric current"@en ;
  schema:description "a measure of the amount of charge passing a given point in one second"@en ;
  dcterms:modified "2026-02-19T08:26:07.170243Z"^^xsd:dateTime .

oakcurric:keyword-light-dependent-resistor
  a curric:Keyword ;
  schema:name "light-dependent resistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly bright light"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170248Z"^^xsd:dateTime .

oakcurric:keyword-semiconductor
  a curric:Keyword ;
  schema:name "semiconductor"@en ;
  schema:description "a material that has both metallic and non-metallic properties"@en ;
  dcterms:modified "2026-02-19T08:26:07.170252Z"^^xsd:dateTime .

oakcurric:keyword-thermistor
  a curric:Keyword ;
  schema:name "thermistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly high temperatures"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170256Z"^^xsd:dateTime .

oakcurric:keyword-velocity-time-graph
  a curric:Keyword ;
  schema:name "velocity-time graph"@en ;
  schema:description "A velocity-time graph shows the velocity of an object over a period of time."@en ;
  dcterms:modified "2026-02-19T08:26:07.170279Z"^^xsd:dateTime .

oakcurric:keyword-acceleration
  a curric:Keyword ;
  schema:name "acceleration"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how much the velocity changes per second."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170284Z"^^xsd:dateTime .

oakcurric:keyword-deceleration
  a curric:Keyword ;
  schema:name "deceleration"@en ;
  schema:description """Deceleration is used to describe a change in velocity where the object slows down."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170288Z"^^xsd:dateTime .

oakcurric:keyword-genetic-variant
  a curric:Keyword ;
  schema:name "genetic variant"@en ;
  schema:description """A genetic variant is produced when a mutation causes a change in the genetic sequence of a gene or a non-coding region of DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170412Z"^^xsd:dateTime .

oakcurric:keyword-exothermic
  a curric:Keyword ;
  schema:name "exothermic"@en ;
  schema:description """An exothermic chemical reaction is a type of reaction in which energy is transferred from the reactants to the surroundings, e.g. combustion."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170416Z"^^xsd:dateTime .

oakcurric:keyword-activation-energy
  a curric:Keyword ;
  schema:name "activation energy"@en ;
  schema:description """The minimum energy that the particles must have in order to react is known as the activation energy."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170421Z"^^xsd:dateTime .

oakcurric:keyword-octet-rule
  a curric:Keyword ;
  schema:name "octet rule"@en ;
  schema:description """The tendency for atoms to fill their outer shell to 8 electrons to become stable. This occurs through chemical bonding, and results in the electron configuration of a noble gas."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170425Z"^^xsd:dateTime .

oakcurric:keyword-covalent-bond
  a curric:Keyword ;
  schema:name "covalent bond"@en ;
  schema:description """The strong electrostatic attraction between a shared pair of electrons and the nuclei of the bonded atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170430Z"^^xsd:dateTime .

oakcurric:keyword-organic-compound
  a curric:Keyword ;
  schema:name "organic compound"@en ;
  schema:description """A chemical compound in which one or more atoms of carbon are covalently linked to atoms of other elements, most commonly hydrogen, oxygen, or nitrogen."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170434Z"^^xsd:dateTime .

oakcurric:keyword-variable-resistor
  a curric:Keyword ;
  schema:name "variable resistor"@en ;
  schema:description "a resistor that can be easily changed to any value in its range"@en ;
  dcterms:modified "2026-02-19T08:26:07.170439Z"^^xsd:dateTime .

oakcurric:keyword-repeat-reading
  a curric:Keyword ;
  schema:name "repeat reading"@en ;
  schema:description "when a measurement is taken again to improve the experiment"@en ;
  dcterms:modified "2026-02-19T08:26:07.170443Z"^^xsd:dateTime .

oakcurric:keyword-best-fit-line
  a curric:Keyword ;
  schema:name "best fit line"@en ;
  schema:description """a line that shows the underlying trend of a set of results on a graph, it can be straight or curved"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170447Z"^^xsd:dateTime .

oakcurric:keyword-crest
  a curric:Keyword ;
  schema:name "crest"@en ;
  schema:description "the crest of a wave is the top or peak of the wave."@en ;
  dcterms:modified "2026-02-19T08:26:07.170452Z"^^xsd:dateTime .

oakcurric:keyword-trough
  a curric:Keyword ;
  schema:name "trough"@en ;
  schema:description "the trough of a wave is the lowest point of the wave."@en ;
  dcterms:modified "2026-02-19T08:26:07.170457Z"^^xsd:dateTime .

oakcurric:keyword-wavelength
  a curric:Keyword ;
  schema:name "wavelength"@en ;
  schema:description """wavelength of a transverse wave is the distance between one wave crest (or trough) and the next."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170461Z"^^xsd:dateTime .

oakcurric:keyword-kilograms-per-cubic-metre
  a curric:Keyword ;
  schema:name "kilograms per cubic metre"@en ;
  schema:description """the unit for density when mass is measured in kilograms (kg) and volume in cubic metres (m³), written as kg/m³"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170468Z"^^xsd:dateTime .

oakcurric:keyword-grams-per-cubic-centimetre
  a curric:Keyword ;
  schema:name "grams per cubic centimetre"@en ;
  schema:description """the unit for density when mass is measured in grams (g) and volume in cubic centimetres (cm³), written as g/cm³"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170472Z"^^xsd:dateTime .

oakcurric:keyword-uniform-magnetic-field
  a curric:Keyword ;
  schema:name "uniform magnetic field"@en ;
  schema:description """has evenly spaced field lines and the strength of the magnetic field is the same everywhere"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170481Z"^^xsd:dateTime .

oakcurric:keyword-flemings-left-hand-rule
  a curric:Keyword ;
  schema:name "Fleming’s left-hand rule"@en ;
  schema:description """indicates the direction a conducting wire is forced to move in a uniform magnetic field"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170486Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-flux-density-b
  a curric:Keyword ;
  schema:name "magnetic flux density, B"@en ;
  schema:description "is a measure of the strength of a magnetic field"@en ;
  dcterms:modified "2026-02-19T08:26:07.170490Z"^^xsd:dateTime .

oakcurric:keyword-tesla-t
  a curric:Keyword ;
  schema:name "tesla (T)"@en ;
  schema:description "is the unit that magnetic flux density is measured in"@en ;
  dcterms:modified "2026-02-19T08:26:07.170495Z"^^xsd:dateTime .

oakcurric:keyword-monomer
  a curric:Keyword ;
  schema:name "monomer"@en ;
  schema:description "Monomers are small molecules that can join together to form a polymer."@en ;
  dcterms:modified "2026-02-19T08:26:07.170576Z"^^xsd:dateTime .

oakcurric:keyword-intermolecular-forces
  a curric:Keyword ;
  schema:name "intermolecular forces"@en ;
  schema:description """Intermolecular forces are weak forces of attraction between molecules, and molecular substances."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170581Z"^^xsd:dateTime .

oakcurric:keyword-le-chateliers-principle
  a curric:Keyword ;
  schema:name "Le Chatelier’s principle"@en ;
  schema:description """states that if a dynamic equilibrium is disturbed by changing the conditions, the equilibrium position ‘shifts’ to counteract the change."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170586Z"^^xsd:dateTime .

oakcurric:keyword-equilibrium-position
  a curric:Keyword ;
  schema:name "equilibrium position"@en ;
  schema:description """refers to the relative concentrations of reactants and products in a reversible reaction at equilibrium."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170590Z"^^xsd:dateTime .

oakcurric:keyword-electron-shell
  a curric:Keyword ;
  schema:name "electron shell"@en ;
  schema:description "is an energy level outside the nucleus which contains electrons."@en ;
  dcterms:modified "2026-02-19T08:26:07.170595Z"^^xsd:dateTime .

oakcurric:keyword-electronic-configuration
  a curric:Keyword ;
  schema:name "electronic configuration"@en ;
  schema:description "of an atom of an element describes how the electrons are arranged in shells."@en ;
  dcterms:modified "2026-02-19T08:26:07.170599Z"^^xsd:dateTime .

oakcurric:keyword-loudness
  a curric:Keyword ;
  schema:name "loudness"@en ;
  schema:description "the loudness of a sound wave is a measure of how loud it is."@en ;
  dcterms:modified "2026-02-19T08:26:07.170629Z"^^xsd:dateTime .

oakcurric:keyword-compensated-ramp
  a curric:Keyword ;
  schema:name "compensated ramp"@en ;
  schema:description "A ramp with a slope to counteract the effect of friction."@en ;
  dcterms:modified "2026-02-19T08:26:07.170777Z"^^xsd:dateTime .

oakcurric:keyword-final-velocity
  a curric:Keyword ;
  schema:name "final velocity"@en ;
  schema:description """The final velocity of an object is the velocity it finishes with after a phase of motion."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170782Z"^^xsd:dateTime .

oakcurric:keyword-light-gate
  a curric:Keyword ;
  schema:name "light gate"@en ;
  schema:description """A light gate can be used to measure velocity. It uses an infrared beam to turn a timer on and off as an object passes through."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170786Z"^^xsd:dateTime .

oakcurric:keyword-repeatable
  a curric:Keyword ;
  schema:name "repeatable"@en ;
  schema:description """Measurements are repeatable if they are very similar when the same procedure is carried out by the same person or team."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170791Z"^^xsd:dateTime .

oakcurric:keyword-uniform-acceleration
  a curric:Keyword ;
  schema:name "uniform acceleration"@en ;
  schema:description "When the acceleration is constant, it is described as uniform acceleration."@en ;
  dcterms:modified "2026-02-19T08:26:07.170795Z"^^xsd:dateTime .

oakcurric:keyword-diode
  a curric:Keyword ;
  schema:name "diode"@en ;
  schema:description "an electrical component that is used to prevent current flow in one direction"@en ;
  dcterms:modified "2026-02-19T08:26:07.170802Z"^^xsd:dateTime .

oakcurric:keyword-reversebiased
  a curric:Keyword ;
  schema:name "reverse–biased"@en ;
  schema:description "when a diode is reverse–biased, it prevents current from flowing"@en ;
  dcterms:modified "2026-02-19T08:26:07.170807Z"^^xsd:dateTime .

oakcurric:keyword-forwardbiased
  a curric:Keyword ;
  schema:name "forward–biased"@en ;
  schema:description "when a diode is forward–biased, it allows current to flow"@en ;
  dcterms:modified "2026-02-19T08:26:07.170811Z"^^xsd:dateTime .

oakcurric:keyword-coulombs-c
  a curric:Keyword ;
  schema:name "coulombs (C)"@en ;
  schema:description "the unit of electric charge"@en ;
  dcterms:modified "2026-02-19T08:26:07.170867Z"^^xsd:dateTime .

oakcurric:keyword-current
  a curric:Keyword ;
  schema:name "current"@en ;
  schema:description "the rate of flow of charge in a circuit"@en ;
  dcterms:modified "2026-02-19T08:26:07.170874Z"^^xsd:dateTime .

oakcurric:keyword-branch
  a curric:Keyword ;
  schema:name "branch"@en ;
  schema:description "a separate series loop in a parallel circuit"@en ;
  dcterms:modified "2026-02-19T08:26:07.170878Z"^^xsd:dateTime .

oakcurric:keyword-compress
  a curric:Keyword ;
  schema:name "compress"@en ;
  schema:description """To make something smaller using forces, e.g. a spring gets shorter when it is compressed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170919Z"^^xsd:dateTime .

oakcurric:keyword-extension
  a curric:Keyword ;
  schema:name "extension"@en ;
  schema:description """The increase in length from the original length of a spring when it is stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:07.170924Z"^^xsd:dateTime .

oakcurric:keyword-spring-constant
  a curric:Keyword ;
  schema:name "spring constant"@en ;
  schema:description "A measure of how stiff a spring is and how hard it is to stretch or compress."@en ;
  dcterms:modified "2026-02-19T08:26:07.170928Z"^^xsd:dateTime .

oakcurric:keyword-watts-w
  a curric:Keyword ;
  schema:name "watts (W)"@en ;
  schema:description """the unit of power; equal to the number of joules of energy transferred each second"""@en ;
  dcterms:modified "2026-02-19T08:26:07.170933Z"^^xsd:dateTime .

oakcurric:keyword-kilowatts-kw
  a curric:Keyword ;
  schema:name "kilowatts (kW)"@en ;
  schema:description "a unit of power; 1 kilowatt is equal to 1000 watts"@en ;
  dcterms:modified "2026-02-19T08:26:07.170939Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-refraction
  a curric:Keyword ;
  schema:name "angle of refraction"@en ;
  schema:description "The angle of refraction is the angle between the refracted ray and the normal."@en ;
  dcterms:modified "2026-02-19T08:26:07.170944Z"^^xsd:dateTime .

oakcurric:keyword-bar-chart
  a curric:Keyword ;
  schema:name "Bar chart"@en ;
  schema:description """A bar chart (bar graph) is a graph consisting of bars visually representing the frequency of objects or groups."""@en ;
  dcterms:modified "2026-02-19T08:26:07.171037Z"^^xsd:dateTime .

oakcurric:keyword-probability
  a curric:Keyword ;
  schema:name "Probability"@en ;
  schema:description """The probability that an event will occur is the proportion of times the event is expected to happen in a suitably large experiment."""@en ;
  dcterms:modified "2026-02-19T08:26:07.171046Z"^^xsd:dateTime .

oakcurric:keyword-wave-equation
  a curric:Keyword ;
  schema:name "wave equation"@en ;
  schema:description "wave speed = frequency × wavelength (v = f × λ)"@en ;
  dcterms:modified "2026-02-19T08:26:07.171080Z"^^xsd:dateTime .

oakcurric:keyword-wave-speed
  a curric:Keyword ;
  schema:name "wave speed"@en ;
  schema:description """The speed of a wave through a medium. Given by the wave equation: wave speed = frequency × wavelength (v = f × λ)"""@en ;
  dcterms:modified "2026-02-19T08:26:07.171085Z"^^xsd:dateTime .

oakcurric:keyword-thinking-distance
  a curric:Keyword ;
  schema:name "thinking distance"@en ;
  schema:description """is the distance a vehicle travels while a driver reacts; the vehicle does not slow during this time"""@en ;
  dcterms:modified "2026-02-19T08:26:07.171089Z"^^xsd:dateTime .

oakcurric:keyword-braking-distance
  a curric:Keyword ;
  schema:name "braking distance"@en ;
  schema:description """is the distance a vehicle travels between the brakes being applied and the vehicle coming to a stop"""@en ;
  dcterms:modified "2026-02-19T08:26:07.171094Z"^^xsd:dateTime .

oakcurric:keyword-stopping-distance
  a curric:Keyword ;
  schema:name "stopping distance"@en ;
  schema:description "is the sum of the thinking and braking distances"@en ;
  dcterms:modified "2026-02-19T08:26:07.171099Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal-wave
  a curric:Keyword ;
  schema:name "longitudinal wave"@en ;
  schema:description """each part of a longitudinal wave oscillates forward and backward in the same direction in which the wave moves."""@en ;
  dcterms:modified "2026-02-19T08:26:07.171243Z"^^xsd:dateTime .

oakcurric:keyword-compression
  a curric:Keyword ;
  schema:name "compression"@en ;
  schema:description """part of a longitudinal wave in which parts of the wave are squashed closer together is called a compression."""@en ;
  dcterms:modified "2026-02-19T08:26:07.171249Z"^^xsd:dateTime .

oakcurric:keyword-rarefaction
  a curric:Keyword ;
  schema:name "rarefaction"@en ;
  schema:description """part of a longitudinal wave in which parts of the wave are spaced further apart is called a rarefaction."""@en ;
  dcterms:modified "2026-02-19T08:26:07.171254Z"^^xsd:dateTime .

oakcurric:keyword-nucleic-acid
  a curric:Keyword ;
  schema:name "nucleic acid"@en ;
  schema:description "A nucleic acid is a polymer made up of nucleotides, an example is DNA."@en ;
  dcterms:modified "2026-02-19T08:26:07.171297Z"^^xsd:dateTime .

oakcurric:keyword-end-point
  a curric:Keyword ;
  schema:name "end point"@en ;
  schema:description "The point at which the chemical reaction has finished."@en ;
  dcterms:modified "2026-02-19T08:26:07.171302Z"^^xsd:dateTime .

oakcurric:keyword-electromagnetic-wave
  a curric:Keyword ;
  schema:name "electromagnetic wave"@en ;
