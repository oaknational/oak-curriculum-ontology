  dcterms:modified "2026-02-19T08:26:07.178992Z"^^xsd:dateTime .

oakcurric:keyword-anhydrous-salt
  a curric:Keyword ;
  schema:name "anhydrous (salt)"@en ;
  schema:description """A salt that does not contain any water molecules in the crystal structure, e.g. anhydrous copper(II) sulfate (CuSO₄)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.178996Z"^^xsd:dateTime .

oakcurric:keyword-double-headed-arrow
  a curric:Keyword ;
  schema:name "double-headed arrow (⇌)"@en ;
  schema:description "Used to show that a chemical reaction is reversible."@en ;
  dcterms:modified "2026-02-19T08:26:07.179000Z"^^xsd:dateTime .

oakcurric:keyword-single-headed-arrow
  a curric:Keyword ;
  schema:name "single-headed arrow (→)"@en ;
  schema:description """Used to show the direction of an (irreversible) chemical reaction, showing that reactants form products."""@en ;
  dcterms:modified "2026-02-19T08:26:07.179004Z"^^xsd:dateTime .

oakcurric:keyword-ripple-tank
  a curric:Keyword ;
