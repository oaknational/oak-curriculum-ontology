  dcterms:modified "2026-02-19T08:26:07.177505Z"^^xsd:dateTime .

oakcurric:keyword-halides
  a curric:Keyword ;
  schema:name "halides"@en ;
  schema:description "are the name of salts formed from halogens, e.g sodium chloride (NaCl)."@en ;
  dcterms:modified "2026-02-19T08:26:07.177509Z"^^xsd:dateTime .

oakcurric:keyword-reaction-profiles
  a curric:Keyword ;
