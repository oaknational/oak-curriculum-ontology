  dcterms:modified "2026-02-19T08:26:13.533199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heart valves stop the backflow of blood in the heart and they can become damaged."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heart disease can be prevented with lifestyle changes, or treated with stents, medicines, transplants and surgery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533209Z"^^xsd:dateTime .

