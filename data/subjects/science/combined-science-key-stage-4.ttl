oakcurric:keylearningpoint-lesson-9619-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electrons have a relative charge of -1 and roughly a relative mass of 0.0005."@en ;
  dcterms:modified "2026-02-19T08:26:13.632759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative mass of 1."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge and contains equal numbers of protons and electrons to balance the charge."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller than that of the atom."""@en ;
  dcterms:modified "2026-02-19T08:26:13.632777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-1
  a curric:KeyLearningPoint ;
