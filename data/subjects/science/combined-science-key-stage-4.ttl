  dcterms:modified "2026-02-19T08:26:13.533356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals secreted by glands, transported in blood plasma and detected by receptors on cells and tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body can be triggered by an increase in hormones (e.g. puberty) and a decrease in them (e.g. menopause)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body are detected by receptors; the nervous system sends nerve impulses to glands to secrete hormones."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of substances move into and out of the blood through selectively-permeable cell membranes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oxygen, carbon dioxide and other small particles move into and out of the blood by diffusion."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-3
  a curric:KeyLearningPoint ;
  rdfs:label "Water moves into and out of the blood by osmosis, a type of diffusion."@en ;
  dcterms:modified "2026-02-19T08:26:13.533381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-4
  a curric:KeyLearningPoint ;
  rdfs:label """The net movement of particles by diffusion and osmosis is down a concentration gradient."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-5
  a curric:KeyLearningPoint ;
  rdfs:label """Large particles are moved into and out of the blood by active transport, which requires energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-1
  a curric:KeyLearningPoint ;
  rdfs:label """The parts of a light microscope and their functions, and the sequence of steps for setting up a light microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-2
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe blood cells on a prepared slide."@en ;
  dcterms:modified "2026-02-19T08:26:13.533477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line drawing with an indication of scale."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-4
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe sections of blood vessels and differences in the structures of their walls."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy of differences in the walls of different blood vessels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-02-19T08:26:13.533730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-2
  a curric:KeyLearningPoint ;
  rdfs:label "Crown gall disease is an example of a disease in plants caused by a bacterium."@en ;
  dcterms:modified "2026-02-19T08:26:13.533734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Barley powdery mildew is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-19T08:26:13.533738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-02-19T08:26:13.533746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-1
  a curric:KeyLearningPoint ;
  rdfs:label """Substances are transported around the body in the blood, which is pumped through vessels by an organ called the heart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-2
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is made of cardiac muscle, which continually contracts and relaxes to pump blood."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-3
  a curric:KeyLearningPoint ;
  rdfs:label """The heart has four chambers with valves, which keep oxygenated and deoxygenated blood separate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiac output can be calculated using: cardiac output = stroke volume × heart rate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have a double circulatory system; blood is pumped to the lungs for gas exchange then around the rest of the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds, not chemically combined together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged."@en ;
  dcterms:modified "2026-02-19T08:26:13.539150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures."@en ;
  dcterms:modified "2026-02-19T08:26:13.539154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and mixtures."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-5
  a curric:KeyLearningPoint ;
  rdfs:label """A formulation is a designed mixture, with each component serving a specific purpose."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH of rain water is naturally below 7."@en ;
  dcterms:modified "2026-02-19T08:26:13.540448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions between certain pollutants and water in the atmosphere may cause a decrease in the pH of rainwater."""@en ;
  dcterms:modified "2026-02-19T08:26:13.540454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-3
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain is not as acidic as vinegar or citric acid that is found in lemons and oranges."""@en ;
  dcterms:modified "2026-02-19T08:26:13.540458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain chemically reacts with carbonates that form many rocks to produce a salt, water and carbon dioxide."""@en ;
  dcterms:modified "2026-02-19T08:26:13.540462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Acid rain can have long term effects on habitats and ecosystems."@en ;
  dcterms:modified "2026-02-19T08:26:13.540466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-02-19T08:26:13.543469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the object."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier callipers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-4
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length × width × height."""@en ;
  dcterms:modified "2026-02-19T08:26:13.543482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms are specialised – they have structures that are adapted for the jobs the cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multicellular organisms grow (make new cells by mitosis) and develop (make specialised cells to form tissues/organs)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unspecialised cells become specialised through a process called differentiation."@en ;
  dcterms:modified "2026-02-19T08:26:13.547672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-4
  a curric:KeyLearningPoint ;
  rdfs:label """During differentiation, particular genes in the cell’s genome are switched off or on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells only use particular genes, so only make the proteins needed for the job they are adapted to do."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-1
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is made of two strands, each a long polymer of nucleotides, wound together in a double helix shape."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-2
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-02-19T08:26:13.547709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nucleotides in each strand of DNA pair up in a complementary way; A pairs with T, and C pairs with G."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-4
  a curric:KeyLearningPoint ;
  rdfs:label """The DNA in chromosomes is unwound & copied during interphase, then the copies separate and the cell divides by mitosis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-5
  a curric:KeyLearningPoint ;
  rdfs:label """Complementary base pairing allows an exact copy of each ‘unzipped’ DNA strand to be made from free nucleotides."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abiotic factors such as light levels, temperature, soil moisture and pH can be measured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Transects can be used to investigate the effects of a changing factor on the distribution and abundance of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-3
  a curric:KeyLearningPoint ;
  rdfs:label """A transect can be placed along a gradient of a factor (e.g. from shade to full sunlight)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-4
  a curric:KeyLearningPoint ;
  rdfs:label """A belt transect uses quadrats placed along the straight line to measure distribution and abundance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the formation of tumours."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-2
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause secondary tumours."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk of developing cancer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations can cause changes in DNA; this alters the nucleotide sequence and genetic code"""@en ;
  dcterms:modified "2026-02-19T08:26:13.547775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms compete for resources such as food, water, space, shelter, light, mates, pollinators and seed dispersers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-2
  a curric:KeyLearningPoint ;
  rdfs:label """The populations of species within a community are interdependent (they rely upon and affect one another)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms have adaptations that help them survive and compete in their environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations can be physiological, structural or behavioural."@en ;
  dcterms:modified "2026-02-19T08:26:13.547810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extremophiles are adapted to live in extreme environments, e.g. high salt concentration or very high or low temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-1
  a curric:KeyLearningPoint ;
  rdfs:label """An early animal embryo is made of unspecialised cells; these are embryonic stem cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-2
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic stem cells can differentiate to become all types of cells in the animal’s body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an animal develops into an adult, some cells remain unspecialised; these are adult stem cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adult stem cells can differentiate to become most but not all types of cells in the animal’s body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of adult stem cells in humans (e.g. in bone marrow; these can divide and differentiate to make blood cells)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.547891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some plants and animals have features that are useful to us (e.g. they can provide food and materials, or do work)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Selective breeding by humans causes particular features to become more (or less) common in the species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-3
  a curric:KeyLearningPoint ;
  rdfs:label """After many generations, the resulting domesticated species can be quite different to their wild ancestors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of the selective breeding of a farm animal and a crop from their wild ancestors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-5
  a curric:KeyLearningPoint ;
  rdfs:label "The dependence of humans on domesticated animals and crops for food security."@en ;
  dcterms:modified "2026-02-19T08:26:13.548252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.548260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps to set up a light microscope to observe cells, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during the cell cycle (including PMAT)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.548270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Microorganisms and detritivores (detritus feeders) are responsible for the decomposition of plant and animal material."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-2
  a curric:KeyLearningPoint ;
  rdfs:label "Decay is needed to keep nutrients cycling around an ecosystem."@en ;
  dcterms:modified "2026-02-19T08:26:13.549108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compost is made out of decomposed plant and animal material."@en ;
  dcterms:modified "2026-02-19T08:26:13.549111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-4
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas is produced when waste material is anaerobically digested."@en ;
  dcterms:modified "2026-02-19T08:26:13.549115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-5
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas contains methane which can be harvested and used as a fuel."@en ;
  dcterms:modified "2026-02-19T08:26:13.549119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-19T08:26:13.549549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including changing the magnification  & focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during stages of the cell cycle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ecosystems contain biotic and abiotic components."@en ;
  dcterms:modified "2026-02-19T08:26:13.549565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in biotic and abiotic factors will affect communities within an ecosystem."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Predators are consumers that eat prey."@en ;
  dcterms:modified "2026-02-19T08:26:13.549573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-4
  a curric:KeyLearningPoint ;
  rdfs:label """The population sizes of predators and prey increase and decrease in predator-prey cycles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes species that appear to be the common ancestor of numerous later species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evolutionary trees can be used to help visualise the relationships between groups of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-3
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes transitional species with features of both evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-4
  a curric:KeyLearningPoint ;
  rdfs:label """A case study of an example of a transitional species (e.g. Archaeopteryx, which links dinosaurs and modern birds)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are gaps in the fossil record, e.g. ‘missing links’ between evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of evolution by natural selection suggests that all modern species evolved from earlier species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes each generation of a species to become better adapted to its environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection can cause common features of a population to change so much that we classify them as a new species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Populations of the same species living in different conditions can evolve to become separate species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of speciation of populations living in different conditions (e.g. Galápagos tortoises)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.549743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the formation of tumours."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all tumours are cancerous; they can be benign or malignant."@en ;
  dcterms:modified "2026-02-19T08:26:13.550452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-4
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause secondary tumours."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk of developing cancer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record is made up of millions of fossils aged from 10,000 to billions of years old."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that some species have gone extinct."@en ;
  dcterms:modified "2026-02-19T08:26:13.550474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that the features of some species have changed (evolved) over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.550478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-4
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a series of fossils showing changes from evolutionary ancestors to modern species (e.g. whales)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic and adult stem cells can be used in treatments to make new specialised cells to replace damaged ones."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples include using stem cells to treat type 1 diabetes and bone marrow transplants for leukaemia."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-3
  a curric:KeyLearningPoint ;
  rdfs:label """Transplanting stem cells into a patient has risks (e.g. immune rejection, cancer from uncontrolled division, infection)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.550536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ethical objections to harvesting embryos as a source of embryonic stem cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.550540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-5
  a curric:KeyLearningPoint ;
  rdfs:label "Debating benefits versus risks and ethical issues."@en ;
  dcterms:modified "2026-02-19T08:26:13.550544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be used to sample an area to estimate population size (abundance)."@en ;
  dcterms:modified "2026-02-19T08:26:13.551068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats are used to sample plants and small, slow-moving animals."@en ;
  dcterms:modified "2026-02-19T08:26:13.551072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be placed at random to help avoid bias."@en ;
  dcterms:modified "2026-02-19T08:26:13.551079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using quadrats to estimate population size (species abundance) in an area."@en ;
  dcterms:modified "2026-02-19T08:26:13.551083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using quadrats to investigate the population size of a plant species using random sampling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reproduction is part of the life cycle of all organisms; sexual reproduction requires specialised cells called gametes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gametes are made from body cells by a type of cell division called meiosis."@en ;
  dcterms:modified "2026-02-19T08:26:13.551675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-3
  a curric:KeyLearningPoint ;
  rdfs:label """During interphase the chromosomes are copied; meiosis follows this and includes two rounds of cell division."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gametes made by meiosis have half the usual number of chromosomes (one from each pair in the original body cell)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mitosis produces 2 genetically identical diploid cells, whereas meiosis produces 4 genetically different haploid cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants have unspecialised cells called meristem cells, which are located in the stem and the tips of roots and shoots."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-2
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in roots and shoots divide and differentiate to enable roots and shoots to grow longer and wider."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-3
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the shoots also divide and differentiate to make leaves and flowers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-4
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the stem and roots also divide and differentiate to make tissues such as xylem and phloem."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-5
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem tissue can be used to produce clones for crops or to protect endangered species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.551787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data and plot a graph of appropriate results to identify and describe patterns or trends in the results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.554480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining the results using ideas about the requirement of light for photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.554484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying sources of systematic and random error that could affect the accuracy of the measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.554488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suggesting improvements (e.g. ways to measure the amount of gas more accurately)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.554492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating the precision, repeatability and reproducibility of the results."@en ;
  dcterms:modified "2026-02-19T08:26:13.554496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-1
  a curric:KeyLearningPoint ;
  rdfs:label "Light waves spread out as they travel from a light source."@en ;
  dcterms:modified "2026-02-19T08:26:13.555649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-2
  a curric:KeyLearningPoint ;
  rdfs:label """Further away from the light source, the same amount of light is spread out over a greater area."""@en ;
  dcterms:modified "2026-02-19T08:26:13.555652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-3
  a curric:KeyLearningPoint ;
  rdfs:label """This means the light intensity decreases with increasing distance from a light source."""@en ;
  dcterms:modified "2026-02-19T08:26:13.555656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light intensity is inversely proportional to the square of the distance from a light source (inverse square law)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.555660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size requires increased land use for resources (including food and fuels) and urbanisation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increased land use by humans leads to habitat destruction, e.g. deforestation and biodiversity loss."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size increases production of waste and pollution, leading to biodiversity loss."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-4
  a curric:KeyLearningPoint ;
  rdfs:label """Release of greenhouse gases contributes to climate change, including global warming, leading to biodiversity loss."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is very strong evidence linking human release of greenhouse gases to global climate change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms go through different phases that are part of a cell cycle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main phases of the cell cycle are interphase and mitosis."@en ;
  dcterms:modified "2026-02-19T08:26:13.556354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-3
  a curric:KeyLearningPoint ;
  rdfs:label """During cell interphase, each chromosome is copied, sub-cellular structures are copied."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stages of mitosis are prophase, metaphase, anaphase, telophase and cytokinesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing food helps feed the increasing human population, but can have negative impacts on ecosystems and biodiversity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.557119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fish farming and animal welfare as examples of positive and negative impacts."@en ;
  dcterms:modified "2026-02-19T08:26:13.557123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eutrophication as an example of a negative impact."@en ;
  dcterms:modified "2026-02-19T08:26:13.557127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-4
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction of non-indigenous species as an example of a negative impact."@en ;
  dcterms:modified "2026-02-19T08:26:13.557131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways of mitigating some of these negative impacts."@en ;
  dcterms:modified "2026-02-19T08:26:13.557138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal oxide with an appropriate acid can form a desired salt and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding metal oxide to excess ensures that the acid fully reacts to form salt and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Excess metal oxide can be removed by filtration so that the filtrate contains only salt and water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be removed from the salt by evaporation."@en ;
  dcterms:modified "2026-02-19T08:26:13.563772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, drag acts in the opposite direction to the gravitational force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases."@en ;
  dcterms:modified "2026-02-19T08:26:13.563784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches terminal velocity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dot and cross diagrams as a model for binary ionic substances"@en ;
  dcterms:modified "2026-02-19T08:26:13.563792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dot and cross diagrams show the empirical formula/ratio of atoms to show how electrons are transferred"""@en ;
  dcterms:modified "2026-02-19T08:26:13.563796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ions are shown with full outer shells, square brackets, and a charge in the top right corner."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds are neutral overall, so positive and negative charge must balance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-5
  a curric:KeyLearningPoint ;
  rdfs:label """When positive ions do not have the same magnitude of charge as negative ions, multiple of some ions will be required."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different surfaces can scatter light or reflect light in a regular way."@en ;
  dcterms:modified "2026-02-19T08:26:13.563815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-2
  a curric:KeyLearningPoint ;
  rdfs:label """The angle of incidence equals the angle of reflection. Angles are measured from the normal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light can be thought of as a wave (ripples) in electric and magnetic fields."@en ;
  dcterms:modified "2026-02-19T08:26:13.563823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-4
  a curric:KeyLearningPoint ;
  rdfs:label "Like all waves, light can be represented using rays or wavefronts."@en ;
  dcterms:modified "2026-02-19T08:26:13.563827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water diffuses into and out of cells by osmosis; net movement is from a more dilute solution to a more concentrated one."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Investigating the effect of sucrose solution concentration on the mass of potato chips."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use of appropriate apparatus to measure volumes, masses and times accurately."@en ;
  dcterms:modified "2026-02-19T08:26:13.563841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-4
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of materials and apparatus."@en ;
  dcterms:modified "2026-02-19T08:26:13.563845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-5
  a curric:KeyLearningPoint ;
  rdfs:label "Control of variables that might affect the results (e.g. temperature)."@en ;
  dcterms:modified "2026-02-19T08:26:13.563849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-1
  a curric:KeyLearningPoint ;
  rdfs:label """As the p.d. across a filament lamp increases, it gets hotter and current through it increases in a non-ohmic way."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the p.d. across a filament lamp, the greater its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.563857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal is made of a lattice of positively charged ions with negatively charged electrons between."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a current flows through metal,  electrons moving through the ion lattice cause it to vibrate more vigorously."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-5
  a curric:KeyLearningPoint ;
  rdfs:label """The more vigorously the ions (ion lattice) vibrate, the hotter the metal and the higher its resistance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or product made) per unit of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate decreases as temperature increases above the optimum, as the active site becomes denatured."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature on enzyme reaction rate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Protons have a positive electric charge of +1 and a mass number of 1."@en ;
  dcterms:modified "2026-02-19T08:26:13.563898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neutrons have no electric charge and have a mass number of 1."@en ;
  dcterms:modified "2026-02-19T08:26:13.563902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of protons in the nucleus of each atom of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of electrons in each atom of that element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of an element that have different numbers of neutrons in their nuclei are isotopes of the element."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-1
  a curric:KeyLearningPoint ;
  rdfs:label "At equilibrium, both reactants and products are formed at the same rate."@en ;
  dcterms:modified "2026-02-19T08:26:13.563919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amounts of reactants and products remain constant at equilibrium."@en ;
  dcterms:modified "2026-02-19T08:26:13.563923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-3
  a curric:KeyLearningPoint ;
  rdfs:label "Equilibrium can only occur in a closed system."@en ;
  dcterms:modified "2026-02-19T08:26:13.563927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animal cell model describes the common structures of animal cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.563931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-2
  a curric:KeyLearningPoint ;
  rdfs:label """These structures include the cytoplasm, cell membrane, nucleus and mitochondria. Each structure has a specific function."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in animals have shapes, sizes and structures that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised animal cells include blood cells and nerve cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.563943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following an appropriate method to vary light intensity and measure the gas given off"""@en ;
  dcterms:modified "2026-02-19T08:26:13.563947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate measurement of variables (distance, time, amount of gas) and control of variables that might affect the results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.563951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting bubbles and measuring volume of gas given off"@en ;
  dcterms:modified "2026-02-19T08:26:13.563955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Record results in an appropriate table"@en ;
  dcterms:modified "2026-02-19T08:26:13.563959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plant cell model describes the common structures of plant cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.563965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of these structures are common with animal cells, such as the cytoplasm, cell membrane, nucleus and mitochondria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plant cells have additional structures, i.e. the cell wall, chloroplasts and vacuole; each has a specific function."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in plants have shapes, sizes and structures that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-5
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised plant cells include root hair cells and palisade cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.563984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-1
  a curric:KeyLearningPoint ;
  rdfs:label "Molecular modelling represents the bonding and structure of substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.564008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way giant covalent structures melt/boil is very different to simple molecules."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct electricity, every atom is bonded to another."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-4
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite each atom is bonded to three others to form layers of hexagonal rings. Each atom contributes a free electron"""@en ;
  dcterms:modified "2026-02-19T08:26:13.564020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-5
  a curric:KeyLearningPoint ;
  rdfs:label """Simple molecules are held together by intermolecular forces, no chemical bonds hold them together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-1
  a curric:KeyLearningPoint ;
  rdfs:label """In forward–bias, a diode has a very small resistance when the p.d. is larger than the threshold voltage."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-2
  a curric:KeyLearningPoint ;
  rdfs:label """In reverse–bias, a diode has a very large resistance and very little current can flow."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the p.d. across a component, the larger the push on electric charges in the component."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a component is calculated from an I–V graph using pairs of readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-5
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through a component, the larger the heating effect on it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-1
  a curric:KeyLearningPoint ;
  rdfs:label """An investigation can measure the temperature change through continuous heating of a substance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curve observations are best presented in a table and graphically."@en ;
  dcterms:modified "2026-02-19T08:26:13.564057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reliable data can be collected by taking repeat measurements, identifying anomalies and calculating a mean."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curves can be used to determine the melting point of a substance."@en ;
  dcterms:modified "2026-02-19T08:26:13.564065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Keys can be used to identify organisms in their habitat."@en ;
  dcterms:modified "2026-02-19T08:26:13.564069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is not possible to count all the organisms in a population, so we use sampling to estimate population size."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling organisms in habitats (e.g. a river using kick sampling and a net)."@en ;
  dcterms:modified "2026-02-19T08:26:13.564077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling animals using a pooter."@en ;
  dcterms:modified "2026-02-19T08:26:13.564083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-5
  a curric:KeyLearningPoint ;
  rdfs:label "Estimating populations using capture-mark-recapture."@en ;
  dcterms:modified "2026-02-19T08:26:13.564087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration is a technique used to separate insoluble substances from a mixture with a liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Separation in filtration occurs due to the difference in size of particles."@en ;
  dcterms:modified "2026-02-19T08:26:13.564095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-3
  a curric:KeyLearningPoint ;
  rdfs:label """The terms 'filtrate' and 'residue' describe the components separated by the process of filtration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wire in a motor is insulated so that the current flows around the coil"@en ;
  dcterms:modified "2026-02-19T08:26:13.564103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections in a motor slide over each other to prevent tangled wires"@en ;
  dcterms:modified "2026-02-19T08:26:13.564109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the coil in a motor kit is horizontal it is connected and a force acts on the sides 90 deg. to the magnetic field"""@en ;
  dcterms:modified "2026-02-19T08:26:13.564115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every half–turn, the coil connections in a motor kit swap over and change the direction of current through the coil"""@en ;
  dcterms:modified "2026-02-19T08:26:13.564120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each side of a coil in a motor kit at 90º to the magnetic field is pushed alternatively up then down every half turn"""@en ;
  dcterms:modified "2026-02-19T08:26:13.564126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across a component in an electric circuit measures the size of push that is moving current through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series circuit adds up to the p.d. across the battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-3
  a curric:KeyLearningPoint ;
  rdfs:label "The current is the same through every component in a series circuit."@en ;
  dcterms:modified "2026-02-19T08:26:13.564417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the total resistance of a series circuit, the smaller the current through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a series circuit, the share of p.d. across each component is proportional to its resistance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-19T08:26:13.564435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time period."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat readings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.564449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-19T08:26:13.564453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-5
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous velocity of an object is equal to the gradient of a tangent to a displacement-time curve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effect of temperature on aerobic cellular respiration investigated in small living organisms (e.g. germinating peas)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-2
  a curric:KeyLearningPoint ;
  rdfs:label """The oxygen used by the respiring organisms in a set time can be measured using a simple respirometer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, and variables to control to increase the validity of the results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-4
  a curric:KeyLearningPoint ;
  rdfs:label """The height of coloured liquid in the capillary tube of the respirometer is measured at the start & end of the set time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting repeat measurements at each temperature, and collecting data at different temperatures."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules), giant covalent, ionic and metallic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it can only hold 2 electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-02-19T08:26:13.564645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or anions, respectfully."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon is found in the atmosphere as carbon dioxide."@en ;
  dcterms:modified "2026-02-19T08:26:13.564669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-2
  a curric:KeyLearningPoint ;
  rdfs:label """The carbon cycle shows how carbon is recycled between organisms and the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be removed from the atmosphere by plants, who use it during the process of photosynthesis."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is returned to the atmosphere by the burning of fossil fuels and the decay of dead plant and animal material."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used to separate substances in a mixture of inks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564689Z"^^xsd:dateTime .

