oakcurric:keylearningpoint-lesson-5541-3
  a curric:KeyLearningPoint ;
  rdfs:label "A myelin sheath on some neurones increases the speed of the nerve impulse"@en ;
  dcterms:modified "2026-02-19T08:26:13.532526Z"^^xsd:dateTime .

