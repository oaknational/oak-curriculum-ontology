<https://w3id.org/uk/curriculum/oakcurriculum/combined-science-key-stage-4>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Combined Science KS4 Instance Data"@en ;
  dc:title "Oak Curriculum Data - Combined Science KS4 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum programmes for 
  Combined Science KS4."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/curriculum/oakcurriculum/combined-science-key-stage-4/0.1.0> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Combined Science KS4, including exam board-specific unit variants and lesson sequences."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2026-02-19T08:26:21.193722Z"^^xsd:dateTime ;
  dcterms:modified "2026-02-19T08:26:21.193802Z"^^xsd:dateTime ;
