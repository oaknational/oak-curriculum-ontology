  dcterms:modified "2026-02-19T08:26:07.178588Z"^^xsd:dateTime .

oakcurric:keyword-state-symbol
  a curric:Keyword ;
  schema:name "state symbol"@en ;
  schema:description "used in chemical equations to indicate the physical state of a substance"@en ;
  dcterms:modified "2026-02-19T08:26:07.178708Z"^^xsd:dateTime .

oakcurric:keyword-ionic-equation
  a curric:Keyword ;
  schema:name "ionic equation"@en ;
