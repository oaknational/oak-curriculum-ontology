    natcurric:substrand-earth-and-atmosphere,
    natcurric:substrand-atomic-structure-periodic-table ,
    natcurric:substrand-structure-bonding-properties-of-matter ,
    natcurric:substrand-chemical-changes ,
    natcurric:substrand-energy-changes-in-chemistry ,
    natcurric:substrand-rate-extent-of-chemical-change ,
    natcurric:substrand-chemical-analysis ,
    natcurric:substrand-chemical-and-allied-industries ,
    natcurric:substrand-earth-and-atmospheric-science ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

