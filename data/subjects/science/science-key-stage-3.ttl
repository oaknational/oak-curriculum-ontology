  schema:description """A medium is usually a liquid or gas that other substances can mix into or move through, enabling other substances to mix or interact."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168579Z"^^xsd:dateTime .

oakcurric:keyword-particles
  a curric:Keyword ;
  schema:name "particles"@en ;
  schema:description "What solids, liquids and gases are made up from."@en ;
  dcterms:modified "2026-02-19T08:26:07.168583Z"^^xsd:dateTime .

oakcurric:keyword-sound-wave
  a curric:Keyword ;
  schema:name "sound wave"@en ;
  schema:description "A ‘pulse’ that travels through a material caused by the vibrations of particles."@en ;
  dcterms:modified "2026-02-19T08:26:07.168588Z"^^xsd:dateTime .

oakcurric:keyword-vacuum
  a curric:Keyword ;
  schema:name "vacuum"@en ;
  schema:description "An area of space with no matter present (that contains no particles)."@en ;
  dcterms:modified "2026-02-19T08:26:07.168592Z"^^xsd:dateTime .

oakcurric:keyword-solute
  a curric:Keyword ;
  schema:name "solute"@en ;
  schema:description "A solute is a substance that has dissolved into a solvent."@en ;
  dcterms:modified "2026-02-19T08:26:07.168599Z"^^xsd:dateTime .

oakcurric:keyword-soluble
  a curric:Keyword ;
  schema:name "soluble"@en ;
  schema:description "When a solute dissolves, it is described as soluble."@en ;
  dcterms:modified "2026-02-19T08:26:07.168604Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-mass
  a curric:Keyword ;
  schema:name "conservation of mass"@en ;
  schema:description """The combined mass of starting materials equals the combined mass of the end products."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168608Z"^^xsd:dateTime .

oakcurric:keyword-dissolve
  a curric:Keyword ;
  schema:name "dissolve"@en ;
  schema:description """Occurs when a substance's particles separate and spread throughout the particles of a solvent resulting in it no longer being seen."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168613Z"^^xsd:dateTime .

oakcurric:keyword-insoluble
  a curric:Keyword ;
  schema:name "insoluble"@en ;
  schema:description """If a substance does not dissolve in a particular solvent, it is described as insoluble."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168617Z"^^xsd:dateTime .

oakcurric:keyword-melting
  a curric:Keyword ;
  schema:name "melting"@en ;
  schema:description """Melting occurs when a substance in the solid state is heated and its particles move into the arrangement of a substance in the liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168622Z"^^xsd:dateTime .

oakcurric:keyword-force-of-attraction
  a curric:Keyword ;
  schema:name "force of attraction"@en ;
  schema:description """A force of attraction is a pulling force that keeps things, such as particles, close together."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168626Z"^^xsd:dateTime .

oakcurric:keyword-suspension
  a curric:Keyword ;
  schema:name "suspension"@en ;
  schema:description """A mixture of an insoluble solid and liquid in which the solid particles are dispersed in the liquid and settle upon the mixture standing."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168633Z"^^xsd:dateTime .

oakcurric:keyword-vibration
  a curric:Keyword ;
  schema:name "vibration"@en ;
  schema:description "A repeated back and forth movement."@en ;
  dcterms:modified "2026-02-19T08:26:07.168638Z"^^xsd:dateTime .

oakcurric:keyword-amplitude
  a curric:Keyword ;
  schema:name "amplitude"@en ;
  schema:description "Measures the size of a vibration, i.e. how far an object vibrates."@en ;
  dcterms:modified "2026-02-19T08:26:07.168642Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description """The independent variable is the variable that is changed during an investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168646Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description """The dependent variable is the variable that is measured or observed during an investigation; it changes as a result of varying the independent variable."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168651Z"^^xsd:dateTime .

oakcurric:keyword-cooling-rate
  a curric:Keyword ;
  schema:name "cooling rate"@en ;
  schema:description "how quickly the temperature of an object falls"@en ;
  dcterms:modified "2026-02-19T08:26:07.168669Z"^^xsd:dateTime .

oakcurric:keyword-cooling-curve
  a curric:Keyword ;
  schema:name "cooling curve"@en ;
  schema:description "a line graph that shows how a cooling object’s temperature changes with time"@en ;
  dcterms:modified "2026-02-19T08:26:07.168674Z"^^xsd:dateTime .

oakcurric:keyword-dissipate
  a curric:Keyword ;
  schema:name "dissipate"@en ;
  schema:description "to spread out"@en ;
  dcterms:modified "2026-02-19T08:26:07.168680Z"^^xsd:dateTime .

oakcurric:keyword-chromatography
  a curric:Keyword ;
  schema:name "chromatography"@en ;
  schema:description """Chromatography is a technique that separates a mixture into its different parts and the results can be analysed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168708Z"^^xsd:dateTime .

oakcurric:keyword-chromatogram
  a curric:Keyword ;
  schema:name "chromatogram"@en ;
  schema:description """A chromatogram is the resultant pattern on the stationary phase after chromatography has been carried out."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168712Z"^^xsd:dateTime .

oakcurric:keyword-filtration
  a curric:Keyword ;
  schema:name "filtration"@en ;
  schema:description "The process of separating an insoluble substance from a liquid using a filter."@en ;
  dcterms:modified "2026-02-19T08:26:07.168724Z"^^xsd:dateTime .

oakcurric:keyword-filter-paper
  a curric:Keyword ;
  schema:name "filter paper"@en ;
  schema:description """Paper with tiny holes, placed inside the filter funnel to separate an insoluble solid from a liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168728Z"^^xsd:dateTime .

oakcurric:keyword-filter-funnel
  a curric:Keyword ;
  schema:name "filter funnel"@en ;
  schema:description """A cone-shaped tool with a tube, placed in the top of a conical flask during filtration."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168735Z"^^xsd:dateTime .

oakcurric:keyword-residue
  a curric:Keyword ;
  schema:name "residue"@en ;
  schema:description "The insoluble solid that remains in the filter paper."@en ;
  dcterms:modified "2026-02-19T08:26:07.168740Z"^^xsd:dateTime .

oakcurric:keyword-filtrate
  a curric:Keyword ;
  schema:name "filtrate"@en ;
  schema:description """The liquid that passes through the filter paper, separating from the insoluble solid."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168745Z"^^xsd:dateTime .

oakcurric:keyword-distillation
  a curric:Keyword ;
  schema:name "distillation"@en ;
  schema:description """Distillation is a separation technique that uses boiling and condensation to remove and isolate the liquid part of a mixture."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168767Z"^^xsd:dateTime .

oakcurric:keyword-boiling
  a curric:Keyword ;
  schema:name "boiling"@en ;
  schema:description """Boiling occurs when a substance in the liquid state is heated and changes to the gas state with gas bubbles formed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168772Z"^^xsd:dateTime .

oakcurric:keyword-condensation
  a curric:Keyword ;
  schema:name "condensation"@en ;
  schema:description """Condensation is the process by which a substance in the gas state is cooled and changes to a liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168777Z"^^xsd:dateTime .

oakcurric:keyword-environment
  a curric:Keyword ;
  schema:name "environment"@en ;
  schema:description """The environment of a living organism is its surroundings and the conditions in which it lives."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168781Z"^^xsd:dateTime .

oakcurric:keyword-lifestyle
  a curric:Keyword ;
  schema:name "lifestyle"@en ;
  schema:description """The lifestyle of a living organism is the things it does and the choices it makes, e.g. diet and exercise."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168786Z"^^xsd:dateTime .

oakcurric:keyword-inherited
  a curric:Keyword ;
  schema:name "inherited"@en ;
  schema:description """Some of the offspring's features can be inherited from parents, through the process of reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168790Z"^^xsd:dateTime .

oakcurric:keyword-separation-technique
  a curric:Keyword ;
  schema:name "separation technique"@en ;
  schema:description """A process or method used to isolate a substance from a mixture, usually to obtain a pure sample of it."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168835Z"^^xsd:dateTime .

oakcurric:keyword-particle-model
  a curric:Keyword ;
  schema:name "particle model"@en ;
  schema:description "the idea that all objects are made of tiny particles that are in constant motion"@en ;
  dcterms:modified "2026-02-19T08:26:07.168840Z"^^xsd:dateTime .

oakcurric:keyword-collide
  a curric:Keyword ;
  schema:name "collide"@en ;
  schema:description "when two objects bump into each other"@en ;
  dcterms:modified "2026-02-19T08:26:07.168845Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conduction
  a curric:Keyword ;
  schema:name "thermal conduction"@en ;
  schema:description """a change in temperature due to particles passing on their motion through their bonds or by particle collisions"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168849Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conductor
  a curric:Keyword ;
  schema:name "thermal conductor"@en ;
  schema:description "a substance along which thermal conduction happens quickly"@en ;
  dcterms:modified "2026-02-19T08:26:07.168854Z"^^xsd:dateTime .

oakcurric:keyword-thermal-insulator
  a curric:Keyword ;
  schema:name "thermal insulator"@en ;
  schema:description "a substance along which thermal conduction happens slowly"@en ;
  dcterms:modified "2026-02-19T08:26:07.168858Z"^^xsd:dateTime .

oakcurric:keyword-forces-of-attraction
  a curric:Keyword ;
  schema:name "forces of attraction"@en ;
  schema:description """hold together the neighbouring particles in a solid or liquid; these forces are weaker the further apart the particles are"""@en ;
  dcterms:modified "2026-02-19T08:26:07.168863Z"^^xsd:dateTime .

oakcurric:keyword-thermal-energy-store
  a curric:Keyword ;
  schema:name "thermal energy store"@en ;
  schema:description "the energy a substance stores because of the random motion of its particles"@en ;
  dcterms:modified "2026-02-19T08:26:07.168867Z"^^xsd:dateTime .

oakcurric:keyword-delivery-tube
  a curric:Keyword ;
  schema:name "delivery tube"@en ;
  schema:description """A delivery tube is a thin tube used to transfer (i.e. "deliver") a substance (usually in the gas state) from one container to another."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168872Z"^^xsd:dateTime .

oakcurric:keyword-condenser
  a curric:Keyword ;
  schema:name "condenser"@en ;
  schema:description """A condenser is a piece of apparatus composed of a tube surrounded by a cold layer, usually cold water."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168876Z"^^xsd:dateTime .

oakcurric:keyword-distillate
  a curric:Keyword ;
  schema:name "distillate"@en ;
  schema:description """The liquid that is condensed from the gas state during distillation is called the distillate."""@en ;
  dcterms:modified "2026-02-19T08:26:07.168881Z"^^xsd:dateTime .

oakcurric:keyword-degrees-celsius
  a curric:Keyword ;
  schema:name "degrees Celsius"@en ;
  schema:description "a unit of temperature"@en ;
  dcterms:modified "2026-02-19T08:26:07.168989Z"^^xsd:dateTime .

oakcurric:keyword-insulation
  a curric:Keyword ;
  schema:name "insulation"@en ;
  schema:description "a layer of thermal insulator around an object to help maintain its temperature"@en ;
  dcterms:modified "2026-02-19T08:26:07.169022Z"^^xsd:dateTime .

oakcurric:keyword-decompose
  a curric:Keyword ;
  schema:name "decompose"@en ;
  schema:description "to break down a substance into smaller parts"@en ;
  dcterms:modified "2026-02-19T08:26:07.169035Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-force
  a curric:Keyword ;
  schema:name "gravitational force"@en ;
  schema:description """Gravitational forces pull objects towards large objects like planets, moons and stars."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169049Z"^^xsd:dateTime .

oakcurric:keyword-direction
  a curric:Keyword ;
  schema:name "direction"@en ;
  schema:description "Direction is the path that something takes to reach a particular place"@en ;
  dcterms:modified "2026-02-19T08:26:07.169088Z"^^xsd:dateTime .

oakcurric:keyword-passive-process
  a curric:Keyword ;
  schema:name "passive process"@en ;
  schema:description "A passive process doesn’t require any additional energy."@en ;
  dcterms:modified "2026-02-19T08:26:07.169114Z"^^xsd:dateTime .

oakcurric:keyword-concentration
  a curric:Keyword ;
  schema:name "concentration"@en ;
  schema:description "Concentration is the number of particles in a volume of liquid or gas."@en ;
  dcterms:modified "2026-02-19T08:26:07.169119Z"^^xsd:dateTime .

oakcurric:keyword-liquid-state
  a curric:Keyword ;
  schema:name "liquid state"@en ;
  schema:description "Substances in the liquid state will take the shape of their container."@en ;
  dcterms:modified "2026-02-19T08:26:07.169123Z"^^xsd:dateTime .

oakcurric:keyword-solid-state
  a curric:Keyword ;
  schema:name "solid state"@en ;
  schema:description """Particles in a substance in a solid state are in a fixed position and can only vibrate."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169128Z"^^xsd:dateTime .

oakcurric:keyword-melting-point
  a curric:Keyword ;
  schema:name "melting point"@en ;
  schema:description """The melting point of a substance is the temperature at which it changes from a solid state to a liquid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169132Z"^^xsd:dateTime .

oakcurric:keyword-freezing-point
  a curric:Keyword ;
  schema:name "freezing point"@en ;
  schema:description """The freezing point is the temperature at which a substance changes from a liquid state to a solid state."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169139Z"^^xsd:dateTime .

oakcurric:keyword-blood
  a curric:Keyword ;
  schema:name "blood"@en ;
  schema:description "Blood is a liquid which transports nutrients and waste  around the body."@en ;
  dcterms:modified "2026-02-19T08:26:07.169200Z"^^xsd:dateTime .

oakcurric:keyword-absorption
  a curric:Keyword ;
  schema:name "absorption"@en ;
  schema:description """Absorption is the process of moving nutrients from the digestive system into the blood."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169205Z"^^xsd:dateTime .

oakcurric:keyword-planet
  a curric:Keyword ;
  schema:name "planet"@en ;
  schema:description "A planet is a very large sphere of rock or gas that orbits a star."@en ;
  dcterms:modified "2026-02-19T08:26:07.169209Z"^^xsd:dateTime .

oakcurric:keyword-dwarf-planet
  a curric:Keyword ;
  schema:name "dwarf planet"@en ;
  schema:description """A dwarf planet is a large, round object that orbits a star but is not big enough to clear its orbital path of other debris."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169216Z"^^xsd:dateTime .

oakcurric:keyword-asteroid
  a curric:Keyword ;
  schema:name "asteroid"@en ;
  schema:description "An asteroid is a small, rocky object that orbits the Sun."@en ;
  dcterms:modified "2026-02-19T08:26:07.169224Z"^^xsd:dateTime .

oakcurric:keyword-solar-system
  a curric:Keyword ;
  schema:name "solar system"@en ;
  schema:description "Our solar system includes the Sun and all the objects in orbit around the Sun."@en ;
  dcterms:modified "2026-02-19T08:26:07.169231Z"^^xsd:dateTime .

oakcurric:keyword-axis
  a curric:Keyword ;
  schema:name "axis"@en ;
  schema:description "The axis of a spinning object is the imaginary line around which it spins."@en ;
  dcterms:modified "2026-02-19T08:26:07.169299Z"^^xsd:dateTime .

oakcurric:keyword-tilt
  a curric:Keyword ;
  schema:name "tilt"@en ;
  schema:description "Something is tilted if it is at an angle to the horizontal or vertical."@en ;
  dcterms:modified "2026-02-19T08:26:07.169303Z"^^xsd:dateTime .

oakcurric:keyword-digestive-system
  a curric:Keyword ;
  schema:name "digestive system"@en ;
  schema:description "The digestive system is a collection of organs that break down food."@en ;
  dcterms:modified "2026-02-19T08:26:07.169317Z"^^xsd:dateTime .

oakcurric:keyword-fibre
  a curric:Keyword ;
  schema:name "fibre"@en ;
  schema:description "Fibre bulks up food so it can be moved through the digestive system more easily."@en ;
  dcterms:modified "2026-02-19T08:26:07.169321Z"^^xsd:dateTime .

oakcurric:keyword-table
  a curric:Keyword ;
  schema:name "Table"@en ;
  schema:description "A way of sorting information made of rows and columns."@en ;
  dcterms:modified "2026-02-19T08:26:07.169487Z"^^xsd:dateTime .

oakcurric:keyword-crystallisation
  a curric:Keyword ;
  schema:name "crystallisation"@en ;
  schema:description """a process that forms solid crystals from a saturated solution by evaporating the solvent"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169562Z"^^xsd:dateTime .

oakcurric:keyword-resultant-force
  a curric:Keyword ;
  schema:name "resultant force"@en ;
  schema:description "is the overall effect of the forces acting on an object"@en ;
  dcterms:modified "2026-02-19T08:26:07.169566Z"^^xsd:dateTime .

oakcurric:keyword-terminal-velocity
  a curric:Keyword ;
  schema:name "terminal velocity"@en ;
  schema:description """is the velocity of an object falling through a fluid, when there is zero resultant force"""@en ;
  dcterms:modified "2026-02-19T08:26:07.169571Z"^^xsd:dateTime .

oakcurric:keyword-ray
  a curric:Keyword ;
  schema:name "ray"@en ;
  schema:description """A ray is a straight line drawn to represent the direction that a light wave travels."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169584Z"^^xsd:dateTime .

oakcurric:keyword-normal
  a curric:Keyword ;
  schema:name "normal"@en ;
  schema:description "The normal is an imaginary line drawn at 90° to a surface."@en ;
  dcterms:modified "2026-02-19T08:26:07.169589Z"^^xsd:dateTime .

oakcurric:keyword-wavefront
  a curric:Keyword ;
  schema:name "wavefront"@en ;
  schema:description "Wavefronts are lines drawn to represent peaks of a wave."@en ;
  dcterms:modified "2026-02-19T08:26:07.169593Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional
  a curric:Keyword ;
  schema:name "directly proportional"@en ;
  schema:description "a relationship between variables in which one is a multiple of the other"@en ;
  dcterms:modified "2026-02-19T08:26:07.169611Z"^^xsd:dateTime .

oakcurric:keyword-cell-wall
  a curric:Keyword ;
  schema:name "cell wall"@en ;
  schema:description """A subcellular structure made from cellulose fibres that strengthens the cell and supports the plant."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169665Z"^^xsd:dateTime .

oakcurric:keyword-classification-key
  a curric:Keyword ;
  schema:name "classification key"@en ;
  schema:description """A classification key is a series of questions about the features of organisms that help us to classify them correctly."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169735Z"^^xsd:dateTime .

oakcurric:keyword-base
  a curric:Keyword ;
  schema:name "Base"@en ;
  schema:description "The base is the side which is perpendicular to the shape’s height."@en ;
  dcterms:modified "2026-02-19T08:26:07.169779Z"^^xsd:dateTime .

oakcurric:keyword-permeable
  a curric:Keyword ;
  schema:name "permeable"@en ;
  schema:description "A material is permeable if particles of a liquid are able to move through it."@en ;
  dcterms:modified "2026-02-19T08:26:07.169800Z"^^xsd:dateTime .

oakcurric:keyword-evaporation-rate
  a curric:Keyword ;
  schema:name "evaporation rate"@en ;
  schema:description "The evaporation rate is a measure of how quickly a substance evaporates."@en ;
  dcterms:modified "2026-02-19T08:26:07.169827Z"^^xsd:dateTime .

oakcurric:keyword-alcohol
  a curric:Keyword ;
  schema:name "alcohol"@en ;
  schema:description "Ethanol is a type of alcohol that has a higher evaporation rate than water."@en ;
  dcterms:modified "2026-02-19T08:26:07.169833Z"^^xsd:dateTime .

oakcurric:keyword-series-circuit
  a curric:Keyword ;
  schema:name "series circuit"@en ;
  schema:description "an electrical circuit with a single loop"@en ;
  dcterms:modified "2026-02-19T08:26:07.169838Z"^^xsd:dateTime .

oakcurric:keyword-potential-difference-pd
  a curric:Keyword ;
  schema:name "potential difference (p.d.)"@en ;
  schema:description "a measure of the push an electric field gives to charges"@en ;
  dcterms:modified "2026-02-19T08:26:07.169843Z"^^xsd:dateTime .

oakcurric:keyword-dynamics-trolley
  a curric:Keyword ;
  schema:name "dynamics trolley"@en ;
  schema:description """A dynamics trolley is a wheeled device used in experiments to study motion, designed to move smoothly over flat surfaces."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169852Z"^^xsd:dateTime .

oakcurric:keyword-average-speed
  a curric:Keyword ;
  schema:name "average speed"@en ;
  schema:description """The average speed of an object is the total distance travelled divided by the total time taken for a journey."""@en ;
  dcterms:modified "2026-02-19T08:26:07.169858Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-speed
  a curric:Keyword ;
  schema:name "instantaneous speed"@en ;
  schema:description "The instantaneous speed of an object is its speed at a specific moment in time."@en ;
  dcterms:modified "2026-02-19T08:26:07.169863Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description "The gradient on a displacement-time graph gives the instantaneous velocity."@en ;
  dcterms:modified "2026-02-19T08:26:07.169878Z"^^xsd:dateTime .

oakcurric:keyword-luminous
  a curric:Keyword ;
  schema:name "luminous"@en ;
  schema:description "Describes something that gives out light."@en ;
  dcterms:modified "2026-02-19T08:26:07.169913Z"^^xsd:dateTime .

oakcurric:keyword-non-luminous
  a curric:Keyword ;
  schema:name "non-luminous"@en ;
  schema:description "Describes something that does not give out light."@en ;
  dcterms:modified "2026-02-19T08:26:07.169918Z"^^xsd:dateTime .

oakcurric:keyword-scatter
  a curric:Keyword ;
  schema:name "scatter"@en ;
  schema:description "Surfaces that scatter light reflect light in many directions at once."@en ;
  dcterms:modified "2026-02-19T08:26:07.169922Z"^^xsd:dateTime .

oakcurric:keyword-pupil
  a curric:Keyword ;
  schema:name "pupil"@en ;
