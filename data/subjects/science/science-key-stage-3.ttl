  dcterms:modified "2026-02-19T08:26:07.172349Z"^^xsd:dateTime .

oakcurric:keyword-absorb
  a curric:Keyword ;
  schema:name "absorb"@en ;
  schema:description """materials that absorb sound reduce the vibrations of the air (as sound is easily transmitted to/through them)"""@en ;
  dcterms:modified "2026-02-19T08:26:07.172353Z"^^xsd:dateTime .

oakcurric:keyword-noise
  a curric:Keyword ;
  schema:name "noise"@en ;
