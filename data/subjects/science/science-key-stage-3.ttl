oakcurric:keylearningpoint-lesson-6019-1
  a curric:KeyLearningPoint ;
  rdfs:label "Farmers use chemicals called  fertilisers to produce more crops."@en ;
  dcterms:modified "2026-02-19T08:26:13.627103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6019-2
  a curric:KeyLearningPoint ;
  rdfs:label "Farmers use chemicals called pesticides to produce more crops."@en ;
  dcterms:modified "2026-02-19T08:26:13.627107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6019-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some pesticides kill insects and this helps crops to grow because they are not being eaten."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6019-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some pesticides kill other plants (weeds) that compete with the crops to grow."@en ;
  dcterms:modified "2026-02-19T08:26:13.627114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6019-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisers and pesticides can be harmful to the environment and wildlife."@en ;
  dcterms:modified "2026-02-19T08:26:13.627120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6024-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ecosystems are made up of a community of organisms that interact with each other and their non-living surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms in an ecosystem are interdependent because they depend upon each other for the things they need to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6024-3
  a curric:KeyLearningPoint ;
  rdfs:label """All organisms depend upon producers to make the food that moves through food chains."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6024-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dead organisms and remains of living organisms provide food for other organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.627136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6024-5
  a curric:KeyLearningPoint ;
  rdfs:label """All living organisms depend upon decomposers that break down dead organisms and recycle useful substances for reuse."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6624-1
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is a chemical substance that can be extracted from the cells of organisms such as fruit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6624-2
  a curric:KeyLearningPoint ;
  rdfs:label """DNA molecules cannot usually be seen with the unaided eye, but clumps of it can be seen when a lot of it is extracted."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observing or following an appropriate method to extract DNA from fruit (e.g. kiwi fruit)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6624-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussion of apparatus and techniques used to filter the tissue and extract the DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6624-5
  a curric:KeyLearningPoint ;
  rdfs:label "Observing and describing the appearance of the DNA after extraction."@en ;
  dcterms:modified "2026-02-19T08:26:13.627214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5031-1
  a curric:KeyLearningPoint ;
  rdfs:label "With the same battery, two bulbs in parallel are brighter than two in series."@en ;
  dcterms:modified "2026-02-19T08:26:13.627313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5031-2
  a curric:KeyLearningPoint ;
  rdfs:label """With the same battery, current through two bulbs in parallel is bigger than through two in series."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5031-3
  a curric:KeyLearningPoint ;
  rdfs:label """With the same battery, voltage across one of two bulbs in parallel is bigger than across one of two bulbs in series."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5031-4
  a curric:KeyLearningPoint ;
  rdfs:label """With the same battery, two bulbs in parallel are transferring energy from the battery more quickly than two in series."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5031-5
  a curric:KeyLearningPoint ;
  rdfs:label """A battery lighting two bulbs in parallel will run out faster than the same battery lighting the two bulbs in series."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5029-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a parallel circuit, each loop can be traced from one end of the cell or battery to the other end."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each loop in a parallel circuit is equivalent to a series circuit connected to the same cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5029-3
  a curric:KeyLearningPoint ;
  rdfs:label """A parallel circuit can be split into a number of series circuits each connected to the ends of the same cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6656-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stimulants make you feel more alert and can give you quicker thinking and reaction times."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6656-2
  a curric:KeyLearningPoint ;
  rdfs:label "Caffeine is a legal stimulant  present in some foods and drinks."@en ;
  dcterms:modified "2026-02-19T08:26:13.627858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6656-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cocaine and ecstasy are examples of illegal stimulants used as recreational drugs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6656-4
  a curric:KeyLearningPoint ;
  rdfs:label "Substance abuse can cause physical and mental health issues."@en ;
  dcterms:modified "2026-02-19T08:26:13.627866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5130-1
  a curric:KeyLearningPoint ;
  rdfs:label """Each column of the periodic table is called a group, and each row is called a period."""@en ;
  dcterms:modified "2026-02-19T08:26:13.634169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5130-2
  a curric:KeyLearningPoint ;
  rdfs:label """The periodic table was developed by a Russian scientist called Dimitri Mendeleev."""@en ;
  dcterms:modified "2026-02-19T08:26:13.634175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5130-3
  a curric:KeyLearningPoint ;
  rdfs:label """The periodic table contains all the elements organised into groups and periods, according to their properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.634179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5130-4
  a curric:KeyLearningPoint ;
  rdfs:label "The elements in the same group in the periodic table have similar properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.634183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5130-5
  a curric:KeyLearningPoint ;
  rdfs:label """In addition to groups, elements can be divided into non-metals and metals, which include the transition metals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.634187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Immiscible liquids do not mix and if allowed to settle, one will float above the other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.636671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6441-2
  a curric:KeyLearningPoint ;
  rdfs:label "Immiscible liquids can be separated by decanting or using a separating funnel."@en ;
  dcterms:modified "2026-02-19T08:26:13.636676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6441-3
  a curric:KeyLearningPoint ;
  rdfs:label "If left, miscible liquids do not separate into layers."@en ;
  dcterms:modified "2026-02-19T08:26:13.636681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6441-4
  a curric:KeyLearningPoint ;
  rdfs:label """The boiling points of liquids can be used to separate miscible liquids by changing states."""@en ;
  dcterms:modified "2026-02-19T08:26:13.636686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6474-1
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources will not run out because they are replenished more quickly than we use them up"""@en ;
  dcterms:modified "2026-02-19T08:26:13.641026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6474-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity can be generated by spinning coils of wire in an electric generator with a turbine"""@en ;
  dcterms:modified "2026-02-19T08:26:13.641030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6474-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turbines can be spun using falling water or wind"@en ;
  dcterms:modified "2026-02-19T08:26:13.641034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6474-4
  a curric:KeyLearningPoint ;
  rdfs:label "Turbines can be spun using moving steam made by burning biomass, oil or gas"@en ;
  dcterms:modified "2026-02-19T08:26:13.641038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6474-5
  a curric:KeyLearningPoint ;
  rdfs:label "Solar panels produce electricity without electric generators"@en ;
  dcterms:modified "2026-02-19T08:26:13.641042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4978-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transparent objects transmit light (let light travel through them). Opaque objects do not transmit light through them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.646980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4978-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light travels in straight lines at an extremely high speed, spreading out as it travels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.647002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4978-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light rays are straight arrows added to diagrams to show the direction that some light is travelling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.647006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4978-4
  a curric:KeyLearningPoint ;
  rdfs:label "A shadow is an unlit area in the shape of an object that is blocking light."@en ;
  dcterms:modified "2026-02-19T08:26:13.647010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6422-1
  a curric:KeyLearningPoint ;
  rdfs:label """The solubility of a substance could depend upon the size of the solute pieces, the choice or temperature of the solvent."""@en ;
  dcterms:modified "2026-02-19T08:26:13.651709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6422-2
  a curric:KeyLearningPoint ;
  rdfs:label """The independent and dependent variables, and any measurements taken during an investigation, are recorded in a table."""@en ;
  dcterms:modified "2026-02-19T08:26:13.651713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6465-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a crystal, the atoms are all arranged in a very regular pattern."@en ;
  dcterms:modified "2026-02-19T08:26:13.655542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6465-2
  a curric:KeyLearningPoint ;
  rdfs:label """In some substances, very high pressure, at a high temperature, can push particles together to form crystals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.655546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6465-3
  a curric:KeyLearningPoint ;
  rdfs:label """Between tectonic plates, the pressure and temperature are high enough for large crystals to grow inside solid rock."""@en ;
  dcterms:modified "2026-02-19T08:26:13.655552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6465-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metamorphic rocks form under extreme pressure and temperature, altering original structures."""@en ;
  dcterms:modified "2026-02-19T08:26:13.655556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6465-5
  a curric:KeyLearningPoint ;
  rdfs:label """Aligned crystals in metamorphic rocks give them useful properties (e.g. decoration or easily separated into sheets)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.655560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6472-1
  a curric:KeyLearningPoint ;
  rdfs:label "Burning a fuel transfers energy by heating its surroundings."@en ;
  dcterms:modified "2026-02-19T08:26:13.661629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6472-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heating water in a boiling tube allows the amounts of energy transferred by different fuels to be compared."""@en ;
  dcterms:modified "2026-02-19T08:26:13.661633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6472-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mass of fuel used needs to be the same for each measurement."@en ;
  dcterms:modified "2026-02-19T08:26:13.661637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6472-4
  a curric:KeyLearningPoint ;
  rdfs:label """The temperature and volume of water being heated needs to be the same for each measurement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.661641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6435-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reactants are the chemicals that react in a chemical reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.662454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6435-2
  a curric:KeyLearningPoint ;
  rdfs:label "Products are the chemicals that are formed in a chemical reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.662458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6435-3
  a curric:KeyLearningPoint ;
  rdfs:label """The products and reactants in a chemical reaction contain exactly the same atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.662462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6435-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atoms in the products of a chemical reaction are bonded differently to the same atoms in the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.662466Z"^^xsd:dateTime .

