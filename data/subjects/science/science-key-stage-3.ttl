  dcterms:modified "2026-02-19T08:26:07.183394Z"^^xsd:dateTime .

oakcurric:keyword-normal-reaction-force
  a curric:Keyword ;
  schema:name "normal reaction force"@en ;
  schema:description """When an object rests on a surface, there will be a normal reaction force acting on it."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183416Z"^^xsd:dateTime .

oakcurric:keyword-vacuole
  a curric:Keyword ;
  schema:name "Vacuole"@en ;
  schema:description """The vacuole of a plant cell contains watery sap which, when full, keeps the cell firm."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183493Z"^^xsd:dateTime .

oakcurric:keyword-depth
  a curric:Keyword ;
  schema:name "depth"@en ;
  schema:description "Depth is the distance under the surface of a liquid."@en ;
  dcterms:modified "2026-02-19T08:26:07.183530Z"^^xsd:dateTime .

oakcurric:keyword-regular-arrangement
  a curric:Keyword ;
  schema:name "regular arrangement"@en ;
  schema:description "In a solid state the particles are in a regular arrangement."@en ;
  dcterms:modified "2026-02-19T08:26:07.183623Z"^^xsd:dateTime .

oakcurric:keyword-random-arrangement
  a curric:Keyword ;
  schema:name "random arrangement"@en ;
  schema:description "In a liquid state the particles are in a random arrangement."@en ;
  dcterms:modified "2026-02-19T08:26:07.183627Z"^^xsd:dateTime .

oakcurric:keyword-displaced
  a curric:Keyword ;
  schema:name "displaced"@en ;
  schema:description "Water is displaced (moved) when an object floats on it or sinks in it."@en ;
  dcterms:modified "2026-02-19T08:26:07.183716Z"^^xsd:dateTime .

oakcurric:keyword-balanced
  a curric:Keyword ;
  schema:name "balanced"@en ;
  schema:description "A beam is balanced if it is not starting to rotate about its pivot."@en ;
  dcterms:modified "2026-02-19T08:26:07.183723Z"^^xsd:dateTime .

oakcurric:keyword-newton-metre
  a curric:Keyword ;
  schema:name "newton-metre"@en ;
  schema:description "One unit for the turning effect of a force is the newton-metre (N m)."@en ;
  dcterms:modified "2026-02-19T08:26:07.183727Z"^^xsd:dateTime .

oakcurric:keyword-newton-centimetre
  a curric:Keyword ;
  schema:name "newton-centimetre"@en ;
  schema:description "Another unit for the turning effect of a force is the newton-centimetre (N cm)."@en ;
  dcterms:modified "2026-02-19T08:26:07.183732Z"^^xsd:dateTime .

oakcurric:keyword-numerical
  a curric:Keyword ;
  schema:name "numerical"@en ;
  schema:description "A value that is a number; these variables may display trends."@en ;
  dcterms:modified "2026-02-19T08:26:07.183795Z"^^xsd:dateTime .

oakcurric:keyword-herbicide
  a curric:Keyword ;
  schema:name "herbicide"@en ;
  schema:description """Herbicides are a type of pesticide. They kill plants. They are sometimes also known as weedkillers."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183815Z"^^xsd:dateTime .

oakcurric:keyword-insecticide
  a curric:Keyword ;
  schema:name "insecticide"@en ;
  schema:description "Insecticides are a type of pesticide. These chemicals kill insects."@en ;
  dcterms:modified "2026-02-19T08:26:07.183819Z"^^xsd:dateTime .

oakcurric:keyword-mortar-and-pestle
  a curric:Keyword ;
  schema:name "mortar and pestle"@en ;
  schema:description "A mortar and pestle are used to crush and grind up solid samples."@en ;
  dcterms:modified "2026-02-19T08:26:07.183828Z"^^xsd:dateTime .

oakcurric:keyword-pipette
  a curric:Keyword ;
  schema:name "pipette"@en ;
  schema:description "A pipette is used to transfer small quantities of liquid."@en ;
  dcterms:modified "2026-02-19T08:26:07.183832Z"^^xsd:dateTime .

oakcurric:keyword-recreational
  a curric:Keyword ;
  schema:name "recreational"@en ;
  schema:description "something that is done for fun"@en ;
  dcterms:modified "2026-02-19T08:26:07.183979Z"^^xsd:dateTime .

oakcurric:keyword-stimulant
  a curric:Keyword ;
  schema:name "stimulant"@en ;
  schema:description "speeds up the messages sent from the brain the nerves"@en ;
  dcterms:modified "2026-02-19T08:26:07.183983Z"^^xsd:dateTime .

oakcurric:keyword-periodic-table
  a curric:Keyword ;
  schema:name "periodic table"@en ;
  schema:description """is a list of all known elements, ordered by increasing atomic number. It is split into vertical columns called groups, and horizontal rows called periods."""@en ;
  dcterms:modified "2026-02-19T08:26:07.185875Z"^^xsd:dateTime .

oakcurric:keyword-transition-metals
  a curric:Keyword ;
  schema:name "transition metals"@en ;
  schema:description "a group of metals found in the central block of the periodic table."@en ;
  dcterms:modified "2026-02-19T08:26:07.185882Z"^^xsd:dateTime .

oakcurric:keyword-immiscible
  a curric:Keyword ;
  schema:name "immiscible"@en ;
  schema:description """Liquids that are not soluble in another liquid are described as immiscible in that liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:07.186727Z"^^xsd:dateTime .

oakcurric:keyword-decanting
  a curric:Keyword ;
  schema:name "decanting"@en ;
  schema:description """Decanting is a process of pouring off the top layer in a mixture of immiscible liquids, or a liquid and insoluble solid."""@en ;
  dcterms:modified "2026-02-19T08:26:07.186732Z"^^xsd:dateTime .

oakcurric:keyword-dissolving
  a curric:Keyword ;
  schema:name "dissolving"@en ;
  schema:description """The process in which a substance's particles separate and spread uniformly throughout the particles of a solvent, resulting in the substance no longer being seen."""@en ;
  dcterms:modified "2026-02-19T08:26:07.189500Z"^^xsd:dateTime .

oakcurric:keyword-table-of-results
  a curric:Keyword ;
  schema:name "table of results"@en ;
  schema:description "An orderly way in which to record data."@en ;
  dcterms:modified "2026-02-19T08:26:07.189504Z"^^xsd:dateTime .

oakcurric:keyword-anomalous
  a curric:Keyword ;
  schema:name "anomalous"@en ;
  schema:description "A result that does not fit an obvious trend."@en ;
  dcterms:modified "2026-02-19T08:26:07.189508Z"^^xsd:dateTime .

oakcurric:keyword-metamorphic-rock
  a curric:Keyword ;
  schema:name "metamorphic rock"@en ;
  schema:description "Rocks that have changed due to heat and/or pressure (e.g. marble, slate)."@en ;
  dcterms:modified "2026-02-19T08:26:07.190012Z"^^xsd:dateTime .

oakcurric:keyword-aligned
  a curric:Keyword ;
  schema:name "aligned"@en ;
  schema:description "Grains that line up in the same direction are described as aligned."@en ;
  dcterms:modified "2026-02-19T08:26:07.190017Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-vaping-harmless-same-inhaling-steam
  a curric:Misconception ;
  curric:statement "Vaping is harmless and the same as inhaling steam."@en ;
  curric:correction "Vapes contain thousands of chemicals that have unknown effects."@en ;
  dcterms:modified "2026-02-19T08:26:10.347239Z"^^xsd:dateTime .

oakcurric:misconception-because-alcohol-legal-isnt-harmful
  a curric:Misconception ;
  curric:statement "Because alcohol is legal it isn't as harmful as other drugs."@en ;
  curric:correction """Alcohol is related to many lifestyle diseases. The WHO estimated 5 % of all deaths are related to alcohol."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347299Z"^^xsd:dateTime .

oakcurric:misconception-type-graph-chosen-represent-data
  a curric:Misconception ;
  curric:statement "The type of graph chosen to represent data can just be personal choice."@en ;
  curric:correction "Specific kinds of graph should be chosen to represent specific kinds of data."@en ;
  dcterms:modified "2026-02-19T08:26:10.347358Z"^^xsd:dateTime .

oakcurric:misconception-many-pupils-likely-still-use
  a curric:Misconception ;
  curric:statement """Many pupils are likely to still use the terms current, voltage and resistance interchangeably."""@en ;
  curric:correction """Repeatedly question pupils about each term and challenge them to use each one correctly throughout their explanations, both written and verbal."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347368Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-idea-small-atom
  a curric:Misconception ;
  curric:statement "Pupils often struggle with the idea of how small an atom actually is."@en ;
  curric:correction """Use examples to show how many atoms make up certain things, e.g. a cell or a grain of sand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347465Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-common-everyday-usage
  a curric:Misconception ;
  curric:statement """Pupils mistake common (everyday) usage of pure (i.e. pure orange juice) as being a pure substance when it is, in fact, a mixture."""@en ;
  curric:correction """'Everyday' usage refers to one source whereas scientific usage refers to particle composition."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347489Z"^^xsd:dateTime .

oakcurric:misconception-compounds-same-properties-elements-made
  a curric:Misconception ;
  curric:statement """Compounds will have the same properties as the elements from which they are made."""@en ;
  curric:correction """Compounds usually have completely different properties from the elements from which they are made."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347700Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-pesticides-build-within
  a curric:Misconception ;
  curric:statement "Pupils do often not understand that pesticides can build up within a food chain."@en ;
  curric:correction """The lesson covers examples of how pesticides can be absorbed into producers and passed along food chains as organisms eat food."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347724Z"^^xsd:dateTime .

oakcurric:misconception-thinking-physical-mental-health-thinking
  a curric:Misconception ;
  curric:statement """Only thinking about physical and not mental health; thinking health is a binary of "healthy or ill"."""@en ;
  curric:correction """The lesson draws upon research on students' understanding of 'health' as a concept to specifically tackle the above misconceptions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348246Z"^^xsd:dateTime .

oakcurric:misconception-people-either-healthy-unhealthy
  a curric:Misconception ;
  curric:statement "People are either healthy or unhealthy."@en ;
  curric:correction "Health is a range from good to ill. Fitness is one indicator of general health."@en ;
  dcterms:modified "2026-02-19T08:26:10.348704Z"^^xsd:dateTime .

oakcurric:misconception-energy-used
  a curric:Misconception ;
  curric:statement "Energy can be used up."@en ;
  curric:correction """Describe the mechanisms that transfer energy from one object to another, or to a system, as the energy in the original object decreases – or vice versa."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348720Z"^^xsd:dateTime .

oakcurric:misconception-malnutrition-thin
  a curric:Misconception ;
  curric:statement "Malnutrition is all about being too thin."@en ;
  curric:correction "Clear statement included to dispel this myth."@en ;
  dcterms:modified "2026-02-19T08:26:10.348763Z"^^xsd:dateTime .

oakcurric:misconception-confusing-spelling-noble-nobel-misunderstanding
  a curric:Misconception ;
  curric:statement """Confusing the spelling of "noble" with "Nobel" and misunderstanding why noble gases are named so."""@en ;
  curric:correction """Clarify that "noble" refers to their stability and lack of reactivity due to a full outer electron shell, meaning they don't need to bond with other elements."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348857Z"^^xsd:dateTime .

oakcurric:misconception-burning-hydrocarbons-results-harmless-products
  a curric:Misconception ;
  curric:statement "Burning hydrocarbons results in harmless products."@en ;
  curric:correction """Teach about carbon dioxide being a greenhouse gas, and the impact on global temperatures."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349010Z"^^xsd:dateTime .

oakcurric:misconception-energy-sort-physical-substance-objects
  a curric:Misconception ;
  curric:statement "Energy is some sort of physical substance that objects have."@en ;
  curric:correction """Energy is just a label for having certain properties. The properties are what allow objects to interact / cause change / make things happen."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349086Z"^^xsd:dateTime .

oakcurric:misconception-genetic-code-dna-same-thing
  a curric:Misconception ;
  curric:statement "The genetic code and DNA are the same thing."@en ;
  curric:correction """The DNA is a long chemical molecule made of four different types of chemical units (A, T, C, G). These units make up the genetic code."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349090Z"^^xsd:dateTime .

oakcurric:misconception-halogens-gases-room-temperature-because
  a curric:Misconception ;
  curric:statement """All halogens are gases at room temperature because they're non-metals; all halogens form toxic compounds."""@en ;
  curric:correction """Not all halogens are gases at room temperature; bromine is a liquid and iodine is a solid. Halogens can be toxic in their elemental form or in high concentrations, but they also form essential compounds, like table salt and disinfectants."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349095Z"^^xsd:dateTime .

oakcurric:misconception-pollen-seeds-seeds-made-sexual
  a curric:Misconception ;
  curric:statement "Pollen are seeds, or that seeds are not made by sexual reproduction."@en ;
  curric:correction """Clearly show the difference between pollen as a gamete and the seeds as the offspring that grows into a new plant."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349378Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-temperature-larger-ice
  a curric:Misconception ;
  curric:statement """Pupils often think that the temperature of larger ice cubes is colder than smaller ones because they take longer to melt."""@en ;
  curric:correction """Emphasise that both a small and large ice cube are at the same temperature when they are in the same freezer."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349410Z"^^xsd:dateTime .

oakcurric:misconception-believing-need-oxygen-breathe
  a curric:Misconception ;
  curric:statement "Believing that we need oxygen to breathe."@en ;
  curric:correction """We breathe to get oxygen into our bodies so cells can use it as fuel for respiration."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349546Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-misidentify-similar-looking
  a curric:Misconception ;
  curric:statement "Pupils tend to misidentify similar looking apparatus."@en ;
  curric:correction """Focus on the uses of each apparatus, highlight its distinguishing features to help pupils correctly identify apparatus."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349687Z"^^xsd:dateTime .

oakcurric:misconception-biodiversity-conservation-take-place-large
  a curric:Misconception ;
  curric:statement """Biodiversity conservation can only take place in large natural habitats such as forests."""@en ;
  curric:correction """Biodiversity conservation can take place on a small scale, for example, by providing habitats in gardens and in urban areas."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349784Z"^^xsd:dateTime .

oakcurric:misconception-carbon-atoms-created-destroyed
  a curric:Misconception ;
  curric:statement "Carbon atoms can be created or destroyed."@en ;
  curric:correction """Focus teaching on the carbon cycle as a closed system in which the total amount of carbon is constant. Discuss the processes of how carbon is transferred from one place to another, rather than processes of how carbon is lost or gained."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349820Z"^^xsd:dateTime .

oakcurric:misconception-control-variables-make-fair-test
  a curric:Misconception ;
  curric:statement "Control variables make it a fair test."@en ;
  curric:correction "Control variables need to be kept the same to make the investigation valid."@en ;
  dcterms:modified "2026-02-19T08:26:10.349907Z"^^xsd:dateTime .

oakcurric:misconception-bacteria-plants-genetic-material-passed
  a curric:Misconception ;
  curric:statement "Bacteria and plants do not have genetic material to be passed to offspring."@en ;
  curric:correction """Examples of both bacteria and plants passing genetic material and features to offspring in reproduction, and the outcomes, i.e. growth."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350030Z"^^xsd:dateTime .

oakcurric:misconception-cells-2d-depicted-diagrams
  a curric:Misconception ;
  curric:statement "Cells are 2D (as they are often depicted in diagrams)."@en ;
  curric:correction """The lesson explores the 3D structure of cells, and the use of both 2D and 3D scientific models of animal cells."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350131Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-negative-refers-neutral
  a curric:Misconception ;
  curric:statement """Pupils often think that ‘negative’ refers to a neutral material, that there is only one type of charge, and that friction creates charge."""@en ;
  curric:correction """Pupils need a secure understanding of the particle model of matter before being introduced to atomic structure. Using dynamic models to help pupils visualise what happens to negative charge can support their progression in understanding."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350184Z"^^xsd:dateTime .

oakcurric:misconception-plants-reproduce-sexually-flowers-produced
  a curric:Misconception ;
  curric:statement "Plants do not reproduce sexually. Flowers are only produced to look attractive."@en ;
  curric:correction """Show examples of the reproductive organs; discuss pollen and ova and relate them to gametes in humans."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350275Z"^^xsd:dateTime .

oakcurric:misconception-elements-cannot-metal-non-metal
  a curric:Misconception ;
  curric:statement "Elements cannot have metal and non-metal properties."@en ;
  curric:correction "Introduction of the metalloids and discussion of their properties."@en ;
  dcterms:modified "2026-02-19T08:26:10.350328Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-everyday-meaning-rather
  a curric:Misconception ;
  curric:statement """Pupils use everyday meaning rather than ecological meaning of the terms population and community."""@en ;
  curric:correction """There is repetition of use of these ecological terms within this unit building on prior learning."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350594Z"^^xsd:dateTime .

oakcurric:misconception-arrows-mean-eats-food-chain
  a curric:Misconception ;
  curric:statement """Arrows mean "eats" in a food chain diagram. Each level is an individual organism."""@en ;
  curric:correction """This lesson explores the meaning of the arrows, and the idea that each level of a food chain diagram is a population of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350807Z"^^xsd:dateTime .

oakcurric:misconception-cells-inert-building-blocks-like
  a curric:Misconception ;
  curric:statement """Cells are inert 'building blocks' like bricks. Microscopes can see structures as small as molecules."""@en ;
  curric:correction """The lesson explores what cells are, including that they are living units, and considers what can and can't be seen using a light microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:10.351829Z"^^xsd:dateTime .

oakcurric:misconception-pupils-interpret-rock-cycle-cause
  a curric:Misconception ;
  curric:statement "Pupils often interpret the rock cycle as the cause of rock formation."@en ;
  curric:correction """Stress the rock cycle is a representation of relationships between the rock types.  For rocks to change from one type to another requires specific conditions (i.e. igneous rock can change into metamorphic or melted into a different igenous rock)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352283Z"^^xsd:dateTime .

oakcurric:misconception-science-understanding-similar-politics-different
  a curric:Misconception ;
  curric:statement """Science understanding is similar to politics and we can all have different opinions about what is correct."""@en ;
  curric:correction """Provide pupils with opportunity to see that scientific understanding is built up on evidence, and the best model we have fits with the evidence and can explain observations."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352431Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-compaction-cementation-same
  a curric:Misconception ;
  curric:statement "Some pupils think that compaction and cementation are the same processes."@en ;
  curric:correction """Highlight that compaction is due to pressure while cementation occurs when minerals act as a 'glue' holding sediments together."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352516Z"^^xsd:dateTime .

oakcurric:misconception-fat-diet-excluded
  a curric:Misconception ;
  curric:statement "All fat in the diet should be excluded."@en ;
  curric:correction """Fat is vital for a healthy balanced diet. Unsaturated fats from plants help to build cell membranes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352660Z"^^xsd:dateTime .

oakcurric:misconception-current-used-consumed-electrical-components
  a curric:Misconception ;
  curric:statement "Current is used up (consumed) by electrical components."@en ;
  curric:correction """Use the rope–loop model to model how the battery (hands) force current (rope) around the circuit against the resistance of components (hands squeezing the rope)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.353109Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sound-material-substance
  a curric:Misconception ;
  curric:statement """Pupils can think that sound is a material substance, or involves particles of some kind (e.g. of air, or 'of sound') travelling or being blown out from a source."""@en ;
  curric:correction """Spend time exploring and modelling how vibrating objects set particles vibrating, how vibrating particles will collide into neighbouring particles to set them vibrating too, and how patterns of vibrations produce the 'pulses' of a sound wave."""@en ;
  dcterms:modified "2026-02-19T08:26:10.353433Z"^^xsd:dateTime .

oakcurric:misconception-thinking-individual-weather-events-evidence
  a curric:Misconception ;
  curric:statement """Thinking that individual weather events are evidence for or against climate change."""@en ;
  curric:correction """The lesson explores the correct idea that an increase in the frequency of extreme weather events is evidence of climate change and we have to look at the long term pattern of weather events as evidence."""@en ;
  dcterms:modified "2026-02-19T08:26:10.354030Z"^^xsd:dateTime .

oakcurric:misconception-solvents-short-term-effects
  a curric:Misconception ;
  curric:statement "Solvents only have very short-term effects."@en ;
  curric:correction "Long-term solvent abuse can lead to brain damage and even death."@en ;
  dcterms:modified "2026-02-19T08:26:10.354368Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-existence-drag-force
  a curric:Misconception ;
  curric:statement """Pupils often do not recognise the existence of a drag force on an object moving through air."""@en ;
  curric:correction """Demonstrate the effect of drag forces by dropping pieces or paper (folded and unfolded) and show they reach the ground at different times."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358280Z"^^xsd:dateTime .

oakcurric:misconception-eat-fat
  a curric:Misconception ;
  curric:statement "We should not eat fat."@en ;
  curric:correction """Fat makes up an important part of our diet. We use it as a store of energy and to make cell membranes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358626Z"^^xsd:dateTime .

oakcurric:misconception-object-force-provides-kind-agency
  a curric:Misconception ;
  curric:statement """An object 'has' force that provides it some kind of agency, which is independent of other objects."""@en ;
  curric:correction """Describe forces as interactions between two objects using the structure 'the force of object A on object B'."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358636Z"^^xsd:dateTime .

oakcurric:misconception-group-2-metals-reactive-group
  a curric:Misconception ;
  curric:statement """Group 2 metals are more reactive than Group 1 because reactivity increases across the groups."""@en ;
  curric:correction """Group 1 metals are more reactive with water; reactivity increases down a group (for Groups 1 and 2), not along a period."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358785Z"^^xsd:dateTime .

oakcurric:misconception-friction-force
  a curric:Misconception ;
  curric:statement "Friction is not a force."@en ;
  curric:correction """Provide examples of friction slowing objects and preventing them from moving when they are pushed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358902Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unable-match-their-experience
  a curric:Misconception ;
  curric:statement """Pupils are often unable to match their experience of different forces with forces in newtons."""@en ;
  curric:correction """Pupils are provided with opportunity to both measure and describe a range of forces."""@en ;
  dcterms:modified "2026-02-19T08:26:10.358907Z"^^xsd:dateTime .

oakcurric:misconception-friction-solids-rubbing-together
  a curric:Misconception ;
  curric:statement "Friction is only between solids that are rubbing together."@en ;
  curric:correction """Highlight the different amounts of friction between the solids that are separated by different liquids."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359015Z"^^xsd:dateTime .

oakcurric:misconception-sun-star
  a curric:Misconception ;
  curric:statement "The Sun is not a star."@en ;
  curric:correction """Make it clear that the only reason the Sun looks different to the stars in the night sky is because it is so much closer to Earth. Use visual examples to show what the Sun and/or other stars would look like at greater distances."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359565Z"^^xsd:dateTime .

oakcurric:misconception-pupils-reluctant-struggle-plot-multiple
  a curric:Misconception ;
  curric:statement "Pupils are reluctant/struggle to plot multiple sets of data on one graph."@en ;
  curric:correction """Fold the table of results so pupils are only looking at one set of data at a time when plotting. Use different plot symbols/colours too."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359585Z"^^xsd:dateTime .

oakcurric:misconception-pupil-confuse-diffusion-brownian-motion
  a curric:Misconception ;
  curric:statement "Pupil confuse diffusion and Brownian motion."@en ;
  curric:correction """Brownian motion is the random movement of particles due to collisions. Diffusion is due to concentration differences between 2 substances."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359595Z"^^xsd:dateTime .

oakcurric:misconception-sound-needs-gaps-moves-order
  a curric:Misconception ;
  curric:statement """Sound needs gaps through which it moves in order to enter a room or space. At the same time, most pupils can state that sound can't travel in a vacuum but the majority cannot correctly explain why."""@en ;
  curric:correction """An alarm can still be heard in a sealed container that has no gaps (e.g. kilner jar). Provide lots of experiences and examples of sound travelling through gases, liquids and solids and struggling to travel through a partial vacuum."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359600Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-similarly-sounding-key
  a curric:Misconception ;
  curric:statement """Pupils confuse similarly sounding key terms; solute, solvent, solution, soluble, insoluble."""@en ;
  curric:correction """Spend time discussing ways to remember the differences, e.g. solvent has more letters = have more of it in the solution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359605Z"^^xsd:dateTime .

oakcurric:misconception-forces-attraction-broken-substance-dissolves
  a curric:Misconception ;
  curric:statement "Forces of attraction are broken when a substance dissolves."@en ;
  curric:correction """Forces of attraction are *overcome*. They are still acting between the particles, but weaker than before so a different particle arrangement"""@en ;
  dcterms:modified "2026-02-19T08:26:10.359613Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-concept-vibrations-explain
  a curric:Misconception ;
  curric:statement """Pupils often do not use the concept of vibrations to explain the source of a sound, if the vibrations are not obvious, such as vibrating air in a wind instrument or from two stones knocked together."""@en ;
  curric:correction """Include examples of sounds caused by vibrations that are not caused by something that is obviously vibrating, such as a string in a stringed instrument."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359638Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-confuse-independent-dependent
  a curric:Misconception ;
  curric:statement "Pupils tend to confuse independent and dependent variables."@en ;
  curric:correction """Think of an experiment as "cause and effect." The independent variable is what you change – the cause. The dependent variable is what you measure – the effect of that change."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359651Z"^^xsd:dateTime .

oakcurric:misconception-energy-hot-objects-disappears-destroyed
  a curric:Misconception ;
  curric:statement "The energy of hot objects disappears (is destroyed) as they cool."@en ;
  curric:correction """Placing a cup of hot water into a surrounding bowl of cold water that is warmed without the waters mixing demonstrates how surroundings are heated as energy is dissipated."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359691Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-interpret-information-contain
  a curric:Misconception ;
  curric:statement """Pupils can struggle to interpret information that contain several samples on one chromatogram."""@en ;
  curric:correction """Stress a systematic approach to interpreting chromatograms - use rulers. Live model this  - using a visualiser helps enormously."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359799Z"^^xsd:dateTime .

oakcurric:misconception-funnel-same-filter-dissolved-substances
  a curric:Misconception ;
  curric:statement """A funnel is the same as a filter.  Dissolved substances will be collected in the filter paper."""@en ;
  curric:correction """A filter separates materials. Dissolved substances are smaller than the pores in the filter paper and so will pass through with the liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359824Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-heating-substance-strongly
  a curric:Misconception ;
  curric:statement """Pupils think that heating a substance strongly and for extended periods will improve distillation."""@en ;
  curric:correction """Stress that distillation is a skill which requires careful control of heating so only one substance is in the condenser at a time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359848Z"^^xsd:dateTime .

oakcurric:misconception-features-caused-environment-lifestyle-passed
  a curric:Misconception ;
  curric:statement "Features caused by the environment or lifestyle can be passed to offspring."@en ;
  curric:correction """Examples of inherited features e.g. eye colour, those that are environment and lifestyle  e.g. scars, and those that are both e.g. height."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359856Z"^^xsd:dateTime .

oakcurric:misconception-filtration-alone-separate-salt-rock
  a curric:Misconception ;
  curric:statement """Filtration alone can separate salt from rock salt - idea that only one technique is needed."""@en ;
  curric:correction """Highlight that each separation technique (so far) creates two products; one of them may still be a mixture that requires further separation."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359913Z"^^xsd:dateTime .

oakcurric:misconception-samples-water-added-different-temperatures
  a curric:Misconception ;
  curric:statement """When samples of water are added at different temperatures, some pupils add or subtract the temperatures, applying a mathematical process without appearing to think about what is happening."""@en ;
  curric:correction """Ask pupils to predict changes to the resulting temperature using water at a range of starting temperatures and then demonstrate each one, measuring the temperature of the resultant mixture each time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359918Z"^^xsd:dateTime .

oakcurric:misconception-heat-substance-flows-thermal-conductors
  a curric:Misconception ;
  curric:statement "Heat is a substance that flows through thermal conductors."@en ;
  curric:correction """Emphasise that in a solid the particles do not move along the material during thermal conduction and that what we experience as ‘heat’ is particles in an object vibrating against our skin."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359922Z"^^xsd:dateTime .

oakcurric:misconception-energy-temperature-same-thing
  a curric:Misconception ;
  curric:statement "Energy and temperature are the same thing."@en ;
  curric:correction """Warm different amounts of water in identical kettles for the same time to show they reach different temperatures for the same energy transferred."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359927Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-gas-state
  a curric:Misconception ;
  curric:statement """Pupils struggle to understand gas state; thinking solids, liquids and gases as 'types' of matter."""@en ;
  curric:correction """Refer to/use particle models to help clarify different states of matter and use these to describe why separation techniques work."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359940Z"^^xsd:dateTime .

oakcurric:misconception-interdependence-organisms-within-ecosystems-arise
  a curric:Misconception ;
  curric:statement """The interdependence of organisms within ecosystems arise from more than just feeding relationships."""@en ;
  curric:correction """This lesson demonstrates that feeding relationships are important and that producers often rely on consumers for reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359984Z"^^xsd:dateTime .

oakcurric:misconception-bacteria-bad-us-make-us
  a curric:Misconception ;
  curric:statement "All bacteria are bad for us and make us unwell."@en ;
  curric:correction """The lesson looks at how helpful bacteria in the gut help us digest our food, provide vitamins, and outcompete harmful bacteria."""@en ;
  dcterms:modified "2026-02-19T08:26:10.359993Z"^^xsd:dateTime .

oakcurric:misconception-pupils-estimate-temperature-object-based
  a curric:Misconception ;
  curric:statement """Pupils often estimate the temperature of an object based on its materials, rather than the temperature of the surroundings."""@en ;
  curric:correction """Measure the temperature of several things that are all at room temperature such as water, sand and the air, in order to show that they are all the same."""@en ;
  dcterms:modified "2026-02-19T08:26:10.360079Z"^^xsd:dateTime .

oakcurric:misconception-insulators-warm-objects
  a curric:Misconception ;
  curric:statement "Insulators warm objects up."@en ;
  curric:correction """Show your class that an insulator keeps an ice cube colder for longer by wrapping one in a conductor (such as aluminium foil) and another in an insulator at the start of the lesson. The ice cube in the conductor will melt first."""@en ;
  dcterms:modified "2026-02-19T08:26:10.360115Z"^^xsd:dateTime .

oakcurric:misconception-gravity-space-even-short-distance
  a curric:Misconception ;
  curric:statement "There is no gravity in space, even a short distance from the Earth."@en ;
  curric:correction """Carefully whirl a rubber bung around your head on a length of string to show how force of a string keeps it orbiting in a circle, just as the force of gravity keeps the Moon orbiting the Earth and the planets orbiting the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361132Z"^^xsd:dateTime .

oakcurric:misconception-particles-want-intend-spread-particles
  a curric:Misconception ;
  curric:statement """Particles want or intend to spread out; particles stop moving after equilibrium has been reached."""@en ;
  curric:correction "Animations show particles in continuous random motion."@en ;
  dcterms:modified "2026-02-19T08:26:10.361263Z"^^xsd:dateTime .

oakcurric:misconception-pupils-cant-understand-substances-change
  a curric:Misconception ;
  curric:statement """Some pupils can't understand that substances can change from one state to another state."""@en ;
  curric:correction """Ensure that the language used is solid state, liquid state and gas state, not solid, liquid and gas."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361273Z"^^xsd:dateTime .

oakcurric:misconception-blood-circulatory-system-synonyms
  a curric:Misconception ;
  curric:statement "That the blood and circulatory system are synonyms."@en ;
  curric:correction "Blood and circulatory system are key words and introduced as specific concepts."@en ;
  dcterms:modified "2026-02-19T08:26:10.361365Z"^^xsd:dateTime .

oakcurric:misconception-stars-planets-our-solar-system
  a curric:Misconception ;
  curric:statement """Stars and the planets in our solar system are intermingled, with stars between the planets."""@en ;
  curric:correction """Make it clear with diagrams, scaled examples and/or videos (freely available online) that 'zoom out' from Earth, that the second nearest star to Earth is 10 000 times further away from the Sun than Neptune, the most distant planet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361370Z"^^xsd:dateTime .

oakcurric:misconception-earth-moves-closer-sun-summer
  a curric:Misconception ;
  curric:statement "Earth moves closer to the Sun in the summer and further away in the winter."@en ;
  curric:correction """Remind students that Earth's orbit is nearly a perfect circle with the Sun at the centre so Earth's distance to the Sun does not significantly change over a year, and also that not everywhere on Earth has a warmer season at the same time, or at all."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361521Z"^^xsd:dateTime .

oakcurric:misconception-role-stomach-misunderstood-main-place
  a curric:Misconception ;
  curric:statement """The role of the stomach is often misunderstood as the main or only place where digestion occurs."""@en ;
  curric:correction """The lesson explores the roles of the stomach and the intestines in digesting food and absorbing nutrients."""@en ;
  dcterms:modified "2026-02-19T08:26:10.361536Z"^^xsd:dateTime .

oakcurric:misconception-particles-cannot-diffuse-seemingly-solid
  a curric:Misconception ;
  curric:statement "Particles cannot diffuse through a seemingly solid material."@en ;
  curric:correction """This practical lesson enables pupils to observe the diffusion of acid through permeable cubes of coloured jelly."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362109Z"^^xsd:dateTime .

oakcurric:misconception-evaporation-occurs-boiling-point-substance
  a curric:Misconception ;
  curric:statement "Evaporation only occurs above the boiling point of a substance."@en ;
  curric:correction "Give examples of substances other than water."@en ;
  dcterms:modified "2026-02-19T08:26:10.362358Z"^^xsd:dateTime .

oakcurric:misconception-light-reflects-mirrors-shiny-objects
  a curric:Misconception ;
  curric:statement """Light only reflects off mirrors and shiny objects, and doesn't reflect off dull surfaces."""@en ;
  curric:correction """All surfaces reflect (some) light. Use ideas of reflected light to explain how we see all the objects around us."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362443Z"^^xsd:dateTime .

oakcurric:misconception-aerobic-cellular-respiration-single-chemical
  a curric:Misconception ;
  curric:statement "Aerobic cellular respiration is a single chemical reaction."@en ;
  curric:correction """This lesson uses the terms 'chemical process' and 'series of chemical reactions'."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362458Z"^^xsd:dateTime .

oakcurric:misconception-recycling-effective-way-reducing-amount
  a curric:Misconception ;
  curric:statement "Recycling is the most effective way reducing the amount of waste we throw away."@en ;
  curric:correction """Highlight the understanding that reusing and reducing what is used is more effective and that recycling should be seen as a last resort. Repairing and repurposing can also help to reduce waste."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362468Z"^^xsd:dateTime .

oakcurric:misconception-thinking-eat-impact-climate-change
  a curric:Misconception ;
  curric:statement """Thinking that what we eat has no impact on climate change, or that all foods have roughly the same impact."""@en ;
  curric:correction """This lesson explores in detail the impacts of different foods in terms of their "carbon footprint" of greenhouse gas emissions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362615Z"^^xsd:dateTime .

oakcurric:misconception-wood-renewable-resource
  a curric:Misconception ;
  curric:statement "Wood is (always) a renewable resource."@en ;
  curric:correction """Discuss with the pupils the different ways in which we can obtain and regenerate (or not) the wood we use. Highlight that trees do not necessarily replace all the wood we take from them, and even if they do, it may take many years of growing."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362673Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-ray-light-reflect
  a curric:Misconception ;
  curric:statement """Some pupils think that a ray of light can reflect off at an angle different to that at which it hits a plane mirror and perhaps in several directions."""@en ;
  curric:correction """Give pupils practical experience of measuring the angles at which light reflects off a plane mirror to confirm the correct rules; share results to confirm; and discuss potential sources of error that may lead to small discrepancies."""@en ;
  dcterms:modified "2026-02-19T08:26:10.362862Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-see-movements
  a curric:Misconception ;
  curric:statement """Pupils can find it challenging to see how the movements of Earth as seen from the perspective of space (looking back at Earth) give rise to the observations experienced from Earth's surface."""@en ;
  curric:correction """Model the motions of objects in space with pupils as part of the model (i.e. representing Earth, moving as Earth moves) and with pupils observing the model. This enables them to experience how the same motion appears from both perspectives."""@en ;
  dcterms:modified "2026-02-19T08:26:10.363497Z"^^xsd:dateTime .

oakcurric:misconception-thinking-muscles-push-bones-fact
  a curric:Misconception ;
  curric:statement "Thinking that muscles can push bones (when in fact they can only pull)."@en ;
  curric:correction """The lesson makes clear that muscles can only pull bones, and work in antagonistic pairs to pull bones in opposite directions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.475375Z"^^xsd:dateTime .

oakcurric:misconception-ideas-nature-light-reflections-taken
  a curric:Misconception ;
  curric:statement """Ideas about the nature of light and reflections are often taken for granted at this stage and simple misconceptions often persist, e.g. that all reflections appear to be on the surface of mirrors."""@en ;
  curric:correction """Give pupils practical experience of systematically investigating reflections, e.g. measuring the apparent location of a mirror image. Explicitly assess for misconceptions about the location and visibility of mirror images of an object."""@en ;
  dcterms:modified "2026-02-19T08:26:10.476859Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-terms-weight-mass
  a curric:Misconception ;
  curric:statement """Pupils often mix up the terms for weight and mass and use weight when they mean mass and vice versa."""@en ;
  curric:correction """Teach pupils that a force lifts objects against the pull of gravity before introducing the term weight."""@en ;
  dcterms:modified "2026-02-19T08:26:10.476929Z"^^xsd:dateTime .

oakcurric:misconception-direction-resultant-force-shows-direction
  a curric:Misconception ;
  curric:statement "The direction of the (resultant) force shows the direction of motion."@en ;
  curric:correction """The direction of the resultant force shows the direction of the change (not the direction of motion). Forces make things change."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477275Z"^^xsd:dateTime .

oakcurric:misconception-mixing-correlation-cause
  a curric:Misconception ;
  curric:statement "Mixing up correlation and cause."@en ;
  curric:correction """This lesson explores the correlation between data showing global warming and data showing increases in greenhouse gas emission, and that 99% of scientists believe the increased greenhouse effect is the causal link."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477545Z"^^xsd:dateTime .

oakcurric:misconception-force-arrows-added-diagrams-carelessly
  a curric:Misconception ;
  curric:statement """Force arrows are often added to diagrams carelessly without regard to accurate representation."""@en ;
  curric:correction """Draw force arrows from the point of interaction in the correct direction with a length proportional to the size of force."""@en ;
  dcterms:modified "2026-02-19T08:26:10.477700Z"^^xsd:dateTime .

oakcurric:misconception-changes-population-within-food-web
  a curric:Misconception ;
  curric:statement """Changes in population within a food web will only impact organisms within the same food chain."""@en ;
  curric:correction """Exemplify that disappearance of one population could affect populations in all parts of the food web (CfU questions address this also)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478302Z"^^xsd:dateTime .

oakcurric:misconception-pupils-describe-absorbing-surface-trapping
  a curric:Misconception ;
  curric:statement """Pupils often describe an absorbing surface as trapping a sound and do not correctly describe how the vibrations of air particles are reduced by making particles in a surface vibrate more."""@en ;
  curric:correction """Provide opportunity for pupils to describe how vibrations of air particles are reduced when sound waves make particles in a surface vibrate more."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478363Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-appreciate-relative-scales
  a curric:Misconception ;
  curric:statement """Pupils struggle to appreciate the relative scales between each layer and features of the mantle."""@en ;
  curric:correction """Use common models (boiled egg or an orange) to stress the relative sizes and use multiple demonstrations to model features of the mantle."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478674Z"^^xsd:dateTime .

oakcurric:misconception-breathing-same-respiration
  a curric:Misconception ;
  curric:statement "Breathing is the same as respiration."@en ;
  curric:correction """Be clear that breathing is the mechanical process to get oxygen in and carbon dioxide out. Whereas, respiration is the chemical process that provides energy for the cell."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478685Z"^^xsd:dateTime .

oakcurric:misconception-seasons-caused-earth-moving-closer
  a curric:Misconception ;
  curric:statement """The seasons are caused by Earth moving closer or further from the Sun, the Sun being hotter or colder, or Earth's tilt changing as it orbits the Sun."""@en ;
  curric:correction """Remind pupils that the Sun's output is constant and also that there is strong evidence for Earth's orbit of the Sun being almost a perfect circle. Seasonal change happens because the direction of Earth's tilt doesn't change as it orbits the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:10.479983Z"^^xsd:dateTime .

oakcurric:misconception-thinking-heart-part-gas-exchange
  a curric:Misconception ;
  curric:statement """Thinking that the heart is part of the gas exchange system, linked to the lungs by "air tubes"."""@en ;
  curric:correction """This lesson explores the organs that make up the gas exchange system and how air is moved into and out of the lungs,"""@en ;
  dcterms:modified "2026-02-19T08:26:10.480307Z"^^xsd:dateTime .

oakcurric:misconception-change-size-population-affect-another
  a curric:Misconception ;
  curric:statement """The change in the size of a population will only affect another population if they are predator-prey"""@en ;
  curric:correction """Ensure that pupils are given opportunities to see how changes in population size impact all other organisms in the food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480317Z"^^xsd:dateTime .

oakcurric:misconception-pressure-force-terms-used-interchangeably
  a curric:Misconception ;
  curric:statement "Pressure and force are terms that are often used interchangeably."@en ;
  curric:correction """Explore examples with pupils in which similar sized forces are used to create different pressures that the pupils can experience first hand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480331Z"^^xsd:dateTime .

oakcurric:misconception-metals-magnetic-object-static-electric
  a curric:Misconception ;
  curric:statement "All metals are magnetic and an object with a static electric charge is magnetic."@en ;
  curric:correction """Provide opportunities for pupils to test some metals that are not magnetic, and a balloon with a static electric charge with a magnet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480342Z"^^xsd:dateTime .

oakcurric:misconception-moving-object-force-keeps-moving
  a curric:Misconception ;
  curric:statement """A moving object has force that keeps it moving, and which runs out when it comes to rest."""@en ;
  curric:correction """Forces come from other objects. Forces change the motion of objects. Objects slow when forces act opposite to the direction of motion."""@en ;
  dcterms:modified "2026-02-19T08:26:10.480747Z"^^xsd:dateTime .

oakcurric:misconception-constant-speed-interpreted-moving-time
  a curric:Misconception ;
  curric:statement """"Constant speed" can be interpreted as "moving all the time", and "steady speed" as "not too fast"."""@en ;
  curric:correction """Use the terms with care, qualifying them with examples when they are used, e.g. "a constant speed of 4 m/s" or "a steady speed of 100 m/s"."""@en ;
  dcterms:modified "2026-02-19T08:26:10.481269Z"^^xsd:dateTime .

oakcurric:misconception-pupils-interpret-distance-time-graphs
  a curric:Misconception ;
  curric:statement "Pupils often interpret distance-time graphs (intuitively) as pictures."@en ;
  curric:correction """Guide pupils step by step through interpreting d-t graphs and link each line with a motion (repeatedly)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.481397Z"^^xsd:dateTime .

oakcurric:misconception-thinking-animals-respire-plants-photosynthesise
  a curric:Misconception ;
  curric:statement """Thinking that only animals respire, and that plants only photosynthesise (and do not respire)."""@en ;
  curric:correction """This lesson uses examples of plants respiring in order to address this misconception."""@en ;
  dcterms:modified "2026-02-19T08:26:10.481760Z"^^xsd:dateTime .

oakcurric:misconception-pupils-associate-use-quadrats-survey
  a curric:Misconception ;
  curric:statement """Pupils often associate the use of quadrats to survey plants in one type of habitat. Pupils do not consider how they can be used to sample sedentary animals, e.g. barnacles or limpets on a rocky shore."""@en ;
  curric:correction """During the slidedeck there is reference to how quadrats can be used to sample plants and sedentary animals in different habitats."""@en ;
  dcterms:modified "2026-02-19T08:26:10.481788Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-numbers-changed
  a curric:Misconception ;
  curric:statement """Pupils get confused with what numbers can be changed, many of them try to change the subscript numbers in formulae to balance equations."""@en ;
  curric:correction """Use the layout modelled in the slides to go through the examples using the 'circled method' and tell pupils that when adding more of a substance they must add all elements in the substance, e.g. 2MgO = (MgO)(MgO)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482041Z"^^xsd:dateTime .

oakcurric:misconception-students-forget-change-non-metal
  a curric:Misconception ;
  curric:statement "Students often forget to change the non-metal name to either -ide or -ate."@en ;
  curric:correction """Emphasise when the non-metal reacts with a metal it changes its name to -ide. It is -ate if the non-metal is also bonded to oxygen."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482060Z"^^xsd:dateTime .

oakcurric:misconception-assuming-substances-like-sodium-chloride
  a curric:Misconception ;
  curric:statement "Assuming that substances like sodium chloride (NaCl) are diatomic."@en ;
  curric:correction """It is very important to emphasise that only non-metals exist as monatomic or molecules."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482327Z"^^xsd:dateTime .

oakcurric:misconception-health-made-physical-health
  a curric:Misconception ;
  curric:statement "Health is only made up of physical health."@en ;
  curric:correction """Remind students that health is a range from good to ill. Physical and mental health both contribute to a person's overall health."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482337Z"^^xsd:dateTime .

oakcurric:misconception-labelling-x-axis-values-investigated
  a curric:Misconception ;
  curric:statement """Labelling the x-axis with the values investigated instead of an evenly spaced range; or putting the axes the wrong way round for independent and dependent variables."""@en ;
  curric:correction """Clearly showing the placement of variables in the table and on the graphs, step-by-step guidance of drawing the graphs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482346Z"^^xsd:dateTime .

oakcurric:misconception-many-misconceptions-evolution-including-because
  a curric:Misconception ;
  curric:statement """There are many misconceptions about evolution, including that because evolution by natural selection is a theory it is an untrustworthy explanation."""@en ;
  curric:correction """This lesson builds understanding that a scientific theory is a well evidenced and well tested explanation that is widely accepted by scientists, and also addresses some common misconceptions about evolution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482583Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-constant-force-trolley
  a curric:Misconception ;
  curric:statement """Pupils may think that the constant force on the trolley will cause it to move at a constant speed."""@en ;
  curric:correction """Demonstrate that the trolly speeds up as it rolls, by finding speed near the start and near the end of the ramp."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482689Z"^^xsd:dateTime .

oakcurric:misconception-means-divide-three
  a curric:Misconception ;
  curric:statement "That means are always divide by three."@en ;
  curric:correction "Show examples where the number of repeats varies."@en ;
  dcterms:modified "2026-02-19T08:26:10.483445Z"^^xsd:dateTime .

oakcurric:misconception-students-think-midday-sun-higher
  a curric:Misconception ;
  curric:statement """Students may think that the midday Sun is higher in the sky because the Sun is further away then, or that the midday Sun has a greater heating effect because the Sun is closer or hotter then."""@en ;
  curric:correction """Use physical models (such as a globe, or a flat card in front of a light bulb with a thermometer attached) to show students how the changes observed over a day to Sun's position in the sky and the Sun's heating effect are caused by Earth's spin."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484208Z"^^xsd:dateTime .

oakcurric:misconception-reactant-disappears-reaction-acids-metals
  a curric:Misconception ;
  curric:statement """The reactant disappears during the reaction. Acids and metals react because the acid eats away the metal."""@en ;
  curric:correction """Use word and symbol equations to reinforce the idea that during the reaction new chemicals are produced from the reactants. Demonstrate that metals less reactive than hydrogen will not react with acid."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484217Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-solid-large
  a curric:Misconception ;
  curric:statement """Pupils can struggle to understand that a solid is not always a large piece of a substance."""@en ;
  curric:correction """Show visually the difference between a transparent coloured solution e.g. copper sulfate solution and a coloured precipitate solution. Practice describing the difference between a white precipitate and a transparent colourless solution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484404Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-reactions-consist
  a curric:Misconception ;
  curric:statement """Pupils often struggle to understand that not all reactions consist of two substances mixed together to cause a reaction."""@en ;
  curric:correction """Show the symbol equation and how the reactants are rearranged to form the products."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484568Z"^^xsd:dateTime .

oakcurric:misconception-students-think-particles-embedded-substance
  a curric:Misconception ;
  curric:statement "Students think that the particles are embedded in the substance"@en ;
  curric:correction """Ensure that students are reminded that all matter is made of small particles and nothing is between the particles."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484803Z"^^xsd:dateTime .

oakcurric:misconception-learners-assume-one-type-cellular
  a curric:Misconception ;
  curric:statement "Learners often assume there is only one type of cellular respiration (aerobic)."@en ;
  curric:correction "This lesson explores aerobic and anaerobic cellular respiration in humans."@en ;
  dcterms:modified "2026-02-19T08:26:10.485036Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-metals-rust
  a curric:Misconception ;
  curric:statement "Pupils often think that all metals rust."@en ;
  curric:correction """Explain that rust is a form of iron oxide and show pupils other examples of metal oxides, e.g. copper oxide, to show how different they are."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485073Z"^^xsd:dateTime .

oakcurric:misconception-bunsen-hot-flames-same-temperature
  a curric:Misconception ;
  curric:statement "All the Bunsen is hot, flames are the same temperature."@en ;
  curric:correction """Ask pupils to explain why they are able to turn the collar without getting burnt. Explain why it is important to select the correct flame."""@en ;
  dcterms:modified "2026-02-19T08:26:10.485229Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-change-speed-instantaneous
  a curric:Misconception ;
  curric:statement """Pupils can think that change in speed is instantaneous due to forces, not over a period of time."""@en ;
  curric:correction """Demonstrate that objects continue to accelerate while the force is acting. Make the force easy to understand (e.g. a pulling string)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.486009Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-biodiversity-number-organisms
  a curric:Misconception ;
  curric:statement """Pupils often believe that biodiversity is the number of organisms that live in a place, rather than the number of different species that live in a place."""@en ;
  curric:correction """There is extensive coverage in the lesson around biodiversity being the range of species that are found in an area."""@en ;
  dcterms:modified "2026-02-19T08:26:10.486027Z"^^xsd:dateTime .

oakcurric:misconception-pupils-like-write-methods-paragraph
  a curric:Misconception ;
  curric:statement """Sometimes pupils like to write methods in paragraph form, which can be difficult to follow."""@en ;
  curric:correction """Suggest pupils draw labelled diagrams of key steps, write a sentence to describe each diagram, then go back to number them in order."""@en ;
  dcterms:modified "2026-02-19T08:26:10.486983Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-difference-chemical-physical
  a curric:Misconception ;
  curric:statement "Students often confuse the difference between chemical and physical properties."@en ;
  curric:correction """A chemical property describes how an element will react with other substances. Physical properties describes the appearance and behaviour."""@en ;
  dcterms:modified "2026-02-19T08:26:10.487167Z"^^xsd:dateTime .

oakcurric:misconception-particles-move-selectively-permeable-membrane
  a curric:Misconception ;
  curric:statement "Particles only move through a selectively-permeable membrane in one direction."@en ;
  curric:correction """The lesson explores the idea that particles move through a selectively-permeable membrane in both directions, but that net movement is down a concentration gradient."""@en ;
  dcterms:modified "2026-02-19T08:26:10.487389Z"^^xsd:dateTime .

oakcurric:misconception-thinking-substances-diffuse-cell-membrane
  a curric:Misconception ;
  curric:statement """Thinking that all, or no, substances can diffuse through the cell membrane. Thinking that cells choose to take in particular substances, or that cells breathe or suck in substances such as oxygen."""@en ;
  curric:correction """The lesson explores the idea that particles of some, but not all, substances are small enough to diffuse through holes in the selectively-permeable cell membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:10.487436Z"^^xsd:dateTime .

oakcurric:misconception-pupils-commonly-confuse-discrete-continuous
  a curric:Misconception ;
  curric:statement """Pupils commonly confuse discrete & continuous data. They also think lines of best fit are straight."""@en ;
  curric:correction """Link *how* the data is collected to the type of data it is.  Stress that best fit lines are just that - a best fit - they aren't exact!"""@en ;
  dcterms:modified "2026-02-19T08:26:10.487710Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-size-organisms-increase
  a curric:Misconception ;
  curric:statement """Pupils often think that the size of organisms has to increase at each trophic level within a food chain diagram."""@en ;
  curric:correction """The lesson addresses the misconception through exemplification. There is coverage of inverted pyramid of number to show that some producers are larger organisms that are eaten by smaller organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488088Z"^^xsd:dateTime .

oakcurric:misconception-common-students-believe-types-variation
  a curric:Misconception ;
  curric:statement """It is common for students to believe that all types of variation can be passed on from parents to their offspring."""@en ;
  curric:correction """This lesson explores examples of variation that can and cannot be passed on from parents to their offspring, and links this to their causes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488578Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-terms-evaporation-boiling
  a curric:Misconception ;
  curric:statement """Pupils sometimes use the terms evaporation and boiling interchangeably, but they are not the same."""@en ;
  curric:correction """Boiling: a liquid substance is heated and gas bubbles form. Evaporation: same, BUT only on the surface of the liquid, no bubbles form and the gas mixes with air."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488875Z"^^xsd:dateTime .

oakcurric:misconception-video-skydiving-lead-pupils-think
  a curric:Misconception ;
  curric:statement """Video of skydiving may lead pupils to think opening a parachute makes a skydiver 'shoot upwards'."""@en ;
  curric:correction """Explain that this 'upwards motion' is relative motion to a cameraman. Discuss what a sudden upwards motion would do to a falling skydiver."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489597Z"^^xsd:dateTime .

oakcurric:misconception-magnetic-field-poles-magnet
  a curric:Misconception ;
  curric:statement "The magnetic field is only at the poles of a magnet."@en ;
  curric:correction """Provide opportunity for pupils to plot magnetic field lines around pairs of bar magnets and to experiment with a second magnet as described in the teacher tip."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489619Z"^^xsd:dateTime .

oakcurric:misconception-pupils-either-put-much-enough
  a curric:Misconception ;
  curric:statement """Pupils either put too much or not enough detail into their drawings = muddled representations"""@en ;
  curric:correction """Use the 'less is more' approach, and remind pupils to include labels - **clarity is key**. Allows for less detail and avoids any confusion."""@en ;
  dcterms:modified "2026-02-19T08:26:10.489706Z"^^xsd:dateTime .

oakcurric:misconception-exceptions-metals-non-metals-different
  a curric:Misconception ;
  curric:statement """There are exceptions for both metals and non-metals, which have different properties."""@en ;
  curric:correction "Use examples such as mercury and graphite in your teaching."@en ;
  dcterms:modified "2026-02-19T08:26:10.490003Z"^^xsd:dateTime .

oakcurric:misconception-pupils-commonly-confuse-instantaneous-average
  a curric:Misconception ;
  curric:statement "Pupils commonly confuse instantaneous and average speeds."@en ;
  curric:correction """Be very careful when using the word speed, always use 'average' or 'instantaneous' explicitly, linking average speed to a time period."""@en ;
  dcterms:modified "2026-02-19T08:26:10.490499Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rarely-develop-intuitive-understanding
  a curric:Misconception ;
  curric:statement """Pupils rarely develop an intuitive understanding of what specific heat capacity means when it is introduced through an equation."""@en ;
  curric:correction """Use this lesson to develop a qualitative understanding of the specific heat capacity of objects, without introducing the equation for specific heat capacity."""@en ;
  dcterms:modified "2026-02-19T08:26:10.490673Z"^^xsd:dateTime .

oakcurric:misconception-point-light-image-comes-one
  a curric:Misconception ;
  curric:statement """Each point of light on an image comes from just one ray of light from a corresponding point on an object."""@en ;
  curric:correction """Show how multiple rays of light from each point of an object pass through a lens and are focused at a single point in the image. Show how covering half of a lens does not cause half of the image to disappear."""@en ;
  dcterms:modified "2026-02-19T08:26:10.490682Z"^^xsd:dateTime .

oakcurric:misconception-writing-subscript-values-superscript-values
  a curric:Misconception ;
  curric:statement "Writing subscript values as superscript values."@en ;
  curric:correction """Subscript values show the number of the atoms, while superscript in maths is used to square a value and so does not apply to chemical formulae."""@en ;
  dcterms:modified "2026-02-19T08:26:10.491674Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-products-water
  a curric:Misconception ;
  curric:statement """Pupils struggle to understand that products of water and carbon dioxide are made when combustion takes place as they cannot see them."""@en ;
  curric:correction """Remind pupils about the rule of rearranging atoms from reactants to form products. Use a molecular modelling kit to show the combustion of methane. Remember to balance the reaction so that conservation of mass occurs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.491684Z"^^xsd:dateTime .

oakcurric:misconception-magnetic-field-same-electric-field
  a curric:Misconception ;
  curric:statement "A magnetic field is the same as the electric field around a charged object."@en ;
  curric:correction """Demonstrate that a balloon with a static electric charge does not affect the magnet in a plotting compass."""@en ;
  dcterms:modified "2026-02-19T08:26:10.492075Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-driving-forces-needed
  a curric:Misconception ;
  curric:statement """Pupils believe driving forces are needed to keep objects moving at constant speed."""@en ;
  curric:correction """Demonstrate that friction (and drag) bring objects to a stop, showing that different surfaces produce the forces that slow objects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.492600Z"^^xsd:dateTime .

oakcurric:misconception-pupils-need-understand-closed-loop
  a curric:Misconception ;
  curric:statement """Pupils need to understand that there has to be a closed loop of conducting material, from one end of the battery or power supply, through the device and back to the battery."""@en ;
  curric:correction """Pupils should test a faulty circuit in a systematic way,  e.g. starting at one point in the circuit and moving from component to component in order, going clockwise or anti-clockwise from that point."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493143Z"^^xsd:dateTime .

oakcurric:misconception-drawing-graph-axes-incorrectly-orientated
  a curric:Misconception ;
  curric:statement """Drawing a graph with the axes incorrectly orientated (independent variable on y axis instead of x)."""@en ;
  curric:correction """Outline and model graphs shown and discussed with links made between independent and dependent variables and the axes they appear on."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493213Z"^^xsd:dateTime .

oakcurric:misconception-animals-misclassified-based-features-incorrectly
  a curric:Misconception ;
  curric:statement """Animals are misclassified based on features that have been incorrectly interpreted, such as wings."""@en ;
  curric:correction """Animals which are often misclassified are included as explicit examples, such as bat, whale and penguin."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493224Z"^^xsd:dateTime .

oakcurric:misconception-genes-dna-exactly-same-thing
  a curric:Misconception ;
  curric:statement "'Genes' and 'DNA' are exactly the same thing."@en ;
  curric:correction """The lesson explores the idea that genes are sections of your DNA, and all the DNA together is the genome."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493241Z"^^xsd:dateTime .

oakcurric:misconception-pupils-generally-confuse-distinctions-rock
  a curric:Misconception ;
  curric:statement "Pupils generally confuse the distinctions between a rock and a mineral."@en ;
  curric:correction """Stress and reinforce the definitions of each.  Use examples of each and practice classifying them as a mineral or rock."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493258Z"^^xsd:dateTime .

oakcurric:misconception-fertilisation-occurs-uterus-happen-time
  a curric:Misconception ;
  curric:statement "Fertilisation occurs in the uterus and can happen at any time."@en ;
  curric:correction """Fertilisation occurs in the fallopian tubes and this can only happen before the egg cell reaches the uterus."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493266Z"^^xsd:dateTime .

oakcurric:misconception-boys-inherit-features-their-father
  a curric:Misconception ;
  curric:statement """Boys only inherit features from their father and girls only inherit features from their mother. All characteristics are caused by genes."""@en ;
  curric:correction """The lesson consolidates understanding from Y7 that offspring inherit characteristics from both parents, and that some characteristics are caused (or changed) by an organism’s lifestyle and environment."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493274Z"^^xsd:dateTime .

oakcurric:misconception-grouping-organisms-based-similarities-their
  a curric:Misconception ;
  curric:statement """Grouping organisms based on similarities in their names (e.g. fish and jellyfish) or habitat."""@en ;
  curric:correction """The lesson makes clear that scientists classify organisms into groups using similarities and differences in their features (e.g. backbone)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493287Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-classify-rocks-colour
  a curric:Misconception ;
  curric:statement """Pupils tend to classify rocks by colour, shape or size - not useful for distinguishing rock types."""@en ;
  curric:correction """Encourage pupils to focus on the texture of a rock (the grains and how they are arranged) to classify them and consider uses of those rocks."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493311Z"^^xsd:dateTime .

oakcurric:misconception-puberty-happens-overnight
  a curric:Misconception ;
  curric:statement "Puberty happens overnight."@en ;
  curric:correction """A clear slide with a guide to timings of puberty stating that it takes place over several years."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493333Z"^^xsd:dateTime .

oakcurric:misconception-bones-living-bones-made-cells
  a curric:Misconception ;
  curric:statement "Bones are not living; bones are not made up of cells."@en ;
  curric:correction """This lesson explores the idea that bone is a tissue made up of cells, and that it is living (because it can heal)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493357Z"^^xsd:dateTime .

oakcurric:misconception-thinking-lifestyle-choices-pregnant-mother
  a curric:Misconception ;
  curric:statement """Thinking that the lifestyle choices of a pregnant mother, including recreational use of drugs such as alcohol and nicotine, will not affect the foetus."""@en ;
  curric:correction """The lesson explores short-term and long-term effects that lifestyle choices of a pregnant mother, including recreational use of drugs such as alcohol and nicotine, can have on the developing foetus."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493451Z"^^xsd:dateTime .

oakcurric:misconception-mixing-terms-zygote-embryo-foetus
  a curric:Misconception ;
  curric:statement """Mixing up the terms zygote, embryo and foetus. Thinking that the mother's blood mixes with the foetus' blood in the placenta."""@en ;
  curric:correction """The lesson explores how the zygote divides, grows and develops in stages including embryo and foetus until the baby is ready to be born. The foetal and mother's blood vessels are close to each other in the placenta but the blood doesn't mix."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493518Z"^^xsd:dateTime .

oakcurric:misconception-using-line-graph-histogram-plot
  a curric:Misconception ;
  curric:statement """Using a line graph or histogram to plot discontinuous data. All features show variation due to environmental and lifestyle factors."""@en ;
  curric:correction """The lesson explores why a bar chart is the correct choice for plotting discontinuous data, and the idea that discontinuous variation usually has only a genetic cause."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493535Z"^^xsd:dateTime .

oakcurric:misconception-think-lavas-magmas-same-type
  a curric:Misconception ;
  curric:statement """Some think all lavas/magmas are the same and the type of igneous rock formed depends on cooling rate."""@en ;
  curric:correction """Stress that the type of igneous rock formed depends upon the mineral composition of the lava/magma *and* the rate of cooling.  Use examples to reinforce this."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493580Z"^^xsd:dateTime .

oakcurric:misconception-sexual-reproduction-occurs-animals-plants
  a curric:Misconception ;
  curric:statement "Sexual reproduction occurs in animals but not in plants."@en ;
  curric:correction "The lesson contains a section on plant sexual reproduction."@en ;
  dcterms:modified "2026-02-19T08:26:10.493592Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-positive-negative-charges
  a curric:Misconception ;
  curric:statement """Pupils often think that both positive and negative charges can move when objects are charged by rubbing."""@en ;
  curric:correction """Emphasise that only electrons can move, explaining that they are found on the outer part of atoms. Use this to explain how a positive charge is created by the removal of electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493601Z"^^xsd:dateTime .

oakcurric:misconception-common-pupils-think-uninsulated-wire
  a curric:Misconception ;
  curric:statement """It is very common for pupils to think that uninsulated wire is needed for the coil of an electromagnet."""@en ;
  curric:correction """When discussing an electromagnet, always refer to the insulated wire in its core, which is necessary so the current in each turn adds to the strength of the electromagnet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493621Z"^^xsd:dateTime .

oakcurric:misconception-pupils-focus-one-feature-classify
  a curric:Misconception ;
  curric:statement "Pupils sometimes focus on one feature to classify rocks as one type or another."@en ;
  curric:correction """Stress that the rock classification system is gradual - show examples of various metamorphic rocks, highlighting similarities / differences."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493927Z"^^xsd:dateTime .

oakcurric:misconception-using-bar-chart-plot-continuous
  a curric:Misconception ;
  curric:statement """Using a bar chart to plot continuous data. Features with continuous variation are only due to genetic factors."""@en ;
  curric:correction """The lesson explores why a histogram or line graph is the correct choice for plotting discontinuous data, and the idea that continuous variation is usually  influenced by many factors, including genetics, the environment and lifestyle."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493947Z"^^xsd:dateTime .

oakcurric:misconception-proteins-main-source-energy-fat
  a curric:Misconception ;
  curric:statement """Proteins are the main source of energy. All fat in the diet can cause ill health."""@en ;
  curric:correction """Protein is used for growth of cells and repair of tissue. Fats are essential for cell membranes and as an energy store."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493984Z"^^xsd:dateTime .

oakcurric:misconception-thinking-muscles-found-attached-skeleton
  a curric:Misconception ;
  curric:statement """Thinking that muscles are only found attached to the skeleton to move our limbs, and nowhere else."""@en ;
  curric:correction "Discussion of three types of muscle, where they are found, and their roles."@en ;
  dcterms:modified "2026-02-19T08:26:10.494013Z"^^xsd:dateTime .

oakcurric:misconception-pupils-teachers-even-textbooks-suggest
  a curric:Misconception ;
  curric:statement """Some pupils (and teachers and even textbooks) suggest that plate movement is due solely to convection currents."""@en ;
  curric:correction """Stress that the understanding of what drives of tectonic plate moment is still developing; using demonstrations to reinforce the current understanding of slab pull and ridge push are helpful. Avoid any demos that reinforce ideas the mantle is liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494030Z"^^xsd:dateTime .

oakcurric:misconception-types-organism-pass-information-their
  a curric:Misconception ;
  curric:statement "Not all types of organism pass information to their offspring."@en ;
  curric:correction "Plants, animals and bacteria shown as parent and offspring."@en ;
  dcterms:modified "2026-02-19T08:26:10.494054Z"^^xsd:dateTime .

oakcurric:misconception-male-reproductive-systems-bigger-complex
  a curric:Misconception ;
  curric:statement """Male reproductive systems are bigger and more complex than females, that they are totally separate systems."""@en ;
  curric:correction """Show female and male systems next to each other and how they work together as a unit to produce offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494154Z"^^xsd:dateTime .

oakcurric:misconception-thinking-atmosphere-acts-like-greenhouse
  a curric:Misconception ;
  curric:statement """Thinking that the atmosphere acts like a greenhouse by presenting a wall (like glass) that traps heat."""@en ;
  curric:correction """Heat is not a substance that can be trapped. This lesson explores the role of greenhouse gases in the atmosphere, which keep the atmosphere warmer than it would be when it is heated by the Sun. This increases the surface temperature of Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494273Z"^^xsd:dateTime .

oakcurric:misconception-dna-discovered-watson-crick
  a curric:Misconception ;
  curric:statement "DNA was discovered by Watson and Crick."@en ;
  curric:correction """The lesson explores the work of various scientists in developing our understanding of DNA, including Rosalind Franklin."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494281Z"^^xsd:dateTime .

oakcurric:misconception-pupils-encountered-moment-equation-physics
  a curric:Misconception ;
  curric:statement "Pupils may not have encountered the moment equation in physics."@en ;
  curric:correction "Pupils might need extra support substituting values into the equation."@en ;
  dcterms:modified "2026-02-19T08:26:10.494289Z"^^xsd:dateTime .

oakcurric:misconception-menstrual-cycle-linked-reproduction
  a curric:Misconception ;
  curric:statement "The menstrual cycle is not linked to reproduction"@en ;
  curric:correction """Descriptions of egg release and function of the uterus lining in regard to the reproduction detailed on the menstrual cycle diagrams"""@en ;
  dcterms:modified "2026-02-19T08:26:10.494302Z"^^xsd:dateTime .

oakcurric:misconception-types-variation-measured-same-way
  a curric:Misconception ;
  curric:statement "All types of variation can be measured in the same way."@en ;
  curric:correction """The lesson explores the differences between discontinuous and continuous variation and how they can be measured."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494322Z"^^xsd:dateTime .

oakcurric:misconception-organisms-classified-according-their-visible
  a curric:Misconception ;
  curric:statement "Organisms are classified only according to their visible (macroscopic) features."@en ;
  curric:correction """This lesson explores the classification of organisms into kingdoms based on the features of their cells."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494466Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-chemical-reactions-changes
  a curric:Misconception ;
  curric:statement """Pupils do not understand chemical reactions as changes, they considered them to be ‘events’. They focus on observable features e.g. colour change rather than formation of a new substance."""@en ;
  curric:correction """Use questioning to encourage pupils to make links between their observations as evidence that a new substance is formed when substances undergo chemical reactions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494478Z"^^xsd:dateTime .

oakcurric:misconception-mirrors-somehow-turn-images-around
  a curric:Misconception ;
  curric:statement """Mirrors must somehow turn images around or ‘flip’ them to make reflections laterally inverted."""@en ;
  curric:correction """Explicitly teach that a mirror merely (and passively) reflects what is directly in front of each part of it. Pupils can observe the reflection of text on clear plastic: the image is the same as what is seen looking through the back of the text."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494487Z"^^xsd:dateTime .

oakcurric:misconception-many-learners-think-way-animals
  a curric:Misconception ;
  curric:statement """Many learners think that the only way animals compete for resources is through physical aggression."""@en ;
  curric:correction """This lessons contains many examples of how animals and other organisms compete for resources."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494503Z"^^xsd:dateTime .

oakcurric:misconception-colour-something-different-light-colours
  a curric:Misconception ;
  curric:statement """Colour is something different to light. The colours of light will mix in the same way that paints of different colours mix."""@en ;
  curric:correction """Show pupils how different colours of light can combine to produce different colours, including white light."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495080Z"^^xsd:dateTime .

oakcurric:misconception-protein-main-source-energy-our
  a curric:Misconception ;
  curric:statement "Protein is the main source of energy in our diets."@en ;
  curric:correction "Carbohydrates and fats are the main source of energy in our diets."@en ;
  dcterms:modified "2026-02-19T08:26:10.495216Z"^^xsd:dateTime .

oakcurric:misconception-substances-freeze-really-cold-like
  a curric:Misconception ;
  curric:statement "All substances freeze when really cold, like water."@en ;
  curric:correction """Show state changes using particle diagrams / kinetic energy model.  Challenge pupils to identify state given real world temperature data."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495283Z"^^xsd:dateTime .

oakcurric:misconception-ray-light-curves-passes-glass
  a curric:Misconception ;
  curric:statement "A ray of light curves as it passes through glass, perspex or water."@en ;
  curric:correction """Use a perspex block with the bottom painted white to demonstrate the path of a ray of light through it. Avoid putting too much emphasis on the term 'bending' light, instead try to primarily refer to light changing direction at a boundary."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495372Z"^^xsd:dateTime .

oakcurric:misconception-using-term-accurate-without-understanding
  a curric:Misconception ;
  curric:statement """Using the term 'accurate' without understanding what it means in relation to scientific measurements. Thinking that an estimate is just a guess."""@en ;
  curric:correction """The lesson explores the concepts of 'accurate' and 'estimate' using simple apparatus to estimate the vital capacity of the lungs."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495930Z"^^xsd:dateTime .

oakcurric:misconception-greenhouse-effect-same-global-warming
  a curric:Misconception ;
  curric:statement "The greenhouse effect is the same as global warming."@en ;
  curric:correction """Discuss the natural greenhouse effect and how it enables life on Earth to flourish. Emphasise that global warming refers to an increasing temperature, rather than to a temperature that is warmer."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495997Z"^^xsd:dateTime .

oakcurric:misconception-pointless-take-action-climate-change
  a curric:Misconception ;
  curric:statement """It is pointless to take action on climate change if some other countries are not."""@en ;
  curric:correction """Discuss how international agreements can enable many countries take action together. And that developing green technologies ahead of other countries may help UK industry in the future."""@en ;
  dcterms:modified "2026-02-19T08:26:10.496212Z"^^xsd:dateTime .

oakcurric:misconception-breathing-respiration-same-thing
  a curric:Misconception ;
  curric:statement "Breathing and respiration are the same thing."@en ;
  curric:correction """This lesson explores the differences between breathing, respiration and gas exchange, including what they are and where they take place."""@en ;
  dcterms:modified "2026-02-19T08:26:10.496364Z"^^xsd:dateTime .

oakcurric:misconception-power-stations-generate-electricity-use
  a curric:Misconception ;
  curric:statement "Power stations generate most of the electricity that we use in the UK."@en ;
  curric:correction """Highlight how over half of UK electricity is now generated using renewable energy resources and that power stations contribute about a third of the electricity. Also highlight the continuing need for power stations due to varying weather and demand."""@en ;
  dcterms:modified "2026-02-19T08:26:10.496540Z"^^xsd:dateTime .

oakcurric:misconception-energy-appear-disappear
  a curric:Misconception ;
  curric:statement "Energy can appear and disappear."@en ;
  curric:correction "Remind students about the conservation of energy."@en ;
  dcterms:modified "2026-02-19T08:26:10.496796Z"^^xsd:dateTime .

oakcurric:misconception-greenhouse-gases-emitted-life-vehicle
  a curric:Misconception ;
  curric:statement "Greenhouse gases are only emitted in the life of a vehicle when it is moving."@en ;
  curric:correction """Discuss greenhouse gas emissions caused by the extraction of resources, production of materials, manufacturing of parts and the vehicle itself, as well as the recycling and disposal of the vehicle at the end of its life."""@en ;
  dcterms:modified "2026-02-19T08:26:10.496919Z"^^xsd:dateTime .

oakcurric:misconception-sunlight-yellow-ish-white
  a curric:Misconception ;
  curric:statement "Sunlight is yellow(ish), not white."@en ;
  curric:correction """Show pupils a yellow light (and illuminate white paper beneath a yellow light) and compare it to sunlight to show that sunlight is white."""@en ;
  dcterms:modified "2026-02-19T08:26:10.496934Z"^^xsd:dateTime .

oakcurric:misconception-driving-high-speed-much-effect
  a curric:Misconception ;
  curric:statement """Driving at a high speed does not have much effect on the amount of energy a car uses for a whole journey."""@en ;
  curric:correction """Discuss the idea that the faster a car travels, the greater the drag force pushing back on the car. A good analogy is walking slowly or quickly through water in a swimming pool - it's much harder to walk quickly because of the increased drag."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497035Z"^^xsd:dateTime .

oakcurric:misconception-reducing-emissions-greenhouse-gases-lower
  a curric:Misconception ;
  curric:statement """Reducing the emissions of greenhouse gases will lower the global surface temperature."""@en ;
  curric:correction """Discuss the effect of adding greenhouse gases more slowly to what is already in the atmosphere. Task B is helpful for consolidating a better understanding of this."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497043Z"^^xsd:dateTime .

oakcurric:misconception-difference-surroundings-reaction-takes-place
  a curric:Misconception ;
  curric:statement """The difference between the surroundings (where the reaction takes place, e.g. solution) and the environment (where the reaction mixture is, e.g. classroom). The existence of cold."""@en ;
  curric:correction """Use the separate terms of surroundings and environment throughout the lesson. Explain that thermal energy transfer only takes place from somewhere that is warmer and somewhere that is cooler."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497176Z"^^xsd:dateTime .

oakcurric:misconception-colour-sum-colour-object-colour
  a curric:Misconception ;
  curric:statement """Colour is the sum of the colour of the object and the colour of light falling on it."""@en ;
  curric:correction """Use coloured lights to show that red coloured objects reflect red light, but not blue or green."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497377Z"^^xsd:dateTime .

oakcurric:misconception-melting-icebergs-sea-ice-cause
  a curric:Misconception ;
  curric:statement "Melting icebergs and sea ice cause sea levels to rise."@en ;
  curric:correction """A detailed explanation of the anomalous properties of ice is not appropirate for most pupils at this stage. Instead, draw attention to water taking up exactly the same space as the part of a floating iceberg that is underwater."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497521Z"^^xsd:dateTime .

oakcurric:misconception-light-lamp-moves-parallel-rays
  a curric:Misconception ;
  curric:statement """Light from a lamp moves in parallel rays in a preferred direction towards the observer."""@en ;
  curric:correction """Overtly discuss the direction light rays move from a lamp by considering where light from a lamp can be seen from."""@en ;
  dcterms:modified "2026-02-19T08:26:10.497570Z"^^xsd:dateTime .

oakcurric:misconception-students-think-advantageous-traits-due
  a curric:Misconception ;
  curric:statement """Students often think that advantageous traits are due to an organism choosing to change itself in order to be successful."""@en ;
  curric:correction "This lesson uses CfUs in order to explore and deconstruct this misconception."@en ;
  dcterms:modified "2026-02-19T08:26:10.498217Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-term-moment-ideas
  a curric:Misconception ;
  curric:statement "Pupils confuse the term moment with ideas about time or movement."@en ;
  curric:correction """Use the term ‘turning effect’ in this lesson whilst ideas are being introduced and consolidated."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498257Z"^^xsd:dateTime .

oakcurric:misconception-students-think-intermolecular-forces-exist
  a curric:Misconception ;
  curric:statement """Students often think that intermolecular forces exist within a molecule, unaware of the significant difference in strength between chemical bonds within atoms and the forces between molecules."""@en ;
  curric:correction """Help students to make the link between the structure of the polymer and its property by using models. Point out where the intermolecular forces occur and compare this to where the chemical bonds are."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498272Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-remember-plants-alive
  a curric:Misconception ;
  curric:statement """As students struggle to remember that plants are alive, they don't think of plants as being adapted to their surroundings."""@en ;
  curric:correction """This lesson gives many examples of the adaptations plants have which help them to thrive in their environments."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498335Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-acids-eat-materials
  a curric:Misconception ;
  curric:statement """Pupils think that acids ‘eat away’ materials and disappear. They observe reactions and see the loss of a reactant, but do not recognise the formation of a new soluble product."""@en ;
  curric:correction """Ensure that pupils understand the concept of solubility and use the words soluble and dissolve when describing the production of metal salts during these reactions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498342Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-red-cabbage-change
  a curric:Misconception ;
  curric:statement """Pupils often think that the red cabbage will change to the same colours as universal indicator solution."""@en ;
  curric:correction """Remind pupils that there are many different indicators used to show different pH."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498349Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-comprehend-absolute-ages
  a curric:Misconception ;
  curric:statement """Students struggle to comprehend absolute ages of key events in the history of Earth and evolutionary history."""@en ;
  curric:correction """This lesson provides many examples and context to give students a sense of the differences in time scales involved in the history of Earth and evolution."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498456Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-confused-litmus-paper
  a curric:Misconception ;
  curric:statement """Pupils can get confused by the litmus paper test and presume that a change has to take place for it to be a positive result."""@en ;
  curric:correction """Use the phrases, stay red, stay blue, turn red, turn blue to help them understand that sometimes a positive test is no colour change."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498470Z"^^xsd:dateTime .

oakcurric:misconception-pupils-refer-walls-alveoli-cell
  a curric:Misconception ;
  curric:statement "Pupils often refer to the walls of the alveoli as \"cell walls\"."@en ;
  curric:correction """This lesson makes the scale of different parts of the gas exchange system clear (e.g. whether a structure is a tissue or cell)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498486Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-word-summaries-different
  a curric:Misconception ;
  curric:statement """Students can often confuse the word summaries for the different types of cellular respiration."""@en ;
  curric:correction """This lesson directly compares the different word summaries for anaerobic cellular respiration to help understand the differences between them."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498518Z"^^xsd:dateTime .

oakcurric:misconception-plants-take-food-their-surroundings
  a curric:Misconception ;
  curric:statement "Plants take in food from their surroundings."@en ;
  curric:correction """This lesson explores why the things taken in by plants are not food, and the idea that plants make the food they need to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498544Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-link-shape
  a curric:Misconception ;
  curric:statement """Pupils find it challenging to link the shape of a line graph with physical change in the real world."""@en ;
  curric:correction """Compare two sections of the graph, using the amount of extra stretch per newton as a measure of how easy the rubber band is to stretch."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498551Z"^^xsd:dateTime .

oakcurric:misconception-thinking-populations-organisms-stay-same
  a curric:Misconception ;
  curric:statement "Thinking that populations of organisms stay the same forever."@en ;
  curric:correction """This model clearly demonstrates that populations change over time due to natural selection, with advantageous traits (e.g. camouflage) becoming more common in the population."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498570Z"^^xsd:dateTime .

oakcurric:misconception-line-graph-go-points
  a curric:Misconception ;
  curric:statement "The line of a graph must go through all of the points."@en ;
  curric:correction """Get pupils to invent plots to add to a graph showing a line of best fit that include small mistakes in the measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498577Z"^^xsd:dateTime .

oakcurric:misconception-difference-concentrated-dilute-vs-strong
  a curric:Misconception ;
  curric:statement """The difference between concentrated and dilute vs strong and weak when referring to acids and alkalis (not covered in this lesson)."""@en ;
  curric:correction """For acids and alkalis concentration is the amount of hydrogen dissolved in a certain volume of solution. The higher the concentration, the lower the pH. Strong and weak refer to the ability of an acid to release hydrogen (not covered in lesson)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498584Z"^^xsd:dateTime .

oakcurric:misconception-appreciating-links-form-function-biological
  a curric:Misconception ;
  curric:statement "Not appreciating the links between form and function in biological structures."@en ;
  curric:correction """This lesson develops a key cross-cutting idea in biology: the shapes and forms of biological structures are adapted for specific functions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498771Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-carry-complex
  a curric:Misconception ;
  curric:statement "Pupils find it difficult to carry out a complex 3-stage practical."@en ;
  curric:correction """Demonstrate the practical or do a 'follow with me' step-by-step method. If you are short on time you could just carry out the first part of the practical to produce the copper sulfate solution then stop."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498786Z"^^xsd:dateTime .

oakcurric:misconception-light-chemical-reactant-photosynthesis-turned
  a curric:Misconception ;
  curric:statement "Light is a chemical reactant in photosynthesis and it is turned into food."@en ;
  curric:correction "Challenge the misconception that light is a chemical reactant in photosynthesis."@en ;
  dcterms:modified "2026-02-19T08:26:10.498808Z"^^xsd:dateTime .

oakcurric:misconception-word-material-challenging-different-meaning
  a curric:Misconception ;
  curric:statement """The word material can be challenging, it has a different meaning in everyday life. Understanding that an alloy is a mixture and not a compound is hard because the elements are difficult to separate."""@en ;
  curric:correction """Provide lots of different examples of materials and use the word correctly within the scientific contexts. An alloy is the exception to the rule and is separated by thermal or chemical processes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498819Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-neutralisation-e-exactly
  a curric:Misconception ;
  curric:statement """Pupils often do not understand what neutralisation is i.e. exactly the correct quantities of components from the acid and base combined to form water."""@en ;
  curric:correction """It is worth emphasising that water is formed and it is this which is neutral as it contains the hydrogen and oxygen atoms from the acid and base."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498838Z"^^xsd:dateTime .

oakcurric:misconception-students-aware-bones-become-fossilised
  a curric:Misconception ;
  curric:statement """Most students will be aware that bones can become fossilised but not realise that other remains such as wood or footprints can also become fossils too."""@en ;
  curric:correction """This lesson contains a broad range of examples of the types of remains that can become fossilised."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498893Z"^^xsd:dateTime .

oakcurric:misconception-pupils-expect-reactions-vigorous-see
  a curric:Misconception ;
  curric:statement """Pupils can expect that all reactions will be vigorous and they will see lots of bubbles being formed instantly."""@en ;
  curric:correction """Get pupils to leave and observe their metal + acid reactions over a period of time, e.g. 5 minutes. This will ensure that they will be able to observe bubbles forming more slowly for metals such as iron or zinc."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498903Z"^^xsd:dateTime .

oakcurric:misconception-catalyst-one-reactants-gets-used
  a curric:Misconception ;
  curric:statement "The catalyst is one of the reactants and gets used up during the reaction."@en ;
  curric:correction """Emphasise that the chemical reaction will take place without the catalyst but at a very slow rate."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498911Z"^^xsd:dateTime .

oakcurric:misconception-understanding-displacement-reactions-challenging-many
  a curric:Misconception ;
  curric:statement """Understanding displacement reactions can be challenging as many pupils think the product has moved from somewhere else rather than being produced during the chemical reaction."""@en ;
  curric:correction """Focus on explaining the macroscopic observations in a displacement reaction in terms of chemical change. Then move on to apply the ideas to the reactivity of the metal."""@en ;
  dcterms:modified "2026-02-19T08:26:10.498932Z"^^xsd:dateTime .

oakcurric:misconception-food-absorbed-without-digested-goodness
  a curric:Misconception ;
  curric:statement """Food is absorbed without being digested; or "goodness" from food is what is absorbed."""@en ;
  curric:correction """The lesson explores the roles of mechanical and chemical digestion (by enzymes) of different food types into small molecules to be absorbed."""@en ;
  dcterms:modified "2026-02-19T08:26:10.499322Z"^^xsd:dateTime .

oakcurric:misconception-non-infectious-diseases-such-heart
  a curric:Misconception ;
  curric:statement """Non-infectious diseases such as heart disease can be passed from person to person."""@en ;
  curric:correction "Only infectious diseases caused by pathogens can spread from person to person."@en ;
  dcterms:modified "2026-02-19T08:26:10.499515Z"^^xsd:dateTime .

oakcurric:misconception-winds-cooling-because-moving-air
  a curric:Misconception ;
  curric:statement """Winds are cooling because they are moving air that is colder than the surrounding air."""@en ;
  curric:correction """Discuss with pupils how hotter objects heat the air around them, so the temperature difference between them and the air is smaller; and how wind blows away this warmer air. Provide opportunity for them to explain this in their own words."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500277Z"^^xsd:dateTime .

oakcurric:misconception-asthma-childhood-disease-people-grow
  a curric:Misconception ;
  curric:statement "Asthma is a childhood disease that people will grow out of."@en ;
  curric:correction """Although symptoms can improve as children get into adolescence, they will always have asthma and it may worsen as they get into old age."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500572Z"^^xsd:dateTime .

oakcurric:misconception-thinking-chop-destroy-forests-without
  a curric:Misconception ;
  curric:statement "Thinking that we can chop down and destroy forests without affecting ecosystems."@en ;
  curric:correction """The lessons explores how deforestation disrupts key processes in the carbon cycle and the water cycle, and how this can increase climate change, flooding, and put our food security at risk."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500596Z"^^xsd:dateTime .

oakcurric:misconception-voltage-parallel-circuit-shared-branch
  a curric:Misconception ;
  curric:statement "Voltage in a parallel circuit is shared out between each branch of the circuit."@en ;
  curric:correction """Provide opportunity for pupils to measure voltage across each branch of a range of parallel circuits to give evidence for the correct rule."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500606Z"^^xsd:dateTime .

oakcurric:misconception-ultrasound-harmful-human-body-similar
  a curric:Misconception ;
  curric:statement "Ultrasound may be harmful to the human body (similar to X–rays)."@en ;
  curric:correction """Ultrasound is essentially the same thing as sound (longitudinal waves). It consists of vibrations of matter, rather than an additional entity or 'ray' that interacts strongly with matter. Compare sound of 19 999 Hz with ultrasound of 20 001 Hz."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500617Z"^^xsd:dateTime .

oakcurric:misconception-water-moves-forwards-water-wave
  a curric:Misconception ;
  curric:statement "Water moves forwards with a water wave."@en ;
  curric:correction """Show pupils animations depicting how transverse waves are created in water (and on ropes) by patterns of oscillation. Explicitly draw their attention to how the wave shape / wave pattern travels forwards without any material travelling forwards."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500631Z"^^xsd:dateTime .

oakcurric:misconception-sound-entity-substance-kind-travels
  a curric:Misconception ;
  curric:statement """Sound is an entity/substance of some kind that travels through air, or is somehow 'carried' by air particles or passed between them in collisions. Sound involves air moving away from a sound source."""@en ;
  curric:correction """Use moving animations to show pupils how the travelling pulses of a longitudinal wave are created from particles vibrating back and forth without being transported. Give pupils time to observe the motion of different single particles."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500666Z"^^xsd:dateTime .

oakcurric:misconception-thinking-agriculture-means-growing-crops
  a curric:Misconception ;
  curric:statement "Thinking that agriculture just means growing crops."@en ;
  curric:correction """The lesson explores the idea that agriculture also includes using land to rear animals, and that this has destroyed more habitat than using land to grow crops."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500673Z"^^xsd:dateTime .

oakcurric:misconception-thinking-plastic-food-packaging-disadvantages
  a curric:Misconception ;
  curric:statement """Thinking that plastic food packaging only has disadvantages, due to its effects as a pollutant in oceans and land ecosystems."""@en ;
  curric:correction """This lesson explores the advantages of plastic packaging in reducing food waste, alongside the risks it can pose to biodiversity."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500680Z"^^xsd:dateTime .

oakcurric:misconception-thinking-species-choose-plan-evolve
  a curric:Misconception ;
  curric:statement """Thinking that species can choose or plan to evolve new adaptations to help them to survive climate change."""@en ;
  curric:correction """Part 2 of the lesson explores the idea that evolution occurs at random and may be too slow to save many species from climate change."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500732Z"^^xsd:dateTime .

oakcurric:misconception-pupils-discriminate-sufficiently-current-voltage
  a curric:Misconception ;
  curric:statement """Most pupils do not discriminate sufficiently between current, voltage, energy and power."""@en ;
  curric:correction """Provide pupils with opportunities to calculate energy usage with appliances that have different power ratings and are used for different lengths of time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500792Z"^^xsd:dateTime .

oakcurric:misconception-sound-waves-same-thing-sound
  a curric:Misconception ;
  curric:statement """Sound waves are the same thing as the sound heard. Sound waves somehow 'have' sound."""@en ;
  curric:correction """Distinguish between the sound heard and the sound wave. The brain creates the sensation of hearing a sound when it receives nerve signals from the ear. The sound (heard) does not exist until created by the brain. Sound waves themselves have no sound."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500800Z"^^xsd:dateTime .

oakcurric:misconception-pupils-analyse-circuits-sequentially-starting
  a curric:Misconception ;
  curric:statement """Pupils often analyse circuits sequentially, starting from the battery, which makes predicting what current does at a junction impossible."""@en ;
  curric:correction """Teach pupils to analyse each complete loop of a parallel circuit as whole loops. The currents through each loop then add to give the current through the battery (rather than current from the battery miraculously ‘knowing’ how to split at a junction)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500817Z"^^xsd:dateTime .

oakcurric:misconception-high-pitched-sounds-higher-frequency
  a curric:Misconception ;
  curric:statement """High pitched sounds (higher frequency sound waves) travel faster than low pitched sounds (lower frequency sound waves)."""@en ;
  curric:correction """Take measurements for the speed of sound using a high-pitched blast of a whistle as well as the lower pitched sound of hitting pieces of wood together to show they are the same (within error)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.500835Z"^^xsd:dateTime .

oakcurric:misconception-pupils-equate-weathering-breakdown-rock
  a curric:Misconception ;
  curric:statement """Pupils equate 'weathering' as the breakdown of rock caused only by the 'weather'. They also tend to use 'weathering' and 'erosion' interchangeably."""@en ;
  curric:correction """Provide many opportunities for pupils to identify weathering from erosion or classify examples of weathering or erosion."""@en ;
  dcterms:modified "2026-02-19T08:26:10.501145Z"^^xsd:dateTime .

oakcurric:misconception-enough-food-world-bees-pollinators
  a curric:Misconception ;
  curric:statement "There is not enough food in the world, and that bees are the only pollinators."@en ;
  curric:correction """Emphasise that food distribution and nutrition is an issue in food security; also that there are many types of pollinator."""@en ;
  dcterms:modified "2026-02-19T08:26:10.501179Z"^^xsd:dateTime .

oakcurric:misconception-offspring-esp-daughters-inherit-features
  a curric:Misconception ;
  curric:statement """Offspring (esp. daughters) inherit all features from mum; parents can control inherited features."""@en ;
  curric:correction """Show examples of offspring inheriting features from both parents. Inherited features that are inherited in genetic material, not chosen."""@en ;
  dcterms:modified "2026-02-19T08:26:10.501200Z"^^xsd:dateTime .

oakcurric:misconception-heart-heart-shaped-heart-gets
  a curric:Misconception ;
  curric:statement """The heart is heart shaped. The heart gets oxygen and glucose from the blood being pumped out."""@en ;
  curric:correction "Point out the shape of the heart and then reinforce with task B."@en ;
  dcterms:modified "2026-02-19T08:26:10.501271Z"^^xsd:dateTime .

oakcurric:misconception-organisms-able-adapt-place-live
  a curric:Misconception ;
  curric:statement "Organisms are able to adapt to the place where they live."@en ;
  curric:correction """Referring to inheritance, explain that changes to organisms take time to evolve - responses to any environmental change is not instant."""@en ;
  dcterms:modified "2026-02-19T08:26:10.501514Z"^^xsd:dateTime .

oakcurric:misconception-thinking-keep-finding-fossil-fuels
  a curric:Misconception ;
  curric:statement """Thinking we can keep finding more fossil fuels to use, and that they are a renewable energy resource."""@en ;
  curric:correction """Teach that fossil fuels take millions of years to form and they are being used at a faster rate than they are produced."""@en ;
  dcterms:modified "2026-02-19T08:26:10.501885Z"^^xsd:dateTime .

oakcurric:misconception-producing-line-drawing-sketched-broken
  a curric:Misconception ;
  curric:statement """Producing a line drawing with sketched broken lines, shading, no labelling and no magnification."""@en ;
  curric:correction """Learning cycle 2 in this lesson explores how to produce a scientific line drawing to record observations from light microscopy."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502373Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-circuit-diagram-map
  a curric:Misconception ;
  curric:statement """Pupils often think of a circuit diagram as a map of a circuit when, in fact, it is a stylised representation that is drawn in a particular way to increase its clarity."""@en ;
  curric:correction """Emphasise that the diagram shows the sequence of the components in the circuit, not the position. A component can be moved to a different place but still be in the same sequence."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502382Z"^^xsd:dateTime .

oakcurric:misconception-students-think-objects-fall-same
  a curric:Misconception ;
  curric:statement """Students may think that all objects fall at the same rate (this is only true in a vacuum)."""@en ;
  curric:correction """Use force diagrams to discuss the effect of different sized drag on the parachutes, linking this to resultant force and acceleration."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502460Z"^^xsd:dateTime .

oakcurric:misconception-many-pupils-imagine-electric-current
  a curric:Misconception ;
  curric:statement """Many pupils imagine electric current to emerge from a battery or a power supply and to move around a circuit in a sequential way.  This leads to a consumption model of electricity."""@en ;
  curric:correction """Give pupils opportunities to test different incorrect models (e.g. the unipolar and clashing current model,s as well as the consumption model)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502487Z"^^xsd:dateTime .

oakcurric:misconception-pupils-hold-consumption-model-electric
  a curric:Misconception ;
  curric:statement """Pupils often hold a consumption model of electric current, believing it is used up in a circuit. They misuse the terms voltage, current and electricity, and may choose a voltmeter to measure current."""@en ;
  curric:correction """Encourage pupils to investigate the size of the current through a range of different conductors (and insulators) using an ammeter in a simple circuit. This will help them become familiar with the ammeter and its correct use."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502510Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-voltage-current-thinking
  a curric:Misconception ;
  curric:statement """Pupils may confuse voltage and current, thinking voltage is part of the current, and struggle to apply their understanding to unfamiliar situations."""@en ;
  curric:correction """Encourage pupils to think of voltage as an ‘electric push’ and current as the flow of electric charge. Have them consider how current flows through a bulb and its effects, with voltage pushing the current and current being the movement of charge."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502540Z"^^xsd:dateTime .

oakcurric:misconception-seed-living
  a curric:Misconception ;
  curric:statement "A seed is not living."@en ;
  curric:correction """A seed is living, it contains an embryo and a food store and is a stage of development in the growth of offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502564Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-think-gases-made
  a curric:Misconception ;
  curric:statement """Pupils tend to think that all gases are made of air. That gases contain no particles."""@en ;
  curric:correction """Ensure that pupils gain the knowledge that the particles are the substance and between the particles there is nothing."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502570Z"^^xsd:dateTime .

oakcurric:misconception-common-misconception-biomass-increases-move
  a curric:Misconception ;
  curric:statement """A common misconception is that the biomass increases as you move to the next trophic level, presumably  because pupils incorrectly assume that biomass refers to individuals rather than populations."""@en ;
  curric:correction """The lesson gets pupils to estimate the biomass of populations at each trophic level to demonstrate that biomass decreases at each trophic level."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502714Z"^^xsd:dateTime .

oakcurric:misconception-length-spring-equal-extension-spring
  a curric:Misconception ;
  curric:statement "The length of the spring is equal to the extension of the spring."@en ;
  curric:correction """Focus on the fact that forces cause the length of the spring to change and pupils are measuring the size of that change."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502721Z"^^xsd:dateTime .

oakcurric:misconception-two-types-cell-plant-animal
  a curric:Misconception ;
  curric:statement "There are only two types of cell: plant and animal."@en ;
  curric:correction """The lesson explores the cells of unicellular organisms and some of their adaptations."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502868Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-distance-time-value
  a curric:Misconception ;
  curric:statement """Pupils can think that a distance or time value read from a distance-time graph is the speed."""@en ;
  curric:correction """Remind pupils of the definition of speed, pointing out that it requires two pieces of information to find - both the distance and time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502885Z"^^xsd:dateTime .

oakcurric:misconception-idea-air-particles-gas
  a curric:Misconception ;
  curric:statement "The idea that there is air between the particles in a gas."@en ;
  curric:correction "Emphasis on explaining that air contains particles and has nothing between them."@en ;
  dcterms:modified "2026-02-19T08:26:10.503065Z"^^xsd:dateTime .

oakcurric:misconception-cells-exactly-like-standard-animal
  a curric:Misconception ;
  curric:statement """All cells are exactly like the standard animal and plant cell models shown in textbooks."""@en ;
  curric:correction """The lesson explores different shapes, sizes, and structures, of specialised cells that are adapted for specific functions."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503074Z"^^xsd:dateTime .

oakcurric:misconception-confusing-reagents-substances-test-results
  a curric:Misconception ;
  curric:statement """Confusing the reagents and the substances they test for, or the results of the tests."""@en ;
  curric:correction """Each test is dealt with separately and the positive and negative results are discussed sequentially."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503126Z"^^xsd:dateTime .

oakcurric:misconception-pupils-likely-use-words-current
  a curric:Misconception ;
  curric:statement """Pupils are likely to use the words current, voltage, power, and energy interchangeably. They often have a consumption model of current and believe that voltage flows through a circuit."""@en ;
  curric:correction """It is essential that pupils distinguish between the current flowing through the circuit (which is conserved), the energy stored in the cell or battery and transferred elsewhere, and the voltage across the cell, battery or component."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503133Z"^^xsd:dateTime .

oakcurric:misconception-members-species-especially-non-human
  a curric:Misconception ;
  curric:statement "All members of a species (especially non-human species) look exactly the same."@en ;
  curric:correction """The lesson explores examples of variation between members of the same species, and causes of these variations."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503142Z"^^xsd:dateTime .

oakcurric:misconception-downwards-force-surface-upward-force
  a curric:Misconception ;
  curric:statement """There is a downwards force on a surface, but no upward force, the surface just gets in the way."""@en ;
  curric:correction """Have pupils describe upward forces they need to exert whilst supporting different sized weights at arms length."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503172Z"^^xsd:dateTime .

oakcurric:misconception-plants-living-organisms-non-living
  a curric:Misconception ;
  curric:statement """Plants are not living organisms; non-living things are alive; any type of movement is a sign of life"""@en ;
  curric:correction """The lesson explores common life processes in a variety of organisms, including plants and microorganisms, and explores movement in detail."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503972Z"^^xsd:dateTime .

oakcurric:misconception-plants-living-plant-cells-same
  a curric:Misconception ;
  curric:statement """Plants are not living; plant cells all have the same shape and structures (as depicted in textbooks)"""@en ;
  curric:correction """This lesson consolidates understanding that plant cells are living, and that different plant cells can have different shapes and structures."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504097Z"^^xsd:dateTime .

oakcurric:misconception-pressure-greater-bottom-wider-container
  a curric:Misconception ;
  curric:statement """Pressure is greater at the bottom of a wider container than at the bottom of a narrower one."""@en ;
  curric:correction """Discuss how the force of water in the wider container is acting over a bigger area and refer to pressure = force ÷ area."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504168Z"^^xsd:dateTime .

oakcurric:misconception-pupils-refer-turns-coil-number
  a curric:Misconception ;
  curric:statement "Pupils often refer to the turns of a coil as the number of coils."@en ;
  curric:correction "Emphasise that turns of wire can be added to a coil to make the coil longer."@en ;
  dcterms:modified "2026-02-19T08:26:10.504181Z"^^xsd:dateTime .

oakcurric:misconception-particle-spacing-overemphasised-expense-particle
  a curric:Misconception ;
  curric:statement "Particle spacing can be overemphasised at the expense of particle movement."@en ;
  curric:correction """Ensure pupils understand that although particles can move over each other, the forces of attraction mean that the particles are touching."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504258Z"^^xsd:dateTime .

oakcurric:misconception-independent-variable-measured-gets-confused
  a curric:Misconception ;
  curric:statement """The independent variable is also measured, so this often gets confused with the dependent variable."""@en ;
  curric:correction """Use the definition for the dependent variable that it is being measured for the purpose of seeing what has happened at the end; the effect that the independent variable has had."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504357Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-light-objects-float
  a curric:Misconception ;
  curric:statement "Pupils may think that all light objects float and that all heavy objects sink."@en ;
  curric:correction """Explore how mass and volume (determined by shape) affect whether objects float or sink - before discussing density."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504423Z"^^xsd:dateTime .

oakcurric:misconception-atmosphere-mostly-oxygen
  a curric:Misconception ;
  curric:statement "The atmosphere is mostly oxygen."@en ;
  curric:correction """Describe the atmosphere as ~78% unreactive nitrogen and ~20% oxygen. Explain that if the atmosphere were mostly oxygen, the planet would quickly be engulfed in fire."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504430Z"^^xsd:dateTime .

oakcurric:misconception-turning-effect-force-wrongly-called
  a curric:Misconception ;
  curric:statement "The turning effect is a force (it is often wrongly called a turning force)."@en ;
  curric:correction """Correct any use of the erroneous term ‘turning force’ and use examples of the turning effect caused by force with a lever."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504442Z"^^xsd:dateTime .

oakcurric:misconception-components-parallel-circuit-match-exact
  a curric:Misconception ;
  curric:statement """Components of a parallel circuit must match the exact layout of a circuit diagram."""@en ;
  curric:correction """Focus on pupils starting at one end of the battery and building each loop up in turn, focusing on putting the connections in the correct order."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504491Z"^^xsd:dateTime .

oakcurric:misconception-displaying-results-table-landscape-variables
  a curric:Misconception ;
  curric:statement "Displaying results in a table landscape with variables the wrong way round."@en ;
  curric:correction "Clear descriptions and examples of correct tables."@en ;
  dcterms:modified "2026-02-19T08:26:10.504513Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-realise-insecticides-herbicides
  a curric:Misconception ;
  curric:statement """Pupils don’t realise that insecticides and herbicides are all examples of pesticides."""@en ;
  curric:correction """Pupils should understand pesticides are a group of chemicals that kill organisms. Different types of pesticide kill different types of pest."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504535Z"^^xsd:dateTime .

oakcurric:misconception-common-think-organisms-especially-humans
  a curric:Misconception ;
  curric:statement """It is common to think that organisms, especially humans, can survive without other organisms."""@en ;
  curric:correction """This lesson highlights and explores the key concept that all living organisms are dependent upon other organisms for their survival."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504542Z"^^xsd:dateTime .

oakcurric:misconception-dna-genetic-information-substance-organisms
  a curric:Misconception ;
  curric:statement """DNA is just 'genetic information' and not a substance; not all organisms contain DNA (e.g. plants)."""@en ;
  curric:correction """The lesson demonstrates that DNA is a physical, chemical substance that can be extracted from cells, and shows that plants contain DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504592Z"^^xsd:dateTime .

oakcurric:misconception-battery-produces-fixed-sized-current
  a curric:Misconception ;
  curric:statement """The battery produces a fixed sized current that splits between each branch of a parallel circuit."""@en ;
  curric:correction """Consider each branch of a parallel circuit as a separate series circuit connected to an identical battery, in which the total current through the battery is determined by the current it can push through each of the branches  added together."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504757Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confused-analyse-parallel-circuit
  a curric:Misconception ;
  curric:statement "Pupils are often confused about how to analyse a parallel circuit."@en ;
  curric:correction """Emphasise the need to consider each loop of a parallel circuit as if it were a single series circuit connected to a cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:10.505057Z"^^xsd:dateTime .

oakcurric:misconception-legal-drugs-cannot-lead-addiction
  a curric:Misconception ;
  curric:statement "Legal drugs cannot lead to addiction."@en ;
  curric:correction "Nearly all drugs used for recreation, legal or illegal, can lead to addiction."@en ;
  dcterms:modified "2026-02-19T08:26:10.505085Z"^^xsd:dateTime .

oakcurric:misconception-elements-same-period-similar-properties
  a curric:Misconception ;
  curric:statement "Elements in the same period have similar properties."@en ;
  curric:correction """Properties vary across a period; it is elements in the same group that share similar properties."""@en ;
  dcterms:modified "2026-02-19T08:26:10.507148Z"^^xsd:dateTime .

oakcurric:misconception-substance-cannot-seen-disappeared-longer
  a curric:Misconception ;
  curric:statement "If a substance cannot be seen, it has disappeared and is no longer present."@en ;
  curric:correction """Remind pupils of work regarding evaporation and use particle models to describe / explain what a solution of two liquids is like."""@en ;
  dcterms:modified "2026-02-19T08:26:10.508066Z"^^xsd:dateTime .

oakcurric:misconception-biomass-renewable-energy-resource-because
  a curric:Misconception ;
  curric:statement "Biomass is a renewable energy resource because plants can be regrown."@en ;
  curric:correction """Discuss the idea that renewable resources **will not** run out, whereas biomass **could** run out or be seriously depleted if it is not used sustainably."""@en ;
  dcterms:modified "2026-02-19T08:26:10.509693Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-light-made-light
  a curric:Misconception ;
  curric:statement """Pupils sometimes think light is made up from light rays (small thing 'pieces' of light). Pupils may also think shadows are objects, reflections or that shadows are always black."""@en ;
  curric:correction """Light rays are just arrows showing the direction some light travels, like arrows on a map showing a route. Leave what light is (oscillating electric & magnetic fields) to KS4. Shadows are unlit areas that look dark compared to lit surroundings."""@en ;
  dcterms:modified "2026-02-19T08:26:10.511450Z"^^xsd:dateTime .

oakcurric:misconception-pupils-regularly-confuse-words-table
  a curric:Misconception ;
  curric:statement "Pupils regularly confuse the words 'table' and 'graph'."@en ;
  curric:correction """Stress that a table of results holds measurements / observations (like a dinner table holds plates), while a graph is only on *graph* paper."""@en ;
  dcterms:modified "2026-02-19T08:26:10.512879Z"^^xsd:dateTime .

oakcurric:misconception-pressure-heating-caused-burying-alone
  a curric:Misconception ;
  curric:statement """Pressure and heating caused by burying alone is enough to cause metamorphism or rock to melt."""@en ;
  curric:correction """Highlight that the temperatures / pressures needed for metamorphism or rocks to melt are typically found at plate boundaries / hot spots."""@en ;
  dcterms:modified "2026-02-19T08:26:10.514090Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-easily-confused-variables
  a curric:Misconception ;
  curric:statement "Pupils get easily confused between variables and how to ensure a fair test."@en ;
  curric:correction """Ensure that pupils understand the independent variable is the type of fuel, the dependent variable is the temperature increase and control variables are mass of fuel and volume of water."""@en ;
  dcterms:modified "2026-02-19T08:26:10.515948Z"^^xsd:dateTime .

oakcurric:misconception-idea-atoms-created-destroyed-new
  a curric:Misconception ;
  curric:statement "The idea that atoms can be created or destroyed when new products are formed."@en ;
  curric:correction """Matter cannot be created or destroyed, only arranged differently to be formed into new products."""@en ;
  dcterms:modified "2026-02-19T08:26:10.516177Z"^^xsd:dateTime .
