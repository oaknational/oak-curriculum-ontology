# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-6654-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vaping is an alternative to smoking."@en ;
  dcterms:modified "2026-02-19T08:26:13.513750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6654-2
  a curric:KeyLearningPoint ;
  rdfs:label "Like smoking, vaping involves consuming nicotine which is detrimental to health."@en ;
  dcterms:modified "2026-02-19T08:26:13.513754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6654-3
  a curric:KeyLearningPoint ;
  rdfs:label "The health effects of vaping are not yet fully known."@en ;
  dcterms:modified "2026-02-19T08:26:13.513758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6654-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific ideas are updated as new evidence emerges."@en ;
  dcterms:modified "2026-02-19T08:26:13.513762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6655-1
  a curric:KeyLearningPoint ;
  rdfs:label "Medicines are drugs that people take when they are ill."@en ;
  dcterms:modified "2026-02-19T08:26:13.513925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6655-2
  a curric:KeyLearningPoint ;
  rdfs:label """People consume other drugs for recreation, including caffeine, nicotine and alcohol."""@en ;
  dcterms:modified "2026-02-19T08:26:13.513932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6655-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recreational drugs can be classified as depressants or stimulants."@en ;
  dcterms:modified "2026-02-19T08:26:13.513936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6655-4
  a curric:KeyLearningPoint ;
  rdfs:label "Depressants slow down thinking and reaction times."@en ;
  dcterms:modified "2026-02-19T08:26:13.513940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6655-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohol is a legal depressant, but long-term alcohol use can damage the brain and liver."""@en ;
  dcterms:modified "2026-02-19T08:26:13.513944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4115-1
  a curric:KeyLearningPoint ;
  rdfs:label """Categoric variables come in distinct types. Continous variables can take any value on a numerical scale."""@en ;
  dcterms:modified "2026-02-19T08:26:13.514128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts are used when the variable you changed in an experiment is categoric."@en ;
  dcterms:modified "2026-02-19T08:26:13.514132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4115-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective lubricant reduces the friction force."@en ;
  dcterms:modified "2026-02-19T08:26:13.514136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4115-4
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion states what you found out in an experiment and also explains how you know."""@en ;
  dcterms:modified "2026-02-19T08:26:13.514139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5026-1
  a curric:KeyLearningPoint ;
  rdfs:label "The longer a wire, the greater its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.514166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5026-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current in a wire is a flow of electrons moving through the spaces between ‘atoms’ (metal ions)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.514170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5026-3
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling the length of a wire doubles its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.514173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5026-4
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the length of a wire doubles the number of ‘atoms’ (metal ions) in the way of the flow of electrons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.514177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5026-5
  a curric:KeyLearningPoint ;
  rdfs:label "The resistance of a (uniform) wire is proportional to its length."@en ;
  dcterms:modified "2026-02-19T08:26:13.514183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6428-1
  a curric:KeyLearningPoint ;
  rdfs:label "All matter is made up of atoms."@en ;
  dcterms:modified "2026-02-19T08:26:13.514491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6428-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton’s model of an atom is of a sphere that cannot be broken up."@en ;
  dcterms:modified "2026-02-19T08:26:13.514495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6428-3
  a curric:KeyLearningPoint ;
  rdfs:label "An element is made up of only one type of atom."@en ;
  dcterms:modified "2026-02-19T08:26:13.514499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6428-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each element is made of a different type of atom."@en ;
  dcterms:modified "2026-02-19T08:26:13.514503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6432-1
  a curric:KeyLearningPoint ;
  rdfs:label """A compound is made of two or more different elements chemically bonded through a chemical reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6432-2
  a curric:KeyLearningPoint ;
  rdfs:label """A compound may have different properties to each of the elements that it is made from."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6020-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some toxic substances are persistent (they stay in the environment and do not break down)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6020-2
  a curric:KeyLearningPoint ;
  rdfs:label "If consumed, persistent toxic substances can be passed up the food chain."@en ;
  dcterms:modified "2026-02-19T08:26:13.515643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6020-3
  a curric:KeyLearningPoint ;
  rdfs:label """The bioaccumulation of toxic substances can cause damage to organisms, particularly top predators."""@en ;
  dcterms:modified "2026-02-19T08:26:13.515648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6020-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of pesticides in farming can cause bioaccumulation."@en ;
  dcterms:modified "2026-02-19T08:26:13.515651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6630-1
  a curric:KeyLearningPoint ;
  rdfs:label "People have both physical health and mental health."@en ;
  dcterms:modified "2026-02-19T08:26:13.517315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6630-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical health and mental health range from good to ill."@en ;
  dcterms:modified "2026-02-19T08:26:13.517321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6630-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in normal body appearance, function and behaviour can be symptoms of ill health."""@en ;
  dcterms:modified "2026-02-19T08:26:13.517325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6637-1
  a curric:KeyLearningPoint ;
  rdfs:label """The recovery time is the time it takes for the heart rate to return to its resting rate after exercise."""@en ;
  dcterms:modified "2026-02-19T08:26:13.518966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6637-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heart rate in beats per minute (bpm) can be measured by taking a person's pulse."@en ;
  dcterms:modified "2026-02-19T08:26:13.518970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6637-3
  a curric:KeyLearningPoint ;
  rdfs:label """A line graph can be plotted showing pulse rate or heart rate over time after exercise."""@en ;
  dcterms:modified "2026-02-19T08:26:13.518997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6637-4
  a curric:KeyLearningPoint ;
  rdfs:label "A person's recovery time can be determined from the line graph."@en ;
  dcterms:modified "2026-02-19T08:26:13.519002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6637-5
  a curric:KeyLearningPoint ;
  rdfs:label "People who are fitter have a shorter recovery time."@en ;
  dcterms:modified "2026-02-19T08:26:13.519006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4116-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-02-19T08:26:13.519042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4116-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy can be transferred by forces that change the properties of an object (or system)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6633-1
  a curric:KeyLearningPoint ;
  rdfs:label "Not consuming a balanced diet can lead to ill health."@en ;
  dcterms:modified "2026-02-19T08:26:13.519204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6633-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body mass index (BMI) is calculated from a person’s height and body mass."@en ;
  dcterms:modified "2026-02-19T08:26:13.519208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6633-3
  a curric:KeyLearningPoint ;
  rdfs:label """Not consuming enough food can cause BMI to become too low, and eventually lead to starvation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6633-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deficiency diseases are the result of not consuming enough of a particular nutrient."""@en ;
  dcterms:modified "2026-02-19T08:26:13.519216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22212-1
  a curric:KeyLearningPoint ;
  rdfs:label "Noble gases are in Group 0 of the periodic table and are unreactive."@en ;
  dcterms:modified "2026-02-19T08:26:13.519563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22212-2
  a curric:KeyLearningPoint ;
  rdfs:label "Noble gases are all gases at room temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.519567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22212-3
  a curric:KeyLearningPoint ;
  rdfs:label "They have complete outer electron shells, making them stable."@en ;
  dcterms:modified "2026-02-19T08:26:13.519571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22212-4
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 0 elements, atomic mass, density and boiling points increase."@en ;
  dcterms:modified "2026-02-19T08:26:13.519575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6504-1
  a curric:KeyLearningPoint ;
  rdfs:label """When fuels containing carbon are burned, it is common for carbon dioxide to be made."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6504-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is a compound with molecules that each contain one carbon atom and two oxygen atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6504-3
  a curric:KeyLearningPoint ;
  rdfs:label "About 0.04 % of Earth’s atmosphere is carbon dioxide."@en ;
  dcterms:modified "2026-02-19T08:26:13.520118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6504-4
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon dioxide is a greenhouse gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.520122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6504-5
  a curric:KeyLearningPoint ;
  rdfs:label """Too many greenhouse gases in the atmosphere cause an increase in average global temperature, known as global warming."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Objects can have energy because they are: moving, raised, hot, stretched/squashed, or contain chemicals that can react."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9051-2
  a curric:KeyLearningPoint ;
  rdfs:label """When an object is said to have energy, this is really just saying the object has certain properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9051-3
  a curric:KeyLearningPoint ;
  rdfs:label """Objects can have gravitational, thermal, elastic, chemical and kinetic stores of energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9051-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having energy means having properties that allow objects to interact, cause changes and make things happen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6623-1
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic material is made of DNA."@en ;
  dcterms:modified "2026-02-19T08:26:13.520387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6623-2
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is a long chemical molecule, made of two chains of smaller chemical units joined together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6623-3
  a curric:KeyLearningPoint ;
  rdfs:label "All of the DNA in a cell is called the genome."@en ;
  dcterms:modified "2026-02-19T08:26:13.520397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6623-4
  a curric:KeyLearningPoint ;
  rdfs:label """The chains are spiralled around one another in a double helix, with links across the middle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6623-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific models of DNA can be evaluated for their strengths and weaknesses."@en ;
  dcterms:modified "2026-02-19T08:26:13.520405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5133-1
  a curric:KeyLearningPoint ;
  rdfs:label """The elements in Group 7 are all non-metals that have coloured vapours, most of which are toxic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5133-2
  a curric:KeyLearningPoint ;
  rdfs:label """The state of the elements at room temperature changes from gas to solid, down Group 7."""@en ;
  dcterms:modified "2026-02-19T08:26:13.520413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5133-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reactivity decreases down Group 7."@en ;
  dcterms:modified "2026-02-19T08:26:13.520417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5133-4
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens react with Group 1 and 2 metals to form metal halides."@en ;
  dcterms:modified "2026-02-19T08:26:13.520421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5133-5
  a curric:KeyLearningPoint ;
  rdfs:label "Metal halides are soluble in water."@en ;
  dcterms:modified "2026-02-19T08:26:13.520425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6661-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pollination is the transfer of pollen from the male anther to the female stigma."@en ;
  dcterms:modified "2026-02-19T08:26:13.521298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6661-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of pollination; self-pollination and cross-pollination. The latter increases variation in a species."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6661-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pollen grains can be transferred by the wind, water or by insects."@en ;
  dcterms:modified "2026-02-19T08:26:13.521306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6661-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisation is the fusion of the nuclei from the male and the female gametes."@en ;
  dcterms:modified "2026-02-19T08:26:13.521312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6661-5
  a curric:KeyLearningPoint ;
  rdfs:label "A zygote grows into an embryo and then a new plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.521316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4945-1
  a curric:KeyLearningPoint ;
  rdfs:label """If left for long enough, all objects in a room will reach the same temperature as the room."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating a solid makes its particles vibrate more quickly."@en ;
  dcterms:modified "2026-02-19T08:26:13.521434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4945-3
  a curric:KeyLearningPoint ;
  rdfs:label "Heating a liquid makes its particles move around more quickly."@en ;
  dcterms:modified "2026-02-19T08:26:13.521438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4945-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating a solid or liquid causes the separation of its particles to increase."@en ;
  dcterms:modified "2026-02-19T08:26:13.521442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4945-5
  a curric:KeyLearningPoint ;
  rdfs:label "Heating a solid or liquid causes it to expand."@en ;
  dcterms:modified "2026-02-19T08:26:13.521446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9129-1
  a curric:KeyLearningPoint ;
  rdfs:label """Why oxygen needs to be absorbed into, and carbon dioxide needs to be removed from, the human body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.521981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9129-2
  a curric:KeyLearningPoint ;
  rdfs:label "The function and structures of the lungs in healthy humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.522008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9129-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mechanism of breathing, including the role of muscles, to move air in and out of the lungs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9129-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations of healthy lungs that increase the amount of gas exchange."@en ;
  dcterms:modified "2026-02-19T08:26:13.522017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9129-5
  a curric:KeyLearningPoint ;
  rdfs:label "Detailed structure of the alveoli in healthy human lungs."@en ;
  dcterms:modified "2026-02-19T08:26:13.522021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9793-1
  a curric:KeyLearningPoint ;
  rdfs:label """Laboratory equipment are designed for specific uses and choice of equipment impacts the quality of results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.522509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9793-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mass can be measured on a balance, in grams"@en ;
  dcterms:modified "2026-02-19T08:26:13.522513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9793-3
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in a measuring cylinder, in cm³"@en ;
  dcterms:modified "2026-02-19T08:26:13.522517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity is the number of different species that live in a place."@en ;
  dcterms:modified "2026-02-19T08:26:13.522832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6021-2
  a curric:KeyLearningPoint ;
  rdfs:label """Biodiversity is important as it keeps habitats healthy, and provides humans with food, medicines and other resources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6021-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humans have a negative impact on biodiversity through habitat destruction and pollution of the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6021-4
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can take action to help maintain biodiversity, such as through conservation activities."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6021-5
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic diversity can be conserved through seed banks and other forms of gene banks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6505-1
  a curric:KeyLearningPoint ;
  rdfs:label "Combustion increases the amount of carbon dioxide in the atmosphere."@en ;
  dcterms:modified "2026-02-19T08:26:13.522964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6505-2
  a curric:KeyLearningPoint ;
  rdfs:label """Respiration of living things increases the amount of carbon dioxide in the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6505-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decomposition of dead plants and animals increases the amount of carbon dioxide in the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6505-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis by plants, phytoplankton and some bacteria reduce the amount of carbon dioxide in the atmosphere."""@en ;
  dcterms:modified "2026-02-19T08:26:13.522976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6505-5
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon dioxide can dissolve in the oceans."@en ;
  dcterms:modified "2026-02-19T08:26:13.522980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6670-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different foods provide different amounts of energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.523349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6670-2
  a curric:KeyLearningPoint ;
  rdfs:label """The amount of energy provided by different foods can be investigated and compared by burning them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.523352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6670-3
  a curric:KeyLearningPoint ;
  rdfs:label "Burning foods can heat water and the temperature change of the water measured."@en ;
  dcterms:modified "2026-02-19T08:26:13.523358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6670-4
  a curric:KeyLearningPoint ;
  rdfs:label "The mean temperature change can be calculated from repeat measurements."@en ;
  dcterms:modified "2026-02-19T08:26:13.523363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6670-5
  a curric:KeyLearningPoint ;
  rdfs:label """Energy provided by the food (J) = mass of water (g) × rise in temperature (°C) × 4.2."""@en ;
  dcterms:modified "2026-02-19T08:26:13.523367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6622-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plant and animal cells are made of parts including a cell membrane, cytoplasm and a nucleus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.523841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6622-2
  a curric:KeyLearningPoint ;
  rdfs:label "In plant, animal and fungi cells, the genetic material is stored in the nucleus."@en ;
  dcterms:modified "2026-02-19T08:26:13.523845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6622-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria are microorganisms and do not have a nucleus; their genetic material is stored in the cytoplasm."""@en ;
  dcterms:modified "2026-02-19T08:26:13.523849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6622-4
  a curric:KeyLearningPoint ;
  rdfs:label """The genetic material of all organisms is made of a chemical substance called DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:13.523853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6622-5
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is built from molecules that form a code used as instructions to build inherited features and control life processes"""@en ;
  dcterms:modified "2026-02-19T08:26:13.523859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4839-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cells have a 3D shape (not 2D as they often appear in textbooks)."@en ;
  dcterms:modified "2026-02-19T08:26:13.524254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4839-2
  a curric:KeyLearningPoint ;
  rdfs:label "Common structures of animal cells can be shown in diagrams."@en ;
  dcterms:modified "2026-02-19T08:26:13.524257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4839-3
  a curric:KeyLearningPoint ;
  rdfs:label "These structures include the cytoplasm, cell membrane, nucleus and mitochondria."@en ;
  dcterms:modified "2026-02-19T08:26:13.524261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4839-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each structure in an animal cell has a specific function."@en ;
  dcterms:modified "2026-02-19T08:26:13.524267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4839-5
  a curric:KeyLearningPoint ;
  rdfs:label "Cells can be represented using 2D and 3D scientific models."@en ;
  dcterms:modified "2026-02-19T08:26:13.524271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4984-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some objects can be charged by rubbing with certain materials."@en ;
  dcterms:modified "2026-02-19T08:26:13.524442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4984-2
  a curric:KeyLearningPoint ;
  rdfs:label """Objects with a static electric charge can exert a force on other objects (that contain electric charge)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.524446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4984-3
  a curric:KeyLearningPoint ;
  rdfs:label "The electrostatic force acts at a distance."@en ;
  dcterms:modified "2026-02-19T08:26:13.524452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4984-4
  a curric:KeyLearningPoint ;
  rdfs:label "Objects with opposite electric charges attract each other."@en ;
  dcterms:modified "2026-02-19T08:26:13.524456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4984-5
  a curric:KeyLearningPoint ;
  rdfs:label "Objects with the same electric charge as each other repel each other."@en ;
  dcterms:modified "2026-02-19T08:26:13.524460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6660-1
  a curric:KeyLearningPoint ;
  rdfs:label "Flowering plants reproduce sexually."@en ;
  dcterms:modified "2026-02-19T08:26:13.524760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6660-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plant reproduction is important as plants are producers and provide food for all animals on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.524764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flowers contain male and female sex organs and gametes."@en ;
  dcterms:modified "2026-02-19T08:26:13.524768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Egg cells (ova) are female gametes."@en ;
  dcterms:modified "2026-02-19T08:26:13.524772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6660-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pollen grains carry male gametes."@en ;
  dcterms:modified "2026-02-19T08:26:13.524776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9078-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hazard symbols are used to decribe the dangers of substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.524954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9078-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each element has its own distinct properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.524958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9078-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metalloid elements have some properties of metals and some properties of non-metals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.524961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6016-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ecosystems are made up of living organisms, which interact and depend on each other, and their physical environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Habitats are where plants and animals live, and they contain living (biotic) and non-living (abiotic) parts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms interact with the environment in which they live."@en ;
  dcterms:modified "2026-02-19T08:26:13.526051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6016-4
  a curric:KeyLearningPoint ;
  rdfs:label "All species have adaptations which make them suited to their environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.526055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Changes to the environment may make it harder for organisms to survive in a particular habitat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6014-1
  a curric:KeyLearningPoint ;
  rdfs:label """Producers are organisms that can make their own food, including plants and some microorganisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers (e.g. humans and other animals) cannot make their own food; they get their food by eating other organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6014-3
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain diagram shows the feeding relationships between populations of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6014-4
  a curric:KeyLearningPoint ;
  rdfs:label "The arrows in a food chain diagram represent transfers of biomass."@en ;
  dcterms:modified "2026-02-19T08:26:13.526955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6014-5
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the size of a population will affect other populations in the food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.526959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9090-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils are found in sedimentary rock, but not in other types of rock."@en ;
  dcterms:modified "2026-02-19T08:26:13.533693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9090-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils are often the remains of living plants or animals."@en ;
  dcterms:modified "2026-02-19T08:26:13.533697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9090-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bones buried in sedimentary rock can be very, very slowly dissolved by water and replaced by minerals in the water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.533701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9090-4
  a curric:KeyLearningPoint ;
  rdfs:label "Geological activities can break or completely destroy fossils."@en ;
  dcterms:modified "2026-02-19T08:26:13.533704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Earth was once thought to be flat, with all the stars and the Sun moving around it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9053-2
  a curric:KeyLearningPoint ;
  rdfs:label """Until the 16th century most people thought Earth was at the centre of the universe."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations with telescopes provide evidence that helps us to understand the universe."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6501-1
  a curric:KeyLearningPoint ;
  rdfs:label "Water in nature always contains minerals."@en ;
  dcterms:modified "2026-02-19T08:26:13.534563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6501-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sediments are deposited when wind or waterways slow down or when glaciers melt."@en ;
  dcterms:modified "2026-02-19T08:26:13.534568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6501-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layers of sediment form over many years, leading to compaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.534573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6501-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentary rock forms when sediment is buried and compressed, and salts from fluids cement the grains together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6501-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strata can be used to create a relative timeline and provide clues to the environment when the sediments were deposited."""@en ;
  dcterms:modified "2026-02-19T08:26:13.534582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6651-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some lifestyle factors affect the risk of developing non-infectious diseases of the gas exchange and circulatory system."""@en ;
  dcterms:modified "2026-02-19T08:26:13.535077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6651-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eating an unbalanced diet and not getting enough exercise can increase the risk of developing lifestyle diseases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.535080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6651-3
  a curric:KeyLearningPoint ;
  rdfs:label """Smoking, drinking alcohol and using drugs can increase the risk of developing lifestyle diseases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.535084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6651-4
  a curric:KeyLearningPoint ;
  rdfs:label """To prevent lifestyle diseases people can exercise, eat a balanced diet, not smoke and avoid drinking alcohol."""@en ;
  dcterms:modified "2026-02-19T08:26:13.535088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5024-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ammeter measures current in amps (A)."@en ;
  dcterms:modified "2026-02-19T08:26:13.536588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5024-2
  a curric:KeyLearningPoint ;
  rdfs:label "Resistance is a measure of how difficult it is for a current to flow."@en ;
  dcterms:modified "2026-02-19T08:26:13.536591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5024-3
  a curric:KeyLearningPoint ;
  rdfs:label "Resistance is measured in ohms (Ω)."@en ;
  dcterms:modified "2026-02-19T08:26:13.536598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5024-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, only the independent variable is changed so that no other variables affect the results."""@en ;
  dcterms:modified "2026-02-19T08:26:13.536602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5024-5
  a curric:KeyLearningPoint ;
  rdfs:label "The variables that are deliberately kept the same are called control variables."@en ;
  dcterms:modified "2026-02-19T08:26:13.536606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4975-1
  a curric:KeyLearningPoint ;
  rdfs:label "A vibrating object causes nearby air particles to vibrate too."@en ;
  dcterms:modified "2026-02-19T08:26:13.537709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Air particles are knocked forwards but then spread backwards when the object moves back."""@en ;
  dcterms:modified "2026-02-19T08:26:13.537713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vibrating air particles knock into their neighbours and set them vibrating too, in the same way."""@en ;
  dcterms:modified "2026-02-19T08:26:13.537717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4975-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pattern of vibrating particles creates a sound wave. Sound does not involve air particles travelling."""@en ;
  dcterms:modified "2026-02-19T08:26:13.537721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4975-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific models often only accurately reflect some aspects of what they represent."""@en ;
  dcterms:modified "2026-02-19T08:26:13.537725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29465-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climate is the average weather conditions for a particular location over a long period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29465-2
  a curric:KeyLearningPoint ;
  rdfs:label """Emissions of greenhouse gases from human activities are causing global warming and climate change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29465-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change includes an increase in the frequency of extreme weather events such as droughts, storms and floods."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29465-4
  a curric:KeyLearningPoint ;
  rdfs:label """Data predict an increased frequency of extreme weather events with increasing global temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29465-5
  a curric:KeyLearningPoint ;
  rdfs:label """We all need to work together to reduce emissions of greenhouse gases to limit climate change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.539678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6657-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inhaling chemicals to become intoxicated is called solvent abuse."@en ;
  dcterms:modified "2026-02-19T08:26:13.541250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6657-2
  a curric:KeyLearningPoint ;
  rdfs:label "Common solvents are paint thinner, glue, and nitrous oxide."@en ;
  dcterms:modified "2026-02-19T08:26:13.541254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6657-3
  a curric:KeyLearningPoint ;
  rdfs:label "Solvents have many physical effects on the body."@en ;
  dcterms:modified "2026-02-19T08:26:13.541258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6657-4
  a curric:KeyLearningPoint ;
  rdfs:label "Solvent abuse has risks of long-term health problems and can lead to death."@en ;
  dcterms:modified "2026-02-19T08:26:13.541262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4250-1
  a curric:KeyLearningPoint ;
  rdfs:label "Streamlining reduces drag."@en ;
  dcterms:modified "2026-02-19T08:26:13.556091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Streamlining reduces how much a fluid needs to be pushed out of the way for an object to move through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4250-3
  a curric:KeyLearningPoint ;
  rdfs:label """The drag force on an object moving through a fluid (liquid or gas) increases with speed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.556099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4250-4
  a curric:KeyLearningPoint ;
  rdfs:label "Streamlining can increase the top speed of a vehicle."@en ;
  dcterms:modified "2026-02-19T08:26:13.556103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9104-1
  a curric:KeyLearningPoint ;
  rdfs:label "Not consuming a balanced diet can lead to ill health."@en ;
  dcterms:modified "2026-02-19T08:26:13.557529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9104-2
  a curric:KeyLearningPoint ;
  rdfs:label "Body mass index (BMI) is calculated from a person’s height and body mass."@en ;
  dcterms:modified "2026-02-19T08:26:13.557534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9104-3
  a curric:KeyLearningPoint ;
  rdfs:label "Consuming too much food can cause BMI to become too high, and lead to obesity."@en ;
  dcterms:modified "2026-02-19T08:26:13.557538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9104-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effects of obesity on the human body."@en ;
  dcterms:modified "2026-02-19T08:26:13.557542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9104-5
  a curric:KeyLearningPoint ;
  rdfs:label """Obesity can increase the risk of developing other health issues, including heart disease."""@en ;
  dcterms:modified "2026-02-19T08:26:13.557545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4110-1
  a curric:KeyLearningPoint ;
  rdfs:label "Contact forces only act when objects are touching."@en ;
  dcterms:modified "2026-02-19T08:26:13.557571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4110-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-contact forces can act with or without the objects touching."@en ;
  dcterms:modified "2026-02-19T08:26:13.557575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4110-3
  a curric:KeyLearningPoint ;
  rdfs:label "Friction is a contact force that slows or prevents movement."@en ;
  dcterms:modified "2026-02-19T08:26:13.557579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4110-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drag is a contact force that pushes against objects moving through liquids or gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.557583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5131-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of elements in each group of the periodic table change gradually down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5131-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 metals are soft, have lower densities than most other metals, and become more reactive down the group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5131-3
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 metals are called alkali metals because they react with water to form an alkaline solution and hydrogen gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5131-4
  a curric:KeyLearningPoint ;
  rdfs:label "Group 2 metals react with dilute acids to form a salt and hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.558033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5131-5
  a curric:KeyLearningPoint ;
  rdfs:label """Group 2 metals become more reactive down the group, but they are less reactive than Group 1 metals in the same period."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Friction is the force of one surface gripping or rubbing on another."@en ;
  dcterms:modified "2026-02-19T08:26:13.558488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Friction prevents or slows down movement between surfaces."@en ;
  dcterms:modified "2026-02-19T08:26:13.558492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Friction is caused by the roughness of surfaces."@en ;
  dcterms:modified "2026-02-19T08:26:13.558496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lubricants are substances added between two surfaces to reduce friction."@en ;
  dcterms:modified "2026-02-19T08:26:13.558500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4111-1
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are measured with a newton meter."@en ;
  dcterms:modified "2026-02-19T08:26:13.558504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4111-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are measure in newtons (N)."@en ;
  dcterms:modified "2026-02-19T08:26:13.558508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4111-3
  a curric:KeyLearningPoint ;
  rdfs:label "With no force, newton meters need to be adjusted to zero."@en ;
  dcterms:modified "2026-02-19T08:26:13.558514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4111-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton meters should be selected by considering the scale."@en ;
  dcterms:modified "2026-02-19T08:26:13.558518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4111-5
  a curric:KeyLearningPoint ;
  rdfs:label "Repeat readings help check for mistakes."@en ;
  dcterms:modified "2026-02-19T08:26:13.558522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9050-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lubricants are substances added between two surfaces to reduce the friction between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9050-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a fair test, only the variable we are testing is changed."@en ;
  dcterms:modified "2026-02-19T08:26:13.558942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9050-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, everything we are not testing is kept the same for every measurement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.558946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeat measurements help check for anomalous results."@en ;
  dcterms:modified "2026-02-19T08:26:13.558950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9050-5
  a curric:KeyLearningPoint ;
  rdfs:label "A mean combines repeat measurements  into a single result."@en ;
  dcterms:modified "2026-02-19T08:26:13.558954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4967-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Sun is a star, an extremely hot sphere of gas that emits light."@en ;
  dcterms:modified "2026-02-19T08:26:13.560161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4967-2
  a curric:KeyLearningPoint ;
  rdfs:label """The stars in the night sky are much smaller and dimmer than the Sun because they are much further away."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4967-3
  a curric:KeyLearningPoint ;
  rdfs:label """A light-year is the distance light travels in one year. This is large enough to be suitable for distances in space."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4967-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the universe, stars are found in groups called galaxies, with billions of stars in each one."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4967-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are billions of galaxies in the universe."@en ;
  dcterms:modified "2026-02-19T08:26:13.560179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6418-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pure material is made of only one type of substance"@en ;
  dcterms:modified "2026-02-19T08:26:13.560239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6418-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pure material has a fixed melting point and boiling point"@en ;
  dcterms:modified "2026-02-19T08:26:13.560243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Impurities change the melting and boiling point of a material"@en ;
  dcterms:modified "2026-02-19T08:26:13.560247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6418-4
  a curric:KeyLearningPoint ;
  rdfs:label "A mixture contains two or more types of substances which can be easily separated"@en ;
  dcterms:modified "2026-02-19T08:26:13.560251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6418-5
  a curric:KeyLearningPoint ;
  rdfs:label "Mixtures melt or boil over a range of temperatures"@en ;
  dcterms:modified "2026-02-19T08:26:13.560256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6423-1
  a curric:KeyLearningPoint ;
  rdfs:label """At a given temperature, there is a limit to how much solute can dissolve in a solvent."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6423-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solutes may become insoluble as a solution cools."@en ;
  dcterms:modified "2026-02-19T08:26:13.560280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6423-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lines of best fit can be used to predict unknowns values if one variable is known."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6423-4
  a curric:KeyLearningPoint ;
  rdfs:label """Data from multiple investigations can be plotted on the same graph for ease of comparison."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6424-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brownian motion is the random motion of particles suspended in a medium."@en ;
  dcterms:modified "2026-02-19T08:26:13.560294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6424-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of a substance released into a fluid (a gas or liquid) move around and are pushed by other particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6424-3
  a curric:KeyLearningPoint ;
  rdfs:label """Substances that have particles that are free to move will eventually reach a random distribution throughout."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6424-4
  a curric:KeyLearningPoint ;
  rdfs:label "At higher temperatures, particles in a gas or solution move more quickly."@en ;
  dcterms:modified "2026-02-19T08:26:13.560309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4976-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound spreads out and becomes quieter (lower amplitude vibrations) as it travels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4976-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sound travels through a medium by vibrations being passed on between the particles of the medium."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4976-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sound travels faster through liquids than gases as the particles are closer so vibrations can be passed on more easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4976-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound travels fastest through solids due to strong attractive forces between particles so many vibrate when one does."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4976-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves are caused by vibrations of particles so sound can't travel through a vacuum (where there are no particles)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6419-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solution is formed when a soluble solid dissolves in an appropriate solvent"@en ;
  dcterms:modified "2026-02-19T08:26:13.560355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6419-2
  a curric:KeyLearningPoint ;
  rdfs:label "In chemistry, mass is measured in grams (g)"@en ;
  dcterms:modified "2026-02-19T08:26:13.560359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6419-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of substances that are mixed adds together to give the total mass of the mixture (mass is conserved)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.560363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suspensions are not solutions, as solid particles can be seen, and eventually will settle over time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6420-2
  a curric:KeyLearningPoint ;
  rdfs:label """Forces of attraction between solute particles have to be overcome for something to dissolve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6420-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a mixture, one particle may fit into spaces between another type, making the total volume less than expected."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6420-4
  a curric:KeyLearningPoint ;
  rdfs:label "Not every substance can be dissolved (is soluble) in a solvent."@en ;
  dcterms:modified "2026-02-19T08:26:13.560382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6420-5
  a curric:KeyLearningPoint ;
  rdfs:label "Dissolving is not the same as melting, but both are physical processes."@en ;
  dcterms:modified "2026-02-19T08:26:13.560387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4974-1
  a curric:KeyLearningPoint ;
  rdfs:label """All sounds are caused by vibrations. Some vibrations are too small or too fast to see."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4974-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a sound means how loud or quiet it is. The pitch of a sound means how high or low it is."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4974-3
  a curric:KeyLearningPoint ;
  rdfs:label """Amplitude is a measure of the distance or size of a vibration. The greater the amplitude, the louder a sound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4974-4
  a curric:KeyLearningPoint ;
  rdfs:label """Frequency is a measure of how often the vibrations occur. The greater the frequency, the higher the pitch."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4974-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sounds of different volume and pitch can be produced by controlling the amplitude and frequency of vibrations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9794-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aspects of an investigation that can be changed and measured are known as variables"""@en ;
  dcterms:modified "2026-02-19T08:26:13.560411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9794-2
  a curric:KeyLearningPoint ;
  rdfs:label "The independent variable is what is changed in an investigation"@en ;
  dcterms:modified "2026-02-19T08:26:13.560415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9794-3
  a curric:KeyLearningPoint ;
  rdfs:label "The dependent variable is what is observed / measured in an investigation"@en ;
  dcterms:modified "2026-02-19T08:26:13.560419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9794-4
  a curric:KeyLearningPoint ;
  rdfs:label "Variables that are kept the same each time are called control variables"@en ;
  dcterms:modified "2026-02-19T08:26:13.560422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9794-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, only the variable being tested is changed so that it is clear that it made a difference to the results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.560426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4947-1
  a curric:KeyLearningPoint ;
  rdfs:label "The higher the temperature of a hot drink, the faster its particles are moving."@en ;
  dcterms:modified "2026-02-19T08:26:13.560510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4947-2
  a curric:KeyLearningPoint ;
  rdfs:label "A hot drink makes the particles in the air around it move more quickly."@en ;
  dcterms:modified "2026-02-19T08:26:13.560514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4947-3
  a curric:KeyLearningPoint ;
  rdfs:label """The particles of a hot drink begin to move less quickly as they transfer energy to the air particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4947-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the temperature difference between a hot drink and the air, the faster it cools down."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6443-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatography can be used for both separation of minute samples and analysis."@en ;
  dcterms:modified "2026-02-19T08:26:13.560849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6443-2
  a curric:KeyLearningPoint ;
  rdfs:label "A pure substance will only produce one spot on a chromatogram."@en ;
  dcterms:modified "2026-02-19T08:26:13.560853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6443-3
  a curric:KeyLearningPoint ;
  rdfs:label "A mixture will produce many spots on a chromatogram."@en ;
  dcterms:modified "2026-02-19T08:26:13.560859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6443-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing chromatograms can help to identify an unknown component in a sample."@en ;
  dcterms:modified "2026-02-19T08:26:13.560863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6443-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pencil is insoluble in water."@en ;
  dcterms:modified "2026-02-19T08:26:13.560867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6438-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magnets attract iron and steel"@en ;
  dcterms:modified "2026-02-19T08:26:13.560964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6438-2
  a curric:KeyLearningPoint ;
  rdfs:label """Insoluble solids can be separated from a liquid using a filter by a process known as filtration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.560968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6438-3
  a curric:KeyLearningPoint ;
  rdfs:label """Filter paper is folded to make a pocket that fits in a filter funnel for filtering fine particles"""@en ;
  dcterms:modified "2026-02-19T08:26:13.560971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6438-4
  a curric:KeyLearningPoint ;
  rdfs:label """A drop of water on a filter funnel helps keep the filter paper cone open for easy filtering"""@en ;
  dcterms:modified "2026-02-19T08:26:13.560975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9887-1
  a curric:KeyLearningPoint ;
  rdfs:label """Simple distillation is used to separate a mixture containing only two substances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9887-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation separates mixtures with 3+ substances, or substances with similar boiling points."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9887-3
  a curric:KeyLearningPoint ;
  rdfs:label """Slower heating during distillation allows for more controlled boiling of individual components."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9887-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the condenser warms up it becomes less effective and more gas will escape."@en ;
  dcterms:modified "2026-02-19T08:26:13.561066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Biological features are inherited when genetic material is passed from parents to their offspring during reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6621-2
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic material provides instructions for growth and other life processes."@en ;
  dcterms:modified "2026-02-19T08:26:13.561074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6621-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only features caused by instructions in the genetic material can be inherited."@en ;
  dcterms:modified "2026-02-19T08:26:13.561078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6621-4
  a curric:KeyLearningPoint ;
  rdfs:label "Features caused by lifestyle and the environment cannot be inherited."@en ;
  dcterms:modified "2026-02-19T08:26:13.561084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6621-5
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of features caused by genetic information (e.g. eye colour) and by the environment (e.g. scars)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6440-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of the substances in a mixture help to determine the technique best suited to separate them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6440-2
  a curric:KeyLearningPoint ;
  rdfs:label """When mixtures contain more than two components, multiple techniques may be needed to separate them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6440-3
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a solution of an existing mixture can allow a specific technique to be used for separation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6440-4
  a curric:KeyLearningPoint ;
  rdfs:label """Separating salt from rock salt requires: making a solution, filtration, and crystallisation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mixing hot water with cold water results in water cooler than the hot water and warmer than the cold."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4946-2
  a curric:KeyLearningPoint ;
  rdfs:label """When hot and cold water are mixed, the temperature is closer to that of the water there was more of."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4946-3
  a curric:KeyLearningPoint ;
  rdfs:label """A cold object placed in hot water makes the water particles move more slowly and those in the object move more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4946-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hot object placed in cold water makes the water particles move more quickly and those in the object move more slowly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4948-1
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature along a thermal conductor increases quickly when it is heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.561266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4948-2
  a curric:KeyLearningPoint ;
  rdfs:label """The temperature along a thermal insulator increases very slowly when it is heated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4948-3
  a curric:KeyLearningPoint ;
  rdfs:label """In thermal conductors, vibrating particles quickly cause the particles near to them to vibrate as well."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4948-4
  a curric:KeyLearningPoint ;
  rdfs:label """In thermal insulators, it is hard for vibrating particles to cause the particles near to them to vibrate as well."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4950-1
  a curric:KeyLearningPoint ;
  rdfs:label """The directions in which particles in a substance move are random. This is true of solids, liquids and gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4950-2
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the temperature, the faster the particles vibrate in a solid or move past each other in a liquid or gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4950-3
  a curric:KeyLearningPoint ;
  rdfs:label "Energy needs to be transferred to an object to raise its temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.561292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4950-4
  a curric:KeyLearningPoint ;
  rdfs:label "For two identical objects, the one at a higher temperature has more energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.561296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4950-5
  a curric:KeyLearningPoint ;
  rdfs:label """For two objects made of the same substance at the same temperature, the one with more particles has more energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6442-1
  a curric:KeyLearningPoint ;
  rdfs:label """A liquid can be separated from a solution by vaporising it and then quickly condensing it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6442-2
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation works due to one part of a solution having a different boiling point than the other part."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6442-3
  a curric:KeyLearningPoint ;
  rdfs:label "A condenser should be kept cold to speed up condensation."@en ;
  dcterms:modified "2026-02-19T08:26:13.561330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6442-4
  a curric:KeyLearningPoint ;
  rdfs:label "The liquid collected (distillate) is pure."@en ;
  dcterms:modified "2026-02-19T08:26:13.561334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6018-1
  a curric:KeyLearningPoint ;
  rdfs:label """All consumers, including humans, depend on producers because they make all of the food for the rest of the food chain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants produce edible seeds and fruits after pollination (transfer pollen from the anthers of flowers to the stigma)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6018-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many plants depend on animals such as insects to pollinate them, and on animals such as birds to disperse their seeds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6018-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because of food chains and pollination, producers and consumers are interdependent."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6018-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pollinators are important, ensuring there is food security for humans (having enough food to feed the human population)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria are living organisms; each bacterium is a microorganism made of a single living cell."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9101-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some bacteria are pathogens that cause diseases, but many bacteria are harmless and some are helpful."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9101-3
  a curric:KeyLearningPoint ;
  rdfs:label "Helpful bacteria live inside the human digestive system."@en ;
  dcterms:modified "2026-02-19T08:26:13.561476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9101-4
  a curric:KeyLearningPoint ;
  rdfs:label "They release enzymes that digest food we cannot digest ourselves."@en ;
  dcterms:modified "2026-02-19T08:26:13.561480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9101-5
  a curric:KeyLearningPoint ;
  rdfs:label """They also help to protect us against pathogens that enter the digestive system by competing against them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4944-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thermometers measure temperature in degrees Celsius (ºC)."@en ;
  dcterms:modified "2026-02-19T08:26:13.561691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4944-2
  a curric:KeyLearningPoint ;
  rdfs:label "Glass thermometers are fragile and need to be handled with care."@en ;
  dcterms:modified "2026-02-19T08:26:13.561695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4944-3
  a curric:KeyLearningPoint ;
  rdfs:label """To accurately read the scale on a glass thermometer, your eye needs to be level with the top of the coloured liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4944-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pure ice melts at 0ºC and pure water boils at 100ºC."@en ;
  dcterms:modified "2026-02-19T08:26:13.561703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4944-5
  a curric:KeyLearningPoint ;
  rdfs:label "If left for long enough, all objects in a room will reach the same temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.561706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4949-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particle vibrations are passed on more quickly between a hot object and conductor than a hot object and an insulator."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4949-2
  a curric:KeyLearningPoint ;
  rdfs:label """Materials that contain trapped air provide good insulation because gases are very poor thermal conductors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4949-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wrapping an object in an insulator keeps a hot object warm and a cold object cool."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4966-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational forces pull (attract) objects towards the centre of large objects like planets, moons and stars."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4966-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the mass of an object, the stronger its gravity."@en ;
  dcterms:modified "2026-02-19T08:26:13.561965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4966-3
  a curric:KeyLearningPoint ;
  rdfs:label """The gravity of a planet, moon or star extends far into space, but gets weaker with distance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4966-4
  a curric:KeyLearningPoint ;
  rdfs:label """Earth’s gravity pulls the Moon towards the centre of Earth, changing the Moon's direction, making it orbit around Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4966-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun's gravity pulls Earth towards the centre of the Sun, changing Earth's direction, making it orbit around the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.561977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9119-1
  a curric:KeyLearningPoint ;
  rdfs:label """All substances, including the cell cytoplasm and substances within it, are made up of particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9119-2
  a curric:KeyLearningPoint ;
  rdfs:label "These particles move in random directions and collide all the time."@en ;
  dcterms:modified "2026-02-19T08:26:13.562307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9119-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concentration is the number of particles in a volume of liquid or gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.562311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9119-4
  a curric:KeyLearningPoint ;
  rdfs:label "The net movement of particles is down a concentration gradient."@en ;
  dcterms:modified "2026-02-19T08:26:13.562316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Diffusion is the passive movement of particles of a substance from an area of higher to lower concentration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5110-1
  a curric:KeyLearningPoint ;
  rdfs:label "When it melts, a substance changes from the solid state to the liquid state."@en ;
  dcterms:modified "2026-02-19T08:26:13.562384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5110-2
  a curric:KeyLearningPoint ;
  rdfs:label "When it freezes, a substance changes from the liquid state to the solid state."@en ;
  dcterms:modified "2026-02-19T08:26:13.562388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5110-3
  a curric:KeyLearningPoint ;
  rdfs:label "At temperatures below its melting point, a substance is in its solid state."@en ;
  dcterms:modified "2026-02-19T08:26:13.562392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5110-4
  a curric:KeyLearningPoint ;
  rdfs:label "At temperatures above its freezing point, a substance is in its liquid state."@en ;
  dcterms:modified "2026-02-19T08:26:13.562419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5110-5
  a curric:KeyLearningPoint ;
  rdfs:label """The melting point and freezing point of a pure substance are the same temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5167-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrates, proteins and fats in food are broken down by digestion into smaller molecules that can be absorbed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5167-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nutrients are absorbed into the blood, which transports them around the body to where they are needed by cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5167-3
  a curric:KeyLearningPoint ;
  rdfs:label """The molecules of some nutrients are small enough to be absorbed into the blood by diffusion."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5167-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptations of the small intestine lining that increase the amount of absorption."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4965-1
  a curric:KeyLearningPoint ;
  rdfs:label "A star is an extremely large sphere of hot gas that gives out light."@en ;
  dcterms:modified "2026-02-19T08:26:13.562821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4965-2
  a curric:KeyLearningPoint ;
  rdfs:label "A planet is a very large sphere of rock or gas that orbits a star."@en ;
  dcterms:modified "2026-02-19T08:26:13.562824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4965-3
  a curric:KeyLearningPoint ;
  rdfs:label """Our solar system includes the Sun (a star) and all the objects that orbit the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Orbiting the Sun are: 8 planets (many of which have moons), dwarf planets and smaller objects such as asteroids."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4965-5
  a curric:KeyLearningPoint ;
  rdfs:label """Distances between objects in our solar system are very, very large compared to the sizes of the objects."""@en ;
  dcterms:modified "2026-02-19T08:26:13.562837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4970-1
  a curric:KeyLearningPoint ;
  rdfs:label """In summer there are more daylight hours, compared to winter, the Sun appears higher in the sky and it is warmer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4970-2
  a curric:KeyLearningPoint ;
  rdfs:label """When it is summer in northern hemisphere countries it is winter in southern hemisphere countries."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4970-3
  a curric:KeyLearningPoint ;
  rdfs:label "Earth spins on an axis that is tilted at an angle of 23.5 degrees."@en ;
  dcterms:modified "2026-02-19T08:26:13.563178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4970-4
  a curric:KeyLearningPoint ;
  rdfs:label "In June, the northern hemisphere is tilted towards the Sun, so has summer."@en ;
  dcterms:modified "2026-02-19T08:26:13.563182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4970-5
  a curric:KeyLearningPoint ;
  rdfs:label "In June, the southern hemisphere is tilted away from the Sun, so has winter."@en ;
  dcterms:modified "2026-02-19T08:26:13.563186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5164-1
  a curric:KeyLearningPoint ;
  rdfs:label """Major organs of the human digestive system and the order in which food moves through them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5164-2
  a curric:KeyLearningPoint ;
  rdfs:label """The functions of the organs, tissues and glands of the digestive system and how they are adapted to break down food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.563250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5164-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food that cannot be digested is passed out of the body as faeces."@en ;
  dcterms:modified "2026-02-19T08:26:13.563254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9120-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of a liquid can move through a material by diffusion if the material is permeable."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9120-2
  a curric:KeyLearningPoint ;
  rdfs:label "Observe a liquid diffusing into a jelly cube."@en ;
  dcterms:modified "2026-02-19T08:26:13.564276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9120-3
  a curric:KeyLearningPoint ;
  rdfs:label """Predict and observe effect of temperature on the diffusion of a liquid into a jelly cube."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9120-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predict and observe effect of cube size on the diffusion of a liquid into a jelly cube."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9120-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use ideas about particles and diffusion to explain these observations."@en ;
  dcterms:modified "2026-02-19T08:26:13.564288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5111-1
  a curric:KeyLearningPoint ;
  rdfs:label "States of matter can have differing amounts of energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.564389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5111-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solid states have the least energy, gas states have the most energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.564393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5111-3
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in its liquid state can evaporate at temperatures below its boiling point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5111-4
  a curric:KeyLearningPoint ;
  rdfs:label "The hotter the water, the more quickly it evaporates."@en ;
  dcterms:modified "2026-02-19T08:26:13.564401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5111-5
  a curric:KeyLearningPoint ;
  rdfs:label "Water evaporates at temperatures that are lower than 100℃."@en ;
  dcterms:modified "2026-02-19T08:26:13.564405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4981-1
  a curric:KeyLearningPoint ;
  rdfs:label "Luminous objects give out light, non–luminous objects do not."@en ;
  dcterms:modified "2026-02-19T08:26:13.564514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4981-2
  a curric:KeyLearningPoint ;
  rdfs:label """All surfaces reflect light. Mirror–like surfaces reflect light in a regular way, other surfaces scatter light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4981-3
  a curric:KeyLearningPoint ;
  rdfs:label """For anything to be seen, light from it (either emitted or reflected) must enter the eye."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light enters the eye through a hole (the pupil) and is detected by the light–sensitive back surface (the retina)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4981-5
  a curric:KeyLearningPoint ;
  rdfs:label """Beams of light can only be seen if the light hits something and reflects (or scatters) towards an eye."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5181-1
  a curric:KeyLearningPoint ;
  rdfs:label "Aerobic cellular respiration requires oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.564536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5181-2
  a curric:KeyLearningPoint ;
  rdfs:label """The reactants and products of aerobic cellular respiration can be summarised using a word equation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5181-3
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the mitochondria and cytoplasm of animal, plant and fungi cells."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5181-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cells that require more energy, because they do a lot of work, have more mitochondria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28957-1
  a curric:KeyLearningPoint ;
  rdfs:label """Waste is often sent to incinerators or landfill sites, which are sources of greenhouse gases."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28957-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reuse, reduce, recycle is what we can do to minimise waste."@en ;
  dcterms:modified "2026-02-19T08:26:13.564559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28957-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable use of resources helps ensure that they are available for future generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28956-1
  a curric:KeyLearningPoint ;
  rdfs:label """Producing food for humans and other animals uses resources and releases greenhouse gases that lead to climate change."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28956-2
  a curric:KeyLearningPoint ;
  rdfs:label """Land-use change, farming, processing, transport, retail and packaging all add to the carbon footprint of food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28956-3
  a curric:KeyLearningPoint ;
  rdfs:label "Meat and plant-based products have different carbon footprints."@en ;
  dcterms:modified "2026-02-19T08:26:13.564621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28956-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food production is more sustainable when it has a smaller, negative impact on the environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28956-5
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in diet and a reduction in food waste can help us eat more sustainably by lowering greenhouse gas emissions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28954-1
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable resources do not run out because they are replenished faster than they are used up."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28954-2
  a curric:KeyLearningPoint ;
  rdfs:label """A resource is sustrainable it is maintained a certain level for as long as it is needed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.564809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28954-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some resources, such as wood, are only renewable if they are used sustainably."@en ;
  dcterms:modified "2026-02-19T08:26:13.564813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28954-4
  a curric:KeyLearningPoint ;
  rdfs:label "We cannot have sustainable transport that uses petrol or diesel fuel."@en ;
  dcterms:modified "2026-02-19T08:26:13.564819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28954-5
  a curric:KeyLearningPoint ;
  rdfs:label "Altering the design of a building can make it more sustainable."@en ;
  dcterms:modified "2026-02-19T08:26:13.564823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4979-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light travelling in one direction (along a ray) that hits a mirror reflects (bounces off the mirror) in one direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4979-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ‘normal’ is an imaginary line drawn at 90° to the point of reflection."@en ;
  dcterms:modified "2026-02-19T08:26:13.565137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4979-3
  a curric:KeyLearningPoint ;
  rdfs:label "The angles of incidence and reflection are measured to the normal."@en ;
  dcterms:modified "2026-02-19T08:26:13.565141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4979-4
  a curric:KeyLearningPoint ;
  rdfs:label """The angle of reflection is always equal to the angle of incidence, the other side of the normal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4979-5
  a curric:KeyLearningPoint ;
  rdfs:label """On a graph, a line of best fit highlights the main pattern of the data, ignoring small errors."""@en ;
  dcterms:modified "2026-02-19T08:26:13.565153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4964-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earth is a planet. It is a sphere that spins once every 24 hours."@en ;
  dcterms:modified "2026-02-19T08:26:13.566469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Earth's spin explains day and night."@en ;
  dcterms:modified "2026-02-19T08:26:13.566473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4964-3
  a curric:KeyLearningPoint ;
  rdfs:label "Earth orbits the Sun, with each orbit taking 365.25 days (1 year)."@en ;
  dcterms:modified "2026-02-19T08:26:13.566477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4964-4
  a curric:KeyLearningPoint ;
  rdfs:label "Earth orbits the Sun in an almost perfect circle."@en ;
  dcterms:modified "2026-02-19T08:26:13.566481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4964-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Moon orbits the Earth about once per month (27.3 days), this explains why the Moon appears to change shape."""@en ;
  dcterms:modified "2026-02-19T08:26:13.566485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5162-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bones meet at joints."@en ;
  dcterms:modified "2026-02-19T08:26:13.567318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5162-2
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles can move bones."@en ;
  dcterms:modified "2026-02-19T08:26:13.567322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5162-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles can only pull, by contracting, and cannot push."@en ;
  dcterms:modified "2026-02-19T08:26:13.567326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5162-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some muscles work together in antagonistic pairs to move bones at a joint."@en ;
  dcterms:modified "2026-02-19T08:26:13.567330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light reflects from mirrors obeying the laws of reflection. Some reflects into our eyes causing an image to be  seen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4980-2
  a curric:KeyLearningPoint ;
  rdfs:label "The image in a mirror is located where the light rays seem to have come from."@en ;
  dcterms:modified "2026-02-19T08:26:13.569239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4980-3
  a curric:KeyLearningPoint ;
  rdfs:label """A reflection appears to be directly opposite the object, the same distance behind the mirror as the object is in front."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4980-4
  a curric:KeyLearningPoint ;
  rdfs:label "The image in a mirror is the right way up but is laterally inverted."@en ;
  dcterms:modified "2026-02-19T08:26:13.569247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4254-1
  a curric:KeyLearningPoint ;
  rdfs:label "The mass of an object is measured in kilograms."@en ;
  dcterms:modified "2026-02-19T08:26:13.569311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4254-2
  a curric:KeyLearningPoint ;
  rdfs:label "A force of about 10 N is needed to lift 1 kg on Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.569315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4254-3
  a curric:KeyLearningPoint ;
  rdfs:label "On Earth, a 1 kg mass pushes down on a surface with a force of about 10 N."@en ;
  dcterms:modified "2026-02-19T08:26:13.569319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4254-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are 1000 g in 1 kg."@en ;
  dcterms:modified "2026-02-19T08:26:13.569323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4254-5
  a curric:KeyLearningPoint ;
  rdfs:label "Gravitational force, W = m × g"@en ;
  dcterms:modified "2026-02-19T08:26:13.569327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4113-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two forces of equal size, acting in opposite directions on an object, are balanced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4113-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant force is the sum of the forces acting on the object, taking into account their direction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4113-3
  a curric:KeyLearningPoint ;
  rdfs:label "When forces are balanced there is no resultant force and no change in speed."@en ;
  dcterms:modified "2026-02-19T08:26:13.569938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4113-4
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two forces acting in opposite directions, the resultant force acts in the direction of the bigger force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4113-5
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the resultant force on a given object, the greater or faster the change in speed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.569946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28953-1
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature data show an unusual, rapid increase in the Earth's average surface temperature over the last century or so."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28953-2
  a curric:KeyLearningPoint ;
  rdfs:label "This recent increase in average surface temperature is called global warming."@en ;
  dcterms:modified "2026-02-19T08:26:13.570344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28953-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a correlation between data showing increasing temperature and data showing increasing greenhouse gas emissions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28953-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most scientists agree that emissions from human activities are increasing the greenhouse effect, causing global warming."""@en ;
  dcterms:modified "2026-02-19T08:26:13.570352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4112-1
  a curric:KeyLearningPoint ;
  rdfs:label "Force arrows show the direction of a force."@en ;
  dcterms:modified "2026-02-19T08:26:13.570541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4112-2
  a curric:KeyLearningPoint ;
  rdfs:label "The length of a force arrow shows the size of a force."@en ;
  dcterms:modified "2026-02-19T08:26:13.570545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4112-3
  a curric:KeyLearningPoint ;
  rdfs:label "A force arrow is drawn starting from a point that shows where the force acts."@en ;
  dcterms:modified "2026-02-19T08:26:13.570551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4112-4
  a curric:KeyLearningPoint ;
  rdfs:label "Force arrows are best labelled as the force acting on (object A) by (object B)."@en ;
  dcterms:modified "2026-02-19T08:26:13.570555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9134-1
  a curric:KeyLearningPoint ;
  rdfs:label "A community of organisms is made up of interacting populations of species."@en ;
  dcterms:modified "2026-02-19T08:26:13.571316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9134-2
  a curric:KeyLearningPoint ;
  rdfs:label """A food web diagram represents several interconnected food chains within a community of organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9134-3
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the size of a population will affect other populations in the food web."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4977-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound reflects from hard surfaces. An echo is when a sound is heard again after reflecting and travelling back."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4977-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smooth, flat surfaces help to produce echoes. Irregular surfaces reflect sound in many directions, spreading it out."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4977-3
  a curric:KeyLearningPoint ;
  rdfs:label """The particles of harder materials are held together by stronger forces so sound waves can’t make them vibrate much."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4977-4
  a curric:KeyLearningPoint ;
  rdfs:label """Soft surfaces absorb a lot of sound because sound waves transfer energy by making the particles in them vibrate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4977-5
  a curric:KeyLearningPoint ;
  rdfs:label """Noise (unwanted sound) can be reduced by using soft materials to absorb it or hard materials to reflect it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6461-1
  a curric:KeyLearningPoint ;
  rdfs:label """Earth is a spherical, rocky planet with a thin crust, partially covered in water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6461-2
  a curric:KeyLearningPoint ;
  rdfs:label "Under Earth’s crust is a dense rocky layer, called the mantle."@en ;
  dcterms:modified "2026-02-19T08:26:13.571920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6461-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the centre of Earth is a solid metallic core surrounded by a liquid outer core."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6461-4
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature and pressure increases towards the centre of Earth, making the inner core extremely hot and solid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6461-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use models to better understand phenomena, including Earth's structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent variable (amount of exercise) and dependent variable (heart rate or breathing rate)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6636-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying control variables (the person and the length of time spent exercising)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6636-3
  a curric:KeyLearningPoint ;
  rdfs:label """The independent variable (amount of exercise) is categoric data and goes on the x-axis of a bar chart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6636-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dependent variable (heart rate or breathing rate) goes on the y-axis of a bar chart."""@en ;
  dcterms:modified "2026-02-19T08:26:13.571951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6636-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using knowledge of cellular respiration to explain the results."@en ;
  dcterms:modified "2026-02-19T08:26:13.571956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4837-1
  a curric:KeyLearningPoint ;
  rdfs:label "All organisms are made up of living building blocks called cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.572029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are usually too small to see with the unaided eye."@en ;
  dcterms:modified "2026-02-19T08:26:13.572033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4837-3
  a curric:KeyLearningPoint ;
  rdfs:label """The cells that make up tissue on a slide can be observed using a light microscope."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4837-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the magnification and focus of a light microscope enables cell structures to be observed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.572041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4971-1
  a curric:KeyLearningPoint ;
  rdfs:label """The seasons change because of Earth’s tilted axis, which does not change direction as Earth orbits the Sun."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4971-2
  a curric:KeyLearningPoint ;
  rdfs:label """In June, the northern hemisphere is tilted towards the Sun so has summer, and the southern hemisphere has winter."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4971-3
  a curric:KeyLearningPoint ;
  rdfs:label """In December, the northern hemisphere is tilted away from the Sun so has winter, and the southern hemisphere has summer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4971-4
  a curric:KeyLearningPoint ;
  rdfs:label """The seasons that occur at a place on Earth can be explained by the different angles made to the sun's rays over a year."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4971-5
  a curric:KeyLearningPoint ;
  rdfs:label """Countries near the Equator do not experience summers and winters as they stay close to ‘face-on’ to the Sun all year."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5178-1
  a curric:KeyLearningPoint ;
  rdfs:label "The structures and functions of the gas exchange system in humans."@en ;
  dcterms:modified "2026-02-19T08:26:13.574708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5178-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mechanism of breathing, including the role of muscles, to move air in and out of the lungs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5178-3
  a curric:KeyLearningPoint ;
  rdfs:label "A pressure model to explain the movement of gases during breathing."@en ;
  dcterms:modified "2026-02-19T08:26:13.574716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6015-1
  a curric:KeyLearningPoint ;
  rdfs:label "Predators are hunters and prey are hunted."@en ;
  dcterms:modified "2026-02-19T08:26:13.574722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6015-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different factors can affect the population sizes of predators and prey (e.g. disease)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6015-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a relationship between the predator and prey population sizes, each is impacted by changes in the other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4260-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure is a measure of how concentrated a force is."@en ;
  dcterms:modified "2026-02-19T08:26:13.574735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4260-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure = force ÷ area."@en ;
  dcterms:modified "2026-02-19T08:26:13.574739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4260-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure is measured in newtons per square metre or per square centimetre."@en ;
  dcterms:modified "2026-02-19T08:26:13.574743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4260-4
  a curric:KeyLearningPoint ;
  rdfs:label "Another name for newtons per square metre is the pascal (Pa)."@en ;
  dcterms:modified "2026-02-19T08:26:13.574763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5004-1
  a curric:KeyLearningPoint ;
  rdfs:label "All magnets have a north–seeking pole and a south–seeking pole."@en ;
  dcterms:modified "2026-02-19T08:26:13.574769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5004-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike magnetic poles attract each other, and similar magnetic poles repel each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5004-3
  a curric:KeyLearningPoint ;
  rdfs:label """Magnetic materials are attracted to both north–seeking and south–seeking magnetic poles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5004-4
  a curric:KeyLearningPoint ;
  rdfs:label """Just three metal elements (iron, cobalt and nickel) are magnetic; other metal and non–metal elements are not magnetic."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5004-5
  a curric:KeyLearningPoint ;
  rdfs:label """A north–seeking pole will point towards the North Pole because Earth has a magnetic field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.574785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4109-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion of faster objects is harder to stop."@en ;
  dcterms:modified "2026-02-19T08:26:13.575340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4109-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion of heavier objects is harder to stop."@en ;
  dcterms:modified "2026-02-19T08:26:13.575344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Objects with a greater mass need a greater force to start or stop it moving, and to change the direction of motion."""@en ;
  dcterms:modified "2026-02-19T08:26:13.575348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4109-4
  a curric:KeyLearningPoint ;
  rdfs:label "A force is a push or a pull."@en ;
  dcterms:modified "2026-02-19T08:26:13.575352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4109-5
  a curric:KeyLearningPoint ;
  rdfs:label "A force is needed to change the motion or shape of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.575356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4244-1
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the speed of an object, the shorter the time it takes to cover a certain distance."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4244-2
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the speed of an object, the more distance it travels in a certain time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4244-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speed = distance ÷ time."@en ;
  dcterms:modified "2026-02-19T08:26:13.576181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4244-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed is measured in m/s or km/h or miles/h."@en ;
  dcterms:modified "2026-02-19T08:26:13.576185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4244-5
  a curric:KeyLearningPoint ;
  rdfs:label "m/s is the number of metres travelled each second."@en ;
  dcterms:modified "2026-02-19T08:26:13.576189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4246-1
  a curric:KeyLearningPoint ;
  rdfs:label "The labels on a graph describe what it shows."@en ;
  dcterms:modified "2026-02-19T08:26:13.576356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4246-2
  a curric:KeyLearningPoint ;
  rdfs:label "The numbers on the scale of a graph go up in equal amounts."@en ;
  dcterms:modified "2026-02-19T08:26:13.576360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4246-3
  a curric:KeyLearningPoint ;
  rdfs:label """The value of each small division is the value of a large division divided by the number of small divisions it contains."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4246-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each point on a distance-time graph describes where an object is at a point in time (not its speed)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4246-5
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of an object can be found from distance and time information read from a distance-time graph."""@en ;
  dcterms:modified "2026-02-19T08:26:13.576372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5180-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration is a chemical process that uses glucose, from food, as a fuel to provide energy for life processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5180-2
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of life processes that require energy from cellular respiration."@en ;
  dcterms:modified "2026-02-19T08:26:13.577019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5180-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration happens in all living organisms all the time to provide the energy to keep them alive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5180-4
  a curric:KeyLearningPoint ;
  rdfs:label "Differences between breathing and respiration."@en ;
  dcterms:modified "2026-02-19T08:26:13.577027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6031-1
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity is important to maintain healthy habitats."@en ;
  dcterms:modified "2026-02-19T08:26:13.577115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6031-2
  a curric:KeyLearningPoint ;
  rdfs:label "A gene pool is the range of DNA in a species."@en ;
  dcterms:modified "2026-02-19T08:26:13.577121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6031-3
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity can be maintained by conservation, protection and gene banks."@en ;
  dcterms:modified "2026-02-19T08:26:13.577125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sampling is used to obtain estimates of populations within an area because it would be impossible to count them all."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6029-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are lots of different sampling methods that can be used to sample plants and animals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6029-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling is essential for conservation to monitor populations and compare them."@en ;
  dcterms:modified "2026-02-19T08:26:13.577137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6454-1
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of the products in a chemical reaction is the same as the mass of the reactants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6454-2
  a curric:KeyLearningPoint ;
  rdfs:label "Word equations are a simple way of describing chemical reactions."@en ;
  dcterms:modified "2026-02-19T08:26:13.577536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6454-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical formulae represent the numbers of each type of atoms in a reactant or product."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6454-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations represent how the atoms in the reactants rearrange to form the products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6454-5
  a curric:KeyLearningPoint ;
  rdfs:label "The arrow in a chemical equation represents the words ‘changes into’."@en ;
  dcterms:modified "2026-02-19T08:26:13.577548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6434-1
  a curric:KeyLearningPoint ;
  rdfs:label """The name of a simple metal–non-metal compound ends '-ide' to indicate bonding has occurred."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6434-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some common groups of compounds are metal carbonates, metal sulfates and metal nitrates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6434-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compounds of metal atoms bonded to -CO₃ are called metal carbonates."@en ;
  dcterms:modified "2026-02-19T08:26:13.577583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6434-4
  a curric:KeyLearningPoint ;
  rdfs:label "Compounds of metal atoms bonded to -SO₄ are called metal sulfates."@en ;
  dcterms:modified "2026-02-19T08:26:13.577588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6434-5
  a curric:KeyLearningPoint ;
  rdfs:label "Compounds of metal atoms bonded to -NO₃ are called metal nitrates."@en ;
  dcterms:modified "2026-02-19T08:26:13.577592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6431-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many non-metals are in the gas state at room temperature."@en ;
  dcterms:modified "2026-02-19T08:26:13.577981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6431-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some non-metals form diatomic molecules that contain two atoms (e.g. O₂, N₂, H₂, Cl₂)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6431-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some non-metals are monatomic and do not form molecules."@en ;
  dcterms:modified "2026-02-19T08:26:13.577991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6431-4
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases are monatomic and are listed in the right-hand column of the periodic table."""@en ;
  dcterms:modified "2026-02-19T08:26:13.577998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6635-1
  a curric:KeyLearningPoint ;
  rdfs:label "Exercise is activity requiring physical effort."@en ;
  dcterms:modified "2026-02-19T08:26:13.578002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6635-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular exercise is beneficial for good physical and mental health."@en ;
  dcterms:modified "2026-02-19T08:26:13.578006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6635-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exercising causes increases in breathing rate and heart rate as cells need more oxygen for cellular respiration."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6667-1
  a curric:KeyLearningPoint ;
  rdfs:label "Experimental data can be analysed by plotting data on a line graph or bar chart."@en ;
  dcterms:modified "2026-02-19T08:26:13.578014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Line graphs are used where the independent variable is continuous; bar charts are used where it is categoric."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6667-3
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing a bar chart and/or line graph follows a set format."@en ;
  dcterms:modified "2026-02-19T08:26:13.578022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6667-4
  a curric:KeyLearningPoint ;
  rdfs:label """A line of best fit on a line graph indicates the trend (relationship between in the independent and dependent variable)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection can cause the common characteristics of a species to change (evolve) over generations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6053-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists explain evolution using the theory of evolution by natural selection."@en ;
  dcterms:modified "2026-02-19T08:26:13.578419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6053-3
  a curric:KeyLearningPoint ;
  rdfs:label """A scientific theory is a general explanation, developed from evidence, that explains many different examples."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6053-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evolution is not planned in advance; new advantageous features appear randomly and are maintained by natural selection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6053-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in the features of an individual within its lifetime are not evolution."@en ;
  dcterms:modified "2026-02-19T08:26:13.578433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4245-1
  a curric:KeyLearningPoint ;
  rdfs:label "A ramp will produce a force that allows a dynamics trolley to roll down it."@en ;
  dcterms:modified "2026-02-19T08:26:13.578590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4245-2
  a curric:KeyLearningPoint ;
  rdfs:label """The average speed of the trolley can be found from distance and time measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4245-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting down ‘3, 2, 1, go’ helps start a stopwatch at the right moment."@en ;
  dcterms:modified "2026-02-19T08:26:13.578600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observing with eyes in line with the finish line helps stop a stopwatch at the right moment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.578605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6666-1
  a curric:KeyLearningPoint ;
  rdfs:label "Seeds are dispersed by different mechanisms to increase the chance of survival."@en ;
  dcterms:modified "2026-02-19T08:26:13.580149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6666-2
  a curric:KeyLearningPoint ;
  rdfs:label """Seeds are adapted to match the mechanism for dispersal; e.g. wind dispersed are light with a large surface area."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Variables are factors that affect the process being investigated, the dependant variable is distance the seed travels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6666-4
  a curric:KeyLearningPoint ;
  rdfs:label """Practical investigation of how far model seeds disperse with changes to their template."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6666-5
  a curric:KeyLearningPoint ;
  rdfs:label """Repeat measurements for each value to identify anomalous results and calculate a mean."""@en ;
  dcterms:modified "2026-02-19T08:26:13.580170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Heating a surface from directly overhead is more effective than heating a surface at a different angle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4969-2
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light hit a surface face-on, they are less spread out than if they hit at an angle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4969-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a place on Earth, the heating effect of the Sun is greatest at midday and lowest at sunrise and sunset."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Over a day, Earth's spin changes the Sun's height in the sky and the angle at which the Sun's rays arrive at a place."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8309-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with acid to produce a metal salt and hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.581658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8309-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with water to produce a metal hydroxide and hydrogen gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.581663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8309-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with oxygen to form a metal oxide."@en ;
  dcterms:modified "2026-02-19T08:26:13.581667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8309-4
  a curric:KeyLearningPoint ;
  rdfs:label """The reactivity series for metals shows how vigorously metals react, compared to each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8309-5
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the position of a metal in the reactivity series, the more vigorously it is likely to react."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precipitation reactions occur when two solutions combine to form an insoluble solid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20334-2
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance of a precipitate is evidence that a chemical reaction has occurred."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20334-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precipitation reactions are important in water treatment, to remove unwanted substances from water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20334-4
  a curric:KeyLearningPoint ;
  rdfs:label """Precipitation reactions are used in qualitative analysis, to identify the presence of certain substances in a solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.581946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20335-1
  a curric:KeyLearningPoint ;
  rdfs:label """Decomposition reactions involve a single compound breaking down into two or more products."""@en ;
  dcterms:modified "2026-02-19T08:26:13.582344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20335-2
  a curric:KeyLearningPoint ;
  rdfs:label "Decomposition reactions usually require heat, light, or electricity, to occur."@en ;
  dcterms:modified "2026-02-19T08:26:13.582350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20335-3
  a curric:KeyLearningPoint ;
  rdfs:label """When metal carbonates decompose upon heating, they typically form metal oxides and carbon dioxide gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.582354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5104-1
  a curric:KeyLearningPoint ;
  rdfs:label "A substance may have a solid, liquid and gas state"@en ;
  dcterms:modified "2026-02-19T08:26:13.582740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5104-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the solid state a substance has a fixed shape, it does not flow and cannot be compressed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.582744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5104-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the liquid state a substance can flow, it fills the shape of its container and cannot be compressed"""@en ;
  dcterms:modified "2026-02-19T08:26:13.582747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5104-4
  a curric:KeyLearningPoint ;
  rdfs:label "All substances are made of particles that are too small to see"@en ;
  dcterms:modified "2026-02-19T08:26:13.582753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5182-1
  a curric:KeyLearningPoint ;
  rdfs:label "Anaerobic cellular respiration takes place without using oxygen."@en ;
  dcterms:modified "2026-02-19T08:26:13.583134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5182-2
  a curric:KeyLearningPoint ;
  rdfs:label """In humans, anaerobic cellular respiration produces lactic acid, which can cause muscle cramps."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5182-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word summaries of the reactants and products of aerobic and anaerobic cellular respiration in humans."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5182-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cytoplasm of cells and does not involve the mitochondria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5182-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration provides less energy than aerobic cellular respiration, but provides energy more quickly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6453-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combustion requires fuel, heat and oxygen, and will not happen without one of them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6453-2
  a curric:KeyLearningPoint ;
  rdfs:label "When a substance reacts to combine with oxygen, this is called oxidation."@en ;
  dcterms:modified "2026-02-19T08:26:13.583219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6453-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of oxidation are combustion and rusting."@en ;
  dcterms:modified "2026-02-19T08:26:13.583223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6453-4
  a curric:KeyLearningPoint ;
  rdfs:label """One of the products of oxidation is always an oxide, but the other products vary."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The heavy base of a Bunsen burner does not get hot"@en ;
  dcterms:modified "2026-02-19T08:26:13.583486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5107-2
  a curric:KeyLearningPoint ;
  rdfs:label """Opening the air hole on a Bunsen burner changes the flame from orange and sooty to a hotter, cleaner, blue flame."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjusting the gas tap controls the size of the Bunsen burner flame."@en ;
  dcterms:modified "2026-02-19T08:26:13.583498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5107-4
  a curric:KeyLearningPoint ;
  rdfs:label """A splint used to light a Bunsen burner should be lit from the nearest Bunsen burner that is already lit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5107-5
  a curric:KeyLearningPoint ;
  rdfs:label """A lit splint should be carried with the flame angled slightly downwards and shielded by the other hand."""@en ;
  dcterms:modified "2026-02-19T08:26:13.583506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4248-1
  a curric:KeyLearningPoint ;
  rdfs:label "A resultant force can change the speed of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.584611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4248-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of an object changes throughout the time a resultant force is acting on it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4248-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the gradient (steeper the line) on a distance-time graph, the faster the movement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6027-1
  a curric:KeyLearningPoint ;
  rdfs:label "Biodiversity is a measure of the range of living organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.584644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6027-2
  a curric:KeyLearningPoint ;
  rdfs:label """Living organisms, including plants, have adaptations that help them to survive in their environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6027-3
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of physical plant adaptations include shallow or deep roots, and the presence of spines to deter consumers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.584653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6027-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can also have behavioural adaptations such as growing towards light."@en ;
  dcterms:modified "2026-02-19T08:26:13.584657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6027-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changes to the environment can affect plant biodiversity."@en ;
  dcterms:modified "2026-02-19T08:26:13.584661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9795-1
  a curric:KeyLearningPoint ;
  rdfs:label """A method provides step-by-step instructions for how to carry out an investigation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9795-2
  a curric:KeyLearningPoint ;
  rdfs:label """Methods should include how equipment is used and specific amounts of substances used."""@en ;
  dcterms:modified "2026-02-19T08:26:13.586539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9795-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methods should be written so that they are both repeatable and reproducible."@en ;
  dcterms:modified "2026-02-19T08:26:13.586543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9795-4
  a curric:KeyLearningPoint ;
  rdfs:label "Methods are written concisely, using clear language and command words."@en ;
  dcterms:modified "2026-02-19T08:26:13.586547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6429-1
  a curric:KeyLearningPoint ;
  rdfs:label "Elements are chemically pure, but can react together."@en ;
  dcterms:modified "2026-02-19T08:26:13.586961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6429-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each element has a fixed melting point and boiling point."@en ;
  dcterms:modified "2026-02-19T08:26:13.586965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6429-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each element has particular physical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.586969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6429-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each element has particular chemical properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.586975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6429-5
  a curric:KeyLearningPoint ;
  rdfs:label "The properties of elements are different from those of a single atom."@en ;
  dcterms:modified "2026-02-19T08:26:13.586979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9122-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of some substances are small enough to diffuse through holes in a selectively-permeable membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9122-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of these substances move through the selectively-permeable membrane in both directions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9122-3
  a curric:KeyLearningPoint ;
  rdfs:label """Predict the direction of net movement of particles through a selectively-permeable membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9122-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observe the direction of net movement of a substance through a selectively-permeable membrane (e.g. Visking tubing)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9122-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explain observations of the diffusion of a substance through a selectively-permeable membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9121-1
  a curric:KeyLearningPoint ;
  rdfs:label """All substances, including the cell cytoplasm and substances within it, are made up of particles."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9121-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of some substances diffuse into and out of a cell by moving through small holes in the cell membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9121-3
  a curric:KeyLearningPoint ;
  rdfs:label """The particles that make up some substances are too big to diffuse through the holes in the cell membrane."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9121-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cell membrane is selectively-permeable because only some substances can diffuse through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9121-5
  a curric:KeyLearningPoint ;
  rdfs:label """The net movement of particles through a cell membrane is down a concentration gradient."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6421-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists transfer data to graphs in order to find any trends in the collected data."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6421-2
  a curric:KeyLearningPoint ;
  rdfs:label "The type of data collected affects the type of graph used to present it."@en ;
  dcterms:modified "2026-02-19T08:26:13.587955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6421-3
  a curric:KeyLearningPoint ;
  rdfs:label """A line of best fit can help to identify and describe relationships between variables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6421-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conclusions refer to both the independent and dependent variables when describing the data collected."""@en ;
  dcterms:modified "2026-02-19T08:26:13.587965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6025-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food chains show the feeding relationships between organisms and the flow of energy through a habitat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6025-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of organisms at each trophic level in a food chain can be used to create a pyramid of number."""@en ;
  dcterms:modified "2026-02-19T08:26:13.588645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pyramids of number use scaled bars to represent the number of organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.588649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6025-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pyramids of number have the producer at the bottom."@en ;
  dcterms:modified "2026-02-19T08:26:13.588653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6050-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are differences in the features of individuals of the same species, and this is called variation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused by the environment (e.g. injuries) or lifestyle (e.g. exercising to grow big muscles)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6050-3
  a curric:KeyLearningPoint ;
  rdfs:label "Environmental variation is not heritable, it cannot be passed on to offspring."@en ;
  dcterms:modified "2026-02-19T08:26:13.589431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused by genetic information (e.g. the instructions for making claws or camouflaged skin)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6050-5
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic variation is heritable, it can be passed on to offspring."@en ;
  dcterms:modified "2026-02-19T08:26:13.589438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9059-1
  a curric:KeyLearningPoint ;
  rdfs:label "The gravitational force on a falling object is constant."@en ;
  dcterms:modified "2026-02-19T08:26:13.591406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9059-2
  a curric:KeyLearningPoint ;
  rdfs:label "The drag force on a falling obejct depends on its speed and shape."@en ;
  dcterms:modified "2026-02-19T08:26:13.591410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9059-3
  a curric:KeyLearningPoint ;
  rdfs:label """Objects falling through the air will reach a terminal velocity when the drag and gravitational forces are equal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9059-4
  a curric:KeyLearningPoint ;
  rdfs:label """The terminal velocity can be changed by changing the drag force (e.g. with a parachute)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.591418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9874-1
  a curric:KeyLearningPoint ;
  rdfs:label """Laboratory apparatus are designed for specific uses and choice of apparatus impacts the quality of results"""@en ;
  dcterms:modified "2026-02-19T08:26:13.591625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9874-2
  a curric:KeyLearningPoint ;
  rdfs:label "Equipment can be communicated using 2D drawings/images"@en ;
  dcterms:modified "2026-02-19T08:26:13.591629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9874-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific diagrams illustrate how equipment is used together for practical investigations"""@en ;
  dcterms:modified "2026-02-19T08:26:13.591633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6430-1
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good thermal and electrical conductors, they are strong, shiny, malleable and ductile."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6430-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-metals are normally poor thermal and electrical conductors, they are not strong, and are dull and brittle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6430-3
  a curric:KeyLearningPoint ;
  rdfs:label "Graphite is a non-metal that is a good electrical and thermal conductor."@en ;
  dcterms:modified "2026-02-19T08:26:13.592361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6430-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are found on the left side and in the middle of the periodic table, non-metals on the right side."""@en ;
  dcterms:modified "2026-02-19T08:26:13.592365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The instantaneous speed of an object is the speed at a particular moment in time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9058-2
  a curric:KeyLearningPoint ;
  rdfs:label "For an accurate measurement a person needs to be in line with the observation."@en ;
  dcterms:modified "2026-02-19T08:26:13.593560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9058-3
  a curric:KeyLearningPoint ;
  rdfs:label "Manual timing can lead to a range of timing errors."@en ;
  dcterms:modified "2026-02-19T08:26:13.593564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9058-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeat readings can reduce the effect of random errors."@en ;
  dcterms:modified "2026-02-19T08:26:13.593568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9058-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some readings are anomalous and these should not be used in caluations of averages."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4951-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is easier to increase the temperature of some materials than others."@en ;
  dcterms:modified "2026-02-19T08:26:13.593749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4951-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of particles and the attractive forces between particles are different in different substances."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4951-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different substances need different amounts of heating to reach the same temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4951-4
  a curric:KeyLearningPoint ;
  rdfs:label """The same amount of different materials at the same temperature can cause different amounts of heating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4951-5
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the specific heat capacity, the more energy 1 kg of a substance has, at a temperature, in the thermal store."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5001-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the light from objects can pass through a lens and become focused to form an image on a screen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some light from every point on an object passes through every part of a lens."@en ;
  dcterms:modified "2026-02-19T08:26:13.593773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5001-3
  a curric:KeyLearningPoint ;
  rdfs:label """A convex lens refracts light rays so they travel more towards each other. A point where rays meet is called a focus."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5001-4
  a curric:KeyLearningPoint ;
  rdfs:label """All the rays from one point on the object are focused to the same point, forming the corresponding part of the image."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5001-5
  a curric:KeyLearningPoint ;
  rdfs:label """The shape of a converging lens refracts (bends) light more at the edges than near to the centre."""@en ;
  dcterms:modified "2026-02-19T08:26:13.593787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6433-1
  a curric:KeyLearningPoint ;
  rdfs:label """The symbols for each element (each type of atom) a substance contains, appear in its chemical formula."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6433-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers (subscripts) next to chemical symbols in a formula show the numbers of each type of atom in a compound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6433-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each compound contains a different combination of elements."@en ;
  dcterms:modified "2026-02-19T08:26:13.595667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6433-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some compounds contain the same elements as other compounds, but in a different ratio."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6452-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combustion requires fuel, oxygen, and an initial source of energy, usually heat, to start the reaction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6452-2
  a curric:KeyLearningPoint ;
  rdfs:label """The term 'burning' describes the reaction of substances with oxygen and is commonly used to refer to visible flames."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6452-3
  a curric:KeyLearningPoint ;
  rdfs:label """Water is often formed in chemical reactions if oxygen and hydrogen atoms are present."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6452-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is often formed in chemical reactions if oxygen and carbon atoms are present."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6452-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide and water both consist of small molecules that form easily with strong bonds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.595691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5007-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the wire."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5007-2
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5007-3
  a curric:KeyLearningPoint ;
  rdfs:label "An electromagnet is made by wrapping a coil of wire around a core."@en ;
  dcterms:modified "2026-02-19T08:26:13.596445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5007-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and turned off."""@en ;
  dcterms:modified "2026-02-19T08:26:13.596449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4249-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant forces make the movement of things change."@en ;
  dcterms:modified "2026-02-19T08:26:13.597593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4249-2
  a curric:KeyLearningPoint ;
  rdfs:label "Friction acts against the direction of movement of an object."@en ;
  dcterms:modified "2026-02-19T08:26:13.597597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4249-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object will continue to move at a steady speed in a straight line unless a resultant force is acting."""@en ;
  dcterms:modified "2026-02-19T08:26:13.597603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quadrats are square frames which can be used to sample plants or slow-moving animals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6030-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different measurements that you can take using a quadrat depending on what you are investigating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6030-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most sampling using quadrats is random to avoid bias in your results."@en ;
  dcterms:modified "2026-02-19T08:26:13.598459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6030-4
  a curric:KeyLearningPoint ;
  rdfs:label "Classification keys can be used to identify different species."@en ;
  dcterms:modified "2026-02-19T08:26:13.598465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6030-5
  a curric:KeyLearningPoint ;
  rdfs:label """The results of ecological sampling can be used to inform conservation and preservation efforts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4987-1
  a curric:KeyLearningPoint ;
  rdfs:label """The path current flows through a filament bulb can be traced, from one connection and through the filament to another."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4987-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a faulty filament bulb, the filament is broken and current cannot flow through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4987-3
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit is not complete if there are any gaps in the circuit, or hidden in faulty wires or components."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4987-4
  a curric:KeyLearningPoint ;
  rdfs:label """A wire or component can be tested by putting it into a simple circuit with a battery and bulb."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4987-5
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit with one faulty component will work if a wire is used to bypass the faulty component."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6036-1
  a curric:KeyLearningPoint ;
  rdfs:label "Make, record and interpret observations of organisms in the field."@en ;
  dcterms:modified "2026-02-19T08:26:13.598643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6036-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use a classification key to identify and classify organisms in the field."@en ;
  dcterms:modified "2026-02-19T08:26:13.598649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6036-3
  a curric:KeyLearningPoint ;
  rdfs:label """How to work safely in a way that minimises harm to living organisms and disruption of ecosystems."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6035-1
  a curric:KeyLearningPoint ;
  rdfs:label """A classification key can be used to find out which groups organisms are classified into."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6035-2
  a curric:KeyLearningPoint ;
  rdfs:label "A classification key is a series of questions about the features of organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.598665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6035-3
  a curric:KeyLearningPoint ;
  rdfs:label "Classification helps us organise and make sense of biodiversity."@en ;
  dcterms:modified "2026-02-19T08:26:13.598669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6626-1
  a curric:KeyLearningPoint ;
  rdfs:label """All organisms have a genome, and there are similarities and differences between the genomes of different organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6626-2
  a curric:KeyLearningPoint ;
  rdfs:label """The genome is made of DNA, wound up into tightly-packed structures called chromosomes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6626-3
  a curric:KeyLearningPoint ;
  rdfs:label """Human body cells have 23 pairs of chromosomes, stored in the nucleus; bacteria have one that is stored in the cytoplasm."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6626-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sections of the DNA in chromosomes are called genes, which store instructions for inherited features and life processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other sections are non-coding DNA, which contains instructions that controls when the information in genes is used."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6460-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rocks consist of minerals and rock fragments."@en ;
  dcterms:modified "2026-02-19T08:26:13.598760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6460-2
  a curric:KeyLearningPoint ;
  rdfs:label """A mineral is a naturally occurring pure substance (an element or a compound) that has a crystal structure."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6460-3
  a curric:KeyLearningPoint ;
  rdfs:label """Minerals are identified by their crystal structure, composition, and physical properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6643-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sperm and egg cells are the sex cells of humans and are called gametes."@en ;
  dcterms:modified "2026-02-19T08:26:13.598772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6643-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans reproduce through sexual reproduction where half the genetic material of the offspring comes from each parent."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fertilisation occurs in the fallopian tubes when gametes join to form a zygote."@en ;
  dcterms:modified "2026-02-19T08:26:13.598781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6643-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each gamete carries half the genetic material of the parent; a zygote has a full set of genetic material."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6643-5
  a curric:KeyLearningPoint ;
  rdfs:label """The zygote divides to form a ball of cells called an embryo, which grows to form a foetus and then a baby."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9103-1
  a curric:KeyLearningPoint ;
  rdfs:label """When organisms reproduce they make offspring of the same kind (species resemblance)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9103-2
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring inherit features from both parents, so they look similar to their parents and one another (family resemblance)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9103-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some features are inherited when DNA is passed from parents to offspring during reproduction"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9103-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some features are caused (or changed) by an organism’s lifestyle and environment"@en ;
  dcterms:modified "2026-02-19T08:26:13.598809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9103-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is usually variation between offspring; they are not usually identical to their parents or one another"""@en ;
  dcterms:modified "2026-02-19T08:26:13.598814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6034-1
  a curric:KeyLearningPoint ;
  rdfs:label """Similarities and differences in the features of organisms are used to classify them into groups within larger groups."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists classify every organism into groups from kingdom down to species."@en ;
  dcterms:modified "2026-02-19T08:26:13.598822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6034-3
  a curric:KeyLearningPoint ;
  rdfs:label """In larger groups such as kingdoms, there are more organisms with fewer similarities in their features."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6034-4
  a curric:KeyLearningPoint ;
  rdfs:label """A species is a group of individuals with similar features and genes that can reproduce to make fertile offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6034-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists give each species a binomial name to identify the genus and species."@en ;
  dcterms:modified "2026-02-19T08:26:13.598834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6458-1
  a curric:KeyLearningPoint ;
  rdfs:label """Components of rocks, such as sand, fossils, shells, crystals, help to indicate how those rocks formed and their age."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6458-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rocks contain grains which can be round or interlocking."@en ;
  dcterms:modified "2026-02-19T08:26:13.598862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6458-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some rocks contain crystals that point in many directions while others are aligned."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6458-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rock types and textures provide insights into geological processes and Earth's history."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6640-1
  a curric:KeyLearningPoint ;
  rdfs:label "During puberty in humans, the male and female bodies undergo changes."@en ;
  dcterms:modified "2026-02-19T08:26:13.598927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6640-2
  a curric:KeyLearningPoint ;
  rdfs:label "The reproductive systems mature to enable adult humans to reproduce."@en ;
  dcterms:modified "2026-02-19T08:26:13.598931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Other changes also prepare the body for reproduction."@en ;
  dcterms:modified "2026-02-19T08:26:13.598935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6640-4
  a curric:KeyLearningPoint ;
  rdfs:label "The changes happen because of sex hormones being produced."@en ;
  dcterms:modified "2026-02-19T08:26:13.598939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6640-5
  a curric:KeyLearningPoint ;
  rdfs:label """Females and males undergo some common changes but also changes that are specific to each sex."""@en ;
  dcterms:modified "2026-02-19T08:26:13.598943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5160-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human body contains a skeleton made up of bones."@en ;
  dcterms:modified "2026-02-19T08:26:13.598980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5160-2
  a curric:KeyLearningPoint ;
  rdfs:label "A joint is where two or more bones meet."@en ;
  dcterms:modified "2026-02-19T08:26:13.598984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5160-3
  a curric:KeyLearningPoint ;
  rdfs:label "The skeleton supports the body and provides protection for organs and tissues."@en ;
  dcterms:modified "2026-02-19T08:26:13.598988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5160-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bones are made of living tissue made up of cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.598992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5160-5
  a curric:KeyLearningPoint ;
  rdfs:label "Red and white blood cells are made in the bone marrow."@en ;
  dcterms:modified "2026-02-19T08:26:13.598996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6645-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some substances can pass through the placenta including some drugs, alcohol and chemicals in cigarette smoke."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6645-2
  a curric:KeyLearningPoint ;
  rdfs:label "This can affect the growth of the foetus."@en ;
  dcterms:modified "2026-02-19T08:26:13.599167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6645-3
  a curric:KeyLearningPoint ;
  rdfs:label """Short term consequences can include miscarriage, premature birth and low birth weight."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6645-4
  a curric:KeyLearningPoint ;
  rdfs:label """Long term consequences can include addiction, sudden infant death and foetal alcohol spectrum disorder."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6644-1
  a curric:KeyLearningPoint ;
  rdfs:label """A zygote divides to become an embryo, which then develops into a foetus made of different cells and tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6644-2
  a curric:KeyLearningPoint ;
  rdfs:label "The human gestation period is about 40 weeks."@en ;
  dcterms:modified "2026-02-19T08:26:13.599323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6644-3
  a curric:KeyLearningPoint ;
  rdfs:label """The foetus grows in an amniotic sac which is filled with amniotic fluid for protection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6644-4
  a curric:KeyLearningPoint ;
  rdfs:label """The mother provides all the nutrients that the growing foetus needs and gets rid of waste products through the placenta."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6644-5
  a curric:KeyLearningPoint ;
  rdfs:label """During birth, the cervix opens and the uterus wall contracts to push the baby out through the vagina."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6042-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a bar chart to display discontinuous data."@en ;
  dcterms:modified "2026-02-19T08:26:13.599385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6042-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plotting data for discontinuous variation on a bar chart."@en ;
  dcterms:modified "2026-02-19T08:26:13.599389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6042-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting and describing a bar chart displaying data for discontinuous variation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6042-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discontinuous variation usually has only a genetic cause and is not affected by environment or lifestyle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6463-1
  a curric:KeyLearningPoint ;
  rdfs:label "The melting point of rock is very high."@en ;
  dcterms:modified "2026-02-19T08:26:13.599502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6463-2
  a curric:KeyLearningPoint ;
  rdfs:label "Melted rock is called either lava (on Earth's surface), or magma (underground)."@en ;
  dcterms:modified "2026-02-19T08:26:13.599506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6463-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extrusive igneous rock forms outside Earth's crust, while instrusive igneous rock forms inside the crust."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6463-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some substances form crystals when they freeze."@en ;
  dcterms:modified "2026-02-19T08:26:13.599514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6463-5
  a curric:KeyLearningPoint ;
  rdfs:label "Crystal size depends on the rate at which melted rock cools."@en ;
  dcterms:modified "2026-02-19T08:26:13.599518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9100-1
  a curric:KeyLearningPoint ;
  rdfs:label "All living organisms have a life cycle."@en ;
  dcterms:modified "2026-02-19T08:26:13.599545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9100-2
  a curric:KeyLearningPoint ;
  rdfs:label "All life cycles include stages of growth and reproduction."@en ;
  dcterms:modified "2026-02-19T08:26:13.599549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9100-3
  a curric:KeyLearningPoint ;
  rdfs:label """In humans, the reproduction stage of the life cycle involves producing a baby that grows into a new human."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9100-4
  a curric:KeyLearningPoint ;
  rdfs:label """In some plants, the reproduction stage of the life cycle involves producing a seed that grows into a new plant."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4985-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms contain positive and negative electric charges."@en ;
  dcterms:modified "2026-02-19T08:26:13.599561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4985-2
  a curric:KeyLearningPoint ;
  rdfs:label "The particles in atoms with a negative electric charge are called electrons."@en ;
  dcterms:modified "2026-02-19T08:26:13.599565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4985-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons can sometimes be transferred from one object to another, depending on the materials the objects are made of."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are difficult to charge because electric charge flows through them, preventing charge from building up."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4985-5
  a curric:KeyLearningPoint ;
  rdfs:label "When static electricity builds up, it can be useful but also problematic."@en ;
  dcterms:modified "2026-02-19T08:26:13.599577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6459-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sedimentary rocks contain distinct grains that are stuck together."@en ;
  dcterms:modified "2026-02-19T08:26:13.600161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6459-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentary rocks may contain fragments of shell or fossils, or larger pieces of grit or pebbles cemented together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6459-3
  a curric:KeyLearningPoint ;
  rdfs:label """Igneous rocks contain crystals that point in many directions; metamorphic rocks contain crystals that mostly line up."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6459-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rocks that contain interlocking grains or interlocking crystals are non-porous; rocks that don't are porous."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6459-5
  a curric:KeyLearningPoint ;
  rdfs:label "The properties of rock influence their uses."@en ;
  dcterms:modified "2026-02-19T08:26:13.600179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6043-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a histogram or line graph to display continuous data."@en ;
  dcterms:modified "2026-02-19T08:26:13.600270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6043-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plotting data for continuous variation on a histogram."@en ;
  dcterms:modified "2026-02-19T08:26:13.600274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6043-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting and describing a histogram displaying data for continuous variation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6043-4
  a curric:KeyLearningPoint ;
  rdfs:label """Continuous variation is usually influenced by many factors, including genetics, the environment and lifestyle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food groups include protein, carbohydrate, lipids/fats, water, minerals, vitamins and fibre."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each food group plays a role in maintaining a healthy body."@en ;
  dcterms:modified "2026-02-19T08:26:13.600351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6631-3
  a curric:KeyLearningPoint ;
  rdfs:label "A balanced diet is needed to maintain good health."@en ;
  dcterms:modified "2026-02-19T08:26:13.600373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6631-4
  a curric:KeyLearningPoint ;
  rdfs:label """People need different amounts of particular nutrients at different times in their lives, depending on their lifestyle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5161-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human body contains muscles."@en ;
  dcterms:modified "2026-02-19T08:26:13.600423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5161-2
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles are a type of tissue made up of specialised cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.600427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5161-3
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles can contract and relax."@en ;
  dcterms:modified "2026-02-19T08:26:13.600431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5161-4
  a curric:KeyLearningPoint ;
  rdfs:label "Muscles need sugar and oxygen to contract."@en ;
  dcterms:modified "2026-02-19T08:26:13.600435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5161-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of muscle have roles in organ systems, including cardiac muscle, smooth muscle and skeletal muscle."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6462-1
  a curric:KeyLearningPoint ;
  rdfs:label """Occurrences of earthquakes and volcanic eruptions suggest Earth’s layers are not static but interact with each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6462-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence, such as rock formations and fossils, supports the idea that the continents were once all joined up."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6462-3
  a curric:KeyLearningPoint ;
  rdfs:label """Earth’s crust is broken into pieces known as tectonic plates, which move very, very slowly."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6462-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plate tectonics is a scientific theory that explains how tectonic plates move and interact with each other."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6462-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plate tectonics help scientists better understand and predict changes to Earth’s surface."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9099-1
  a curric:KeyLearningPoint ;
  rdfs:label """All living things develop from other living things; reproduction is the process of making new living things (offspring)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9099-2
  a curric:KeyLearningPoint ;
  rdfs:label """When organisms reproduce they make offspring of the same kind (species resemblance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9099-3
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring inherit features from both parents so they look similar to their parents and one another (family resemblance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9099-4
  a curric:KeyLearningPoint ;
  rdfs:label """Features are inherited when genetic material (DNA) is passed from parents to their offspring during reproduction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9099-5
  a curric:KeyLearningPoint ;
  rdfs:label """The genetic material (DNA) contains the instructions for building our body and its features."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6641-1
  a curric:KeyLearningPoint ;
  rdfs:label "The function of the male reproductive system is to produce sperm cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.600714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sperm cells are made and stored in the testes."@en ;
  dcterms:modified "2026-02-19T08:26:13.600718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6641-3
  a curric:KeyLearningPoint ;
  rdfs:label """Females are born with all their eggs inside their ovaries, each month an egg is released."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6641-4
  a curric:KeyLearningPoint ;
  rdfs:label "The testes and the ovaries make hormones."@en ;
  dcterms:modified "2026-02-19T08:26:13.600726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6641-5
  a curric:KeyLearningPoint ;
  rdfs:label """The male and female reproductive systems must work together to produce offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28952-1
  a curric:KeyLearningPoint ;
  rdfs:label "A gardener can use a greenhouse to keep plants warm."@en ;
  dcterms:modified "2026-02-19T08:26:13.600978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28952-2
  a curric:KeyLearningPoint ;
  rdfs:label """A greenhouse maintains the optimal temperature range for the growth and survival of the plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28952-3
  a curric:KeyLearningPoint ;
  rdfs:label """A natural greenhouse effect maintains optimal temperature range for life on Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28952-4
  a curric:KeyLearningPoint ;
  rdfs:label "Greenhouse gases in Earth’s atmosphere cause the natural greenhouse effect."@en ;
  dcterms:modified "2026-02-19T08:26:13.600993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28952-5
  a curric:KeyLearningPoint ;
  rdfs:label """Human activities are increasing the amount of greenhouse gases in the atmosphere, increasing the greenhouse effect."""@en ;
  dcterms:modified "2026-02-19T08:26:13.600997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6625-1
  a curric:KeyLearningPoint ;
  rdfs:label """DNA was discovered in 1869, but scientists did not work out its structure until 1953."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6625-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists collected evidence and shared findings to develop a model to describe the structure of DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6625-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rosalind Franklin’s team in London used X-rays to produce an image of a DNA molecule in1952."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6625-4
  a curric:KeyLearningPoint ;
  rdfs:label """Maurice Wilkins from Franklin’s group showed the picture to James Watson from Cambridge."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6625-5
  a curric:KeyLearningPoint ;
  rdfs:label """Watson and Francis Crick used the picture evidence to complete a model to describe the double helix structure of DNA."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5163-1
  a curric:KeyLearningPoint ;
  rdfs:label """A muscle attached to a bone exerts a force on the bone when the muscle contracts, which makes the bone move."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5163-2
  a curric:KeyLearningPoint ;
  rdfs:label "Biomechanics is the study of this movement."@en ;
  dcterms:modified "2026-02-19T08:26:13.601027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5163-3
  a curric:KeyLearningPoint ;
  rdfs:label "A moment is the turning effect of the force when a bone pivots at a joint."@en ;
  dcterms:modified "2026-02-19T08:26:13.601031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5163-4
  a curric:KeyLearningPoint ;
  rdfs:label "The size of the moment when a bone pivots at a joint can be calculated."@en ;
  dcterms:modified "2026-02-19T08:26:13.601037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adult human females have a menstrual cycle that prepares them for sexual reproduction"""@en ;
  dcterms:modified "2026-02-19T08:26:13.601042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6642-2
  a curric:KeyLearningPoint ;
  rdfs:label "On average the menstrual cycle is 28 days"@en ;
  dcterms:modified "2026-02-19T08:26:13.601046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6642-3
  a curric:KeyLearningPoint ;
  rdfs:label "In each cycle, an egg cell is released from an ovary (ovulation)"@en ;
  dcterms:modified "2026-02-19T08:26:13.601050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6642-4
  a curric:KeyLearningPoint ;
  rdfs:label """After ovulation, the uterus lining breaks down and leaves the body (menstruation)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.601054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6041-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some features have discontinuous variation (limited variations falling into particular categories)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6041-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some features have continuous variation (can take any value within a range)."@en ;
  dcterms:modified "2026-02-19T08:26:13.601099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6041-3
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of features in humans, other animals and plants that show discontinuous and continuous variation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6041-4
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting primary data on examples of discontinuous and continuous variation in features."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6037-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified into groups based on their characteristics at the microscopic, cellular level."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6037-2
  a curric:KeyLearningPoint ;
  rdfs:label "The common features of the cells of animals, plants, fungi and bacteria."@en ;
  dcterms:modified "2026-02-19T08:26:13.601461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of cell features to classify organisms into the kingdoms of animals, plants, fungi and bacteria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6448-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characteristics of chemical reactions include changes in colour, bubbling, or a change of temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6448-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bubbles appear when a gas is produced in a chemical reaction."@en ;
  dcterms:modified "2026-02-19T08:26:13.601473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6448-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a chemical reaction, atoms rearrange themselves to form new substances."@en ;
  dcterms:modified "2026-02-19T08:26:13.601477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6448-4
  a curric:KeyLearningPoint ;
  rdfs:label "Generally, chemical reactions are irreversible."@en ;
  dcterms:modified "2026-02-19T08:26:13.601483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4999-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflections are the same size as the object, upright, and the same distance behind the mirror as the object is in front."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4999-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a plane mirror, reflections appear laterally inverted compared to the object when it is facing us."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4999-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mirrors reflect what is in front of them. Reflections are laterally inverted as objects are turned to face a mirror."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4999-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reflections are virtual images; they appear where light rays seem to have come from, not where they actually come from."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4999-5
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual rays show where light rays appear to have come from; they are drawn as dashed lines."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6049-1
  a curric:KeyLearningPoint ;
  rdfs:label """All living organisms need resources from their habitat to enable them to survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6049-2
  a curric:KeyLearningPoint ;
  rdfs:label "Resources are limited, so individuals are in competition for them."@en ;
  dcterms:modified "2026-02-19T08:26:13.601526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6049-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms compete for resources such as food, water, space, shelter, light, mates, pollinators and seed dispersers."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6049-4
  a curric:KeyLearningPoint ;
  rdfs:label """Variation means some individuals are better adapted to compete more successfully than others."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6049-5
  a curric:KeyLearningPoint ;
  rdfs:label "These individuals have the best ‘fit’ to their environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.601539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4994-1
  a curric:KeyLearningPoint ;
  rdfs:label """All colours of light can be created by mixing the primary colours of light; red, green and blue."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mixing equal amounts of two primary colours creates a secondary colour. All three mixed in equal amounts makes white."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4994-3
  a curric:KeyLearningPoint ;
  rdfs:label """The retina, on the back of the eye, detects light. When there is no light, we see black."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4994-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the retina, three types of cone cell detect either red, green or blue light, and rod cells detect brightness."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4994-5
  a curric:KeyLearningPoint ;
  rdfs:label """Display screens are made of tiny red, green and blue lights (pixels) which vary in brightness to make different colours."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6634-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food is a source of building materials to make biomass for growth and repair."@en ;
  dcterms:modified "2026-02-19T08:26:13.603005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food also provides the fuel for cellular respiration, to provide energy for life processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6634-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different individuals require different daily amounts of food and energy."@en ;
  dcterms:modified "2026-02-19T08:26:13.603012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6634-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food labels contain information on the content of the food and daily recommended amounts of nutrients and energy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6634-5
  a curric:KeyLearningPoint ;
  rdfs:label "The amount of energy provided by food can be compared in kilojoules or calories."@en ;
  dcterms:modified "2026-02-19T08:26:13.603020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9877-1
  a curric:KeyLearningPoint ;
  rdfs:label "State changes are visible as plateaus on cooling curves."@en ;
  dcterms:modified "2026-02-19T08:26:13.603208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9877-2
  a curric:KeyLearningPoint ;
  rdfs:label """As it cools, a substance transfers energy into the surroundings by heating and it may condense or freeze."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is released to the surroundings as a substance cools and this is observed as a decrease in substance temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9877-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphs provide a visual representation of data for easier analysis and help identify trends/patterns."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light changes direction when it moves into a new medium (material) at an angle to the normal. This is called refraction."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5000-2
  a curric:KeyLearningPoint ;
  rdfs:label "When light enters a transparent material from air, it turns towards the normal."@en ;
  dcterms:modified "2026-02-19T08:26:13.603244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5000-3
  a curric:KeyLearningPoint ;
  rdfs:label """When light leaves a transparent material and re–enters air it turns away from the normal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5000-4
  a curric:KeyLearningPoint ;
  rdfs:label """A ray that enters and leaves glass through parallel sides ends up in its original direction, but displaced to the side."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5000-5
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can cause virtual images of objects to appear where light seems to be coming from."""@en ;
  dcterms:modified "2026-02-19T08:26:13.603256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9869-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vital capacity of the lungs is the maximum volume of air that can be exhaled after inhaling fully."""@en ;
  dcterms:modified "2026-02-19T08:26:13.604495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9869-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to measure vital capacity using simple apparatus."@en ;
  dcterms:modified "2026-02-19T08:26:13.604499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9869-3
  a curric:KeyLearningPoint ;
  rdfs:label """The closer a measurement is to the true value, the more accurate it is said to be."""@en ;
  dcterms:modified "2026-02-19T08:26:13.604503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9869-4
  a curric:KeyLearningPoint ;
  rdfs:label """An estimate is an approximate (rough) value of a quantity (without taking accurate measurements)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.604509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9869-5
  a curric:KeyLearningPoint ;
  rdfs:label """An estimate of lung volume can be calculated from a measurement of vital capacity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.604513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28958-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing levels of greenhouse gases in the atmosphere is leading to global warming and climate change"""@en ;
  dcterms:modified "2026-02-19T08:26:13.604684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28958-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide is a greenhouse gas, released by living organisms and produced when burning fuels"""@en ;
  dcterms:modified "2026-02-19T08:26:13.604688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28958-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methane is a greenhouse gas, released by living organisms and from the ground"@en ;
  dcterms:modified "2026-02-19T08:26:13.604692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28958-4
  a curric:KeyLearningPoint ;
  rdfs:label "Methane is a more potent greenhouse gas than carbon dioxide"@en ;
  dcterms:modified "2026-02-19T08:26:13.604696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28958-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reducing greenhouse gas emissions can reduce the rate of global warming and may even help to reverse it"""@en ;
  dcterms:modified "2026-02-19T08:26:13.604700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28963-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon capture and storage separates CO₂ from other emissions and stores it in suitable deep underground locations"""@en ;
  dcterms:modified "2026-02-19T08:26:13.605238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon capture and storage can reduce CO₂ emissions but is very expensive"@en ;
  dcterms:modified "2026-02-19T08:26:13.605242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28963-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy sector uses fuel for heating, electricity generation and transport as well as manufacturing and construction"""@en ;
  dcterms:modified "2026-02-19T08:26:13.605246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28963-4
  a curric:KeyLearningPoint ;
  rdfs:label "The energy sector produces approximately 75% of global greenhouse gas emissions"@en ;
  dcterms:modified "2026-02-19T08:26:13.605250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28963-5
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gas emissions can be reduced by using less energy and switching to renewable energy sources"""@en ;
  dcterms:modified "2026-02-19T08:26:13.605254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5177-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans and other animals breathe to move air in and out of their lungs."@en ;
  dcterms:modified "2026-02-19T08:26:13.606013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5177-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cells need oxygen from the air for cellular respiration, to provide energy for life processes."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5177-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cellular respiration produces carbon dioxide as a waste product."@en ;
  dcterms:modified "2026-02-19T08:26:13.606024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5177-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oxygen needs to be absorbed into, and carbon dioxide needs to be removed from, the human body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5177-5
  a curric:KeyLearningPoint ;
  rdfs:label """In gas exchange, oxygen diffuses from the lungs into the blood; carbon dioxide diffuses from the blood into the lungs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6473-1
  a curric:KeyLearningPoint ;
  rdfs:label """Over half of the electricity in the UK is generated from the Sun, wind and falling water."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6473-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many power stations in the UK burn natural gas and oil to heat water into steam."@en ;
  dcterms:modified "2026-02-19T08:26:13.606497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6473-3
  a curric:KeyLearningPoint ;
  rdfs:label """The moving steam in power stations pushes turbines, which drive electric generators that produce electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6473-4
  a curric:KeyLearningPoint ;
  rdfs:label """Natural gas and oil are fossil fuels used in power stations; coal is no longer used in UK power stations."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6473-5
  a curric:KeyLearningPoint ;
  rdfs:label """Natural gas, oil, waste and wood are fuels that produce greenhouse gases and pollutants when burned."""@en ;
  dcterms:modified "2026-02-19T08:26:13.606512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9074-1
  a curric:KeyLearningPoint ;
  rdfs:label """Heating transfers energy into a substance and can cause it to melt, evaporate or boil."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9074-2
  a curric:KeyLearningPoint ;
  rdfs:label "Melting, evaporation and boiling are endothermic."@en ;
  dcterms:modified "2026-02-19T08:26:13.607362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9074-3
  a curric:KeyLearningPoint ;
  rdfs:label """As it cools, a substance transfers energy into the surroundings by heating and it may condense or freeze."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9074-4
  a curric:KeyLearningPoint ;
  rdfs:label "Condensing and freezing are exothermic."@en ;
  dcterms:modified "2026-02-19T08:26:13.607373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28961-1
  a curric:KeyLearningPoint ;
  rdfs:label """Burning fuels for transport produces greenhouse gases, other pollutant gases, and particulates."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28961-2
  a curric:KeyLearningPoint ;
  rdfs:label """Petrol and diesel vehicles burn fuels, while electric vehicles do not, but fuels may be burned to generate electricity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28961-3
  a curric:KeyLearningPoint ;
  rdfs:label "The energy use of planes, trains, cars, ships, and buses can be compared."@en ;
  dcterms:modified "2026-02-19T08:26:13.607619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28961-4
  a curric:KeyLearningPoint ;
  rdfs:label "Vehicles use energy and resources during manufacturing."@en ;
  dcterms:modified "2026-02-19T08:26:13.607623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28961-5
  a curric:KeyLearningPoint ;
  rdfs:label "Parts of vehicles may become waste at the end of their useful lives."@en ;
  dcterms:modified "2026-02-19T08:26:13.607627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4995-1
  a curric:KeyLearningPoint ;
  rdfs:label """White light from the Sun and light bulbs consists of light of all the colours in the visible light spectrum (a rainbow)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4995-2
  a curric:KeyLearningPoint ;
  rdfs:label """A transparent triangular prism can split up sunlight into a visible light spectrum."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4995-3
  a curric:KeyLearningPoint ;
  rdfs:label "The visible light spectrum shows the range of colours that light can have."@en ;
  dcterms:modified "2026-02-19T08:26:13.607662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4995-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cone cells in the eye detect colour. There are 3 kinds (R, G and B); each is sensitive to a range of colours of light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4995-5
  a curric:KeyLearningPoint ;
  rdfs:label """The colour we see depends on which cone cells are triggered to send a signal to the brain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28962-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cars use more energy to travel 100 km if they are heavier or travel at higher speeds."""@en ;
  dcterms:modified "2026-02-19T08:26:13.607998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28962-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cars use less energy if their tyres are inflated to the correct air pressure"@en ;
  dcterms:modified "2026-02-19T08:26:13.608002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28962-3
  a curric:KeyLearningPoint ;
  rdfs:label "Walking and cycling regularly improve a person’s physical health"@en ;
  dcterms:modified "2026-02-19T08:26:13.608006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28962-4
  a curric:KeyLearningPoint ;
  rdfs:label """Well-planned infrastructure for cycling, walking and public transport make it easier and safer to travel without a car"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28959-1
  a curric:KeyLearningPoint ;
  rdfs:label """Global surface temperatures are calculated from tens of thousands of measurements worldwide"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28959-2
  a curric:KeyLearningPoint ;
  rdfs:label "Temperatures are compared with the long-term average for each region"@en ;
  dcterms:modified "2026-02-19T08:26:13.608021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28959-3
  a curric:KeyLearningPoint ;
  rdfs:label """Since the industrial revolution, in the 1850s, overall global surface temperatures have been increasing"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28959-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence from trees rings and ice cores provides data of longer-term changes in temperature"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28959-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can explain how increased levels of greenhouse gases contribute to global warming"""@en ;
  dcterms:modified "2026-02-19T08:26:13.608033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6468-1
  a curric:KeyLearningPoint ;
  rdfs:label """An exothermic chemical reaction causes an increase in temperature (of the surroundings)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6468-2
  a curric:KeyLearningPoint ;
  rdfs:label """An endothermic chemical reaction causes a decrease in temperature (of the surroundings)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.608599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6468-3
  a curric:KeyLearningPoint ;
  rdfs:label "An exothermic reaction transfers energy from the reactants to the surroundings."@en ;
  dcterms:modified "2026-02-19T08:26:13.608603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6468-4
  a curric:KeyLearningPoint ;
  rdfs:label "An endothermic reaction transfers energy from the surroundings to the products."@en ;
  dcterms:modified "2026-02-19T08:26:13.608607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4996-1
  a curric:KeyLearningPoint ;
  rdfs:label """Colour is detected in the eye by the R, G and B ‘cone cells’ that each detect a range of colours of light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4996-2
  a curric:KeyLearningPoint ;
  rdfs:label """The colour of an object in white or coloured light depends on the amounts of R, G and B light it is reflecting."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4996-3
  a curric:KeyLearningPoint ;
  rdfs:label """White objects reflect all colours of light so look the same colour as the incident light (whether white or coloured)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4996-4
  a curric:KeyLearningPoint ;
  rdfs:label """The colours of light that an object does not reflect are absorbed. Black objects absorb all colours of light."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4996-5
  a curric:KeyLearningPoint ;
  rdfs:label """In red/green/blue light, an object will appear red/green/blue if it reflects that colour, and black if it does not."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28960-1
  a curric:KeyLearningPoint ;
  rdfs:label "Greenhouse gases in the atmosphere keep it warmer than it would be without them."@en ;
  dcterms:modified "2026-02-19T08:26:13.609377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28960-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating from the Sun controls the average temperature of Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.609382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28960-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increased temperatures melt ice sheets more quickly, moving more water into the sea, making sea levels rise."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28960-4
  a curric:KeyLearningPoint ;
  rdfs:label """More sea ice melts in summer, but this does not add water to the sea or raise sea levels."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28960-5
  a curric:KeyLearningPoint ;
  rdfs:label "Warmer oceans and seas expand, causing sea levels to rise."@en ;
  dcterms:modified "2026-02-19T08:26:13.609394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9062-1
  a curric:KeyLearningPoint ;
  rdfs:label """A pinhole camera is an empty, closed box with a tiny hole on the front face and a screen on the back face."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light moves in straight lines from a light source, through the pinhole, to the screen at the back of a pinhole camera."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9062-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light from each different point on the object falls on a different single point on the screen, forming the image."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9062-4
  a curric:KeyLearningPoint ;
  rdfs:label """The image produced by a pinhole camera is dim and inverted. Adding more holes produces multiple images."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9062-5
  a curric:KeyLearningPoint ;
  rdfs:label """Making the hole larger makes the image brighter but blurred. More light passes through the hole in more directions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.609551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Variation within a population of a species means some individuals are better adapted to compete and survive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The fittest (better adapted) individuals are more likely to survive to reproduce."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6051-3
  a curric:KeyLearningPoint ;
  rdfs:label """These individuals are more likely to pass on heritable, advantageous features to their offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6051-4
  a curric:KeyLearningPoint ;
  rdfs:label """This is natural selection, and causes the advantageous features to become more common in each generation of offspring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6051-5
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in environmental conditions, including changes caused by humans, can affect natural selection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4258-1
  a curric:KeyLearningPoint ;
  rdfs:label "Levers can multiply a small force into a larger force."@en ;
  dcterms:modified "2026-02-19T08:26:13.611189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4258-2
  a curric:KeyLearningPoint ;
  rdfs:label "Levers can multiply a small movement into a larger movement."@en ;
  dcterms:modified "2026-02-19T08:26:13.611193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4258-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of lever, each with the pivot in a different position."@en ;
  dcterms:modified "2026-02-19T08:26:13.611197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8307-1
  a curric:KeyLearningPoint ;
  rdfs:label """Polymers are made from small molecules called monomers that join together to form very long chains of atoms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8307-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some polymers have high melting points because their molecules are hard to separate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8307-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers can be made synthetically, but some also exist naturally."@en ;
  dcterms:modified "2026-02-19T08:26:13.611228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8307-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plasticiser added to a polymer gets between polymer molecules and allows them to move over each other more easily."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8307-5
  a curric:KeyLearningPoint ;
  rdfs:label """Cross-links between polymer molecules can make a polymer harder and less flexible."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5503-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant leaves take in carbon dioxide gas from the air for photosynthesis"@en ;
  dcterms:modified "2026-02-19T08:26:13.611240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5503-2
  a curric:KeyLearningPoint ;
  rdfs:label "The oxygen made by photosynthesis is released as a gas from leaves into the air"@en ;
  dcterms:modified "2026-02-19T08:26:13.611244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5503-3
  a curric:KeyLearningPoint ;
  rdfs:label "This process is called gas exchange"@en ;
  dcterms:modified "2026-02-19T08:26:13.611248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5503-4
  a curric:KeyLearningPoint ;
  rdfs:label "Leaves have small holes in their surface called stomata for gas exchange"@en ;
  dcterms:modified "2026-02-19T08:26:13.611252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5503-5
  a curric:KeyLearningPoint ;
  rdfs:label "Molecules of gases move through open stomata by diffusion"@en ;
  dcterms:modified "2026-02-19T08:26:13.611258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6048-1
  a curric:KeyLearningPoint ;
  rdfs:label """Species have features which make them well suited to survive in their environment."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6048-2
  a curric:KeyLearningPoint ;
  rdfs:label "These features are called adaptations."@en ;
  dcterms:modified "2026-02-19T08:26:13.611417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6048-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of adaptations of particular species of animals and plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.611422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6048-4
  a curric:KeyLearningPoint ;
  rdfs:label """How particular adaptations provide an advantage in the environment in which the species lives."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6451-1
  a curric:KeyLearningPoint ;
  rdfs:label """A group of one carbon atom and three oxygen atoms bonded together is called a carbonate group."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6451-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metal carbonate + acid → salt + water + carbon dioxide"@en ;
  dcterms:modified "2026-02-19T08:26:13.611434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6451-3
  a curric:KeyLearningPoint ;
  rdfs:label """The test for carbon dioxide gas is to bubble it through limewater as it turns the solution cloudy (milky)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6451-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rain water is usually a little acidic and when it is more acidic than normal it is called acid rain."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6451-5
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain reacts with marble to produce a salt, water and carbon dioxide, using up some of the marble."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8300-1
  a curric:KeyLearningPoint ;
  rdfs:label """Red cabbage solution is pink or red in an acid, purple in a neutral solution, and green in an alkali."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8300-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different chemical indicators have their advantages and disadvantages."@en ;
  dcterms:modified "2026-02-19T08:26:13.611454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8300-3
  a curric:KeyLearningPoint ;
  rdfs:label "Universal indicator will turn many different colours depending on pH."@en ;
  dcterms:modified "2026-02-19T08:26:13.611457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6047-1
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence suggests Earth was formed 4.5 billion years ago (one billion is one thousand million)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence suggests the first living organisms (microorganisms) appeared around 3.8 billion years ago."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The oldest fossils are around 3.5 billion years old, and the newest fossils are around 10 thousand years old."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6047-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence suggests the first land plants appeared 500mya, the first mammals 200mya, and modern humans 350k years ago."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6047-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists divide Earth’s history into eons, periods and epochs to make it easier to understand."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8297-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edible acids have a sour taste."@en ;
  dcterms:modified "2026-02-19T08:26:13.611731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8297-2
  a curric:KeyLearningPoint ;
  rdfs:label "A base is any substance that reacts with acids to form a compound called a salt."@en ;
  dcterms:modified "2026-02-19T08:26:13.611735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8297-3
  a curric:KeyLearningPoint ;
  rdfs:label "Alkalis are soluble bases, and form alkaline solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.611739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8297-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some acids and alkalis are corrosive and can cause chemical burns."@en ;
  dcterms:modified "2026-02-19T08:26:13.611743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8297-5
  a curric:KeyLearningPoint ;
  rdfs:label "An acid turns blue litmus paper red, an alkali turns red litmus paper blue."@en ;
  dcterms:modified "2026-02-19T08:26:13.611748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5179-1
  a curric:KeyLearningPoint ;
  rdfs:label "The lungs are made up of tiny air sacs called alveoli."@en ;
  dcterms:modified "2026-02-19T08:26:13.611774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5179-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas exchange takes place between air in alveoli and blood in capillaries."@en ;
  dcterms:modified "2026-02-19T08:26:13.611778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5179-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are millions of alveoli to increase the surface area of the lungs for gas exchange."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5179-4
  a curric:KeyLearningPoint ;
  rdfs:label """The walls of the alveoli are one cell thick to create a short diffusion distance for gas exchange."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5179-5
  a curric:KeyLearningPoint ;
  rdfs:label """The alveoli are surrounded by capillaries carrying blood, to maintain a concentration gradient for gas exchange."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5183-1
  a curric:KeyLearningPoint ;
  rdfs:label """In microorganisms, anaerobic cellular respiration produces carbon dioxide and a type of alcohol called ethanol."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5183-2
  a curric:KeyLearningPoint ;
  rdfs:label """A word summary of the reactants and products of anaerobic cellular respiration in microorganisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5183-3
  a curric:KeyLearningPoint ;
  rdfs:label "Anaerobic cellular respiration in microorganisms is also called fermentation."@en ;
  dcterms:modified "2026-02-19T08:26:13.611921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5183-4
  a curric:KeyLearningPoint ;
  rdfs:label """Humans use fermentation in microorganisms to make useful products such as bread, yogurt and alcoholic drinks."""@en ;
  dcterms:modified "2026-02-19T08:26:13.611925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5500-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants are living organisms that need light, air, water and minerals to stay alive and grow"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5500-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants take in light and gases from air through their leaves, and take in water and minerals through their roots"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5500-3
  a curric:KeyLearningPoint ;
  rdfs:label "Water and minerals are not food, but plants do need food to stay alive and grow"@en ;
  dcterms:modified "2026-02-19T08:26:13.611975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5500-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plants do not take in food from their surroundings, they are producers that make their own food"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5500-5
  a curric:KeyLearningPoint ;
  rdfs:label """The food that plants make is carbohydrate, which they use for growth and as a source of energy"""@en ;
  dcterms:modified "2026-02-19T08:26:13.611983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9067-1
  a curric:KeyLearningPoint ;
  rdfs:label """A rubber band is elastic because it returns to its original length when a force is removed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9067-2
  a curric:KeyLearningPoint ;
  rdfs:label """The extension of a rubber band increases different amounts for each equal sized increase in force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9067-3
  a curric:KeyLearningPoint ;
  rdfs:label "The extension of a spring is not directly proportional to the force applied."@en ;
  dcterms:modified "2026-02-19T08:26:13.612011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9067-4
  a curric:KeyLearningPoint ;
  rdfs:label """The extension pattern is explained by the behaviour of molecular chains in the rubber."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6052-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple model can be used to demonstrate natural selection, e.g. picking up green and white cocktail sticks from grass."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6052-2
  a curric:KeyLearningPoint ;
  rdfs:label """The model can be used to make predictions about how a population will change over time due to natural selection."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6052-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prediction may change if the environmental conditions change (e.g. if the grass becomes frosty/snowy)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4256-1
  a curric:KeyLearningPoint ;
  rdfs:label "A line of best fit can show the relationship between variables clearly."@en ;
  dcterms:modified "2026-02-19T08:26:13.612058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4256-2
  a curric:KeyLearningPoint ;
  rdfs:label """The extension of a spring increases the same amount for each equal sized increase in force."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4256-3
  a curric:KeyLearningPoint ;
  rdfs:label "The extension of a spring is directly proportional to the force applied."@en ;
  dcterms:modified "2026-02-19T08:26:13.612066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4256-4
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastic because it returns to its original length when a force is removed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4256-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hooke's law describes the behaviour of springs."@en ;
  dcterms:modified "2026-02-19T08:26:13.612074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8299-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most acids and alkalis are colourless solutions, so indicators can be used to identify them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8299-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH stands for ‘potential of hydrogen’ and acids contain hydrogen."@en ;
  dcterms:modified "2026-02-19T08:26:13.612084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8299-3
  a curric:KeyLearningPoint ;
  rdfs:label "The higher the concentration of hydrogen, the lower the pH."@en ;
  dcterms:modified "2026-02-19T08:26:13.612088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8299-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pH scale goes up and down in factors of ten, so an acid of pH 2 is ten times more acidic than pH 3."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8299-5
  a curric:KeyLearningPoint ;
  rdfs:label """A low pH means acidic, a high pH means alkaline and solutions with a pH of 7 are neutral."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5502-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant leaves are made up of cells that contain structures called chloroplasts."@en ;
  dcterms:modified "2026-02-19T08:26:13.612596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5502-2
  a curric:KeyLearningPoint ;
  rdfs:label "Photosynthesis takes place in chloroplasts."@en ;
  dcterms:modified "2026-02-19T08:26:13.612600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5502-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chloroplasts contain chlorophyll, which absorbs light for photosynthesis."@en ;
  dcterms:modified "2026-02-19T08:26:13.612604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5502-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plant leaves are thin to allow light to pass through to cells containing chloroplasts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5502-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plant leaves have a large surface area to absorb light for photosynthesis."@en ;
  dcterms:modified "2026-02-19T08:26:13.612616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8304-1
  a curric:KeyLearningPoint ;
  rdfs:label "A metal oxide consists of metal atoms bonded to oxygen atoms."@en ;
  dcterms:modified "2026-02-19T08:26:13.612648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8304-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases and can react with acids to neutralise them."@en ;
  dcterms:modified "2026-02-19T08:26:13.612652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8304-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxide + acid ⭢ metal salt + water"@en ;
  dcterms:modified "2026-02-19T08:26:13.612656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8304-4
  a curric:KeyLearningPoint ;
  rdfs:label "A non-metal oxide consists of non-metal atoms bonded to oxygen atoms."@en ;
  dcterms:modified "2026-02-19T08:26:13.612660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8304-5
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides in water make acidic solutions."@en ;
  dcterms:modified "2026-02-19T08:26:13.612664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5501-1
  a curric:KeyLearningPoint ;
  rdfs:label "Producers make their own food using a process called photosynthesis."@en ;
  dcterms:modified "2026-02-19T08:26:13.612731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5501-2
  a curric:KeyLearningPoint ;
  rdfs:label "Photosynthesis can only happen when there is light."@en ;
  dcterms:modified "2026-02-19T08:26:13.612735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5501-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photosynthesis is a series of chemical reactions that take place inside cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.612739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5501-4
  a curric:KeyLearningPoint ;
  rdfs:label """The reactants of photosynthesis are water and carbon dioxide, and the products are oxygen and glucose (a carbohydrate)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5501-5
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis involves many chemical reactions; a word summary of the reactants and products is a model of the process."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8306-1
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good thermal and electrical conductors, they are strong, shiny, malleable and ductile."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8306-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ceramics are made from soft substances, becoming hard and brittle when heated."@en ;
  dcterms:modified "2026-02-19T08:26:13.612775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8306-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plastics are made from polymers and there are many types of plastics with very different properties."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8306-4
  a curric:KeyLearningPoint ;
  rdfs:label "An alloy is a mixture of elements including at least one metal."@en ;
  dcterms:modified "2026-02-19T08:26:13.612783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8306-5
  a curric:KeyLearningPoint ;
  rdfs:label "Composites combine materials to create a new material with improved properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.612787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8302-1
  a curric:KeyLearningPoint ;
  rdfs:label "Neutralisation reaction general equation is: base + acid → metal salt + water."@en ;
  dcterms:modified "2026-02-19T08:26:13.612811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8302-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sodium hydroxide has the formula NaOH(aq) and hydrochloric acid has the formula HCl(aq)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8302-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a neutralisation reaction, the metal salt formed is named after the metal (from the base) and acid used."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8302-4
  a curric:KeyLearningPoint ;
  rdfs:label "Common bases include metal oxides and hydroxides."@en ;
  dcterms:modified "2026-02-19T08:26:13.612824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8302-5
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g) and (aq) in chemical equations identify the state of each substance as solid, liquid, gas or in solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6046-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils provide evidence about organisms from long ago and their habitats."@en ;
  dcterms:modified "2026-02-19T08:26:13.612992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6046-2
  a curric:KeyLearningPoint ;
  rdfs:label """All fossils are the mineralised remains of once-living organisms or of traces left behind by organisms."""@en ;
  dcterms:modified "2026-02-19T08:26:13.612996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6046-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that some species have gone extinct."@en ;
  dcterms:modified "2026-02-19T08:26:13.613000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that the features of some species have changed over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.613005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6046-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are limitations to the conclusions and explanations that can be made from fossil evidence."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6450-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a metal reacts with acid bubbles may form, it is exothermic and the metal reduces in size (disappears)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6450-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different metals have varying reactivity with acids."@en ;
  dcterms:modified "2026-02-19T08:26:13.613018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6450-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a metal reacts with an acid, the products are a metal salt and hydrogen gas."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6450-4
  a curric:KeyLearningPoint ;
  rdfs:label """The word equation for a metal and acid reaction is: metal + acid → metal salt + hydrogen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6450-5
  a curric:KeyLearningPoint ;
  rdfs:label """The test for hydrogen gas is to introduce a lit splint, which will make a squeaky pop in hydrogen."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5005-1
  a curric:KeyLearningPoint ;
  rdfs:label "The needle of a plotting compass lines up with the magnetic field of a magnet."@en ;
  dcterms:modified "2026-02-19T08:26:13.613036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5005-2
  a curric:KeyLearningPoint ;
  rdfs:label """A magnetic field line can be followed from the north–seeking pole to the south–seeking pole of a magnet."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5005-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north–seeking pole of another magnet would be forced."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5005-4
  a curric:KeyLearningPoint ;
  rdfs:label "The magnetic field of a bar magnet is symmetrical."@en ;
  dcterms:modified "2026-02-19T08:26:13.613049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5005-5
  a curric:KeyLearningPoint ;
  rdfs:label "Magnetic field lines do not cross over and are continuous."@en ;
  dcterms:modified "2026-02-19T08:26:13.613053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22196-1
  a curric:KeyLearningPoint ;
  rdfs:label """A catalyst speeds up a chemical reaction without being used up or chemically changed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22196-2
  a curric:KeyLearningPoint ;
  rdfs:label """Catalysts are specific to particular reactions; different reactions require different catalysts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22196-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are biological catalysts that speed up reactions in living cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.613065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5010-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnetic door lock uses an electromagnet to pull a magnetic bolt to unlock a door."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5010-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric bell often contains an electromagnet that attracts and moves the striker, making it hit the bell."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5010-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an electromagnet moves the striker in an electric bell, it breaks its own circuit to let the striker spring back."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5010-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motor contains a spinning coil of wire that is an electromagnet."@en ;
  dcterms:modified "2026-02-19T08:26:13.613083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5010-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is a current in the spinning coil of wire in a motor, other magnets around it will push it round."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8310-1
  a curric:KeyLearningPoint ;
  rdfs:label """A more reactive metal will displace another that is less reactive from its salt, in solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8310-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a displacement reaction magnesium displaces copper from copper sulfate(aq) to form magnesium sulfate (aq) and copper."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8310-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement reactions can be used to confirm the position of a metal in the reactivity series for metals."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8310-4
  a curric:KeyLearningPoint ;
  rdfs:label """A metal ore is typically rock that contains a metal in a form that can be extracted."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8310-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon can be used to extract some metals from their ores when carbon is more reactive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.613143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5165-1
  a curric:KeyLearningPoint ;
  rdfs:label """The differences between mechanical and chemical digestion and where they take place."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Food is made up of carbohydrates, proteins and fats."@en ;
  dcterms:modified "2026-02-19T08:26:13.614336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5165-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrates, proteins and fats in food are broken down by digestion into smaller molecules that can be absorbed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5165-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzymes are biological molecules that act as catalysts to speed up chemical digestion of carbohydrate, protein and fat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5165-5
  a curric:KeyLearningPoint ;
  rdfs:label """Enzymes digest carbohydrates into starch and sugars, proteins into amino acids, and fats into fatty acids and glycerol."""@en ;
  dcterms:modified "2026-02-19T08:26:13.614349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6650-1
  a curric:KeyLearningPoint ;
  rdfs:label "Infectious diseases can be passed from one organism to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.614703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6650-2
  a curric:KeyLearningPoint ;
  rdfs:label "Infectious diseases are caused by pathogens including viruses and some bacteria."@en ;
  dcterms:modified "2026-02-19T08:26:13.614711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some lifestyle factors are linked to non-infectious diseases."@en ;
  dcterms:modified "2026-02-19T08:26:13.614716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6650-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-infectious diseases cannot be passed from one organism to another."@en ;
  dcterms:modified "2026-02-19T08:26:13.614720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28955-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thermal insulators can reduce the energy needed to heat a building."@en ;
  dcterms:modified "2026-02-19T08:26:13.616775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28955-2
  a curric:KeyLearningPoint ;
  rdfs:label """Improving a building's insulation makes it easier to heat it using only renewable resources."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28955-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thermostats can control temperature automatically in different rooms and help reduce unnecessary heating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.616783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28955-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the temperature difference between the inside and outside of a house, the faster it warms up or cools down"""@en ;
  dcterms:modified "2026-02-19T08:26:13.616787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28955-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planting near a house increases the outside temperature on cold days and decreases it on hot days"""@en ;
  dcterms:modified "2026-02-19T08:26:13.616792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20053-1
  a curric:KeyLearningPoint ;
  rdfs:label "Asthma is a common non-infectious disease that can cause breathing difficulties."@en ;
  dcterms:modified "2026-02-19T08:26:13.617701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20053-2
  a curric:KeyLearningPoint ;
  rdfs:label "During an asthma attack, the breathing (bronchial) tubes narrow."@en ;
  dcterms:modified "2026-02-19T08:26:13.617705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20053-3
  a curric:KeyLearningPoint ;
  rdfs:label "Symptoms include wheezing and shortness of breath."@en ;
  dcterms:modified "2026-02-19T08:26:13.617709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20053-4
  a curric:KeyLearningPoint ;
  rdfs:label "Symptoms of asthma can be treated using medication taken using an inhaler."@en ;
  dcterms:modified "2026-02-19T08:26:13.617713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20053-5
  a curric:KeyLearningPoint ;
  rdfs:label """Risk factors for asthma include air pollution, smoking, low birth weight, having an allergy, and family history."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28966-1
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation disrupts the carbon cycle because less CO₂ is absorbed from the atmosphere for photosynthesis"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28966-2
  a curric:KeyLearningPoint ;
  rdfs:label """CO₂ is a greenhouse gas in the atmosphere that enhances the greenhouse effect and contributes to climate change"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28966-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation disrupts the water cycle because less water is absorbed and transpired"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28966-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation leads to more surface runoff of water, increasing flooding and putting our food security at risk"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mitigation strategies include reforestation and legal protection of forests to prevent deforestation"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5028-1
  a curric:KeyLearningPoint ;
  rdfs:label "A voltmeter is connected to each side of a cell, battery or component."@en ;
  dcterms:modified "2026-02-19T08:26:13.617769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5028-2
  a curric:KeyLearningPoint ;
  rdfs:label "Voltage (or potential difference) is measured in volts (V)."@en ;
  dcterms:modified "2026-02-19T08:26:13.617773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5028-3
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage across a cell or battery measures the strength with which it can ‘push’ current around a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5028-4
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage across a component in an electric circuit measures the size of ‘push’ that is moving current through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5028-5
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage across each branch of a parallel circuit is the same as the voltage across the cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5020-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves of frequency below 20 Hz usually cannot be heard by humans, so are called infrasound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5020-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves of frequency above 20 000 Hz usually cannot be heard by humans, so are called ultrasound."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5020-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ultrasound waves can cause objects to vibrate, so transfer energy. They do not cause harm to the human body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5020-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ultrasound can be used to image structures inside the body as it reflects from boundaries between tissues."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5020-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ultrasound vibrations can clean delicate objects and can help to treat injuries and illnesses in physiotherapy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5014-1
  a curric:KeyLearningPoint ;
  rdfs:label """As a water wave moves forward, each bit of water is moving up and down (oscillating), not forward."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water waves are transverse waves: the direction of oscillation is 90° to the direction of energy transfer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5014-3
  a curric:KeyLearningPoint ;
  rdfs:label """The amplitude of a water wave is the greatest distance water moves above and below the rest position."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Waves that pass through each other can ‘add up’ or ‘cancel out’; this is called wave superposition."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5014-5
  a curric:KeyLearningPoint ;
  rdfs:label "Water waves reflect from hard barriers, obeying the laws of reflection."@en ;
  dcterms:modified "2026-02-19T08:26:13.617846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves are caused when objects vibrate, causing nearby air particles to vibrate as well."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5017-2
  a curric:KeyLearningPoint ;
  rdfs:label """As a sound wave travels, each bit of air is vibrating parallel to the direction of wave travel, not travelling forwards."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5017-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sound is a longitudinal wave: the direction of vibration is parallel to the direction of energy transfer."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5017-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves are faster in solids/liquids than gases; the particles are very close so vibrations are easily passed on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5017-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves are faster in solids than liquids; the strong forces between particles mean vibrations travel even faster."""@en ;
  dcterms:modified "2026-02-19T08:26:13.617915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Growing crops to feed animals and humans requires significant land use"@en ;
  dcterms:modified "2026-02-19T08:26:13.617921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28965-2
  a curric:KeyLearningPoint ;
  rdfs:label "Converting land for agricultural use is one of the major causes of deforestation"@en ;
  dcterms:modified "2026-02-19T08:26:13.617926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28965-3
  a curric:KeyLearningPoint ;
  rdfs:label "Deforestation results in habitat loss for many species"@en ;
  dcterms:modified "2026-02-19T08:26:13.617930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conversion of land for agriculture is a major cause of habitat loss and biodiversity loss"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28965-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mitigation strategies include changing diets and positive land use change (e.g. reforestation and rewilding)"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28970-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many foods are sold packaged in plastic, which is usually made from non-renewable resources such as fossil fuels"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28970-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plastic waste in landfills and oceans is a pollutant that takes a long time to degrade and can harm organisms"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28970-3
  a curric:KeyLearningPoint ;
  rdfs:label """Biodegradable bioplastics made from renewable resources are a sustainable alternative to traditional plastic packaging"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28970-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic packaging helps prevents food spoilage and reduces food waste"@en ;
  dcterms:modified "2026-02-19T08:26:13.617954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28970-5
  a curric:KeyLearningPoint ;
  rdfs:label """We must weigh up the benefits of using plastic packaging against emissions from production and damage to biodiversity"""@en ;
  dcterms:modified "2026-02-19T08:26:13.617958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Species have adaptations that enable them to live and thrive in the conditions of their habitat"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28968-2
  a curric:KeyLearningPoint ;
  rdfs:label """Human emissions of greenhouse gases are leading to global warming and climate change"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28968-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is changing the conditions in habitats, so species may be less well adapted to live there"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28968-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, species can survive changes in conditions by migrating to a new habitat"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28968-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change, including more frequent extreme weather events, can lead to biodiversity loss"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5025-1
  a curric:KeyLearningPoint ;
  rdfs:label "The thicker a wire, the smaller its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.618092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5025-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the cross–sectional area of a wire, the smaller its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.618096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5025-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current in a wire is a flow of electrons moving between ‘atoms’ (metal ions)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5025-4
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling the cross-sectional area of a wire halves its resistance."@en ;
  dcterms:modified "2026-02-19T08:26:13.618105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the cross-sectional area of a wire doubles the number of electrons that can flow through the wire."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28969-1
  a curric:KeyLearningPoint ;
  rdfs:label "Food production is at risk due to global warming and climate change"@en ;
  dcterms:modified "2026-02-19T08:26:13.618220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change makes extreme weather events more common, and this makes it more challenging to produce food"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28969-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emissions of greenhouse gases from various stages of food production add to the carbon footprint of foods"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in our diet can help us reduce emissions from food production and limit climate change"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28969-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing emissions data for different diets helps us understand the impact of food choices"""@en ;
  dcterms:modified "2026-02-19T08:26:13.618238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22195-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrical appliances and devices use different amounts of energy each second, as indicated by their power rating."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22195-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power is a measure of the amount of energy used by or supplied to a device in one second."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22195-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-19T08:26:13.618347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22195-4
  a curric:KeyLearningPoint ;
  rdfs:label """Multiplying power of a device in kilowatts (kW) by time in hours (h) gives us the energy used in kilowatt–hours (kWh)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22195-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electricity bills are based on the amount of energy units used; 1 unit of energy is equal to 1 kWh."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5019-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves cause our eardrums, tiny bones within our ears, and the cochlea to vibrate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5019-2
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in the cochlea sense vibrations and cause electrical signals to be sent to the brain along a nerve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5019-3
  a curric:KeyLearningPoint ;
  rdfs:label """The brain creates the sensation of hearing a sound when it receives signals from the ear through a nerve."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5019-4
  a curric:KeyLearningPoint ;
  rdfs:label """Human ears can detect sound waves with frequencies between 20 Hz and 20 kHz, being most sensitive to 2–5 kHz waves."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5019-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves below 20 Hz are called infrasound; above 20 kHz, ultrasound. They are not detected by human ears."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current through the battery in a parallel circuit is measured with an ammeter, connected next to one end of the battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5030-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are connections to the rest of the circuit at the ends of each branch in a parallel circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5030-3
  a curric:KeyLearningPoint ;
  rdfs:label """The current through a branch of a parallel circuit is measured between its connections to the rest of the circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5030-4
  a curric:KeyLearningPoint ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the total current through the battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5018-1
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘speed of sound’ is the distance travelled by a sound wave pulse every second, measured in m/s."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sound wave speed depends on the medium: it is about 340 m/s in air, faster in liquids and faster still in solids."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5018-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sound waves can reflect from hard surfaces, travel back and be heard again (an echo)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5018-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound waves (or the distance they travel) can be calculated using the equation: speed = distance ÷ time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5018-5
  a curric:KeyLearningPoint ;
  rdfs:label """In an experiment, measuring longer distances and times means any errors are a smaller proportion of the measurements."""@en ;
  dcterms:modified "2026-02-19T08:26:13.618451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6498-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weathering is the slow breakdown of rocks on Earth's surface. It happens while the rocks are ‘in place’."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6498-2
  a curric:KeyLearningPoint ;
  rdfs:label """Erosion is the process that removes material from where bedrock has been broken down or weathered."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6498-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rock can be weathered biologically, chemically or physically."@en ;
  dcterms:modified "2026-02-19T08:26:13.619560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6498-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rock can be eroded by the wind, rain, or by flowing streams and rivers, oceans, ice flows or gravity."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6498-5
  a curric:KeyLearningPoint ;
  rdfs:label "Small changes caused by weathering and erosion can have large impacts over time."@en ;
  dcterms:modified "2026-02-19T08:26:13.619569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pollinators are animals which transfer pollen from one flower to another, which enables plants to reproduce sexually."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many food crops are pollinated by animal pollinators, including fruits, vegetables and nuts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6662-3
  a curric:KeyLearningPoint ;
  rdfs:label "The majority of pollinators are insects, with bees being the largest group."@en ;
  dcterms:modified "2026-02-19T08:26:13.619638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6662-4
  a curric:KeyLearningPoint ;
  rdfs:label """Food security means having enough affordable and nutritious food in an area or country."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6662-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pollinating insects need to be protected from pesticides, climate change and habitat loss to ensure food security."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reproduction (having offspring) is part of the life cycle of all organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.619698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6620-2
  a curric:KeyLearningPoint ;
  rdfs:label """When organisms reproduce they make offspring of the same kind (species resemblance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6620-3
  a curric:KeyLearningPoint ;
  rdfs:label "Heredity is the process of organisms passing on features to their offspring."@en ;
  dcterms:modified "2026-02-19T08:26:13.619706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6620-4
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring inherit features from both parents, so they look similar to them and one another (family resemblance)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6620-5
  a curric:KeyLearningPoint ;
  rdfs:label """Usually offspring vary and are not identical to their parents or one another (except for identical twins)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Smoking involves inhaling smoke from burning tobacco leaves."@en ;
  dcterms:modified "2026-02-19T08:26:13.619953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tobacco leaves contain nicotine which is a very addictive substance and it affects the body."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6652-3
  a curric:KeyLearningPoint ;
  rdfs:label "Smoking affects the gas exchange system."@en ;
  dcterms:modified "2026-02-19T08:26:13.619963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6652-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smoking increases the risk of diseases such as asthma, COPD, lung cancer and heart disease."""@en ;
  dcterms:modified "2026-02-19T08:26:13.619968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6439-1
  a curric:KeyLearningPoint ;
  rdfs:label """Evaporation can remove solvent from a solution, leading to the production of a saturated solution."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6439-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation reforms a solute as crystals from a saturated solution following a change in conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6439-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solvents evaporate into the air around you during the process of crystallisation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6439-4
  a curric:KeyLearningPoint ;
  rdfs:label "Larger crystals form when the solvent evaporates more slowly."@en ;
  dcterms:modified "2026-02-19T08:26:13.620192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6439-5
  a curric:KeyLearningPoint ;
  rdfs:label "Heating a solution makes the solvent evaporate more quickly."@en ;
  dcterms:modified "2026-02-19T08:26:13.620196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Prey have adaptations to help them avoid being hunted, and predators are adapted to help them capture prey."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6017-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some common adaptations of prey animals are that they have good camouflage or that they are nocturnal."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6017-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some common adaptations of predators are big teeth, good eyesight and the ability to run fast."""@en ;
  dcterms:modified "2026-02-19T08:26:13.620532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6502-1
  a curric:KeyLearningPoint ;
  rdfs:label """Coal is a sedimentary rock that burns because it is made mostly of carbon, with some impurities."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6502-2
  a curric:KeyLearningPoint ;
  rdfs:label "Coal is formed from deep sediments of organic matter made of prehistoric plants."@en ;
  dcterms:modified "2026-02-19T08:26:13.621598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6502-3
  a curric:KeyLearningPoint ;
  rdfs:label """Oil and gas formed from dead plankton mixed in with sediments that formed millions of years ago."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6502-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oil and natural gas are found in pores of sedimentary rock."@en ;
  dcterms:modified "2026-02-19T08:26:13.621606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6502-5
  a curric:KeyLearningPoint ;
  rdfs:label """The organic matter that formed coal, oil and natural gas decomposed into hydrocarbons."""@en ;
  dcterms:modified "2026-02-19T08:26:13.621613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9798-1
  a curric:KeyLearningPoint ;
  rdfs:label "The cells that make up tissue can be viewed using a light microscope."@en ;
  dcterms:modified "2026-02-19T08:26:13.622967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9798-2
  a curric:KeyLearningPoint ;
  rdfs:label "A sample of tissue can be prepared on a slide to view using a microscope."@en ;
  dcterms:modified "2026-02-19T08:26:13.622971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9798-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a stain can make it easier to see some parts of cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.622975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9798-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the magnification and focus of a light microscope enables stained cell structures to be observed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9798-5
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a scientific line drawing."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4986-1
  a curric:KeyLearningPoint ;
  rdfs:label "The names and symbols of the basic components of an electric circuit."@en ;
  dcterms:modified "2026-02-19T08:26:13.622987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4986-2
  a curric:KeyLearningPoint ;
  rdfs:label """A series circuit is an electric circuit with one complete loop from one end of a battery to the other end."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4986-3
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit is built systematically following a circuit diagram in one direction, starting from any point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4986-4
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit diagram is drawn systematically, following the circuit in one direction, starting from any point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.622999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4986-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wires in a circuit diagram are drawn using a ruler for clarity, with no gaps that would indicate a break in the circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4251-1
  a curric:KeyLearningPoint ;
  rdfs:label "The larger the surface of a parachute, the bigger its drag."@en ;
  dcterms:modified "2026-02-19T08:26:13.623197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4251-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gravity pulls down with a steady force."@en ;
  dcterms:modified "2026-02-19T08:26:13.623201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4251-3
  a curric:KeyLearningPoint ;
  rdfs:label """At top speed the force of drag on a parachute is the same size as the force of gravity on the jumper."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4988-1
  a curric:KeyLearningPoint ;
  rdfs:label """One end of a battery has a positive charge and one end has a negative charge, because of chemical reactions inside it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4988-2
  a curric:KeyLearningPoint ;
  rdfs:label "A battery pushes electric charge (electrons) one way round a complete circuit."@en ;
  dcterms:modified "2026-02-19T08:26:13.623280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4988-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are electric charges in all atoms of the wires and components in a circuit, even when it is not turned on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4988-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a circuit is turned on, electrons everywhere in the circuit start moving at the same time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4988-5
  a curric:KeyLearningPoint ;
  rdfs:label """Individual electrons move round a circuit slowly, at a speed of just a few millimetres each second."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4989-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ammeter is used to measure the size of an electric current."@en ;
  dcterms:modified "2026-02-19T08:26:13.623332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4989-2
  a curric:KeyLearningPoint ;
  rdfs:label """An ammeter measures the current flowing through it without affecting the current in the circuit it is connected into."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4989-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electric current is measured in amps (A), which is short for amperes."@en ;
  dcterms:modified "2026-02-19T08:26:13.623340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4989-4
  a curric:KeyLearningPoint ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-02-19T08:26:13.623344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4989-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component to a series circuit changes the current everywhere, on both sides of the component."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4991-1
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage of a battery measures the strength with which it can ‘push’ current around a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4991-2
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage of a component in an electric circuit measures the size of ‘push’ that is moving current through it."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4991-3
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage across each component in an electric circuit adds up to the voltage of the cell or battery."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4991-4
  a curric:KeyLearningPoint ;
  rdfs:label "A battery can be made of several electrical cells added together."@en ;
  dcterms:modified "2026-02-19T08:26:13.623424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4991-5
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage of a battery made of electrical cells added in series is equal to the voltages of the cells added together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Seeds contain an embryo, food store and a tough outer coat, and they are formed in the ovary."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6663-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fruit is the mature and ripened ovary of a seed-producing plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.623479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fruits often contain seeds which will grow into a new plant, given the right conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6663-4
  a curric:KeyLearningPoint ;
  rdfs:label "Seeds are adapted to be dispersed by animals, wind and water."@en ;
  dcterms:modified "2026-02-19T08:26:13.623487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5108-1
  a curric:KeyLearningPoint ;
  rdfs:label """The condensing point and boiling point are the same temperature for a substance, for water this is 100°C."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Steam is water in the gas state."@en ;
  dcterms:modified "2026-02-19T08:26:13.623495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5108-3
  a curric:KeyLearningPoint ;
  rdfs:label "A substance increases in volume in the gas state when boiled."@en ;
  dcterms:modified "2026-02-19T08:26:13.623499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5108-4
  a curric:KeyLearningPoint ;
  rdfs:label "A substance decreases in volume in the liquid state when condensed."@en ;
  dcterms:modified "2026-02-19T08:26:13.623503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5108-5
  a curric:KeyLearningPoint ;
  rdfs:label """Particles move further apart when boiled and move closer together when condensed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Food chains show feeding relationships between organisms and how food moves from one organism to another in a habitat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6026-2
  a curric:KeyLearningPoint ;
  rdfs:label """Biomass is the mass of living material in one or more organisms, and may be estimated."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6026-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pyramids of biomass show the biomass of organisms at each stage in a food chain."@en ;
  dcterms:modified "2026-02-19T08:26:13.623907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6026-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pyramids of biomass use scaled bars to represent the total mass of organisms within a habitat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6026-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pyramids of biomass have the producer at the bottom."@en ;
  dcterms:modified "2026-02-19T08:26:13.623915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4255-1
  a curric:KeyLearningPoint ;
  rdfs:label "Applying a force to a spring will make it extend (stretch)."@en ;
  dcterms:modified "2026-02-19T08:26:13.623919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4255-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of masses suspended on a mass holder will produce constant and measurable forces on a spring."""@en ;
  dcterms:modified "2026-02-19T08:26:13.623923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4255-3
  a curric:KeyLearningPoint ;
  rdfs:label "A set square ensures measuring scales are vertical."@en ;
  dcterms:modified "2026-02-19T08:26:13.623927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4255-4
  a curric:KeyLearningPoint ;
  rdfs:label "Diagrams show how equipment should be set up."@en ;
  dcterms:modified "2026-02-19T08:26:13.623934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4838-1
  a curric:KeyLearningPoint ;
  rdfs:label "Unicellular organisms are made of a single living cell."@en ;
  dcterms:modified "2026-02-19T08:26:13.624310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4838-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multicellular organisms are made of more than one cell (sometimes millions), and different cells take on different jobs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4838-3
  a curric:KeyLearningPoint ;
  rdfs:label """In multicellular organisms, cells join together to form tissues with specific jobs."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4838-4
  a curric:KeyLearningPoint ;
  rdfs:label """An organ is a group of tissues working together to do a specific job, and organs work together in an organ system."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4838-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unicellular organisms have different structures that have adaptations to help them function and stay alive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4247-1
  a curric:KeyLearningPoint ;
  rdfs:label "A level line on a distance-time graph shows a stationary object (no movement)."@en ;
  dcterms:modified "2026-02-19T08:26:13.624347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4247-2
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the gradient (steeper the line) on a distance-time graph, the faster the movement."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4247-3
  a curric:KeyLearningPoint ;
  rdfs:label """Upward and downward sloping lines on a distance-time graph show movement in opposite directions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4247-4
  a curric:KeyLearningPoint ;
  rdfs:label """The average speed between two points is calculated using speed = change in distance ÷ time taken."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5109-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the gas state a substance can flow, it fills the whole of a container and can be compressed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5109-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the gas state, particles of a substance are moving very quickly in random directions with gaps between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5109-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the gas state, particles have enough energy to be free of the attractive forces between them."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5109-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is nothing at all between the particles in a gas."@en ;
  dcterms:modified "2026-02-19T08:26:13.624877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4841-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animal and plant cell models describe common features of cells."@en ;
  dcterms:modified "2026-02-19T08:26:13.624881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4841-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all cells have all these features, and some cells have additional ones."@en ;
  dcterms:modified "2026-02-19T08:26:13.624885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in animals and plants have shapes, sizes, and structures, that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4841-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of specialised cells include red blood cells in animals and root hair cells in plants."""@en ;
  dcterms:modified "2026-02-19T08:26:13.624898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5166-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reagents can be used to test for large food molecules including protein, fat, and carbohydrates such as starch."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5166-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reagents can be used to test for smaller food molecules, such as sugars from the breakdown of starch."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Interpretation of qualitative food test results."@en ;
  dcterms:modified "2026-02-19T08:26:13.625018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4990-1
  a curric:KeyLearningPoint ;
  rdfs:label "Voltage is a commonly used term for potential difference."@en ;
  dcterms:modified "2026-02-19T08:26:13.625022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4990-2
  a curric:KeyLearningPoint ;
  rdfs:label """A voltmeter measures the voltage supplied by a cell or battery or across a component."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4990-3
  a curric:KeyLearningPoint ;
  rdfs:label "A voltmeter is connected across the terminals of a cell, battery, or component."@en ;
  dcterms:modified "2026-02-19T08:26:13.625030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4990-4
  a curric:KeyLearningPoint ;
  rdfs:label "Voltage (or potential difference) is measured in volts (V)."@en ;
  dcterms:modified "2026-02-19T08:26:13.625034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4990-5
  a curric:KeyLearningPoint ;
  rdfs:label """The voltage of a cell or battery indicates the force 'pushing' electric charges around a circuit."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6040-1
  a curric:KeyLearningPoint ;
  rdfs:label "Differences between species are greater than differences within species."@en ;
  dcterms:modified "2026-02-19T08:26:13.625042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6040-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are differences in the features of individuals of the same species, and this is called variation."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6040-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some variation is caused only by the environment (e.g. injuries)."@en ;
  dcterms:modified "2026-02-19T08:26:13.625050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6040-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused only by inherited genetic information in the genome (e.g. blood type)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6040-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation results from a combination of genetic and environmental/lifestyle factors (e.g. body mass)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4257-1
  a curric:KeyLearningPoint ;
  rdfs:label "More force is needed to hold up a bigger mass up in the air."@en ;
  dcterms:modified "2026-02-19T08:26:13.625141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4257-2
  a curric:KeyLearningPoint ;
  rdfs:label "The bigger the mass on a beam, the more the beam bends."@en ;
  dcterms:modified "2026-02-19T08:26:13.625144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4257-3
  a curric:KeyLearningPoint ;
  rdfs:label "The more a beam bends, the greater the force it pushes back with."@en ;
  dcterms:modified "2026-02-19T08:26:13.625148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4257-4
  a curric:KeyLearningPoint ;
  rdfs:label """The bigger the mass on a floor, the more particles in the floor are squashed together."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4257-5
  a curric:KeyLearningPoint ;
  rdfs:label """The more particles in a floor are squashed together, the greater the force they push back with."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4836-1
  a curric:KeyLearningPoint ;
  rdfs:label "The same life processes happen in all living organisms."@en ;
  dcterms:modified "2026-02-19T08:26:13.625271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4836-2
  a curric:KeyLearningPoint ;
  rdfs:label """These life processes include movement, reproduction, sensitivity, growth, respiration, excretion and nutrition."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4836-3
  a curric:KeyLearningPoint ;
  rdfs:label "All living organisms are made from other living organisms when they reproduce."@en ;
  dcterms:modified "2026-02-19T08:26:13.625280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4836-4
  a curric:KeyLearningPoint ;
  rdfs:label "Movement is a sign of life when the organism moves itself to achieve something."@en ;
  dcterms:modified "2026-02-19T08:26:13.625284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4836-5
  a curric:KeyLearningPoint ;
  rdfs:label """All these processes happen at some stage in the life cycle of every living organism."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4840-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant cells have some common structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.625826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4840-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of these structures are common with animal cells, such as the cytoplasm, cell membrane, nucleus and mitochondria."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4840-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plant cells have additional structures including the cell wall and vacuole, and some have chloroplasts."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4840-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each structure in a plant cell has a specific function."@en ;
  dcterms:modified "2026-02-19T08:26:13.625840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4840-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plant cells can be adapted with different shapes and structures."@en ;
  dcterms:modified "2026-02-19T08:26:13.625844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6028-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals have adaptations that help them to survive in their environment."@en ;
  dcterms:modified "2026-02-19T08:26:13.625849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6028-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some adaptations are physical, such as thick fur."@en ;
  dcterms:modified "2026-02-19T08:26:13.625852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some adaptations are behavioural, such as being nocturnal."@en ;
  dcterms:modified "2026-02-19T08:26:13.625856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6028-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in the environment can affect animal biodiversity."@en ;
  dcterms:modified "2026-02-19T08:26:13.625860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9066-1
  a curric:KeyLearningPoint ;
  rdfs:label """The bigger the surface area of a boat’s hull, the bigger the upthrust on it can be."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure in liquid increases with depth because there is more liquid pushing down."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9066-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure in the atmosphere reduces with height because there is less air pushing down."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5008-1
  a curric:KeyLearningPoint ;
  rdfs:label """The more turns of wire in the coil of an electromagnet, the stronger its magnetic field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5008-2
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through the coil of an electromagnet, the stronger its magnetic field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5008-3
  a curric:KeyLearningPoint ;
  rdfs:label """The more closely spaced the coils of wire of an electromagnet, the stronger its magnetic field."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5008-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet made from bare wire will not work if adjacent turns are touching."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5008-5
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes magnetised when it is turned on."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5106-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the solid state, forces of attraction between particles hold them in fixed positions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5106-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the liquid state, particles are held together but have enough energy to break free to move around."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5106-3
  a curric:KeyLearningPoint ;
  rdfs:label """The stronger the force of attraction between particles in a substance, the higher its melting point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5106-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water freezes at 0ºC, room temperature is about 20ºC and body temperature is about 37ºC."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5106-5
  a curric:KeyLearningPoint ;
  rdfs:label "The bulb of a thermometer is made of very thin glass and is delicate."@en ;
  dcterms:modified "2026-02-19T08:26:13.626311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some seeds (e.g. cress seeds) will germinate on cotton wool in the right conditions."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6664-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation and writing a method for factors affecting the germination of seeds on cotton wool."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6664-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding which variable to change to become the independent variable and what values to investigate."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6664-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding which variable to measure to conclude on the effect (the dependent variable)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6664-5
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding which variables to keep the same to ensure a valid conclusion (control variables)."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4261-1
  a curric:KeyLearningPoint ;
  rdfs:label "The whole of an object is floating on water if part of it is above the surface."@en ;
  dcterms:modified "2026-02-19T08:26:13.626749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4261-2
  a curric:KeyLearningPoint ;
  rdfs:label """How well an object floats in a liquid does not depend on the depth of the liquid."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4261-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object floats in water if its shape can push its own mass of water out of the way without going under."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9091-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earth’s atmosphere is mostly within 7 to 15 km of its surface."@en ;
  dcterms:modified "2026-02-19T08:26:13.626761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9091-2
  a curric:KeyLearningPoint ;
  rdfs:label """Earth's atmosphere is 78% N₂ and 21% O₂, with very small amounts of other gases and particles of liquids and solids."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9091-3
  a curric:KeyLearningPoint ;
  rdfs:label "Greenhouse gases keep Earth’s temperature warm enought for human life."@en ;
  dcterms:modified "2026-02-19T08:26:13.626768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9091-4
  a curric:KeyLearningPoint ;
  rdfs:label "The test for oxygen gas is that it relights a glowing splint."@en ;
  dcterms:modified "2026-02-19T08:26:13.626774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9091-5
  a curric:KeyLearningPoint ;
  rdfs:label """The test for carbon dioxide gas is that it forms a white precipitate that turns limewater milky."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4259-1
  a curric:KeyLearningPoint ;
  rdfs:label "A moment causes turning."@en ;
  dcterms:modified "2026-02-19T08:26:13.626802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4259-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moment = force × (perpendicular) distance from the pivot."@en ;
  dcterms:modified "2026-02-19T08:26:13.626806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4259-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moments are measured in Newton-metres (Nm)."@en ;
  dcterms:modified "2026-02-19T08:26:13.626810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5027-1
  a curric:KeyLearningPoint ;
  rdfs:label """A parallel circuit is a circuit with more than one complete loop, from one end of a battery to the other end."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5027-2
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit is built systematically following a circuit diagram, round in one direction, starting from any point."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5027-3
  a curric:KeyLearningPoint ;
  rdfs:label """A parallel circuit is built systematically, completing each loop of the circuit in turn."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5027-4
  a curric:KeyLearningPoint ;
  rdfs:label """A circuit diagram is drawn systematically, following each loop round and completing each one in turn."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5027-5
  a curric:KeyLearningPoint ;
