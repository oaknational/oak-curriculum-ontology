oakcurric:keylearningpoint-lesson-1200-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can plan and test how squashing, bending, twisting and stretching can change the shape of some materials."""@en ;
  dcterms:modified "2026-02-19T08:26:13.625778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-1
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat is where a group of plants and animals live."@en ;
  dcterms:modified "2026-02-19T08:26:13.626384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-2
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat provides the things an animal or plant needs to survive."@en ;
  dcterms:modified "2026-02-19T08:26:13.626390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most living things live in habitats to which they are suited."@en ;
  dcterms:modified "2026-02-19T08:26:13.626394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants live in different habitats, depending on their basic needs."@en ;
  dcterms:modified "2026-02-19T08:26:13.626398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recycling is one of the 3Rs: Reduce, Reuse, Recycle."@en ;
  dcterms:modified "2026-02-19T08:26:13.626453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rubbish needs to be sorted into different materials before it can be recycled."@en ;
  dcterms:modified "2026-02-19T08:26:13.626457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic, glass and wood can be recycled and made into new and useful things."@en ;
  dcterms:modified "2026-02-19T08:26:13.626461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-1
  a curric:KeyLearningPoint ;
  rdfs:label """Squashing, bending, twisting and stretching are ways in which some shapes of objects can be changed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results of a test can show what happens when objects are squashed, bent, twisted and stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some objects are made from materials whose shape cannot be changed when squashed, bent, twisted or stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials do not change back to their original shape on their own after being squashed, bent, twisted or stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans live on a planet called Earth."@en ;
  dcterms:modified "2026-02-19T08:26:13.626783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials come from different places."@en ;
  dcterms:modified "2026-02-19T08:26:13.626787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials may cause harm to the planet when they are made, or if they are not recycled."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials can be found naturally or they are grown, and these can cause less harm to planet Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists design and invent new materials that cause little or no harm to Earth."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-1
  a curric:KeyLearningPoint ;
  rdfs:label "The world is made up of things that are living and not living (non-living)."@en ;
  dcterms:modified "2026-02-19T08:26:13.626816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-2
  a curric:KeyLearningPoint ;
  rdfs:label "A living thing is something that is alive and needs food, water and air."@en ;
  dcterms:modified "2026-02-19T08:26:13.626821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thing that is not living does not need food, water and air because it is not alive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-4
  a curric:KeyLearningPoint ;
  rdfs:label """Living and non-living things can be compared and grouped by looking at what is the same and what is different."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of materials make them suitable or unsuitable for particular uses."""@en ;
  dcterms:modified "2026-02-19T08:26:13.626835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being absorbent is one such property of some materials."@en ;
  dcterms:modified "2026-02-19T08:26:13.626839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-3
  a curric:KeyLearningPoint ;
  rdfs:label "If a material is absorbent, it soaks up something, often a liquid such as water."@en ;
  dcterms:modified "2026-02-19T08:26:13.626843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials are absorbent, and this makes them suitable for certain uses."@en ;
  dcterms:modified "2026-02-19T08:26:13.626847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists test materials to find out which are absorbent and which are not."@en ;
  dcterms:modified "2026-02-19T08:26:13.626853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials can be described in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.627002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-2
  a curric:KeyLearningPoint ;
  rdfs:label "The describing words we use for a material are called its properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.627008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use our senses when describing properties of materials."@en ;
  dcterms:modified "2026-02-19T08:26:13.627012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be compared and grouped on the basis of their simple properties."@en ;
  dcterms:modified "2026-02-19T08:26:13.627017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-1
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other for food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each plant and animal has an important part, or role, to play in a food chain."@en ;
  dcterms:modified "2026-02-19T08:26:13.627530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations, books, the internet and experts provide information about what animals eat."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-1
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat is where a group of plants and animals live."@en ;
  dcterms:modified "2026-02-19T08:26:13.627776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-2
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat provides the things an animal or plant needs to survive."@en ;
  dcterms:modified "2026-02-19T08:26:13.627780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most living things live in habitats to which they are suited."@en ;
  dcterms:modified "2026-02-19T08:26:13.627784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different animals live in different habitats, depending on their basic needs."@en ;
  dcterms:modified "2026-02-19T08:26:13.627788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-1
  a curric:KeyLearningPoint ;
  rdfs:label """A living thing is something that is currently alive and needs food, air and water to stay alive."""@en ;
  dcterms:modified "2026-02-19T08:26:13.627838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Something that is dead was once living but is no longer alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.627842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-3
  a curric:KeyLearningPoint ;
  rdfs:label "A non-living thing is something that has never been alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.627846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-4
  a curric:KeyLearningPoint ;
  rdfs:label "Things can be compared and grouped into alive, dead and never alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.627850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different animals eat different types of food."@en ;
  dcterms:modified "2026-02-19T08:26:13.648306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some animals only eat meat, including the flesh of other animals. They are called carnivores."""@en ;
  dcterms:modified "2026-02-19T08:26:13.648310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals only eat plants or plant products. They are called herbivores."@en ;
  dcterms:modified "2026-02-19T08:26:13.648314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals eat both meat and plants. They are called omnivores."@en ;
  dcterms:modified "2026-02-19T08:26:13.648319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-5
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can be named and grouped according to what they eat."@en ;
  dcterms:modified "2026-02-19T08:26:13.648322Z"^^xsd:dateTime .

