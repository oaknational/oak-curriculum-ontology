  a curric:KeyLearningPoint ;
  rdfs:label """Reptiles are animals that have a backbone, a body covered with scales or hard parts, and are cold blooded."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602630Z"^^xsd:dateTime .

