# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-season
  a curric:Keyword ;
  schema:name "season"@en ;
  schema:description """Seasons are periods of similar weather. In the UK, there are four seasons (spring, summer, autumn and winter)."""@en ;
  dcterms:modified "2026-02-19T08:26:07.147262Z"^^xsd:dateTime .

oakcurric:keyword-winter
  a curric:Keyword ;
  schema:name "winter"@en ;
  schema:description "Winter is the coldest season of the year. It is between autumn and spring."@en ;
  dcterms:modified "2026-02-19T08:26:07.147267Z"^^xsd:dateTime .

oakcurric:keyword-deciduous
  a curric:Keyword ;
  schema:name "deciduous"@en ;
  schema:description "Trees that lose their leaves once a year are deciduous."@en ;
  dcterms:modified "2026-02-19T08:26:07.147271Z"^^xsd:dateTime .

oakcurric:keyword-evergreen
  a curric:Keyword ;
  schema:name "evergreen"@en ;
  schema:description "Trees and bushes that do not lose their leaves in winter are evergreen."@en ;
  dcterms:modified "2026-02-19T08:26:07.147276Z"^^xsd:dateTime .

oakcurric:keyword-observe
  a curric:Keyword ;
  schema:name "observe"@en ;
  schema:description "To observe is to look very closely and use other senses too."@en ;
  dcterms:modified "2026-02-19T08:26:07.147280Z"^^xsd:dateTime .

oakcurric:keyword-compare
  a curric:Keyword ;
  schema:name "compare"@en ;
  schema:description """involves identifying similarities between two or more things, ideas, concepts or texts"""@en ;
  dcterms:modified "2026-02-19T08:26:07.147665Z"^^xsd:dateTime .

oakcurric:keyword-plants
  a curric:Keyword ;
  schema:name "plants"@en ;
  schema:description "A plant is a living thing that often has roots, stem and leaves."@en ;
  dcterms:modified "2026-02-19T08:26:07.148096Z"^^xsd:dateTime .

oakcurric:keyword-flowers
  a curric:Keyword ;
  schema:name "flowers"@en ;
  schema:description "A flower is the part of a plant that makes it able to reproduce."@en ;
  dcterms:modified "2026-02-19T08:26:07.148100Z"^^xsd:dateTime .

oakcurric:keyword-common
  a curric:Keyword ;
  schema:name "common"@en ;
  schema:description "Something that happens in large numbers or you see it a lot."@en ;
  dcterms:modified "2026-02-19T08:26:07.148105Z"^^xsd:dateTime .

oakcurric:keyword-identify
  a curric:Keyword ;
  schema:name "identify"@en ;
  schema:description "To identify something is to be able to name it correctly."@en ;
  dcterms:modified "2026-02-19T08:26:07.148109Z"^^xsd:dateTime .

oakcurric:keyword-spring
  a curric:Keyword ;
  schema:name "spring"@en ;
  schema:description "Spring is the season that comes after winter and before summer."@en ;
  dcterms:modified "2026-02-19T08:26:07.148484Z"^^xsd:dateTime .

oakcurric:keyword-weather
  a curric:Keyword ;
  schema:name "weather"@en ;
  schema:description """Weather is what the conditions are like in a particular place at a particular time. For example, rain, wind or sun."""@en ;
  dcterms:modified "2026-02-19T08:26:07.148488Z"^^xsd:dateTime .

oakcurric:keyword-rain-gauge
  a curric:Keyword ;
  schema:name "rain gauge"@en ;
  schema:description "A rain gauge is a device for measuring how much rain has fallen."@en ;
  dcterms:modified "2026-02-19T08:26:07.148492Z"^^xsd:dateTime .

oakcurric:keyword-measure
  a curric:Keyword ;
  schema:name "measure"@en ;
  schema:description """To measure is to find out the size of something or how much of something there is."""@en ;
  dcterms:modified "2026-02-19T08:26:07.148496Z"^^xsd:dateTime .

oakcurric:keyword-offspring
  a curric:Keyword ;
  schema:name "offspring"@en ;
  schema:description "your children can be referred to as your offspring"@en ;
  dcterms:modified "2026-02-19T08:26:07.148655Z"^^xsd:dateTime .

oakcurric:keyword-human-body
  a curric:Keyword ;
  schema:name "human body"@en ;
  schema:description "The human body is a group of parts that make up a human being."@en ;
  dcterms:modified "2026-02-19T08:26:07.149531Z"^^xsd:dateTime .

oakcurric:keyword-name
  a curric:Keyword ;
  schema:name "name"@en ;
  schema:description "A word by which a person or thing is known."@en ;
  dcterms:modified "2026-02-19T08:26:07.149540Z"^^xsd:dateTime .

oakcurric:keyword-draw
  a curric:Keyword ;
  schema:name "draw"@en ;
  schema:description "When you draw, you make a picture."@en ;
  dcterms:modified "2026-02-19T08:26:07.149544Z"^^xsd:dateTime .

oakcurric:keyword-label
  a curric:Keyword ;
  schema:name "label"@en ;
  schema:description "A label is a sign that gives us information about the thing it is with."@en ;
  dcterms:modified "2026-02-19T08:26:07.149549Z"^^xsd:dateTime .

oakcurric:keyword-life-cycle
  a curric:Keyword ;
  schema:name "life cycle"@en ;
  schema:description "A life cycle is the way in which a living thing changes  throughout its life."@en ;
  dcterms:modified "2026-02-19T08:26:07.149909Z"^^xsd:dateTime .

oakcurric:keyword-material
  a curric:Keyword ;
  schema:name "material"@en ;
  schema:description """A material is what an object is made from. An object can be made from more than one material."""@en ;
  dcterms:modified "2026-02-19T08:26:07.150718Z"^^xsd:dateTime .

oakcurric:keyword-properties
  a curric:Keyword ;
  schema:name "properties"@en ;
  schema:description "The describing words we use for a material are called its properties."@en ;
  dcterms:modified "2026-02-19T08:26:07.150725Z"^^xsd:dateTime .

oakcurric:keyword-suitable
  a curric:Keyword ;
  schema:name "suitable"@en ;
  schema:description """Someone or something that is suitable for a particular purpose or occasion is right or acceptable for it."""@en ;
  dcterms:modified "2026-02-19T08:26:07.150729Z"^^xsd:dateTime .

oakcurric:keyword-waterproof
  a curric:Keyword ;
  schema:name "waterproof"@en ;
  schema:description "A waterproof material does not allow any water to pass through it."@en ;
  dcterms:modified "2026-02-19T08:26:07.150734Z"^^xsd:dateTime .

oakcurric:keyword-investigate
  a curric:Keyword ;
  schema:name "investigate"@en ;
  schema:description """When scientists investigate they are trying to find out what happens when something is changed."""@en ;
  dcterms:modified "2026-02-19T08:26:07.150738Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description "able to continue over a long time"@en ;
  dcterms:modified "2026-02-19T08:26:07.150796Z"^^xsd:dateTime .

oakcurric:keyword-habitat
  a curric:Keyword ;
  schema:name "habitat"@en ;
  schema:description "the natural home or environment of an animal, plant or other organism"@en ;
  dcterms:modified "2026-02-19T08:26:07.150811Z"^^xsd:dateTime .

oakcurric:keyword-research
  a curric:Keyword ;
  schema:name "research"@en ;
  schema:description """Work done to collect information in an organised way in order to increase understanding about a topic is known as research"""@en ;
  dcterms:modified "2026-02-19T08:26:07.150969Z"^^xsd:dateTime .

oakcurric:keyword-autumn
  a curric:Keyword ;
  schema:name "autumn"@en ;
  schema:description "Autumn is the season after summer and before winter."@en ;
  dcterms:modified "2026-02-19T08:26:07.151010Z"^^xsd:dateTime .

oakcurric:keyword-change
  a curric:Keyword ;
  schema:name "change"@en ;
  schema:description "If something changes it does not stay the same."@en ;
  dcterms:modified "2026-02-19T08:26:07.151016Z"^^xsd:dateTime .

oakcurric:keyword-describe
  a curric:Keyword ;
  schema:name "describe"@en ;
  schema:description "To say or write what someone or something is like."@en ;
  dcterms:modified "2026-02-19T08:26:07.151021Z"^^xsd:dateTime .

oakcurric:keyword-heart-rate
  a curric:Keyword ;
  schema:name "heart rate"@en ;
  schema:description "the number of beats per minute (bpm) of the heart"@en ;
  dcterms:modified "2026-02-19T08:26:07.151138Z"^^xsd:dateTime .

oakcurric:keyword-healthy
  a curric:Keyword ;
  schema:name "healthy"@en ;
  schema:description """The health of a living thing is how well or ill it is. A healthy diet keeps a person or animal well."""@en ;
  dcterms:modified "2026-02-19T08:26:07.151159Z"^^xsd:dateTime .

oakcurric:keyword-nutritionist
  a curric:Keyword ;
  schema:name "nutritionist"@en ;
  schema:description "A nutritionist is a scientist who studies food and how it works in your body."@en ;
  dcterms:modified "2026-02-19T08:26:07.151164Z"^^xsd:dateTime .

oakcurric:keyword-choice
  a curric:Keyword ;
  schema:name "choice"@en ;
  schema:description "A choice is the act of picking or choosing something."@en ;
  dcterms:modified "2026-02-19T08:26:07.151169Z"^^xsd:dateTime .

oakcurric:keyword-result
  a curric:Keyword ;
  schema:name "result"@en ;
  schema:description "The result of a test is what happened or what was found out."@en ;
  dcterms:modified "2026-02-19T08:26:07.151173Z"^^xsd:dateTime .

oakcurric:keyword-animals
  a curric:Keyword ;
  schema:name "animals"@en ;
  schema:description "Animals are living things that can move and eat other animals or plants."@en ;
  dcterms:modified "2026-02-19T08:26:07.151717Z"^^xsd:dateTime .

oakcurric:keyword-familiar
  a curric:Keyword ;
  schema:name "familiar"@en ;
  schema:description "If something is familiar, it is well known to you."@en ;
  dcterms:modified "2026-02-19T08:26:07.151722Z"^^xsd:dateTime .

oakcurric:keyword-pets
  a curric:Keyword ;
  schema:name "pets"@en ;
  schema:description "Pets are animals that can be kept at home and looked after by humans."@en ;
  dcterms:modified "2026-02-19T08:26:07.151726Z"^^xsd:dateTime .

oakcurric:keyword-wild-animal
  a curric:Keyword ;
  schema:name "wild animal"@en ;
  schema:description "A wild animal lives freely and finds their own food, water and shelter."@en ;
  dcterms:modified "2026-02-19T08:26:07.151731Z"^^xsd:dateTime .

oakcurric:keyword-group
  a curric:Keyword ;
  schema:name "group"@en ;
  schema:description "To group things is to put similar things together."@en ;
  dcterms:modified "2026-02-19T08:26:07.151735Z"^^xsd:dateTime .

oakcurric:keyword-decay
  a curric:Keyword ;
  schema:name "decay"@en ;
  schema:description "to rot or decompose"@en ;
  dcterms:modified "2026-02-19T08:26:07.151805Z"^^xsd:dateTime .

oakcurric:keyword-exercise
  a curric:Keyword ;
  schema:name "exercise"@en ;
  schema:description """Exercise means using a lot of effort to move our bodies so that they stay fit and healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:07.152373Z"^^xsd:dateTime .

oakcurric:keyword-lungs
  a curric:Keyword ;
  schema:name "lungs"@en ;
  schema:description "The lung is an organ that some animals use to breathe. Mammals have two lungs."@en ;
  dcterms:modified "2026-02-19T08:26:07.152378Z"^^xsd:dateTime .

oakcurric:keyword-muscles
  a curric:Keyword ;
  schema:name "muscles"@en ;
  schema:description "A muscle is a part of our body that helps us to move."@en ;
  dcterms:modified "2026-02-19T08:26:07.152385Z"^^xsd:dateTime .

oakcurric:keyword-senses
  a curric:Keyword ;
  schema:name "senses"@en ;
  schema:description "Humans and animals use their senses to detect what is happening around them."@en ;
  dcterms:modified "2026-02-19T08:26:07.152393Z"^^xsd:dateTime .

oakcurric:keyword-sight
  a curric:Keyword ;
  schema:name "sight"@en ;
  schema:description "Sight is the ability to see things. We use our eyes to see."@en ;
  dcterms:modified "2026-02-19T08:26:07.152397Z"^^xsd:dateTime .

oakcurric:keyword-touch
  a curric:Keyword ;
  schema:name "touch"@en ;
  schema:description "Touch is the ability to feel things. We use our skin to touch."@en ;
  dcterms:modified "2026-02-19T08:26:07.152402Z"^^xsd:dateTime .

oakcurric:keyword-tongue
  a curric:Keyword ;
  schema:name "tongue"@en ;
  schema:description "The tongue is the organ with which we taste. A human's tongue is in its mouth."@en ;
  dcterms:modified "2026-02-19T08:26:07.152408Z"^^xsd:dateTime .

oakcurric:keyword-skin
  a curric:Keyword ;
  schema:name "skin"@en ;
  schema:description "The skin is the organ with which we feel. Skin covers the bodies of animals."@en ;
  dcterms:modified "2026-02-19T08:26:07.152413Z"^^xsd:dateTime .

oakcurric:keyword-temperature
  a curric:Keyword ;
  schema:name "temperature"@en ;
  schema:description "Temperature is a measure of how hot or cold something is."@en ;
  dcterms:modified "2026-02-19T08:26:07.152603Z"^^xsd:dateTime .

oakcurric:keyword-thermometer
  a curric:Keyword ;
  schema:name "thermometer"@en ;
  schema:description "A thermometer is a piece of equipment for measuring temperature."@en ;
  dcterms:modified "2026-02-19T08:26:07.152608Z"^^xsd:dateTime .

oakcurric:keyword-hygiene
  a curric:Keyword ;
  schema:name "hygiene"@en ;
  schema:description "Hygiene means keeping yourself and where you live clean."@en ;
  dcterms:modified "2026-02-19T08:26:07.152888Z"^^xsd:dateTime .

oakcurric:keyword-germs
  a curric:Keyword ;
  schema:name "germs"@en ;
  schema:description """A germ is a living thing that is very small. Some germs keep us healthy and other germs can cause harm and make you ill."""@en ;
  dcterms:modified "2026-02-19T08:26:07.152894Z"^^xsd:dateTime .

oakcurric:keyword-prevent
  a curric:Keyword ;
  schema:name "prevent"@en ;
  schema:description "To prevent something is to stop it from happening."@en ;
  dcterms:modified "2026-02-19T08:26:07.152899Z"^^xsd:dateTime .

oakcurric:keyword-hand-washing
  a curric:Keyword ;
  schema:name "hand washing"@en ;
