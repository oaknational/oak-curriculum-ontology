  dcterms:modified "2026-02-19T08:26:13.601411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of plants can grow from different types of seeds, including trees, fruit and vegetables."""@en ;
  dcterms:modified "2026-02-19T08:26:13.601415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-3
  a curric:KeyLearningPoint ;
