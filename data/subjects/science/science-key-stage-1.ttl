  dcterms:modified "2026-02-19T08:26:13.601427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1173-1
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other"""@en ;
  dcterms:modified "2026-02-19T08:26:13.601431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1173-2
  a curric:KeyLearningPoint ;
