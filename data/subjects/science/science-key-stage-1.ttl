  a curric:Keyword ;
  schema:name "scientist"@en ;
  schema:description "A scientist is a person who learns about science and carries out enquiries."@en ;
  dcterms:modified "2026-02-19T08:26:07.180424Z"^^xsd:dateTime .

oakcurric:keyword-stretch
  a curric:Keyword ;
  schema:name "stretch"@en ;
  schema:description "to make longer or fuller"@en ;
  dcterms:modified "2026-02-19T08:26:07.181919Z"^^xsd:dateTime .

oakcurric:keyword-microhabitat
  a curric:Keyword ;
  schema:name "microhabitat"@en ;
  schema:description """A microhabitat is a very small habitat. It might be just under one tree or log or a single rock pool."""@en ;
  dcterms:modified "2026-02-19T08:26:07.182861Z"^^xsd:dateTime .

oakcurric:keyword-minibeast
  a curric:Keyword ;
  schema:name "minibeast"@en ;
  schema:description "You can call very small creatures, such as insects or spiders, minibeasts."@en ;
  dcterms:modified "2026-02-19T08:26:07.182866Z"^^xsd:dateTime .

oakcurric:keyword-unsuitable
  a curric:Keyword ;
  schema:name "unsuitable"@en ;
  schema:description """Someone or something that is unsuitable for a particular purpose or occasion is not right or acceptable for it."""@en ;
  dcterms:modified "2026-02-19T08:26:07.182897Z"^^xsd:dateTime .

oakcurric:keyword-materials
  a curric:Keyword ;
  schema:name "materials"@en ;
  schema:description """A material is what an object is made from. An object can be made from more than one material."""@en ;
  dcterms:modified "2026-02-19T08:26:07.182901Z"^^xsd:dateTime .

oakcurric:keyword-wood
  a curric:Keyword ;
  schema:name "wood"@en ;
  schema:description "Wood is the material that comes from trees."@en ;
  dcterms:modified "2026-02-19T08:26:07.182967Z"^^xsd:dateTime .

oakcurric:keyword-sort
  a curric:Keyword ;
  schema:name "sort"@en ;
  schema:description "To sort is to put items into different groups."@en ;
  dcterms:modified "2026-02-19T08:26:07.182994Z"^^xsd:dateTime .

oakcurric:keyword-life-processes
  a curric:Keyword ;
  schema:name "life processes"@en ;
  schema:description "These are the processes or actions that all living things do."@en ;
  dcterms:modified "2026-02-19T08:26:07.183078Z"^^xsd:dateTime .

oakcurric:keyword-move
  a curric:Keyword ;
  schema:name "move"@en ;
  schema:description "To change position or to go from one place to another."@en ;
  dcterms:modified "2026-02-19T08:26:07.183083Z"^^xsd:dateTime .

oakcurric:keyword-reuse
  a curric:Keyword ;
  schema:name "reuse"@en ;
  schema:description "When we reuse something, we use it again."@en ;
  dcterms:modified "2026-02-19T08:26:07.183136Z"^^xsd:dateTime .

oakcurric:keyword-protect
  a curric:Keyword ;
  schema:name "protect"@en ;
  schema:description "To protect something is to keep it safe from harm."@en ;
  dcterms:modified "2026-02-19T08:26:07.183258Z"^^xsd:dateTime .

oakcurric:keyword-stretchy
  a curric:Keyword ;
  schema:name "stretchy"@en ;
  schema:description "Something that is stretchy can be pulled to change its shape."@en ;
  dcterms:modified "2026-02-19T08:26:07.183323Z"^^xsd:dateTime .

oakcurric:keyword-damage
  a curric:Keyword ;
  schema:name "damage"@en ;
  schema:description """When something is spoiled or harmed, it is damaged. If you damage something, it will not work well and may be broken."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183407Z"^^xsd:dateTime .

oakcurric:keyword-wildlife-friendly-garden
  a curric:Keyword ;
  schema:name "wildlife-friendly garden"@en ;
  schema:description """A wildlife-friendly garden is a garden that attracts wildlife such as butterflies, birds and minibeasts."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183475Z"^^xsd:dateTime .

oakcurric:keyword-squash
  a curric:Keyword ;
  schema:name "squash"@en ;
  schema:description "You can squash something by squeezing or pressing on it."@en ;
  dcterms:modified "2026-02-19T08:26:07.183479Z"^^xsd:dateTime .

oakcurric:keyword-bend
  a curric:Keyword ;
  schema:name "bend"@en ;
  schema:description "To bend something is to curve it so that it is not straight."@en ;
  dcterms:modified "2026-02-19T08:26:07.183484Z"^^xsd:dateTime .

oakcurric:keyword-twist
  a curric:Keyword ;
  schema:name "twist"@en ;
  schema:description """When you twist something, you hold each end and turn them in opposite directions."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183488Z"^^xsd:dateTime .

oakcurric:keyword-shape
  a curric:Keyword ;
  schema:name "shape"@en ;
  schema:description "A shape is the outline or form of something."@en ;
  dcterms:modified "2026-02-19T08:26:07.183693Z"^^xsd:dateTime .

oakcurric:keyword-non-living
  a curric:Keyword ;
  schema:name "non-living"@en ;
  schema:description """Something which is non-living is not alive. It does not show any of the characteristics of living things."""@en ;
  dcterms:modified "2026-02-19T08:26:07.183736Z"^^xsd:dateTime .

oakcurric:keyword-absorbent
  a curric:Keyword ;
  schema:name "absorbent"@en ;
  schema:description "Absorbent materials soak up other materials."@en ;
  dcterms:modified "2026-02-19T08:26:07.183741Z"^^xsd:dateTime .

oakcurric:keyword-feel
  a curric:Keyword ;
  schema:name "feel"@en ;
  schema:description "To feel something is to touch it."@en ;
  dcterms:modified "2026-02-19T08:26:07.183786Z"^^xsd:dateTime .

oakcurric:keyword-dead
  a curric:Keyword ;
  schema:name "dead"@en ;
  schema:description "Something that is dead was once living and now is no longer alive."@en ;
  dcterms:modified "2026-02-19T08:26:07.183970Z"^^xsd:dateTime .

oakcurric:keyword-never-alive
  a curric:Keyword ;
  schema:name "never alive"@en ;
  schema:description "Something that has never been alive cannot be called alive or dead."@en ;
  dcterms:modified "2026-02-19T08:26:07.183975Z"^^xsd:dateTime .

oakcurric:keyword-meat
  a curric:Keyword ;
  schema:name "meat"@en ;
  schema:description "Meat is the flesh of an animal when it is used for food."@en ;
  dcterms:modified "2026-02-19T08:26:07.188851Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-snows-winter
  a curric:Misconception ;
  curric:statement "It always snows in winter."@en ;
  curric:correction """Explanation including different kinds of weather that the pupils may experience in winter."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347386Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-flowers-year
  a curric:Misconception ;
  curric:statement """Pupils may think that all plants have flowers all year round and that all flowers look the same."""@en ;
  curric:correction """Use examples of plants at different times of the year, both with and without flowers, as well as examples of plants with flowers of various colours, shapes, and sizes."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347636Z"^^xsd:dateTime .

oakcurric:misconception-pupils-associate-different-seasons-activities
  a curric:Misconception ;
  curric:statement """Pupils may associate different seasons with activities, rather than physical characteristics like the weather."""@en ;
  curric:correction """Explanation of different weathers that pupils may experience in different seasons."""@en ;
  dcterms:modified "2026-02-19T08:26:10.347756Z"^^xsd:dateTime .

oakcurric:misconception-human-body-single-entity-rather
  a curric:Misconception ;
  curric:statement """The human body is a single entity rather than being made of different parts that work together."""@en ;
  curric:correction "Examples of different parts of the body and the jobs that they do."@en ;
  dcterms:modified "2026-02-19T08:26:10.348140Z"^^xsd:dateTime .

oakcurric:misconception-children-instinctively-classify-objects-observational
  a curric:Misconception ;
  curric:statement """Children may instinctively classify objects by observational similarities or through knowledge of use rather than by the material from which the objects are made."""@en ;
  curric:correction """Importance of testing each material to check if we are correct and not to rely on what we think we already know. Scientists ask questions and test their ideas."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348552Z"^^xsd:dateTime .

oakcurric:misconception-fat-diet-cause-ill-health
  a curric:Misconception ;
  curric:statement "All fat in the diet can cause ill health."@en ;
  curric:correction """Explanation that humans need some fat in their diet but that they should not eat large amounts of fat regularly if they want to have a healthy diet."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348710Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-four-legged-mammals
  a curric:Misconception ;
  curric:statement "Pupils may think that only four-legged mammals that are pets, are animals."@en ;
  curric:correction """Discuss a range of familiar animals that can be kept as pets that are not just four-legged."""@en ;
  dcterms:modified "2026-02-19T08:26:10.348895Z"^^xsd:dateTime .

oakcurric:misconception-household-chores-examples-physical-activity
  a curric:Misconception ;
  curric:statement """Household chores are not examples of physical activity but sports, running and climbing are. Playing, dancing and walking are not fitness activities."""@en ;
  curric:correction "Examples of a variety of different physical activities."@en ;
  dcterms:modified "2026-02-19T08:26:10.349152Z"^^xsd:dateTime .

oakcurric:misconception-lot-people-think-touch-our
  a curric:Misconception ;
  curric:statement "A lot of people think we only touch with our hands rather than our skin."@en ;
  curric:correction """Examples including touching with other parts of body such as feet, or touching an arm against a cold metal table leg and feeling the difference in temperature."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349194Z"^^xsd:dateTime .

oakcurric:misconception-seen-healthy-unhealthy-linked-personal
  a curric:Misconception ;
  curric:statement """Being seen as ‘healthy’ or ‘unhealthy’ is linked to personal attributes as well as physical attributes (such as regarding an unhealthy character as lazy or untidy)."""@en ;
  curric:correction """Explanation that everyone can take steps to be healthy and that good hygiene is an important part of being healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349419Z"^^xsd:dateTime .

oakcurric:misconception-children-think-plants-look-same
  a curric:Misconception ;
  curric:statement """Children may think that all plants look the same/similar with the same style petals and leaves."""@en ;
  curric:correction """Provide examples of flowering plants with leaves and petals of different shapes, sizes and colour."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349602Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-balanced-diet-include
  a curric:Misconception ;
  curric:statement """Pupils may think that a ‘balanced’ diet should include equal-sized proportions of the different food groups (rather than appropriate amounts of each food group)."""@en ;
  curric:correction """Explanation that humans need to eat different amounts of foods, depending on how healthy or unhealthy they are for us. Explanation of the importance of eating different types of food."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349753Z"^^xsd:dateTime .

oakcurric:misconception-children-think-offspring-resemble-their
  a curric:Misconception ;
  curric:statement "Children may think that all offspring resemble their parents."@en ;
  curric:correction "Examples of offspring that resemble their parents and of those who do not."@en ;
  dcterms:modified "2026-02-19T08:26:10.349762Z"^^xsd:dateTime .

oakcurric:misconception-children-think-animals-same-body
  a curric:Misconception ;
  curric:statement """Children may think that all animals have the same body structure, e.g. four legs."""@en ;
  curric:correction """Examples of different structures, e.g. fish, birds, that clearly show that not all animals look similar or have the same body structure."""@en ;
  dcterms:modified "2026-02-19T08:26:10.349837Z"^^xsd:dateTime .

oakcurric:misconception-idea-health-relates-physical-health
  a curric:Misconception ;
  curric:statement "The idea of health only relates to physical health, in particular ‘fitness’."@en ;
  curric:correction """Explanation that there are different ways of staying healthy and the importance of teeth brushing."""@en ;
  dcterms:modified "2026-02-19T08:26:10.350224Z"^^xsd:dateTime .

oakcurric:misconception-plants-flowers-grown-pots
  a curric:Misconception ;
  curric:statement "Plants have flowers and are grown in pots."@en ;
  curric:correction "Examples of plants in different environments and different sorts of plants."@en ;
  dcterms:modified "2026-02-19T08:26:10.350231Z"^^xsd:dateTime .

oakcurric:misconception-same-amount-daylight-season
  a curric:Misconception ;
  curric:statement "We have the same amount of daylight in every season."@en ;
  curric:correction """Explanation of how day length changes throughout the year and is shorter during winter."""@en ;
  dcterms:modified "2026-02-19T08:26:10.351327Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-humans-use-different
  a curric:Misconception ;
  curric:statement "Pupils may not know how humans use different senses to stay safe."@en ;
  curric:correction """Examples of different scenarios where humans use different senses to check for danger and to stay safe."""@en ;
  dcterms:modified "2026-02-19T08:26:10.351429Z"^^xsd:dateTime .

oakcurric:misconception-children-think-trees-look-same
  a curric:Misconception ;
  curric:statement "Children may think that all trees look the same."@en ;
  curric:correction "Examples of different types of trees with differing features."@en ;
  dcterms:modified "2026-02-19T08:26:10.351791Z"^^xsd:dateTime .

oakcurric:misconception-pupils-associate-sunny-weather-summer
  a curric:Misconception ;
  curric:statement "Pupils may associate sunny weather with summer and not winter."@en ;
  curric:correction """Explanation that there are different types of weather in winter, but the temperature is generally cooler than during other seasons."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352045Z"^^xsd:dateTime .

oakcurric:misconception-children-think-animals-offspring-smaller
  a curric:Misconception ;
  curric:statement """Children may think that an animal’s offspring is always a smaller version of the parent."""@en ;
  curric:correction """Include examples of animals whose offspring do not resemble them e.g. caterpillar/butterfly, swan/cygnet, tadpoles/frogs etc."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352104Z"^^xsd:dateTime .

oakcurric:misconception-children-realise-trees-plants
  a curric:Misconception ;
  curric:statement "Children may not realise that trees are plants."@en ;
  curric:correction "Explanation that trees are a type of plant."@en ;
  dcterms:modified "2026-02-19T08:26:10.352173Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sunny-summer
  a curric:Misconception ;
  curric:statement "Pupils may think that it is always sunny in summer."@en ;
  curric:correction """Explanation that there are different types of weather in summer but the temperature is generally warmer than during other seasons."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352370Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-animals-eat-same
  a curric:Misconception ;
  curric:statement """Pupils may think that all animals eat the same food, and also have food provided by humans."""@en ;
  curric:correction """Visuals to show lots of examples of different animals eating different food, and getting it in different ways."""@en ;
  dcterms:modified "2026-02-19T08:26:10.352717Z"^^xsd:dateTime .

oakcurric:misconception-different-animals-need-different-things
  a curric:Misconception ;
  curric:statement "Different animals need different things in order to stay alive."@en ;
  curric:correction """Examples of different types of animals and how they need the same things to stay alive e.g. different foods they eat."""@en ;
  dcterms:modified "2026-02-19T08:26:10.476918Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plant-without-light
  a curric:Misconception ;
  curric:statement """Pupils may think that a plant without light will grow less, rather than grow taller initially."""@en ;
  curric:correction """Ensure opportunities for first-hand observation of plants growing without light over an extended period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.478710Z"^^xsd:dateTime .

oakcurric:misconception-children-realise-humans-animals
  a curric:Misconception ;
  curric:statement "Children may not realise that humans are animals."@en ;
  curric:correction "Clear explanation that humans are a type of animal."@en ;
  dcterms:modified "2026-02-19T08:26:10.480298Z"^^xsd:dateTime .

oakcurric:misconception-trees-leaves-lose-year
  a curric:Misconception ;
  curric:statement "All trees have leaves that they lose every year."@en ;
  curric:correction "Show a range of examples of different types of trees including evergreen."@en ;
  dcterms:modified "2026-02-19T08:26:10.482290Z"^^xsd:dateTime .

oakcurric:misconception-humans-animals-four-legged-mammals
  a curric:Misconception ;
  curric:statement """Humans are not animals. Only four legged mammals such as dogs that can be kept as pets are animals."""@en ;
  curric:correction """Use of humans as an example animal in this lesson. Use of a wide variety of mammals, including wild animals, as examples in this lesson."""@en ;
  dcterms:modified "2026-02-19T08:26:10.482304Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-grow-seeds
  a curric:Misconception ;
  curric:statement "Pupils may think that all plants grow from seeds."@en ;
  curric:correction """Show everyday examples of plants that grow from bulbs, as well as plant bulbs to observe them grow."""@en ;
  dcterms:modified "2026-02-19T08:26:10.483513Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-remove-one-growing
  a curric:Misconception ;
  curric:statement """Pupils may not know how to remove only one growing condition in order to compare plants."""@en ;
  curric:correction """Explain that a plant without water will still require warmth and light, and discuss group A, B and C's options as a whole class."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484490Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-warmer-plant-better
  a curric:Misconception ;
  curric:statement """Pupils may think the warmer the plant, the better it grows and the healthier it is."""@en ;
  curric:correction """Show that different plants need different amounts of warmth, and to expose a plant to high or low temperatures could cause it damage"""@en ;
  dcterms:modified "2026-02-19T08:26:10.484785Z"^^xsd:dateTime .

oakcurric:misconception-everything-lives-water-fish-fish
  a curric:Misconception ;
  curric:statement """Everything that lives in water is a fish and that fish cannot breathe underwater."""@en ;
  curric:correction """Examples of fish and amphibians with explanation that both can live in water. Explanation that fish use gills to breathe underwater."""@en ;
  dcterms:modified "2026-02-19T08:26:10.484794Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-need-lots
  a curric:Misconception ;
  curric:statement "Pupils may think that plants need lots of water everyday"@en ;
  curric:correction """Remind pupils that different plants need different amounts of water, and a plant with too much, or not enough, water could become unhealthy"""@en ;
  dcterms:modified "2026-02-19T08:26:10.488545Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-arrows-food-chain
  a curric:Misconception ;
  curric:statement "Pupils may think that the arrows in the food chain mean \"eats\"."@en ;
  curric:correction """Explain that the arrows in a food chain mean "is food for". Provide pupils with lots of opportunities to use this language."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488553Z"^^xsd:dateTime .

oakcurric:misconception-children-think-plants-planted-humans
  a curric:Misconception ;
  curric:statement "Children may think that all plants have been planted by humans."@en ;
  curric:correction """Clear explanation that plants can grow in the wild without need for human intervention or support."""@en ;
  dcterms:modified "2026-02-19T08:26:10.488867Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-food-comes-shops
  a curric:Misconception ;
  curric:statement """Pupils may think that all food comes from shops. Pupils may think that all plants are edible."""@en ;
  curric:correction """Clear examples showing edible plants in their natural habitats. Warning that some plants can be harmful if ingested."""@en ;
  dcterms:modified "2026-02-19T08:26:10.493560Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-observe-using-our
  a curric:Misconception ;
  curric:statement "Pupils may think that we observe using only our eyes"@en ;
  curric:correction """Show how we can use other senses to observe, we might listen, smell or touch when we observe"""@en ;
  dcterms:modified "2026-02-19T08:26:10.493568Z"^^xsd:dateTime .

oakcurric:misconception-children-think-two-stages-animals
  a curric:Misconception ;
  curric:statement """Children may think that there are only two stages in an animal's life; child and adult."""@en ;
  curric:correction """Refer to other stages in animal's lives. For example, in humans we have children, teenagers, adults and the elderly."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494264Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plants-appear-ground
  a curric:Misconception ;
  curric:statement """Pupils may think plants appear from the ground or that big plants like trees do not grow from seeds."""@en ;
  curric:correction """Ensure first-hand experience of handling and planting a range of seeds, and observing them grow."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494433Z"^^xsd:dateTime .

oakcurric:misconception-food-chain-shows-full-detail
  a curric:Misconception ;
  curric:statement """A food chain shows the full detail and is a true representation of what organisms eat."""@en ;
  curric:correction """Include explanations that animals have a varied diet and eat many different foods. A food chain only shows one food source at a time."""@en ;
  dcterms:modified "2026-02-19T08:26:10.494445Z"^^xsd:dateTime .

oakcurric:misconception-animals-fur-four-legs-amphibians
  a curric:Misconception ;
  curric:statement """All animals have fur and four legs. Amphibians and reptiles are the same. All birds fly."""@en ;
  curric:correction """Range of birds and reptiles and clear explanation of what defines each type of animal."""@en ;
  dcterms:modified "2026-02-19T08:26:10.495036Z"^^xsd:dateTime .

oakcurric:misconception-habitats-microhabitats-minibeasts-insects
  a curric:Misconception ;
  curric:statement "All habitats are microhabitats. All minibeasts are insects."@en ;
  curric:correction """Clear explanation and definition of what a microhabitat is and how it differs from other habitats, e.g. ocean, forest, Arctic, desert etc. Examples of a variety of minibeasts including insects and non-insects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502359Z"^^xsd:dateTime .

oakcurric:misconception-pupils-instinctively-classify-objects-observational
  a curric:Misconception ;
  curric:statement """Pupils may instinctively classify objects by observational similarities or through knowledge of use rather than by the material from which the objects are made."""@en ;
  curric:correction """Examples of different objects made from different materials to promote discussion of the properties of materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502394Z"^^xsd:dateTime .

oakcurric:misconception-science-engineering-careers-male-jobs
  a curric:Misconception ;
  curric:statement """Science and engineering careers are male jobs. Females cannot work in science or engineering."""@en ;
  curric:correction """Examples of women working in science and explanations that science jobs are for everybody."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502428Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-object-material-s
  a curric:Misconception ;
  curric:statement """Pupils may confuse the object with the material/s that it is made from. e.g. only fabrics are materials, building materials are materials, the word ‘rock’ describes an object rather than a material."""@en ;
  curric:correction """Explanation of what an object is with a definition. Opportunities to name objects. Definition of what a material is and how this is applied to objects."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502547Z"^^xsd:dateTime .

oakcurric:misconception-comparing-extent-given-property-two
  a curric:Misconception ;
  curric:statement """In comparing the extent of a given property in two materials children may rely purely on observation rather than on active testing."""@en ;
  curric:correction "Opportunity to use real-life results to answer questions and draw conclusions."@en ;
  dcterms:modified "2026-02-19T08:26:10.502591Z"^^xsd:dateTime .

oakcurric:misconception-plants-move-because-cannot-see
  a curric:Misconception ;
  curric:statement """Plants do not move because we cannot see them move. All things that move are alive."""@en ;
  curric:correction """Examples of how plants move very slowly (e.g. sunflower following sun throughout the day). Examples of things like wind-up or battery operated toys that move but are not alive."""@en ;
  dcterms:modified "2026-02-19T08:26:10.502687Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-stretch-materials-go
  a curric:Misconception ;
  curric:statement """Pupils might not think that when you stretch some materials, they go back to the shape they were (and some snap)."""@en ;
  curric:correction """Examples of different materials, some that stretch and return to their previous length, some that stretch and do not return to their previous length, and some materials that do not stretch and may snap if stretched."""@en ;
  dcterms:modified "2026-02-19T08:26:10.503016Z"^^xsd:dateTime .

oakcurric:misconception-children-think-minibeasts-insects-children
  a curric:Misconception ;
  curric:statement """Children may think that all minibeasts are insects. Children may think that all minibeasts like the same conditions (e.g. damp and dark)."""@en ;
  curric:correction """Provide examples of different microhabitats with differing conditions, e.g. light, dark, wet etc."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504042Z"^^xsd:dateTime .

oakcurric:misconception-children-think-objects-squashed-bent
  a curric:Misconception ;
  curric:statement """Children may think that all objects that can be squashed, bent, twisted or stretched may return to their previous shape (elasticity)."""@en ;
  curric:correction """Opportunities to explore the impact of squashing, bending, twisting and stretching different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504071Z"^^xsd:dateTime .

oakcurric:misconception-habitats-divided-hot-cold-habitats
  a curric:Misconception ;
  curric:statement """Habitats can only be divided into 'hot' and 'cold' habitats. Plants are not living things."""@en ;
  curric:correction """Examples of different habitats where plants live and how these meet their needs, including different conditions such as underwater, desert, grasslands and savannah."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504283Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-objects-squashed-bent
  a curric:Misconception ;
  curric:statement """Pupils may think that all objects that can be squashed, bent, twisted or stretched will return to their previous shape."""@en ;
  curric:correction """Opportunities to explore the impact of squashing, bending, twisting and stretching different materials."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504376Z"^^xsd:dateTime .

oakcurric:misconception-children-become-confused-materials-called
  a curric:Misconception ;
  curric:statement """Children can become confused with what some materials are called when they look at where these materials come from, e.g. paper that makes books is processed after originally coming from trees."""@en ;
  curric:correction """Ensure a clear distinction between the natural materials that are used to make our man-made materials, e.g. a bookshelf is made from wood and a magazine is made from paper."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504436Z"^^xsd:dateTime .

oakcurric:misconception-plants-living-things-because-cannot
  a curric:Misconception ;
  curric:statement "Plants are not living things because we cannot see them move."@en ;
  curric:correction "Show examples of living things, including plants."@en ;
  dcterms:modified "2026-02-19T08:26:10.504449Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-soft-means-smooth
  a curric:Misconception ;
  curric:statement """Some pupils may think that soft means smooth. Younger pupils may find it hard to describe a material based only on its properties (and not its function)."""@en ;
  curric:correction """Opportunities to rehearse expressing ideas and describing properties. Teacher to model and correct as necessary, making clear the difference between the function of an object and the properties of its material(s)."""@en ;
  dcterms:modified "2026-02-19T08:26:10.504504Z"^^xsd:dateTime .

oakcurric:misconception-food-chains-put-living-things
  a curric:Misconception ;
  curric:statement "Food chains put living things in order of importance."@en ;
  curric:correction "Explanation of interdependence of each living thing within a food chain."@en ;
  dcterms:modified "2026-02-19T08:26:10.504969Z"^^xsd:dateTime .

oakcurric:misconception-animals-habitat-like-its-home
  a curric:Misconception ;
  curric:statement """An animal’s habitat is like its ‘home’. Habitats can be divided into 'hot' and 'cold' habitats."""@en ;
  curric:correction "Examples and photographs showing different habitats."@en ;
  dcterms:modified "2026-02-19T08:26:10.505063Z"^^xsd:dateTime .

oakcurric:misconception-non-living-thing-something-dead
  a curric:Misconception ;
  curric:statement "A non-living thing is something that is dead."@en ;
  curric:correction "Examples demonstrating that non-living things have never been alive."@en ;
  dcterms:modified "2026-02-19T08:26:10.505078Z"^^xsd:dateTime .

oakcurric:misconception-animals-eat-same-food
  a curric:Misconception ;
  curric:statement "All animals eat the same food."@en ;
  curric:correction "Examples of animals that eat different types of food."@en ;
  dcterms:modified "2026-02-19T08:26:10.511845Z"^^xsd:dateTime .
