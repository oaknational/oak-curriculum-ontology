  dcterms:modified "2026-02-19T08:26:13.599440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-2
  a curric:KeyLearningPoint ;
  rdfs:label "Often plants are grown as crops for people to eat."@en ;
  dcterms:modified "2026-02-19T08:26:13.599446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some crops can be grown locally, including in gardens and school grounds."@en ;
  dcterms:modified "2026-02-19T08:26:13.599450Z"^^xsd:dateTime .

