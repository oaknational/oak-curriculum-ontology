  dcterms:modified "2026-02-19T08:26:13.590023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wildflowers grow from seeds, often without any help from people."@en ;
  dcterms:modified "2026-02-19T08:26:13.590027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wildflowers can be looked at closely and compared using observation skills."@en ;
  dcterms:modified "2026-02-19T08:26:13.590031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wildflowers can be identified and named using simple secondary sources of information."""@en ;
  dcterms:modified "2026-02-19T08:26:13.590035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-1
  a curric:KeyLearningPoint ;
