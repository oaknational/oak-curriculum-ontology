oakcurric:keylearningpoint-lesson-1137-5
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be sorted into fish and amphibians using simple classification skills."""@en ;
  dcterms:modified "2026-02-19T08:26:13.582736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants are living things, they need water to grow, stay alive and and keep healthy."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-2
  a curric:KeyLearningPoint ;
  rdfs:label """Without water, a plant can dry out, drop leaves, lose its strength and begin to wilt."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in plant growth can be compared and described using observation skills."@en ;
  dcterms:modified "2026-02-19T08:26:13.589383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants can survive without water for different amounts of time."@en ;
  dcterms:modified "2026-02-19T08:26:13.589387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unhealthy plants without water can sometimes be recovered with water within a short period of time."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals need food from plants and other animals to stay alive."@en ;
  dcterms:modified "2026-02-19T08:26:13.589395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-2
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other for food."""@en ;
  dcterms:modified "2026-02-19T08:26:13.589399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-3
  a curric:KeyLearningPoint ;
  rdfs:label "A food chain begins with a plant."@en ;
  dcterms:modified "2026-02-19T08:26:13.589403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-1
  a curric:KeyLearningPoint ;
