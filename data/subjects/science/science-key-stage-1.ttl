  a curric:KeyLearningPoint ;
  rdfs:label "Different birds and reptiles have different names."@en ;
  dcterms:modified "2026-02-19T08:26:13.602634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1136-4
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be sorted into birds and reptiles using simple classification skills."""@en ;
  dcterms:modified "2026-02-19T08:26:13.602638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-1
  a curric:KeyLearningPoint ;
