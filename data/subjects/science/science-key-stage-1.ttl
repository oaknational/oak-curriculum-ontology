  a curric:KeyLearningPoint ;
  rdfs:label "Sustainable crops in the UK include wheat, fruit, potatoes and other vegetables."@en ;
  dcterms:modified "2026-02-19T08:26:13.599458Z"^^xsd:dateTime .

