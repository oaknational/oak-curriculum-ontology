  dcterms:modified "2026-02-19T08:26:13.599466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-2
  a curric:KeyLearningPoint ;
  rdfs:label """Healthy plants grow strong and upright. The leaves are firm and flowers fruit and root systems are well formed."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-3
  a curric:KeyLearningPoint ;
  rdfs:label """An unhealthy plant can be dry, dull, brown or yellow in colour and unable to stand upright."""@en ;
  dcterms:modified "2026-02-19T08:26:13.599474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-4
  a curric:KeyLearningPoint ;
  rdfs:label "The growth of plants over time can be observed and recorded in different ways."@en ;
  dcterms:modified "2026-02-19T08:26:13.599478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-1
  a curric:KeyLearningPoint ;
  rdfs:label "All animals grow and change from birth to being an  adult"@en ;
  dcterms:modified "2026-02-19T08:26:13.600966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-2
  a curric:KeyLearningPoint ;
  rdfs:label """The journey of an animal from beginning until it is fully grown is called its life cycle"""@en ;
  dcterms:modified "2026-02-19T08:26:13.600970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can use observation skills to describe the stage an animal has reached in its life cycle"""@en ;
  dcterms:modified "2026-02-19T08:26:13.600974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-1
  a curric:KeyLearningPoint ;
