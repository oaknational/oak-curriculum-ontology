# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sfc
  a curric:Keyword ;
  schema:name "SFC"@en ;
  schema:description "silent final consonant: silent letter (d, s, t, x) at the end of a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.347251Z"^^xsd:dateTime .

oakcurric:keyword-sfe
  a curric:Keyword ;
  schema:name "SFe"@en ;
  schema:description "silent final 'e': silent 'e' at the end of a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.347256Z"^^xsd:dateTime .

oakcurric:keyword-faire
  a curric:Keyword ;
  schema:name "faire"@en ;
  schema:description "French verb meaning 'to do, make'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347275Z"^^xsd:dateTime .

oakcurric:keyword-adjective
  a curric:Keyword ;
  schema:name "adjective"@en ;
  schema:description "describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.348100Z"^^xsd:dateTime .

oakcurric:keyword-noun
  a curric:Keyword ;
  schema:name "noun"@en ;
  schema:description "a naming word for people, places or things"@en ;
  dcterms:modified "2026-06-07T15:30:02.348107Z"^^xsd:dateTime .

oakcurric:keyword-verb
  a curric:Keyword ;
  schema:name "verb"@en ;
  schema:description "a doing, being or having word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348112Z"^^xsd:dateTime .

oakcurric:keyword-ain
  a curric:Keyword ;
  schema:name "[(a)in]"@en ;
  schema:description "sound-symbol correspondence (SSC) pronounced as in ‘train’"@en ;
  dcterms:modified "2026-06-07T15:30:02.348502Z"^^xsd:dateTime .

oakcurric:keyword-tu
  a curric:Keyword ;
  schema:name "tu"@en ;
  schema:description "possessve adjective meaning 'your'"@en ;
  dcterms:modified "2026-06-07T15:30:02.348736Z"^^xsd:dateTime .

oakcurric:keyword-present-tense
  a curric:Keyword ;
  schema:name "present tense"@en ;
  schema:description "tells the reader the action is happening now"@en ;
