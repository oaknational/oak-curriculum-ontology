# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-23540-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [(a)in] sounds like the ‘ain’ in the French word
  ‘train’; [in] and [ain] sound the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23540-2
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article ‘des’ is the French word for the determiner ‘some’."@en ;
  dcterms:modified "2026-06-07T15:30:29.004566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23540-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Combien de ?’ is how to ask ‘how many?’"@en ;
  dcterms:modified "2026-06-07T15:30:29.004570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23568-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC (sound-symbol correspondence) [ien] is pronounced as in the word
  'chien'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23568-2
  a curric:KeyLearningPoint ;
  rdfs:label """In French all nouns are either masculine or feminine. This is grammatical gender. It
  is not the same as male or female."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23568-3
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we refer to pets as ‘he’ or ‘she’ but we use ‘it’ to refer to animals in
  general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23568-4
  a curric:KeyLearningPoint ;
  rdfs:label """In French, we use il (he) and elle (she) to mean it. We use il and elle to refer
  both to pets and to animals in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23568-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must match the gender of the noun they describe in French. Regular
  adjectives add an -e in the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23624-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs (sound-symbol correspondences) [au], [eau] and [o] make the same sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.004623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23624-2
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to a masculine noun use the indefinite article un. To refer to a feminine
  noun use the indefinite article une."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23624-3
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to a plural noun use the indefinite article 'des' (some). It does not
  change based on the gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23624-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective agreement is the change of spelling of an adjective based on the gender
  and number of the noun it describes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23624-5
  a curric:KeyLearningPoint ;
  rdfs:label """We often add an 'e' to make an adjective feminine and an 's' to make it plural. Add
  an 'es' to make it feminine plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23640-1
  a curric:KeyLearningPoint ;
  rdfs:label """The final letter of a word is often silent in French due to SFCs (silent final
  consonants) and SFes (silent final 'e's)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23640-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'faire' can mean 'to do, doing' or 'to make, making'."@en ;
  dcterms:modified "2026-06-07T15:30:29.251592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23640-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Faire' can be combined with a range of nouns for activities at home. E.g. 'faire le
  lit' (to make the bed)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23640-4
  a curric:KeyLearningPoint ;
  rdfs:label """'I do, make' is 'je fais', 'he does, makes' is 'il fait' and 'she does, makes' is
  'elle fait'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23556-1
  a curric:KeyLearningPoint ;
  rdfs:label """Accents can change the pronunciation of a letter in French. The SSCs [e], [è] and
  [é] make different sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23556-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Manger' (to eat) and 'passer' (to spend) are two regular -er verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.252260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23556-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French, there is only one way to talk about things in the present tense: je
  regarde."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23556-4
  a curric:KeyLearningPoint ;
  rdfs:label """In English, there are two ways to refer to the present: I watch and I am
  watching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23556-5
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: (je) -e, (tu)
  -es, (il) -e and (elle) -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23537-1
  a curric:KeyLearningPoint ;
  rdfs:label """For closed [eu] the tongue is near the top of the mouth, for open [eu] the tongue is
  near the bottom of the mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23537-2
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article 'the' in French is 'le' for masculine and 'la' for feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23537-3
  a curric:KeyLearningPoint ;
  rdfs:label """L' is the definite article used in front of masculine and feminine nouns starting
  with a vowel sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23541-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [(a)in] is a nasal sound; the vowel [a] is an oral
  sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23541-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Il y a' means both there is and there are."@en ;
  dcterms:modified "2026-06-07T15:30:29.255801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23541-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.255806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23536-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say a closed vowel [eu], your tongue is near the top of your mouth,
  closing it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23536-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say an open vowel [eu], your tongue is near the top of your mouth,
  opening it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23536-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [eu] is open when followed by r, f, l, but closed
  before x, s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23536-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both nouns and definite articles have a grammatical gender in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.256604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23536-5
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article ‘the’ in French is ‘le’ for masculine and ‘la’ for feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23620-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC (sound-symbol correspondence) [oi] is pronounced as in 'trois'."@en ;
  dcterms:modified "2026-06-07T15:30:29.258205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23620-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mardi Gras is a popular French celebration (Shrove Tuesday). People make 'les
  crêpes' and take part in carnival parades."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23620-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Haiti, the Mardi Gras carnival is often known as : Mardi Gras or 'Kanaval' (in
  Haitian Creole)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23620-4
  a curric:KeyLearningPoint ;
  rdfs:label "A negative sentence states something that is not true or is not happening."@en ;
  dcterms:modified "2026-06-07T15:30:29.258219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23620-5
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we add 'don’t' before the verb. In French we use 'ne' and 'pas' around
  the verb: je ne chante pas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23610-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [é], [er], [et] and [ez] are spelt differently but they make the exact same
  sound, as in 'bébé'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23610-2
  a curric:KeyLearningPoint ;
  rdfs:label """-er verbs follow the same verb endings: add -e with je, il and elle, and -es with tu
  in the singular form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23610-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the plural form, we use -ons with 'nous' and -ez with 'vous': nous célébrons,
  vous célébrez."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23610-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'some' in French, we use 'des'. This is an indefinite article."@en ;
  dcterms:modified "2026-06-07T15:30:29.258675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23610-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike 'un and 'une' (meaning 'a'), 'des' does not change based on the gender of the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23567-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter c is soft before the letters e and i. It is hard before the letters a, o
  and u."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23567-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter ç (c cedilla) makes a soft sound before a, o and u."@en ;
  dcterms:modified "2026-06-07T15:30:29.258932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23567-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pronouns il and elle can be translated as it in French, as every French noun has
  a gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23567-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives have masculine forms 'mon' and 'ton' and feminine forms 'ma'
  and 'ta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23534-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [-ez] and 'et', meaning and, sound the same as [é]
  and [-er]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23534-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs in the present tense change ending to match the pronoun: 'je' -e, 'tu'
  -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23534-3
  a curric:KeyLearningPoint ;
  rdfs:label "Endings -e and -es sound the same because of the silent final consonant."@en ;
  dcterms:modified "2026-06-07T15:30:29.259582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23576-1
  a curric:KeyLearningPoint ;
  rdfs:label """In French, you change a statement into a question by raising your voice at the end.
  This is an intonation question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23576-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'être' (to be) and 'avoir' (to have) are two important verbs to know in
  French. They are irregular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23576-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'parler' (to speak) is an -er verb. Other regular -er verbs follow the same
  verb endings pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23576-4
  a curric:KeyLearningPoint ;
  rdfs:label "In French, most adjectives go after the noun. These are postnominal adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.260738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23576-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must agree with the gender of the noun they describe: un vélo gris, une
  voiture grise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23614-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letters è and ê make the same sound, it is different to [e]. Accents can change
  the pronunciation of a letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23614-2
  a curric:KeyLearningPoint ;
  rdfs:label "Haiti gained independence from France on the 1st January 1804."@en ;
  dcterms:modified "2026-06-07T15:30:29.261203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23614-3
  a curric:KeyLearningPoint ;
  rdfs:label "To refer to one person in French, we use the pronouns il or elle (he or she)."@en ;
  dcterms:modified "2026-06-07T15:30:29.261207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23614-4
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to more than one person in French, we use the pronouns ils or elles (they
  in the masculine or feminine forms)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23614-5
  a curric:KeyLearningPoint ;
  rdfs:label """Tout le monde means everyone. It uses the 3rd person singular of the verb, not the
  third person plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [on] and [om] make the same sound. They are nasal vowels. We use [om]
  before a 'p' or a 'b': tomber, compter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23606-2
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to one boy we use 'il est': he is. To refer to a group of boys (or boys and
  girls) we use 'ils sont': they are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23606-3
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to one girl we use 'elle est': she is. To refer to a group of girls we use
  'elles sont': they are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23606-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives change spelling based on the gender and number of the noun they describe.
  This is called adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23597-1
  a curric:KeyLearningPoint ;
  rdfs:label """The final consonant of a word is often silent in French. We call this SFC for Silent
  Final Consonant: dans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23597-2
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel 'e' is often silent at the end of a word. We call this SFe, Silent Final
  ‘e’: timide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23597-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives change spelling based on the gender of the noun they describe."@en ;
  dcterms:modified "2026-06-07T15:30:29.262678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23597-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most adjectives add an 'e' in the feminine form: perdu, perdue. Some adjectives
  change spelling: sérieux, sérieuse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23597-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives end in an 'e' in both the masculine and feminine forms: calme."@en ;
  dcterms:modified "2026-06-07T15:30:29.262686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23648-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [s] sounds like 'z' in English. It is a 'hard' sound when it is between two
  vowels, including in a liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23648-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is 'soft' when at the beginning of a word/syllable, before/after a consonant and
  where there is a double [ss]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23648-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'mon' to mean 'my' for masculine nouns and 'ma' for feminine nouns: 'mon
  chien' (my dog), 'ma sœur' (my sister)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23648-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also use 'mon' (my) or 'ton' (your) for nouns beginning with a vowel or a silent
  'h': 'mon amie' (my female friend)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23648-5
  a curric:KeyLearningPoint ;
  rdfs:label """For plural nouns, use 'mes' for 'my' and 'tes' for 'your': 'mes parents' (my
  parents) 'tes amis' (your friends)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many sports in French are cognates but their pronunciation is quite different and
  therefore needs practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23646-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'aimer' + 'le, la' to say which sport you like e.g. 'j'aime le football'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23646-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'jouer' + 'à + le, la' to say which sport you play e.g. 'je joue au
  football'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23646-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can join two clauses together to form longer sentences e.g. 1) 'Quand il fait
  beau ...' 2) '... je joue au tennis'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23557-1
  a curric:KeyLearningPoint ;
  rdfs:label """Accents can change the pronunciation of a letter in French. The SSCs [e], [è] and
  [é] make different sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23557-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Manger' (to eat) and 'passer' (to spend) are two regular -er verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.263695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23557-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French, there is only one way to talk about things in the present tense: 'je
  regarde'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23557-4
  a curric:KeyLearningPoint ;
  rdfs:label """In English, there are two ways to refer to the present: 'I watch' and 'I am
  watchin'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23557-5
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: 'je' -e, 'tu'
  -es, 'il' -e and 'elle' -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23626-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter s is normally a silent final consonant. If followed by a word starting
  with a vowel, the s is not silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23626-2
  a curric:KeyLearningPoint ;
  rdfs:label """When followed by a word starting with a vowel, there is a liaison: 'des
  ordinateurs'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23626-3
  a curric:KeyLearningPoint ;
  rdfs:label "To refer to the first person plural of the verb 'avoir', we use 'nous avons'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23626-4
  a curric:KeyLearningPoint ;
  rdfs:label "To refer to the second person plural of the verb 'avoir', we use 'vous avez'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23626-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Vous avez' and 'nous avons' have a liaison."@en ;
  dcterms:modified "2026-06-07T15:30:29.263730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23642-1
  a curric:KeyLearningPoint ;
  rdfs:label """In French the letter 'c' is naturally soft before the letters 'e' or 'i' and hard
  before the letters 'a', 'o' or 'u'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23642-2
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ç/c] is pronounced as in 'centre' and 'français'. The cedilla 'ç' softens
  the hard 'c' before 'a', 'o' or 'u'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23642-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'faire' means both 'to do' and 'to make'."@en ;
  dcterms:modified "2026-06-07T15:30:29.264889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23642-4
  a curric:KeyLearningPoint ;
  rdfs:label """'I do/make' is 'je fais'. 'You do/make' is 'tu fais'. 'He does/makes' is 'il fait'.
  'She does/makes' is 'elle fait'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23642-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Faire' can be used with a range of nouns to express different activities, e.g.
  'faire la cuisine' (to do the cooking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23643-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to revisit French vocabulary regularly to keep our knowledge strong
  and healthy (like a plant!)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23643-2
  a curric:KeyLearningPoint ;
  rdfs:label """I do, make is 'je fais', you do, make is 'tu fais', 'he does, makes' is 'il fait'
  and 'she does, makes' is 'elle fait'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23643-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Faire' can be used with a range of nouns to express different activities e.g.
  'faire la cuisine' (to do the cooking)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23643-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make a yes/no question clear, we can add 'est-ce que' (‘is it that…?) at the
  start of any statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23643-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a ‘what’ question, we can add 'qu'est-ce que' (‘what is it that…?’) at the
  start of any statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23618-1
  a curric:KeyLearningPoint ;
  rdfs:label """Accents can change the pronunciation of a letter. This is an acute accent: é, grave
  accent: è, a circumflex accent: ê."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23618-2
  a curric:KeyLearningPoint ;
  rdfs:label """La Chandeleur is a popular 'fête' in France, it is a similar celebration to 'Shrove
  Tuesday'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23618-3
  a curric:KeyLearningPoint ;
  rdfs:label "A negative sentence states something that is not true or is not happening."@en ;
  dcterms:modified "2026-06-07T15:30:29.267109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23618-4
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we add 'don’t' before the verb. In French we use 'ne' and 'pas' around
  the verb: je ne chante pas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23618-5
  a curric:KeyLearningPoint ;
  rdfs:label "Before a vowel 'ne' changes to: n' (je n'aime pas les chiens)."@en ;
  dcterms:modified "2026-06-07T15:30:29.267117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23566-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter c makes a soft sound before the letters e and i. It makes a hard sound
  before the letters a, o and u."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23566-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter ç (c cedilla) makes a soft sound before a, o and u."@en ;
  dcterms:modified "2026-06-07T15:30:29.267124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23566-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pronouns 'il' and 'elle' can be translated as 'it' in French, as every French
  noun has a gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23566-4
  a curric:KeyLearningPoint ;
  rdfs:label """'La Francophonie' refers to countries in the world which share the common language
  of French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23566-5
  a curric:KeyLearningPoint ;
  rdfs:label "La fête des mères is celebrated across 'la Francophonie'."@en ;
  dcterms:modified "2026-06-07T15:30:29.267137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23644-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'il fait' usually means 'he does/makes'. For example 'il fait la cuisine'.
  (He does the cooking.)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23644-2
  a curric:KeyLearningPoint ;
  rdfs:label """We also use 'il fait' to mean 'it is' for describing the weather. For example 'il
  fait froid'. (It is cold.)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the preposition 'à' to describe the weather 'in' a town or city e.g. 'Il fait
  froid à Calais.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.267387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23644-4
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about the weather 'in' a feminine country use 'en', for a masculine country
  use 'au'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23644-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use the preposition 'dans' to talk about the weather 'in' the cardinal points
  e.g. 'Il fait beau dans le Nord.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.267394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23577-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to practise key vocabulary regularly."@en ;
  dcterms:modified "2026-06-07T15:30:29.268353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23577-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis' is from the verb 'être' and means 'I am', e.g. 'je suis Sophie' ('I am
  Sophie')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23577-3
  a curric:KeyLearningPoint ;
  rdfs:label """'J'ai', from the verb 'avoir', means I have: 'j'ai un chat' (I have a cat). Use
  'j'ai' for age: 'j'ai six ans' (I am 6)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23577-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing a letter, think carefully about formal or informal greetings and
  sign-offs: 'salut', 'Monsieur', 'Madame'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23634-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [oi] is pronounced as in the verb 'voir' (to
  see)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-31 in French can be tricky to remember and so they must be practised
  regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23634-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say how many of something there is/are in French, use 'il y a' + number or 'des'
  (some). 'Il y a trois salles'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23634-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'there isn't a/an' or 'there aren't any' in French, use 'il n'y a pas de/d''.
  'Il n'y a pas de salles.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.269168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23634-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Il n'y a pas' is always followed by 'de' or 'd'', never by 'un/une' or 'des'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23612-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [é], [er], [et] and [ez] are spelt differently but they make the exact same
  sound, as in the word: répéter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23612-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two different ways to say 'you' in French. 'Tu' is singular (one person)
  and 'vous' is plural (2+ people)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23612-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'tu' when talking to one young person or to an adult you know well."@en ;
  dcterms:modified "2026-06-07T15:30:29.269869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23612-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'vous' when talking to one adult you do not know well. 'Vous' can be both plural
  or formal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23612-5
  a curric:KeyLearningPoint ;
  rdfs:label """To make a noun plural in French, often add an -s. Nouns ending in -au or -eu add -x.
  Nouns ending in -al change to -aux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23565-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must agree with the noun they describe in French. They can be either
  masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Regular feminine adjectives add an -e: 'une voiture lente'. This is a SFe (silent
  final e)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23565-3
  a curric:KeyLearningPoint ;
  rdfs:label "In English, adjectives come before the noun: 'a grey bike'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23565-4
  a curric:KeyLearningPoint ;
  rdfs:label """In French, most adjectives go after the noun: 'un vélo gris'. These are called
  postnominal adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23565-5
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb 'très' means very. It goes between the noun and the adjective in French:
  'un vélo très gris'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23533-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [é] can be contrasted for practice with the sound
  [e]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23533-2
  a curric:KeyLearningPoint ;
  rdfs:label """French infinitive verbs translate two ways into English, e.g., ‘to sing’ and
  ‘singing’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23533-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising word recall often helps to secure word knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.270545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23562-1
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘e’ at the end of a word in French makes no sound, it is a SFe (silent
  final e)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23562-2
  a curric:KeyLearningPoint ;
  rdfs:label """J’ai means I have and tu as means you have. These are singular forms of the verb
  avoir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ask a question in French by raising your voice at the end of a statement. This is
  called an intonation question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23562-4
  a curric:KeyLearningPoint ;
  rdfs:label """An intonation question is a closed question. The answer can be either oui (yes) or
  non (no)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23552-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [j] and soft [g] sound the same, as in
  'aujourd'hui' (today) and 'courageux' (brave)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23552-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ça va' can be both a question: 'Is it going OK?' or 'how’s it going'? and an
  answer: 'it's going OK' or 'I'm OK'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23552-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means 'to have'. It can be translated as 'to be, being' with certain
  expressions, e.g. 'j'ai chaud' (I am hot)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23546-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [am/em] sounds the same as [an/en], as in the months
  'janvier' and 'septembre'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23546-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many French months of the year are cognates but are pronounced differently from
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23546-3
  a curric:KeyLearningPoint ;
  rdfs:label """When followed by a vowel, 'mon' changes from a nasal to an oral sound, e.g. mon
  anniversaire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23596-1
  a curric:KeyLearningPoint ;
  rdfs:label """The final consonant of a word is often silent in French. We call this SFC for Silent
  Final Consonant: dans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23596-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb être means to be or being. Use the verb être with adjectives to describe
  people: il est heureux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23596-3
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective must agree with the gender of the noun it describes; this is called
  adjective agreement: elle est heureuse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23596-4
  a curric:KeyLearningPoint ;
  rdfs:label """After the verb être, a liaison is optional: je suis amusante (you can pronounce the
  SFC 's' or not)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23596-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask an information question, put a question word at the end of a statement.
  'Comment' is how and 'qui' is who."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23553-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many French word-final consonants are silent; words ending in -c, -r, -f and -l may
  be exceptions, e.g. 'mal', 'peur'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23553-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Être' means to be. 'Avoir' means to have."@en ;
  dcterms:modified "2026-06-07T15:30:29.273462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23553-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' can sometimes be translated as 'to be, being', with certain expressions,
  e.g. 'j'ai chaud', I am hot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23553-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Avoir mal' means 'to be in pain' or 'to be sick'."@en ;
  dcterms:modified "2026-06-07T15:30:29.273471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23553-5
  a curric:KeyLearningPoint ;
  rdfs:label """With a part of the body 'avoir mal' means that something hurts, e.g. 'j'ai mal à la
  tête', my head hurts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23623-1
  a curric:KeyLearningPoint ;
  rdfs:label """The e at the end of the word makes no sound. This is a Silent final e (SFe). The
  consonant before a SFe is pronounced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23623-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives change spelling based on the gender of the noun they describe. Most
  adjectives add an e in the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23623-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'avoir' means to have: j'ai (I have), tu as (you have), il a (he has), elle
  a (she has)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23623-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'être' means to be: je suis (I am), tu es (you are), il est (he is), elle
  est (she is)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23623-5
  a curric:KeyLearningPoint ;
  rdfs:label """'S' and 't' are silent final consonants. 'As' and 'a' sound the same and 'es' and
  'est' sound the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23555-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often add -e in the feminine form to describe a girl, woman or feminine
  noun. This is adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives are irregular in the feminine form, e.g. 'beau' (m), 'belle'
  (f)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23555-3
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting vocabulary regularly is important to strengthen one's memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.275088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23608-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound [eu] can be pronounced as an open or closed vowel sound, like in 'peur' or
  'un peu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23608-2
  a curric:KeyLearningPoint ;
  rdfs:label """The closed [eu] is pronounced like 'un peu'; your tongue is near the top of your
  mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23608-3
  a curric:KeyLearningPoint ;
  rdfs:label """The open [eu] is pronounced like 'peur'; your tongue is near the bottom of your
  mouth. The mouth is more open."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23608-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Il' is he and 'elle' is she. 'They' is 'ils' (a groups of boys, or boys and girls)
  and 'elles' (a group of girls)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23608-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can also use 'il' and 'elle' to mean 'it', and 'ils' and 'elles' to mean 'they'
  referring to both people and things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23650-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [tion] is pronounced as in 'attention'. It is an 's' sound, different to the
  'sh' sound of 'tion' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23650-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'il fait' usually means 'he does, makes', but it is used with weather in
  French to mean 'it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23650-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'do' with sports use 'faire' + 'de', e.g. 'je fais du sport' ('I do
  sport')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23650-4
  a curric:KeyLearningPoint ;
  rdfs:label """Remember to use 'faire' + 'un/une' with other nouns, e.g. 'je fais un gâteau' ('I am
  making a cake')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23650-5
  a curric:KeyLearningPoint ;
  rdfs:label """Remember, to say 'play' with sports use 'jouer' + 'à', e.g. 'je joue au tennis' ('I
  play tennis')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23649-1
  a curric:KeyLearningPoint ;
  rdfs:label """French has three words for 'my' and three for 'your'. You have to look at the noun
  that follows to choose the right one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23649-2
  a curric:KeyLearningPoint ;
  rdfs:label """For singular masculine nouns, we use 'mon' (my) and 'ton' (your), and for feminine
  nouns 'ma' (my) and 'ta' (your)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23649-3
  a curric:KeyLearningPoint ;
  rdfs:label "For masculine and feminine plural nouns we use 'mes' (my) and 'tes' (your)."@en ;
  dcterms:modified "2026-06-07T15:30:29.285498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23649-4
  a curric:KeyLearningPoint ;
  rdfs:label """To ask 'which' with a masculine noun, use 'quel': 'Tu joues à quel sport ?' (Which
  sport do you play?)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23649-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask 'which' with a feminine noun, use 'quelle': 'Tu fais quelle activité ?'
  (Which activity do you do?)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23616-1
  a curric:KeyLearningPoint ;
  rdfs:label """The e at the end of the word makes no sound. It is a Silent final e -SFe. An é at
  the end of a word is pronounced: bébé."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23616-2
  a curric:KeyLearningPoint ;
  rdfs:label "The consonant before a SFe is pronounced: timide."@en ;
  dcterms:modified "2026-06-07T15:30:29.285535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23616-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are different ways to ask closed (yes/no) questions in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.285584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change a statement into a question by raising your voice at the end: tu aimes
  l'histoire ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.285607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23616-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'est-ce que' at the start of a statement. Est-ce que literally means ‘is it
  that’: est-ce que tu aimes l'histoire ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.285614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23601-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letters [in], [ain], [im] and [aim] make the same sound: matin, main, simple,
  faim."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23601-2
  a curric:KeyLearningPoint ;
  rdfs:label """The question word quand means 'when'. When saying your birthday in French, the
  number always comes before the month."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23601-3
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we use ordinal numbers with dates (27th); in French, we use cardinal
  numbers (27)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23601-4
  a curric:KeyLearningPoint ;
  rdfs:label """When saying a date in French, we use 'le' before the number to say (on) the: c'est
  le trois avril."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23601-5
  a curric:KeyLearningPoint ;
  rdfs:label "If we add a day to a date, we no longer need 'le': c'est mardi trois avril."@en ;
  dcterms:modified "2026-06-07T15:30:29.286969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23598-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound [an/en] makes a nasal sound. When you say a nasal vowel, air passes
  through your nose and your mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23598-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sound [a] makes an oral sound. When you say an oral vowel, air passes through
  your mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23598-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'être' means to be, being. 'Nous sommes' means we are. It is the first
  person plural of 'être'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives change spelling based on the gender and number of the noun they describe.
  This is called adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23598-5
  a curric:KeyLearningPoint ;
  rdfs:label """We often add an 's' to adjectives in the plural form. It is a SFC (silent final
  consonant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23539-1
  a curric:KeyLearningPoint ;
  rdfs:label """When numbers 2, 3 and 10 are followed by a noun beginning with a vowel, the -s and
  -x are pronounced; this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23539-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.291585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23539-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contrasting ‘il y a’ and ‘il a’ for practice helps to distinguish between them."@en ;
  dcterms:modified "2026-06-07T15:30:29.291589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23558-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondences (SSCs) [è] and [ai] make the same sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.294764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23558-2
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives have masculine forms 'mon', 'ton' and feminine forms 'ma' and
  'ta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23558-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Aimer' is a regular -er verb meaning 'to like'."@en ;
  dcterms:modified "2026-06-07T15:30:29.294772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23558-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: (je) -e, (tu)
  -es, (il) -e and (elle) -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23554-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound [è/ê] is pronounced as in the word 'tête'."@en ;
  dcterms:modified "2026-06-07T15:30:29.304948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23554-2
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'de' can be translated as 'of'; to show possession, for example: 'le
  frère de Sam', Sam's brother."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23554-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'de' (of) can also show description, for example: 'le Carnaval de
  Menton', Menton Carnival."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23551-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some numbers are exceptions to the SFC rule and do not have silent final consonants,
  e.g. 5, 6, 7, 8, 9, 10."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23551-2
  a curric:KeyLearningPoint ;
  rdfs:label """When numbers 2, 3, 6, 10 are followed by a noun beginning with a vowel, the -s and
  -x are pronounced; this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23551-3
  a curric:KeyLearningPoint ;
  rdfs:label """Avoir means 'to have, having'; it can also be translated into English as ‘to be,
  being’ with certain expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Avoir is also used for age, e.g. ‘j’ai quatre ans’, I am four years old."@en ;
  dcterms:modified "2026-06-07T15:30:29.304974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23530-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [u] sounds like the 'u' in 'tu' which means
  'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23530-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ou] sounds like the 'ou' in 'nous' which means
  'we'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23530-3
  a curric:KeyLearningPoint ;
  rdfs:label """These two SSCs sound similar but they are different, so it is important to practise
  their pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23530-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading a French story may seem challenging; focus first on all the words you know,
  using these to work out other words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23604-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [u] and [ou] make a different sound. [u] is pronounced as in 'tu' and [ou]
  is pronounced as in 'nous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23604-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two different ways of saying 'you' in French: 'tu' and 'vous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.307649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23604-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Tu es' means 'you are' when talking to one person. 'vous êtes' means 'you are' when
  talking to more than one person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23604-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Rarement', 'maintenant', 'souvent' and 'toujours' are adverbs meaning 'rarely',
  'now', 'often' and 'always'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives change spelling based on the gender and number of the noun they describe.
  This is called adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23636-1
  a curric:KeyLearningPoint ;
  rdfs:label "Québec is a region of Canada where French is the official language."@en ;
  dcterms:modified "2026-06-07T15:30:29.308391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23636-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [ai] is pronounced as in 'vrai' (true)."@en ;
  dcterms:modified "2026-06-07T15:30:29.308395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Directions in French use capital letters: 'le Nord' (north), 'l'Est' (east), 'le
  Sud' (south) and 'l'Ouest' (west)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23636-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb aller is irregular: 'je vais' means 'I go', 'il va' means 'he goes' and
  'elle va' means 'she goes'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23548-1
  a curric:KeyLearningPoint ;
  rdfs:label """[(a)in] sounds like the 'ain' in the French word 'main', hand; [in] and [ain] sound
  the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23548-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 1-12 go before nouns to indicate how many there are."@en ;
  dcterms:modified "2026-06-07T15:30:29.312280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23548-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most numbers don't change their spelling for gender or number, apart from 'one'
  which can be 'un' or 'une'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23548-4
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article 'des' is the French word for the determiner 'some'."@en ;
  dcterms:modified "2026-06-07T15:30:29.312288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23548-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Combien de ?' is how to ask 'how many?'"@en ;
  dcterms:modified "2026-06-07T15:30:29.312292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23625-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs (sound-symbol correspondences) [au], [eau] and [o] make the same sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.314986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23625-2
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to a plural noun use the indefinite article des (some). It does not change
  based on the gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23625-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective agreement is the change of spelling of an adjective based on the gender
  and number of the noun it describes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23625-4
  a curric:KeyLearningPoint ;
  rdfs:label """We often add an 'e' to make an adjective feminine and an 's' to make it plural. Add
  an 'es' to make it feminine plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23625-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Il y a' means 'there are'. 'Ce sont' means 'these are'. 'Ce sont' is the plural
  form of 'c'est'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23572-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [-tion] and [-ssion] make the same sound. Unlike the English 'sh' sound,
  they make a 's' sound in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23572-2
  a curric:KeyLearningPoint ;
  rdfs:label "An infinitive tells us the general meaning of a verb: parler (to speak)."@en ;
  dcterms:modified "2026-06-07T15:30:29.315200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23572-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say who is doing the action, we change the verb to a finite form, e.g. je parle
  (I speak)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23572-4
  a curric:KeyLearningPoint ;
  rdfs:label """A 1-verb structure is when just one finite verb appears in a sentence, e.g. je parle
  français."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23572-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a 2-verb structure, a finite verb is followed by a second verb in the infinitive
  form: j'aime parler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23564-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must agree with the noun they describe in French. They can be either
  masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23564-2
  a curric:KeyLearningPoint ;
  rdfs:label """Regular feminine adjectives add an -e: une voiture lente. This is a SFe (silent
  final e)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23564-3
  a curric:KeyLearningPoint ;
  rdfs:label "In English, adjectives come before the noun: 'a grey bike'."@en ;
  dcterms:modified "2026-06-07T15:30:29.318420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23564-4
  a curric:KeyLearningPoint ;
  rdfs:label """In French, most adjectives go after the noun: 'un vélo gris'. These are called
  postnominal adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23564-5
  a curric:KeyLearningPoint ;
  rdfs:label """'J'ai' means 'I have' and 'tu as' means 'you have'. These are singular forms of the
  verb 'avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23622-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 'e' at the end of the word makes no sound (SFE - Silent final e). The consonant
  before a SFe is pronounced: timide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23622-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means to have: j'ai (I have), tu as (you have), il a (he has), elle a (she
  has). These are its singular forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23622-3
  a curric:KeyLearningPoint ;
  rdfs:label """In English, adjectives come before the noun. In French, most adjectives go after the
  noun (postnominal adjectives)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23622-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must agree with the gender of the noun they describe. We often add an -e
  in the feminine form: vert - verte."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23622-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives, like rapide, end in an e in both the masculine and feminine forms:
  une voiture rapide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23633-1
  a curric:KeyLearningPoint ;
  rdfs:label """The final letter of a word is often silent in French due to SFCs (silent final
  consonants) and SFes (silent final 'e's)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23633-2
  a curric:KeyLearningPoint ;
  rdfs:label "To greet a teacher we use 'bonjour' and to greet a classmate we use 'salut'."@en ;
  dcterms:modified "2026-06-07T15:30:29.321852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23633-3
  a curric:KeyLearningPoint ;
  rdfs:label """Learning classroom instructions as a rhyme helps us to remember when to give the
  teacher our full attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23633-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'être' means 'to be' or 'being'. Use the verb être with adjectives to
  describe people: il est heureux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23633-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective must agree with the gender of the noun it describes; this is called
  adjective agreement: elle est heureuse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23570-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [(a)in] is pronounced as in 'Tintin'."@en ;
  dcterms:modified "2026-06-07T15:30:29.321898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Person nouns change based on the gender of the person in French: un cousin, une
  cousine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23570-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis', 'tu es', 'il est' and 'elle est' are the singular forms of the verb
  'être', to be. 'C'est' means 'it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23570-4
  a curric:KeyLearningPoint ;
  rdfs:label """'C'est' can be used to say what or who someone is: C'est ma cousine - she is my
  cousin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23570-5
  a curric:KeyLearningPoint ;
  rdfs:label """'J'ai', 'tu as', 'il a' and 'elle a' are the singular forms of the verb 'avoir', to
  have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23560-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [oi] makes the sound as in 'trois'."@en ;
  dcterms:modified "2026-06-07T15:30:29.323055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23560-2
  a curric:KeyLearningPoint ;
  rdfs:label """In French, there is only one way to talk about things in the present tense: je
  regarde."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23560-3
  a curric:KeyLearningPoint ;
  rdfs:label """In English, there are two ways to refer to the present: I watch and I am
  watching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23560-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: (je) -e, (tu)
  -es, (il) -e and (elle) -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23560-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Adorer', 'aimer', 'préférer' and 'détester' are opinion verbs, which usually
  translate into the simple present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23550-1
  a curric:KeyLearningPoint ;
  rdfs:label """French [r] is a raspy sound pronounced in the back of the throat; there is no sound
  like this in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23550-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means to have, having; it can also be used to mean 'to be, being', e.g.
  'j'ai raison', 'I am right'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23550-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Avoir' is also used for age, e.g. 'j'ai quatre ans', 'I am four years old'."@en ;
  dcterms:modified "2026-06-07T15:30:29.324248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23531-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [au] sounds similar to [ou] but they are different
  so it is important to practise them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23531-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means 'to have'. Its singular forms are 'j'ai' (I have), 'tu as' (you have)
  and 'il, elle a' (he, she has)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23531-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use 'quoi' with forms of 'avoir' to ask questions about what I and others
  have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23531-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is fun to use reference resources to build up a treasure trove of vocabulary to
  use when writing in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23600-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [i] is pronounced as in 'midi'."@en ;
  dcterms:modified "2026-06-07T15:30:29.324897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23600-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 21 and 31 are different to other two digit numbers in French, they include
  an 'et': vingt-et-un, trente-et-un"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Months of the year are cognates. Unlike in English, months of the year do not use
  capital letters in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23600-4
  a curric:KeyLearningPoint ;
  rdfs:label """When saying your birthday in French, the number always comes before the month: c'est
  le trois avril."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23600-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Quand' means 'when'. When giving your birthday, use 'le' before the number to say
  (on) the: c'est le trois avril."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23630-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French [ch] is different to the English 'ch'. The French [ch] sounds like the
  English 'sh'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23630-2
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to a singular noun in French, use the definite article 'the': 'le' (m) or
  'la' (f). Before a vowel use 'l’'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23630-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before a plural noun, use the definite article 'the': 'les'. 'Les' does not change
  based on the gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23630-4
  a curric:KeyLearningPoint ;
  rdfs:label "In French, adjectives often go after the noun, e.g. 'le visage rond'."@en ;
  dcterms:modified "2026-06-07T15:30:29.350463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree in gender and number with the noun they describe (adjective
  agreement), e.g. 'les cheveux bouclés'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23631-1
  a curric:KeyLearningPoint ;
  rdfs:label """We use the verb 'avoir' ('to have') when saying ages in French, e.g. 'j’ai neuf
  ans'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23631-2
  a curric:KeyLearningPoint ;
  rdfs:label "'J'ai' means 'I have', 'je suis' means 'I am'."@en ;
  dcterms:modified "2026-06-07T15:30:29.354936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Months of the year are cognates in French and English."@en ;
  dcterms:modified "2026-06-07T15:30:29.354940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23631-4
  a curric:KeyLearningPoint ;
  rdfs:label "In French, adjectives often go after the noun, e.g. 'les yeux bleus'."@en ;
  dcterms:modified "2026-06-07T15:30:29.354943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23631-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree in gender and number with the noun they describe (adjective
  agreement), e.g. 'les cheveux bouclés'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many words end in SFCs (silent final consonants). The letters c, r, f and l are,
  however, generally pronounced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23545-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis'- I am, 'tu es'- you are, and 'elle, il est'- she, he is are all parts of
  the verb 'être', 'to be' or 'being'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23545-3
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives have masculine forms 'mon', 'ton' and feminine forms 'ma' and
  'ta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23628-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'avoir' means 'to have'. 'J'ai', 'tu as', 'il a' and 'elle a' are its
  singular forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23628-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nous avons' and 'vous avez' are plural forms of the verb 'avoir' meaning 'we have'
  and 'you have'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23628-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Ils ont' (mpl/mfpl) and 'elles ont' (fpl) mean 'they have'."@en ;
  dcterms:modified "2026-06-07T15:30:29.372428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23628-4
  a curric:KeyLearningPoint ;
  rdfs:label "In French, many adjectives go after the noun they describe: un ordinateur lent."@en ;
  dcterms:modified "2026-06-07T15:30:29.372434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives go before the noun in French (prenominal adjectives) that refer to
  beauty, age, good/bad or size (BAGS)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23514-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [an/en] sound the same, as in the word 'enfant'
  ('child')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23514-2
  a curric:KeyLearningPoint ;
  rdfs:label "Silent final consonant -d is not pronounced, as in the adjective 'grand'."@en ;
  dcterms:modified "2026-06-07T15:30:29.377137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23514-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tu es' means 'you are' and is part of the verb 'être' ('to be, being')."@en ;
  dcterms:modified "2026-06-07T15:30:29.377141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23520-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising the sound-symbol correspondence [eu] in a poem can anchor the
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23520-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -eux change to -euse in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.378608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23520-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Je suis’, ‘tu es’ and ‘elle, il est’ are all parts of the verb ‘être’ (to be,
  being)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23519-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [eu] sounds like the ‘eu’ in ‘deux’ (two)."@en ;
  dcterms:modified "2026-06-07T15:30:29.385151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23519-2
  a curric:KeyLearningPoint ;
  rdfs:label "The silent final consonant -x is not pronounced, as in the adjective ‘heureux’."@en ;
  dcterms:modified "2026-06-07T15:30:29.385155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23519-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -eux change to -euse in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.385158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23535-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [-ez] and ‘et’, meaning and, sound the same as [é]
  and [-er]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23535-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs in the present tense change ending to match the pronoun: je-e, tu-es, elle,
  il-e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23535-3
  a curric:KeyLearningPoint ;
  rdfs:label "Endings -e and -es sound the same because of the silent final consonant."@en ;
  dcterms:modified "2026-06-07T15:30:29.386859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23511-1
  a curric:KeyLearningPoint ;
  rdfs:label """Silent final consonants can be practised by reading familiar and unfamiliar words
  aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23511-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis' means 'I am'; 'elle, il est' means 'she, he is'; the -s and -t are silent
  final consonants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23511-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives often add -e to describe a girl or woman."@en ;
  dcterms:modified "2026-06-07T15:30:29.391960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23574-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC (sound-symbol correspondence) [r] is pronounced as in 'rue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.393130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23574-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Please' in French is 's'il te plait' or 's'il vous plait', thank you is
  'merci'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23574-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 's'il te plait' with family and friends your own age and 's'il vous plait' with
  adults outside of your family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23574-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plural definite article (the) is 'les'. There is a liaison after 'les' with
  plural nouns that begin with a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23574-5
  a curric:KeyLearningPoint ;
  rdfs:label """When giving an opinion about something in French, we often use the definite article:
  le, la, l’, les: j'adore les chats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23518-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [eu] sounds like the 'eu' in 'jeudi', Thursday."@en ;
  dcterms:modified "2026-06-07T15:30:29.396150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23518-2
  a curric:KeyLearningPoint ;
  rdfs:label """'C'est' is part of the verb 'être' combined with 'ce' and means 'it is'; it is used
  to say what day of the week it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Practising new language in a song can be an effective way to embed it in long term
  memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23521-1
  a curric:KeyLearningPoint ;
  rdfs:label """Silent final consonants, vowels and combinations [an/en] and [eu] are very common
  French sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23521-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practising key sounds by joining in with songs and rhymes helps embed the
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23538-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [oi] sounds like the ‘oi’ in 'trois', 'three'."@en ;
  dcterms:modified "2026-06-07T15:30:29.411664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23538-2
  a curric:KeyLearningPoint ;
  rdfs:label "To make nouns plural French often adds ‘s’."@en ;
  dcterms:modified "2026-06-07T15:30:29.411668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23538-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before nouns to indicate how many there are; numbers don’t change
  their spelling for gender or number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23538-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Il y a’ means there is, there are."@en ;
  dcterms:modified "2026-06-07T15:30:29.411676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23517-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-correspondence [an/en] can be practised with similar but contrasting
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23517-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Je suis’, ‘tu es’ and ‘elle, il est’ are all parts of the verb ‘être’ (to be,
  being)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23517-3
  a curric:KeyLearningPoint ;
  rdfs:label "Statements become yes/no questions by raising your tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.413214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23515-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [an/en] can be contrasted for practice with [a], [e]
  and [ain]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23515-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often add -e to describe a female person; adjectives already ending in -e
  do not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23515-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis', 'tu es' and 'elle, il est' are all parts of the verb 'être' to
  be, being."""@en ;
  dcterms:modified "2026-06-07T15:30:29.414010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23508-1
  a curric:KeyLearningPoint ;
  rdfs:label "The vowels [a] [e] [i] are pronounced differently in French and English."@en ;
  dcterms:modified "2026-06-07T15:30:29.415202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23508-2
  a curric:KeyLearningPoint ;
  rdfs:label """French vowels [a] [e] [i] can be practised with source words - ‘banane’, ‘cheval’
  and ‘midi’ - which have these sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23508-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of French sound-spelling correspondences can be strengthened by joining in
  with a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23516-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [an/en] is a nasal vowel and [a] is an oral vowel;
  both appear in the word 'maman', mum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23516-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives already ending in -e do not change; the final consonant in the word is
  pronounced, e.g., malade."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23516-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis', 'tu es' and 'elle, il est' are all parts of the verb 'être' to
  be, being."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23547-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [qu] is pronounced differently in French and
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23547-2
  a curric:KeyLearningPoint ;
  rdfs:label "[qu] appears in several French question words, e.g. 'quoi', 'qui', 'quand.'"@en ;
  dcterms:modified "2026-06-07T15:30:29.419017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23547-3
  a curric:KeyLearningPoint ;
  rdfs:label """When followed by a vowel, 'mon' changes from a nasal to an oral sound, e.g. 'mon
  anniversaire'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23547-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Joyeux anniversaire’ or 'Bon anniversaire' are common for happy birthday; in
  Quebec, Canada, there's also 'Bonne fête'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23549-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 1-12 go before nouns to indicate how many there are."@en ;
  dcterms:modified "2026-06-07T15:30:29.423548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23549-2
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article des is the French word for the determiner some."@en ;
  dcterms:modified "2026-06-07T15:30:29.423552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23549-3
  a curric:KeyLearningPoint ;
  rdfs:label """When 'des', 2, 3 and 10 are followed by a noun beginning with a vowel, the -s and -x
  are pronounced; this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23549-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Il y a' means both there is and there are; 'il a' means 'he, it has'."@en ;
  dcterms:modified "2026-06-07T15:30:29.423562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23561-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: (je) -e, (tu)
  -es, (il) -e and (elle) -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23561-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Adorer', 'aimer', 'préférer' and 'détester' are opinion verbs. They are regular -er
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23561-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opinion verbs usually translate into the simple present tense in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.425101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23561-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to practise vocabulary regularly."@en ;
  dcterms:modified "2026-06-07T15:30:29.425105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23524-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ch] sounds like the 'ch' in 'chercher', to look
  for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23524-2
  a curric:KeyLearningPoint ;
  rdfs:label """Intonation yes/no questions are formed by raising tone of voice at the end of a
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23524-3
  a curric:KeyLearningPoint ;
  rdfs:label """Intonation questions become information questions by adding a question word after
  c'est like 'quoi', what."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23524-4
  a curric:KeyLearningPoint ;
  rdfs:label """When learning a new language it is important to practise vocabulary regularly to
  strengthen your word knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23523-1
  a curric:KeyLearningPoint ;
  rdfs:label "C'est means 'it is' or it's and usually has a silent-final consonant."@en ;
  dcterms:modified "2026-06-07T15:30:29.425387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23523-2
  a curric:KeyLearningPoint ;
  rdfs:label """C'est can be used with any singular noun and its indefinite article to state what
  something is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23523-3
  a curric:KeyLearningPoint ;
  rdfs:label """When c'est is followed by 'un' or 'une' the 't' is pronounced; this is an example of
  liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23522-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [un] is a nasal vowel sound; ‘un’ means 'a/an' and
  number one in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23522-2
  a curric:KeyLearningPoint ;
  rdfs:label "All nouns have grammatical gender, masculine or feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.425438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23522-3
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine word for 'a/an' is 'un', the feminine word is 'une'; these determiners
  are called indefinite articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23527-1
  a curric:KeyLearningPoint ;
  rdfs:label "A singular verb form is used when only one person is doing or being something."@en ;
  dcterms:modified "2026-06-07T15:30:29.425448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23527-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of the verb 'avoir' are 'jai' (I have), 'tu as' (you have), 'il
  a' (he has) and 'elle a' (she has)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23527-3
  a curric:KeyLearningPoint ;
  rdfs:label """To change a statement into a yes/no question you raise your voice at the end; this
  is called intonation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23527-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is no word for 'do' or 'does' in French intonation questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.425461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23527-5
  a curric:KeyLearningPoint ;
  rdfs:label """When learning a new language it is important to practise vocabulary regularly to
  strengthen your word knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23526-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [on] is a nasal sound, as in the word 'Non !'"@en ;
  dcterms:modified "2026-06-07T15:30:29.426262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23526-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising nouns helps us remember the word and the gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.426266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23526-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'avoir' means 'to have' in French. 'Tu as' means 'you have'."@en ;
  dcterms:modified "2026-06-07T15:30:29.426270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23526-4
  a curric:KeyLearningPoint ;
  rdfs:label """French yes/no questions don't have a word for 'do'. Intonation can change the
  statement 'you have' into do you have?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23509-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French vowels [a], [e], [i], [o] and [u] can be practised by listening and
  distinguishing between the five sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23509-2
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of French sound-spelling correspondences can be strengthened by reading
  aloud short sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23509-3
  a curric:KeyLearningPoint ;
  rdfs:label """Four important verbs to recognise and understand in the classroom are 'écouter',
  'parler', 'lire', 'écrire'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23525-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revise the days of the week by listening to a song."@en ;
  dcterms:modified "2026-06-07T15:30:29.427642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23525-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use intonation to ask and answer what day of the week it is with 'aujourd'hui' and
  c'est'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23525-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'avoir' means 'to have'. 'J'ai' means I have, 'il a' means he has and 'elle
  a' means 'she has'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23525-4
  a curric:KeyLearningPoint ;
  rdfs:label """These verbs are used with nouns and their indefinite articles to say what I and
  someone else has."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23512-1
  a curric:KeyLearningPoint ;
  rdfs:label """Silent final consonants -s, -t, -x and -d can be practised with words like ‘dans’,
  ‘mot’, ‘prix’ and ‘grand’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23512-2
  a curric:KeyLearningPoint ;
  rdfs:label "French statements become questions by raising tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.432694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23512-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a space before a ? in French and also before a ! e.g. Salut !"@en ;
  dcterms:modified "2026-06-07T15:30:29.432698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23635-1
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective must agree with the gender of the noun it describes; this is called
  adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23635-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most adjectives end in -e in the feminine form, but some are irregular like 'beau'
  (beautiful) which becomes 'belle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23635-3
  a curric:KeyLearningPoint ;
  rdfs:label """To express 'they have' use 'ils ont' or 'elles ont'. To express 'they are' use 'ils
  sont' or 'elles sont'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23635-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must also agree with the noun in number; many add -s in the masculine
  plural form and -es in the feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23635-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some common adjectives are irregular in the plural: 'vieux' and 'mauvais' stay the
  same and 'beau' becomes 'beaux'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23528-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [o] and [au] sound the same, like the [au] in
  gauche, left."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23528-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'avoir' means to have. 'Tu as', 'il a' and 'elle a' are singular forms of
  this verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23528-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'être' means to be. 'Tu es', 'il est and 'elle est' are singular forms of
  this verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23528-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the singular forms of 'avoir' to have and 'être' to be, sound similar, e.g.,
  tu as, tu es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23544-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vowels [a] [o] [i] [o] [u] are pronounced differently in French and English."@en ;
  dcterms:modified "2026-06-07T15:30:29.434115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23544-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Voici' means 'this is or 'here is'. It can be used to introduce somebody."@en ;
  dcterms:modified "2026-06-07T15:30:29.434119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23544-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je suis', 'I am', can be used to introduce myself, and 'elle, il est', 'she, he
  is', to introduce others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23544-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often add -e in the feminine form to describe a girl or woman. This is
  adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23529-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [o/au/eau] all have the same sound as in 'gauche',
  left."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23529-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [eau] is also a word which means water in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.435102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23529-3
  a curric:KeyLearningPoint ;
  rdfs:label """Preparing to understand a new text means learning key new words and also revising
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23529-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Moi' and 'toi' mean 'me' and 'you'. We use them when we want to emphasise who."@en ;
  dcterms:modified "2026-06-07T15:30:29.435110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23529-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud really helps us to practise good pronunciation."@en ;
  dcterms:modified "2026-06-07T15:30:29.435114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23513-1
  a curric:KeyLearningPoint ;
  rdfs:label """Silent final consonants -s and -t can be practised by listening and matching speech
  to written words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23513-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ça va can be the question ‘Is it going ok? or ‘how’s it going’? and the answer ‘it’s
  OK’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23513-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different word-final spellings can have the same final sound, e.g., the -yn in
  Jocelyn and -en in bien."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23637-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'aller' is irregular and means 'to go'. 'Je vais' is 'I go', 'il va' is 'he
  goes' and 'elle va' is 'she goes'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23637-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 's' of 'je vais' is normally an SFC but if followed by a vowel like 'à', you
  pronounce it; this is called liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23637-3
  a curric:KeyLearningPoint ;
  rdfs:label """The word 'dans' means 'in'. After 'aller' it can mean 'into' or just 'to', e.g. 'je
  vais dans le parc'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23637-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'à' to talk about going to or being in a town or city; use 'dans' to talk about
  going to a cardinal point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23637-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'en' to talk about going to a feminine country, use 'au' (à + le) to talk about
  going to a masculine country/region."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23638-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [a] and [ai] sound different. The sound [a] is pronounced as in 'banane',
  [ai] is pronounced as in 'vrai'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23638-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'aller' means 'to go, going'. 'Je vais' is 'I go, I am going' and 'tu vas'
  is 'you go, you are going'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23638-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to (the) ...' use 'au' before a masculine noun, 'à la' before a feminine
  noun and 'à l'' before a vowel or 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23638-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make a yes/no question clear, we can add 'est-ce que' (‘is it that …?) at the
  start of any statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23638-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a ‘where’ question, we can add 'où est-ce que' (‘where is it that …?’) at the
  start of any statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-31 in French are tricky to remember and so they must be practised
  regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23641-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'faire' means both 'to do, doing' and 'to make, making'."@en ;
  dcterms:modified "2026-06-07T15:30:29.599093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23641-3
  a curric:KeyLearningPoint ;
  rdfs:label """'I do, make' is 'je fais', 'he does, makes' is 'il fait' and 'she does, makes' is
  'elle fait'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23641-4
  a curric:KeyLearningPoint ;
  rdfs:label """Negative sentences in English have 'don't' before the verb. In French we 'sandwich'
  the verb between 'ne' and 'pas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23641-5
  a curric:KeyLearningPoint ;
  rdfs:label "For example: 'je fais le lit' (positive) and 'je ne fais pas le lit' (negative)."@en ;
  dcterms:modified "2026-06-07T15:30:29.599105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23510-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many word-final consonants in French are not pronounced."@en ;
  dcterms:modified "2026-06-07T15:30:29.616389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23510-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Salut’ ('hi') is a more informal greeting than ‘bonjour’ ('hello')."@en ;
  dcterms:modified "2026-06-07T15:30:29.616393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23510-3
  a curric:KeyLearningPoint ;
  rdfs:label "The irregular verb ‘être’ means to be, being."@en ;
  dcterms:modified "2026-06-07T15:30:29.616397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23510-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Je suis’ means ‘I am’; ‘elle, il est’ means ‘she, he is’; the -s and -t are silent
  final consonants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23602-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [an], [en], [am] and [em] make the same sound: enfant, ensemble,
  chambre"""@en ;
  dcterms:modified "2026-06-07T15:30:29.618069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23602-2
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we use ordinal numbers with dates (27th), in French we use cardinal
  numbers (27)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23602-3
  a curric:KeyLearningPoint ;
  rdfs:label """When saying a date in French, we use 'le' before the number to say (on) the: c'est
  le trois avril."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23602-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Quel' and 'quelle' mean 'which'. They match the gender of the noun they refer to:
  c'est quel jour / quelle date ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.618081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23602-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Quel' and 'quelle' are often translated into English more naturally as 'what'."@en ;
  dcterms:modified "2026-06-07T15:30:29.618087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23563-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives must agree with the noun they describe in French. They can be either
  masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23563-2
  a curric:KeyLearningPoint ;
  rdfs:label """Regular adjectives add an -e in the feminine form. This is a SFe (silent
  final e)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23563-3
  a curric:KeyLearningPoint ;
  rdfs:label "In English, adjectives come before the noun: 'a grey bike'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23563-4
  a curric:KeyLearningPoint ;
  rdfs:label """In French, most adjectives go after the noun: 'un vélo gris'. These are called
  postnominal adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23563-5
  a curric:KeyLearningPoint ;
  rdfs:label """'J'ai' means I have and 'tu as' means you have. These are singular forms of the verb
  'avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23559-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Habiter' is a regular -er verb meaning 'to live'."@en ;
  dcterms:modified "2026-06-07T15:30:29.620364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23559-2
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er verbs have the following endings in the singular form: (je) -e, (tu)
  -es, (il) -e and (elle) -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23559-3
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition 'à' can mean 'to', 'at' or 'in'."@en ;
  dcterms:modified "2026-06-07T15:30:29.620375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23559-4
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb 'aussi' goes after the verb in French, when translated as 'also': il aide
  aussi à la maison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23559-5
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb 'aussi' will only go at the end of a sentence in French, when translated
  as 'as well' or 'too'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23532-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [é] and [er] sounds like the 'é' and 'er' in
  'répéter', to repeat, repeating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23532-2
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive form of a verb gives its general meaning, e.g. to listen,
  listening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23532-3
  a curric:KeyLearningPoint ;
  rdfs:label "French infinitives often end in -er, e.g., écouter."@en ;
  dcterms:modified "2026-06-07T15:30:29.621660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23532-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the infinitive starts the sentence, it is translated -ing, e.g., listening."@en ;
  dcterms:modified "2026-06-07T15:30:29.621664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23656-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice of sound-symbol correspondences is important to ensure good
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23656-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘play’ with sports use ‘jouer’ + ‘à’, e.g. ‘je joue au tennis’ (‘I play
  tennis’)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23656-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘do’ with sports, use ‘faire’ + ‘de’, e.g. ‘je fais du sport’ (‘I do sport’).
  We call this the partitive article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23656-4
  a curric:KeyLearningPoint ;
  rdfs:label """The partitive article is also used to mean 'some' (an unspecified amount) with food
  and drink."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23656-5
  a curric:KeyLearningPoint ;
  rdfs:label """For masculine nouns, use 'du', for feminine use 'de la' and for nouns starting with
  a vowel or silent 'h' use 'de l''."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23569-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [ien], [(a)in] and [on] make nasal sounds. Air passes through both the nose
  and the mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23569-2
  a curric:KeyLearningPoint ;
  rdfs:label """In French all nouns are either masculine or feminine. This is grammatical gender. It
  is not the same as male or female."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23569-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use reference materials such a dictionaries to help us determine the type of
  a word and the gender of a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23569-4
  a curric:KeyLearningPoint ;
  rdfs:label """All dictionaries have symbols to give information about word type and noun gender.
  For example 'nm' is a masculine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23569-5
  a curric:KeyLearningPoint ;
  rdfs:label """When saying your favourite animal in French, use the article the (le, la, l'): mon
  animal préféré est le chien."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23609-1
  a curric:KeyLearningPoint ;
  rdfs:label """Haiti is a French speaking country located in the Caribbean, it is part of 'la
  francophonie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23609-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Haiti people celebrate 'le Reveyon' the 24th December. They eat 'griot de porc',
  'banann peze' et 'riz collé ak pwa'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Children make 'fanaux', lanterns made from paper and cardboard in the shape of
  houses, a Christmas tradition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23609-4
  a curric:KeyLearningPoint ;
  rdfs:label "In Haiti, there are two official languages: Haitian Creole and French."@en ;
  dcterms:modified "2026-06-07T15:30:29.635666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Haitian Creole contains French words and words from many different African
  languages: Boujou ! Padon ! Mèsi !"""@en ;
  dcterms:modified "2026-06-07T15:30:29.635670Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-23540
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use ‘des’ and numbers 1-12 with plural nouns to answer the question ‘combien
  de ?’"""@en ;
  dcterms:modified "2026-06-07T15:30:41.064117Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23568
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form sentences describing zoo animals in French, using singular adjective
  agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064121Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23624
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form sentences using adjective agreement with plural adjectives, and the
  indefinite article 'des'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064131Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23640
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use singular forms of 'faire' with a range of nouns to express what 'I', 'he'
  and 'she' do or make at home."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064324Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23556
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use singular -er verbs to say what I do at the weekend."@en ;
  dcterms:modified "2026-06-07T15:30:41.064458Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23537
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a range of singular verbs and definite articles to talk about birthday
  activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064967Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23541
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'il y a' with indefinite articles 'un', 'une' and 'des' and numbers 1-12
  to say how many there are."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065166Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23536
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use singular verbs and definite articles to understand about family
  activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065333Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23620
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe the Mardi Gras festival using affirmative and negative sentences."@en ;
  dcterms:modified "2026-06-07T15:30:41.065730Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23610
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand sentences describing Christmas traditions in Haiti using
  -er verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065840Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23567
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use possessive adjectives in French to describe preparations for 'la fête des
  mères'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066094Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23534
  a curric:PupilLessonOutcome ;
  rdfs:label """I can read and understand 'je' and 'tu' -er verbs in the present tense talking about
  activities at school."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066246Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23576
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask friends questions about themselves and I can answer questions about myself
  in French."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066512Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23614
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form sentences to describe independence celebrations in Haiti using plural -er
  verbs and the pronouns 'ils' and 'elles'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066629Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23606
  a curric:PupilLessonOutcome ;
  rdfs:label """I can write sentences describing what people are like, using 'ils/elles sont' and
  plural adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066829Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23597
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read and understand a short story in French."@en ;
  dcterms:modified "2026-06-07T15:30:41.066974Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23648
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the correct possessive pronoun in French in order to refer to 'my' or
  'your' things."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066994Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23646
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say which sport I and others play, and link two clauses with 'quand' to create
  longer sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067135Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23557
  a curric:PupilLessonOutcome ;
  rdfs:label "I can translate French present tense sentences into English."@en ;
  dcterms:modified "2026-06-07T15:30:41.067246Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23626
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and form sentences using the plural form of 'avoir' ('nous' and
  'vous')."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067250Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23642
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use singular forms of 'faire' with a range of nouns to describe who does what
  at home."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067397Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23643
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use 'qu'est-ce que' with singular 'faire' to ask what others are doing."@en ;
  dcterms:modified "2026-06-07T15:30:41.067755Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23618
  a curric:PupilLessonOutcome ;
  rdfs:label "I can form negative sentences in French using 'ne ... pas'."@en ;
  dcterms:modified "2026-06-07T15:30:41.067830Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23566
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read and understand a text about ‘la fête des mères’ in 'la Francophonie'."@en ;
  dcterms:modified "2026-06-07T15:30:41.067834Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23644
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'il fait' with a variety of adjectives to describe the weather as well as
  activities on holiday."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067892Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23577
  a curric:PupilLessonOutcome ;
  rdfs:label "I can write a short letter in French to a friend."@en ;
  dcterms:modified "2026-06-07T15:30:41.068156Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23634
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my knowledge of numbers, ‘il y a’ and ‘il n’y a pas de’ to understand and
  give descriptions of school facilities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068338Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23612
  a curric:PupilLessonOutcome ;
  rdfs:label """I can distinguish between the different forms of 'you' in French and I can form
  sentences with -er verbs and plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068513Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23565
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say sentences in French to describe what I or others have."@en ;
  dcterms:modified "2026-06-07T15:30:41.068517Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23533
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and translate correctly a number of -er verbs talking about
  classroom activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068668Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23562
  a curric:PupilLessonOutcome ;
  rdfs:label "I can ask questions using intonation and ‘tu as’ to find out what somebody has."@en ;
  dcterms:modified "2026-06-07T15:30:41.068874Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23552
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand 'avoir' with nouns to mean how people are feeling."@en ;
  dcterms:modified "2026-06-07T15:30:41.069116Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23546
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand the months of the year and when people's birthday are."@en ;
