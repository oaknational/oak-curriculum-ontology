    oakcurric:thread-verb-to-be-being ,
    oakcurric:thread-questions ,
    oakcurric:thread-read-and-respond-to-texts .

oakcurric:unit-3187
  a curric:Unit ;
  rdfs:label "School: 'avoir', 'être' , 'il y a' and regular verbs in the present"@en ;
  curric:slug "school-avoir-etre-il-y-a-and-regular-verbs-in-the-present" ;
  rdfs:comment """In this unit, pupils secure prior knowledge of essential verbs, introducing and
  describing friends. They revisit useful verbs for class activities and instructions,
  numbers 1-31 and extend their knowledge of negation to 'il n'y a pas de'. Knowledge of
  several key sounds is strengthened."""@en ;
  curric:whyThisWhyNow """Pupils will already have learnt and revisited all forms of 'avoir' and
  'être'. This unit further anchors this knowledge in plentiful listening, reading, speakng and
  writing practice. Numbers 1-31 are secured in practice. Prior knowledge of ne...pas negation
  with -er verbs is further applied to the high frequency verb phrase 'il y a', enabling pupils
  to say what there is or are not. Sounds secured in this unit include oi, (a)in.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3187-1 ,
    oakcurric:priorknowledge-3187-2 ,
    oakcurric:priorknowledge-3187-3 ,
    oakcurric:priorknowledge-3187-4 ;
  curric:id "3187"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.669525Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-languages-key-stage-2 ;
