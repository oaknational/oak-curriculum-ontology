  dcterms:modified "2026-06-07T15:29:23.550184Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use the contraction of the definite article after 'à' and 'de'."@en ;
  dcterms:modified "2026-06-07T15:29:23.550189Z"^^xsd:dateTime .

oakcurric:priorknowledge-2862-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form the perfect tense with 'avoir' or ‘être’ as the auxiliary
