  dcterms:modified "2026-06-07T15:30:41.117499Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21593
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe my free time using a range of verbs in the present tense and the
