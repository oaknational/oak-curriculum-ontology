  dcterms:modified "2026-06-07T15:29:23.314764Z"^^xsd:dateTime .

oakcurric:priorknowledge-2832-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use two-verb structures e.g. aimer + infinitive."@en ;
  dcterms:modified "2026-06-07T15:29:23.314769Z"^^xsd:dateTime .

oakcurric:priorknowledge-2832-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the question words comment, quand, quoi and pourquoi."@en ;
  dcterms:modified "2026-06-07T15:29:23.314774Z"^^xsd:dateTime .

oakcurric:priorknowledge-2831-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the subject pronouns je, tu, il, elle, nous, vous, ils, elles."@en ;
  dcterms:modified "2026-06-07T15:29:23.524078Z"^^xsd:dateTime .

oakcurric:priorknowledge-2831-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the verb 'aller' in the first, second and third person singular."@en ;
  dcterms:modified "2026-06-07T15:29:23.524090Z"^^xsd:dateTime .

oakcurric:priorknowledge-2831-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know to combine 'à' with the definite article for 'to' a place."@en ;
  dcterms:modified "2026-06-07T15:29:23.524097Z"^^xsd:dateTime .

oakcurric:priorknowledge-2831-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that à + le contracts to 'au' and à + les contracts to 'aux'."@en ;
  dcterms:modified "2026-06-07T15:29:23.524103Z"^^xsd:dateTime .

oakcurric:priorknowledge-2831-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use regular -er verbs in the present in all persons of the verb."@en ;
  dcterms:modified "2026-06-07T15:29:23.524108Z"^^xsd:dateTime .

oakcurric:priorknowledge-2836-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know what an infinitive is."@en ;
  dcterms:modified "2026-06-07T15:29:23.526202Z"^^xsd:dateTime .

oakcurric:priorknowledge-2836-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the subject pronouns je, tu, il and elle."@en ;
  dcterms:modified "2026-06-07T15:29:23.526215Z"^^xsd:dateTime .

oakcurric:priorknowledge-2836-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to negate a sentence using ne...pas."@en ;
  dcterms:modified "2026-06-07T15:29:23.526221Z"^^xsd:dateTime .

oakcurric:priorknowledge-2836-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can make questions using inversion with single and two verb structures."@en ;
  dcterms:modified "2026-06-07T15:29:23.526227Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form past participles of regular -er verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.550137Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the past participles of verbs like 'prendre', and of irregular verbs
  faire, dire, boire and avoir."""@en ;
  dcterms:modified "2026-06-07T15:29:23.550152Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form the perfect tense with 'avoir' as the auxiliary verb."@en ;
  dcterms:modified "2026-06-07T15:29:23.550159Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form questions using intonation and est-ce que, with and without
  question words."""@en ;
  dcterms:modified "2026-06-07T15:29:23.550164Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to negate perfect tense sentences using ne...pas."@en ;
  dcterms:modified "2026-06-07T15:29:23.550169Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can translate the perfect tense using the simple past and the present perfect
  in English."""@en ;
  dcterms:modified "2026-06-07T15:29:23.550174Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know to use 'vous' instead of 'tu' for 'you' and 'nous' instead of 'on' for
  'we' in formal situations."""@en ;
  dcterms:modified "2026-06-07T15:29:23.550179Z"^^xsd:dateTime .

oakcurric:priorknowledge-2861-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use verbs like 'entendre' and verbs like 'écrire' in the present
