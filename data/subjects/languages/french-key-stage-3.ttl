    oakcurric:priorknowledge-2828-5 ,
    oakcurric:priorknowledge-2828-6 ,
    oakcurric:priorknowledge-2828-7 ,
    oakcurric:priorknowledge-2828-8 ;
  curric:id "2828"^^xsd:positiveInteger;
