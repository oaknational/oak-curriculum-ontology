  dcterms:modified "2026-06-07T15:30:41.117698Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21572
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use infinitives, like nouns, as the subjects of sentences to express an
