  dcterms:modified "2026-06-07T15:30:41.120254Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21512
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my knowledge of the plural forms of -IR verbs like 'sortir' and 'venir' to
