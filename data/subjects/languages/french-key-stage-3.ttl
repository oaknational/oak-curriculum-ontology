  dcterms:modified "2026-06-07T15:30:41.117694Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21533
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use comparative structures with adjectives and adverbs, and a variety of -ir
