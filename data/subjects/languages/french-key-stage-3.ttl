  dcterms:modified "2026-06-07T15:30:41.120249Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21516
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like 'choisir' in the 'je' and 'il, elle' forms to say what I and
