  dcterms:modified "2026-06-07T15:29:23.630115Z"^^xsd:dateTime .

oakcurric:priorknowledge-2838-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the verb être in the present tense in all persons."@en ;
