  dcterms:modified "2026-06-07T15:29:23.630040Z"^^xsd:dateTime .

oakcurric:priorknowledge-2862-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form past participles of regular -er verbs, including feminine
  and plural past participle agreement."""@en ;
  dcterms:modified "2026-06-07T15:29:23.630060Z"^^xsd:dateTime .

oakcurric:priorknowledge-2862-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use intonation questions in the present and perfect tenses."@en ;
  dcterms:modified "2026-06-07T15:29:23.630071Z"^^xsd:dateTime .

oakcurric:priorknowledge-2862-4
  a curric:PriorKnowledgeRequirement ;
