  dcterms:modified "2026-06-07T15:29:23.076894Z"^^xsd:dateTime .

oakcurric:priorknowledge-2863-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are confident with Silent Final Consonants [SFC] and Silent Final ‘e’
  [SFe]."""@en ;
  dcterms:modified "2026-06-07T15:29:23.076900Z"^^xsd:dateTime .

oakcurric:priorknowledge-2832-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the subject pronouns je, tu, il, elle, nous, vous, ils and elles."@en ;
  dcterms:modified "2026-06-07T15:29:23.314747Z"^^xsd:dateTime .

oakcurric:priorknowledge-2832-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use regular -er verbs in the present tense in all persons of the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:29:23.314758Z"^^xsd:dateTime .

oakcurric:priorknowledge-2832-3
  a curric:PriorKnowledgeRequirement ;
