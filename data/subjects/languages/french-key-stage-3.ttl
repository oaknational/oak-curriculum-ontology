# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sfc
  a curric:Keyword ;
  schema:name "SFC"@en ;
  schema:description "silent final consonant: silent letter (d, s, t, x) at the end of a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.347251Z"^^xsd:dateTime .

oakcurric:keyword-sfe
  a curric:Keyword ;
  schema:name "SFe"@en ;
  schema:description "silent final 'e': silent 'e' at the end of a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.347256Z"^^xsd:dateTime .

oakcurric:keyword-il-elle
  a curric:Keyword ;
  schema:name "il, elle"@en ;
  schema:description "French pronouns meaning 'he', 'she' and 'it'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347263Z"^^xsd:dateTime .

oakcurric:keyword-ils-elles
  a curric:Keyword ;
  schema:name "ils, elles"@en ;
  schema:description "French pronouns meaning 'they' (masculine and feminine)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347268Z"^^xsd:dateTime .

oakcurric:keyword-faire
  a curric:Keyword ;
  schema:name "faire"@en ;
  schema:description "French verb meaning 'to do, make'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347275Z"^^xsd:dateTime .

oakcurric:keyword-imperfect-tense
  a curric:Keyword ;
  schema:name "imperfect tense"@en ;
  schema:description "tense used to describe how things were or used to be in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.347280Z"^^xsd:dateTime .

oakcurric:keyword-sound-symbol-correspondence
  a curric:Keyword ;
  schema:name "sound-symbol correspondence"@en ;
  schema:description "relationship between letters and their sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.347335Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-simple-present
  a curric:Keyword ;
  schema:name "simple present"@en ;
  schema:description "verb tense used to express habitual events in the present e.g. 'I do'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347450Z"^^xsd:dateTime .

oakcurric:keyword-adjective
  a curric:Keyword ;
  schema:name "adjective"@en ;
  schema:description "describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.348100Z"^^xsd:dateTime .

oakcurric:keyword-noun
  a curric:Keyword ;
  schema:name "noun"@en ;
  schema:description "a naming word for people, places or things"@en ;
  dcterms:modified "2026-06-07T15:30:02.348107Z"^^xsd:dateTime .

oakcurric:keyword-verb
  a curric:Keyword ;
  schema:name "verb"@en ;
  schema:description "a doing, being or having word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348112Z"^^xsd:dateTime .

oakcurric:keyword-vocabulary
  a curric:Keyword ;
  schema:name "vocabulary"@en ;
  schema:description "the use of specific words and phrases to convey a meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.348165Z"^^xsd:dateTime .

oakcurric:keyword-auxiliary-verb
  a curric:Keyword ;
  schema:name "auxiliary verb"@en ;
  schema:description "the helping verb that is always paired with the main verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348256Z"^^xsd:dateTime .

oakcurric:keyword-adverb
  a curric:Keyword ;
  schema:name "adverb"@en ;
  schema:description "describes a verb"@en ;
