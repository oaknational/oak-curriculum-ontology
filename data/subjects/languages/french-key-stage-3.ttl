  dcterms:modified "2026-06-07T15:30:41.117993Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21459
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use negation with 'ne … pas' to describe what isn’t happening in everyday
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118096Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25496
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like 'entendre' in the present tense singular, including with
  inversion questions."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118274Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25495
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like ‘entendre’ in the present tense singular to communicate with a
  penfriend."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118297Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21626
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the perfect and imperfect tenses together, including within 'est-ce que'
  structures to describe simultaneous events."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118369Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21469
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'aller' in the 1st and 2nd persons plural with an infinitive to express
  what we and you (plural) are going to do."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118555Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21573
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use infinitives to describe an activity or an action in French."@en ;
  dcterms:modified "2026-06-07T15:30:41.118560Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21520
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use prenominal and postnominal adjectives in the context of news
  headlines."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118634Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25494
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the plural forms of verbs like 'choisir' to discuss what I and other
  people do this weekend and every weekend."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119048Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21618
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the perfect tense, including past participles like 'sorti' and 'choisi' in
