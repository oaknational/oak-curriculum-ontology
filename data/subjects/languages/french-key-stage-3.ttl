# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-21604-1
  a curric:KeyLearningPoint ;
  rdfs:label """The consonants d, s, t and x are often silent at the end of a word. We call this
  SFC, Silent Final Consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21604-2
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel 'e' is often silent at the end of a word. This is SFe, Silent Final ‘e’.
  The final consonant is pronounced."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many verbs that end in -ate in English have in fact come from French verbs ending in
  -er: 'éliminer' - 'eliminate'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every noun has a gender in French. 'Il' and 'elle' can mean 'it', and 'ils' and
  'elles' mean 'they' (people and things)."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21604-5
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'faire' is an irregular verb meaning 'to do, make'."@en ;
  dcterms:modified "2026-06-07T15:30:28.998852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21453-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [(a)in] is pronounced as in the French word 'train'."@en ;
  dcterms:modified "2026-06-07T15:30:29.000108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21453-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je dis', 'tu dis' and 'il, elle dit' are the singular forms of the -re verb 'dire',
  to say, saying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21453-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je prends', 'tu prends', 'il, elle prend' are the singular forms of the -re verb
  'prendre', to take."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21453-4
  a curric:KeyLearningPoint ;
  rdfs:label """The same verb endings can be applied to the -re verbs 'apprendre', to learn, and
  'comprendre', to understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21450-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to' a town or city, we use the preposition 'à' on its own, for example 'Je
  vais à Londres'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21450-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'to' a feminine country we use 'en', for example 'Tu vas en Angleterre.'"@en ;
  dcterms:modified "2026-06-07T15:30:29.002778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21450-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say going 'to' someone's house or place, it's 'chez', for example 'Il va chez le
  dentiste' - He goes to the dentist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21450-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'you (plural) go' or 'you are going', we use 'vous allez'. This is called the
  2nd person plural of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21450-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'they go' or 'they are going', we use 'ils, elles vont'. This is called the
  3rd person plural of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21471-1
  a curric:KeyLearningPoint ;
  rdfs:label "[tion] sounds like 'attention'"@en ;
  dcterms:modified "2026-06-07T15:30:29.002795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21471-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what you have to, or want to do, use modal verbs 'devoir' and
  'vouloir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21471-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person (I) of 'devoir' is 'dois'; the 3rd person (she, he) is 'doit'."@en ;
  dcterms:modified "2026-06-07T15:30:29.002822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21471-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person (I) of 'vouloir' is 'veux'; the 3rd person (she, he) is 'veut'."@en ;
  dcterms:modified "2026-06-07T15:30:29.002828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21471-5
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are usually followed by another verb which must be in the infinitive
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21584-1
  a curric:KeyLearningPoint ;
  rdfs:label "[tion] is pronounced as in 'attention' [tion] words are always feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.003028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21584-2
  a curric:KeyLearningPoint ;
  rdfs:label "Form the perfect tense by combining part of 'avoir' and a past participle."@en ;
  dcterms:modified "2026-06-07T15:30:29.003032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21584-3
  a curric:KeyLearningPoint ;
  rdfs:label """-er verb past participles change from -er to é, verbs like prendre change to 'pris'
  and some participles are irregular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21584-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Ne ...pas' wraps around part of 'avoir' in the perfect tense to make negative
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21584-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ask intonation questions in the perfect tense by raising your voice. You can also
  add 'est-ce que' before the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21608-1
  a curric:KeyLearningPoint ;
  rdfs:label """In French the SSC (sound-symbol correspondence) [th] makes a t sound, as in
  'théâtre'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21608-2
  a curric:KeyLearningPoint ;
  rdfs:label """Soixante-dix is 70, quatre-vingts is 80, quatre-vingt-dix is 90 and cent is one
  hundred."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21608-3
  a curric:KeyLearningPoint ;
  rdfs:label """In France, the euro symbol € comes after the number and a comma is used instead of a
  decimal point: 40,25 €."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21608-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb payer (to pay) has two different spellings in the singular form: je paie /
  je paye."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21608-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the pronoun 'it' as a direct object in French, we use either 'le'
  (masculine) or 'la' (feminine)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21598-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ou] is pronounced as in 'nous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.003764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21598-2
  a curric:KeyLearningPoint ;
  rdfs:label "[u] is pronounced as in 'tu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.003769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'un an' to count years + 'une année' to describe events or duration within a
  year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'ans' with 'avoir' to describe age e.g. 'J'ai douze ans' and 'Quel âge as-tu ?'
  to ask someone's age."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21598-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperfect tense (all verb groups), take the nous form of the present
  tense, remove –ons, add -ais or -ait."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21478-1
  a curric:KeyLearningPoint ;
  rdfs:label """French is not a stress-timed language. Sound all vowels. Say syllables equally with
  a slight emphasis on the last one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21478-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means 'to have, having', 'j'ai' means 'I have', 'tu as' means 'you
  have'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21478-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Être' means 'to be, being', 'je suis' means 'I am', 'il est' means 'he is' and
  'elle est' means 'she is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21478-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using 'être' to describe professions, no article (un/une) is needed before the
  job noun in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21478-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ask questions in French with intonation, inversion and 'est-ce que'. Inversion is
  more formal than 'est-ce que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21539-1
  a curric:KeyLearningPoint ;
  rdfs:label "The French [s] can make a hard 'z' or a soft 's' sound: maison, société."@en ;
  dcterms:modified "2026-06-07T15:30:29.004889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21539-2
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [tion] makes a soft 's' sound: attention. The SSC [ç/c] makes a soft 's'
  sound: cinéma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21539-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense to talk about an action that happened in the past: avoir +
  past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21539-4
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a closed question in the perfect tense use inversion: swap the subject and
  the verb (avoir): as-tu commencé ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.004901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21509-1
  a curric:KeyLearningPoint ;
  rdfs:label """[s] sounds like maison. Use the hard 's' sound when it appears between two vowels
  and the soft 's' elsewhere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21509-2
  a curric:KeyLearningPoint ;
  rdfs:label """'De' changes before the definite article to 'du', 'de la', 'de l'' and 'des' before
  plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21509-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Jouer', the verb to play is followed by the preposition 'à' before sports/games and
  'de' before musical instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21480-1
  a curric:KeyLearningPoint ;
  rdfs:label "[h] is silent in French, as in the word 'heure'."@en ;
  dcterms:modified "2026-06-07T15:30:29.253117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21480-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most French person nouns for jobs become feminine by adding -e, e.g. une
  avocate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21480-3
  a curric:KeyLearningPoint ;
  rdfs:label """Person nouns already ending in -e stay the same, but the article changes, e.g. le →
  la secrétaire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21480-4
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine person nouns ending in -eur typically change to -rice in the feminine
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21480-5
  a curric:KeyLearningPoint ;
  rdfs:label """The rules around job nouns are still changing and there are exceptions to
  the rules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nationality and religious adjectives can become nouns when used with an article.
  These are identity nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Religious nouns do not use capital letters, unlike nationality nouns. Le musulman -
  l'Algérien."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21575-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is no article 'un/une' after 'être' when using nouns to describe identity. Il
  est Anglais: He is an Englishman."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21575-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns ending in -ien often change to -ienne in the feminine form: le chrétien - la
  chrétienne."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21575-5
  a curric:KeyLearningPoint ;
  rdfs:label """To make nouns plural, we usually add an -s. Nouns ending in -eu, -(e)au, -al or -ail
  make their plurals with -(au)x."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25510-1
  a curric:KeyLearningPoint ;
  rdfs:label """[un/um] is pronounced as in 'un' (a). [un/um] becomes non-nasal before a vowel e.g.
  'unité'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25510-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'entendre' are similar in the present/perfect tenses but verbs like
  'venir' are very different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25510-3
  a curric:KeyLearningPoint ;
  rdfs:label """Listen for an auxiliary verb to identify the tense, only the perfect tense has an
  auxiliary verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25510-4
  a curric:KeyLearningPoint ;
  rdfs:label "Add question words to the start of a sentence to ask an information question."@en ;
  dcterms:modified "2026-06-07T15:30:29.254754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25510-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is no subject-verb inversion when 'qui' is the first word of clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.254758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21581-1
  a curric:KeyLearningPoint ;
  rdfs:label "[en/an] is pronounced as in 'enfant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.254763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21581-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ain/in] is pronounced as in 'train'."@en ;
  dcterms:modified "2026-06-07T15:30:29.254767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21581-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means to have/having but is often used when we would use the verb to be
  (être) in English to describe feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21581-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using 'avoir' expressions like 'avoir raison' and 'avoir chaud', there is no
  article after avoir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21581-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Donc’ means ‘so/therefore’. It connects two short, related sentences to make a
  longer sentence with cause and effect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21499-1
  a curric:KeyLearningPoint ;
  rdfs:label """The [r] is a common sound in French and is tricky to pronounce, so keep practising
  your tongue-twisters!"""@en ;
  dcterms:modified "2026-06-07T15:30:29.255445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21499-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ce, cet, cette and ces' are demonstrative adjectives, used to specify which noun
  you are referring to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21499-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ce' means 'this' for masculine nouns, 'cet' if they start with a vowel or 'h'.
  'Cette' goes before feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21499-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Ces' goes with all plural nouns and means 'these'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21499-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can add a demonstrative adjective to an intonation question to make it more
  specific."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25501-1
  a curric:KeyLearningPoint ;
  rdfs:label "[y] is pronounced as in 'y' and [oy] is pronounced as in 'envoyer'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25501-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like ‘lire’ add -s to the stem before adding the regular endings -ons, -ez and
  -ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25501-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 's' is pronounced in the plural forms of the verb but is a silent final
  consonant at the end of 'je' and 'tu' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25501-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'traduire', 'conduire', 'interdire' and 'dire' follow the same pattern
  except for the exception 'vous dites'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21470-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French [g] has two sounds: soft before the letters e, i and y and hard before
  other letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21470-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'aller' in the present tense followed by an infinitive to talk about future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21470-3
  a curric:KeyLearningPoint ;
  rdfs:label """'They' has two different pronouns in French: 'ils' for a male or mixed gender group
  and 'elles' for a female group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Questions about future plans follow the normal patterns for closed (yes/no) and
  information questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21470-5
  a curric:KeyLearningPoint ;
  rdfs:label """When forming inversion questions for future plans, only 'aller' and the pronoun swap
  e.g. Vont-ils venir ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.256244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21594-1
  a curric:KeyLearningPoint ;
  rdfs:label "[oi] is pronounced as in 'voir'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions tell us how a noun is related to another noun, often in terms of place
  or time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21594-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Moi' and 'toi' are emphatic pronouns. We use them after prepositions."@en ;
  dcterms:modified "2026-06-07T15:30:29.256411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21488-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [om] is the same sound as [on], like in 'non' and 'nom'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21488-2
  a curric:KeyLearningPoint ;
  rdfs:label """When this sound appears in front of the letters -p or -b, it is spelled with [om]
  instead of [on]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21488-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'his', 'her' we use the possessive adjectives 'son' (masculine) 'sa'
  (feminine) or 'ses' (plural)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21488-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives agree with the noun that follows so we often need context to
  identify the 'possessor'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21488-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Son', 'sa' 'ses' can also mean 'your' or 'their' when talking about things
  belonging to people in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21449-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [an] and [en] make the same sound, as in 'enfant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21449-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Au', 'à la', 'à l'' and 'aux' all mean 'to the'. The one you choose depends on the
  type of noun which follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21449-3
  a curric:KeyLearningPoint ;
  rdfs:label """For masculine nouns (au), for feminine (à la), if it starts with a vowel (à l') and
  if it is plural (aux)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21449-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to' a town or city, we use the preposition 'à' on its own e.g. à Londres -
  to London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21449-5
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person plural of 'aller' is 'nous allons' - we go, we are going. Due to
  liaison we pronounce the s of 'nous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21442-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting sound-symbol correspondences regularly supports accurate spelling and
  pronunciation of new/familiar words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21442-2
  a curric:KeyLearningPoint ;
  rdfs:label """To really ‘know’ a word, you need to be able to understand it and use it to listen,
  read, speak and write."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21442-3
  a curric:KeyLearningPoint ;
  rdfs:label """Secure knowledge of high frequency verbs is essential for independent
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21504-1
  a curric:KeyLearningPoint ;
  rdfs:label "The French [o] sound can be open like in 'porte' or closed like in 'photo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.257051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21504-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the [o] is the final sound, is followed by a 'z' sound, or has a circumflex [ô],
  it is closed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21504-3
  a curric:KeyLearningPoint ;
  rdfs:label "Before reading an extended text, it is important to learn key vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.257059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21504-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predicting the themes and key ideas of the text is also a useful strategy to help
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21504-5
  a curric:KeyLearningPoint ;
  rdfs:label """Applying vocabualry and grammar knowledge to understand the order of events is
  essential."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21445-1
  a curric:KeyLearningPoint ;
  rdfs:label """The e at the end of words is silent in French. This is called the silent final e or
  SFe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21445-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a noun starts with a vowel or an h, we use 'l'' for 'the'. It is important to
  learn the noun's gender by heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21445-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs like 'souvent' and 'rarement' come after the verb in French, unlike in
  English where they come before."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21445-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to the' before a singular noun starting with a vowel or an h, use the
  preposition 'à l''."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21445-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to the' before a plural noun, use 'aux'. The 'x' of 'aux' is pronounced like
  English 'z' before a vowel or an h."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21528-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before a consonant or at the end of a word the SSCs [um/un] are identical nasal
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21528-2
  a curric:KeyLearningPoint ;
  rdfs:label """When ‘um’ and ‘un’ come before a vowel the ‘m’ and ‘n’ are pronounced as two
  different oral sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21528-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs describe verbs, whereas adjectives describe nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.257585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21528-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Plus' or 'moins' go before adverbs to compare how things happen, e.g. Inès arrive
  plus vite: Inès arrives more quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21528-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Better' is both adjective and adverb in English. In French, the adjective is
  'meilleur(e)' and the adverb is 'mieux'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21577-1
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives have different forms based on the gender and number of the
  possessed noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21577-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Mon', 'ma', 'mes' and 'ton', 'ta', 'tes' are possessive adjectives meaning 'my' and
  'your' in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21577-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Son', 'sa' and 'ses' are possessive adjectives meaning 'his/her' in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.257605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21577-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Notre', 'nos' and 'votre', 'vos' are possessive adjectives meaning 'our' and 'your
  (plural or formal)' in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21577-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Leur' and 'leurs' mean 'they'. Like 'notre' and 'votre', 'leur' does not change
  based on the gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21602-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondence [-ill/ille] sounds as in 'fille'; vowel + -ill/ille also
  has a final sound like English 'y'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21602-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use the emphatic pronouns 'moi' and 'toi' after a preposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.258412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21602-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Qui' (who/which/that) can be used to introduce more information about a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.258418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21602-4
  a curric:KeyLearningPoint ;
  rdfs:label """Movement + change of state verbs take 'être', not 'avoir' in the perfect tense. Past
  participles agree in gender/number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21514-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [oy] sounds like [oi] + 'yih', like the [oy] in 'envoyer', which means 'to
  send'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21514-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pronoun 'vous' means you (pl), but it can also mean you (sing) when you talk to
  one person in a formal situation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21514-3
  a curric:KeyLearningPoint ;
  rdfs:label """This could be an older person, someone in a position of responsibility or an adult
  you don't know well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21514-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'tu' for you (sing) in informal situations, such as when we talk to friends,
  family and children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21514-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are two ways of saying please in French: 's'il te plait' (informal) and 's'il
  vous plait' (formal)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21592-1
  a curric:KeyLearningPoint ;
  rdfs:label "[au] is pronounced as in 'gauche'."@en ;
  dcterms:modified "2026-06-07T15:30:29.259254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21592-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many French verbs are followed by 'à' or 'de' and a noun; 'à' and 'de' link to the
  definite article before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21592-3
  a curric:KeyLearningPoint ;
  rdfs:label """'De' is 'du' before masculine nouns, 'de la' (feminine), 'des' (plural) or 'de l''
  before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21592-4
  a curric:KeyLearningPoint ;
  rdfs:label """'À' is 'au' before masculine nouns, 'à la' (feminine), 'aux' (plural) or 'à l''
  before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21592-5
  a curric:KeyLearningPoint ;
  rdfs:label """The present endings for verbs like 'entendre' are -s, -s, -, -ons, -ez, -ent.
  'Mettre' drops a 't' in the singular form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21517-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [y] sounds different to the English [y] and is pronounced as in 'physique'
  and 'style'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21517-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like choisir (to choose, choosing) form another group of -IR verbs, including
  'remplir' (to fill) and 'réussir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21517-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'you' (singular) with a verb like choisir, remove the -IR from the infinitive
  and add -is: tu choisis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21517-4
  a curric:KeyLearningPoint ;
  rdfs:label "This is the same ending as the 'je' form of verbs like 'choisir'."@en ;
  dcterms:modified "2026-06-07T15:30:29.259614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21517-5
  a curric:KeyLearningPoint ;
  rdfs:label """The French school system is different to the English. For example, you don't wear
  school uniform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25493-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [h] is silent in French, like in the words 'hôtel', 'hôpital' and
  'heure'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25493-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of time tell you when something happens, e.g. 'le week-end prochain' which
  means 'next weekend'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25493-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Mardi', used without an article, means 'on Tuesday' or 'this coming Tuesday'. 'Ce
  mardi' means the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25493-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Le mardi' means 'on Tuesday' or 'every Tuesday'. We use this to talk about what we
  do every week."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25493-5
  a curric:KeyLearningPoint ;
  rdfs:label """The 'nous' form of verbs like 'choisir' ends in -issons, the 'vous' form ends in
  -issez."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21571-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quebec is a region on the East Coast of Canada, the only Canadian province with
  French as its only official language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21571-2
  a curric:KeyLearningPoint ;
  rdfs:label """Connaître is conjugated as follows in the present tense singular: connais, connais,
  connaît."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21571-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Connaitre' and 'savoir' both mean 'to know'. 'Connaitre' means knowing/being
  familiar with a person/place/thing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21571-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Savoir' means 'can/know how to' when used as a modal verb + 'know' when used alone
  or with a question word/ 'que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21612-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates may look very similar to English but sound quite different so attention
  must be paid to pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21612-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs require à or de before an infinitive e.g. aider à, arrêter de. Some like
  'continuer' can have à or de."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21612-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are two correct spellings with identical pronunciation for the singular forms
  of 'essayer'; 'essaie' and 'essaye'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21612-4
  a curric:KeyLearningPoint ;
  rdfs:label "'On' is an impersonal pronoun applying to everyone."@en ;
  dcterms:modified "2026-06-07T15:30:29.260346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21612-5
  a curric:KeyLearningPoint ;
  rdfs:label """il est + adjective + de + infinitive can be used to express it is
  difficult/easy/forbidden to + a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21596-1
  a curric:KeyLearningPoint ;
  rdfs:label "[s] is pronounced as in 'maison'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21596-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'la' to sixième, cinquième, quatrième + troisième to say school years. The lower
  the number, the older the pupils."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21596-3
  a curric:KeyLearningPoint ;
  rdfs:label """In English, knowledge is singular + plural. When you have lots of knowledge in
  French, add s for plural, connissances"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21596-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the imperfect tense to talk about events and actions that used to happen
  regularly in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21596-5
  a curric:KeyLearningPoint ;
  rdfs:label """For the 1st person imperfect, take je + the stem of present tense ‘nous’ form. Add
  the ending -ais. e.g. 'je regardais'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21529-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before a consonant or at the end of a word the SSCs [um/un] sound the same; they are
  both nasal sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21529-2
  a curric:KeyLearningPoint ;
  rdfs:label """When ‘um’ or ‘un’ come before a vowel the ‘m’ and ‘n’ are pronounced and the two
  oral sounds are like [u] + 'm' or 'n'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21529-3
  a curric:KeyLearningPoint ;
  rdfs:label """The three ways to compare two nouns using a comparative adjective are 'plus...que',
  'moins...que' and 'aussi ... que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21529-4
  a curric:KeyLearningPoint ;
  rdfs:label """The adjective goes in the middle of the comparative phrase, e.g. 'le village est
  plus grand que la ville'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21529-5
  a curric:KeyLearningPoint ;
  rdfs:label """In this way, we can compare how people do things using adverbs in the middle, e.g.
  'Léa travaille plus vite qu'Amir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25503-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many 'Francophone' (French-speaking) countries to explore around the
  world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25503-2
  a curric:KeyLearningPoint ;
  rdfs:label """French and English are spoken in Quebec as the province was a French and English
  colony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25503-3
  a curric:KeyLearningPoint ;
  rdfs:label "[e] is pronounced as in 'je'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25503-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Mettre' follows the same pattern of endings as 'entendre', but loses a -t- in the
  'je', 'tu' and 'il/elle' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21570-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ai] is pronounced as in 'vrai'; [é/er/ez] is pronounced as in 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Without an article, words like 'québecois' are adjectives, with a capital letter,
  they are nouns meaning a person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21570-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the preposition 'à' to talk about going to/being in a town/city and 'en' with
  feminine countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'au' ('à' + le) to talk about going to/being in masculine countries (usually
  country names not ending in -e)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21605-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'prendre' means to take, taking; it follows the same verb pattern as
  'comprendre' and 'apprendre'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21605-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'lire' means 'to read'; it follows the same verb pattern as 'dire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21605-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs cannot stand alone and must be followed by a direct object; e.g. 'je
  prends un livre'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21605-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs can stand alone, or take a direct object, e.g. 'il comprend l'anglais',
  'il comprend.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.261334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21605-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some verbs stand alone and do not take a direct object, e.g. 'nous dormons'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21500-1
  a curric:KeyLearningPoint ;
  rdfs:label """French vowel sounds can be open or closed. The closed [eu] sound is like the [eu] in
  'peu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21500-2
  a curric:KeyLearningPoint ;
  rdfs:label "The open [eu/œu] sound is in the word 'cœur'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21500-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French, Switzerland is 'la Suisse' and 'Genève' (Geneva) is one of its major
  cities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21500-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 'il, elle' form of the perfect tense uses 'il, elle a' and the past participle
  to express what he or she did."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21500-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using different verb forms in the perfect tense, the form of 'avoir' changes,
  not the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25489-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can pronounce a usually silent final consonant if it is followed by a vowel;
  this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the partitive article with uncountable nouns/ non-specific amounts; change to
  'de' after quantities/negatives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25489-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'est-ce que' at the beginning of a sentence to signal questioning."@en ;
  dcterms:modified "2026-06-07T15:30:29.262573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25489-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make perfect tense sentences negative, put 'ne … pas' around the form of
  'avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25500-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondences [aill/ail], [eill/eil], [euill/euil] and [ouill/ouil]
  are pronounced like a vowel + 'yih'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25500-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ending for -RE verbs like 'entendre' in the 3rd person plural form is -ent, the
  same ending as for -ER verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25500-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pronounce the 'd' in the 3rd person plural with -RE verbs but not in the singular
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25500-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ask questions with verbs like 'entendre' by using intonation; raise your voice at
  the end of a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21588-1
  a curric:KeyLearningPoint ;
  rdfs:label "[s] is pronounced as in 'maison'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21588-2
  a curric:KeyLearningPoint ;
  rdfs:label """A double 's' between vowels is always soft but a single 's' between vowels is always
  a hard 's' [s] and sounds like 'z'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Movement verbs such as 'entrer', 'tomber' and 'monter' use 'être' in the perfect
  tense before the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21588-4
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles used with être must agree in gender + number with the subject of
  the verb. Add 's' for plural subjects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21588-5
  a curric:KeyLearningPoint ;
  rdfs:label """How (often) adverbs usually go after the first verb but longer -ment adverbs usually
  go at the end or even the start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21417-1
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a question you can raise the pitch of your voice at the end of a
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21417-2
  a curric:KeyLearningPoint ;
  rdfs:label """To get more information, we can add a question word such as 'quoi' (what) at the end
  of intonation questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21417-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Faire' means 'to do/make'. Use je fais for 'I do/make', il fait for 'he
  does/makes', elle fait for 'she does/makes'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use definite articles le, la, les, l' after the verb faire to describe every day
  activities e.g. 'Il fait les courses.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.263489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21417-5
  a curric:KeyLearningPoint ;
  rdfs:label "[ain/in] sounds like 'train'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25485-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ill/ille] sounds like 'famille' with some exceptions
  (mille/Lille/tranquille/ville)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Double 'l' after any other vowel is pronounced like a normal 'l' e.g. 'salle'."@en ;
  dcterms:modified "2026-06-07T15:30:29.263737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25485-3
  a curric:KeyLearningPoint ;
  rdfs:label """Change the partitive article (du/de la/de l') to de/d' after quantity expressions
  and negatives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Articles can't be omitted like in English. Use the definite article with specific
  nouns/giving opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25485-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use the partitive article for non-specific and uncountable nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.263748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21522-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ain/in] sounds like 'train'. [aim/im] sounds like 'faim'. These sound-symbol
  correspondences have the same sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21522-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Aller' means to go/going, an irregular verb used with infinitives to give future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21522-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make two-verb structures negative, put ne … pas around the first (conjugated)
  verb in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21522-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make double verbs negative, put 'ne ... pas' around the first (conjugated) verb
  in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21522-5
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions for 'in/to' with places vary for the type of place, the gender and
  whether it is singular or plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25499-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondences [aill/ail], [eill/eil], [euill/euil] and [ouill/ouil]
  are pronounced like a vowel + 'yih'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25499-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Les faux amis' or 'false friends' are words that look like cognates but have
  different meanings in English and French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25499-3
  a curric:KeyLearningPoint ;
  rdfs:label """The endings for verbs like 'entendre' in the present tense in the 1st and 2nd
  persons plural are 'ons' and 'ez'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21576-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vowel sounds in French can be open or closed."@en ;
  dcterms:modified "2026-06-07T15:30:29.263927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21576-2
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [eu] can be closed, like in 'peu'. Your tongue should be near the top of
  your mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21576-3
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [eu] can be open, like in 'peur'. Your tongue should be near the bottom of
  your mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21576-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in -eur often end in -or or -our in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.263941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21576-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'your' when talking to someone formally or to more than one person, use:
  'votre' (m/f) and 'vos' (mpl/fpl)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21561-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letters 'd', 's', 't' and 'x' are usually silent at the end of words in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21561-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plural forms of être are 'nous sommes', (we are) 'vous êtes' (you are) and
  'ils/elles' sont (they are)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21561-3
  a curric:KeyLearningPoint ;
  rdfs:label """The most common adjective agreement pattern for plural adjectives is the addition of
  -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21561-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives already ending -s/-x don't change + masculine plural adjectives ending
  -al change to aux in the plural form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25498-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [tion], [ill/ille] and [ien] all contain [i] and are pronounced as in
  ‘attention’, ‘fille’, ‘bien’ and ‘midi’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25498-2
  a curric:KeyLearningPoint ;
  rdfs:label """Translate 'tout' as ‘the whole’ in English in the singular form (uncountable) and
  ‘all’ in the plural form (countable)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25498-3
  a curric:KeyLearningPoint ;
  rdfs:label """The endings for verbs like 'écrire' are ‘s’, ‘s’ and ‘t’, the same as for verbs like
  ‘lire’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25498-4
  a curric:KeyLearningPoint ;
  rdfs:label """Endings are different in the plural form, so it is better to think of them as
  different types of -re verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21501-1
  a curric:KeyLearningPoint ;
  rdfs:label """French vowel sounds can be open or closed. The closed [eu] sound is like the [eu] in
  'peu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21501-2
  a curric:KeyLearningPoint ;
  rdfs:label "The open [eu/œu] sound is in the word 'cœur'."@en ;
  dcterms:modified "2026-06-07T15:30:29.265927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21501-3
  a curric:KeyLearningPoint ;
  rdfs:label """A pronounced consonant follows an open [eu/œu] sound, for example 'fleur' or
  'jeune'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21501-4
  a curric:KeyLearningPoint ;
  rdfs:label """To express there is or are, we use the expression 'il y a'. To express there was or
  were, we use 'il y avait'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21501-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both of these remain the same for singular or plural noun descriptions e.g. il y
  avait un chien, il y avait cinq chats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21574-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in -ien become -ienne in the feminine form: canadien-canadienne.
  The 'e' in -ienne sounds like [è/ê]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21574-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Soutenir' (to support) and 'appartenir à' (to belong to) follow the same verb
  pattern as 'venir'. Je soutiens ..."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21574-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'croire' (to believe) follows the same pattern as 'boire' in its singular
  form. Je crois, tu crois etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21574-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nationality adjectives can become nouns when used with an article: française - la
  Française."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21574-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is no article 'un/une' after 'être' when using nouns to describe identity. Il
  est Anglais: He is an Englishman."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25483-1
  a curric:KeyLearningPoint ;
  rdfs:label "[gn] sounds like 'ligne'."@en ;
  dcterms:modified "2026-06-07T15:30:29.266557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25483-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'envoyer' changes spelling in the present tense from 'y' to 'ie' in all
  forms apart from 'nous' and 'vous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25483-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make the perfect tense with regular -er verbs, use 'j'ai' followed by the past
  participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25483-4
  a curric:KeyLearningPoint ;
  rdfs:label "To make the past participle of regular -er verbs, replace -er with é."@en ;
  dcterms:modified "2026-06-07T15:30:29.266568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25509-1
  a curric:KeyLearningPoint ;
  rdfs:label """[on] is pronounced as in 'non' and [om] is pronounced as in 'nom'. They become
  non-nasal before a vowel e.g. 'colonial'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25509-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the past participles of verbs like 'entendre' and 'venir', remove -re/ir
  from the infinitive, add the ending -u."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25509-3
  a curric:KeyLearningPoint ;
  rdfs:label "With verbs like 'mettre', remove -ettre from the infinitive and add -is."@en ;
  dcterms:modified "2026-06-07T15:30:29.266580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25509-4
  a curric:KeyLearningPoint ;
  rdfs:label """Turn perfect tense sentences into questions by inverting the subject and auxiliary
  verb and adding a hyphen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25509-5
  a curric:KeyLearningPoint ;
  rdfs:label "Add -t- between il/elle and the verb to create a liaison."@en ;
  dcterms:modified "2026-06-07T15:30:29.266587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21610-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ç/c] is pronounced as in 'ici'"@en ;
  dcterms:modified "2026-06-07T15:30:29.266790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21610-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs, like 'apprendre', 'aider' and 'commencer', form two-verb structures with
  'à' followed by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21610-3
  a curric:KeyLearningPoint ;
  rdfs:label """Opinion verbs, modal verbs and 'aller' don't require 'a'; they are followed directly
  by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21599-1
  a curric:KeyLearningPoint ;
  rdfs:label """The present and imperfect tenses are one word tenses with the same word order so
  only the verb endings tell them apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21599-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense describes an ongoing action for a period of time in the
  past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21599-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Il y a' + noun means there is/are. 'Il y a' + time means ago."@en ;
  dcterms:modified "2026-06-07T15:30:29.267894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Translate 'year' as 'an' after a number. So, 'il y a deux ans' means 'two years
  ago'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21436-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Nous sommes' and 'vous êtes' are the 1st and 2nd persons plural of the verb 'être'
  ('to be, being')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21436-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ils sont' and 'elles sont' are the third person plural of the verb 'être' ('to be,
  being')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21436-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often add -e in the feminine form, this is regular adjective gender
  agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21436-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives often add -s as the regular marker in the plural form."@en ;
  dcterms:modified "2026-06-07T15:30:29.268418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21436-5
  a curric:KeyLearningPoint ;
  rdfs:label """Describing a photograph is a useful exercise to consolidate key grammar and
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21600-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pronunciation difference between [é] in the perfect tense + [ai] in the
  imperfect tense greatly alters meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21600-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ai] is pronounced as in vrai'; [é] is pronounced as in 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Languages are not fixed; new words enter the language constantly whilst other words
  fall out of use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21600-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 'tu' form of the imperfect tense is formed like the 'je' form (present tense
  nous form, remove -ons, add -ais)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21562-1
  a curric:KeyLearningPoint ;
  rdfs:label "[é/er/ez] is pronounced as in 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21562-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form -er verbs in the present tense, remove -er and add the endings -e, -es and
  -e for the singular verb forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21562-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘(in order) to do something’ or ‘without doing something’, use 'pour' or
  'sans' before a verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ask intonation questions in French by raising your voice pitch; add a question word
  at the end for more information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21586-1
  a curric:KeyLearningPoint ;
  rdfs:label "[è/ê] is pronounced as in 'tête'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21586-2
  a curric:KeyLearningPoint ;
  rdfs:label """The letter 'e' is usually pronounced as [è/ê] before double consonants or the
  letters c/l at the end of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21586-3
  a curric:KeyLearningPoint ;
  rdfs:label """Movement verbs like 'aller' and 'rester' take 'être' instead of 'avoir' in the
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21586-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'e' to the past participle of verbs that take 'être' if the subject is
  feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regularly revisiting SSCs supports accurate spelling and pronunciation, building
  confidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25488-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the perfect tense with -er verbs, use the present tense of ‘avoir’ and a
  past participle ending in 'é'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25488-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Which’ agrees with the gender and number of the noun it describes; 'quel',
  'quelle', 'quels' and 'quelles'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25488-4
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'à' follows 'jouer' with sports, 'de' follows 'jouer' with musical
  instruments and 'faire' with sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25488-5
  a curric:KeyLearningPoint ;
  rdfs:label """To make job nouns feminine, add -e, change the spelling from -eur to -rice/euse, or
  just change the article.."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21510-1
  a curric:KeyLearningPoint ;
  rdfs:label "[th] sounds like 'thé'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21510-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'acheter' and 'peser' have a spelling change in the present tense from 'e'
  to 'è' affecting pronounciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21510-3
  a curric:KeyLearningPoint ;
  rdfs:label """Un/une/des is for whole items; the partitive article du/de la/de l' is for parts. It
  must not be missed out in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21510-4
  a curric:KeyLearningPoint ;
  rdfs:label """De + definite article means, e.g. 'of the', 'from the'. The partitive looks
  identical but its meaning is 'some'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21510-5
  a curric:KeyLearningPoint ;
  rdfs:label """The word for 'some' changes depending on the gender/number/spelling of the noun it
  describes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25504-1
  a curric:KeyLearningPoint ;
  rdfs:label "[r] is pronounced as in 'rue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25504-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add the prefix -re before a verb to mean 'do the action again'. Pronunciation is
  different to English 're'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25504-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ne ... jamais' means 'never', it negates in the same way as 'ne ... pas',
  surrounding the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25504-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite articles (un, une, des) and partitive articles (du, de la, de l’, des)
  change to 'de' after a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21519-1
  a curric:KeyLearningPoint ;
  rdfs:label """To make masculine nouns ending -eu/eau plural, add -x and change nouns ending
  -al/ail to -aux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21519-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make most adjectives plural, add -s, which makes no difference to pronunciation,
  as 's' is a Silent Final Consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21519-3
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine plural adjectives ending -eux don’t change, adjectives ending -al change
  to aux in the masculine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21519-4
  a curric:KeyLearningPoint ;
  rdfs:label """The feminine versions of -euse adjectives are regular, just add -s, which is
  silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21519-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use grammatical context clues, familiar vocabulary and cognates to read longer
  French texts, including articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21466-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting key phonics, vocabulary and grammar helps to embed knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.269216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21466-2
  a curric:KeyLearningPoint ;
  rdfs:label "Most adjectives come after the noun in French: 'un livre intéressant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21466-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives go before the noun. These adjectives refer to beauty, age, good/bad
  and size (BAGS): 'un vieux vélo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21466-4
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, read the sentences carefully to identify key vocabulary and
  grammatical structures before translating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21489-1
  a curric:KeyLearningPoint ;
  rdfs:label """To express the date in French we add 'le' before the number and then add the
  month."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21489-2
  a curric:KeyLearningPoint ;
  rdfs:label "To ask someone when their birthday is you say 'C'est quand ton anniversaire ?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21489-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'our' in French, we use the possessive adjectives 'notre' or 'nos'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21489-4
  a curric:KeyLearningPoint ;
  rdfs:label """The words for 'our' only agree with the number of the noun, it is 'notre' for
  masculine and feminine singular nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21595-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs take à or de before a noun; it's important to learn each verb together
  with its required preposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21595-2
  a curric:KeyLearningPoint ;
  rdfs:label """The forms of 'à' and 'de' change before masculine and plural nouns to 'au', 'aux',
  'du' and 'des'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21595-3
  a curric:KeyLearningPoint ;
  rdfs:label """Learn the genders of all nouns so that you know which form of 'à' or 'de' to
  use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21590-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense can be translated into the simple past and present perfect in
  English depending on the context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21590-2
  a curric:KeyLearningPoint ;
  rdfs:label """The present tense has one conjugated verb; the perfect tense has two verbs, a part
  of avoir/être + a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21590-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use a conjugated form of 'avoir' with most verbs but use 'être' with movement verbs
  and past participles must agree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21513-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [euil/euill] sounds like the long [eu/œu] + 'yih', like in the word
  'feuille', which means 'leaf'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21513-2
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'sans' can be followed by a noun or a verb in its infinitive
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21513-3
  a curric:KeyLearningPoint ;
  rdfs:label """The -IR verbs 'sortir', 'venir' , 'partir', 'devenir' and 'revenir' follow the same
  pattern of verb endings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21513-4
  a curric:KeyLearningPoint ;
  rdfs:label "In the 3rd person plural form these -IR verbs end in -ent."@en ;
  dcterms:modified "2026-06-07T15:30:29.269647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21513-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'sortir' keeps the 't' to become 'sortent' and 'venir' doubles its 'n' to
  become 'viennent'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21589-1
  a curric:KeyLearningPoint ;
  rdfs:label """'S' at the beginning of a word is soft 's' (sont) but a single 's' between vowels is
  a hard 's' ('vous êtes')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21589-2
  a curric:KeyLearningPoint ;
  rdfs:label """All French people have a 'Carte Vitale' necessary to use French health services.
  Call the SAMU in a medical emergency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21589-3
  a curric:KeyLearningPoint ;
  rdfs:label """The present tense has one conjugated verb; the perfect tense has two verbs, a part
  of avoir/être + a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21589-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use a conjugated form of 'avoir' with most verbs but use 'être' with movement verbs,
  and past participles must agree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21616-1
  a curric:KeyLearningPoint ;
  rdfs:label "[tion] is pronounced as in 'attention'. [on] is pronounced as in 'non'."@en ;
  dcterms:modified "2026-06-07T15:30:29.269901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21616-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Concorde was a project between France and the UK after the 2nd world war to
  build supersonic planes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions of place tell us where things are in relation to other things. Some
  like 'loin' need 'de' before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Say French years the same as normal numbers, not split like in English. There is no
  –s after mille/cent in years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21616-5
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions of movement are used to translate ‘to’ and ‘from’; 'à' and 'de' can
  change before the definite article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21502-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closed [o/ô] sound can be found in French words like 'hôpital' and 'photo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.270299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21502-2
  a curric:KeyLearningPoint ;
  rdfs:label """Geneva is an important city in Switzerland and is the base for international
  organisations such as the Red Cross."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21502-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can form an intonation question in French by raising your voice at the end of a
  statement: 'Il a visité la ville ?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21502-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatively, you can add 'est-ce que' to the beginning of a statement: 'Est-ce
  qu'il a visité la ville ?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'me' and 'te' as reflexive pronouns in French. Shorten them to m'/t' before a
  vowel/silent 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21621-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs can mean different things when they’re used reflexively and can be
  translated differently in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21498-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French SSC [r] sounds very different to the English. It is a raspy sound
  pronounced in the back of your throat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21498-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use the perfect tense in French to say what I did. It uses 'j'ai' from the verb
  'avoir' with a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21498-3
  a curric:KeyLearningPoint ;
  rdfs:label "To form the past participle of regular -er verbs, you replace the -er with -é."@en ;
  dcterms:modified "2026-06-07T15:30:29.271024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21498-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the perfect tense with 'tu' you use 'tu as' followed by the same past
  participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21498-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form yes, no questions in the perfect tense, you simply raise your voice at the
  end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21583-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use un/une to talk about whole things, and du/de la/de l' (the partitive article) to
  talk about 'part' of something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21583-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whole things are normally countable – you can put 'a' or a number in front
  of them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21583-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some nouns are uncountable. You can't put 'a' or a number in front of them.
  Uncountable nouns only take the partitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21583-4
  a curric:KeyLearningPoint ;
  rdfs:label "The partitive article changes to 'de' after a quantity and in negatives."@en ;
  dcterms:modified "2026-06-07T15:30:29.272682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21444-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound symbol correspondences [ou] and [u] sound similar but they are different
  so it is important to practise them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21444-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of 'aller' ('to go, going') are 'je vais' (I go), 'tu vas' (you
  go) and 'il, elle va' (he, she goes)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21444-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use question words like 'où ?' to form intonation questions. In French the
  question word goes after the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21444-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to go by' + transport in French we use 'aller' with 'en' + noun, for example
  'je vais en train' (I go by train)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21409-1
  a curric:KeyLearningPoint ;
  rdfs:label "The [e] sounds like 'je'."@en ;
  dcterms:modified "2026-06-07T15:30:29.273034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21409-2
  a curric:KeyLearningPoint ;
  rdfs:label """The final 't' in 'c'est' is a silent final consonant but if followed by a vowel it
  is pronounced ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21409-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ce' means 'this/that' and 'est' means 'is'; together they make 'c'est', meaning 'it
  is' or 'this is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every noun has a gender: masculine or feminine. To say 'a/an', we use 'un' for
  masculine and 'une' for feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21413-1
  a curric:KeyLearningPoint ;
  rdfs:label "-e at the end of a word is usually silent in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.273054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21413-2
  a curric:KeyLearningPoint ;
  rdfs:label "'C'est' means it/this is but applied to people it means he/she is."@en ;
  dcterms:modified "2026-06-07T15:30:29.273058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21413-3
  a curric:KeyLearningPoint ;
  rdfs:label "An -e is often added to a person noun in the feminine form e.g une amie."@en ;
  dcterms:modified "2026-06-07T15:30:29.273062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21413-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cognates are words where most of the letters are the same in two languages."@en ;
  dcterms:modified "2026-06-07T15:30:29.273065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21413-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use cognates and our knowledge of grammar to understand French texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.273069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25487-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ail/aill] sounds like 'taille'."@en ;
  dcterms:modified "2026-06-07T15:30:29.273281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25487-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Dire' has the same ending pattern as sortir/venir, but verbs like 'prendre' are
  different in the 3rd person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives usually follow nouns they describe, but BAGS (beauty/age/goodness/size)
  adjectives come before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25487-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree with the nouns they describe. Irregular adjectives include
  'beau/belle' and 'vieux/vieille'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Regular adjectives need -e in the feminine/-s in the plural forms. Don't add another
  -e to adjectives already ending -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21485-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the nasal sound [en/an] appears before -p or -b it is spelled [em/am], e.g.
  'jambe', 'camp'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising vocabulary 'little and often' helps to strengthen your knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.273483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21485-3
  a curric:KeyLearningPoint ;
  rdfs:label "To ask information questions with 'est-ce que' the question word comes first."@en ;
  dcterms:modified "2026-06-07T15:30:29.273487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21485-4
  a curric:KeyLearningPoint ;
  rdfs:label "The subject and verb stay in the same order, there is no inversion."@en ;
  dcterms:modified "2026-06-07T15:30:29.273493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21485-5
  a curric:KeyLearningPoint ;
  rdfs:label """When the question word 'que' (what) is used before 'est-ce que', it becomes
  'qu'est-ce que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21465-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting key phonics, vocabulary and grammar helps to embed knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.274548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21465-2
  a curric:KeyLearningPoint ;
  rdfs:label "[a], [oi], [i], [ou], [u], [(e)au], [eu] and [é] are common French sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.274552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21465-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je', 'tu' 'il', 'elle', 'nous', 'vous', 'ils' and 'elles' are French pronouns.
  Verbs change to match the pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21465-4
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no and information questions can be formed with inversion: swap the subject and
  the verb '(quand) sors-tu ce soir ?'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.274562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21465-5
  a curric:KeyLearningPoint ;
  rdfs:label "To make a sentence negative, use 'ne ... pas' around the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.274566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25486-1
  a curric:KeyLearningPoint ;
  rdfs:label "[a] sounds like 'animal'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25486-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ail/aill] sounds like 'taille'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25486-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'sortir' and 'dormir' have the same ending pattern (-s, -s, -t) as does
  'venir' with a stem change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25486-4
  a curric:KeyLearningPoint ;
  rdfs:label """How/how often adverbs usually come after the verb they describe and where/when
  adverbs usually come at the start/end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25486-5
  a curric:KeyLearningPoint ;
  rdfs:label """An exception is the adverb 'parfois' which comes at the start of a sentence. Word
  order can differ in French/English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21406-1
  a curric:KeyLearningPoint ;
  rdfs:label """When an adjective describes a woman or girl, its spelling and sound can change. This
  is called the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21406-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most common change is to add an 'e' to the adjective to make the
  feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding 'e' to an adjective can change the pronunciation. An 'e' following a
  consonant means we do hear the consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21406-4
  a curric:KeyLearningPoint ;
  rdfs:label """Useful adjectives are anglais (English), français (French), grand (tall), petit
  (short). We add 'e' for feminine forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21406-5
  a curric:KeyLearningPoint ;
  rdfs:label "[a] sounds like 'animal'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21487-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [ain] and [in] sound the same. This is also the same sound as [aim/im]."@en ;
  dcterms:modified "2026-06-07T15:30:29.281584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21487-2
  a curric:KeyLearningPoint ;
  rdfs:label """When this nasal sound appears in front of the letters -p or -b, it is spelled [im]
  instead of [in], e.g. 'timbre'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21487-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French, the subject pronoun 'on' is used to talk about what people in
  general do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21487-4
  a curric:KeyLearningPoint ;
  rdfs:label """'On' can be translated as 'everyone' (or 'people'), 'you' or 'one'. It is commonly
  used in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21487-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pronoun 'on' uses the same verb endings as 'il, elle'."@en ;
  dcterms:modified "2026-06-07T15:30:29.281599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21408-1
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] sounds like 'deux'."@en ;
  dcterms:modified "2026-06-07T15:30:29.281642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21408-2
  a curric:KeyLearningPoint ;
  rdfs:label """When an adjective is feminine, its spelling and sound can change. Usually an 'e' is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21408-3
  a curric:KeyLearningPoint ;
  rdfs:label """An 'e' is not added to form a feminine adjective if the masculine adjective already
  ends in '-e', e.g., 'triste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21408-4
  a curric:KeyLearningPoint ;
  rdfs:label "To change a statement into a question, you can raise your voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.281654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21408-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use 'oui' (yes) and 'non' (no) to answer questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.281657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21412-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'je suis' for 'I am', 'tu es' for 'you are', 'il est' for 'he is' and 'elle est'
  for 'she is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21412-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'j'ai' for 'I have', 'tu as' for 'you have', 'il a' for 'he has' and 'elle a'
  for 'she has'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21412-3
  a curric:KeyLearningPoint ;
  rdfs:label "In French, adjectives normally come after the noun, e.g., 'un ordinateur cher'."@en ;
  dcterms:modified "2026-06-07T15:30:29.287033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21412-4
  a curric:KeyLearningPoint ;
  rdfs:label """An 'e' is added to many adjectives to form the feminine adjective, but not if the
  adjective already ends in -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21412-5
  a curric:KeyLearningPoint ;
  rdfs:label "[ou] sounds like 'nous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.287043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21411-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Avoir' means 'to have, having', 'j'ai' means 'I have', 'tu as' means 'you
  have'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21411-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a question, you can raise the pitch of your voice at the end of a
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21411-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'c'est' plus an adjective or 'c'est' plus 'un/une' and a noun to say what
  something is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21411-4
  a curric:KeyLearningPoint ;
  rdfs:label "[u] sounds like 'tu' and [eu] sounds like 'deux'."@en ;
  dcterms:modified "2026-06-07T15:30:29.287876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21410-1
  a curric:KeyLearningPoint ;
  rdfs:label "[au/eau] sounds like 'gauche'."@en ;
  dcterms:modified "2026-06-07T15:30:29.291811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Avoir means 'to have, having', j'ai means 'I have', il a means 'he has' and elle a
  means 'she has'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21410-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pronoun je becomes j' before a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.291819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21410-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say what someone has we can use part of the verb 'avoir' followed by un/une and a
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21508-1
  a curric:KeyLearningPoint ;
  rdfs:label "[s] sounds like maison"@en ;
  dcterms:modified "2026-06-07T15:30:29.301159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21508-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two 's' sounds in French. Use the hard 's' between 2 vowels and soft 's'
  in other words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21508-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'de' can mean 'of', 'from' and sometimes it's not translated
  at all."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21508-4
  a curric:KeyLearningPoint ;
  rdfs:label """'De' changes before the definite article; use 'du' for masculine nouns, 'de la' for
  feminine and 'de l'' before vowels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21426-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ien] sounds like 'bien'"@en ;
  dcterms:modified "2026-06-07T15:30:29.305384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21426-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple present tense singular endings are -e with 'je, -es with 'tu' and -e'
  with il/elle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.305388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21426-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use à after to penser to say 'think about' something/someone."@en ;
  dcterms:modified "2026-06-07T15:30:29.305392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21426-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'penser que' (think that) to give opinions in French. 'Que' always follows even
  if we would miss it out in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21416-1
  a curric:KeyLearningPoint ;
  rdfs:label "'On' sounds like 'non'."@en ;
  dcterms:modified "2026-06-07T15:30:29.306959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Add -s to most nouns in the plural form."@en ;
  dcterms:modified "2026-06-07T15:30:29.306963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21416-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘the’ for plural nouns, use ‘les’ and to say ‘the’ before nouns beginning
  with ‘h’ or a vowel, use ‘l’'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21416-4
  a curric:KeyLearningPoint ;
  rdfs:label """The final 's' in a word is a silent final consonant, but if is followed by a vowel,
  it is pronounced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21407-1
  a curric:KeyLearningPoint ;
  rdfs:label "[i] sounds like midi."@en ;
  dcterms:modified "2026-06-07T15:30:29.307547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21407-2
  a curric:KeyLearningPoint ;
  rdfs:label """être means 'to be, being', je suis means 'I am', il est means 'he is' and elle est
  means 'she is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21407-3
  a curric:KeyLearningPoint ;
  rdfs:label "Je means 'I', il means 'he' and elle means 'she'. They are pronouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.307555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21407-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates are words which share most of the same letters in two languages (e.g.
  English and French)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21518-1
  a curric:KeyLearningPoint ;
  rdfs:label """French is not a stress-timed language. Sound all vowels. Say syllables equally with
  a slight emphasis on the last one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21518-2
  a curric:KeyLearningPoint ;
  rdfs:label "Add -s to the majority of nouns to make them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.309470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add -x to masculine nouns ending in -eau or -eu. There is no difference in
  pronunciation because 'x' is a SFC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21518-4
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine nouns ending -al or -ail end in -aux in the plural form; the singular and
  plural forms sound different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21452-1
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers in French should be practised regularly as they come up in many
  contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21452-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of any verb is the 'je' form, the 3rd person singular is the
  'il, elle' form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21452-3
  a curric:KeyLearningPoint ;
  rdfs:label """To summarise a text written in the 1st person singular, we switch the verb forms to
  the 3rd person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21452-4
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -er verbs, these two forms are spelt the same, but for irregular verbs
  like 'être' they will be different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21560-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most final consonants + final letter 'e' are silent e.g. 'dans' and 'timide'.
  Pronounce the consonant preceding a SFC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree with the noun they describe. Add -e to most adjectives in the
  feminine form and learn other patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21560-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular pronouns in French are 'je', 'tu', and 'il/elle'. The irregular verb
  'être' means to be'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21560-4
  a curric:KeyLearningPoint ;
  rdfs:label """Put ne … pas around the verb to negate it. 'Ne' becomes 'n' before a
  vowel/silent h."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21560-5
  a curric:KeyLearningPoint ;
  rdfs:label """Languages are not fixed; they adopt new words to reflect how people live and
  speak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21625-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to talk about things that used to happen regularly in
  the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21625-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form, take the nous form of the present tense, remove -ons, add -ais (1st/2nd
  persons) or -ait (3rd persons)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21625-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense of il y a is il y avait, which means ‘there used to be’ or
  'there was/were'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21405-1
  a curric:KeyLearningPoint ;
  rdfs:label """Je (I) and tu (you) are pronouns. They tell us who is doing the verb or who the verb
  is about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21405-2
  a curric:KeyLearningPoint ;
  rdfs:label "Être means 'to be, being', je suis means 'I am' and tu es means 'you are'."@en ;
  dcterms:modified "2026-06-07T15:30:29.315622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21405-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consonants such as -s, -t, -x and -d at the end of a word are usually silent in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21405-4
  a curric:KeyLearningPoint ;
  rdfs:label """Four important skills for learning are: écouter (listening), lire (reading), parler
  (speaking) and écrire (writing)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21419-1
  a curric:KeyLearningPoint ;
  rdfs:label "[qu] sounds like 'question'."@en ;
  dcterms:modified "2026-06-07T15:30:29.317468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21419-2
  a curric:KeyLearningPoint ;
  rdfs:label "Colours can be used as adjectives and must agree with what they are describing."@en ;
  dcterms:modified "2026-06-07T15:30:29.317474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21419-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use prior knowledge and cognates when reading longer French texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.317478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21484-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [em] and [am] are identical nasal sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.317901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21484-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'célébrer' is a regular -er verb but the 2nd é in the stem changes to è in
  all forms except 'nous' and 'vous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21484-3
  a curric:KeyLearningPoint ;
  rdfs:label """The French calendar months are similar to English but they do not have capital
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21484-4
  a curric:KeyLearningPoint ;
  rdfs:label "French numbers 13-16 are 'treize', 'quatorze', 'quinze' and 'seize'."@en ;
  dcterms:modified "2026-06-07T15:30:29.317913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21484-5
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 17-31 are made up of a combination of hyphenated numbers e.g. 'dix-sept',
  'vingt-deux', 'trente-et-un'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21415-1
  a curric:KeyLearningPoint ;
  rdfs:label "[en/an] sounds like ‘enfant’."@en ;
  dcterms:modified "2026-06-07T15:30:29.319918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21415-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every noun has a gender: masculine or feminine. To say 'the', use 'le' for masculine
  and 'la' for feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21415-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Anglais’ and ‘français’ are also nouns meaning languages. We use an article with
  languages except after 'parler/en'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21523-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ai] is pronounced as in 'vrai' and [i] as in 'midi'. Both are oral vowel
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21523-2
  a curric:KeyLearningPoint ;
  rdfs:label """Devoir, pouvoir, savoir and vouloir are modal verbs, they are usually followed by a
  second verb in the infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Savoir and pouvoir both mean 'can' but 'savoir' is used for activities requiring
  specific skills, knowing 'how to' do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21523-4
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures with infinitives, 'how' and 'how often' adverbs come before
  the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21523-5
  a curric:KeyLearningPoint ;
  rdfs:label """In negative sentences with two-verb structures with infinitives, ne ...pas surrounds
  the first verb, before the adverb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21474-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ien] sounds like 'bien'."@en ;
  dcterms:modified "2026-06-07T15:30:29.323078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21474-2
  a curric:KeyLearningPoint ;
  rdfs:label "[(a)in] sounds like 'train'."@en ;
  dcterms:modified "2026-06-07T15:30:29.323082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21474-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a two-verb sentence, make sentences negative by adding ne ... pas around the
  first verb, which should be conjugated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21474-4
  a curric:KeyLearningPoint ;
  rdfs:label """Swap the position of the subject pronoun and conjugated modal verb to ask inversion
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21468-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many French words containing [qu] are cognates. English words ending in -c, -k and
  -cal often change to -que in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21468-2
  a curric:KeyLearningPoint ;
  rdfs:label """When learning a foreign language it is important to practise vocabulary 'little and
  often' to strengthen knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21468-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be made negative by adding 'ne ... pas' around the main verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.323834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21468-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two verbs, 'ne ... pas' goes around the first verb (in its short
  form)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21468-5
  a curric:KeyLearningPoint ;
  rdfs:label """To express future plans we use 'aller' + infinitive, in this case 'ne...pas' would
  surround the form of 'aller' used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21521-1
  a curric:KeyLearningPoint ;
  rdfs:label "[a] sounds like ‘animal’ and [e] sounds like ‘je’."@en ;
  dcterms:modified "2026-06-07T15:30:29.323917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21521-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are both oral vowels, unlike the nasal vowels [em/am] and [en/an]."@en ;
  dcterms:modified "2026-06-07T15:30:29.323921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21521-3
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more adjectives after the noun are separated by ‘et’. Adjectives before the
  noun don't need ‘et’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21521-4
  a curric:KeyLearningPoint ;
  rdfs:label """In some French sentences, adjectives sandwich the noun e.g. une belle maison
  blanche."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21455-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound [è/ê] is pronounced as in the word tête."@en ;
  dcterms:modified "2026-06-07T15:30:29.336878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21455-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je viens', 'tu viens' and 'il, elle vient' are singular forms of the -ir verb
  'venir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21455-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je sors', 'tu sors' and 'il, elle sort' are singular forms of the -ir verb
  'sortir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21455-4
  a curric:KeyLearningPoint ;
  rdfs:label """For a 'yes/no' or closed inversion question in French, swap the subject and the verb
  (e.g. Sors-tu ce soir ?)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.336892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21455-5
  a curric:KeyLearningPoint ;
  rdfs:label """A two-verb inversion question follows this word order: pronoun + verb + infinitive
  (e.g. Aimes-tu sortir ?)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.336896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21486-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [aim] and [im] sound identical in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.350068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21486-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Préférer' is a regular -er verb but the 2nd -é in the stem changes to an -è in all
  forms apart from 'nous' and 'vous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21486-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French we add 'le' before a number to make it into a date. 'Of' in English is not
  translated, e.g. 'le deux mai'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21486-4
  a curric:KeyLearningPoint ;
  rdfs:label """We only use an ordinal number to express the first of the month in French, e.g. 'le
  premier janvier.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.350081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21467-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [qu] has the same sound in French as the hard 'c', like the [qu] in 'quand'
  which means 'when'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21467-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of the verb 'partir' (to leave) have the same endings as the verb
  'sortir' (to go out); -s,-s,-t,-t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21467-3
  a curric:KeyLearningPoint ;
  rdfs:label """These endings are silent final consonants, so the singular verb forms all sound the
  same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21467-4
  a curric:KeyLearningPoint ;
  rdfs:label """To express our future intentions, we use the 'je' form of the verb 'aller' followed
  by a verb in its infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21467-5
  a curric:KeyLearningPoint ;
  rdfs:label """To express other people's future intentions, we use the 'tu' or 'il, elle' forms of
  'aller' followed by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21447-1
  a curric:KeyLearningPoint ;
  rdfs:label "[é/er/ez] is pronounced as in 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.364551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives follow different patterns. 'Naturel' is 'naturelle' in the feminine
  form and 'heureux' is 'heureuse'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21447-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many cognates in French which can be used to infer meaning of surrounding
  words and understand context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21447-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates may look very similar to English but sound quite different so attention
  must be paid to pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21425-1
  a curric:KeyLearningPoint ;
  rdfs:label "[tion] sounds like 'attention'."@en ;
  dcterms:modified "2026-06-07T15:30:29.366946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21425-2
  a curric:KeyLearningPoint ;
  rdfs:label """There is only one present tense in French which conveys the simple and continuous
  present tenses in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21425-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition à means 'to' as well as 'at' and follows the verbs 'donner',
  'parler' and 'demander'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21425-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is not always a translation ncessary for 'à' in English but it should never be
  omitted in French ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21457-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC (sound-symbol correspondence) [ai] is pronounced as in 'vrai'."@en ;
  dcterms:modified "2026-06-07T15:30:29.368083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21457-2
  a curric:KeyLearningPoint ;
  rdfs:label """The question word 'quel' (meaning which) matches the gender of the noun: 'quel' (m)
  and 'quelle' (f)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21457-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form a yes/no question in French, we can use inversion; swap the verb and the
  pronoun: comprends-tu ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21457-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form an information question in French, we can use inversion with a question
  word: combien comprends-tu ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21422-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ç/c] is pronounced as in 'ici'."@en ;
  dcterms:modified "2026-06-07T15:30:29.369565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21422-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use context to work out the meanings of words with more than one meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.369568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21422-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘En’ means ‘in’ and ‘by'."@en ;
  dcterms:modified "2026-06-07T15:30:29.369572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21422-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Faire’ means 'to do/make' but has a number of additional meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.369576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21440-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘T’ at the end of a word is usually silent but liaison means that we can pronounce
  it when followed by a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21440-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'he, she does' in the present tense, use '(il, elle) fait' (the 3rd person
  singular)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21440-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'they do' in the present tense, use '(ils, elles) font' (the 3rd person
  plural)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23108-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondences help us with spelling and pronunciation of new and
  familiar vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23108-2
  a curric:KeyLearningPoint ;
  rdfs:label "All nouns have a grammatical gender in French, masculine or feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.373468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23108-3
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite article is 'un' for masculine singular nouns, 'une' for feminine
  singular nouns and 'des' for plurals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23108-4
  a curric:KeyLearningPoint ;
  rdfs:label "The French definite articles are 'le, 'la', 'l''and 'les'."@en ;
  dcterms:modified "2026-06-07T15:30:29.373476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23108-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'il y a' + indefinite article/number say what there is and 'il n' y a pas' +
  de/d' to say what there isn't."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21490-1
  a curric:KeyLearningPoint ;
  rdfs:label "[um/un] sounds like 'un'."@en ;
  dcterms:modified "2026-06-07T15:30:29.376949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21490-2
  a curric:KeyLearningPoint ;
  rdfs:label """-er verbs take the following endings in the present tense: je-e, tu-es,
  il/elle/on-e, nous-ons, vous-ez, ils/elles-ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21490-3
  a curric:KeyLearningPoint ;
  rdfs:label """'à' + definite article combine to make au/à la/à l’/aux, depending on the gender,
  number and spelling of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21490-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs need a preposition in English, but not in French' e.g. 'chercher,' ('to
  look for'). Others need prepositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21490-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs can be identified from their position and ending; look for the infinitive form
  in the dictionary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21505-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French [o] sound can be open or closed. It is open when followed by any
  consonant sound other than a 'z'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21505-2
  a curric:KeyLearningPoint ;
  rdfs:label """The [o] is closed when it is the final sound in a word, when it is followed by a 'z'
  sound or when it has a circumflex."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21505-3
  a curric:KeyLearningPoint ;
  rdfs:label """Studying the vocabulary and grammar in a model text helps us to prepare for a
  similar writing task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21505-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a content and language checklists helps us to plan, improve and check our
  drafted written work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21464-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter 'c' is naturally soft (sounds like s) before 'e' or 'i'. It is hard
  (sounds like k) before 'a', 'o' or 'u'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21464-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'c' is sometimes softened before 'a', 'o' or 'u' with a cedilla: 'ç'."@en ;
  dcterms:modified "2026-06-07T15:30:29.399377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most adjectives add an 'e' in the feminine form. Some adjectives are irregular in
  the feminine: eg. beau (m), belle (f)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21464-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most adjectives come after the noun in French: 'un livre intéressant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.399386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21464-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives go before the noun. These adjectives refer to beauty, age, good/bad
  and size (BAGS): 'un vieux vélo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21463-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter 'c' is naturally soft (sounds like 's') before 'e' or 'i'. It is hard
  (sounds like k) before 'a', 'o' or 'u'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21463-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'c' is sometimes softened before 'a', 'o' or 'u' with a cedilla: 'ç'."@en ;
  dcterms:modified "2026-06-07T15:30:29.399398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21463-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many adjectives add an 'e' in the feminine form. Some adjectives are irregular in
  the feminine e.g. beau (m), belle (f)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21463-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most adjectives come after the noun in French: 'un livre intéressant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.399408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21463-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives go before the noun. These adjectives refer to beauty, age, good/bad
  and size (BAGS): 'un vieux vélo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21432-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular of the verb is the 'je' form, the verb ends in -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.402359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21432-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person plural of the verb is the 'nous' form, the verb ends in -ons."@en ;
  dcterms:modified "2026-06-07T15:30:29.402363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21432-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular of the verb is the 'tu' form, the verb ends in -es."@en ;
  dcterms:modified "2026-06-07T15:30:29.402367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21432-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person plural of the verb is the 'vous' form, the verb ends in -ez."@en ;
  dcterms:modified "2026-06-07T15:30:29.402371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21432-5
  a curric:KeyLearningPoint ;
  rdfs:label """To turn a statement into a question, you raise your voice at the end. This is called
  intonation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21441-1
  a curric:KeyLearningPoint ;
  rdfs:label """French has different words for possessive adjectives because all nouns have
  grammatical gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21441-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say my/your, use 'mon/ton' for masculine singular nouns, 'ma/ta' for feminine
  singular and 'mes/tes' for plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21441-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pronounce the final letters of 'mon' and 'mes' when the next word starts with a
  vowel; we call this liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21456-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Je sors', 'tu sors' and 'il, elle sort' are singular forms of the -ir verb
  'sortir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21456-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Je viens', 'tu viens' and 'il, elle vient' are singular forms of the -ir verb
  'venir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21456-3
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition 'de' can mean both 'of' and 'from' in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.405394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21456-4
  a curric:KeyLearningPoint ;
  rdfs:label """When asking a closed inversion question using 'il/elle', pronounce the 't'
  (sort-elle ce soir ?)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21456-5
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb ends in a vowel, add a 't' before 'il/elle' (a-t-elle un chien ?)."@en ;
  dcterms:modified "2026-06-07T15:30:29.405402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21433-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [eu] sounds like the 'eu' in 'deux', two."@en ;
  dcterms:modified "2026-06-07T15:30:29.405924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21433-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.405929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21433-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before nouns to indicate how many there are; most numbers don’t
  change spelling for gender or number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21433-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Il y a' means there is, there are."@en ;
  dcterms:modified "2026-06-07T15:30:29.405937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21433-5
  a curric:KeyLearningPoint ;
  rdfs:label """When numbers ending in an -s or -x are followed by a vowel, the -s and -x are
  pronounced; this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21418-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'je fais' for I do/make, 'tu fais' for you do/make, 'il fait' for he does/makes,
  'elle fait' for she does/makes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21418-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use definite articles le, la, les, l' after the verb 'faire' to describe everyday
  activities e.g. 'il fait les courses'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21418-3
  a curric:KeyLearningPoint ;
  rdfs:label "'C'est qui ?' means 'Who is it?' and 'C'est quoi ?' means 'What is it?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.405961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21418-4
  a curric:KeyLearningPoint ;
  rdfs:label "[ê/è] sounds like 'tête', [é] sounds like 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.405966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21439-1
  a curric:KeyLearningPoint ;
  rdfs:label "[u] sounds like 'tu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.406594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21439-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'we do' in the present tense, use '(nous) faisons'."@en ;
  dcterms:modified "2026-06-07T15:30:29.406598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21439-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'you do' (plural) in the present tense, use '(vous) faites'."@en ;
  dcterms:modified "2026-06-07T15:30:29.406602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21578-1
  a curric:KeyLearningPoint ;
  rdfs:label """Senegal is a French-speaking country in West Africa. An independent nation since
  1960, Senegal was a French colony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21578-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about an action that happened in the past, we can use 'le passé composé'
  (the perfect tense), e.g. 'j'ai mangé'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21578-3
  a curric:KeyLearningPoint ;
  rdfs:label """When using the perfect tense, the adverb generally goes after the verb 'avoir' and
  before the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21578-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form an inversion question in the perfect tense, swap the subject and the verb
  ('avoir'), e.g. 'As-tu commencé ?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21578-5
  a curric:KeyLearningPoint ;
  rdfs:label "In negative sentences, 'ne … pas' and 'ne … jamais' go around the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.408418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21434-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb phrase 'il y a' means 'there is/are' and can be used with numbers and
  singular or plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21434-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Un' is the masculine form of the indefinite article 'a/an'. 'Une' is the feminine
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21434-3
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article ‘des’ is the French word for the determiner ‘some’."@en ;
  dcterms:modified "2026-06-07T15:30:29.409599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21434-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading a longer passage can help practise newly acquired vocabulary and
  grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21437-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [(e)au] is pronounced as in 'gauche'."@en ;
  dcterms:modified "2026-06-07T15:30:29.413344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21437-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nous avons' and 'vous avez' are the 1st and 2nd persons plural of the verb 'avoir',
  to have, having."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21437-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Nous avons' and 'vous avez' have a liaison; the -s in 'nous' and 'vous' is
  pronounced as it is followed by a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21437-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Un' and 'une' are the indefinite article 'a/an.' 'Un' is used with masculine nouns,
  'une' is used with feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21437-5
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article ‘des’ is ‘some’; it is used with plural nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.413360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21491-1
  a curric:KeyLearningPoint ;
  rdfs:label """Change statements into questions in French with raised intonation; a question word
  at the end gets more information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21491-2
  a curric:KeyLearningPoint ;
  rdfs:label """More formal inversion yes/no questions swap subject and verb; question words go at
  the start of information questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21491-3
  a curric:KeyLearningPoint ;
  rdfs:label """For negation meaning 'not', put ne … pas around the first verb in a sentence; ne
  shortens to n' before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21491-4
  a curric:KeyLearningPoint ;
  rdfs:label """To develop productive skills, keep a bank of vocabulary with words from texts,
  glossaries or the dictionary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21563-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plural verb endings for -er verbs are -ons, -ez (pronounced like the infinitive)
  and -ent (silent letters)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21563-2
  a curric:KeyLearningPoint ;
  rdfs:label """The French name for the English Channel is 'la Manche' because of its sleeve-like
  shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21563-3
  a curric:KeyLearningPoint ;
  rdfs:label """'On' and ‘nous’ both mean ‘we’; 'on' in informal conversation and 'nous' in more
  formal situations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21563-4
  a curric:KeyLearningPoint ;
  rdfs:label """'On' can mean 'everyone' (or 'people'), 'you' or 'one'; ‘nous’ is only used for 'we'
  with the sense of 'you and I'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21563-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask information questions with 'est-ce que', keep the same word order and still
  use intonation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21606-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter 'h' is often silent in French: heure."@en ;
  dcterms:modified "2026-06-07T15:30:29.420124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21606-2
  a curric:KeyLearningPoint ;
  rdfs:label """A word ending in a silent consonant followed by a word starting with a silent [h]
  has a liaison: c'est horrible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21606-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some words replace their final letter with an apostrophe before a silent [h]. This
  is called elision: j'habite."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21606-4
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object is a noun that receives the action of the verb. It answers either
  what? Or whom?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21606-5
  a curric:KeyLearningPoint ;
  rdfs:label """The direct object what or whom can also be a pronoun; 'me' and 'te' are the direct
  object pronouns 'me' and 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21623-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'un an' to indicate a specific unit of time/quantity and 'une année' for
  description/duration. Both mean 'a year'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21623-2
  a curric:KeyLearningPoint ;
  rdfs:label """Apply the pattern of adding -(n)eé to 'jour', 'matin' and 'soir' to describe
  different periods of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21623-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the reflexive pronoun 'se' when somebody is doing the action of the verb to
  himself or herself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21623-4
  a curric:KeyLearningPoint ;
  rdfs:label """If someone does the action to someone else, use the direct object pronouns 'le' and
  'la' for the receiver of the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21565-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'est-ce que' to the start of a question sentence, on its own or after a question
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21565-2
  a curric:KeyLearningPoint ;
  rdfs:label """The modal verbs 'devoir', 'vouloir', pouvoir' and 'savoir' give information about
  another verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are usually followed by a second verb, which is always in the infinitive
  form"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21565-4
  a curric:KeyLearningPoint ;
  rdfs:label "Add '-ment' to the feminine form of most adjectives to make them into an adverb."@en ;
  dcterms:modified "2026-06-07T15:30:29.422416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21565-5
  a curric:KeyLearningPoint ;
  rdfs:label """When/where adverbs normally come at the start/end of a sentence and how (often)
  adverbs after the first verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21423-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ai] sounds like 'vrai'"@en ;
  dcterms:modified "2026-06-07T15:30:29.422808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21423-2
  a curric:KeyLearningPoint ;
  rdfs:label "the infinitive of a verb in English can be translated as -to or ing"@en ;
  dcterms:modified "2026-06-07T15:30:29.422812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21423-3
  a curric:KeyLearningPoint ;
  rdfs:label """regular -er verbs endings in the present tense are -e for 'je', -es for 'tu' and -e
  for 'il/elle'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21421-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ch] sounds like 'chercher'."@en ;
  dcterms:modified "2026-06-07T15:30:29.423181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21421-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Faire' means 'to do/make'."@en ;
  dcterms:modified "2026-06-07T15:30:29.423185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21421-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use je fais for 'I do/make', tu fais for 'you do /make', il fait for 'he does/makes'
  and elle fait for 'she does/makes'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21421-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Faire' has other meanings like 'to go', e.g., 'faire les magasins' (to go
  shopping)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21624-1
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] is pronounced as in 'deux' and open [eu/œu] is pronounced as in 'cœur'."@en ;
  dcterms:modified "2026-06-07T15:30:29.423318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21624-2
  a curric:KeyLearningPoint ;
  rdfs:label "When [eu/œu] is followed by a pronounced consonant, it is an open sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.423322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21624-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to talk about things that used to happen regularly in
  the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21624-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form it, take the 'nous' form of the present tense, remove -ons, add -ais
  (1st/2nd persons) or -ait (3rd persons)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'être' in the imperfect tense with an adjective to mean 'was'. The stem for
  'être' in the imperfect tense is -ét."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21603-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the imperfect tense to talk about events and actions that used to happen
  regularly in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21603-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperfect tense, take the present tense 'nous' form without -ons, add
  -ais (je/tu) or ait (il/elle/on)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21603-3
  a curric:KeyLearningPoint ;
  rdfs:label """Four groups of -re verbs are: verbs like entendre, verbs like prendre, verbs like
  traduire and verbs like écrire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21603-4
  a curric:KeyLearningPoint ;
  rdfs:label """Three groups of -ir verbs are: verbs like choisir, verbs like partir and verbs like
  venir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21603-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense to talk about specific/one-off events + actions that
  happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21454-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Je prends', 'tu prends', 'il, elle prend' are the singular forms of the -re verb
  'prendre', to take, taking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21454-2
  a curric:KeyLearningPoint ;
  rdfs:label """The same verb endings can be applied to the -re verbs 'apprendre', to learn, and
  'comprendre', to understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21454-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Je dis', 'tu dis' and 'il, elle dit' are the singular forms of the -re verb 'dire',
  to say, saying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21454-4
  a curric:KeyLearningPoint ;
  rdfs:label """Like intonation questions, an inversion question is another way to ask a question in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21454-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form French yes/no or closed inversion questions, swap the subject pronoun and
  verb, inserting a hyphen in-between."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21460-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions like 'dans', 'sur' and 'sous' tell us where objects are."@en ;
  dcterms:modified "2026-06-07T15:30:29.424950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21460-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say what doesn't happen, use 'ne ... pas' around the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.424954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21460-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Ne' shortens to 'n’' before a verb starting with a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.424958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21460-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can pronounce the ‘s’ in ‘pas’ when it is followed by a word starting with a
  vowel; this is liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21472-1
  a curric:KeyLearningPoint ;
  rdfs:label "[tion] sounds like 'attention'"@en ;
  dcterms:modified "2026-06-07T15:30:29.425134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21472-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what you have to, or want to do, use modal verbs: 'devoir' and
  'vouloir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21472-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Devoir' changes to 'dois' in the 2nd person singular. 'Vouloir' changes to 'veux'
  in the 2nd person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21472-4
  a curric:KeyLearningPoint ;
  rdfs:label "If modal verbs are followed by another verb it must be in the infinitive form."@en ;
  dcterms:modified "2026-06-07T15:30:29.425146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ai] is pronounced as in 'vrai'. This makes the same sound as the SSC [è, ê]
  as in 'tête'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21458-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form an information question, use intonation: 'Tu vas quand en vacances ?' The
  question word goes after the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21458-3
  a curric:KeyLearningPoint ;
  rdfs:label """Or use inversion: 'Quand vas-tu en vacances ?' Swap the verb and the subject and
  place the question word at the start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21458-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Quoi' and 'que' both mean 'what'. Use 'quoi' with intonation questions and 'que'
  with inversion questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21458-5
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to and reading a longer passage can help consolidate vocabulary and
  grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21511-1
  a curric:KeyLearningPoint ;
  rdfs:label """The word for 'some' changes depending on the gender/number/spelling of the noun it
  describes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21511-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the partitive article for parts of food and drink and sports activities with
  faire e.g. je fais du sport."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21511-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Which' (quel/quelle/quels/quelles) in French changes for the gender/number of the
  noun it is describing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21503-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [au/eau] is in the word 'gauche' which means 'left'."@en ;
  dcterms:modified "2026-06-07T15:30:29.426697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21503-2
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [au/eau] is identical to the closed [o/ô] even though they are spelled
  differently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21503-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make a sentence mean the opposite, we use negation. One way to do this is to use
  'ne … pas' around the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21503-4
  a curric:KeyLearningPoint ;
  rdfs:label """With two-verb structures like the perfect tense, the 'ne ... pas' surrounds the
  first verb, the form of 'avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21503-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is no one-word equivalent for 'didn't' in French. It is expressed by using 'ne
  ... pas' and the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs that tell us when and where are usually positioned at the start or end of
  the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21585-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs that tell us how (often) are usually positioned straight after the first
  verb in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21585-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense can be translated into the simple past/present perfect in English
  depending on the context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21585-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Jamais' means never. In perfect tense sentences, ne …jamais surrounds the first
  verb (avoir), just like ne ...pas does."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21538-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter 'c' is naturally soft (sounds like 's') before 'e' or 'i'. It is hard
  (sounds like k) before 'a', 'o' or 'u'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21538-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'c' is sometimes softened before 'a', 'o' or 'u' with a cedilla: 'ç'."@en ;
  dcterms:modified "2026-06-07T15:30:29.427799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21538-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'partir' and 'quitter' both mean ‘to leave’ in English: 'je quitte la
  maison', 'je pars dans deux heures'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21538-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'quitter' followed by a direct object and 'partir' followed by a preposition or
  an adverb of time (or on its own)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21538-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense to talk about an action that happened in the past: avoir +
  past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21427-1
  a curric:KeyLearningPoint ;
  rdfs:label """The final consonant of a word is often silent in French, called the silent final
  consonant (SFC)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21427-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -e at the end of words is also silent, called the silent final e (SFe)."@en ;
  dcterms:modified "2026-06-07T15:30:29.431849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21427-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'I' + -er verb in French, the verb ending is -e; we call this the 1st person
  singular of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21427-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'we' + -er verb, the verb ending is -ons; we call this the 1st person
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21427-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'manger' (to eat, eating) behaves differently in the 'nous' form; it keeps
  the 'e' before the -ons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25502-1
  a curric:KeyLearningPoint ;
  rdfs:label "[y] is pronounced as the ‘y’ in ‘il y a’ and [oy] is pronounced as in 'envoyer'."@en ;
  dcterms:modified "2026-06-07T15:30:29.431868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25502-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'écrire' add -v to the stem in plural forms; the endings are the same as
  regular -er verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25502-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ask questions in French by using intonation, using the questioning device 'est-ce
  que' and using inversion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21526-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [om] and [on] are nasal sounds. Before a consonant they have the same nasal
  sound, like in ‘bombe’ and 'monde'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21526-2
  a curric:KeyLearningPoint ;
  rdfs:label """Before a vowel the 'm' and 'n' are pronounced, like in 'omelette' and 'monotone'.
  They are different oral sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21526-3
  a curric:KeyLearningPoint ;
  rdfs:label """In French, the ending of an adjective matches the noun it describes. This is called
  adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21526-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are various ways to make an adjective feminine, including adding an -e and
  changing -eur to -euse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21526-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some short masculine adjectives ending in -n, -l or -s double the last letter before
  adding -e, e.g. gentil, gentille."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21431-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence [i] sounds like the 'i' in 'midi."@en ;
  dcterms:modified "2026-06-07T15:30:29.587305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21431-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two ways of saying 'you' in French: for one person you use 'tu' for more
  than one person you use 'vous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21431-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say you (singular) + regular -er verbs, the verb ends in -es. For you (plural)
  the verb ends in -ez."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21431-4
  a curric:KeyLearningPoint ;
  rdfs:label "We call these two forms of the verb the 2nd persons singular and plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.587322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21438-1
  a curric:KeyLearningPoint ;
  rdfs:label """A cognate is a word that looks and sounds the same, or similar, in English and
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21438-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ils ont' and 'elles ont' are the 3rd person plural of the verb 'avoir', 'to have,
  having'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21438-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ils ont' and 'elles ont' have a liasion; the -s in 'ils' and 'elles' is pronounced
  as 'z' as it is followed by a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21438-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 's' in 'ils ont' and 'elles ont' ('z') is pronounced differently to the 's' in
  'ils sont' and 'elles sont' ('s')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21438-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reading a longer passage can help practise and consolidate previously learnt and
  newly acquired vocabulary and grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21424-1
  a curric:KeyLearningPoint ;
  rdfs:label "[oi] sounds like 'voir'"@en ;
  dcterms:modified "2026-06-07T15:30:29.590049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21424-2
  a curric:KeyLearningPoint ;
  rdfs:label "the infinitive of a verb in English can be translated as -to or ing"@en ;
  dcterms:modified "2026-06-07T15:30:29.590053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21424-3
  a curric:KeyLearningPoint ;
  rdfs:label """regular -er verbs endings in the present tense are -e for 'je', -es for 'tu' and -e
  for 'il/elle'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.590057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21424-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a sentence has two verbs, the second verb needs to be in the long
  form/infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21531-1
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is pronounced as in 'rue', in the back of your throat to make a raspy sound,
  which is different to English 'r'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21531-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make the third person plural of verbs like 'prendre', add the ending -ent to the
  stem 'prenn' - 'ils/elles prennent'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21531-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Prend' is pronounced as in 'enfant', a nasal vowel, whereas 'prennent' is an oral
  vowel because of the double 'n'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21461-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ch] sounds like 'chercher'."@en ;
  dcterms:modified "2026-06-07T15:30:29.591063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21461-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions such as 'derrière', 'devant' and 'entre' are useful for telling us
  where objects are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21461-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you don't have use 'ne ... pas' around 'avoir'. After this all articles
  change to 'de' or 'd''."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21461-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'there isn't' or 'there aren't' we use 'il n'y a pas'. After this all
  articles change to 'de' or 'd''."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21611-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use interrogative adjectives quel (m.sing), quelle (f.sing), quels (mpl), + quelles
  (fpl) to ask ‘which’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21611-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use demonstrative adjectives ce, cet, cette, ces to mean ‘this/that/those’. They
  often answer the question ‘which’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21611-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs in French are followed by 'de' and an infinitive; others by 'a' and an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21611-4
  a curric:KeyLearningPoint ;
  rdfs:label "Opinion, modal verbs and 'aller' are followed directly by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.592243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21611-5
  a curric:KeyLearningPoint ;
  rdfs:label """Two-verb structures that don’t translate word-for-word into English require
  additional practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21627-1
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of ‘voir’ in the present tense are ‘vois’ (‘je’, ‘tu’) and ‘voit’
  (‘il’, ‘elle’)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21627-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'voir' is used in many expressions in French like 'voir grand', 'rien à
  voir avec' and 'voir la vie en rose'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21627-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the imperfect tense to express the past continuous 'was -ing'."@en ;
  dcterms:modified "2026-06-07T15:30:29.592311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect + imperfect tenses together with a conjunction to describe what
  happened when you were doing something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23110-1
  a curric:KeyLearningPoint ;
  rdfs:label """[oi] is pronounced as in 'voir'. [oin] is pronounced as in 'besoin'. [oin] is nasal
  only when followed by a consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23110-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite adjectives go before the noun they describe. Tout le agrees in
  number/gender. Chaque/plusieurs don't change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23110-3
  a curric:KeyLearningPoint ;
  rdfs:label """Même/autre agree in number. Quelques is an indefinite ajective meaning some. It
  agrees in number, so is usually plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21579-1
  a curric:KeyLearningPoint ;
  rdfs:label """Senegal is a postcolonial West African nation. French as an official language
  coexists with many national languages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21579-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Devoir', 'pouvoir', 'vouloir' and 'savoir' are modal verbs and they are followed by
  infinitives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21579-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'devoir' to say what someone must or has to do. Another way to show necessity
  is to use 'il faut'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21579-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -if change to -ive in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.592400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21579-5
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives show who things belong to. They change to agree with the
  gender and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21582-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most French adjectives come after the noun they describe."@en ;
  dcterms:modified "2026-06-07T15:30:29.592408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21582-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use BRAGS (beauty, rank, age, goodness, size) to remember pre-nominal
  adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21582-3
  a curric:KeyLearningPoint ;
  rdfs:label """With more than one adjective, add 'et' after the noun. Nouns can also be surrounded
  by adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21582-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make comparisons in French, use the structures 'plus/aussi/moins' + 'que' with
  adjectives and adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21582-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some comparative forms are irregular, such as 'meilleur', 'mieux', and 'pire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.592428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21429-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound symbol correspondence [a] is very common in French and sounds like the 'a'
  in 'animal'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21429-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'he/she' + -er verb in French, the verb ending is -e, which is an SFe and so
  is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21429-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'they' + -er verb, the ending is -ent which is also silent. We call this the
  third person plural verb form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21429-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Ils' means 'they' when referring to a group of boys or a mixed gender group."@en ;
  dcterms:modified "2026-06-07T15:30:29.596076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21429-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Elles' mean 'they' when referring to a group of girls. The final 's' of 'ils/elles'
  is a SFC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21609-1
  a curric:KeyLearningPoint ;
  rdfs:label """The English 'th' sound does not exist in French. In French the SSC (sound-symbol
  correspondence) [th] makes a 't' sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21609-2
  a curric:KeyLearningPoint ;
  rdfs:label """The French [ch] does not make the same sound as the English 'ch'. In French, the SSC
  [ch] makes a 'sh' sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21609-3
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object is a noun that receives the action of the verb. It answers either
  what? or whom?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.596095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21609-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the direct object pronoun 'it' to replace a masculine noun we use 'le'; to
  replace a feminine noun we use 'la'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct object pronouns go before the verb; 'le' and 'la' shorten to 'l’ ' before a
  verb starting with a vowel or 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21540-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [qu], [ch] and [th] are consonant clusters pronounced as in 'question',
  'chercher' and 'th'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of time (saying exactly when), and of place, normally come at the beginning
  of a sentence: hier, j'ai travaillé."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21540-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other adverbs, including adverbs of time saying generally when, come after the
  conjugated verb form: j'ai enfin mangé."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21540-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense can be translated into both the simple past and the present
  perfect in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21540-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences with adverbs of a specific time use the simple past in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.596188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21532-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice of sound-symbol correspondences is important to ensure good
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21532-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of an adjective matches the noun it describes in gender and number. This
  is called adjective agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21532-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are various ways to make an adjective plural, including adding an -s, an -x or
  changing -al to -aux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21532-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives usually come after the noun, except those that refer to beauty, rank,
  age, goodness or size (B-R-A-G-S)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21532-5
  a curric:KeyLearningPoint ;
  rdfs:label """In French, -re verbs can be divided into groups according to their conjugation
  patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25484-1
  a curric:KeyLearningPoint ;
  rdfs:label "[i] sounds like 'midi'."@en ;
  dcterms:modified "2026-06-07T15:30:29.603839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25484-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ill/ille] sounds like 'fille'."@en ;
  dcterms:modified "2026-06-07T15:30:29.603844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25484-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Boire' (to drink) is irregular but has the same singular present tense endings as
  verbs like 'sortir' and 'venir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25484-4
  a curric:KeyLearningPoint ;
  rdfs:label """Uncountable nouns cannot be counted, only measured; they always need the partitive
  article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25484-5
  a curric:KeyLearningPoint ;
  rdfs:label """In negative sentences, change the partitive article to 'de' or 'd'' before nouns
  starting with a vowel/h."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21443-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound symbol correspondence [ou] sounds like the 'ou' in 'nous', meaning 'we in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21443-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'aller' means to go, going. 'Je vais' is 'I go, I am going', 'il,elle va'
  is 'he, she goes, is going'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21443-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 's' in 'vais' is usually a SFC, but when it is followed by a vowel, it is
  pronounced like the English 'z'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21443-4
  a curric:KeyLearningPoint ;
  rdfs:label """To express 'to (the)...' we use 'au' or 'à la' depending on whether the noun which
  follows is masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21435-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [e] is pronounced as in the word 'je'."@en ;
  dcterms:modified "2026-06-07T15:30:29.610049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21435-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nous sommes' and 'vous êtes' are the 1st and 2nd persons plural of the verb 'être',
  'to be, being'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21435-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often add -e in the feminine form, this is regular adjective gender
  agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21435-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives often add -s as the regular marker in the plural form."@en ;
  dcterms:modified "2026-06-07T15:30:29.610062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21446-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary should be practised little and often if you want to remember it."@en ;
  dcterms:modified "2026-06-07T15:30:29.611217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21446-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Aux' means 'to the' for masculine and feminine plural nouns, 'au' means the same
  for singular masculine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21446-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Aux' sounds like 'au' unless it is followed by a vowel or an 'h', when the 'x'
  would be pronounced like 'z' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21446-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can ask intonation questions with question words like 'où ?'. In French, they go
  after the verb in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21446-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing in French, it is useful to use reference resources to personalise or
  add a touch of flair to our work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21462-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say you don’t have something, use ‘ne … pas’ around the verb ‘avoir’ and change
  indefinite articles to 'de'/d''."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21462-2
  a curric:KeyLearningPoint ;
  rdfs:label "Other verbs such as ‘faire’ work in the same way as 'avoir'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21462-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Être’ is an exception, use the indefinite article after ‘être’ to give more
  information about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21462-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say you don’t have ‘the’ noun, the definite article stays the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.614568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21622-1
  a curric:KeyLearningPoint ;
  rdfs:label """[closed o/o] is pronounced as in 'photo', [au] is pronounced as in 'gauche' and
  [open o] is pronounced as in 'porte'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21622-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the direct object pronouns 'le' and 'la' to mean 'him'/'her' and 'it'. Shorten
  to l' before a vowel/silent 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21622-3
  a curric:KeyLearningPoint ;
  rdfs:label """The reflexive pronoun meaning 'himself'/'herself' is 'se', placed before the verb
  and shortened to s' before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21622-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs use reflexive pronouns in French, but we don’t always translate the
  reflexive pronoun in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21580-1
  a curric:KeyLearningPoint ;
  rdfs:label "[en/an] is pronounced as in 'enfant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21580-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ain/in] is pronounced as in 'train'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21580-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 17-69 are made up of a combination of numbers. Add 'et' before 'un' and a
  hyphen between other numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21580-4
  a curric:KeyLearningPoint ;
  rdfs:label """To ask what time it is in French, say 'Quelle heure est-il ?' To say at what time
  something happens, we use 'à'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.614734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21580-5
  a curric:KeyLearningPoint ;
  rdfs:label """To tell the time, use impersonal verb 'il est' + number + heure(s) + minutes. The
  24-hour clock is used more in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25497-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ill/ille] is pronounced as in 'fille'."@en ;
  dcterms:modified "2026-06-07T15:30:29.615087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25497-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ien] is pronounced as in 'bien'."@en ;
  dcterms:modified "2026-06-07T15:30:29.615091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25497-3
  a curric:KeyLearningPoint ;
  rdfs:label """The noun ‘informations’ is usually plural in French. In the singular form it means
  'a piece of information'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25497-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Tout’ means ‘all’ or ‘the whole’. It agrees with the object it describes. ‘Tous’ is
  the masculine plural form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25497-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like ‘lire’ follow the same pattern as ‘dire’ in the present tense singular.
  The endings are ‘s’, ‘s’ and ‘t’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21430-1
  a curric:KeyLearningPoint ;
  rdfs:label """For 'she, he' + verb in French, the verb ends in -e, 'nous' + verb the ending is
  -ons and for 'ils, elles' it's -ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21430-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 'she, he' form of the verb is called the 3rd person singular, the 'they' form is
  the 3rd person plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21430-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a name or a noun in the place of a pronoun before the verb e.g. 'le
  garçon' or 'David' instead of 'il'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21430-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is difficult to distinguish between the 'il, elle' and the 'ils, elles' verb
  forms because they sound the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21430-5
  a curric:KeyLearningPoint ;
  rdfs:label """If a singular/plural noun is used before the 3rd person singular/plural, the article
  helps us to identify the verb form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21566-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ou] is pronounced as in 'nous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.617120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21566-2
  a curric:KeyLearningPoint ;
  rdfs:label "[u] is pronounced as in 'tu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.617124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21566-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the 1st and 2nd persons plural of modal verbs, remove -oir from the
  infinitive + add the endings 'ons' and 'ez'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21566-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are usually followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.617133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21566-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use inversion questions in formal situations such as job interviews."@en ;
  dcterms:modified "2026-06-07T15:30:29.617137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21617-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many French nouns end in -ation and -ion and have a verb in the same family. Add
  ation/ion to the stem of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21617-2
  a curric:KeyLearningPoint ;
  rdfs:label "Around 33% of English words originate from French due to the Norman conquest."@en ;
  dcterms:modified "2026-06-07T15:30:29.618130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21617-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many -ir verbs in the present follow the pattern of sortir: remove -(t)ir and add:
  -s, -s, -t, -ons, -ez, -ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21617-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many -ir verbs in the present follow the pattern of choisir: remove -ir and add -is,
  -is, -it, -issons, -issez, -issent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21617-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some -ir verbs in the present follow the pattern of venir. The stem is vien(n) in
  all but the nous and vous forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21568-1
  a curric:KeyLearningPoint ;
  rdfs:label """'il faut' is a common impersonal verb, only used in the 3rd person singular, meaning
  'it is necessary to'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21568-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'ne ... pas' to 'il faut' to say what must not be done e.g. 'Il ne faut pas
  courir' (you must not run)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21568-3
  a curric:KeyLearningPoint ;
  rdfs:label "Change -if adjectives to -ive in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.619058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21568-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending -if/ive are often cognates but [i] is a longer vowel than English
  'i'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21473-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ien] sounds like 'bien'"@en ;
  dcterms:modified "2026-06-07T15:30:29.619638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21473-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'pouvoir' to talk about ability or permission; use 'savoir' to talk about skills
  or things you have learned to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21473-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Pouvoir' changes to 'peux' in the first and second persons singular and 'peut' in
  the 3rd person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21473-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Savoir' changes to 'sais' in the first and second persons singular and 'sait' in
  the 3rd person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21473-5
  a curric:KeyLearningPoint ;
  rdfs:label "If modal verbs are followed by another verb it must be in the infinitive form."@en ;
  dcterms:modified "2026-06-07T15:30:29.619655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21587-1
  a curric:KeyLearningPoint ;
  rdfs:label """[a] is pronounced as in 'animal'. The tu and il/elle forms of 'avoir'
  contain [a]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21587-2
  a curric:KeyLearningPoint ;
  rdfs:label """[è/ê] is pronounced as in 'tête'. The tu and il/elle forms of 'être' contain
  [è/ê]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vowels with circumflex accents often show removal of letters from French words of
  Latin origin. English retains the 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most verbs take ‘avoir’ in the perfect tense, but movement verbs and 'rester' take
  ‘être’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21567-1
  a curric:KeyLearningPoint ;
  rdfs:label """For third person plural forms of modal verbs 'vouloir', 'devoir', 'pouvoir' and
  'savoir', add -ent to the stem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21567-2
  a curric:KeyLearningPoint ;
  rdfs:label """The stems of 'devoir' and 'pouvoir' are their singular stems 'doi' and 'peu' plus
  'v'; 'doiv-' and 'peuv-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21567-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stem of 'vouloir' is singular stem 'veu' plus 'l'; 'veul-'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21567-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stem of 'savoir' is 'sav', the same as its other plural 'nous' and
  'vous' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21567-5
  a curric:KeyLearningPoint ;
  rdfs:label """To make a sentence with two or more verbs negative, add 'ne … pas' around the first
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21479-1
  a curric:KeyLearningPoint ;
  rdfs:label """Omit indefinite articles with être + profession but include articles when describing
  jobs in general or with adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21479-2
  a curric:KeyLearningPoint ;
  rdfs:label """être means 'to be, being', nous sommes means 'we are', vous êtes means 'you are' and
  ils/elles sont means 'they are'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21479-3
  a curric:KeyLearningPoint ;
  rdfs:label """avoir means 'to have, having', nous avons means 'we have', vous avez means 'you
  have' and ils/elles ont is 'they have'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21479-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pronounce the 's' at the end of 'ils' when it is followed by a vowel; it sounds like
  a 'z'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21451-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [on] sounds like the 'on' in 'non', meaning 'no' in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.620920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21451-2
  a curric:KeyLearningPoint ;
  rdfs:label """To express going 'to' a place in French, we use 'à' for a town/city, 'en' for
  feminine countries and 'chez' for homes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21451-3
  a curric:KeyLearningPoint ;
  rdfs:label """These prepositions can also mean 'in' or 'at' when used with the verbs 'arriver', to
  arrive, and 'habiter' to live."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21451-4
  a curric:KeyLearningPoint ;
  rdfs:label """Preposition 'de' means ‘of’ and also replaces the English ‘s for possession, e.g.
  Lea’s cousin is ‘le cousin de Léa’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21451-5
  a curric:KeyLearningPoint ;
  rdfs:label """When completing an extended listening task, taking notes and/or using a support grid
  can help understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23109-1
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives change for gender and number."@en ;
  dcterms:modified "2026-06-07T15:30:29.620943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23109-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'mon/ton' before masculine singular nouns, 'ma/ta' before feminine singular
  nouns and 'mes/tes' before plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23109-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Il' and 'elle' mean 'it' when replacing a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.620951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23109-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Ils' and 'elles' mean 'they' for people and objects."@en ;
  dcterms:modified "2026-06-07T15:30:29.620955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25482-1
  a curric:KeyLearningPoint ;
  rdfs:label "[gn] sounds like 'ligne'."@en ;
  dcterms:modified "2026-06-07T15:30:29.622101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25482-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use the perfect tense to say what you did in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.622105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25482-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say what I did, use 'j'ai' and a past participle."@en ;
  dcterms:modified "2026-06-07T15:30:29.622109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25482-4
  a curric:KeyLearningPoint ;
  rdfs:label "The past participles of 'dire' and 'faire' are 'dit' and 'fait'."@en ;
  dcterms:modified "2026-06-07T15:30:29.622113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25482-5
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles 'dit' and 'fait' sound identical to the present tense verb
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21515-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [oy] sounds like a ‘yih’ sound after SSC [oi]. This is similar to the [i] vs
  [-ill-/ille] pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21515-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use the pronoun 'on' when talking about people in general. We translate it as
  'people', 'you' or 'one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21515-3
  a curric:KeyLearningPoint ;
  rdfs:label "'On' uses the 3rd person singular ('il', 'elle') verb endings."@en ;
  dcterms:modified "2026-06-07T15:30:29.622727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21515-4
  a curric:KeyLearningPoint ;
  rdfs:label """'On' can mean 'we' in an informal conversation, such as talking to friends. The verb
  endings are the same ('il'/'elle')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21515-5
  a curric:KeyLearningPoint ;
  rdfs:label "We have to use the context to work out if 'on' means 'people' or 'we'."@en ;
  dcterms:modified "2026-06-07T15:30:29.622735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21593-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to revisit vocabulary as it boosts our long-term retention
  of words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21593-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative pronoun 'qui' introduces a relative clause to give more information
  about a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21593-3
  a curric:KeyLearningPoint ;
  rdfs:label """Translate 'qui' as who/that for describing people and which/that when describing
  animals/things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21593-4
  a curric:KeyLearningPoint ;
  rdfs:label """The endings for verbs like 'écrire' are 's', 's' and 't', 'vons', 'vez' and
  'vent'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21593-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are followed by 'à' before a noun and the form changes depending on the
  gender/number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21533-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practise of sound-symbol correspondences is important to ensure good
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21533-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make comparisons in French use 'plus ... que' (more than), 'moins ... que' (less
  than) and 'aussi ... que' (as, as)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21533-3
  a curric:KeyLearningPoint ;
  rdfs:label """French comparative structures sandwich adjectives to compare two nouns, and adverbs
  to compare how people do things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21533-4
  a curric:KeyLearningPoint ;
  rdfs:label """More than one adjective before a noun needs no comma or 'et'; multiple adjectives
  after the noun need 'et' in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21533-5
  a curric:KeyLearningPoint ;
  rdfs:label """In French, -ir verbs can be divided into groups according to their conjugation
  patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21572-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [qu] is pronounced as in 'question."@en ;
  dcterms:modified "2026-06-07T15:30:29.625662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21572-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -que in French are often cognates with words ending in -c in
  English: hisorique - historic"""@en ;
  dcterms:modified "2026-06-07T15:30:29.625666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21572-3
  a curric:KeyLearningPoint ;
  rdfs:label "The infinitive is the long form of the verb. It always ends in: -er, -ir or -re."@en ;
  dcterms:modified "2026-06-07T15:30:29.625691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21572-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say who is or what is doing the action, we change the infinitive to a short form
  of the verb: regarder - je regarde"""@en ;
  dcterms:modified "2026-06-07T15:30:29.625702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21572-5
  a curric:KeyLearningPoint ;
  rdfs:label """An infinitive can be used as the subject of a sentence to express an activity (like
  a noun): conduire, c'est difficile"""@en ;
  dcterms:modified "2026-06-07T15:30:29.625826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21530-1
  a curric:KeyLearningPoint ;
  rdfs:label "[r] is pronounced as in 'rue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.625861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21530-2
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is pronounced in the back of the throat to make the raspy sound which is
  different to English 'r'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21530-3
  a curric:KeyLearningPoint ;
  rdfs:label """For the 1st and 2nd persons plural of 'prendre', remove -re, then 'd' from the stem,
  and add the endings 'ons' and 'ez'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21530-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verbs 'apprendre' and 'comprendre' follow the same pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.625912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21597-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ordinal numbers are used to describe the order in which things happen e.g. the
  fourth year, the sixth lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21597-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make French ordinal numbers, add the suffix 'ième'. Remove the -e from numbers
  ending -e first and add 'u' to 'cinq'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21597-3
  a curric:KeyLearningPoint ;
  rdfs:label """'First' (premier/première) is an exception but 'twenty-first' follows the normal
  pattern 'le vingt-et-unième'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21597-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperfect tense for 'il/elle/on', take the present tense 'nous' form,
  remove 'ons' and add -ait."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21613-1
  a curric:KeyLearningPoint ;
  rdfs:label """French nouns and masculine adjectives ending -al change to end in -aux in the plural
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21613-2
  a curric:KeyLearningPoint ;
  rdfs:label "French adjectives with -al endings have nouns as their root."@en ;
  dcterms:modified "2026-06-07T15:30:29.626021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21613-3
  a curric:KeyLearningPoint ;
  rdfs:label """'il est' can be used with an adjective and an infinitive to talk about how things
  are for people in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21613-4
  a curric:KeyLearningPoint ;
  rdfs:label """In impersonal phrases, ‘il’ never means ‘he’. It often means ‘it’, but does not
  refer to a specific person or thing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21527-1
  a curric:KeyLearningPoint ;
  rdfs:label """Normally the SSCs [om] and [on] are identical nasal sounds. However they sound
  different when placed before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21527-2
  a curric:KeyLearningPoint ;
  rdfs:label """Before a vowel the ‘om’ and ‘on’ are pronounced as oral sounds, so they sound
  different from one another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21527-3
  a curric:KeyLearningPoint ;
  rdfs:label """To compare people and things in French, we say one is more/less + adjective than
  another. We use 'que' for 'than'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21527-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'plus ... que' for 'more than', 'moins ... que' for 'less than' and 'aussi
  ... que' for 'as... as'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21527-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Bon' (good) and 'mauvais' (bad) have special comparative forms: 'meilleur' (better)
  and 'pire' (worse)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21459-1
  a curric:KeyLearningPoint ;
  rdfs:label "[oi] sounds like 'voir'"@en ;
  dcterms:modified "2026-06-07T15:30:29.627393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21459-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'dormir' means 'to sleep'. Singular forms 'dors' and 'dort' sound the same
  due to silent final consonants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21459-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say what doesn't happen, we use 'ne ... pas' around the verb; this is one form of
  negation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25496-1
  a curric:KeyLearningPoint ;
  rdfs:label "Open [eu/œu] is pronounced as in 'cœur'."@en ;
  dcterms:modified "2026-06-07T15:30:29.629010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25496-2
  a curric:KeyLearningPoint ;
  rdfs:label "Closed [eu] is pronounced as in 'deux'."@en ;
  dcterms:modified "2026-06-07T15:30:29.629014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25496-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the definite article with language nouns except after 'parler'."@en ;
  dcterms:modified "2026-06-07T15:30:29.629018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25496-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives describing nationalities agree with nouns. Nationalities of people ('un
  Espagnol') have a capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.629022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25496-5
  a curric:KeyLearningPoint ;
  rdfs:label """Swap the subject-verb order to ask an inversion question; use liaison between the
  verb and subject if a vowel follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.629026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25495-1
  a curric:KeyLearningPoint ;
  rdfs:label "Open [eu/œu] is pronounced as in 'cœur'."@en ;
  dcterms:modified "2026-06-07T15:30:29.629973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25495-2
  a curric:KeyLearningPoint ;
  rdfs:label "Closed [eu] is pronounced as in 'deux'."@en ;
  dcterms:modified "2026-06-07T15:30:29.629977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25495-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Répondre' is followed by the preposition 'à' in French, 'dépendre' is always
  followed by 'de'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.629981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25495-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Entendre’ is an -re verb. Verbs like ‘entendre’ follow the same pattern as verbs
  like ‘prendre’ in the singular forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.629985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21626-1
  a curric:KeyLearningPoint ;
  rdfs:label "[r] is pronounced as in 'rue'. It is different to English 'r'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21626-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense for one-off past actions and the imperfect for things that
  used to happen regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the imperfect tense to express the past continuous 'was -ing'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21626-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect + imperfect tenses together with a conjunction to describe what
  happened when you were doing something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'est-ce que' in the imperfect tense with its usual structure to ask about 2
  things happening at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21469-1
  a curric:KeyLearningPoint ;
  rdfs:label """The French 'g' has 2 sounds: soft before e, i and y and hard before other
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21469-2
  a curric:KeyLearningPoint ;
  rdfs:label """With a definite article, 'l'allemand' is a noun, without an article it is an
  adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21469-3
  a curric:KeyLearningPoint ;
  rdfs:label """With capital letter, 'Allemand' is a noun meaning a person from Germany, as with
  'anglais' and other languages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21469-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present tense of 'aller' followed by an infinitive to express future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21469-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'nous allons' and 'vous allez' + infinitive to express what we and you
  (plural) are going to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21573-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ique in French are often cognates with words ending in -ical in
  English: historique - historical."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21573-2
  a curric:KeyLearningPoint ;
  rdfs:label """An infinitive can be used as the subject of a sentence to express an activity (like
  a noun): conduire, c'est difficile."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21573-3
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitives are also frequently used after modal verbs or 'aimer' and 'aller': il
  doit conduire dans la neige."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21573-4
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive is translated in the -ing form in English when used as a noun and as
  'to …' when after a modal verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the infinitive after 'pour' to say why someone is doing something and after
  'sans' to say 'without doing something'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21520-1
  a curric:KeyLearningPoint ;
  rdfs:label """[em/am] is pronounced like 'temps' and [en/an] sounds like 'enfant' before a
  consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21520-2
  a curric:KeyLearningPoint ;
  rdfs:label """[em/am] and [en/an] are the same nasal sound before a consonant and different oral
  sounds before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21520-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prenominal adjectives come before the noun they describe. These are Beauty, Rank,
  Age, Goodness and Size adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21520-4
  a curric:KeyLearningPoint ;
  rdfs:label "The acronym BRAGS reminds us which adjectives are prenominal."@en ;
  dcterms:modified "2026-06-07T15:30:29.631163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21520-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Plusieurs', 'autre' and 'même' are examples of 'Rank' adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.631167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25494-1
  a curric:KeyLearningPoint ;
  rdfs:label """If a word ends with an SFC, the consonant is pronounced before a word beginning with
  [h], this is called liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25494-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words like 'le', 'je', 'ne' and 'que' replace their final letter with an apostrophe
  before a word beginning with [h]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25494-3
  a curric:KeyLearningPoint ;
  rdfs:label "This is called elision, which we have seen before, e.g. 'j'ai' and 'c'est'."@en ;
  dcterms:modified "2026-06-07T15:30:29.633191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25494-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 'nous' form of verbs like 'choisir' ends in -issons, the 'vous' form ends in
  -issez."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25494-5
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ils, elles' form of verbs like 'choisir' ends in -issent."@en ;
  dcterms:modified "2026-06-07T15:30:29.633200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21618-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ain/in] is pronounced as in 'train' and [aim/im] is pronounced as in 'faim'."@en ;
  dcterms:modified "2026-06-07T15:30:29.634518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21618-2
  a curric:KeyLearningPoint ;
  rdfs:label """The nasal sounds [aim/im] and [ain/in] become non-nasal sounds when they come before
  a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21618-3
  a curric:KeyLearningPoint ;
  rdfs:label """During WW2, after Paris was captured by Germany, France was divided into different
  zones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21618-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense to talk about past specific/one-off events/actions. Use part
  of 'avoir/être' + a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21618-5
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of verbs like 'sortir' and 'choisir' both end in -i. To form,
  remove -r from the infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21481-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a word ending in a normally silent consonant is followed by a mute 'h', the
  consonant is heard due to liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21481-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding and responding to a text is a good way to deepen vocabulary knowledge
  of previously taught words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21481-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make a regular adjective feminine, add an -e. If the masculine form already ends
  in –e, it does not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21481-4
  a curric:KeyLearningPoint ;
  rdfs:label "Change adjectives ending -x to -se in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.635687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21481-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives are irregular, you need to learn both forms e.g 'beau' and
  'belle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21607-1
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object is a noun that receives the action of the verb. It answers either
  'what?' or 'whom?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21607-2
  a curric:KeyLearningPoint ;
  rdfs:label """The direct object noun for 'what' or 'whom' can be replaced by a direct object
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21607-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Me' and 'te' are the direct object pronouns for 'me' and 'you'."@en ;
  dcterms:modified "2026-06-07T15:30:29.635744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before a vowel, direct object pronouns have a elision. 'Me' and 'te' become m’ and
  t’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21543-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'prendre' (to take, taking) has an irregular past participle: pris - j'ai
  pris une photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21543-2
  a curric:KeyLearningPoint ;
  rdfs:label """Other verbs like 'prendre' (comprendre, apprendre) have the same past participle
  ending: il a compris la tâche."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21543-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about 'having' a meal, food or drink in French, use the verb 'prendre', not
  'avoir': tu as pris un café hier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21543-4
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb 'déjà' means 'already': j'ai déjà mangé. In a question, it can also mean
  'yet': tu as déjà mangé ?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.635801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21543-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverb 'encore' means 'again': j'ai encore joué. In a negative sentence, it means
  'not yet': je n'ai pas encore joué."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21619-1
  a curric:KeyLearningPoint ;
  rdfs:label """The nasal SSCs [em/am] (pronounced as in 'temps') and [en/an] (pronounced as in
  'enfant') are non-nasal before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21619-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'sortir' look and sound very different in the present and perfect
  tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21619-3
  a curric:KeyLearningPoint ;
  rdfs:label """Orally, only the presence or absence of an auxiliary verb shows whether verbs like
  'choisir' are past or present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21619-4
  a curric:KeyLearningPoint ;
  rdfs:label """Jean Bascle was a member of the French Resistance who was arrested and sent to a
  concentration camp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21475-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consonants such as -s, -t, -x and -d at the end of a word are usually silent in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21475-2
  a curric:KeyLearningPoint ;
  rdfs:label "To talk about what you can/are able to do, use a form of the verb 'pouvoir'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21475-3
  a curric:KeyLearningPoint ;
  rdfs:label "If modal verbs are followed by another verb, it must be in the infinitive form."@en ;
  dcterms:modified "2026-06-07T15:30:29.636666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21475-4
  a curric:KeyLearningPoint ;
  rdfs:label """When developing a personal response, it's helpful to use reference materials to look
  up new vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21564-1
  a curric:KeyLearningPoint ;
  rdfs:label "[en/an] is pronouced as in 'enfant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21564-2
  a curric:KeyLearningPoint ;
  rdfs:label "[on] is pronounced as in 'non'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21564-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'aller' is irregular, its present tense forms are 'vais, 'vas', 'va',
  'allons', 'allez' and 'vont'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21564-4
  a curric:KeyLearningPoint ;
  rdfs:label """To express our future intentions, we use a form of the verb 'aller' followed by a
  verb in its infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21564-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you're not going to do, put 'ne' before the part of 'aller' and pas'
  after."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21428-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spelling words accurately in French is tricky and needs regular practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.637703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21428-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'she/he' + verb in French, the verb often ends in -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.637710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21428-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'we' + verb in French, the verb usually ends in  -ons."@en ;
  dcterms:modified "2026-06-07T15:30:29.637714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21428-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Préféré(e)' means favourite in French and has an extra -e added at the end when
  describing a feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21428-5
  a curric:KeyLearningPoint ;
  rdfs:label """When listening in French, taking brief notes of key words in English and/or using a
  support grid can help understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21601-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending -al in English often end in -al or more commonly -el in French.
  The feminine form is -elle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense for specific one-off past events and the imperfect for
  regularly repeated past events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the present tense of avoir/être and a past participle to form the
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21601-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the present tense of the 'nous' form, remove -ons and add -ais/ait for the
  singular imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21601-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb shows if the action used to happen all the time or was a single, completed
  event; time phrases give detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21542-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [j/soft g] is pronounced as in 'jambe'. The letter 'g' can be soft or hard
  in French: 'la gare', 'la gymnase'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21542-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [gn] is pronounced as in 'ligne'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21542-3
  a curric:KeyLearningPoint ;
  rdfs:label """The expression 'avoir mal' means to be 'in pain' or 'hurt'. 'J'ai eu mal' is the
  perfect tense: 'I have had, had pain'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21542-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Eu' is an irregular past participle. Other irregular past participles are 'fait'
  (faire), 'bu' (boire), 'dit' (dire)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21542-5
  a curric:KeyLearningPoint ;
  rdfs:label """Perfect tense questions can be translated in two different ways: 'Tu as bu ?' - 'Did
  you drink?', 'Have you drunk?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21414-1
  a curric:KeyLearningPoint ;
  rdfs:label "é/-er/-ez sounds like écrire"@en ;
  dcterms:modified "2026-06-07T15:30:29.637770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21414-2
  a curric:KeyLearningPoint ;
  rdfs:label "'il' and 'elle' mean 'it' when replacing a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.637774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21414-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use conjunctions and adverbs with adjectives to describe people to write more
  detailed sentences"""@en ;
  dcterms:modified "2026-06-07T15:30:29.637778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21516-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [y] sounds different to the English [y] and is pronounced as in ‘physique’
  and 'style'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21516-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'choisir' ('to choose, choosing') form another type of -IR verb. These
  include 'réussir' and 'définir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21516-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'I' with a verb like 'choisir', remove the -IR from the infinitive and add
  -is, e.g. 'je choisis'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21516-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'she, he', remove the -IR and add -it, e.g. 'il, elle choisit'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21516-5
  a curric:KeyLearningPoint ;
  rdfs:label """These two verb forms sound the same because the -s and -t are silent final
  consonants (SFCs)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21512-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [eil/eill] sounds like [è] + 'yih' and [ouil/ouill] like [ou] + 'yih'."@en ;
  dcterms:modified "2026-06-07T15:30:29.638283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21512-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'sortir' can mean either 'to go out' or 'to take out' depending on the
  context of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21512-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say without something use 'sans' before a noun. To say without doing something
  use 'sans' before an infinitive verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21512-4
  a curric:KeyLearningPoint ;
  rdfs:label """-IR verbs like 'sortir' and 'venir' end in -ons in the 'nous' form and 'ez' in the
  'vous' form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21512-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pattern is the same for the verbs 'dormir', 'partir', 'devenir' and
  'revenir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21420-1
  a curric:KeyLearningPoint ;
  rdfs:label "j/soft g sounds like jour"@en ;
  dcterms:modified "2026-06-07T15:30:29.638594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21420-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the definite article (le/la/l'/les) for specific nouns and the indefinite
  article un/une for non specific nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21420-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use similes with 'comme' to compare two things."@en ;
  dcterms:modified "2026-06-07T15:30:29.638602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21620-1
  a curric:KeyLearningPoint ;
  rdfs:label "[gn] is pronounced as in 'ligne'. [j/soft g] is pronounced as in 'jour'."@en ;
  dcterms:modified "2026-06-07T15:30:29.638606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21620-2
  a curric:KeyLearningPoint ;
  rdfs:label """'g' is hard before 'a', 'o', 'u', 'r', 'l' and 'm'. 'g' is soft before 'e', 'i' and
  'y'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21620-3
  a curric:KeyLearningPoint ;
  rdfs:label """When ‘me’ or ‘you’ is the direct object of a verb, we use the direct object pronouns
  'me' and 'te' before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21620-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes, the ‘doer’ (subject) and the ‘receiver’ (object) is the same
  (myself/yourself). These are reflexive pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21620-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'me and 'te' as reflexive pronouns in French. Shorten them to m', t' before a
  vowel or silent 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638625Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-21604
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the pronouns 'il, elle' and 'ils, elles' to mean 'it' and 'they' in French
  in the context of reading."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063055Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21453
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the singular forms of -re verb ‘dire’ and verbs like 'prendre' in the
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063329Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21450
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the plural forms of 'aller' with the prespositions 'à', 'en' and 'chez' to
  say and understand where we and others go."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063878Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21471
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the modal verbs 'devoir' and 'vouloir' in the 1st and 3rd persons in the
  context of summer activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063882Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21584
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the present and perfect tenses, including negation and questions to talk
  about significant events in French history."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063917Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21608
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and say how much something costs in French using the verb 'payer',
  numbers 70-99 and the direct object pronoun 'it' in the context of shopping."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064001Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21598
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe things now compared to how they used to be in childhood."@en ;
  dcterms:modified "2026-06-07T15:30:41.064009Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21478
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask 'est-ce que' questions about people using the verbs 'avoir' and
  'être'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064135Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21539
  a curric:PupilLessonOutcome ;
  rdfs:label "I can plan questions for a school report using inversion and the perfect tense"@en ;
  dcterms:modified "2026-06-07T15:30:41.064184Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21509
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what I play using the prepositions 'à' and 'de'."@en ;
  dcterms:modified "2026-06-07T15:30:41.064612Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21480
  a curric:PupilLessonOutcome ;
  rdfs:label "I can make person nouns feminine to talk about different jobs."@en ;
  dcterms:modified "2026-06-07T15:30:41.064616Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21575
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read and understand sentences about secularism in France."@en ;
  dcterms:modified "2026-06-07T15:30:41.064676Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25510
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like 'entendre' and 'venir' in the present and perfect tenses in the
  context of French colonisation, including in information questions."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064959Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21581
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use 'avoir' and 'être' to describe my daily routine."@en ;
  dcterms:modified "2026-06-07T15:30:41.064963Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21499
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the perfect tense to form intonation questions with 'ce, cet, cette and
  ces'"""@en ;
  dcterms:modified "2026-06-07T15:30:41.065090Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25501
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like 'lire' in all forms of the present tense to talk about a school
  trip."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065093Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21470
  a curric:PupilLessonOutcome ;
  rdfs:label "I can ask about future plans using inversion questions with question words."@en ;
  dcterms:modified "2026-06-07T15:30:41.065253Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21594
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use emphatic pronouns when describing a crime that has happened."@en ;
  dcterms:modified "2026-06-07T15:30:41.065287Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21488
  a curric:PupilLessonOutcome ;
