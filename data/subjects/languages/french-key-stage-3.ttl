  ‘ils/elles’ meaning ‘they’."""@en ;
  dcterms:modified "2026-06-07T15:29:23.076805Z"^^xsd:dateTime .

oakcurric:priorknowledge-2863-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use all persons of verbs like 'prendre' and ‘lire’, and ‘faire’, in the
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.076860Z"^^xsd:dateTime .

oakcurric:priorknowledge-2863-3
  a curric:PriorKnowledgeRequirement ;
