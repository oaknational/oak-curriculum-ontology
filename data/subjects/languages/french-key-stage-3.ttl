  dcterms:modified "2026-06-07T15:30:41.120371Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21420
  a curric:PupilLessonOutcome ;
  rdfs:label "I can write a French poem using 'comme' similes."@en ;
  dcterms:modified "2026-06-07T15:30:41.120451Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21620
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use direct object and reflexive pronouns to talk about life as a refugee."@en ;
