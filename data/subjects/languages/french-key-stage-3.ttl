oakcurric:unit-2850
  a curric:Unit ;
  rdfs:label "The environment: -RE verbs in the present, adjectives"@en ;
  curric:slug "the-environment-re-verbs-in-the-present-adjectives" ;
  rdfs:comment """This unit consolidates previous learning of -re and -ir verbs with a wide range of
  known vocabulary. Pupils also reviste comparative adjectives and adverbs, and adjective
  positioning."""@en ;
  curric:whyThisWhyNow """In this unit, pupils embed known vocabulary and grammar as they revisit
  -re and -ir verbs in the present tense. Pupils apply previous knowledge on adjective
  agreement and placement and comparatives together with their considerable verb lexicon to the
  new context of the environment and discussion of eco-friendly options.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2850-1 ,
    oakcurric:priorknowledge-2850-2 ,
    oakcurric:priorknowledge-2850-3 ,
    oakcurric:priorknowledge-2850-4 ,
    oakcurric:priorknowledge-2850-5 ,
    oakcurric:priorknowledge-2850-6 ;
  curric:id "2850"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.864086Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-languages-key-stage-3 ;
  curric:includesThread
    oakcurric:thread-the-present ,
    oakcurric:thread-adjectives ,
    oakcurric:thread-word-order .

