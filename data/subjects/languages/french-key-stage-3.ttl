  dcterms:modified "2026-06-07T15:30:41.117975Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21530
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs like 'prendre' in the 1st and 2nd persons plural to talk about
  learning a language."""@en ;
  dcterms:modified "2026-06-07T15:30:41.117980Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21597
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the first and third persons of the imperfect tense to talk about how I've
  changed in the context of school."""@en ;
  dcterms:modified "2026-06-07T15:30:41.117984Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21613
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use impersonal phrases to talk about life during the global pandemic."@en ;
  dcterms:modified "2026-06-07T15:30:41.117989Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21527
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compare people or things using three different comparative adjectives with
