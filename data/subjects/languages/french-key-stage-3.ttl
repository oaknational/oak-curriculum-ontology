  dcterms:modified "2026-06-07T15:30:41.119360Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21481
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use adjectives, person nouns and the verbs avoir and être to talk
  about jobs."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119715Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21607
  a curric:PupilLessonOutcome ;
  rdfs:label """I can read and write letters, using direct object pronouns, about school and
  university life in 'la Francophonie'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119729Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21543
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the verb 'prendre' in the perfect tense to say what I had for
  breakfast."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119734Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21619
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and use verbs like 'sortir' and 'choisir' in the context of French
  history."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119960Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21475
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my knowledge of French vocabulary and structures to understand simple
  French poetry and use my own repertoire and reference materials to adapt it."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119965Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21564
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'aller' with infinitives to say what I'm going to and not going to do in
  the future."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120099Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21428
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions about favourite things and use singular and 'nous'
  form present -er verbs to say what I do with others."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120235Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21601
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the imperfect and perfect tenses to talk about one-off events and events
  that happened regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120240Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21542
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say what hurts in the present and what hurt in the past (present perfect)
  using irregular past participles."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120244Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-21414
  a curric:PupilLessonOutcome ;
  rdfs:label """I can write about a friend using 'être' and 'avoir' and a range of adjectives,
