  curric:hasPupilLessonOutcome oakcurric:pupillessonoutcome-lesson-21516 ;
  curric:hasMisconception
    oakcurric:misconception-y-sound-same-french-english ;
  dcterms:modified "2026-06-07T15:29:48.681987Z"^^xsd:dateTime .

