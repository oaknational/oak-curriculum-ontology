  a curric:Keyword ;
  schema:name "é/-er/-ez"@en ;
  schema:description "pronounced as in écrire"@en ;
  dcterms:modified "2026-06-07T15:30:02.428362Z"^^xsd:dateTime .

oakcurric:keyword-eileill
  a curric:Keyword ;
  schema:name "[eil/eill]"@en ;
  schema:description """sound-symbol correspondence (SSC) like the 'eille' in 'bouteille', which
  means 'bottle'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428454Z"^^xsd:dateTime .

oakcurric:keyword-ouilouill
  a curric:Keyword ;
  schema:name "[ouil/ouill]"@en ;
  schema:description """sound-symbol correspondence (SSC) like the 'ouill' in 'brouillard', which
  means 'fog'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428460Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-il-elle-mean-refer-people
  a curric:Misconception ;
  curric:statement "'Il' and 'elle' mean he and she and can only refer to people."@en ;
  curric:correction """Every noun has a gender in French. Therefore 'il' and 'elle' can mean 'it',
  and 'ils' and 'elles' mean 'they' (people and things)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083777Z"^^xsd:dateTime .

oakcurric:misconception-verbs-dire-prendre-same-verb
  a curric:Misconception ;
  curric:statement "The verbs 'dire' and 'prendre' have the same verb endings."@en ;
  curric:correction """‘Dire’ and ‘prendre’ are high frequency -re verbs that have slightly
  different endings from each other, and from the most common -re pattern of endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084183Z"^^xsd:dateTime .

oakcurric:misconception-translate-french-use
  a curric:Misconception ;
  curric:statement "To translate 'to' into French we just use 'à'."@en ;
  curric:correction """There are several ways to express 'to' and 'at' in French and we need to
  carefully learn them to speak and write accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084866Z"^^xsd:dateTime .

oakcurric:misconception-need-conjugate-verb-following-modal
  a curric:Misconception ;
  curric:statement "You need to conjugate the verb following a modal verb."@en ;
  curric:correction "The second verb following a modal verb must be in the infinitive form."@en ;
  dcterms:modified "2026-06-07T15:30:15.084872Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-formed-same-way
  a curric:Misconception ;
  curric:statement "All past participles are formed in the same way."@en ;
  curric:correction """Regular -er verb past participles are formed by changing the -er at the end
  of the infinitive to é but there are other past participle patterns such as verbs like
  prendre changing to 'pris' and some irregular past participles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084921Z"^^xsd:dateTime .

oakcurric:misconception-numbers-70-80-90-one
  a curric:Misconception ;
  curric:statement """Numbers 70, 80 and 90 are one word numbers in French, just like 20 (vingt), 30
  (trente), 40 (quarante) etc."""@en ;
  curric:correction """In French, the numbers 70 (soixante-dix), 80 (quatre-vingts), and 90
  (quatre-vingt-dix) are not single-word numbers. Unlike 20 (vingt), 30 (trente), and 40
  (quarante)—which are single words—70, 80, and 90 are constructed using compound
  expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085056Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-formation-different-ir
  a curric:Misconception ;
  curric:statement "The imperfect tense formation is different for ir/re verbs."@en ;
  curric:correction """The imperfect tense is formed exactly the same way as with -er verbs. Take
  the present tense nous form, remove -ons and add the imperfect endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085070Z"^^xsd:dateTime .

oakcurric:misconception-indefinite-article-des-changes-based
  a curric:Misconception ;
  curric:statement """The indefinite article 'des' changes based on gender as do the indefinite
  articles 'un' and 'une'."""@en ;
  curric:correction """The indefinite article 'des' does not change based on gender. Un livre - des
  livres. Une orange - des oranges."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085234Z"^^xsd:dateTime .

oakcurric:misconception-need-use-intonation-using-inversion
  a curric:Misconception ;
  curric:statement "There is no need to use intonation when using inversion and 'est-ce que'."@en ;
  curric:correction """Even when we form questions with inversion or 'est-ce que', it is still
  important to use intonation to signal that it is a question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085261Z"^^xsd:dateTime .

oakcurric:misconception-forming-inversion-question-perfect-tense
  a curric:Misconception ;
  curric:statement """When forming an inversion question in the perfect tense, the past participle
  comes after 'avoir'."""@en ;
  curric:correction """When forming an inversion question in the perfect tense, only the verb avoir
  and the subject swap. The past participle remains at the end: as-tu commencé ?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.085455Z"^^xsd:dateTime .

oakcurric:misconception-des-means
  a curric:Misconception ;
  curric:statement "'Des' always means 'some'."@en ;
  curric:correction """'Des' is the word for 'some' but is also a form of the preposition 'de'
  before plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086080Z"^^xsd:dateTime .

oakcurric:misconception-add-e-person-nouns-make
  a curric:Misconception ;
  curric:statement "Add an -e to all person nouns to make them feminine."@en ;
  curric:correction """The most common way to make a person noun feminine is to add an -e to the
  masculine version. If nouns already end in -e, person nouns usually stay the same but the
  article changes. Jobs ending in 'eur' usually change to 'rice' in the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086087Z"^^xsd:dateTime .

oakcurric:misconception-like-non-person-object-nouns
  a curric:Misconception ;
  curric:statement """Like non-person or object nouns, identity nouns exist in only one form and
  gender."""@en ;
  curric:correction """Unlike non-person or object nouns, identity nouns can have both masculine and
  feminine forms: le chrétien - la chrétienne. This is the same as other French person nouns
  you may know, e.g. le directeur/la directrice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086176Z"^^xsd:dateTime .

oakcurric:misconception-verbs-entendre-venir-same-auxiliary
  a curric:Misconception ;
  curric:statement "The verbs 'entendre' and 'venir' have the same auxiliary verb."@en ;
  curric:correction """Although their past participles are formed in the same way (ending in u),
  ‘venir’ is always formed with the auxiliary verb 'être' and never with ‘avoir’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086555Z"^^xsd:dateTime .

oakcurric:misconception-avoir-means
  a curric:Misconception ;
  curric:statement "'Avoir' always means 'to have/having'."@en ;
  curric:correction """Most of the time, we translate 'avoir' as 'to have/having' but there are
  expressions, where we would use the verb to be in English, where French uses 'avoir',
  usually expressing feelings/states e.g 'avoir froid', to be cold."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086561Z"^^xsd:dateTime .

oakcurric:misconception-express-masculine-nouns-ce
  a curric:Misconception ;
  curric:statement "I can express 'this' for all masculine nouns with 'ce'."@en ;
  curric:correction """There is another way of expressing 'this' in French for masculine nouns,
  which is 'cet', this is for masculine nouns beginning with a vowel or an 'h'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086762Z"^^xsd:dateTime .

oakcurric:misconception-verbs-traduire-conduire-interdire-dire
  a curric:Misconception ;
  curric:statement """The verbs 'traduire', 'conduire', 'interdire' and 'dire' follow exactly the
  same pattern as 'lire' in the present tense."""@en ;
  curric:correction """The verbs 'traduire', 'conduire', 'interdire' and 'dire' follow exactly the
  same pattern as 'lire' in the present tense with one important exception. The 2nd person
  plural form of 'dire' is 'dites'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086767Z"^^xsd:dateTime .

oakcurric:misconception-create-inversion-questions-french-swap
  a curric:Misconception ;
  curric:statement """To create inversion questions in French, you just swap the verb and subject
  around."""@en ;
  curric:correction """As well as swapping verb and subject, a hyphen is needed betwen the verb and
  the subject pronoun when forming inversion questions, e.g. 'Vont-elles créer des vêtements
  ?' - 'Are they going to create clothes?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087076Z"^^xsd:dateTime .

oakcurric:misconception-use-subject-pronouns-prepositions-link
  a curric:Misconception ;
  curric:statement "Use subject pronouns after prepositions to link nouns/pronouns."@en ;
  curric:correction """Use the emphatic pronouns 'moi' and 'toi' instead of subject pronouns to link
  and emphasise nouns/pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087128Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjective-son-sa-ses
  a curric:Misconception ;
  curric:statement """The possessive adjective 'son, sa, ses' matches the person who owns the noun
  that follows. So 'his' is 'son, 'her' is 'sa' and 'their' is 'ses'."""@en ;
  curric:correction """In French, the possessive pronoun matches the noun that follows it, not the
  person to whom the object belongs. This is why sometimes you cannot tell whether the owner
  is male or female because the words for 'his' and 'her' are the same in French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087134Z"^^xsd:dateTime .

oakcurric:misconception-en-different-sounds
  a curric:Misconception ;
  curric:statement "[en] and [an] are different sounds."@en ;
  curric:correction "[en] and [an] sound exactly the same as in 'enfant'."@en ;
  dcterms:modified "2026-06-07T15:30:15.087195Z"^^xsd:dateTime .

oakcurric:misconception-once-know-vocabulary-move
  a curric:Misconception ;
  curric:statement "Once you 'know' some vocabulary, you should move on."@en ;
  curric:correction """Vocabulary and grammatical concepts need consistently revisiting in order to
  move it in to your long term memory. Work out what learning techniques work for you but
  the most important thing is repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087359Z"^^xsd:dateTime .

oakcurric:misconception-o-sound-french-pronounced-one
  a curric:Misconception ;
  curric:statement "The [o] sound in French is only pronounced one way."@en ;
  curric:correction """The [o] sound in French can be open, like the [o] in 'porte' and 'd'accord'
  or closed like the [o] in 'radio' or 'dos'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087365Z"^^xsd:dateTime .

oakcurric:misconception-combine-plural-noun-les-becomes
  a curric:Misconception ;
  curric:statement "When I combine 'à' with a plural noun with 'les', it becomes 'à les'."@en ;
  curric:correction """When using 'à' with a plural noun to express 'to (the)' in French, it becomes
  'aux'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087371Z"^^xsd:dateTime .

oakcurric:misconception-one-word-better-french-meilleur
  a curric:Misconception ;
  curric:statement "There is only one word for 'better' in French: 'meilleur'."@en ;
  curric:correction """The adjective 'meilleur(e)' means 'better' in French and describes a noun,
  e.g.'il a un meilleur ordinateur' ('he has a better computer'). To describe an action as
  'better' we use the adverb 'mieux', e.g. 'il chante mieux' ('he sings better')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087514Z"^^xsd:dateTime .

oakcurric:misconception-like-possessive-adjectives-mon-ton
  a curric:Misconception ;
  curric:statement """Like the possessive adjectives 'mon' and 'ton', the possessive adjective
  'leur' changes in the singular form based on the gender of the noun possessed."""@en ;
  curric:correction """Unlike the possessive adjectives 'mon' and 'ton', the possessive adjective
  'leur' does not change in the singular form based on the gender of the noun possessed, it
  remains the same: leur chien, leur souris."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087522Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-tre-dont-change
  a curric:Misconception ;
  curric:statement """Past participles with 'être' don't change, just like past participles with
  'avoir'."""@en ;
  curric:correction """Past participles with 'être' always agree in gender and number with the
  subject. Add 'e' to agree a feminine past participle and 's' to agree a plural past
  participle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087766Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-please-person
  a curric:Misconception ;
  curric:statement """There is only one way to say please to a person in French: 's'il vous
  plait'."""@en ;
  curric:correction """There are two ways to say please in French: 'sil vous plait' for someone you
  don't know very well or someone in a position of responsibility like your teacher. But for
  friends and family you use 's'il te plait'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087893Z"^^xsd:dateTime .

oakcurric:misconception-mettre-verb-like-entendre-follows
  a curric:Misconception ;
  curric:statement "'Mettre' is a verb like 'entendre' and it follows the same pattern."@en ;
  curric:correction """'Mettre' has the same present tense endings as verbs like 'entendre' but the
  stem is different in the singular forms. Drop one of the 't's from the infinitive, leaving
  the remaining 't' as a silent final consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088220Z"^^xsd:dateTime .

oakcurric:misconception-school-systems-roughly-same
  a curric:Misconception ;
  curric:statement "All school systems are roughly the same."@en ;
  curric:correction """School systems around the world can be quite different. For example in France
  you don't go to school on a Wednesday afternoon and you don't wear school uniform!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.088339Z"^^xsd:dateTime .

oakcurric:misconception-need-use-future-tense-french
  a curric:Misconception ;
  curric:statement "We need to use the future tense in French to describe future activities."@en ;
  curric:correction """The present tense can be used with time adverbs to describe a future
  activity. For example, 'Mardi je vais chez Léa.' means: 'This coming Tuesday I am going to
  Léa's house.'. This is a future activity but the present tense has been used here."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088475Z"^^xsd:dateTime .

oakcurric:misconception-connaitre-savoir-mean-know-used
  a curric:Misconception ;
  curric:statement """'Connaitre' and 'savoir' both mean 'know' so they can be used
  interchangeably."""@en ;
  curric:correction """'Connaitre' and 'savoir' both mean 'know', but 'connaitre' is used for being
  familiar with people/places/things, whereas 'savoir' usually means 'to know how to' or
  used on its own/with 'que'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088590Z"^^xsd:dateTime .

oakcurric:misconception-il-est-means
  a curric:Misconception ;
  curric:statement "'Il est' always means 'he is'."@en ;
  curric:correction """'Il est' can be used as an impersonal verb where 'il' means 'it' and is not
  referring to a specific thing but talking about 'it' in general. e.g. 'Il est difficile de
  croire' means 'It is difficult to believe'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088597Z"^^xsd:dateTime .

oakcurric:misconception-school-years-work-same-english
  a curric:Misconception ;
  curric:statement "School years work the same in English and French."@en ;
  curric:correction """French uses 'la' before ordinal numbers for school years, the lower the
  number, the higher the school year e.g. 'sixième' is equivalent to Y7 and 'cinquième' is
  Y8. Use 'en' to say you're in a school year e.g. 'en sixième'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088603Z"^^xsd:dateTime .

oakcurric:misconception-use-adjectives-comparative-structures-like
  a curric:Misconception ;
  curric:statement "I only use adjectives with comparative structures like 'plus ... que'."@en ;
  curric:correction """Adjectives help us to compare two nouns with comparative structures such as
  'plus ... que'. For example, 'Emily est plus petite que Lucy'. We can use adverbs in the
  same way to compare how people do things. For example, 'Emily va plus vite que Lucy'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088918Z"^^xsd:dateTime .

oakcurric:misconception-conjugate-mettre-remettre-exactly-like
  a curric:Misconception ;
  curric:statement "I can conjugate 'mettre' and 'remettre' exactly like 'entendre'."@en ;
  curric:correction """'Mettre' and 'remettre' do take the same verb endings as 'entendre'; however,
  they also drop a 't' in the singular present tense forms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089001Z"^^xsd:dateTime .

oakcurric:misconception-sound-symbol-correspondences-ai-er
  a curric:Misconception ;
  curric:statement """The sound-symbol correspondences [ai] and [é/er/ez] sound the same in
  French."""@en ;
  curric:correction """The letters 'ai/ay' are the same as the SSC [é/er/ez] in French but [ai] is
  pronounced as in 'vrai' with slightly more relaxed lips than 'ai/ay' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089009Z"^^xsd:dateTime .

oakcurric:misconception-verbs-followed-direct-object
  a curric:Misconception ;
  curric:statement "All verbs can be followed by a direct object."@en ;
  curric:correction """Not all verbs can be followed by a direct object; J'habite dans une maison;
  'une maison' is connected to the verb by the preposition 'dans'. The verb 'j'habite' (I
  live) stands alone and does not have a direct object; we cannot say: 'I live a house'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089017Z"^^xsd:dateTime .

oakcurric:misconception-closed-eu-open-eu-u
  a curric:Misconception ;
  curric:statement "The closed [eu] and the open [eu/œu] sounds are the same."@en ;
  curric:correction """There are open vowel sounds and closed vowel sounds in French. The closed
  [eu] sound is like the [eu] in 'peu', it is short and sharp. The open [eu/oœu] sound is a
  longer sound like the [œu] in 'sœur'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089248Z"^^xsd:dateTime .

oakcurric:misconception-ne-pas-goes-around-main
  a curric:Misconception ;
  curric:statement """Ne ... pas goes around the main verb (the past participle) in perfect tense
  sentences."""@en ;
  curric:correction """Just like in other double verb sentences, ne...pas goes around the first
  verb; in the perfect tense, that's the conjugated form of 'avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089463Z"^^xsd:dateTime .

oakcurric:misconception-il-y-means
  a curric:Misconception ;
  curric:statement "'Il y a' always means 'there is'."@en ;
  curric:correction """'Il y a' can mean 'there is' or 'there are' and can be used with singular or
  plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089545Z"^^xsd:dateTime .

oakcurric:misconception-3rd-persons-singular-plural-verbs
  a curric:Misconception ;
  curric:statement """The 3rd persons singular and plural with verbs like 'entendre' have different
  spellings but the same pronunciation."""@en ;
  curric:correction """The 'd' at the end of the 3rd person singular is a silent final consonant but
  the 'd' in the 3rd person plural is pronounced, whilst the -ent is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089587Z"^^xsd:dateTime .

oakcurric:misconception-s-sounds-same-french
  a curric:Misconception ;
  curric:statement "'S' always sounds the same in French."@en ;
  curric:correction """The 's' at the beginning of words and double 's' is a soft sound but 's'
  between two consonants is [s], pronounced as in 'maison'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089731Z"^^xsd:dateTime .

oakcurric:misconception-verb-faire-single-definition
  a curric:Misconception ;
  curric:statement "The verb 'faire' only has a single definition."@en ;
  curric:correction """The verb 'faire' is used to translate two key verbs in English, both 'to do'
  and 'to make'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089793Z"^^xsd:dateTime .

oakcurric:misconception-articles-missed-french-like-english
  a curric:Misconception ;
  curric:statement "Articles can be missed out in French like in English."@en ;
  curric:correction """Articles can't be omitted in French. Use the definite article with specific
  nouns/giving opinions and the partitive article with uncountable and non-specific nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089867Z"^^xsd:dateTime .

oakcurric:misconception-use-one-preposition-like-english
  a curric:Misconception ;
  curric:statement "Use one preposition for 'in' like in English."@en ;
  curric:correction """There are a number of prepositions for 'in', depending on the number and
  gender of the noun. Use 'en' for feminine countries, à for cities, au with masculine
  nouns, à la with feminine nouns and aux with plural nouns and countries."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089873Z"^^xsd:dateTime .

oakcurric:misconception-word-looks-same-french-english
  a curric:Misconception ;
  curric:statement """If a word looks the same in French and English, it will always be a
  cognate."""@en ;
  curric:correction """There are lots of cognates, where English and French words are the same or
  similar. However, there are some words, known as 'false friends'. These are words whose
  meanings are not what they look like e.g. 'attendre' meaning 'to wait' not 'to attend'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089878Z"^^xsd:dateTime .

oakcurric:misconception-one-way-saying-your-french
  a curric:Misconception ;
  curric:statement "There is one way of saying 'your' in French."@en ;
  curric:correction """'Your' in French changes, depending on who you are talking to and what you
  are talking about. Use 'ton' (m), 'ta' (f) or 'tes' (pl) when talking to someone you know
  well. Use 'votre' (m/f) or 'vos' (mpl/fpl) when talking to someone formally."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089934Z"^^xsd:dateTime .

oakcurric:misconception-add-s-make-adjectives-plural
  a curric:Misconception ;
  curric:statement "Add -s to make all adjectives plural."@en ;
  curric:correction """Regular adjectives usually need -s adding in the plural form, however there
  are other patterns and differences between the masculine and the feminine form with
  adjectives ending in -x and -al."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090088Z"^^xsd:dateTime .

oakcurric:misconception-verbs-like-ecrire-formed-same
  a curric:Misconception ;
  curric:statement "Verbs like 'ecrire' are formed the same way as verbs like 'lire'."@en ;
  curric:correction """Although verbs like 'écrire' do have the same endings in the singular persons
  ('je', 'tu' and 'il'/'elle'), they are different in the plural form, so it is better to
  think of them as different types of -re verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090204Z"^^xsd:dateTime .

oakcurric:misconception-il-y-il-y-avait
  a curric:Misconception ;
  curric:statement """'Il y a' and 'il y avait' mean there is and there was in descriptions of
  singular things."""@en ;
  curric:correction """'Il y a' and 'il y avait' mean there is or there are and there was and there
  were. They stay the same if you are talking about one thing or more than one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090431Z"^^xsd:dateTime .

oakcurric:misconception-like-nationality-adjectives-nationality-nouns
  a curric:Misconception ;
  curric:statement """Like nationality adjectives, nationality nouns use lowercase letters in
  French: il est anglais - c'est un anglais."""@en ;
  curric:correction """Unlike nationality adjectives, nationality nouns use capital letters in
  French: il est anglais - c'est un Anglais."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090505Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-made-one-part
  a curric:Misconception ;
  curric:statement "The perfect tense is made up of one part like it is in English."@en ;
  curric:correction """You must have both parts of the perfect tense; the present tense of 'avoir'
  and a past participle. Regular past participles end in é."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090637Z"^^xsd:dateTime .

oakcurric:misconception-forming-inversion-questions-perfect-tense
  a curric:Misconception ;
  curric:statement """When forming inversion questions in the perfect tense, you just have to swap
  the subject and the verb."""@en ;
  curric:correction """Swapping the position of the subject and the verb is an important step in
  forming inversion questions but remember to add a hyphen and -t- in the third person
  singular e.g. 'A-t-elle vendu sa maison ?'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.090643Z"^^xsd:dateTime .

oakcurric:misconception-two-verb-sentences-infinitive
  a curric:Misconception ;
  curric:statement "All two-verb sentences have à (to) before the infinitive."@en ;
  curric:correction """Modal verbs, verbs of like/dislike and 'aller' are followed directly by an
  infinitive to form two-verb structures but some verbs form two-verb structures with 'à' +
  infinitive; for example, 'aider', 'apprendre' and 'commencer'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090726Z"^^xsd:dateTime .

oakcurric:misconception-one-way-referring-french-english
  a curric:Misconception ;
  curric:statement "There is just one way of referring to 'they' in French, as in English."@en ;
  curric:correction """There is both a masculine and feminine form of the pronoun 'they'. Use 'ils'
  when referring to a group of boys or a group of boys and girls, and use 'elles' when
  referring to a group of girls."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091270Z"^^xsd:dateTime .

oakcurric:misconception-ai-sound-same-french
  a curric:Misconception ;
  curric:statement "[ai] and [é] sound the same in French."@en ;
  curric:correction """In some regional accents [ai] and [é] can sound similar. Officially there is
  a difference in pronunciation and meaning as the ending of the imperfect tense is supposed
  to be pronounced [ai], whereas a common ending of the past participle is [é]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091276Z"^^xsd:dateTime .

oakcurric:misconception-add-question-word-end-question
  a curric:Misconception ;
  curric:statement """When you add a question word at the end of a question, there is no need to
  change your intonation."""@en ;
  curric:correction """It is important to use your intonation by raising the pitch of your voice at
  the end of all questions in French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091281Z"^^xsd:dateTime .

oakcurric:misconception-letter-e-pronounced-same-french
  a curric:Misconception ;
  curric:statement "The letter 'e' is always pronounced the same in French."@en ;
  curric:correction """The letter 'e' is often pronounced as the 'e' in 'je' is but can be
  pronounced like [è/ê]. Pronounce 'e' like [è/ê] before double consonants and the letters
  c/l if they are in the last syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091292Z"^^xsd:dateTime .

oakcurric:misconception-change-your-main-verb-past
  a curric:Misconception ;
  curric:statement """Only change your main verb into a past verb in French like we can do in
  English to form the past tense, e.g. I do → I did."""@en ;
  curric:correction """In French you need two verbs in the perfect tense for it to make sense; the
  correct part of 'avoir' and the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091348Z"^^xsd:dateTime .

oakcurric:misconception-left-french-like-english
  a curric:Misconception ;
  curric:statement "'Some' can be left out in French just like it can in English."@en ;
  curric:correction """Always use an article before food nouns in French, if it is a whole item, use
  the indefinite article and if it's uncountable or part of an item, use the partitive
  article du, de la or de l'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091357Z"^^xsd:dateTime .

oakcurric:misconception-add-ne-jamais-around-verb
  a curric:Misconception ;
  curric:statement """Just add 'ne ... jamais' around the verb to say 'never'; the rest of the
  sentence stays the same."""@en ;
  curric:correction """Add 'ne ... jamais' around the conjugated verb, but in addition, change any
  indefinite/partitive articles to de/d' after a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091442Z"^^xsd:dateTime .

oakcurric:misconception-add-s-adjectives-plural-form
  a curric:Misconception ;
  curric:statement "Add -s to all adjectives in the plural form."@en ;
  curric:correction """Most adjectives do need an 's' in the plural form, but there are exceptions.
  Masculine adjectives ending -eux don't change at all and those ending -al change to -aux
  in the plural form. The feminine plural versions of these adjectives are regular."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091541Z"^^xsd:dateTime .

oakcurric:misconception-translating-french-english-vice-versa
  a curric:Misconception ;
  curric:statement """When translating from French to English or vice versa, you simply translate
  word-for-word."""@en ;
  curric:correction """Word order is often different in French and English. In many cases, we can't
  translate word-for-word and you may need to paraphrase."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091546Z"^^xsd:dateTime .

oakcurric:misconception-use-notre-mean-our-french
  a curric:Misconception ;
  curric:statement "I use 'notre' to mean 'our' in French just with masculine nouns."@en ;
  curric:correction """The possessive adjective 'notre' is used before masculine and feminine
  singular nouns to mean 'our' in French. We use 'nos' when the 'possessed' noun is plural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091577Z"^^xsd:dateTime .

oakcurric:misconception-learning-genders-important-learning-noun
  a curric:Misconception ;
  curric:statement "Learning genders is not as important as learning the noun itself."@en ;
  curric:correction """Leaning the genders of words is essential because it affects other parts of
  the sentence such as which form of 'à/de' to use before a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091586Z"^^xsd:dateTime .

oakcurric:misconception-use-verb-avoir-help-form
  a curric:Misconception ;
  curric:statement "Always use the verb 'avoir' to help you form the perfect tense."@en ;
  curric:correction """Remember - for movement verbs and 'rester' use 'être', instead of 'avoir', to
  help you form the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091593Z"^^xsd:dateTime .

oakcurric:misconception-3rd-person-plural-form-verb
  a curric:Misconception ;
  curric:statement """The 3rd person plural 'they' form of the verb 'sortir' is 'sorent' and of the
  verb 'venir' is 'vienent'."""@en ;
  curric:correction """The verb 'sortir' keeps its 't' to become 'sortent' and the verb 'venir'
  doubles its 'n' to become 'viennent'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091709Z"^^xsd:dateTime .

oakcurric:misconception-s-end-word-silent-because
  a curric:Misconception ;
  curric:statement """Every 's' at the end of a word is silent because of the silent final consonant
  rule."""@en ;
  curric:correction """Usually 's' is silent at the end of a word but if the next word starts with a
  vowel, you usually hear liaison, whereby the final consonant is pronounced. When the final
  consonat is 's', it sounds like the hard 's' in 'maison'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091742Z"^^xsd:dateTime .

oakcurric:misconception-words-tion-cognates-therefore-pronounced
  a curric:Misconception ;
  curric:statement """Words with [tion] are cognates, therefore pronounced the same in English and
  French."""@en ;
  curric:correction """Although [tion] words are usually cognates, the sound is different and useful
  to revisit regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091813Z"^^xsd:dateTime .

oakcurric:misconception-need-translate-word-form-question
  a curric:Misconception ;
  curric:statement "I need to translate the word 'did' when I form a question in French."@en ;
  curric:correction """To form a question in French, you can either raise your voice at the end of a
  statement to form an intonation question, or you can add 'est-ce que' at the beginning of
  a sentence. There is no French equivalent for 'did' in a question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092010Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-verbs-translated-literally-english
  a curric:Misconception ;
  curric:statement "Reflexive verbs can always be translated literally into English."@en ;
  curric:correction """There are sometimes more natural ways to translate reflexive verbs into
  English. For example, 'Je me prépare' is 'I prepare myself', but 'I get ready' sounds more
  natural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092042Z"^^xsd:dateTime .

oakcurric:misconception-pronounce-r-same-french-english
  a curric:Misconception ;
  curric:statement "I pronounce [r] the same in French as in English."@en ;
  curric:correction """The SSC [r] is very different in French. It is a raspy sound from the back of
  your throat like the [r] in 'rue'. It does require quite a lot of practice to master this
  sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092266Z"^^xsd:dateTime .

oakcurric:misconception-use-partitive-article-uncountable-nouns
  a curric:Misconception ;
  curric:statement "Use the partitive article with all uncountable nouns, even negatives."@en ;
  curric:correction """After quantities and negatives use 'de/d' instead of the partitive article.
  E.g Il y a beaucoup de riz. Il n'y a pas de riz."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092852Z"^^xsd:dateTime .

oakcurric:misconception-ou-means-french
  a curric:Misconception ;
  curric:statement "'Ou' means 'or' and 'where' in French."@en ;
  curric:correction "'Ou' without an accent means 'or' and 'où' with an accent means 'where'."@en ;
  dcterms:modified "2026-06-07T15:30:15.092865Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-french
  a curric:Misconception ;
  curric:statement "There is only one way to say 'a' in French."@en ;
  curric:correction """All nouns have a gender in French. We use 'un' for all masculine nouns and
  'une' for all feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092992Z"^^xsd:dateTime .

oakcurric:misconception-cest-translates
  a curric:Misconception ;
  curric:statement "'C'est' only translates to 'it is/that is'."@en ;
  curric:correction """When talking about objects, 'c'est' translates to 'it is/that is' but when
  applied to people it can also mean 'he/she is'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092997Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-come-noun-describe-french
  a curric:Misconception ;
  curric:statement "All adjectives come after the noun they describe in French."@en ;
  curric:correction """Most adjectives follow the noun they describe, but not adjectives of beauty,
  age, goodness and size, which come before like English adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093074Z"^^xsd:dateTime .

oakcurric:misconception-am-forming-information-questions-est
  a curric:Misconception ;
  curric:statement """When I am forming information questions with 'est-ce que' I put the question
  word after it."""@en ;
  curric:correction """When forming information questions with 'est-ce que', the question word must
  come before it, e.g example: 'Qu'est-ce que tu vas faire demain ?' 'What are you going to
  do tomorrow?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093137Z"^^xsd:dateTime .

oakcurric:misconception-sscs-ou-u-make-same
  a curric:Misconception ;
  curric:statement "The SSCs [ou] and [u] make the same sound in French."@en ;
  curric:correction """The SSCs [ou] and [u] are similar but make different sounds in French. [ou]
  is pronounced as in 'nous' and [u] is pronounced as in 'tu'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093587Z"^^xsd:dateTime .

oakcurric:misconception-word-order-adverbs-same-french
  a curric:Misconception ;
  curric:statement "Word order with adverbs is the same in French and English."@en ;
  curric:correction """Word order with adverbs is sometimes the same and sometimes different in
  French and English. Think about whether the adverb is a how/how often or a where/when
  adverb to know where to place it in French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094160Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-french-one-form-used
  a curric:Misconception ;
  curric:statement """Adjectives in French have only one form that can be used to describe any noun,
  like English."""@en ;
  curric:correction """In French, adjectives may change their spelling and/or sound when describing
  a woman, girl or feminine noun. This is called the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094185Z"^^xsd:dateTime .

oakcurric:misconception-equivalent-one-english-therefore-formal
  a curric:Misconception ;
  curric:statement """'On' is equivalent to 'one' in English and is therefore is very formal and
  rarely used."""@en ;
  curric:correction """'On' is very commonly used in French and can mean 'everyone', 'people', 'you'
  and 'one'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095841Z"^^xsd:dateTime .

oakcurric:misconception-questions-french-question-word-start
  a curric:Misconception ;
  curric:statement "All questions in French must have a question word or start with a verb."@en ;
  curric:correction """Statements can be made into questions in French by changing the tone of your
  voice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095866Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-usually-come-noun-describing
  a curric:Misconception ;
  curric:statement """Adjectives usually come before the noun they are describing like in
  English."""@en ;
  curric:correction "Adjectives in French usually come after the noun they are describing."@en ;
  dcterms:modified "2026-06-07T15:30:15.097528Z"^^xsd:dateTime .

oakcurric:misconception-ask-questions-need-know-french
  a curric:Misconception ;
  curric:statement """To ask 'do you have ...?' questions we need to know 'do you ...?' in
  French."""@en ;
  curric:correction """There is no phrase for 'do you ...?'. We use intonation to ask 'do you have
  ...?' questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097791Z"^^xsd:dateTime .

oakcurric:misconception-avoir-means-english
  a curric:Misconception ;
  curric:statement "'Avoir' only means 'to have' in English."@en ;
  curric:correction "'Avoir' can be translated both as 'to have' or 'having'."@en ;
  dcterms:modified "2026-06-07T15:30:15.099049Z"^^xsd:dateTime .

oakcurric:misconception-sound-s-pronounced-same-french
  a curric:Misconception ;
  curric:statement "The sound 's' is always pronounced the same in French."@en ;
  curric:correction """There are two 's' sounds, the hard 's' sound which sounds like a 'z', found
  between two vowels, including in liaisons and the soft 's' found in other words, often at
  the beginning, of words, between consonants and as a double 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103398Z"^^xsd:dateTime .

oakcurric:misconception-possible-leave-que-french-like
  a curric:Misconception ;
  curric:statement "It is possible to leave 'que' out in French like it is in English."@en ;
  curric:correction """Even if we would not translate 'que' (that) in English, in French we always
  need to put it when we mean 'think that'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105026Z"^^xsd:dateTime .

oakcurric:misconception-two-words-masculine-feminine-version
  a curric:Misconception ;
  curric:statement "There are just two words for 'the': a masculine and feminine version."@en ;
  curric:correction """There are four different ways to say 'the' in French: 'le', 'las', 'les' and
  'l'' (masculine singular, feminine singular, plural and preceding a vowel/h)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105505Z"^^xsd:dateTime .

oakcurric:misconception-elle-meaning-pronounced-sound-start
  a curric:Misconception ;
  curric:statement "'Elle' meaning she is pronounced with an [i] sound at the start."@en ;
  curric:correction "'Elle' is pronounced with a hard e sound like in egg."@en ;
  dcterms:modified "2026-06-07T15:30:15.105726Z"^^xsd:dateTime .

oakcurric:misconception-add-s-make-nouns-plural
  a curric:Misconception ;
  curric:statement "Add -s to make all nouns plural in French."@en ;
  curric:correction """Many nouns do need an -s in the plural form but masculine nouns ending in
  -eau or -eu need -x adding in the plural form, and there are other exceptions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106393Z"^^xsd:dateTime .

oakcurric:misconception-1st-person-singular-3rd-person
  a curric:Misconception ;
  curric:statement """The 1st person singular and 3rd person singular verb forms are always spelt
  the same."""@en ;
  curric:correction """The 1st and 3rd person singular verb forms are spelt the same for regular -er
  verbs, but for irregular verbs like 'être' and 'avoir' they are different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106923Z"^^xsd:dateTime .

oakcurric:misconception-languages-dont-change-fixed-number
  a curric:Misconception ;
  curric:statement "Languages don't change; they have a fixed number of words in them."@en ;
  curric:correction """Languages are not fixed; they are changing all the time, adopting new words
  to reflect how people live and speak."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107722Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-translated-used-english
  a curric:Misconception ;
  curric:statement "The imperfect tense is always translated as 'used to' in English."@en ;
  curric:correction """The imperfect tense is often translated as 'used to' in English but sometimes
  the simple past is used instead to convey repeated past actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107992Z"^^xsd:dateTime .

oakcurric:misconception-final-consonants-pronounced-english-pronounced
  a curric:Misconception ;
  curric:statement """Final consonants that are pronounced in English are also pronounced in
  French."""@en ;
  curric:correction """The letters d, s, t and x are usually silent at the end of words in
  French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108349Z"^^xsd:dateTime .

oakcurric:misconception-il-means-english
  a curric:Misconception ;
  curric:statement "'Il' always means 'he' in English."@en ;
  curric:correction """Impersonal verbs nearly always have the subject 'il'. This translates as 'it'
  instead of 'he', e.g. 'il fait beau' - 'it is nice weather'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108586Z"^^xsd:dateTime .

oakcurric:misconception-colours-nouns
  a curric:Misconception ;
  curric:statement "Colours are always nouns."@en ;
  curric:correction """Colours can be used as nouns or adjectives. When used as adjectives, they
  must agree with the noun they are describing e.g. une chose bleue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108693Z"^^xsd:dateTime .

oakcurric:misconception-combination-numbers-french-written-like
  a curric:Misconception ;
  curric:statement """Combination numbers in French are written like this: 'dix sept',
  'vingt deux'."""@en ;
  curric:correction """French numbers which are made up of a combination of more than one number
  must be hyphenated, e.g. 'dix-sept' (17), 'vingt-deux' (22), and 'trente-et-un' (31)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108834Z"^^xsd:dateTime .

oakcurric:misconception-french-like-english-one-way
  a curric:Misconception ;
  curric:statement "In French, like in English, there is only one way to say 'the'."@en ;
  curric:correction """There is more than one word to say 'the' in French. For singular masculine
  nouns, use 'le', and for singular feminine nouns, use 'la'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109531Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-same-word-order-french
  a curric:Misconception ;
  curric:statement """Adverbs have the same word order in French as they do in English in two-verb
  sentences."""@en ;
  curric:correction """Adverbs that tell us 'how' and 'how often' come before the infinitive e.g.
  'Elle peut souvent visiter les musées'. 'Tu ne peux pas encore visiter Alger.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.109750Z"^^xsd:dateTime .

oakcurric:misconception-ne-pas-goes-around-verbs
  a curric:Misconception ;
  curric:statement "'Ne ... pas' goes around both verbs in a two-verb sentence."@en ;
  curric:correction """'Ne ... pas' surrounds the first verb in a two-verb sentence. If a sentence
  contains a modal verb and an infinitive, it will surround the conjugated modal verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110517Z"^^xsd:dateTime .

oakcurric:misconception-put-ne-pas-together-main
  a curric:Misconception ;
  curric:statement """We put the 'ne ... pas' together after the main verb to form a negative
  sentence."""@en ;
  curric:correction """The 'ne ... pas' is in two separate parts and must be placed either side of
  the main (1st) verb in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110789Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-follow-same-order-punctuation
  a curric:Misconception ;
  curric:statement "Adjectives follow the same order and punctuation as in English."@en ;
  curric:correction """If there is more than one adjective in a sentence, adjectives after the noun
  are separated by ‘et’. BRAGS adjectives go before the noun and do not need ‘et’. In some
  sentences, there are adjectives surrounding the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110809Z"^^xsd:dateTime .

oakcurric:misconception-accents-pronounced-same-french-written
  a curric:Misconception ;
  curric:statement """The accents é and è are pronounced the same in French and can be written
  interchangably."""@en ;
  curric:correction """It is essential to write an accent accurately as the accents é and è are
  pronounced differently. É is pronounced as in the word 'écrire' and è is pronounced as in
  the word 'trés'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115285Z"^^xsd:dateTime .

oakcurric:misconception-express-date-use-de-2nd
  a curric:Misconception ;
  curric:statement """To express the date I use 'de' for 'of' so 2nd January would be 'le deux de
  janvier'."""@en ;
  curric:correction """There is no need to translate 'of' into French to express the date. For
  example 2nd January would be 'le deux janvier'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119427Z"^^xsd:dateTime .

oakcurric:misconception-french-qu-pronounced-same-english
  a curric:Misconception ;
  curric:statement """In French [qu] is pronounced the same as in English, in words like 'queen' and
  'quiet'."""@en ;
  curric:correction """In French [qu] has the same sound as the hard 'c', this requires a lot of
  practice!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.120883Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-go-noun-french
  a curric:Misconception ;
  curric:statement "All adjectives go after the noun in French."@en ;
  curric:correction """While the majority of adjectives are placed after the noun, certain types of
  adjective go in front. Students should be aware of which adjectives go where in order to
  speak and write with greater accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123851Z"^^xsd:dateTime .

oakcurric:misconception-add-e-adjectives-make-them
  a curric:Misconception ;
  curric:statement "Add -e to all adjectives to make them feminine."@en ;
  curric:correction """Some adjectives follow different patterns. 'Heureux' changes to 'heureuse'
  and 'naturel' changes to 'naturelle'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125091Z"^^xsd:dateTime .

oakcurric:misconception-like-english-french-two-present
  a curric:Misconception ;
  curric:statement "Like in English, French has two present tenses."@en ;
  curric:correction """There is no 'be -ing' in French. There is only one present tense for both the
  simple present and continuous present."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125877Z"^^xsd:dateTime .

oakcurric:misconception-like-other-question-words-french
  a curric:Misconception ;
  curric:statement """Like other question words in French, 'quel' does not change based on the
  gender of the noun."""@en ;
  curric:correction """Unlike other question words in French, 'quel' does change based on the gender
  of the noun, it becomes 'quelle' in the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126256Z"^^xsd:dateTime .

oakcurric:misconception-en-means
  a curric:Misconception ;
  curric:statement "'En' always means 'in'."@en ;
  curric:correction """Many words in French have more than one meaning. 'En' means 'in' and
  'by'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126799Z"^^xsd:dateTime .

oakcurric:misconception-faire-means-make
  a curric:Misconception ;
  curric:statement "'Faire' always means 'to do' or 'to make'."@en ;
  curric:correction """'Faire' has multiple meanings. 'To do' and 'to make' are the most common, but
  it can also mean 'to go' and 'to have', and it has other meanings in different verbal
  phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127112Z"^^xsd:dateTime .

oakcurric:misconception-use-same-articles-il-y
  a curric:Misconception ;
  curric:statement "Use the same articles after 'il y a' and 'il n'y a pas'."@en ;
  curric:correction """Use the indefinite article, depending on gender and number after 'il y a' but
  after 'il n' y a pas', always use de regardless of gender/number and d' for any nouns
  starting with a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129414Z"^^xsd:dateTime .

oakcurric:misconception-fine-use-infinitive-next-subject
  a curric:Misconception ;
  curric:statement "It is fine to use the infinitive next to the subject pronoun."@en ;
  curric:correction """The infinitive is the dictionary form of the verb but verbs change ending to
  match their subject (I, you, she, he etc.). Regular -er verbs always add the same set of
  endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131067Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-plan-my-written
  a curric:Misconception ;
  curric:statement "I don't need to plan my written work before I start writing in French."@en ;
  curric:correction """Planning is essential for success in any written task. Using a content and
  language checklist helps us to plan, improve and check our drafted written work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138749Z"^^xsd:dateTime .

oakcurric:misconception-letter-c-makes-soft-sound
  a curric:Misconception ;
  curric:statement "The letter 'c' makes a soft sound in front of 'a', 'o' and 'u'."@en ;
  curric:correction """The letter 'c' makes a hard sound in front of 'a', 'o' and 'u'. We use the
  cedilla 'ç' to make a soft sound in front of 'a', 'o' and 'u': français."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140020Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-go-noun-french-opposite
  a curric:Misconception ;
  curric:statement """All adjectives go after the noun in French, the opposite to the word order of
  nouns and adjectives in English."""@en ;
  curric:correction """Most adjectives do go after the noun in French, however some adjectives go
  before the noun, these are pre-nominal adjectives. They refer to age, beauty, goodness and
  size (BAGS)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140028Z"^^xsd:dateTime .

oakcurric:misconception-forming-questions-translate-french
  a curric:Misconception ;
  curric:statement "When forming questions, we have to translate 'do you' into French."@en ;
  curric:correction """There is no phrase for 'do you' in French; we can use intonation instead to
  form questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141067Z"^^xsd:dateTime .

oakcurric:misconception-like-english-one-word-my
  a curric:Misconception ;
  curric:statement "Like in English, there is just one word for 'my' in French."@en ;
  curric:correction """French has 3 words for 'my' and the gender of the possession determines which
  'my' to use; 'mon' for masculine singular nouns, 'ma' for feminine singular nouns and
  'mes' for plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141735Z"^^xsd:dateTime .

oakcurric:misconception-nationalities-use-capital-letters-english
  a curric:Misconception ;
  curric:statement "Nationalities use capital letters as in English: I am French."@en ;
  curric:correction "In French, nationalities do not use capital letters: je suis français."@en ;
  dcterms:modified "2026-06-07T15:30:15.142138Z"^^xsd:dateTime .

oakcurric:misconception-numbers-ending-s-x-followed
  a curric:Misconception ;
  curric:statement """Numbers ending in 's' and 'x' followed by nouns beginning with a vowel are
  pronounced the same as numbers followed by a noun beginning with a consonant."""@en ;
  curric:correction """Numbers ending in 's' and 'x' followed by nouns beginning with a vowel are
  pronounced with a liasion; the final consonant of the number is pronounced. 'Trois
  oranges' has a liaison, 'trois chiens' does not."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142340Z"^^xsd:dateTime .

oakcurric:misconception-singular-forms-verb-faire-spelled
  a curric:Misconception ;
  curric:statement """The singular forms of the verb 'faire' are spelled the same way because they
  are pronounced the same way."""@en ;
  curric:correction """The singular forms of the verb 'faire' are spelled differently, but sound the
  same because the 's' and 't' are silent final consonants (SFC)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142354Z"^^xsd:dateTime .

oakcurric:misconception-one-equivalent-tense-english-perfect
  a curric:Misconception ;
  curric:statement """There is just one equivalent tense in English to the perfect tense in
  French."""@en ;
  curric:correction """There are in fact two equivalent tenses in English to the perfect tense in
  French: the present perfect and the simple past. 'J'ai voyagé au Sénégal' can mean both 'I
  travelled to France' and 'I have travelled to France'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143170Z"^^xsd:dateTime .

oakcurric:misconception-liaison-s-followed-vowel
  a curric:Misconception ;
  curric:statement "There is always a liaison when an 's' is followed by a vowel."@en ;
  curric:correction """The liaison between a verb and an article (nous avons un chien) is in fact
  optional. An optional liaison is often used in a more formal setting, for example when
  reading aloud a prepared speech rather than in a more formal conversation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144697Z"^^xsd:dateTime .

oakcurric:misconception-use-inversion-add-question-word
  a curric:Misconception ;
  curric:statement """If you use inversion and add a question word, you don't need to change your
  intonation."""@en ;
  curric:correction """Even when using inversion and/or question words, still raise your voice at
  the end of a sentence in French when asking a question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147828Z"^^xsd:dateTime .

oakcurric:misconception-nous-mean-used-interchangeably
  a curric:Misconception ;
  curric:statement "'On' and 'nous' both mean 'we' and can be used interchangeably."@en ;
  curric:correction """'On' and 'nous' both mean 'we' but 'on' is used more to talk about people
  generally, 'nous' is always used to talk about yourself and another person/people. The
  verb endings are different, 'on' uses il/elle verb endings and the 'nous' ending is -ons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147834Z"^^xsd:dateTime .

oakcurric:misconception-letter-h-pronounced-like-english
  a curric:Misconception ;
  curric:statement "The letter 'h' is pronounced like in English."@en ;
  curric:correction "The letter 'h' is in fact often silent in French: j'habite."@en ;
  dcterms:modified "2026-06-07T15:30:15.148773Z"^^xsd:dateTime .

oakcurric:misconception-time-phrases-like-ann-e
  a curric:Misconception ;
  curric:statement "Time phrases like 'an and 'année' are interchangeable in French."@en ;
  curric:correction """Although they have the same meaning, 'an', 'jour', 'soir' and 'matin' are
  used to indicate specific units of time whereas, 'année', 'journée', 'soirée' and matinée'
  are used for description or duration."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148782Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-tell-us-something-happens
  a curric:Misconception ;
  curric:statement """All adverbs that tell us how and how often something happens come straight
  after the verb and we add -ment to all adjectives to make them adverbs."""@en ;
  curric:correction """There are exceptions to the adverb placement and adverb formation rules. For
  example 'parfois' usually comes at the start of a sentence. 'Dur' is an adjective which
  often doesn't change even when it is used as an adverb with certain verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149453Z"^^xsd:dateTime .

oakcurric:misconception-use-infinitive-je
  a curric:Misconception ;
  curric:statement "Use the infinitive with 'je'."@en ;
  curric:correction """The long form of the verb (infinitive) means -to or -ing so it needs changing
  for the correct subject pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149557Z"^^xsd:dateTime .

oakcurric:misconception-form-imperfect-tense-verbs-take
  a curric:Misconception ;
  curric:statement """To form the imperfect tense with all verbs, take the 'nous' form of the
  present tense, remove -ons and add the appropriate endings."""@en ;
  curric:correction """The verb 'être' is an exception to the rule. Use the stem -ét before adding
  the endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149721Z"^^xsd:dateTime .

oakcurric:misconception-re-ir-verbs-follow-same
  a curric:Misconception ;
  curric:statement "All -re and -ir verbs follow the same pattern."@en ;
  curric:correction """There are different groups of -ir and -re verbs that follow slightly
  different patterns. It's good to revisit these regularly in their own right and because
  they can help with other tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149782Z"^^xsd:dateTime .

oakcurric:misconception-closed-question-requires-am-start
  a curric:Misconception ;
  curric:statement """A closed question requires 'do/does' or 'am/are/is' at the start in French,
  like in English."""@en ;
  curric:correction """Closed questions in French do not start with 'do/does' or 'am/are/is', they
  simply invert the subject and the verb: tu es anglaise, es-tu anglaise ?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.150130Z"^^xsd:dateTime .

oakcurric:misconception-using-ne-n-makes-verbs
  a curric:Misconception ;
  curric:statement "Using 'ne'/'n' makes verbs negatives in French, like 'not' in English."@en ;
  curric:correction """French negation has two parts, 'ne' before the verb and 'pas' after, to say
  what there isn't."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150175Z"^^xsd:dateTime .

oakcurric:misconception-sscs-sound-symbol-correspondences-ai
  a curric:Misconception ;
  curric:statement """The SSCs (sound-symbol correspondences) [ai] and [è/ê] make different
  sounds."""@en ;
  curric:correction """The SSCs (sound-symbol correspondences) [ai] and [è/ê] make the same sound in
  French: 'paire' and 'père'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150477Z"^^xsd:dateTime .

oakcurric:misconception-faire-use-definite-article-french
  a curric:Misconception ;
  curric:statement "After faire, use the definite article in French."@en ;
  curric:correction """Many activities such as doing homework or cooking are followed by the
  definite article, but sports activities with faire are followed by the partitive article
  e.g. 'je fais du vélo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150698Z"^^xsd:dateTime .

oakcurric:misconception-translate-didnt-french
  a curric:Misconception ;
  curric:statement "I have to translate 'didn't' into French."@en ;
  curric:correction """There is no direct translation for 'didn't' in French. Using 'ne ... pas'
  with the perfect tense expresses the equivalent of 'didn't' in French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150751Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-come-same-place-sentence
  a curric:Misconception ;
  curric:statement "Adverbs always come in the same place in a sentence."@en ;
  curric:correction """The type of adverb tells us where to place it. When and where adverbs usually
  come at the beginning or end of a sentence and how (often) adverbs usaully come straight
  after the first verb in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151028Z"^^xsd:dateTime .

oakcurric:misconception-letter-c-makes-same-sound
  a curric:Misconception ;
  curric:statement "The letter 'c' always makes the same sound in French."@en ;
  curric:correction """The letter 'c' is naturally soft (sounds like 's') before 'e' or 'i'. It is
  hard (sounds like k) before 'a', 'o' or 'u'. The 'c' is sometimes softened before 'a', 'o'
  or 'u' with a cedilla: 'ç'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151036Z"^^xsd:dateTime .

oakcurric:misconception-verbs-nous-form-end-ons
  a curric:Misconception ;
  curric:statement "All verbs in the 'nous' form end in -ons."@en ;
  curric:correction """Some verbs like 'manger' behave a little differently. The 'nous' form of
  'manger' is 'mangeons' so that the g sound remains soft."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152277Z"^^xsd:dateTime .

oakcurric:misconception-use-inversion-est-ce-que
  a curric:Misconception ;
  curric:statement """If you use inversion or 'est-ce que' as a questioning device, you don't need
  to change your intonation."""@en ;
  curric:correction """Even if you are changing the word order to use inversion, or adding 'est-ce
  que', you still need to make your voice go up at the end of a sentence to show that you
  are asking a question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152282Z"^^xsd:dateTime .

oakcurric:misconception-sscs-om-sound-same
  a curric:Misconception ;
  curric:statement "The SSCs [om] and [on] always sound the same."@en ;
  curric:correction """When [om] or [on] appear at the end of a word or before a consonant, they
  have a nasal sound and are pronounced the same. However, before a vowel their sounds are
  oral, the 'm' and 'n' are pronounced more clearly, making these SSCs sound different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152573Z"^^xsd:dateTime .

oakcurric:misconception-one-way-saying-french-like
  a curric:Misconception ;
  curric:statement "There is just one way of saying 'you' in French like in English."@en ;
  curric:correction """There are two ways of saying 'you' in French. We use 'tu' for 'you singular'
  and 'vous' for 'you plural'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155343Z"^^xsd:dateTime .

oakcurric:misconception-s-liaison-ils-ont-elles
  a curric:Misconception ;
  curric:statement """The 's' in the liaison of 'ils ont' and 'elles ont' is pronounced like an
  English 's'."""@en ;
  curric:correction """The 's' in the liaison of 'ils ont' and 'elles ont' is pronounced like an
  English 'z'. This is distinguishable to 'ils sont' and 'elles sont' which have the
  pronounciation of an English 's' (no liaison)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155353Z"^^xsd:dateTime .

oakcurric:misconception-ir-verbs-follow-same-pattern
  a curric:Misconception ;
  curric:statement """All -ir verbs follow the same pattern in the present tense, like -er
  verbs."""@en ;
  curric:correction """-ir verbs can be grouped into verbs like 'choisir', verbs like 'partir',
  verbs like 'venir' and verbs like 'ouvrir'. By learning the stem formation and endings for
  these four verbs, students should be able to use wide range of -ir verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155499Z"^^xsd:dateTime .

oakcurric:misconception-french-infinitive-verbs-translated-structure
  a curric:Misconception ;
  curric:statement """French infinitive verbs can only be translated by the 'to - ' structure in
  English."""@en ;
  curric:correction """The infinitive verb can be translated as 'to -' or '-ing' e.g. 'to do' or
  'doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156224Z"^^xsd:dateTime .

oakcurric:misconception-3rd-persons-singular-plural-prendre
  a curric:Misconception ;
  curric:statement """The 3rd persons singular and plural of 'prendre' sound the same, both end with
  silent letters."""@en ;
  curric:correction """The pronunciation of 'prend' and 'prennent' is different. 'Prend' contains
  [en] like in 'enfant' whereas 'prennent' is an oral vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156253Z"^^xsd:dateTime .

oakcurric:misconception-use-indefinite-article-il-ny
  a curric:Misconception ;
  curric:statement """Use the indefinite article after 'il n'y a pas' like you would with
  'il y a'."""@en ;
  curric:correction """After 'il n'y a pas' always use 'de' (or 'd'' before words starting with
  vowels or silent 'h'), regardless of gender or number."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156555Z"^^xsd:dateTime .

oakcurric:misconception-de-translated-english
  a curric:Misconception ;
  curric:statement "'De' is always translated as 'to' in English."@en ;
  curric:correction """'De' is often translated as 'to'. However, it can be translated as 'from' and
  is sometimes not translated at all."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156959Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-describes-used-happen
  a curric:Misconception ;
  curric:statement "The imperfect tense only describes what used to happen."@en ;
  curric:correction """The imperfect tense describes what was happening and what used to happen and
  can be used with the perfect tense and a conjunction like 'quand' or 'pendant que'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156985Z"^^xsd:dateTime .

oakcurric:misconception-indefinite-adjectives-agree-number-gender
  a curric:Misconception ;
  curric:statement "Indefinite adjectives always agree in number and gender."@en ;
  curric:correction """'Tout le' agrees in number and gender but 'même', 'autre' and 'quelque' agree
  in number only. 'Chaque' and 'plusieurs' do not change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156990Z"^^xsd:dateTime .

oakcurric:misconception-il-il-faut-means
  a curric:Misconception ;
  curric:statement "The 'il' in 'il faut' means 'he'."@en ;
  curric:correction """'Il faut' is from the impersonal verb 'falloir' - 'to be necessary'. 'Il'
  does not mean 'he'; we translate 'il faut' as 'it is necessary' or 'you must'. It works
  like a modal verb in that it is usually followed by a 2nd verb in the infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157010Z"^^xsd:dateTime .

oakcurric:misconception-ent-ending-3rd-person-plural
  a curric:Misconception ;
  curric:statement "The -ent ending of the 3rd person plural of the verb is pronounced."@en ;
  curric:correction """The -ent ending of the 3rd person plural of the verb is not pronounced. It is
  therefore difficult to tell the difference between the 'il/elle' form and the 'ils/elles'
  form of verbs when spoken."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158046Z"^^xsd:dateTime .

oakcurric:misconception-direct-object-pronouns-le-la
  a curric:Misconception ;
  curric:statement """The direct object pronouns 'le' and 'la' change to 'l' ' if the noun starts
  with a vowel or a 'h': Je lis l'histoire."""@en ;
  curric:correction """The direct object pronouns 'le' and 'la' change to 'l' ' if the verb starts
  with a vowel or a 'h', not the noun: J'achète le chapeau - je l'achète."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158051Z"^^xsd:dateTime .

oakcurric:misconception-sound-symbol-correspondences-qu-ch
  a curric:Misconception ;
  curric:statement """The sound-symbol correspondences [qu], [ch] and [th] are pronounced the same
  as in English."""@en ;
  curric:correction """The SSCs [qu], [ch] and [th] are pronounced differently in French than in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158070Z"^^xsd:dateTime .

oakcurric:misconception-make-adjective-plural-french-add
  a curric:Misconception ;
  curric:statement "To make an adjective plural in French we add an -s like in English."@en ;
  curric:correction """In French there are various ways to make an adjective plural, including
  adding an -s, an -x or changing -al to -aux."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158739Z"^^xsd:dateTime .

oakcurric:misconception-use-partitive-article-food-drink
  a curric:Misconception ;
  curric:statement """Always use the partitive article after food and drink items, even with
  negative sentences."""@en ;
  curric:correction """The partitive article changes to 'de' to say what you don't eat and drink
  e.g. 'je ne mange pas de pizza'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160230Z"^^xsd:dateTime .

oakcurric:misconception-le-le
  a curric:Misconception ;
  curric:statement "'à' + 'le' = 'à le'."@en ;
  curric:correction "When 'à' is followed by 'le' it becomes 'au'."@en ;
  dcterms:modified "2026-06-07T15:30:15.162273Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-change-spelling-based-gender
  a curric:Misconception ;
  curric:statement """Adjectives do not change spelling based on gender or number, as in
  English."""@en ;
  curric:correction """Adjectives do change spelling based on gender or number, for example: 'un
  chien amusant', 'deux tortues amusantes'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162315Z"^^xsd:dateTime .

oakcurric:misconception-au-used-masculine-singular-plural
  a curric:Misconception ;
  curric:statement """'Au' can be used before masculine singular and plural nouns to mean 'to the'
  and 'at the'."""@en ;
  curric:correction """'Au' can only be used before masculine singular nouns to mean 'to the' and
  'at the', 'aux' needs to be used before masculine/feminine plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162635Z"^^xsd:dateTime .

oakcurric:misconception-negating-change-articles-de-d
  a curric:Misconception ;
  curric:statement "When negating, change any articles to 'de/d''."@en ;
  curric:correction """Change indefinite articles to 'de/d'' when negating but keep the definite
  articles the same and keep the indefinite articles when using 'être'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163424Z"^^xsd:dateTime .

oakcurric:misconception-translate-reflexive-verbs-literally-english
  a curric:Misconception ;
  curric:statement """Translate reflexive verbs literally into English with the reflexive
  pronoun."""@en ;
  curric:correction """Some verbs use reflexive pronouns in French, but we don’t always translate
  the reflexive pronoun in English e.g. 'Je me sens' meaning 'I feel'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163429Z"^^xsd:dateTime .

oakcurric:misconception-knowing-lower-numbers-enough-able
  a curric:Misconception ;
  curric:statement "Knowing the lower numbers is enough to be able to tell the time in French."@en ;
  curric:correction """As French uses 24-hour clock more than English and gives the minutes after
  the hour, you need to know numbers 1-59 well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163565Z"^^xsd:dateTime .

oakcurric:misconception-information-used-french-like-english
  a curric:Misconception ;
  curric:statement "'Information' is used in French like it is in English."@en ;
  curric:correction """'Information' is a cognate but it is usually in the plural form in French
  ('des informations'). When used in the singular form, it means 'a piece of information'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163758Z"^^xsd:dateTime .

oakcurric:misconception-still-need-use-subject-pronoun
  a curric:Misconception ;
  curric:statement """I still need to use the subject pronoun even if I am using a name or a noun
  before the verb form."""@en ;
  curric:correction """A noun or name can replace a subject pronoun. So 'ils chantent ensemble'
  could be changed to 'les garçons chantent ensemble' or 'David, Robert et Jacques chantent
  ensemble'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164363Z"^^xsd:dateTime .

oakcurric:misconception-ou-u-same-u-sound
  a curric:Misconception ;
  curric:statement "[ou] and [u] are both the same 'u' sound."@en ;
  curric:correction """Be careful not to mix up the similar but not identical sounds, people may not
  understand you or you could be saying a different word to the one you mean."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164369Z"^^xsd:dateTime .

oakcurric:misconception-il-faut-works-like-modal
  a curric:Misconception ;
  curric:statement """'Il faut' works like modal verbs, it changes for different subject
  pronouns."""@en ;
  curric:correction """'Il faut' is only used in the 3rd person singular and it is impersonal, it is
  used to talk about what it is necessary for people in general to do or what they must do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165060Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-french-like-english
  a curric:Misconception ;
  curric:statement "There is one verb for 'can' in French like in English."@en ;
  curric:correction """The verb for 'can' changes depending on whether you need specific
  skills/knowledge to be able to do it. If not, use 'pouvoir', if it does, use 'savoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165225Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-follow-same-pattern
  a curric:Misconception ;
  curric:statement "All modal verbs follow the same pattern in the 3rd person plural."@en ;
  curric:correction """'Devoir' and 'pouvoir' are formed the same way, 'vouloir' is the same with
  the addition of an 'l' instead of a 'v' and 'savoir' is different; it follows the same
  pattern as the 'nous'/'vous' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165231Z"^^xsd:dateTime .

oakcurric:misconception-ils-ont-ils-sont-sound
  a curric:Misconception ;
  curric:statement "'Ils ont' and 'ils sont' sound the same."@en ;
  curric:correction """Although these two verbs sound similar, there is a distinction between the
  'z' sound created by s-liaison in 'ils ont' and the 's' sound at the beginning of 'sont'
  after the silent 's' on 'ils'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165607Z"^^xsd:dateTime .

oakcurric:misconception-translate-de-english
  a curric:Misconception ;
  curric:statement "We translate 'de' into English with 'of'."@en ;
  curric:correction """Sometimes we don't actually need to translate the 'de' in a French sentence
  into English. For example, there is no possessive apostrophe in French so to express
  'Sophie's sister' we have to say 'the sister of Sophie' - 'la sœur de Sophie'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165669Z"^^xsd:dateTime .

oakcurric:misconception-ma-possessive-adjective-feminine-singular
  a curric:Misconception ;
  curric:statement "'Ma' is the possessive adjective for all feminine singular nouns."@en ;
  curric:correction "Use 'mon/ton' before all nouns starting with a vowel/h."@en ;
  dcterms:modified "2026-06-07T15:30:15.165675Z"^^xsd:dateTime .

oakcurric:misconception-difference-french-present-perfect-tense
  a curric:Misconception ;
  curric:statement """There is no difference in French between the present and perfect tense forms
  'I do' and 'I did', 'I say' and 'I said', because they sound the same."""@en ;
  curric:correction """The spellings of the past participles 'fait' and 'dit' are different to the
  first person (I) present tense but sound the same because of silent final consonants.
  Another difference is using 'j'ai' before past participles to say 'I did'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166052Z"^^xsd:dateTime .

oakcurric:misconception-pronoun-means-people-general
  a curric:Misconception ;
  curric:statement "The pronoun 'on' only means 'people in general'."@en ;
  curric:correction """The pronoun 'on' does mean 'people in general' but it is often used to mean
  'we' in informal conversations, like when you are talking to friends. You will have seen
  this meaning before in the phrase 'on y va !' which means 'let's go!'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166214Z"^^xsd:dateTime .

oakcurric:misconception-qui-used-question-word
  a curric:Misconception ;
  curric:statement "'Qui' is always used as a question word."@en ;
  curric:correction """'Qui' is a question word meaning 'who' but is also used as a relative pronoun
  to introduce a relative clause, for example 'L'homme qui est grand est mon papa', meaning
  'the man who is tall is my dad'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166426Z"^^xsd:dateTime .

oakcurric:misconception-using-one-adjective-french-need
  a curric:Misconception ;
  curric:statement "When using more than one adjective in French we need 'et' between them."@en ;
  curric:correction """We only need 'et' between French adjectives if they come after the noun. For
  the B-R-A-G-S adjectives that come before the noun, no connective is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166434Z"^^xsd:dateTime .

oakcurric:misconception-words-ending-c-like-historic
  a curric:Misconception ;
  curric:statement "Words ending in -c (like historic) also end in -c in French."@en ;
  curric:correction "Words ending in -c in English often end in -que in French: historique."@en ;
  dcterms:modified "2026-06-07T15:30:15.166732Z"^^xsd:dateTime .

oakcurric:misconception-form-present-tense-prendre-1st
  a curric:Misconception ;
  curric:statement """To form the present tense of 'prendre' in the 1st and 2nd persons plural,
  remove -re from the infinitive to get the stem."""@en ;
  curric:correction """To get the stem for the plural forms of 'prendre' in the present tense, you
  also need to drop the 'd' before adding the correct endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166740Z"^^xsd:dateTime .

oakcurric:misconception-add-me-make-ordinal-numbers
  a curric:Misconception ;
  curric:statement "Add 'ième' to make all ordinal numbers."@en ;
  curric:correction """Add 'ième' to make the majority of ordinal numbers but 'first'
  (premier/première) is an exception and cardinal numbers ending -e, drop the final -e
  before adding 'ième'. There are a few other spelling exceptions like 'neuvième' and
  'cinquième'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166746Z"^^xsd:dateTime .

oakcurric:misconception-equivalent-way-add-er-onto
  a curric:Misconception ;
  curric:statement """There is an equivalent way to add -er onto adjectives to make comparisons like
  in English."""@en ;
  curric:correction """We cannot change adjectives to make comparisons in French. To compare two
  people or things, we instead have to say that one is more or less 'something' than
  another. For example: 'Elle est plus grande que son frère.' She is taller than her
  brother."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166752Z"^^xsd:dateTime .

oakcurric:misconception-using-ne-verb-makes-verbs
  a curric:Misconception ;
  curric:statement "Using 'ne' before the verb makes verbs negative, like 'don't' in English."@en ;
  curric:correction """In French, there are two parts to negation, 'ne' before the verb and 'pas'
  after."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168164Z"^^xsd:dateTime .

oakcurric:misconception-describe-language-something-someone-use
  a curric:Misconception ;
  curric:statement """To describe a language, where something or someone is from, use exactly the
  same word in French, as we do in English, e.g. 'I learn Spanish,' 'he is Spanish'."""@en ;
  curric:correction """When used as a noun for a language, the word needs a definite article. When
  used as an adjective to describe nationality of a person or thing, the word agrees with
  the noun it describes. When used for nationality, the word needs a capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168384Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-verbs-depend-reply-english
  a curric:Misconception ;
  curric:statement """Prepositions with the verbs 'depend' and 'reply' in English work the same way
  as prepositions with 'dépendre' and 'répondre' in French."""@en ;
  curric:correction """'Depend' is followed by 'on' in English and 'dépendre' by a form of 'de' in
  French. 'Répondre' is always followed by a form of 'à' in French whereas in English it can
  be translated as 'reply to' but also with 'answer', where there is no preposition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168395Z"^^xsd:dateTime .

oakcurric:misconception-r-same-english-r-sound
  a curric:Misconception ;
  curric:statement "[r] is the same as the English 'r' sound."@en ;
  curric:correction """[r] in French is a raspier sound, produced in the back of the throat, which
  you can practise."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168479Z"^^xsd:dateTime .

oakcurric:misconception-word-german-allemand-lower-case
  a curric:Misconception ;
  curric:statement "The word German is always 'allemand' with a lower case 'a' in French."@en ;
  curric:correction """With a capital letter, Allemand is a noun meaning a person from Germany. With
  a lower case letter it is an adjective describing someone or something that comes from
  Germany and also a noun meaning the German language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168627Z"^^xsd:dateTime .

oakcurric:misconception-one-translation-french-infinitive-english
  a curric:Misconception ;
  curric:statement "There is only one translation of a French infinitive into English."@en ;
  curric:correction """An infinitive can be translated into English using the -ing form or 'to ...':
  conduire - to drive, driving."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168633Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-postnominal-french-come-noun
  a curric:Misconception ;
  curric:statement "All adjectives are postnominal in French; they come after the noun."@en ;
  curric:correction """Most adjectives in French come after the noun but there are a group of
  prenominal adjectives. We use BRAGS to remember that adjectives of Beauty, Rank, Age,
  Goodness and Size come before the noun like adjectives in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168737Z"^^xsd:dateTime .

oakcurric:misconception-need-know-h-french-silent
  a curric:Misconception ;
  curric:statement "All I need to know about [h] in French is that it is silent."@en ;
  curric:correction """The rules of liaison and elision apply to the French silent [h]. Before a
  word starting with [h], if a word ends with an SFC, the consonant is pronounced (liaison)
  and words like 'le' and 'que' replace their final letter with an apostrophe (elision)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169270Z"^^xsd:dateTime .

oakcurric:misconception-letters-ain-aim-pronounced-same
  a curric:Misconception ;
  curric:statement "The letters 'ain' and 'aim' are always pronounced the same way."@en ;
  curric:correction """Before a consonant or at the end of a word, [ain] and [aim] are nasal but
  before a vowel, they are non-nasal sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169776Z"^^xsd:dateTime .

oakcurric:misconception-direct-object-pronouns-me-me
  a curric:Misconception ;
  curric:statement """The direct object pronouns 'me' and 'you' are always 'me' and 'te' in
  French."""@en ;
  curric:correction """The direct object pronouns 'me' and 'te' change before a vowel in French,
  they become 'm' and 't'. This is an elision."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170335Z"^^xsd:dateTime .

oakcurric:misconception-like-english-talk-meal-food
  a curric:Misconception ;
  curric:statement """Like in English, to talk about 'having' a meal, food or drink in French, use
  the verb 'avoir': j'ai le petit-déjeuner (I am having breakfast)."""@en ;
  curric:correction """To talk about 'having' a meal, food or drink in French, use the verb
  'prendre', not 'avoir': je prends le petit-déjeuner."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170341Z"^^xsd:dateTime .

oakcurric:misconception-verbs-like-sortir-choisir-follow
  a curric:Misconception ;
  curric:statement """Verbs like 'sortir' and 'choisir' follow the same patterns in the present and
  perfect tenses."""@en ;
  curric:correction """Verbs like 'sortir' and 'choisir' follow the same patterns in the perfect
  tense - they need an auxiliary verb and a past participle ending in -i but follow
  different patterns in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170650Z"^^xsd:dateTime .

oakcurric:misconception-look-word-dictionary-including-verb
  a curric:Misconception ;
  curric:statement "You can look up any word in the dictionary, including verb forms."@en ;
  curric:correction """The only form of the verb you find in the dictionary is the infinitive so you
  may still need to change it for the right person and tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170656Z"^^xsd:dateTime .

oakcurric:misconception-en-sound-same-french
  a curric:Misconception ;
  curric:statement "[en/an] and [on] sound the same in French."@en ;
  curric:correction """Although the sounds are simililar and both nasal vowels, [en/an] is a nasal
  'a' and [on] is a nasal 'o'. The mouth should be wide for [en/an] and almost closed for
  [on]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170836Z"^^xsd:dateTime .

oakcurric:misconception-pr-f-r-e-spelt
  a curric:Misconception ;
  curric:statement """Préféré(e) is often spelt wrong, with not enough, or indeed too many
  accents!"""@en ;
  curric:correction """'Préféré' is favourite in its masculine form. The e that is added in the
  feminine form does not have an accent; 'préférée'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171017Z"^^xsd:dateTime .

oakcurric:misconception-use-time-phrase-show-whether
  a curric:Misconception ;
  curric:statement """You can use a time phrase to show whether you mean a completed action in the
  past or a regular past event/activity."""@en ;
  curric:correction """In French, the verb alone already shows whether you mean a completed action
  in the past (use the formation rule for the perfect tense) or a regular past
  event/activity (use the formation rule for the imperfect tense). Time phrases can also be
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171023Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-follow-regular-er
  a curric:Misconception ;
  curric:statement """All past participles follow the regular -er verb pattern: change the -er to
  -é: 'j'ai commencé' ('I started')."""@en ;
  curric:correction """Some past participles are irregular and do not follow the regular -er verb
  pattern: 'j'ai fait' ('I did')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171028Z"^^xsd:dateTime .

oakcurric:misconception-y-sound-same-french-english
  a curric:Misconception ;
  curric:statement "The [y] sound is the same in French as it does in English."@en ;
  curric:correction """The English [y] has two different sounds, as in 'myth', a short 'i' sound,
  and 'cycling' where it sounds like the word 'eye'. The French [y] sounds like the SSC [i]
  as in 'midi'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171036Z"^^xsd:dateTime .

oakcurric:misconception-like-english-sans-followed-ing
  a curric:Misconception ;
  curric:statement "Like in English, 'sans' is followed by the -ing form of a verb in French."@en ;
  curric:correction """In French, 'sans' is followed by the infinitive form of a verb, e.g. 'elle
  part sans dire un mot' - 'she leaves without saying a word'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171182Z"^^xsd:dateTime .

oakcurric:misconception-articles-le-la-l-les
  a curric:Misconception ;
  curric:statement "The articles le/la/l'/les and un/une can be used interchangeably."@en ;
  curric:correction """Use the definite article (le/la/l'/les) for specific nouns and the indefinite
  article (un/une) for non-specific nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171269Z"^^xsd:dateTime .

oakcurric:misconception-me-te-direct-object-pronouns
  a curric:Misconception ;
  curric:statement "'Me' and 'te' are always the direct object pronouns 'me' and 'you'."@en ;
  curric:correction """'Me' and 'te' are used as direct object pronouns but also the reflexive
  pronouns meaning 'myself' and yourself'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171280Z"^^xsd:dateTime .
