  dcterms:modified "2026-06-07T15:29:23.076873Z"^^xsd:dateTime .

oakcurric:priorknowledge-2863-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use intonation, inversion and est-ce que questions in the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.076882Z"^^xsd:dateTime .

oakcurric:priorknowledge-2863-5
  a curric:PriorKnowledgeRequirement ;
