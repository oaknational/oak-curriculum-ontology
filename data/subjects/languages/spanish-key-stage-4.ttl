oakcurric:priorknowledge-3171-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of the preterite, including some irregular verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.100102Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of the present tense, including some irregular verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.100118Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know direct objects lo', 'la', 'los', 'las', and rules for direct objects in
  one and two-verb constructions."""@en ;
  dcterms:modified "2026-06-07T15:29:23.100126Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know 'quisiera' with an infinitive and 'me/te/le gustaría' with an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:29:23.100131Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to use present tense and imperfect tense persons of 'estar' with a
  present participle."""@en ;
  dcterms:modified "2026-06-07T15:29:23.100137Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of the imperfect tense, including some irregular verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.100151Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know to use the preterite for interruptions to ongoing events in the
  past."""@en ;
  dcterms:modified "2026-06-07T15:29:23.100157Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know syntax of prepositions in questions."@en ;
  dcterms:modified "2026-06-07T15:29:23.100162Z"^^xsd:dateTime .

oakcurric:priorknowledge-3171-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all sound-symbol correspondences."@en ;
  dcterms:modified "2026-06-07T15:29:23.100167Z"^^xsd:dateTime .

oakcurric:priorknowledge-3518-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of the present tense, including irregulars."@en ;
  dcterms:modified "2026-06-07T15:29:23.394181Z"^^xsd:dateTime .

oakcurric:priorknowledge-3518-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of the preterite, including irregulars."@en ;
  dcterms:modified "2026-06-07T15:29:23.394193Z"^^xsd:dateTime .

oakcurric:priorknowledge-3518-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to talk in a formal register, using 'usted' to mean 'you', and
  possessive adjective 'su' to mean formal 'your'."""@en ;
  dcterms:modified "2026-06-07T15:29:23.394199Z"^^xsd:dateTime .

oakcurric:priorknowledge-3518-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the difference between 'ser' and 'estar'."@en ;
  dcterms:modified "2026-06-07T15:29:23.394204Z"^^xsd:dateTime .

oakcurric:priorknowledge-3518-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to use the present tense with 'desde hace', and 'llevar' with a time
  period and present participle ."""@en ;
  dcterms:modified "2026-06-07T15:29:23.394208Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the imperfect is for habitual actions in the past."@en ;
  dcterms:modified "2026-06-07T15:29:23.479093Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know singular persons of regular -ar, -er, -ir verbs in the imperfect."@en ;
  dcterms:modified "2026-06-07T15:29:23.479104Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know 'tenía' and 'tenías' mean 'had' and 'había' means there 'was/were'."@en ;
  dcterms:modified "2026-06-07T15:29:23.479110Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know 'era' and 'eras' mean 'was' or 'were' with a trait."@en ;
  dcterms:modified "2026-06-07T15:29:23.479114Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know sound-symbol correspondences silent [h], [ch],"@en ;
  dcterms:modified "2026-06-07T15:29:23.479119Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know strong vowels [a], [o], [e]."@en ;
  dcterms:modified "2026-06-07T15:29:23.479123Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use 'hay'."@en ;
  dcterms:modified "2026-06-07T15:29:23.479127Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know modal verb 'poder' and that its stem changes from o to ue."@en ;
  dcterms:modified "2026-06-07T15:29:23.479132Z"^^xsd:dateTime .

oakcurric:priorknowledge-3162-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know they can use 'hace' with a noun to talk about the weather."@en ;
