  schema:description "a word meaning 'a', 'an' or 'any' in questions"@en ;
  dcterms:modified "2026-06-07T15:30:02.416685Z"^^xsd:dateTime .

oakcurric:keyword-alguna
  a curric:Keyword ;
  schema:name "alguna"@en ;
  schema:description "a word meaning 'a', 'an' or 'any' in questions"@en ;
  dcterms:modified "2026-06-07T15:30:02.416690Z"^^xsd:dateTime .

oakcurric:keyword-esto
  a curric:Keyword ;
  schema:name "esto"@en ;
  schema:description """Spanish pronoun meaning 'this' for something unspecific or a general
  idea"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417850Z"^^xsd:dateTime .

oakcurric:keyword-eso
  a curric:Keyword ;
  schema:name "eso"@en ;
  schema:description """Spanish pronoun meaning 'that' for something unspecific or a general
  idea"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417856Z"^^xsd:dateTime .

oakcurric:keyword-los-que-las-que
  a curric:Keyword ;
  schema:name "los que, las que"@en ;
  schema:description "relative pronoun meaning 'that', 'which' or 'who' for a plural noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.417861Z"^^xsd:dateTime .

oakcurric:keyword-el-cual-la-cual
  a curric:Keyword ;
  schema:name "el cual, la cual"@en ;
  schema:description """relative pronoun meaning 'that', 'which' or 'who' for a singular or
  uncountable noun"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417869Z"^^xsd:dateTime .

oakcurric:keyword-los-cuales-las-cuales
  a curric:Keyword ;
  schema:name "los cuales, las cuales"@en ;
  schema:description "relative pronoun meaning 'that', 'which' or 'who' for a plural noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.417877Z"^^xsd:dateTime .

oakcurric:keyword-interesar-type-verbs
  a curric:Keyword ;
  schema:name "'interesar'-type verbs"@en ;
  schema:description "group of verbs which require the use of an indirect object pronoun"@en ;
  dcterms:modified "2026-06-07T15:30:02.421044Z"^^xsd:dateTime .

oakcurric:keyword-active-reading
  a curric:Keyword ;
  schema:name "active reading"@en ;
  schema:description """engaging fully with the text in a focused effort to understand and find
  relevant information"""@en ;
  dcterms:modified "2026-06-07T15:30:02.422101Z"^^xsd:dateTime .

oakcurric:keyword-irregular-1st-person-verb
  a curric:Keyword ;
  schema:name "irregular 1st person verb"@en ;
  schema:description """verb that is irregular in the 1st person singular form of the
  present tense"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424490Z"^^xsd:dateTime .

oakcurric:keyword-haber
  a curric:Keyword ;
  schema:name "haber"@en ;
  schema:description """special verb that helps form the perfect tense in Spanish, translated as
  'have, has' in English, e.g. 'I have lived', 'he has spoken'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424734Z"^^xsd:dateTime .

oakcurric:keyword-auxiliary
  a curric:Keyword ;
  schema:name "auxiliary"@en ;
  schema:description "verb that helps form part of a 2-verb tense structure"@en ;
  dcterms:modified "2026-06-07T15:30:02.424744Z"^^xsd:dateTime .

oakcurric:keyword-listening-strategies
  a curric:Keyword ;
  schema:name "listening strategies"@en ;
  schema:description """techniques to improve understanding and retention; they include
  pre-listening, during-listening, and after-listening tasks to enhance comprehension"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425061Z"^^xsd:dateTime .

oakcurric:keyword-verb-of-commandrequest
  a curric:Keyword ;
  schema:name "verb of command/request"@en ;
  schema:description """expresses a command, suggestion or request for something to happen; these
  verbs often introduce the subjunctive after 'que'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427157Z"^^xsd:dateTime .

oakcurric:keyword-donde
  a curric:Keyword ;
  schema:name "donde"@en ;
  schema:description "relative pronoun meaning 'where'"@en ;
  dcterms:modified "2026-06-07T15:30:02.427168Z"^^xsd:dateTime .

oakcurric:keyword-past-continuous
  a curric:Keyword ;
  schema:name "past continuous"@en ;
  schema:description """verb tense used to talk about what was happening and to set the scene in
  past-tense accounts"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427177Z"^^xsd:dateTime .

oakcurric:keyword-aquel
  a curric:Keyword ;
  schema:name "aquel"@en ;
  schema:description "'that' before a singular or uncountable masculine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427364Z"^^xsd:dateTime .

oakcurric:keyword-aquella
  a curric:Keyword ;
  schema:name "aquella"@en ;
  schema:description "'that' before a singular or uncountable feminine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427370Z"^^xsd:dateTime .

oakcurric:keyword-aquellos
  a curric:Keyword ;
  schema:name "aquellos"@en ;
  schema:description "'those' before a plural masculine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427377Z"^^xsd:dateTime .

oakcurric:keyword-aquellas
  a curric:Keyword ;
  schema:name "aquellas"@en ;
  schema:description "'those' before a plural feminine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427388Z"^^xsd:dateTime .

oakcurric:keyword-antes-de
  a curric:Keyword ;
  schema:name "antes de"@en ;
  schema:description "adverb (+ infinitive) meaning 'before (+ -ing)'"@en ;
  dcterms:modified "2026-06-07T15:30:02.427560Z"^^xsd:dateTime .

oakcurric:keyword-despus-de
  a curric:Keyword ;
  schema:name "después de"@en ;
  schema:description "adverb (+ infinitive) meaning 'after (+ -ing)'"@en ;
  dcterms:modified "2026-06-07T15:30:02.427568Z"^^xsd:dateTime .

oakcurric:keyword-infinitive-clause
  a curric:Keyword ;
  schema:name "infinitive clause"@en ;
  schema:description """phrase with an infinitive verb that adds information about the main
  clause"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427591Z"^^xsd:dateTime .

oakcurric:keyword-algunos
  a curric:Keyword ;
  schema:name "algunos"@en ;
  schema:description "'some' before a plural masculine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427689Z"^^xsd:dateTime .

oakcurric:keyword-algunas
  a curric:Keyword ;
  schema:name "algunas"@en ;
  schema:description "'some' before a plural feminine noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.427694Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-develop-my-answers-much-possible
  a curric:Misconception ;
  curric:statement """I should develop my answers as much as possible for all parts of the speaking
  exam."""@en ;
  curric:correction """It is not necessary to develop your answers extensively for all parts of the
  speaking exam. Remember to keep your answers short and succinct in the role-play section."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083811Z"^^xsd:dateTime .

oakcurric:misconception-like-role-play-keep-my
  a curric:Misconception ;
  curric:statement """Like in a role-play, I should keep my answers short and concise in a
  conversation."""@en ;
  curric:correction """Conversation answers should be developed and extended with at least three
  verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083849Z"^^xsd:dateTime .

oakcurric:misconception-verb-dar-translates-give-giving
  a curric:Misconception ;
  curric:statement "The verb 'dar' always translates as 'to give, giving'."@en ;
  curric:correction """The verb 'dar' means 'to give, giving' but can also translate as 'to be' +
  adjective when describing how something makes people feel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083855Z"^^xsd:dateTime .

oakcurric:misconception-rely-strategies-like-prediction-successfully
  a curric:Misconception ;
  curric:statement """I can rely on strategies like prediction to successfully complete listening
  comprehension questions."""@en ;
  curric:correction """Strategies like prediction can be useful, but the most important way to
  successfully answer listening comprehension questions is by having a broad vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084492Z"^^xsd:dateTime .

oakcurric:misconception-spanish-ma-ana-means-morning
  a curric:Misconception ;
  curric:statement "In Spanish, 'mañana' always means 'morning'."@en ;
  curric:correction """In Spanish 'mañana' has two meanings. It can mean 'morning' or
  'tomorrow'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084741Z"^^xsd:dateTime .

oakcurric:misconception-tu-subject-pronoun-possessive-adjective
  a curric:Misconception ;
  curric:statement """'Tu' is both the subject pronoun 'you' and the possessive adjective
  'your'."""@en ;
  curric:correction """'Tu' without an accent is a possessive adjective: you; 'tú' with an accent is
  a subject pronoun: you."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084746Z"^^xsd:dateTime .

oakcurric:misconception-translation-fuimos-went
  a curric:Misconception ;
  curric:statement "The only translation of 'fuimos' is 'we went'."@en ;
  curric:correction """'fuimos' can mean 'we went' or 'we were' depending on the context. The verbs
  'ser' and 'ir' are identical in the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084752Z"^^xsd:dateTime .

oakcurric:misconception-role-play-conversation-answers-kept
  a curric:Misconception ;
  curric:statement "Role-play and conversation answers should be kept brief."@en ;
  curric:correction """Role-play answers should be kept relatively brief, whereas conversations
  present the opportunity to develop answers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084821Z"^^xsd:dateTime .

oakcurric:misconception-cu-l-cu-les-appear
  a curric:Misconception ;
  curric:statement "'Cuál' and 'cuáles' may appear directly before a noun."@en ;
  curric:correction """'Cuál' and 'cuáles' may not appear directly before a noun. As they are
  pronouns, they either stand alone or appear before a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084941Z"^^xsd:dateTime .

oakcurric:misconception-spanish-subject-pronouns-necessary-verb
  a curric:Misconception ;
  curric:statement """In Spanish, subject pronouns are never necessary as verb endings indicate who
  is doing the action."""@en ;
  curric:correction """We can use subject pronouns 'tú' (you, sing) and 'vosotros/as' (you all) to
  give emphasis or to present a contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084946Z"^^xsd:dateTime .

oakcurric:misconception-word-order-questions-same-spanish
  a curric:Misconception ;
  curric:statement "Word order in questions is the same in Spanish and English."@en ;
  curric:correction """Prepositions appear at the start of Spanish questions. They usually appear at
  the end of English questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085121Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-gender-number-marking
  a curric:Misconception ;
  curric:statement "Past participles do not have gender and number marking."@en ;
  curric:correction """In passive sentences with 'ser' + past participle, the past participle must
  agree in number with the noun it acts on."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085530Z"^^xsd:dateTime .

oakcurric:misconception-translate-sentences-desde-hace-word
  a curric:Misconception ;
  curric:statement "I can translate sentences with 'desde hace' word for word."@en ;
  curric:correction """In Spanish, 'desde hace' appears together with a verbs in the present tense
  to say how long you've been doing something. We use a different tense in English. 'Vivo
  aquí desde hace años' - 'I have been living here for years'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085536Z"^^xsd:dateTime .

oakcurric:misconception-english-translation-visitado-visited
  a curric:Misconception ;
  curric:statement "The English translation of 'he visitado' is 'I visited'."@en ;
  curric:correction """The perfect tense is used to express what has happened. The English
  translation of 'he visitado' is 'I have visited'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085773Z"^^xsd:dateTime .

oakcurric:misconception-accents-present-several-forms-ir
  a curric:Misconception ;
  curric:statement """Accents are present in several forms of 'ir' and -ar verbs in the imperfect
  tense."""@en ;
  curric:correction """Accents are only present in the 1st person singular (we) form of 'ir'
  ('íbamos') and -ar verbs (-ábamos) in the imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085818Z"^^xsd:dateTime .

oakcurric:misconception-singular-plural-translated-same-spanish
  a curric:Misconception ;
  curric:statement """You are (singular) and you are (plural) are translated the same in Spanish -
  'estás'."""@en ;
  curric:correction """To say ‘you are’ (singular), we say 'estás'; To say ‘you are’ (plural), we
  say 'estáis'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085945Z"^^xsd:dateTime .

oakcurric:misconception-suffix-ito-added-end-noun
  a curric:Misconception ;
  curric:statement """The suffix -ito is added to the end of any noun to give the meaning
  'small'."""@en ;
  curric:correction """The final letter is removed from nouns ending in ‘a’ or ‘o’ before adding
  -ito or -ita."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086501Z"^^xsd:dateTime .

oakcurric:misconception-translate-verbs-like-basta-hace
  a curric:Misconception ;
  curric:statement "I can translate verbs like 'basta' and 'hace falta' word-for-word."@en ;
  curric:correction """Verbs like 'basta' and 'hace falta' can’t always be translated word-for-word
  - they don’t work the same way as English verbs. You need to choose the most idiomatic or
  natural-sounding translation based on the context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086689Z"^^xsd:dateTime .

oakcurric:misconception-spanish-masculine-adjectives-end-o
  a curric:Misconception ;
  curric:statement "In Spanish, all masculine adjectives end in -o."@en ;
  curric:correction """Many masculine adjectives end in -o, but this is not always the case. For
  example, many masculine adjectives of nationality end in -és e.g. 'inglés' and 'francés'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086695Z"^^xsd:dateTime .

oakcurric:misconception-spanish-word-order-identical-english
  a curric:Misconception ;
  curric:statement """Spanish word order is identical to English so I can translate sentences with
  indirect object pronouns literally from one language to another."""@en ;
  curric:correction """Spanish word order is different to English. Indirect object pronouns come
  before the conjugated verb. With 2-verb structures, they can go before the first verb or
  after the infinitive, attached to it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087440Z"^^xsd:dateTime .

oakcurric:misconception-include-much-detail-possible-role
  a curric:Misconception ;
  curric:statement "I should include as much detail as possible in role-play answers."@en ;
  curric:correction """When performing a role-play, answers should contain one verb and be concise.
  Do not add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087553Z"^^xsd:dateTime .

oakcurric:misconception-translating-word-word-effective-strategy
  a curric:Misconception ;
  curric:statement """Translating word-for-word is an effective strategy when tackling translation
  tasks."""@en ;
  curric:correction """Effective translation requires more than direct word-for-word substitution.
  Applying knowledge of grammar and using proofing strategies, such as the VAN check (Verbs,
  Adjectives, Nouns), can significantly improve accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087777Z"^^xsd:dateTime .

oakcurric:misconception-conjugated-form-ir-voy-vas
  a curric:Misconception ;
  curric:statement """Any conjugated form of 'ir' ('voy', 'vas', 'va') can refer to routines or
  future events. For example, 'voy al parque' means 'I'm going to the park' or 'I'm going to
  go to the park'."""@en ;
  curric:correction """We can use 'ir' to talk about routines and to talk about the future, but when
  referring to future intentions, 'ir' needs to be followed by 'a' + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087820Z"^^xsd:dateTime .

oakcurric:misconception-tener-noun-translates-english-noun
  a curric:Misconception ;
  curric:statement "'Tener' + noun always translates in English as 'to have' + noun."@en ;
  curric:correction """The idiomatic expression 'tener' + noun is translated in English as 'to be' +
  adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087848Z"^^xsd:dateTime .

oakcurric:misconception-difference-ning-n-ninguno
  a curric:Misconception ;
  curric:statement "There is no difference between 'ningún' and 'ninguno'."@en ;
  curric:correction """'Ningún' and 'ninguno' look very similar but they are used differently in
  Spanish. 'Ninguno' is a pronoun and it replaces a masculine singular noun. 'Ningún' is an
  indefinite adjective and it comes before a masculine singular noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088441Z"^^xsd:dateTime .

oakcurric:misconception-conjugating-verbs-spanish-need-start
  a curric:Misconception ;
  curric:statement """When conjugating verbs in Spanish, you always need to start by taking off the
  infinitive ending."""@en ;
  curric:correction """Some verb tenses, such as the inflectional future, are formed by adding the
  relevant ending to the infinitive. As such, the infinitive ending is not taken off."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088526Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-en
  a curric:Misconception ;
  curric:statement "The only Spanish translation of 'in' is 'en'."@en ;
  curric:correction """There are several Spanish words for 'in' depending on the context. For
  example, the phrase 'por la tarde' means 'in the afternoon'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088782Z"^^xsd:dateTime .

oakcurric:misconception-affirmative-imperative-same-2nd-person
  a curric:Misconception ;
  curric:statement """The affirmative imperative is the same as 2nd person singular form of the
  verb."""@en ;
  curric:correction """When talking to somebody familiar to you, using 'tú', the affirmative
  imperative is the same as the 3rd person singular form of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088788Z"^^xsd:dateTime .

oakcurric:misconception-meaning-por
  a curric:Misconception ;
  curric:statement "The only meaning of 'por' is 'for'."@en ;
  curric:correction """'Por' can mean several things in Spanish. For example, in addition to 'for',
  it can also mean 'by' and 'in' in certain contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088799Z"^^xsd:dateTime .

oakcurric:misconception-one-word-your-spanish
  a curric:Misconception ;
  curric:statement "There is only one word for 'your' in Spanish."@en ;
  curric:correction """'Tu' means 'your' when addressing one person. 'Vuestro' means 'your' when
  addressing more than one person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088924Z"^^xsd:dateTime .

oakcurric:misconception-necessary-use-subject-pronouns-spanish
  a curric:Misconception ;
  curric:statement "It is always necessary to use subject pronouns before Spanish verbs."@en ;
  curric:correction """It is not usually necessary to use subject pronouns before Spanish verbs as
  the verb ending shows the subject. However, they can be used to emphasise a change of
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089199Z"^^xsd:dateTime .

oakcurric:misconception-their-one-way-say-your
  a curric:Misconception ;
  curric:statement "Their is only one way to say 'your' in Spanish."@en ;
  curric:correction """There are six ways to say 'your' in Spanish depending on the gender and
  number of the following noun, and whether the owner is singular or plural: tu, tus,
  vuestro, vuestra, vuestros and vuestras"""@en ;
  dcterms:modified "2026-06-07T15:30:15.089301Z"^^xsd:dateTime .

oakcurric:misconception-verbs-like-poner-venir-hacer
  a curric:Misconception ;
  curric:statement """Verbs like 'poner', 'venir' and 'hacer' follow the rules of regular -er/-ir
  verbs in the present tense."""@en ;
  curric:correction """Verbs like 'poner', 'venir' and 'hacer' are irregular and add -g- in the 1st
  person singular present (e.g. 'pongo', 'vengo', 'hago', and 'decir' - 'digo')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089307Z"^^xsd:dateTime .

oakcurric:misconception-played-spanish-jug
  a curric:Misconception ;
  curric:statement "'I played' in Spanish is 'jugé'."@en ;
  curric:correction """'I played' in Spanish is 'jugué'. An extra 'u' is added after the 'g' to
  preserve the hard [g] sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089423Z"^^xsd:dateTime .

oakcurric:misconception-relative-pronouns-que-donde-cuando
  a curric:Misconception ;
  curric:statement "The relative pronouns 'que', 'donde' and 'cuando' have a written accent."@en ;
  curric:correction """The relative pronouns 'que' (who/that), 'donde' (where) and 'cuando' (when)
  do not have a written accent. However, the question words 'qué' (what), 'dónde' (where)
  and 'cuándo' (when) do have a written accent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089429Z"^^xsd:dateTime .

oakcurric:misconception-once-youve-learnt-word-once
  a curric:Misconception ;
  curric:statement "Once you've learnt a word once, it will stay in your memory forever."@en ;
  curric:correction """If you learn a word once and don't revisit it, it is unlikely to stay in your
  long-term memory. It is important to revisit prior learning regularly to retain knowledge
  in the long-term memory."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089533Z"^^xsd:dateTime .

oakcurric:misconception-rely-strategies-like-listening-synonyms
  a curric:Misconception ;
  curric:statement """I can rely on strategies like listening out for synonyms and distractors to do
  well in my listening exam."""@en ;
  curric:correction """Strategies like listening out for synonyms and distractors are useful for
  listening exams, but the most important thing is to have a broad vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089581Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-masculine-feminine-forms
  a curric:Misconception ;
  curric:statement "All Spanish adjectives have masculine and feminine forms."@en ;
  curric:correction """Many Spanish adjectives have masculine and feminine forms, but some are
  invariable. Adjectives ending in -e (e.g. 'grave') and in consonants like -l, -r and -n
  (e.g. 'dificil', 'mejor', 'marrón') are invariable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090380Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-pronouns-come-conjugated-verb
  a curric:Misconception ;
  curric:statement "Reflexive pronouns always come before the conjugated verb."@en ;
  curric:correction """Reflexive pronouns can go in two plaes: before the conjugated verb or or
  after the infinitive, attached to it, with 2-verb modal structures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090564Z"^^xsd:dateTime .

oakcurric:misconception-past-participle-used-acabar-de
  a curric:Misconception ;
  curric:statement "A past participle is used after 'acabar de'."@en ;
  curric:correction "An infinitive is used after 'acabar de'."@en ;
  dcterms:modified "2026-06-07T15:30:15.090626Z"^^xsd:dateTime .

oakcurric:misconception-use-para-que-subjunctive-express
  a curric:Misconception ;
  curric:statement "We always use 'para que' + subjunctive to express intentions in Spanish."@en ;
  curric:correction """We only use 'para que' + subjunctive to express intentions when the subject
  of the 2nd verb in the sentence is different from the first. Where the subject is the same
  in the whole sentence, express intentions with 'para' + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090631Z"^^xsd:dateTime .

oakcurric:misconception-much-prepare-listening-exam
  a curric:Misconception ;
  curric:statement "There is not much I can do to prepare for the listening exam."@en ;
  curric:correction """You can prepare for the listening exam by revising vocabulary and being ready
  to listen out for synoynms and distractors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091034Z"^^xsd:dateTime .

oakcurric:misconception-me-means-me-my-te
  a curric:Misconception ;
  curric:statement "'Me' means 'to me' and 'my', and 'te' means 'to you' and 'your'."@en ;
  curric:correction """'Me' and 'te' look very similar to the possessive adjectives 'mi' and 'tu',
  but their meanings are different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091425Z"^^xsd:dateTime .

oakcurric:misconception-acceptable-give-short-answers-conversation
  a curric:Misconception ;
  curric:statement """It is acceptable to only give short answers in the conversation element of the
  speaking exam."""@en ;
  curric:correction """Students should focus on giving answers in conversation that include at least
  three verb clauses. They should also regularly practise developing their answers with
  different verb tenses, subjects, opinions and reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091715Z"^^xsd:dateTime .

oakcurric:misconception-translates-es-haciendo-spanish
  a curric:Misconception ;
  curric:statement "'She, he is doing' translates as 'es haciendo' in Spanish."@en ;
  curric:correction """'She, he is doing' is 'está haciendo'. To form the present continuous, use
  'estar' and a verb in the present participle (-ando, -iendo)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091759Z"^^xsd:dateTime .

oakcurric:misconception-possible-describe-photo-without-needing
  a curric:Misconception ;
  curric:statement "It is possible to describe a photo without needing to use verbs."@en ;
  curric:correction """It is necessary to use full sentences to successfully describe a photo.
  Sentences always include a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092393Z"^^xsd:dateTime .

oakcurric:misconception-present-participles-follow-regular-rules
  a curric:Misconception ;
  curric:statement """All present participles follow regular rules and there are no spelling
  exceptions."""@en ;
  curric:correction """Verbs whose stems end in a vowel ('leer', 'construir') have a i->y spelling
  change when in the past participle ending."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092497Z"^^xsd:dateTime .

oakcurric:misconception-singular-persons-ar-er-ir
  a curric:Misconception ;
  curric:statement """All the singular persons of -ar, -er, and -ir verbs in the preterite have an
  accent."""@en ;
  curric:correction """Only the 'I' and 'she, he, it' forms have an accent. For -ar verbs, the
  endings are -é and -ó; for -er and -ir verbs the endings are -í and -ió."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093003Z"^^xsd:dateTime .

oakcurric:misconception-conversation-answers-kept-short-simple
  a curric:Misconception ;
  curric:statement "Conversation answers should be kept as short and simple as possible."@en ;
  curric:correction """It is important to develop conversation answers to showcase a range of
  vocabulary and grammar. This can be achieved by using adverbs to add more detail and by
  incorporating a range of grammatical persons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094099Z"^^xsd:dateTime .

oakcurric:misconception-way-mean-singular-spanish-t
  a curric:Misconception ;
  curric:statement "The only way to mean 'you (singular)' in Spanish is 'tú'."@en ;
  curric:correction """There are two ways to mean 'you (singular)' in Spanish. Use 'tú' to mean
  'you' in an informal context, and 'usted' to mean 'you' in a formal context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098592Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-agree-gender-number
  a curric:Misconception ;
  curric:statement "All Spanish adjectives agree in gender and number with the noun."@en ;
  curric:correction """Most adjectives in Spanish agree in gender and number with the noun. However,
  adjectives ending in -e only agree with the noun in number."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106717Z"^^xsd:dateTime .

oakcurric:misconception-ingl-s-adjective
  a curric:Misconception ;
  curric:statement "'inglés' can only be an adjective."@en ;
  curric:correction """'inglés' can be an adjective, as in 'la comida inglesa' (English food), or a
  noun, as in 'el inglés' (the English person (m)). The process of making a noun in this way
  from an adjective or verb is called nominalisation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107526Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-such-me-gustar
  a curric:Misconception ;
  curric:statement """Modal verbs such as 'me gustaría' and 'quisiera' can be followed by simple
  present verbs."""@en ;
  curric:correction """Modal verbs such as 'me gustaría' and 'quisiera' cannot be followed by simple
  present verbs. To say what you would like to do, use a modal verb followed by an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107532Z"^^xsd:dateTime .

oakcurric:misconception-spanish-questions-same-punctuation-english
  a curric:Misconception ;
  curric:statement "Spanish questions have the same punctuation as in English."@en ;
  curric:correction "Spanish questions begin with an upside down question mark (¿)."@en ;
  dcterms:modified "2026-06-07T15:30:15.107931Z"^^xsd:dateTime .

oakcurric:misconception-one-word-answers-sufficient-role
  a curric:Misconception ;
  curric:statement "One-word answers are sufficient in the role play."@en ;
  curric:correction """It's important to say a few words or a short phrase/sentence in response to
  each prompt/bullet rather than one-word answers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108330Z"^^xsd:dateTime .

oakcurric:misconception-give-natural-translation-dar
  a curric:Misconception ;
  curric:statement "'To give' is always a natural translation of 'dar'."@en ;
  curric:correction """When 'dar' appears with a noun of feeling or emotion, it is more natural to
  use 'to be' + adjective in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108530Z"^^xsd:dateTime .

oakcurric:misconception-completing-photo-description-spanish-stick
  a curric:Misconception ;
  curric:statement """When completing a photo description in Spanish, I should stick to short,
  simple sentences."""@en ;
  curric:correction """When describing photos in Spanish, it is important to plan extended sentences
  to talk for a prolonged period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109801Z"^^xsd:dateTime .

oakcurric:misconception-1st-person-singular-form-influir
  a curric:Misconception ;
  curric:statement "The 1st person singular form of 'influir' is 'influo'."@en ;
  curric:correction """The verb 'influir' does not follow the normal pattern of -ir verbs. Verbs
  ending in -uir gain a 'y' in persons 1,2,3 and 6 to aid pronunciation. As such, the 1st
  person singular forms of 'influir' is 'influyo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113750Z"^^xsd:dateTime .

oakcurric:misconception-verbs-emotion-like-gustar-encantar
  a curric:Misconception ;
  curric:statement """Verbs of emotion like 'gustar', 'encantar', 'dar', 'molestar', etc. are always
  followed by the infinitive."""@en ;
  curric:correction """Use a verb of emotion + infinitive to react to your own actions. Use a verb
  of emotion + 'que' + subjunctive to react to someone else’s. Both forms often talk about
  emotions, but the change of subject triggers the use of subjunctive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115174Z"^^xsd:dateTime .

oakcurric:misconception-present-participle-leer-leiendo
  a curric:Misconception ;
  curric:statement "The present participle of 'leer' is 'leiendo'."@en ;
  curric:correction """As the stem of 'leer' ends in a vowel, it has a spelling change in the
  present participle, forming 'leyendo'. This is the same with other verbs with a stem
  ending in a vowel e.g. 'constuyendo' from the verb 'construir'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120525Z"^^xsd:dateTime .

oakcurric:misconception-use-border-short-pieces-writing
  a curric:Misconception ;
  curric:statement "I can only use BORDER for short pieces of writing."@en ;
  curric:correction """BORDER is also a very useful strategy for extended pieces of writing. Simply
  apply it to each paragraph separately. This will help you respond clearly and completely
  to each bullet point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120531Z"^^xsd:dateTime .

oakcurric:misconception-translating-spanish-english-translate-word
  a curric:Misconception ;
  curric:statement """When translating from Spanish to English, I should translate each word in the
  order it appears in the Spanish sentence."""@en ;
  curric:correction """When translating from Spanish to English, make sure your translations sound
  natural in English. This may mean you need to change the word order from the original
  Spanish sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120646Z"^^xsd:dateTime .

oakcurric:misconception-say-am-older-work-hospital
  a curric:Misconception ;
  curric:statement """To say 'when I am older I will work in a hospital', say 'cuando soy mayor
  trabajaré en un hospital'."""@en ;
  curric:correction """To say 'when I am older I will work in a hospital', say 'cuando sea mayor
  trabajaré en un hospital'. After 'cuando', use the subjunctive to talk about an event that
  hasn't yet happened."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120665Z"^^xsd:dateTime .

oakcurric:misconception-keep-my-answers-short-conversation
  a curric:Misconception ;
  curric:statement """I should keep my answers short in a conversation and avoid extending my
  sentences."""@en ;
  curric:correction """In a conversation, you should extend and develop your sentences to include at
  least three verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120747Z"^^xsd:dateTime .

oakcurric:misconception-give-order-command-t-informal
  a curric:Misconception ;
  curric:statement """To give an order or command to 'tú' (you, informal), you should use the 2nd
  person singular form of the verb."""@en ;
  curric:correction """When talking to somebody familiar to you ('tú') with the affirmative
  imperative of an -ar verb, use the ending -a, and for an -er or -ir verb, use the ending
  -e. Irregular imperative verbs include: 'sé', 've', 'ten', 'ven', 'haz', 'di', 'pon',
  'sal'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120897Z"^^xsd:dateTime .

oakcurric:misconception-stress-me-gustar-falls-second
  a curric:Misconception ;
  curric:statement "The stress in 'me gustaría' falls on the second syllable 'ta'."@en ;
  curric:correction """The stress in 'me gustaría' falls on the 'í'. We can tell this because it has
  an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.121082Z"^^xsd:dateTime .

oakcurric:misconception-much-prepare-spanish-reading-exams
  a curric:Misconception ;
  curric:statement "There is not much I can do to prepare for Spanish reading exams."@en ;
  curric:correction """You can prepare for Spanish reading exams by revising vocabulary to make sure
  you can understand as many words as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:15.121123Z"^^xsd:dateTime .

oakcurric:misconception-spanish-auxiliary-verb-sounds-like
  a curric:Misconception ;
  curric:statement "In Spanish, the auxiliary verb 'he' sounds like the English 'he'."@en ;
  curric:correction """In Spanish, the auxiliary verb 'he' sounds different to the English 'he'. It
  has a silent 'h' and 'e' is pronounced as in 'elefante'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122740Z"^^xsd:dateTime .

oakcurric:misconception-need-use-subject-pronouns-spanish
  a curric:Misconception ;
  curric:statement """I always need to use subject pronouns in Spanish to show who is doing an
  action."""@en ;
  curric:correction """It is not usually necessary to use subject pronouns in Spanish to show who is
  doing an action. The subject of an action is usually shown by the verb ending."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122793Z"^^xsd:dateTime .

oakcurric:misconception-use-my-knowledge-sound-symbol
  a curric:Misconception ;
  curric:statement """I can use my knowledge of sound-symbol correspondences (SSCs) to successfully
  complete a read-aloud task."""@en ;
  curric:correction """Simply re-reading without purpose doesn't necessarily lead to better
  comprehension. Strategies such as reading through the text and questions, using each
  question to find the relevant part of the text, avoiding distractors, etc., are more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122844Z"^^xsd:dateTime .

oakcurric:misconception-translated-tengo
  a curric:Misconception ;
  curric:statement "'I have' is always translated as 'tengo'."@en ;
  curric:correction """When 'have' means 'to possess something' e.g. 'I have a car', use 'tengo' -
  'tengo un coche'. When 'have' is part of the perfect tense, to say you have done
  something, use the verb 'haber' e.g. 'I have played' - 'he jugado'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122864Z"^^xsd:dateTime .

oakcurric:misconception-keep-my-answers-follow-questions
  a curric:Misconception ;
  curric:statement """I should keep my answers to the follow-up questions after the photo
  description short without extra detail."""@en ;
  curric:correction """You need to try and develop your answers to the follow-up questions with at
  least 3 verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123082Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-like-quiero-followed
  a curric:Misconception ;
  curric:statement """Modal verbs like 'quiero' can be followed with a 1st person singular verb like
  'compro'."""@en ;
  curric:correction """Modal verbs like 'quiero' must be followed with an infinitive verb like
  'comprar'. For example, 'I want to buy' in Spanish is 'quiero comprar'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123131Z"^^xsd:dateTime .

oakcurric:misconception-times-read-text-better-ill
  a curric:Misconception ;
  curric:statement "The more times I read the text, the better I’ll understand it."@en ;
  curric:correction """Simply re-reading without purpose doesn’t necessarily lead to better
  comprehension. Strategies such as reading through the text and questions, using each
  question to find the relevant part of the text, avoiding distractors, etc., are more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123327Z"^^xsd:dateTime .

oakcurric:misconception-translation-visited-spanish-visit
  a curric:Misconception ;
  curric:statement "The only translation of 'I visited' in Spanish is 'visité'."@en ;
  curric:correction """In Spanish, 'visité' means 'I visited' for a single, completed action in the
  past. You could also, however, use 'visitaba' to mean 'I visited' for an action that
  happened repeatedly over a period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123494Z"^^xsd:dateTime .

oakcurric:misconception-translate-english-word-individually-translating
  a curric:Misconception ;
  curric:statement """I should translate each English word individually when translating into
  Spanish."""@en ;
  curric:correction """It is important to read the whole sentence first and translate chunks of
  language rather than each individual word."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123877Z"^^xsd:dateTime .

oakcurric:misconception-describe-past-use-preterite-imperfect
  a curric:Misconception ;
  curric:statement """To describe the past we can use both the preterite and the imperfect
  interchangeably."""@en ;
  curric:correction """We use the imperfect to set the scene, to give background information and to
  describe onling states. And we use the preterite to express completed actions that move
  the plot forward."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125120Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-pronouns-appear-conjugated-verb
  a curric:Misconception ;
  curric:statement "Reflexive pronouns appear after a conjugated verb."@en ;
  curric:correction "The reflexive pronoun 'se' appears before a conjugated verb in any tense."@en ;
  dcterms:modified "2026-06-07T15:30:15.125445Z"^^xsd:dateTime .

oakcurric:misconception-translate-best-thing-word-word
  a curric:Misconception ;
  curric:statement "I can translate 'the best thing was' word-for-word in Spanish."@en ;
  curric:correction """In Spanish, we use the structure 'lo' + adjective, so we do not include the
  word 'thing', e.g. 'lo mejor fue el final' translates into English as 'the best thing was
  the ending'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125694Z"^^xsd:dateTime .

oakcurric:misconception-final-s-sus-refers-one
  a curric:Misconception ;
  curric:statement "The final ‘-s’ in ‘sus’ refers to more than one person."@en ;
  curric:correction "The final ‘s’ refers to a plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:15.127992Z"^^xsd:dateTime .

oakcurric:misconception-english-double-negatives-structures-spanish
  a curric:Misconception ;
  curric:statement """As in English, double negatives structures in Spanish are not considered
  acceptable in formal language."""@en ;
  curric:correction """Double negative structures are commonly used in Spanish and are considered
  acceptable in formal language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129941Z"^^xsd:dateTime .

oakcurric:misconception-spanish-repeat-language-used-question
  a curric:Misconception ;
  curric:statement """In Spanish, you can always repeat language used in the question to form your
  answer."""@en ;
  curric:correction """If 2nd person language is used in a Spanish question, this must be converted
  into 1st person language for the answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131040Z"^^xsd:dateTime .

oakcurric:misconception-que-cue-pronounced-same
  a curric:Misconception ;
  curric:statement "[que] and [cue] are pronounced the same."@en ;
  curric:correction """[que] is pronounced as in the word 'porque', and [cue] as in the word
  'cuerpo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133134Z"^^xsd:dateTime .

oakcurric:misconception-cuando-need-subjunctive-forms-tenga
  a curric:Misconception ;
  curric:statement """After ‘cuando’ I always need the subjunctive forms 'tenga', 'tengas', 'tenga'
  to mean ‘I have', 'you have', 'she, he, it has’."""@en ;
  curric:correction """After ‘cuando’ we use the subjunctive forms only when the action is not yet
  real, or is uncertain. When the action happens regularly, we use the indicative forms
  ‘tengo’, 'tienes', 'tiene’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138324Z"^^xsd:dateTime .

oakcurric:misconception-translation-fue
  a curric:Misconception ;
  curric:statement "The only translation of 'fue' is 'she, he, it was'."@en ;
  curric:correction """'Fue' can mean 'she, he, it was' or 'she, he, it went' depending on the
  context. The verbs 'ser' and 'ir' are identical in the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140045Z"^^xsd:dateTime .

oakcurric:misconception-lo-que-refer-specific-noun
  a curric:Misconception ;
  curric:statement "'Lo que' can refer to a specific noun or a person."@en ;
  curric:correction """'Lo que' means 'what' or 'the thing that'. It refers to a general idea,
  rather than a specific noun or person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141149Z"^^xsd:dateTime .

oakcurric:misconception-era-means-used
  a curric:Misconception ;
  curric:statement "'Era' only means 'she, he, it was' or 'she, he, it used to be'."@en ;
  curric:correction """'Era' also means 'I was' or 'I used to be'. Look for the pronouns 'yo', 'él'
  and 'ella' to understand the meaning of 'era' in context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142104Z"^^xsd:dateTime .

oakcurric:misconception-first-thing-hear-correctly-understand
  a curric:Misconception ;
  curric:statement """The first thing I hear correctly and understand is usually the answer to a
  listening comprehension question."""@en ;
  curric:correction """It is important to listen to the whole text before answering a listening
  comprehension question, as information may not be presented in an obvious order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142554Z"^^xsd:dateTime .

oakcurric:misconception-letter-r-pronounced-same-spanish
  a curric:Misconception ;
  curric:statement "The letter 'r' is always pronounced the same in Spanish."@en ;
  curric:correction """In Spanish, 'r' is pronounced differently depending on its position within a
  word. 'r' in the middle or at the end of a word is pronounced as in 'pero', whereas 'r' at
  the beginning of a word and 'rr' are pronounced as in 'perro'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142561Z"^^xsd:dateTime .

oakcurric:misconception-quiero-espero-deseo-prefiero-followed
  a curric:Misconception ;
  curric:statement "'Quiero', espero', 'deseo', 'prefiero' are always followed by infinitives."@en ;
  curric:correction """Use 'quiero' + infinitive when you want to do something yourself. Use
  'quiero' + 'que' + subjunctive when you want someone else to do something. Both forms
  often talk about the future, but the change of subject triggers the use of subjunctive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142599Z"^^xsd:dateTime .

oakcurric:misconception-word-spanish
  a curric:Misconception ;
  curric:statement "There is always a word for 'do' or 'did' in Spanish."@en ;
  curric:correction "There is no word for 'do' or 'did' in Spanish questions."@en ;
  dcterms:modified "2026-06-07T15:30:15.149276Z"^^xsd:dateTime .

oakcurric:misconception-talking-weather-translate-directly-english
  a curric:Misconception ;
  curric:statement """When talking about the weather, I can translate directly from English (e.g.
  'it's cold')."""@en ;
  curric:correction """It's important to remember that Spanish uses the verb 'hacer' when talking
  about the weather. For example, 'it's cold' translates as 'hace frío'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149917Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-placed-noun
  a curric:Misconception ;
  curric:statement "In Spanish, all adjectives must be placed after the noun."@en ;
  curric:correction """The position of adjectives in Spanish can be flexible. When adjectives follow
  nouns, this communicates a literal, objective description. If an adjective is placed
  before a noun, this can communicate a figurative, subjective description."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150355Z"^^xsd:dateTime .

oakcurric:misconception-english-indirect-object-pronouns-follow
  a curric:Misconception ;
  curric:statement "As in English, indirect object pronouns follow the verb in Spanish."@en ;
  curric:correction """In 1-verb constructions, indirect object pronouns precede the verb in
  Spanish. This word order is different to English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150483Z"^^xsd:dateTime .

oakcurric:misconception-responding-conversation-questions-suffice-give
  a curric:Misconception ;
  curric:statement """When responding to conversation questions, it will suffice to give one-word
  answers."""@en ;
  curric:correction """Conversation answers should be consistently developed with 2-3 clauses.
  One-word answers are not enough."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150688Z"^^xsd:dateTime .

oakcurric:misconception-masculine-singular-form-ninguna-ninguno
  a curric:Misconception ;
  curric:statement "The masculine singular form of 'ninguna' is 'ninguno'."@en ;
  curric:correction """When used as an adjective, the masculine singular form of 'ninguna' is
  'ningún'. The word 'ninguno' does, however, exist as a pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150930Z"^^xsd:dateTime .

oakcurric:misconception-factor-understanding-listening-tasks-vocabulary
  a curric:Misconception ;
  curric:statement """The only factor in understanding listening tasks is vocabulary. If I know
  enough words, I don’t need any strategies to comprehend what I hear."""@en ;
  curric:correction """A strong knowledge of high frequency vocabulary is key to unlocking effective
  listening comprehension. However, strategies such as prediction, synonym recognition and
  identifying distractors can also improve listening skills."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150936Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-followed-conjugated-verb
  a curric:Misconception ;
  curric:statement """Modal verbs are followed by a conjugated verb which changes its ending to
  match the person who is speaking."""@en ;
  curric:correction "Modal verbs are followed by the infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:15.151016Z"^^xsd:dateTime .

oakcurric:misconception-correct-spanish-translation-am-hungry
  a curric:Misconception ;
  curric:statement "The correct Spanish translation of 'I am hungry' is 'estoy hambre'."@en ;
  curric:correction """The correct translation of 'I am hungry' is 'tengo hambre'. Sometimes Spanish
  uses ‘tengo’ + noun where the English would be ‘I am’ + adjective. Other examples of this
  structure are ‘tengo frío’ (I am cold) and ‘tengo miedo’ (I am scared)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151565Z"^^xsd:dateTime .

oakcurric:misconception-stem-changing-verbs-like-encontrar
  a curric:Misconception ;
  curric:statement """Stem-changing verbs like 'encontrar' and 'pensar' have a stem change in all
  conjugations of the simple present."""@en ;
  curric:correction """Stem-changing verbs 'encontrar' and 'pensar' have a stem change in persons 1,
  2, 3 and 6 of the simple present. The stem reverts back to the original for persons 4 and
  5."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151571Z"^^xsd:dateTime .

oakcurric:misconception-producing-written-work-spanish-stick
  a curric:Misconception ;
  curric:statement """When producing written work in Spanish, I should stick to short simple
  sentences."""@en ;
  curric:correction """When producing written work in Spanish, you should try to develop and extend
  your sentences to demonstrate grammatical complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151633Z"^^xsd:dateTime .

oakcurric:misconception-mark-first-thing-hear-correct
  a curric:Misconception ;
  curric:statement """I should mark down the first thing I hear as the correct answer when answering
  listening questions."""@en ;
  curric:correction """It is important not to rush, and to listen to the whole text before answering
  a listening question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152008Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-past-participle-e
  a curric:Misconception ;
  curric:statement """The Spanish translation of 'I have' + past participle, e.g. 'I have listened',
  is 'tengo' + past participle, e.g. 'tengo escuchado'."""@en ;
  curric:correction """The Spanish translation of 'I have listened' is 'he escuchado'. In Spanish,
  the auxiliary verb used in the formation of the perfect tense is 'haber', not 'tener'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152019Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-er-ir-verbs
  a curric:Misconception ;
  curric:statement """As in the present tense, -er and -ir verbs have different endings in the
  preterite tense."""@en ;
  curric:correction "Verbs ending in -er and -ir have the same endings in the preterite tense."@en ;
  dcterms:modified "2026-06-07T15:30:15.152219Z"^^xsd:dateTime .

oakcurric:misconception-inflectional-future-communicates-going-happen
  a curric:Misconception ;
  curric:statement "The inflectional future communicates what is 'going to' happen."@en ;
  curric:correction """The inflectional future communicates what 'will' happen. 'Voy a + infinitive'
  communicates what is 'going to' happen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152885Z"^^xsd:dateTime .

oakcurric:misconception-adjective-used-comparative-superlative-structure
  a curric:Misconception ;
  curric:statement """The adjective used in a comparative or superlative structure does not need to
  agree with any noun."""@en ;
  curric:correction """The adjective used in a comparative or superlative structure must agree with
  the preceding noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152890Z"^^xsd:dateTime .

oakcurric:misconception-cuando-followed-subjunctive
  a curric:Misconception ;
  curric:statement "'Cuando' is always followed by the subjunctive."@en ;
  curric:correction """'Cuando' + subjunctive is used for future actions, while 'cuando' + present
  is used for everyday present actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154510Z"^^xsd:dateTime .

oakcurric:misconception-verb-hacer-follows-same-rule
  a curric:Misconception ;
  curric:statement """The verb 'hacer' follows the same rule as 'poner' for forming the 1st person
  singular of the present tense."""@en ;
  curric:correction """The letter 'g' replaces the 'c' in hacer in the first person singular of the
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155371Z"^^xsd:dateTime .

oakcurric:misconception-spanish-official-language-spain
  a curric:Misconception ;
  curric:statement "Spanish is the official language only in Spain."@en ;
  curric:correction """Spanish is the official language in 21 countries across 3 different
  continents."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155385Z"^^xsd:dateTime .

oakcurric:misconception-inflectional-future-verbs-endings-added
  a curric:Misconception ;
  curric:statement """In the inflectional future with all verbs, the endings are added to the
  infinitive and they are the same for -ar, -er and -ir verbs."""@en ;
  curric:correction """A small number of verbs are irregular in the inflectional future and have
  irregular future stems."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155399Z"^^xsd:dateTime .

oakcurric:misconception-translated-m-s-que
  a curric:Misconception ;
  curric:statement "'More than' is always translated as 'más que'."@en ;
  curric:correction """'More than' can be translated as 'más que' or 'más de'. 'Más de' is followed
  by numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155411Z"^^xsd:dateTime .

oakcurric:misconception-add-s-spanish-noun-make
  a curric:Misconception ;
  curric:statement "Add an -s to any Spanish noun to make it plural."@en ;
  curric:correction """Add an -s to Spanish nouns ending in a vowel to make them plural. Add -es to
  Spanish nouns ending in a consonant to make them plural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156754Z"^^xsd:dateTime .

oakcurric:misconception-cognates-words-look-sound-like
  a curric:Misconception ;
  curric:statement "Cognates are words that look and sound like English."@en ;
  curric:correction """Cognates may look very similar to English but sound quite different so
  attention must be paid to pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156760Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-spanish-ever-appear-noun
  a curric:Misconception ;
  curric:statement "Adjectives in Spanish only ever appear after the noun."@en ;
  curric:correction """Most adjectives in Spanish appear after the noun. However, some are used
  before it. These are called prenominal adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156765Z"^^xsd:dateTime .

oakcurric:misconception-tell-somebody-familiar-something-use
  a curric:Misconception ;
  curric:statement """To tell somebody who is familiar to you to do something, use the 2nd person
  singular form of the verb."""@en ;
  curric:correction """To tell somebody who is familiar to you to do something, use the affirmative
  imperative. For -ar verbs this ends in -a, and for -er/-ir verbs this ends in -e."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157404Z"^^xsd:dateTime .

oakcurric:misconception-form-plural-imperative-reflexive-verb
  a curric:Misconception ;
  curric:statement """To form the plural imperative of a reflexive verb, add the pronoun -os to a
  plural imperative verb."""@en ;
  curric:correction """To form the plural imperative of a reflexive verb, drop the final -d and add
  the pronoun -os to a plural imperative verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157411Z"^^xsd:dateTime .

oakcurric:misconception-eso-esto-appear-noun
  a curric:Misconception ;
  curric:statement "'Eso' and 'esto' can appear before a noun."@en ;
  curric:correction """'Eso' and 'esto' cannot appear before a noun because they are pronouns.
  Instead it is necessary to use 'este' and 'esta' (to mean 'this') and 'ese' and 'esa' (to
  mean 'that')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158040Z"^^xsd:dateTime .

oakcurric:misconception-el-que-el-cual-completely
  a curric:Misconception ;
  curric:statement "'El que' and 'el cual' are completely interchangeable."@en ;
  curric:correction "'El cual' tends to appear in more formal contexts than 'el que'."@en ;
  dcterms:modified "2026-06-07T15:30:15.158057Z"^^xsd:dateTime .

oakcurric:misconception-way-mean-sg-spanish-t
  a curric:Misconception ;
  curric:statement "The only way to mean 'you (sg)' in Spanish is 'tú'."@en ;
  curric:correction """There are two ways to mean 'you (sg)' in Spanish. Use 'tú' to mean 'you' in
  an informal context, and 'usted' to mean 'you' in a formal context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158278Z"^^xsd:dateTime .

oakcurric:misconception-word-ends-preterite-tense
  a curric:Misconception ;
  curric:statement "Any word that ends in -é is in the preterite tense."@en ;
  curric:correction """Some words that end in -é are in the inflectional future. In this case, the
  -é ending is added to the infinitive - 'trabajaré' (I will work) - rather than the stem,
  as in the preterite - 'trabajé' (I worked)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158284Z"^^xsd:dateTime .

oakcurric:misconception-developing-conversation-future-travel-plans
  a curric:Misconception ;
  curric:statement """When developing a conversation about future travel plans, it is important to
  consistently use the future time frame in answers."""@en ;
  curric:correction """Whilst it is important to be able to refer to the future confidently, it is
  also helpful to add in different time frames to give more detail as well as opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158880Z"^^xsd:dateTime .

oakcurric:misconception-spanish-sentences-start-subject
  a curric:Misconception ;
  curric:statement "Spanish sentences always start with the subject."@en ;
  curric:correction """Spanish sentences can start with the subject or with the indirect object.
  This is important when using indirect object pronouns as they can come before the verb
  (e.g. 'me interesan las matemáticas')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159581Z"^^xsd:dateTime .

oakcurric:misconception-best-stick-short-one-word
  a curric:Misconception ;
  curric:statement """It is best to stick to short, one-word answers when responding to role-play
  prompts."""@en ;
  curric:correction """It is advisable to include at least one verb in each answer given as part of
  a role-play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159630Z"^^xsd:dateTime .

oakcurric:misconception-ending-used-er-ir-verbs
  a curric:Misconception ;
  curric:statement """The ending -ió is always used with -er and -ir verbs to refer to she, he or it
  in the preterite tense."""@en ;
  curric:correction """For -er and -ir verbs whose stem ends in a vowel, add -yó to refer to 'he',
  'she' or 'it in the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161026Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-ive-broken-my
  a curric:Misconception ;
  curric:statement """The Spanish translation of 'I've broken my arm' is 'me he roto mi brazo'. You
  use the possessive adjective for body parts."""@en ;
  curric:correction """When referring to body parts, Spanish speakers replace possessive adjectives
  with definite articles, e.g. 'me he roto el brazo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161404Z"^^xsd:dateTime .

oakcurric:misconception-indirect-object-pronouns-same-emphatic
  a curric:Misconception ;
  curric:statement "Indirect object pronouns are the same as emphatic pronouns."@en ;
  curric:correction """Indirect object pronouns refer to a person or thing indirectly affected by
  the verb and go before 'interesar'-type verbs, while emphatic pronouns are used for
  emphasis after prepositions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161409Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-played-football-monday
  a curric:Misconception ;
  curric:statement """The Spanish translation of 'I played football on Monday' is 'jugué al fútbol
  en lunes'."""@en ;
  curric:correction """Rather then the preposition 'en', Spanish uses the definite article before
  days of the week. As such, the Spanish translation of 'I played football on Monday' is
  'jugué al fútbol el lunes'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161415Z"^^xsd:dateTime .

oakcurric:misconception-describing-photos-speech-writing-one
  a curric:Misconception ;
  curric:statement """When describing photos in speech and writing, a one-word answer will
  suffice."""@en ;
  curric:correction """When describing photos in Spanish, it is important to use full sentences and
  convey a range of information."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161523Z"^^xsd:dateTime .

oakcurric:misconception-completed-events-actions-past-use
  a curric:Misconception ;
  curric:statement """For completed events and actions in the past I can use either the preterite or
  the imperfect."""@en ;
  curric:correction """The imperfect is used to set the scene, give background information and for
  repeated actions in the past and the preterite to say what happened, talk about completed
  events and actions in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161829Z"^^xsd:dateTime .

oakcurric:misconception-participles-spanish-end-ado-ido
  a curric:Misconception ;
  curric:statement "All participles in Spanish end in -ado or -ido."@en ;
  curric:correction """Regular verbs do follow this pattern, but irregular ones do not. Some
  irregular verbs are: 'decir' - 'dicho', 'morir' - 'muerto', 'romper' - 'roto', 'volver' -
  'vuelto', 'descubrir' - 'descubierto', 'cubrir' - 'cubierto'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161835Z"^^xsd:dateTime .

oakcurric:misconception-hacer-translates-make-making
  a curric:Misconception ;
  curric:statement "'Hacer' only translates as 'to do, make; doing, making'."@en ;
  curric:correction """'Hacer' can be used to talk about the weather and therefore we can't always
  translate phrases with 'hacer' literally. 'Hace sol' translates as 'it's sunny' and 'hizo
  calor' translates as 'it was hot'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162180Z"^^xsd:dateTime .

oakcurric:misconception-am-reading-read-translate-leo
  a curric:Misconception ;
  curric:statement "'I am reading' and 'I read' both translate as 'leo'."@en ;
  curric:correction """'I am reading' is the present continuous and therefore it translates as
  'estoy leyendo'. 'I read' is the present simple and it translates as 'leo'. We need to use
  context and time markers to know when to use each."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162369Z"^^xsd:dateTime .

oakcurric:misconception-describe-photo-using-single-words
  a curric:Misconception ;
  curric:statement "I can describe a photo using single words."@en ;
  curric:correction """When describing photos in Spanish, it is important to use full sentences with
  verbs. To make the description even more interesting and complex add justifications and
  contrasts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162587Z"^^xsd:dateTime .

oakcurric:misconception-reading-re-reading-text-effective
  a curric:Misconception ;
  curric:statement """Reading and re-reading a text is always an effective way to read for
  understanding and get the right answers to comprehension questions."""@en ;
  curric:correction """Simply reading and re-reading a text isn't always the most effective way to
  read for understanding. Using active reading strategies such as reading the title and
  reading and annotating the questions can boost comprehension and accuracy in responses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162593Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-tener
  a curric:Misconception ;
  curric:statement "The Spanish translation of 'I will have' is 'teneré'."@en ;
  curric:correction """The verb 'tener' is irregular in the inflectional future. The Spanish
  translation of 'I will have' is 'tendré'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162598Z"^^xsd:dateTime .

oakcurric:misconception-subjunctive-matter-speakers-attitude-am
  a curric:Misconception ;
  curric:statement """The subjunctive is a matter of the speaker's attitude so when I am the speaker
  I can always choose whether to use the subjunctive or not."""@en ;
  curric:correction """Certain situations and structures always require the subjunctive: 'cuando' +
  subjunctive + future tense for events that have not yet happened; 'es' + adjective + que
  for subjective points of view; verbs of wishing that someone else does something."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162604Z"^^xsd:dateTime .

oakcurric:misconception-estaba-means-imperfect
  a curric:Misconception ;
  curric:statement "'Estaba' only means 'I was' in the imperfect."@en ;
  curric:correction "'Estaba' means 'I was' but also 'she, he, it was' in the imperfect."@en ;
  dcterms:modified "2026-06-07T15:30:15.164374Z"^^xsd:dateTime .

oakcurric:misconception-verbs-different-subjects-objects
  a curric:Misconception ;
  curric:statement "Verbs must always have different subjects and objects."@en ;
  curric:correction """Verbs do not always have different subjects and objects. For example,
  reflexive verbs have the same subject and object."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164925Z"^^xsd:dateTime .

oakcurric:misconception-spanish-ssc-qui-pronounced-queen
  a curric:Misconception ;
  curric:statement "In Spanish, the SSC [qui] is pronounced as in 'queen'."@en ;
  curric:correction "In Spanish, the SSC [qui] is pronounced as in 'equipo'."@en ;
  dcterms:modified "2026-06-07T15:30:15.164931Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronouns-used-verb-indicate
  a curric:Misconception ;
  curric:statement "Subject pronouns are always used with a verb to indicate the subject."@en ;
  curric:correction """Subject pronouns are not always used with a verb. Verb endings alone often
  tell us the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164937Z"^^xsd:dateTime .

oakcurric:misconception-spanish-t-tu-mean-same
  a curric:Misconception ;
  curric:statement "In Spanish, 'tú' and 'tu' mean the same thing."@en ;
  curric:correction """In Spanish, 'tú' and 'tu' do not mean the same thing. 'Tú' is a subject
  pronoun meaning 'you' (informal), whereas 'tu' is a possessive adjective meaning 'your'
  (informal)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164942Z"^^xsd:dateTime .

oakcurric:misconception-translation-best-spanish-el-mejor
  a curric:Misconception ;
  curric:statement "The only translation of 'the best' in Spanish is 'el mejor'."@en ;
  curric:correction """The superlative 'el mejor' must agree with the noun it describes in number
  and gender. Its other forms are 'la mejor', 'los mejores' and 'las mejores'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164951Z"^^xsd:dateTime .

oakcurric:misconception-spanish-masculine-nouns-end-o
  a curric:Misconception ;
  curric:statement """In Spanish, all masculine nouns end in -o and all feminine nouns end
  in -a."""@en ;
  curric:correction """This is often the case, but it is not a blanket rule. For example, words
  ending in -ista, -ente and -ante can be masculine or feminine depending on the context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165439Z"^^xsd:dateTime .

oakcurric:misconception-answering-questions-use-verb-question
  a curric:Misconception ;
  curric:statement """When answering questions, I can use the verb in the question to start my
  answer."""@en ;
  curric:correction """You can start your answer using the question verb but it's important to not
  copy the question word-for-word. If questions use 2nd person verbs, you need to change
  them to 1st person, changing 'you' verbs into 'I' or 'we' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165445Z"^^xsd:dateTime .

oakcurric:misconception-sufficient-give-one-word-answers
  a curric:Misconception ;
  curric:statement "It is sufficient to give one-word answers in a role-play."@en ;
  curric:correction """In a role-play pupils need to answer each question with a short phrase or
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165453Z"^^xsd:dateTime .

oakcurric:misconception-spanish-g-pronounced-gol
  a curric:Misconception ;
  curric:statement "In Spanish, [g] is always pronounced as in 'gol'."@en ;
  curric:correction """The pronunciation of [g] varies depending on the vowels that follow. [g]
  followed by [a], [o] or [u] is hard, whereas [g] followed by [i] or [e] is soft."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165504Z"^^xsd:dateTime .

oakcurric:misconception-way-saying-played-spanish-jugu
  a curric:Misconception ;
  curric:statement "The only way of saying 'I played' in Spanish is 'jugué'."@en ;
  curric:correction """'I played' could be translated as 'jugué' or 'jugaba'. The preterite verb
  'jugué' implies a single, completed action in the past, whereas the imperfect verb
  'jugaba' implies a habitual action in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165765Z"^^xsd:dateTime .

oakcurric:misconception-singular-imperative-form-2nd-person
  a curric:Misconception ;
  curric:statement """The singular imperative form for 2nd person 'tú' is the same as the present
  tense ending: -as or -es."""@en ;
  curric:correction """The singular imperative form for 2nd person 'tú' is the same as the 3rd
  person present tense - the ending is -a for -ar verbs, and -e for -er and -ir verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165774Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-spanish-end-ado
  a curric:Misconception ;
  curric:statement """All past participles in Spanish end in -ado (-ar verbs) or -ido (-er/-ir
  verbs)."""@en ;
  curric:correction """Although most Spanish past participles do follow these regular patterns, some
  verbs have irregular past participles which just need to be learnt, e.g. 'escrito'
  ('written'), 'visto' ('seen'), 'hecho' ('done'), 'dicho' ('said')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165779Z"^^xsd:dateTime .

oakcurric:misconception-form-inflectional-future-tense-take
  a curric:Misconception ;
  curric:statement """To form the inflectional future tense, take off the infinitive ending before
  adding -é, -ás, -á."""@en ;
  curric:correction """To form the inflectional future tense, add the endings -é, -ás, -á, to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165941Z"^^xsd:dateTime .

oakcurric:misconception-long-get-gist-meaning-spanish
  a curric:Misconception ;
  curric:statement """As long as I get the gist of the meaning of a Spanish question, I can answer
  successfully."""@en ;
  curric:correction """In conversation it is important to listen carefully to the tense of questions
  before answering. Otherwise your answers might not be relevant. For example, 'What did you
  do after school yesterday?' 'I usually do my homework.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.165947Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-sunny-es-sol
  a curric:Misconception ;
  curric:statement "The Spanish translation of 'it is sunny' is 'es sol'."@en ;
  curric:correction """When describing weather conditions, the verb 'hace' translates as 'it is'.
  The Spanish translation of 'it is sunny' is 'hace sol'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165952Z"^^xsd:dateTime .

oakcurric:misconception-decide-use-border-apply-once
  a curric:Misconception ;
  curric:statement "If I decide to use BORDER I will apply it once for the whole writing."@en ;
  curric:correction """If you choose to use BORDER, apply it to each paragraph separately. This will
  help you respond clearly and completely to each bullet point."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165958Z"^^xsd:dateTime .

oakcurric:misconception-es-adjective-que-followed-subjunctive
  a curric:Misconception ;
  curric:statement "'Es' + adjective + 'que' is always followed by the subjunctive."@en ;
  curric:correction """The subjunctive is used after 'es' + adjective + 'que' when the action is
  uncertain, desired or not a fact. When the verb before 'que' expresses certainty, the
  action after 'que' is more a statement of fact and does not require the subjunctive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166318Z"^^xsd:dateTime .

oakcurric:misconception-knowing-using-one-listening-strategy
  a curric:Misconception ;
  curric:statement "Knowing and using one listening strategy is enough."@en ;
  curric:correction """All three sets of strategies work together, and you should be flexible in
  applying them as needed throughout the listening process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166324Z"^^xsd:dateTime .

oakcurric:misconception-give-long-developed-answers-role
  a curric:Misconception ;
  curric:statement "I should give long, developed answers to role-play prompts."@en ;
  curric:correction """It is not necessary to give long, developed answers to role-play prompts. It
  is best to respond using a short phrase or sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166663Z"^^xsd:dateTime .

oakcurric:misconception-translation-ve-spanish-sees
  a curric:Misconception ;
  curric:statement "The only translation of 've' in Spanish is 'she, he, it sees'."@en ;
  curric:correction """In Spanish, the verb 've' usually means 'she, he, it sees', but it is also
  the affirmative imperative form of 'ir', meaning 'go'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168843Z"^^xsd:dateTime .

oakcurric:misconception-command-request-verbs-followed-infinitive
  a curric:Misconception ;
  curric:statement """Command/request verbs are always followed by an infinitive, as in English,
  e.g. 'I want you to go', 'I'm asking you to leave'."""@en ;
  curric:correction """When the sentence refers to only one person, these verbs are followed by an
  infinitive, but if the sentence mentions two people, the command/request verbs are
  followed by a subjunctive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168848Z"^^xsd:dateTime .

oakcurric:misconception-form-verb-conditional-add-conditional
  a curric:Misconception ;
  curric:statement """To form any verb in the conditional, add a conditional ending to the
  infinitive."""@en ;
  curric:correction """Not all verbs are regular in the conditional and some don't follow this
  pattern. Some verbs have irregular stems in the conditional, e.g. 'tener' ('tendr-') and
  'poder' ('podr-')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168856Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-used-talk-something
  a curric:Misconception ;
  curric:statement """The imperfect tense is only used to talk about something that used to happen
  repeatedly."""@en ;
  curric:correction """The imperfect is used to talk about something that used to happen repeatedly,
  but it has other uses in different contexts. For example, it can be used to set the scene
  in a narrative account or story, and to describe general situations in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168870Z"^^xsd:dateTime .

oakcurric:misconception-performing-role-play-one-word
  a curric:Misconception ;
  curric:statement "When performing a role-play, one-word answers are enough."@en ;
  curric:correction """When preparing and performing role-plays, it is important to answer using
  short phrases or sentences, avoiding one-word answers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168876Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-strategy-tackling-translation
  a curric:Misconception ;
  curric:statement "I don't need to have a strategy when tackling a translation."@en ;
  curric:correction """It is important to read Spanish sentences carefully before translating them
  into English. Identifying the tense in each sentence, for example, can really help to
  improve accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168893Z"^^xsd:dateTime .

oakcurric:misconception-form-past-participle-verb-spanish
  a curric:Misconception ;
  curric:statement """To form the past participle of any verb in Spanish, remove the infinitive
  ending and add -ado."""@en ;
  curric:correction """To form the past participle of regular -ar verbs, remove the -ar and add
  -ado. However, to form the past participle of regular -er and -ir verbs, remove the
  -er/-ir and add -ido."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169239Z"^^xsd:dateTime .

oakcurric:misconception-ese-esa-words-noun-spanish
  a curric:Misconception ;
  curric:statement "'Ese' and 'esa' are the only words for 'that' before a noun in Spanish."@en ;
  curric:correction """'Aquel' and 'aquella' also mean 'that' and refer to something far away in
  space or time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169244Z"^^xsd:dateTime .

oakcurric:misconception-translation-hablamos-speak
  a curric:Misconception ;
  curric:statement "The only translation of 'hablamos' is 'we speak'."@en ;
  curric:correction """The ending -amos also corresponds to the 1st person plural form of the
  preterite for -ar verbs. Therefore, 'hablamos' can also mean 'we spoke'. The context of
  the verb should clarify which is the correct translation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169395Z"^^xsd:dateTime .

oakcurric:misconception-translation-iba-used-go
  a curric:Misconception ;
  curric:statement "The only translation of 'iba' is 'I used to go'."@en ;
  curric:correction """'iba' can means 'I used to go' or 'she, he, it used to go'. As 'iba' has
  several meanings, it’s important to consider to context of the sentence to work out who it
  refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169401Z"^^xsd:dateTime .

oakcurric:misconception-spanish-words-ending-consonant-other
  a curric:Misconception ;
  curric:statement """Spanish words ending in a consonant other than -n or -s always show final
  syllable stress."""@en ;
  curric:correction """Spanish words ending in a consonant other than -n or -s show final syllable
  stress unless otherwise indicated by an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169407Z"^^xsd:dateTime .

oakcurric:misconception-mean-impersonal-general-sense-use
  a curric:Misconception ;
  curric:statement "To mean 'you' in an impersonal, general sense use 'tú'."@en ;
  curric:correction """'Tú' means 'you' when directed at a specific person. To mean 'you' in an
  impersonal, general sense use 'se' e.g. 'se puede' (you can)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169415Z"^^xsd:dateTime .

oakcurric:misconception-important-use-range-verb-tenses
  a curric:Misconception ;
  curric:statement """It is important to use a range of verb tenses and complex language in
  role-play answers."""@en ;
  curric:correction """Role-play answers must consist of short words or phrases. Overcomplicating
  answers runs the risk of introducing ambiguity through grammatical error."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169611Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-antes-de-despu-s
  a curric:Misconception ;
  curric:statement """Adverbs 'antes de' and 'después de' and the preposition 'sin' are always
  followed by a gerund (-ing) in Spanish, the same as in English."""@en ;
  curric:correction """Adverbs 'antes de' and 'después de' and the preposition 'sin' are always
  followed by an infinitive in Spanish, unlinke English that uses a gerund (-ing)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169657Z"^^xsd:dateTime .

oakcurric:misconception-answering-reading-comprehension-questions-translate
  a curric:Misconception ;
  curric:statement """When answering reading comprehension questions, you should translate as much
  of the text as possible in the hope of including the correct answer."""@en ;
  curric:correction """You should make sure that your answers to reading comprehension questions are
  specific by locating relevant vocabulary in the text before responding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169697Z"^^xsd:dateTime .

oakcurric:misconception-el-lo-interchangeable-la-article
  a curric:Misconception ;
  curric:statement """'El' and 'lo' are interchangeable, as 'la' (article) and 'la' (DOP) and 'las'
  (article) and 'las' (DOP) look exactly the same."""@en ;
  curric:correction """Remember that direct object pronouns (lo, la, los and las) come before a
  verb. 'El' is the masculine singular form of the definite article 'the'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169712Z"^^xsd:dateTime .

oakcurric:misconception-ce-ci-z-sound-like
  a curric:Misconception ;
  curric:statement """[ce], [ci] and [z] always sound like the 'th' in 'think' in Spain, the Canary
  Islands and Latin America."""@en ;
  curric:correction """[ce], [ci] and [z] sound like the 'th' in 'think' in most of Spain, and 's'
  in Latin America and the Canary Islands."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169933Z"^^xsd:dateTime .

oakcurric:misconception-alguno-used-singular-uncountable-masculine
  a curric:Misconception ;
  curric:statement "'Alguno' can be used before a singular or uncountable masculine noun."@en ;
  curric:correction """'Alguno' cannot be used before a singular or uncountable masculine noun.
  'Algún' must be used instead."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169971Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translation-money-hers-exampl
  a curric:Misconception ;
  curric:statement """The Spanish translation of 'the money is hers' (for exampl) is 'el dinero es
  suya' because the owner is feminine."""@en ;
  curric:correction """The Spanish translation of 'the money is hers' is 'el dinero es suyo' because
  the object is masculine. Possessive adjectives agree with the object, not the owner."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170450Z"^^xsd:dateTime .

oakcurric:misconception-long-say-something-topic-doesnt
  a curric:Misconception ;
  curric:statement """As long as I say something about the topic, it doesn't matter what tense I
  use."""@en ;
  curric:correction """You must respond to the bullet point using the correct tense (e.g. past,
  present, future) to fully address it. Other tenses can add depth, but they don't replace
  the need to respond directly in the specified tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170455Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-go-noun-spanish
  a curric:Misconception ;
  curric:statement "All adjectives go after the noun in Spanish."@en ;
  curric:correction """There are some adjectives that can also go before the noun and these are
  called prenominal adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170461Z"^^xsd:dateTime .
