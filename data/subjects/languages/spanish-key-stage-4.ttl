    oakcurric:priorknowledge-3151-5 ,
    oakcurric:priorknowledge-3151-6 ,
    oakcurric:priorknowledge-3151-7 ,
    oakcurric:priorknowledge-3151-8 ,
    oakcurric:priorknowledge-3151-9 ,
    oakcurric:priorknowledge-3151-10 ;
  curric:id "3151"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.145155Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-languages-key-stage-4 ;
