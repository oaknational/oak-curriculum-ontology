  dcterms:modified "2026-06-07T15:30:29.358884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26187-2
  a curric:KeyLearningPoint ;
  rdfs:label """For 'vosotros' commands, use -ad for -ar verbs, -ed for -er and -id for -ir verbs.
  This is the affirmative imperative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26187-3
  a curric:KeyLearningPoint ;
