oakcurric:keylearningpoint-lesson-26161-1
  a curric:KeyLearningPoint ;
  rdfs:label "The simple present is used to express habitual events in the present."@en ;
  dcterms:modified "2026-06-07T15:30:28.999029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26161-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to express completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:28.999034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26161-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Ir a + infinitive’ is used to say what is going to happen."@en ;
  dcterms:modified "2026-06-07T15:30:28.999038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26161-4
  a curric:KeyLearningPoint ;
  rdfs:label "A verb clause is a piece of information containing a verb."@en ;
  dcterms:modified "2026-06-07T15:30:28.999042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26161-5
  a curric:KeyLearningPoint ;
  rdfs:label """A well developed or extended response in a conversation has at least three verb
  clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29190-1
  a curric:KeyLearningPoint ;
  rdfs:label "The simple present is used to express habitual events in the present."@en ;
  dcterms:modified "2026-06-07T15:30:28.999289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29190-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to express completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:28.999293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29190-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Ir a + infinitive' is used to say what is going to happen."@en ;
  dcterms:modified "2026-06-07T15:30:28.999297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29190-4
  a curric:KeyLearningPoint ;
  rdfs:label "A verb clause is a piece of information containing a verb."@en ;
  dcterms:modified "2026-06-07T15:30:28.999304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29190-5
  a curric:KeyLearningPoint ;
  rdfs:label """A well developed or extended response in a converation has at least three verb
  clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29213-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of Spanish SSCs in order to accurately
  transcribe spoken Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29213-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a broad vocabulary to be successful at answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29213-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen out for synonyms and distractors when answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26080-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use adverbs of time and verb tenses to interpret time frames in reading
  comprehension tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26080-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the strong vowels are [a], [e] and [o]. These are always fully
  pronounced and don't glide into other sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26080-3
  a curric:KeyLearningPoint ;
  rdfs:label """The stress in Spanish words ending in a vowel, 'n' or 's' falls on the penultimate
  syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26080-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stress in Spanish words ending in a consonant, excluding 'n' and 's', falls on
  the final syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26080-5
  a curric:KeyLearningPoint ;
  rdfs:label """Words that break the rules of stress in Spanish pronunciation indicate where the
  stress should fall with an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26037-1
  a curric:KeyLearningPoint ;
  rdfs:label "Listening to distinguish sounds e.g. [l] and [ll], improves pronunciation."@en ;
  dcterms:modified "2026-06-07T15:30:29.002282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26037-2
  a curric:KeyLearningPoint ;
  rdfs:label """'De' can translate as 'from' and 'of'. It can also mean 'of' and show possession;
  this replaces 's in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs have an irregular stem in the preterite: pud-, vin-, pus-, quis-, traj-,
  estuv-, dij-, -tuv-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26037-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Tú' is the subject pronoun 'you' and goes before a verb. 'Tu' and 'tus' are
  possessive adjectives and mean 'your'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26037-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Vosotros/as' are the subject pronoun 'you all'. 'Vuestro(s)/a(s)' are possessive
  adjectives and both mean 'your'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26042-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, it is important to differentiate between vowel sounds in a
  diphthong."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26042-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verbs ‘ser’ and ‘ir’ have the same preterite tense conjugations."@en ;
  dcterms:modified "2026-06-07T15:30:29.002310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26042-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular preterite tense forms of ‘ser’ and ‘ir’ are ‘fui’, ‘fuiste’ and
  ‘fue’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26042-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plural preterite tense forms of ‘ser’ and ‘ir’ are ‘fuimos’, ‘fuisteis’ and
  ‘fueron’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26042-5
  a curric:KeyLearningPoint ;
  rdfs:label """Preterite tense of ‘ser’ can be used to describe completed events or situations in
  the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26062-1
  a curric:KeyLearningPoint ;
  rdfs:label """When preparing and performing role-plays, it’s important to include a verb in each
  answer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Role-play answers should be relatively brief, whereas conversations present the
  opportunity to develop answers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26062-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can develop opinions about life at school by using justifications and
  contrasts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26062-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use conjunctions and connectives to provide justifications and
  contrasts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26059-1
  a curric:KeyLearningPoint ;
  rdfs:label """In most of mainland Spain the 'c' in 'ce' and 'ci' is pronounced as in the 'th' of
  the English 'throw'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26059-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Cuánto' agrees with the noun in gender and number when it is used as an adjective:
  cuánto, cuánta, cuántos, cuántas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26059-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Cuál' and 'quién' are pronouns. They stand alone or appear before a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.003218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26059-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Cuál' refers to a singular noun and 'cuáles' refers to a plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.003222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26059-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Quién' refers to one person and 'quiénes' refers to more than one person."@en ;
  dcterms:modified "2026-06-07T15:30:29.003226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26036-1
  a curric:KeyLearningPoint ;
  rdfs:label "Aurresku, Jota and Sevillanas are traditional dances from Spain."@en ;
  dcterms:modified "2026-06-07T15:30:29.003232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26036-2
  a curric:KeyLearningPoint ;
  rdfs:label "[v] is pronounced the same as [b]."@en ;
  dcterms:modified "2026-06-07T15:30:29.003239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26036-3
  a curric:KeyLearningPoint ;
  rdfs:label "Regular -er and -ir verbs have the same endings in the preterite."@en ;
  dcterms:modified "2026-06-07T15:30:29.003243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26036-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er/-ir verb endings in the preterite: iste for the 2nd person singular and
  -isteis for the 2nd person plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use subject pronouns 'tú' (you singular) and 'vosotros/as' (you all) to give
  emphasis or to present a contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26014-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [ca], [co], [cu] are prononced as in 'casa', 'comer' and 'escuchar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.003908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26014-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [ce] and [ci] are pronounced as in 'doce' and 'cinco'."@en ;
  dcterms:modified "2026-06-07T15:30:29.003912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26014-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -er/-ir verbs: 2nd and 3rd singular persons in the preterite tense (iste &
  -ió)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Form questions in the preterite tense for singular persons. Remember prepositions
  are placed at the beginning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26086-1
  a curric:KeyLearningPoint ;
  rdfs:label "In passive sentences, the focus is on what is done rather than who is doing it."@en ;
  dcterms:modified "2026-06-07T15:30:29.005091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26086-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some passive sentences in Spanish use 'ser' + past participle."@en ;
  dcterms:modified "2026-06-07T15:30:29.005095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26086-3
  a curric:KeyLearningPoint ;
  rdfs:label """In passive sentences with 'ser', the past participle must agree in gender and number
  with the noun it acts on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26086-4
  a curric:KeyLearningPoint ;
  rdfs:label "The word 'por' means 'by' when it appears after 'ser' + past participle."@en ;
  dcterms:modified "2026-06-07T15:30:29.005103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26086-5
  a curric:KeyLearningPoint ;
  rdfs:label "Unprepared questions often focus on opinions and past experiences."@en ;
  dcterms:modified "2026-06-07T15:30:29.005107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26073-1
  a curric:KeyLearningPoint ;
  rdfs:label """Barcelona is the capital of Catalonia, a region in northeastern Spain, and is known
  for its art and architecture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26073-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use 'desde' meaning 'since' with a specific point in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.005115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26073-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Desde hace' means 'for' and it appears together with the present tense to say how
  long we've been doing something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26073-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Hace' means 'ago' and we use it with the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.005123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26073-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present tense of 'llevar + time + present participle' to say how long we
  have been doing something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26076-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is used to express what has happened, e.g. 'I have listened', 'I
  have bought'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26076-2
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite tense is used to express single, completed actions in the past, e.g.
  'I listened', 'I bought'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27616-1
  a curric:KeyLearningPoint ;
  rdfs:label """ábamos, -abais and -aban are the 1st, 2nd and 3rd person plural endings of -ar verbs
  in the imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27616-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘ir’ is an irregular verb in the imperfect tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.252029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27616-3
  a curric:KeyLearningPoint ;
  rdfs:label """-íbamos, -ibais and -iban are the 1st, 2nd and 3rd person plural forms of ‘ir’ in
  the imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish adverbs ending in -mente (e.g. rápidamente) correspond to English adverbs
  ending in -ly (e.g. 'quickly')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27616-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form adverbs ending in -mente, add this ending to the feminine form of the
  adjective (e.g. 'rápida' - 'rápidamente')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26028-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words with stress on the last syllable have a written accent if the last letter is
  -n, -s or a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26028-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' in present tense, plural persons has the forms 'estamos', 'estáis' and
  'están'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26028-3
  a curric:KeyLearningPoint ;
  rdfs:label """Estar + present participle of -ar & -er / -ir (-ando, -iendo) is used to talk about
  ongoing events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26028-4
  a curric:KeyLearningPoint ;
  rdfs:label """Peñas are associations of people who gather together to celebrate local costumes and
  traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26028-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo include description of: people, action, location and
  mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26058-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Este' and 'esta' mean 'this' before a singular or uncountable noun. 'Este' is
  masculine and 'esta' is feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26058-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estos' and 'estas' mean 'these' before a plural noun. 'Estos' is masculine and
  'estas' is feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26058-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -ísimo and -ísima mean 'very' and appear at the end of an
  adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26058-4
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ito and -ita mean 'little' and appear at the end of a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.254578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26190-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Hay que', 'se debe', 'se puede' and 'se necesita' are impersonal verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.255174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26190-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of impersonal uses of verbs are ‘basta (con)’, ‘falta’, ‘hace falta’,
  ‘parece’ and ‘vale la pena’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26190-3
  a curric:KeyLearningPoint ;
  rdfs:label "These impersonal verbs are used without a subject and followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.255183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26190-4
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate the conditional, add -ía, -ías, -ía, -íamos, -iáis, and -ían to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26190-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26045-1
  a curric:KeyLearningPoint ;
  rdfs:label """The present indicative forms of ‘ser’ are ‘soy’, ‘eres’, ‘es’, ‘somos’, ‘sois’ and
  ‘son’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26045-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives of nationality must agree with the nouns they describe."@en ;
  dcterms:modified "2026-06-07T15:30:29.255200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26045-3
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine adjectives ending in -o change to -a, -os- or -as depending on the gender
  and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine adjectives ending in -és change to -esa, -eses or -esas depending on the
  gender and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26022-1
  a curric:KeyLearningPoint ;
  rdfs:label """When weak vowels [i] and [u] appear next to a strong vowel, [a], [e] and [o], they
  make a single syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26022-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Doler’ (to hurt, to be painful) is very commonly used with an indirect object
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26022-3
  a curric:KeyLearningPoint ;
  rdfs:label """Me (to me), te (to you, singular) and le (to him, her, it) are the singular indirect
  object pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26022-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nos (to us), os (to you, plural) and les (to them) are the plural indirect object
  pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26022-5
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns can go before the conjugated verb or attached to the
  infinitive in two-verb constructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29220-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Hay que', 'se debe', 'se puede' and 'se necesita' are impersonal verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.258103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29220-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of impersonal uses of verbs are ‘basta (con)’, ‘falta’, ‘hace falta’,
  ‘parece’ and ‘vale la pena’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29220-3
  a curric:KeyLearningPoint ;
  rdfs:label "These impersonal verbs are used without a subject and followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.258114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29220-4
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate the conditional, add -ía, -ías, -ía, -íamos, -iáis, and -ían to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29220-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26149-1
  a curric:KeyLearningPoint ;
  rdfs:label """Successful transcription involves careful listening, writing and checking, ensuring
  every word written makes sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26149-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective translation requires more than direct word-for-word substitution."@en ;
  dcterms:modified "2026-06-07T15:30:29.258446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26149-3
  a curric:KeyLearningPoint ;
  rdfs:label """The VAN check involves checking your verbs, adjectives and nouns after
  translating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26149-4
  a curric:KeyLearningPoint ;
  rdfs:label """The VAN check can significantly improve accuracy when tackling translation
  tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26039-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding adjectives, adverbs and nouns is an easy way to give more details and develop
  your sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26039-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ir' is an irregular verb. Its singular and plural forms are 'voy', 'vas', 'va',
  'vamos', 'vais', 'van'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26039-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use 'ir' to talk about routines and to talk about the future. Use 'ir' + a +
  infinitive to refer to the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'al' and 'a la' mean 'to the'. Use 'a la' before a feminine noun, and 'al'
  before a masculine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26039-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Puente' can be used to refer to a long weekend or bank holiday."@en ;
  dcterms:modified "2026-06-07T15:30:29.258552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26118-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' means 'to have, having'. Its forms are: 'tengo', 'tienes', 'tiene',
  'tenemos', 'tenéis', 'tienen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26118-2
  a curric:KeyLearningPoint ;
  rdfs:label """An idiom is a phrase which does not translate word-for-word into another
  language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26118-3
  a curric:KeyLearningPoint ;
  rdfs:label """The idiomatic expression 'tener' + noun is translated as 'to be' + adjective in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26118-4
  a curric:KeyLearningPoint ;
  rdfs:label """The term 'artificial intelligence', 'la inteligencia artificial (IA)' in Spanish,
  was coined by scientists in 1956."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26118-5
  a curric:KeyLearningPoint ;
  rdfs:label """AI use is now transforming daily lives; we can use 'tener' + noun expressions to
  discuss benefits and concerns with AI."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26072-1
  a curric:KeyLearningPoint ;
  rdfs:label """Madrid is the capital of Spain and its largest city. It's famous for its many
  museums, palaces and parks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26072-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite pronouns replace a noun in the sentence and match the gender and number
  of the noun they refer to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26072-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alguno, alguna, algunos and algunas mean 'some', 'any' or 'a, an' and are used in
  affirmative sentences and questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26072-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Ninguno' and 'ninguna' mean 'none', 'no-one', 'not a single one'; they are always
  used in the singular form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26072-5
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite adjectives and indefinite pronouns are identical apart from the masculine
  singular form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26102-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-spelling correspondences to
  produce accurate transcriptions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26102-2
  a curric:KeyLearningPoint ;
  rdfs:label """The inflectional future is a 1-verb structure used to say what will happen in the
  future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular conjugations of the inflectional future are formed by adding the endings
  -é, -ás or -á to the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26102-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'poner' and 'haber' have irregular stems in the future tense: 'pondr'- and
  'habr-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26052-1
  a curric:KeyLearningPoint ;
  rdfs:label "The ‘look, cover, write, check’ method is a useful way to learn vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.260647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs of time indicate when a verb is performed."@en ;
  dcterms:modified "2026-06-07T15:30:29.260650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26052-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs of manner indicate how a verb is performed."@en ;
  dcterms:modified "2026-06-07T15:30:29.260654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26052-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs of place indicate where a verb is performed."@en ;
  dcterms:modified "2026-06-07T15:30:29.260658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26024-1
  a curric:KeyLearningPoint ;
  rdfs:label "Present tense -ar verbs in 1st, 2nd, 3rd person singular (-o, -as, -a)."@en ;
  dcterms:modified "2026-06-07T15:30:29.260661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the affirmative imperative (also known as a positive command) to tell somebody
  to do something or give instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26024-3
  a curric:KeyLearningPoint ;
  rdfs:label """When talking to somebody familiar to you (tú) with the affirmative imperative with
  -ar verbs, use the ending -a."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26024-4
  a curric:KeyLearningPoint ;
  rdfs:label """[s] sounds like 'siempre', [z] sounds like 'empezar' and [ce] sounds like
  'entonces'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26024-5
  a curric:KeyLearningPoint ;
  rdfs:label """La Tomatina is a Spanish festival in Buñol, where participants throw tomatoes at
  each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26116-1
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate reflexive verbs, place the pronouns 'me', 'te', 'se', 'nos', 'os' or
  'se' before the conjugated verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26116-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns precede conjugated verbs in 1-verb structures, e.g. 'me
  hablan todos los días'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26116-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns can precede the conjugated verb or follow the
  infinitive/gerund in 2-verb structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26032-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to distinguish between the [j] + vowel and [g] + a, o or u
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26032-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'your' for two or more people, use 'vuestro'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26032-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Vuestro' is used for a singular or uncountable masculine noun and 'vuestros' is
  used for a plural masculine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26032-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Vuestra' is used for a singular or uncountable feminine noun and 'vuestras' is used
  for a plural feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26043-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish subject pronouns are ‘yo’, ‘tú’, ‘él/ella/usted’, ‘nosotros’,
  ‘vosotros’, and ‘ellos/ellas/ustedes’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26043-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of a Spanish verb is usually made clear by the verb ending."@en ;
  dcterms:modified "2026-06-07T15:30:29.261807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26043-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish subject pronouns can be used to provide emphasis if there is a change of
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Spanish 2nd person subject pronouns are 'tú', 'vosotros' and 'vosotras'."@en ;
  dcterms:modified "2026-06-07T15:30:29.262091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish 2nd person possessive adjectives are 'tu(s)', 'vuestro(s)' and
  'vuestra(s)'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26051-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -ar verbs in the 2nd person singular of the preterite tense end in
  -aste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26051-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular -ar verbs in the 2nd person plural of the preterite tense end in
  -asteis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26033-1
  a curric:KeyLearningPoint ;
  rdfs:label """[u] and [i] are weak vowels and they merge with other vowels making a single
  syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26033-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Contigo' is a pronoun and it means 'with you'."@en ;
  dcterms:modified "2026-06-07T15:30:29.262109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs have an irregular stem and add a -g- in 1st person singular, present
  tense: pongo, vengo, hago, digo - digo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26077-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'look, cover, write, check' method is a useful way to revisit vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.262447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26077-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can develop past-tense conversation answers by using a variety of tenses, such
  as the perfect and preterite."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26056-1
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite adjectives 'todo', 'mismo' and 'otro' all change to agree in gender
  and number with the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26056-2
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite adjective 'cada' never changes."@en ;
  dcterms:modified "2026-06-07T15:30:29.262460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26056-3
  a curric:KeyLearningPoint ;
  rdfs:label "Indefinite adjectives appear before the noun in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.262464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26056-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative pronouns 'que', 'donde' and 'cuando' introduce more information in a
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26047-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to revisit prior learning to strengthen long-term memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.262744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26047-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple present expresses habitual events and repeated actions in the
  present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26047-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use the simple present to describe and compare annual traditions and customs in
  the Spanish-speaking world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26195-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of Spanish SSCs in order to accurately
  transcribe spoken Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26195-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a broad vocabulary to be successful at answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262875Z"^^xsd:dateTime .

