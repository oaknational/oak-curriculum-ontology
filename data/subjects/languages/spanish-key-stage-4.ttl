oakcurric:unit-3647
  a curric:Unit ;
  rdfs:label "Communication and the world around us: acciones para un mundo mejor"@en ;
  curric:slug "my-neighbourhood-acciones-para-un-mundo-mejor" ;
  rdfs:comment """This unit introduces 'ir' and 'ver' in the imperfect, and plural forms of -ar,
  -er, and -ir verbs in the imperfect. Pupils revisit singular forms of these verbs in the
  imperfect, contrast the preterite and imperfect, form the past continuous with - ar verbs,
  and revisit modals."""@en ;
  curric:whyThisWhyNow """In this unit, pupils strengthen singular forms of -ar, -er, -ir verbs in
  the imperfect for habitual events. They expand on this by learning their plural forms, and
  irregular verbs 'ir' and 'ver' in all persons. Pupils anchor this knowledge in the context of
  global matters, and learn about journalist Arturo Pérez. To help build a solid foundation for
  using verbs in the past, pupils consolidate contrasting the imperfect with the preterite for
  interruptions, forming the past continuous, using modal verbs in the past, and the verbs
  'tenía', 'tenías', 'había'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3647-1 ,
    oakcurric:priorknowledge-3647-2 ,
    oakcurric:priorknowledge-3647-3 ,
    oakcurric:priorknowledge-3647-4 ,
    oakcurric:priorknowledge-3647-5 ,
    oakcurric:priorknowledge-3647-6 ,
    oakcurric:priorknowledge-3647-7 ,
    oakcurric:priorknowledge-3647-8 ;
  curric:id "3647"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.820959Z"^^xsd:dateTime ;
