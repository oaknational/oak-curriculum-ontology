# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-imperfect-tense
  a curric:Keyword ;
  schema:name "imperfect tense"@en ;
  schema:description "tense used to describe how things were or used to be in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.347280Z"^^xsd:dateTime .

oakcurric:keyword-sound-symbol-correspondence
  a curric:Keyword ;
  schema:name "sound-symbol correspondence"@en ;
  schema:description "relationship between letters and their sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.347335Z"^^xsd:dateTime .

oakcurric:keyword-palm
  a curric:Keyword ;
  schema:name "PALM"@en ;
  schema:description """acronym for photo description (people and objects, action, location,
  mood)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347340Z"^^xsd:dateTime .

oakcurric:keyword-verb-clause
  a curric:Keyword ;
  schema:name "verb clause"@en ;
  schema:description "a piece of information that contains a subject and a verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.347348Z"^^xsd:dateTime .

oakcurric:keyword-final-syllable-stress
  a curric:Keyword ;
  schema:name "final syllable stress"@en ;
  schema:description """pronouncing the last syllable more heavily than other syllables in a
  word"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347436Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-simple-present
  a curric:Keyword ;
  schema:name "simple present"@en ;
  schema:description "verb tense used to express habitual events in the present e.g. 'I do'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347450Z"^^xsd:dateTime .

oakcurric:keyword-preterite
  a curric:Keyword ;
  schema:name "preterite"@en ;
  schema:description "verb tense used to express completed actions in the past e.g. 'I did'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347454Z"^^xsd:dateTime .

oakcurric:keyword-ir-a-infinitive
  a curric:Keyword ;
  schema:name "ir a + infinitive"@en ;
  schema:description "2-verb structure meaning ‘going to + infinitive'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347459Z"^^xsd:dateTime .

oakcurric:keyword-irregular-verb
  a curric:Keyword ;
  schema:name "irregular verb"@en ;
  schema:description "a verb that does not follow the regular rules"@en ;
  dcterms:modified "2026-06-07T15:30:02.347466Z"^^xsd:dateTime .

oakcurric:keyword-dar
  a curric:Keyword ;
  schema:name "dar"@en ;
  schema:description "-ar irregular verb meaning 'to give, giving'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347473Z"^^xsd:dateTime .

oakcurric:keyword-idiom
  a curric:Keyword ;
  schema:name "idiom"@en ;
  schema:description """a phrase or expression whose meaning we don't translate word-for-word, e.g.
  'it's raining cats and dogs'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347478Z"^^xsd:dateTime .

oakcurric:keyword-passive
  a curric:Keyword ;
  schema:name "passive"@en ;
  schema:description """not acting to influence or change a situation; allowing other people to be
  in control"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347491Z"^^xsd:dateTime .

oakcurric:keyword-para
  a curric:Keyword ;
  schema:name "para"@en ;
  schema:description "word meaning 'for' or 'in order to'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347680Z"^^xsd:dateTime .

oakcurric:keyword-tense
  a curric:Keyword ;
  schema:name "Tense"@en ;
  schema:description """A verb’s tense will tell you whether the action happened in the past,
  present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347923Z"^^xsd:dateTime .

oakcurric:keyword-suffix
  a curric:Keyword ;
  schema:name "suffix"@en ;
