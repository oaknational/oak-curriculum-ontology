    oakcurric:priorknowledge-3161-5 ,
    oakcurric:priorknowledge-3161-6 ,
    oakcurric:priorknowledge-3161-7 ,
    oakcurric:priorknowledge-3161-8 ,
    oakcurric:priorknowledge-3161-9 ;
  curric:id "3161"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.738814Z"^^xsd:dateTime ;
