  dcterms:modified "2026-06-07T15:30:29.353796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26170-1
  a curric:KeyLearningPoint ;
  rdfs:label "To conjugate the perfect tense, use the verb ‘haber’ + past participle."@en ;
  dcterms:modified "2026-06-07T15:30:29.353964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26170-2
  a curric:KeyLearningPoint ;
  rdfs:label "To form the past participle of regular -ar verbs, remove the -ar and add -ado."@en ;
  dcterms:modified "2026-06-07T15:30:29.353968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26170-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the past participle of regular -er/ir verbs, remove the -er/ir and
  add -ido."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26170-4
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed conversation answer contains three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.353976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26185-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the affirmative imperative to tell somebody to do something or to give
  instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26185-2
  a curric:KeyLearningPoint ;
  rdfs:label """For 'tú' commands, use -a for -ar verbs and -e for -er/-ir verbs in the affirmative
  imperative: habla, come, escribe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26185-3
  a curric:KeyLearningPoint ;
  rdfs:label """Irregular imperative verbs include: 'sé', 've', 'ten', 'ven', 'haz', 'di', 'pon',
  'sal'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26185-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the familiar affirmative imperative of reflexive verbs, add the pronoun 'te'
  along with any necessary accents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29197-1
  a curric:KeyLearningPoint ;
  rdfs:label "To use comparatives in Spanish, use 'más' or 'menos' + adjective + que'."@en ;
  dcterms:modified "2026-06-07T15:30:29.354875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29197-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say something is better or worse than something else, use 'mejor que' or 'peor
  que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29197-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs express necessity or possibility, and can be used to communicate future
  hopes and desires."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29197-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you would like to do, use a modal verb like 'me gustaría' followed by an
  infinitve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29195-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29195-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to spot tricky sounds and cognates, and mentally rehearse before
  reading aloud in Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29195-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a broad vocabulary to be successful at answering reading
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29195-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to look out for synonyms and distractors when answering reading
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26164-1
  a curric:KeyLearningPoint ;
  rdfs:label "To use comparatives in Spanish, use 'más' or 'menos' + adjective + 'que'."@en ;
  dcterms:modified "2026-06-07T15:30:29.355232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26164-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say something is better or worse than something else, use 'mejor que' or 'peor
  que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26164-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs express necessity or possibility, and can be used to communicate future
  hopes and desires."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26164-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you would like to do, use a modal verb like 'me gustaría' followed by an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29206-1
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate singular forms of the perfect tense, use 'he', 'has' or 'ha' (from
  'haber') + past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29206-2
  a curric:KeyLearningPoint ;
  rdfs:label "To form the past participle of regular -ar verbs, remove the -ar and add -ado."@en ;
  dcterms:modified "2026-06-07T15:30:29.355497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29206-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the past participle of regular -er/ir verbs, remove the -er/ir and
  add -ido."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29206-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common irregular past participles include: hecho, visto, escrito, puesto, muerto,
  vuelto, cubierto, dicho, roto."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29206-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use the PALM acronym to structure photo descriptions."@en ;
  dcterms:modified "2026-06-07T15:30:29.355513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29188-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting words through themes can be a good way to strengthen vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.355651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29188-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple present tense is used to express habitual events in the present, e.g. 'I
  do'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29188-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite tense is used to express completed actions in the past, e.g.
  'I did'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29188-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common verbs that are irregular in the present and preterite tenses include: 'ser',
  'tener, 'estar', 'hacer' and 'ir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29188-5
  a curric:KeyLearningPoint ;
  rdfs:label """The PALM acronym is a useful tool to describe photos using a range of
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29216-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a checklist before a read-aloud task is a powerful and effective strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.355812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29216-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a read-aloud task, think carefully about how to correctly pronounce the letters
  in each word and spot tricky sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29216-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considering cognates and mentally rehearsing the text are key steps in preparation
  for a read-aloud task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29216-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can avoid distractors by not rushing to select an answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.355826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29216-5
  a curric:KeyLearningPoint ;
  rdfs:label """Distractors can appear anywhere - in the question, the answer options or the text
  itself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29209-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can boost our word knowledge by making connections between words such as word
  families, synonyms, opposites, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29209-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple present tense is used to express habitual events in the present e.g. 'I
  do'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29209-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is used to express completed actions in the past e.g. 'I have
  played', 'I have done'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29209-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to express how things were or used to be in the past, or
  to say what was happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29209-5
  a curric:KeyLearningPoint ;
  rdfs:label """The PALM acronym is a useful tool to describe photos using a range of
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26180-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish there are two verbs for 'to be'. Use 'estar' for location, state or mood
  and 'ser' for permanent traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26180-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to express how things were or used to be in the past, or
  to say what was happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26180-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' is an irregular verb in many tenses, but it follows regular patterns in the
  imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26180-4
  a curric:KeyLearningPoint ;
