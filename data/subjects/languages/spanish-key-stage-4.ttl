  dcterms:modified "2026-06-07T15:30:29.353770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29225-3
  a curric:KeyLearningPoint ;
  rdfs:label """When translating from Spanish to English, it is important to read the whole sentence
  before writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29225-4
  a curric:KeyLearningPoint ;
  rdfs:label """When translating from Spanish to English, make sure your translations sound natural
  in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29225-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating from Spanish to English, make sure to check the tense and subject
  of each verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29223-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a broad vocabulary to be successful at answering reading
