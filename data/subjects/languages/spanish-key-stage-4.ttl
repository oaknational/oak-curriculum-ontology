  dcterms:modified "2026-06-07T15:30:29.353766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29225-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to look out for synonyms and distractors when answering reading
