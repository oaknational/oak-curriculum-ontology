oakcurric:keylearningpoint-lesson-29215-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the affirmative imperative to tell somebody to do something or to give
  instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29215-2
  a curric:KeyLearningPoint ;
  rdfs:label """For 'tú' commands, use -a for -ar verbs and -e for -er/-ir verbs in the affirmative
  imperative: habla, come, escribe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29215-3
  a curric:KeyLearningPoint ;
  rdfs:label """Irregular imperative verbs include: 'sé', 've', 'ten', 'ven', 'haz', 'di', 'pon',
  'sal'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29215-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the familiar affirmative imperative of reflexive verbs, add the pronoun 'te'
  along with any necessary accents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29194-1
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate regular -are verbs in the preterite tense, use the endings -é, -aste,
  -ó, -amos, -asteis, -aron."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29194-2
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate regular -er/-ir verbs in the preterite tense, use the endings -í,
  -iste, -ió, -imos, -isteis, -ieron."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29194-3
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate regular -ar verbs in the imperfect tense, use the endings -aba, -abas,
  -aba, -ábamos, -ábais, -aban."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29194-4
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate regular -er/-ir verbs in the imperfect tense, use the endings -ía,
  -ías, -ía, -íamos, -íais, -ían."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29194-5
  a curric:KeyLearningPoint ;
  rdfs:label """The only irregular verbs in the imperfect tense are 'ir' ('iba'), 'ser' ('era') and
  'ver' ('veía')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358733Z"^^xsd:dateTime .

