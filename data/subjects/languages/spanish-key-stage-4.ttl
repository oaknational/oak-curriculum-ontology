  dcterms:modified "2026-06-07T15:30:29.353792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29223-3
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
