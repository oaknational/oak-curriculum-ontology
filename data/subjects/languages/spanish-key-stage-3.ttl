# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-verb-dar-means-give-giving
  a curric:Misconception ;
  curric:statement "The verb 'dar' means 'to give, giving' only."@en ;
  curric:correction """'Dar' usually translates as 'to give' but it is also used to describe how
  something makes people feel. e.g. da rabia - it makes me angry."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083790Z"^^xsd:dateTime .

oakcurric:misconception-words-ending-ia-accent
  a curric:Misconception ;
  curric:statement "All words ending in -ia must have an accent."@en ;
  curric:correction """Words ending in a vowel usually stress the penultimate syllable. Words ending
  in -ía have stress on the final syllable, so they need an accent e.g., energía. Words
  ending in -ia stress the penultimate syllable, so no accent is needed e.g. ciencia."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083840Z"^^xsd:dateTime .

oakcurric:misconception-verb-dar-translates-give-giving
  a curric:Misconception ;
  curric:statement "The verb 'dar' always translates as 'to give, giving'."@en ;
  curric:correction """The verb 'dar' means 'to give, giving' but can also translate as 'to be' +
  adjective when describing how something makes people feel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083855Z"^^xsd:dateTime .

oakcurric:misconception-word-para-translated
  a curric:Misconception ;
  curric:statement "The word 'para' is always translated as 'for'."@en ;
  curric:correction """The word 'para' is translated as 'for' when it is followed by a noun, but it
  is translated as 'in order to' when followed by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083922Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-spanish-go-noun
  a curric:Misconception ;
  curric:statement "All adjectives in Spanish go after the noun."@en ;
  curric:correction """Most adjectives in Spanish go after the noun, except prenominal adjectives,
  which go before the noun. Some prenominal adjectives are: 'último', 'primero', 'segundo',
  'tercero', 'bueno', 'propio'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083940Z"^^xsd:dateTime .

oakcurric:misconception-conocer-saber-mean-know-knowing
  a curric:Misconception ;
  curric:statement "Both 'conocer' and 'saber' mean 'to know, knowing'."@en ;
  curric:correction """They both mean 'to know, knowing' but 'conocer' is used for knowing facts and
  information, while 'saber' is used to say that you are familiar or become familiar with a
  place, a person or a thing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083963Z"^^xsd:dateTime .

oakcurric:misconception-verb-ending-o-refers-preterite
  a curric:Misconception ;
  curric:statement "The verb ending -o refers to 'she', 'he' or 'it' in the preterite tense."@en ;
  curric:correction """The verb ending -o refers to 'I' in the present tense. The verb ending -ó
  (with accent) refers to 'she', 'he' or 'it' in the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084735Z"^^xsd:dateTime .

oakcurric:misconception-two-vowels-together-read-one
  a curric:Misconception ;
  curric:statement "Two vowels together are always read as one vowel."@en ;
  curric:correction """In Spanish, when two strong vowels [a], [e] or [i] appear next to each other
  they are pronounced separately. This is why we call them 'strong' vowels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084760Z"^^xsd:dateTime .

oakcurric:misconception-verb-ir-regular-verb-apply
  a curric:Misconception ;
  curric:statement """The verb 'ir' is a regular verb so I can apply the regular conjugation rules
  for -ir verbs."""@en ;
  curric:correction """The verb 'ir' is irregular, therefore, it does not follow the normal
  conjugation rules. To say 'I go' we say 'voy', 'you go' - 'vas' and 'she, he, it goes' -
  'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085116Z"^^xsd:dateTime .

oakcurric:misconception-say-better-spanish-use-m
  a curric:Misconception ;
  curric:statement """To say 'better than' in Spanish I can use 'más bueno que'. To say 'worse than'
  I can use 'menos malo que'."""@en ;
  curric:correction """In English we don't say 'more good than' or 'more bad than'. We say 'better
  than' or 'worse than'. Spanish also has words for 'better' and worse'. To say 'better
  than' use 'mejor que' and to say 'worse than' use 'peor que'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085281Z"^^xsd:dateTime .

oakcurric:misconception-spanish-like-english-object-goes
  a curric:Misconception ;
  curric:statement "In Spanish, like in English, the object always goes after the verb."@en ;
  curric:correction """In Spanish, unlike in English, the object can go before or after the verb. In
  object-first sentences, we add the object pronouns lo (masculine) or la (feminine) before
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085523Z"^^xsd:dateTime .

oakcurric:misconception-spanish-translate-word-word-english
  a curric:Misconception ;
  curric:statement """In Spanish, we translate word-for-word from English to say 'I am going to',
  using 'soy' or 'estoy'."""@en ;
  curric:correction """Some structures do not allow for word-for-word translations between English
  and Spanish. To say 'I am going to' in Spanish, use the present tense of 'ir' + 'a' + 2nd
  infinitive verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085548Z"^^xsd:dateTime .

oakcurric:misconception-gustar-type-verbs-verb-agrees
  a curric:Misconception ;
  curric:statement """With gustar-type verbs, the verb agrees with the person who likes
  something."""@en ;
  curric:correction """In gustar-type verbs, the verb agrees with the subject - the thing liked,
  literally, the thing that pleases - not the person, e.g. 'Me gusta la música.' Since
  'música' is singular, the correct form is 'gusta'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085758Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-come-noun-spanish
  a curric:Misconception ;
  curric:statement "Adjectives always come after the noun in Spanish."@en ;
  curric:correction """In Spanish, adjectives generally come after the noun; however, certain
  prenominal adjectives come before the noun, e.g. 'último', 'mismo', 'propio', 'primero',
  'segundo', 'tercero'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085968Z"^^xsd:dateTime .

oakcurric:misconception-me-reflexive-pronoun-myself-possessive
  a curric:Misconception ;
  curric:statement "'Me' is a reflexive pronoun (myself) and a possessive adjective (my)."@en ;
  curric:correction """'Me' is a reflexive pronoun used to say that I do something to myself e.g. me
  despierto (I wake 'myself' up). 'Mi' is the possessive adjective 'my' used for masculine
  or feminine singular nouns e.g. 'mi madre', 'mi amigo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086397Z"^^xsd:dateTime .

oakcurric:misconception-form-present-continuous-use-est
  a curric:Misconception ;
  curric:statement "To form the present continuous I just use 'está' + present participle."@en ;
  curric:correction """To form the present continuous you first conjugate 'estar'; e.g. for 'they
  are' use 'están'. Then add the present participle; which is the verb stem + -ando for -ar
  verbs and -iendo for -er/-ir verbs, e.g. 'están hablando' - 'they are talking'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086403Z"^^xsd:dateTime .

oakcurric:misconception-simple-present-tense-spanish-habitual
  a curric:Misconception ;
  curric:statement """The simple present tense in Spanish is only for habitual actions, e.g. 'every
  week I do my homework'."""@en ;
  curric:correction """The simple present in Spanish is used for habitual actions and immediate
  plans. '¿Qué haces hoy?' means 'What are you doing today?' and 'hoy hago mis deberes'
  means 'today I am doing my homework'. English uses the present continuous here instead."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086679Z"^^xsd:dateTime .

oakcurric:misconception-nuestro-agree-noun-gender-number
  a curric:Misconception ;
  curric:statement "'Nuestro' does not agree with the noun in gender or number."@en ;
  curric:correction """'Nuestro' agrees with the noun in both gender and number. 'Nuestro' and
  'nuestros' refer to masculine nouns, while 'nuestra' and 'nuestras' refer to feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086930Z"^^xsd:dateTime .

oakcurric:misconception-two-verbs-together-e-g
  a curric:Misconception ;
  curric:statement """When there are two verbs together, e.g. 'I must go', we need to conjugate
  both."""@en ;
  curric:correction """English confuses us here. We say 'I must go' rather than 'I must to go' as
  English uses an infinitive but without 'to'. In Spanish, after modal verbs 'deber',
  'poder' and 'querer' the 2nd verb must always be an infinitive; 'I must go' is 'Debo ir'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086944Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronouns-e-g-used
  a curric:Misconception ;
  curric:statement """Subject pronouns, e.g. 'I', 'she', 'we', 'they', are used in the same way in
  Spanish and English."""@en ;
  curric:correction """English always uses subject pronouns. Spanish often relies on verb endings
  alone to indicate the 'doer'. However, Spanish has subject pronouns, e.g. 'yo' (I), 'tú'
  (you), 'él' (he), 'ella' (she), which are used for emphasis and clarity, as needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087434Z"^^xsd:dateTime .

oakcurric:misconception-er-verbs-same-ending-1st
  a curric:Misconception ;
  curric:statement """-er verbs have the same ending in the 1st person plural of the present and
  preterite tenses."""@en ;
  curric:correction """Unlike -ir verbs, -er verbs do not have the same ending in these tenses. The
  verb ending -emos is used in the present tense and -imos is used in the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087699Z"^^xsd:dateTime .

oakcurric:misconception-verb-ending-gustar-type-verbs
  a curric:Misconception ;
  curric:statement """The verb ending for gustar-type verbs depends on who is affected, not on the
  subject."""@en ;
  curric:correction """The verb ending depends on the subject, i.e. what causes the feeling of
  liking, interest, importance or concern, etc., e.g. 'le encanta el juego' - 'the game
  delights him, her', 'le encantan los juegos' - 'the games delight him, her'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087937Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-verbs-routine-activities
  a curric:Misconception ;
  curric:statement "Reflexive verbs are just for routine activities."@en ;
  curric:correction """In Spanish there are many reflexive verbs and they are not just used to
  describe routine activities. This lesson includes the verb 'acordar' ('to agree') compared
  with the reflexive verb 'acordarse' ('to remember')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087998Z"^^xsd:dateTime .

oakcurric:misconception-definite-article-translates-el-spanish
  a curric:Misconception ;
  curric:statement """The definite article 'the' translates as 'el' in Spanish and it can be used
  with singular nouns, both masculine and feminine."""@en ;
  curric:correction """There are two words for 'the' with singular nouns. The masculine singular
  definite article 'el' and the feminine singular definite article is 'la'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088140Z"^^xsd:dateTime .

oakcurric:misconception-want-want-wants-same-stem
  a curric:Misconception ;
  curric:statement """'I want', 'you want' and 'she, he, it wants' have the same stem as the
  infinitive, 'querer', so you just need to change the verb endings."""@en ;
  curric:correction """'Quiero', 'quieres' and 'quiere' are spelt slightly different to the
  infinitive 'querer'. They have an extra 'i'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088303Z"^^xsd:dateTime .

oakcurric:misconception-one-word-one-word-spanish
  a curric:Misconception ;
  curric:statement "There is just one word for ‘we’ and one word for ‘they’ in Spanish."@en ;
  curric:correction """Spanish has two words each for ‘we’ and ‘they’. The plural pronoun ‘we’ is
  ‘nosotros’ for boys/men or mixed gender groups, ‘nosotras’ for girls/women; ‘they’ also
  has two forms, 'ellos' and 'ellas'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088432Z"^^xsd:dateTime .

oakcurric:misconception-like-english-spanish-one-word
  a curric:Misconception ;
  curric:statement """Like in English, in Spanish there is only one word for 'that' and one for
  'those'."""@en ;
  curric:correction """In Spanish, to say ‘that’ for a singular masculine noun, use ‘ese’. To say
  ‘that’ for a singular feminine noun, use ‘esa’. To say ‘those’ for a plural masculine
  noun, use ‘esos’. To say ‘those’ for a plural feminine noun, use ‘esas’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088521Z"^^xsd:dateTime .

oakcurric:misconception-say-past-remove-infinitive-ending
  a curric:Misconception ;
  curric:statement "To say what I did in the past, remove the infinitive ending and add -é."@en ;
  curric:correction """To say what I did in the past for a regular -ar verb, remove the infinitive
  ending and add -é. To say what I did in the past for a regular -er or -ir verb, remove the
  infinitive ending and add -í."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088776Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-forms-model-verb
  a curric:Misconception ;
  curric:statement """All present tense forms of the model verb 'poder' have the same vowel change
  in the stem, o-> ue."""@en ;
  curric:correction """The 1st, 2nd, 3rd persons singular ('puedo', 'puedes', 'puede') and 3rd
  person plural ('pueden') forms all have a stem change from 'o' to 'ue' but 1st person
  plural 'we' form is 'podemos'; it keeps the same vowel as the infinitive 'poder'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088878Z"^^xsd:dateTime .

oakcurric:misconception-say-my-spanish-use-mi
  a curric:Misconception ;
  curric:statement "To say 'my' in Spanish we use 'mi'."@en ;
  curric:correction """There are two ways of saying 'my' in Spanish. 'Mi' is for singular nouns
  (masculine or feminine), e.g. 'mi madre' (my mother) and 'mis' is for plural nouns, e.g.
  'mis padres' (my parents)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088886Z"^^xsd:dateTime .

oakcurric:misconception-swap-verb-subject-around-ask
  a curric:Misconception ;
  curric:statement """We swap the verb and subject around to ask a closed, yes/no question as in
  English, e.g. 'Are we going to go on holiday?'"""@en ;
  curric:correction """All closed questions in Spanish have the same word order as the equivalent
  statement, e.g.'Vamos a ir de vacaciones' ('We are going to go on holiday') → '¿Vamos a ir
  de vacaciones?' ('Are we going to go on holiday?')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088892Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adverbs-position-use-del
  a curric:Misconception ;
  curric:statement "In Spanish, after adverbs of position we always use 'del'."@en ;
  curric:correction """In Spanish, after adverbs of position we use 'de', 'del' or 'de la'. 'De'
  when what follows is a person or place name, 'del' when what follows is a masculine noun
  and 'de la' when what follows is a feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089102Z"^^xsd:dateTime .

oakcurric:misconception-singular-plural-verbs-same-endings
  a curric:Misconception ;
  curric:statement "Singular and plural verbs have the same endings."@en ;
  curric:correction """Singular and plural verbs have different forms for first, second and third
  person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089108Z"^^xsd:dateTime .

oakcurric:misconception-accents-dont-affect-pronounce-spanish
  a curric:Misconception ;
  curric:statement "Accents don't affect how we pronounce Spanish words."@en ;
  curric:correction """Accents are very important and can differentiate between past and present.
  When we pronounce words with accents, we must remember to stress that syllable. For
  example, the verb 'caminó' means 'he, she, it walked' while 'camino' means 'I walk'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089414Z"^^xsd:dateTime .

oakcurric:misconception-spanish-like-english-one-el
  a curric:Misconception ;
  curric:statement "In Spanish, like in English, there is only one 'the' and that is 'el'."@en ;
  curric:correction """In Spanish, there are four words for 'the' - 'el' that accompanies singular
  and masculine nouns; 'la' for singular and feminine nouns, 'los' for plural and masculine
  nouns, and 'las' for plural and feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089525Z"^^xsd:dateTime .

oakcurric:misconception-spanish-needs-word-questions-e
  a curric:Misconception ;
  curric:statement """Spanish needs a word for 'do' in questions, e.g. 'Do you have?' and 'What do
  you have?'."""@en ;
  curric:correction """Spanish questions are easy to form. Yes/no questions have the same words as
  statements; to make a question you raise the pitch of your voice. Information questions
  just add a question word, e.g. 'Qué ... ?' in front of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089984Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjectives-spanish-agree-number
  a curric:Misconception ;
  curric:statement "Possessive adjectives in Spanish do not agree in number with the noun."@en ;
  curric:correction """Possessive adjectives in Spanish agree in number with the noun. For example,
  'mi' becomes 'mis' when it refers to a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090116Z"^^xsd:dateTime .

oakcurric:misconception-me-gusta-correct-way-say
  a curric:Misconception ;
  curric:statement "'Me gusta' is always the correct way to say 'I like'."@en ;
  curric:correction """'Me gusta' is 'I like' for a singular or uncountable noun, but plural nouns
  require 'me gustan'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090173Z"^^xsd:dateTime .

oakcurric:misconception-conjugate-2nd-person-plural-ar
  a curric:Misconception ;
  curric:statement "To conjugate 2nd person plural -ar verbs, use the verb ending -ais."@en ;
  curric:correction """To conjugate 2nd person plural -ar verbs, use the verb ending -áis. The
  accent on the 'a' is important as it tells us to stress the final syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090238Z"^^xsd:dateTime .

oakcurric:misconception-say-matter-verb-use
  a curric:Misconception ;
  curric:statement "To say 'they are' it does not matter which verb 'to be' we use."@en ;
  curric:correction """In Spanish there are two verbs 'to be'; we say 'son' (they are) to describe
  permanent traits, and 'están' (they are) to describe temporary states."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090897Z"^^xsd:dateTime .

oakcurric:misconception-form-present-continuous-need-remove
  a curric:Misconception ;
  curric:statement """To form the present continuous we just need to remove the -ar/-er/-ir from the
  infinitive and add -ando or -iendo."""@en ;
  curric:correction """To form the present continuous we need to use the correct form of the verb
  'estar' and then the present participle which is formed by removing the -ar/-er/-ir from
  the infinitive and adding -ando or -iendo."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090903Z"^^xsd:dateTime .

oakcurric:misconception-spanish-h-silent-matter-letter
  a curric:Misconception ;
  curric:statement """The Spanish [h] is always silent, no matter which letter it appears
  next to."""@en ;
  curric:correction """The Spanish [h] is not pronounced, but [ch] is always pronounced like the
  [ch] in 'churros' and 'chocolate'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091125Z"^^xsd:dateTime .

oakcurric:misconception-hablo-habl-mean-same
  a curric:Misconception ;
  curric:statement "'Hablo' and 'habló' mean the same."@en ;
  curric:correction """The 1st person of the present ends in -o, e.g. 'hablo', meaning 'I speak'.
  The 3rd person of the preterite ends in -ó, e.g. 'habló', meaning 'she, he, it spoke'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091378Z"^^xsd:dateTime .

oakcurric:misconception-spanish-er-ir-verbs-share
  a curric:Misconception ;
  curric:statement "Spanish -er and -ir verbs share the same endings in the present tense."@en ;
  curric:correction """The verbs endings for Spanish -er and -ir verbs are the same for 'I', 'you
  (singular)', 'she', 'he', 'it' and 'they'. The 1st person plural ‘we’ ending for -er verbs
  is -emos, and for -ir verbs is -imos."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091488Z"^^xsd:dateTime .

oakcurric:misconception-like-mi-tu-nuestro-agree
  a curric:Misconception ;
  curric:statement "Like 'mi' and 'tu', 'nuestro' does not agree with the noun in gender."@en ;
  curric:correction """Unlike 'mi' and 'tu', 'nuestro' agrees with the noun in gender. 'Nuestro' and
  'nuestros' refer to masculine nouns, while 'nuestra' and 'nuestras' refer to feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091493Z"^^xsd:dateTime .

oakcurric:misconception-fue-means-went
  a curric:Misconception ;
  curric:statement "'Fue' means 'I went'."@en ;
  curric:correction """'Fui' means 'I went' and 'fue' means 'she, he, it went'. The two have similar
  spelling so are easily confused."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091982Z"^^xsd:dateTime .

oakcurric:misconception-direct-object-pronouns-go-verb
  a curric:Misconception ;
  curric:statement "Direct object pronouns go after the verb, like in English."@en ;
  curric:correction """In Spanish, the direct object pronoun usually goes before the verb, e.g.
  'pruebas el chocolate caliente' - 'lo pruebas.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.092047Z"^^xsd:dateTime .

oakcurric:misconception-like-english-use-same-form
  a curric:Misconception ;
  curric:statement """Like in English, I can use the same form of the verb to adress 'you' for one
  person and 'you' for several people."""@en ;
  curric:correction """In Spanish, there are different verb endings to refer to 'you' (singular) and
  'you' (plural). For -ar verbs these are -as and -áis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092230Z"^^xsd:dateTime .

oakcurric:misconception-say-need-words
  a curric:Misconception ;
  curric:statement """To say 'I have', 'you have', 'she, he, it has' you need the words for 'I',
  'you' and 'she, he, it'."""@en ;
  curric:correction """The verbs 'tengo', 'tienes' and 'tiene' mean 'I have', 'you have' and 'she,
  he, it has'. You do not need to use separate pronouns 'I', 'you', 'she, he, it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092730Z"^^xsd:dateTime .

oakcurric:misconception-ll-pronounced-same-spanish-english
  a curric:Misconception ;
  curric:statement "[ll] is pronounced the same in Spanish and English."@en ;
  curric:correction """[ll] is pronounced differently in Spanish and English. It is important to
  recognise and pronounce sound-spelling links correctly to understand and be understood by
  other Spanish speakers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095126Z"^^xsd:dateTime .

oakcurric:misconception-3rd-person-singular-preterite-verb
  a curric:Misconception ;
  curric:statement """The 3rd person singular preterite verb ending for -ar verbs is the same as the
  present tense 1st person singular verb ending: -o."""@en ;
  curric:correction """The 3rd person singular preterite verb ending - ó has a very important accent
  which distinguishes it from the 1st person present tense. Compare 'hablo' - I talk, am
  talking and 'habló' - he, she, it talked. Without the accent it is a different tense!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.096530Z"^^xsd:dateTime .

oakcurric:misconception-necessary-use-pronouns-spanish-verbs
  a curric:Misconception ;
  curric:statement "It is necessary to use pronouns with Spanish verbs."@en ;
  curric:correction """In most cases, it is not necessary to use pronouns with Spanish verbs. The
  verb itself communicates the action and the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097406Z"^^xsd:dateTime .

oakcurric:misconception-letter-c-spanish-pronounced-same
  a curric:Misconception ;
  curric:statement "The letter 'c' in Spanish is always pronounced in the same way."@en ;
  curric:correction """The pronunciation of the letter 'c' changes depending on the following vowel.
  [ci] and [ce] have soft 'c' sounds and [ca], [co], [cu] have hard 'c' sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103965Z"^^xsd:dateTime .

oakcurric:misconception-weak-vowel-next-strong-vowel
  a curric:Misconception ;
  curric:statement "When a weak vowel is next to a strong vowel, we pronounce them separately."@en ;
  curric:correction """When a weak vowel is next to a strong vowel, like for example [i] next to
  [a], [e] or [o], it merges with them to make a single syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106379Z"^^xsd:dateTime .

oakcurric:misconception-nouns-ending-feminine
  a curric:Misconception ;
  curric:statement "All nouns ending in 'a' are feminine."@en ;
  curric:correction """There are exceptions to this, like 'problema' or 'día', that's why it is
  important to learn the article and the noun together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106387Z"^^xsd:dateTime .

oakcurric:misconception-pronounced-same-spanish-english
  a curric:Misconception ;
  curric:statement "[a] is pronounced the same in Spanish and English."@en ;
  curric:correction """Whilst the [a] sound varies in English, in different words and in different
  places, it is only pronounced as in 'alto' in Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106570Z"^^xsd:dateTime .

oakcurric:misconception-form-preterite-tense-take-er
  a curric:Misconception ;
  curric:statement """To form the preterite tense I just take off the -er/-ir and add the correct
  ending (-ió - for she, he, it) to all the verbs."""@en ;
  curric:correction """Some verbs are irregular and don’t follow the pattern. e.g. hacer - hizo,
  tener - tuvo, ir - fue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107516Z"^^xsd:dateTime .

oakcurric:misconception-form-ar-verbs-form-same
  a curric:Misconception ;
  curric:statement """The 'she, he, it' form of -ar verbs and the 'they' form have the same
  ending."""@en ;
  curric:correction """The 'she, he, it' form of -ar verbs ends in -a, but the 'they' form ends in
  -an."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107663Z"^^xsd:dateTime .

oakcurric:misconception-word-coche-means-coach
  a curric:Misconception ;
  curric:statement "The word 'coche' means 'coach'."@en ;
  curric:correction "In Spanish, the word 'coche' means 'car'. 'Coach' is 'autobús'."@en ;
  dcterms:modified "2026-06-07T15:30:15.109281Z"^^xsd:dateTime .

oakcurric:misconception-need-spanish-words-ask-questions
  a curric:Misconception ;
  curric:statement """I need Spanish words for 'do' and 'are' to ask yes/no questions, just like in
  English, e.g. 'Do you go to town?', 'Are you going to the park?'."""@en ;
  curric:correction """Spanish yes/no questions use the same words in the same order as Spanish
  statements. To make a statement into a spoken question, use raised intonation. Written
  questions use two question marks; the one at the start is upside down."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109397Z"^^xsd:dateTime .

oakcurric:misconception-know-sound-spanish-word-starts
  a curric:Misconception ;
  curric:statement "I know from the sound if a Spanish word starts with 'h'."@en ;
  curric:correction """The letter 'h' is a silent letter in Spanish. We need to learn the spelling
  of words that start with 'h' by practising vocabulary regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109402Z"^^xsd:dateTime .

oakcurric:misconception-say-instead-spanish-change-pronoun
  a curric:Misconception ;
  curric:statement """To say what 'we do' instead of what 'I do' in Spanish, you just change the
  pronoun from 'I' to 'we' and keep the verb the same."""@en ;
  curric:correction """In Spanish it's the verb ending and not the pronoun that changes the subject
  of the verb, so you need to pay close attention to the verb form to know who is doing the
  action of the verb, e.g. 'I sell' - 'vendo', 'we sell' - 'vendemos'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109545Z"^^xsd:dateTime .

oakcurric:misconception-one-word-spanish
  a curric:Misconception ;
  curric:statement "There is just one word for 'some' in Spanish."@en ;
  curric:correction """There are two words for 'some' in Spanish, just as there are two words for
  'a/an'. 'Unos' is 'some' for plural masculine nouns. 'Unas' is 'some' for plural feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109807Z"^^xsd:dateTime .

oakcurric:misconception-strategies-use-understand-words-text
  a curric:Misconception ;
  curric:statement """There are no strategies I can use to understand words in a text; I either know
  them or I don't."""@en ;
  curric:correction """I can use several strategies to help me understand a text: I can use the
  surrounding words that I do know, I can use my knowledge of patterns, e.g. for adjectives,
  and I can use cognates."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110860Z"^^xsd:dateTime .

oakcurric:misconception-spanish-simple-present-used-routine
  a curric:Misconception ;
  curric:statement """In Spanish, the simple present can be used for routine as well as for ongoing
  events."""@en ;
  curric:correction """The simple present is used to describe routine actions, and also immediate
  plans for today, but the present continuous is used to describe ongoing events."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111455Z"^^xsd:dateTime .

oakcurric:misconception-one-word-plural-spanish-los
  a curric:Misconception ;
  curric:statement "There is only one word for plural 'the' in Spanish and that is 'los'."@en ;
  curric:correction """In Spanish, the plural 'the' has two forms: 'los' for plural masculine nouns,
  and 'las' for plural feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112927Z"^^xsd:dateTime .

oakcurric:misconception-regular-er-ir-verbs-plural
  a curric:Misconception ;
  curric:statement "Regular -er/-ir verbs in plural form always end in -en."@en ;
  curric:correction "Only the 3rd person plural form ends in -en."@en ;
  dcterms:modified "2026-06-07T15:30:15.114666Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-spanish
  a curric:Misconception ;
  curric:statement "There is only one verb for 'to be, being' in Spanish."@en ;
  curric:correction """There are two verbs for to be in Spanish: 'estar' for location and temporary
  states and 'ser' for general traits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115428Z"^^xsd:dateTime .

oakcurric:misconception-forming-question-verb-form-changes
  a curric:Misconception ;
  curric:statement """When forming a question the verb form changes in Spanish like it does in
  English (auxiliary 'did' + verb)."""@en ;
  curric:correction """The verb stays the same in Spanish and only the intonation (spoken) or
  punctuation (written) marks the sentence as a question. There is no need to translate a
  form of 'do', 'did' etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116703Z"^^xsd:dateTime .

oakcurric:misconception-ar-verbs-same-ending-form
  a curric:Misconception ;
  curric:statement """-AR verbs have the same ending for the 'I' form of the present and preterite
  tense."""@en ;
  curric:correction """In the present tense, the 1st person singular ends in '-o' and in the
  preterite, the 1st person singular ends in '-é'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116976Z"^^xsd:dateTime .

oakcurric:misconception-verb-ending-o-means-youre
  a curric:Misconception ;
  curric:statement "The verb ending -o means 'I' but only if you're a boy or man."@en ;
  curric:correction """For regular verbs, the 'I' verb form always ends in 'o'. Verb endings match
  the person, but don't change for gender, so 'hablo' means 'I speak' for everyone. It is
  adjectives that change ending -o to -a to describe a girl or woman."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117050Z"^^xsd:dateTime .

oakcurric:misconception-spanish-use-verb-ser-talk
  a curric:Misconception ;
  curric:statement "In Spanish, I can use the verb 'ser' to talk about 'being' in any context."@en ;
  curric:correction """In Spanish, the verb 'ser' means 'to be, being' for general traits. To refer
  to a location, mood or state, use 'estar'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117131Z"^^xsd:dateTime .

oakcurric:misconception-huir-works-exactly-same-way
  a curric:Misconception ;
  curric:statement """'Huir' works in exactly the same way as all regular -ir verbs, e.g.
  'escribir'."""@en ;
  curric:correction """The verb 'huir' has a spelling change (i → y) in the present tense in the 1st
  person singular, 2nd person singular, 3rd person singular, and 3rd person plural forms:
  huyo, huyes, huye, huyen. This makes the vowel pronunciation easier - huyo not huio."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117416Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-end-o
  a curric:Misconception ;
  curric:statement "In Spanish, adjectives always end in -o."@en ;
  curric:correction """In Spanish, adjectives must agree with the noun they describe in gender and
  number. If the noun is feminine, the adjective will end in -a, but if it is masculine, it
  will end in -o. If the adjective already ends in -e, it will stay the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124893Z"^^xsd:dateTime .

oakcurric:misconception-english-spelling-spanish-adjectives-remains
  a curric:Misconception ;
  curric:statement """As in English, the spelling of Spanish adjectives remains the same regardless
  of the noun they are describing."""@en ;
  curric:correction """The spelling of Spanish adjectives changes from -o to -a when desciring a
  person or animal that is female."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124928Z"^^xsd:dateTime .

oakcurric:misconception-adjective-needs-agree-verb
  a curric:Misconception ;
  curric:statement "The adjective needs to agree with the verb."@en ;
  curric:correction """This is only the case with attribute verbs like 'ser' or 'estar' because the
  adjective is still referring to an implicit noun (person, thing)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125494Z"^^xsd:dateTime .

oakcurric:misconception-cu-l-used-english-followed
  a curric:Misconception ;
  curric:statement "Cuál is used as in English, followed by a noun."@en ;
  curric:correction "In Spanish, cuál is never followed by a noun."@en ;
  dcterms:modified "2026-06-07T15:30:15.125509Z"^^xsd:dateTime .

oakcurric:misconception-matter-whether-use-preterite-imperfect
  a curric:Misconception ;
  curric:statement """It does not matter whether I use the preterite or the imperfect as both refer
  to the past."""@en ;
  curric:correction """To talk about something completed in the past, we use the preterite tense.
  However, to talk about something that happened repeatedly in the past, with the meaning
  'used to', we use the imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125951Z"^^xsd:dateTime .

oakcurric:misconception-g-j-same-sound-spanish
  a curric:Misconception ;
  curric:statement "[g] and [j] always have the same sound in Spanish, like [b] and [v] do."@en ;
  curric:correction """[g] sounds different when followed by a, o, u, when it sounds just like g +
  a, o, u in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126426Z"^^xsd:dateTime .

oakcurric:misconception-hay-pronounced-english-hi-means
  a curric:Misconception ;
  curric:statement """'Hay' is pronounced as the English 'hi' and means there is. There is another
  word for 'there are'."""@en ;
  curric:correction """The 'h' is not pronounced in 'hay' and it means both 'there is' and 'there
  are'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126619Z"^^xsd:dateTime .

oakcurric:misconception-h-pronounced-spanish
  a curric:Misconception ;
  curric:statement "The 'h' is sometimes pronounced in Spanish."@en ;
  curric:correction """The 'h' is never pronounced in Spanish, regardless of its position in the
  word (hola, zanahoria)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126940Z"^^xsd:dateTime .

oakcurric:misconception-feminine-plural-demonstrative-adjective-same
  a curric:Misconception ;
  curric:statement """The feminine plural demonstrative adjective for 'these' is the same as the
  'tú' form of the verb 'estar'."""@en ;
  curric:correction """Accents are really important in Spanish. The 'tú' form of 'estar' has an
  accent on the á: 'estás' (you are) whereas the demonstrative adjective for plural feminine
  nouns, 'estas' does not: 'estas flores' (these flowers)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129890Z"^^xsd:dateTime .

oakcurric:misconception-best-focus-first-unfamiliar-words
  a curric:Misconception ;
  curric:statement "It is best to focus first on the unfamiliar words in a longer text."@en ;
  curric:correction "This should be done in last place, when context has been read."@en ;
  dcterms:modified "2026-06-07T15:30:15.129903Z"^^xsd:dateTime .

oakcurric:misconception-sound-z-pronounced-same-spanish
  a curric:Misconception ;
  curric:statement "The sound [z] is pronounced the same in every Spanish-speaking country."@en ;
  curric:correction """The sound [z] is pronounced differently in parts of Spain and in other parts
  of the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129908Z"^^xsd:dateTime .

oakcurric:misconception-once-word-learnt-stays-memory
  a curric:Misconception ;
  curric:statement "Once a word is learnt, it stays in the memory forever."@en ;
  curric:correction """Words need revisiting from time to time in order to not disappear from the
  memory."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131888Z"^^xsd:dateTime .

oakcurric:misconception-verbs-ending-feminine
  a curric:Misconception ;
  curric:statement "Verbs ending in -a are feminine."@en ;
  curric:correction """Unlike nouns, verbs in Spanish are not masculine or feminine. 3rd person
  singular verbs ending in -a can refer to he or she."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133810Z"^^xsd:dateTime .

oakcurric:misconception-de-appears-el-becomes-de
  a curric:Misconception ;
  curric:statement "When 'de' appears before 'el' it becomes 'de el'."@en ;
  curric:correction """When 'de' appears before a singular masculine noun with the definite article
  'el' it merges with it to form 'del', e.g. 'la jugadora está fuera del estadio' - 'the
  player is outside the stadium'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138318Z"^^xsd:dateTime .

oakcurric:misconception-cu-nto-used-ask-one
  a curric:Misconception ;
  curric:statement "'Cuánto' is used to ask about one thing and 'cuántos' for several things."@en ;
  curric:correction "'Cuánto' is used for uncountable nouns, not for one thing."@en ;
  dcterms:modified "2026-06-07T15:30:15.141047Z"^^xsd:dateTime .

oakcurric:misconception-make-noun-plural-spanish-add
  a curric:Misconception ;
  curric:statement "To make a noun plural in Spanish, just add -s."@en ;
  curric:correction "Spanish nouns ending in a consonant add -es for plural."@en ;
  dcterms:modified "2026-06-07T15:30:15.141423Z"^^xsd:dateTime .

oakcurric:misconception-sounds-b-v-different-english
  a curric:Misconception ;
  curric:statement "The sounds for [b] and [v] are different, as in English."@en ;
  curric:correction """This is one of the rare cases in Spanish where one sound can have two
  spellings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141510Z"^^xsd:dateTime .

oakcurric:misconception-sounds-ge-gi-pronounced-like
  a curric:Misconception ;
  curric:statement "The sounds [ge] and [gi] are pronounced just like in English."@en ;
  curric:correction """Both sounds are pronounced like an 'h' followed by 'e' for [ge] and followed
  by 'i' for [gi]"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141886Z"^^xsd:dateTime .

oakcurric:misconception-ge-gi-soft-g-sound
  a curric:Misconception ;
  curric:statement """[ge] and [gi] are a soft 'g' sound as in English. Spanish [j] is different so
  you can always hear the difference when you transcribe words with these sounds."""@en ;
  curric:correction """Spanish [ge] and [gi] sounds like Spanish [j] + e and [j] + i, so you cannot
  hear the difference when you transcribe. However, there is often a clue from English,
  e.g., 'religión' in Spanish is spelled with [gi] as in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141898Z"^^xsd:dateTime .

oakcurric:misconception-spanish-verb-endings-rarely-change
  a curric:Misconception ;
  curric:statement """In Spanish the verb endings rarely change depending on who the verb refers to,
  like in English."""@en ;
  curric:correction """In Spanish verb endings always change depending on who the verb refers to.
  For -ar verbs, 'I' ends in -o, 'you' ends in -as, 'she, he, it' ends in -a, 'we' ends in
  -amos, and 'they' ends in -an."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142436Z"^^xsd:dateTime .

oakcurric:misconception-es-son-mean-same
  a curric:Misconception ;
  curric:statement "'Es' and 'son' mean the same."@en ;
  curric:correction "'Es' means 'she, he, it is' and 'son' means 'they are'."@en ;
  dcterms:modified "2026-06-07T15:30:15.142539Z"^^xsd:dateTime .

oakcurric:misconception-hacer-means
  a curric:Misconception ;
  curric:statement "'Hacer' only means 'to do'."@en ;
  curric:correction """In Spanish, 'hacer' is used for 'to do' and 'to make', there is no specific
  verb for either."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142593Z"^^xsd:dateTime .

oakcurric:misconception-spanish-verbs-follow-same-pattern
  a curric:Misconception ;
  curric:statement """Spanish verbs follow the same pattern as English verbs. The 'I', 'you', 'we'
  and 'they' forms are all the same and the only change happens in the 'she, he, it' form."""@en ;
  curric:correction """In Spanish, each subject has its own special ending. For -ar verbs, this is
  '-o' for 'I', '-as' for 'you', '-a' for 'she, he, it', '-amos' for 'we' and '-an' for
  'they'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142799Z"^^xsd:dateTime .

oakcurric:misconception-verb-tener-means
  a curric:Misconception ;
  curric:statement "The verb 'tener' always means 'to have, having'."@en ;
  curric:correction """The verb 'tener' translates into English as 'to be' when used as part of
  idioms, e.g. 'tengo suerte' translates as 'I am lucky'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147199Z"^^xsd:dateTime .

oakcurric:misconception-que-means-spanish
  a curric:Misconception ;
  curric:statement "'Que' means 'what' in Spanish."@en ;
  curric:correction """'Qué' with an accent on the 'e' is the question word 'what'. 'Que' without an
  accent is a conjunction meaning 'that' - 'Creo que hay una solución'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148181Z"^^xsd:dateTime .

oakcurric:misconception-doesnt-matter-spanish-translation-verb
  a curric:Misconception ;
  curric:statement """It doesn't matter which Spanish translation of the verb 'to be' we use, as
  they both mean 'to be, being'."""@en ;
  curric:correction """The verb 'ser' is for permanent traits, and the verb 'estar' is for temporary
  states/moods and location. It sounds as odd to a Spanish person if we use the wrong verb
  'to be' as it does when someone says 'I make sport' or 'I do a cake' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149471Z"^^xsd:dateTime .

oakcurric:misconception-spanish-words-stress-second-last
  a curric:Misconception ;
  curric:statement """All Spanish words with stress on the second-to-last syllable must have a
  written accent."""@en ;
  curric:correction """If a word ends in a vowel, -n, or -s, it usually has that stress naturally
  and doesn’t need an accent. Accents are only used when the word sounds different from the
  normal rule."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149730Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-go-noun
  a curric:Misconception ;
  curric:statement "In Spanish, all adjectives go after the noun."@en ;
  curric:correction """Most Spanish adjectives go after the noun; they describe objective qualities
  (traits, origin, colours,...). However, some adjectives go before the noun; these
  prenominal adjectives often express subjective opinions or give emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150136Z"^^xsd:dateTime .

oakcurric:misconception-para-means
  a curric:Misconception ;
  curric:statement "'Para' always means 'for'."@en ;
  curric:correction """The word 'para' doesn't always mean 'for'. It can also mean 'in order to'
  when followed by an infinitive verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150154Z"^^xsd:dateTime .

oakcurric:misconception-use-word-like-spanish-questions
  a curric:Misconception ;
  curric:statement "We have to use a word like 'did' in Spanish questions."@en ;
  curric:correction """In Spanish, you don't need a word like do or did to ask questions. The verb
  ending itself shows the tense and subject, e.g. '¿Trabajaste en el campo?' - 'Did you work
  in the countryside?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150540Z"^^xsd:dateTime .

oakcurric:misconception-asking-questions-like-travel-plane
  a curric:Misconception ;
  curric:statement """When asking questions like 'Did you travel by plane?' in Spanish, I need to
  start by translating the word 'did'."""@en ;
  curric:correction """To ask a 'did'-style question in Spanish, you can form an intonation question
  by simply raising your voice at the end of a past-tense sentence. It is not necessary to
  translate the word 'did'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150731Z"^^xsd:dateTime .

oakcurric:misconception-spanish-one-way-say-like
  a curric:Misconception ;
  curric:statement "Spanish has only one way to say 'you are,' like English."@en ;
  curric:correction """In Spanish, the form of 'you are' changes depending on who you're talking to.
  To say ‘you are’ to one person, use ‘eres’. To say ‘you are’ to two or more people, use
  ‘sois’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150841Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-follow-noun
  a curric:Misconception ;
  curric:statement "Spanish adjectives always follow the noun."@en ;
  curric:correction """This is the general case, but it is not a rule. There are many cases where
  the adjective precedes the noun, like for certain collocations ('una gran amistad') or
  when more flair is sought."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150912Z"^^xsd:dateTime .

oakcurric:misconception-say-my-mum-teacher-its
  a curric:Misconception ;
  curric:statement "To say 'my mum is a teacher', it's 'mi madre es una profesora.'"@en ;
  curric:correction """In Spanish, we do not need the indefinite article ('un', 'una') when
  referring to jobs, so we would just say 'mi madre es profesora.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.151553Z"^^xsd:dateTime .

oakcurric:misconception-two-verbs-together-conjugate
  a curric:Misconception ;
  curric:statement "When there are two verbs together, we must conjugate both."@en ;
  curric:correction """When we have two verbs together, we must conjugate the first one and use the
  infinitive for the second verb, i.e., 'Debo ayudar con las tareas en mi casa.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.151759Z"^^xsd:dateTime .

oakcurric:misconception-guess-meaning-words-dont-know
  a curric:Misconception ;
  curric:statement "I can guess the meaning of the words I don't know just by looking at them."@en ;
  curric:correction """Guessing the meaning is not a reliable strategy for most words in Spanish as
  it may lead to misunderstanding, especially for tricky or abstract vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151987Z"^^xsd:dateTime .

oakcurric:misconception-different-persons-ar-verbs-preterite
  a curric:Misconception ;
  curric:statement """All the different persons of the -ar verbs in the preterite tense have the
  same endings, as in the English simple past, e.g. 'did', 'ate', 'went', 'learned'."""@en ;
  curric:correction """In Spanish, the endings for -ar verbs in the preterite tense differ depending
  on the grammatical person. The 'I' form ends in -é and the 'you' form ends in -aste."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151994Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-say-am-spanish
  a curric:Misconception ;
  curric:statement "There is only one verb to say 'I am' and 'you are' in Spanish."@en ;
  curric:correction """In Spanish, there are two ways to say 'I am' and 'you are'. 'I am in general'
  is 'soy' and 'I am now' is 'estoy'. 'You are in general' is 'eres' and 'you are now' is
  'estás'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152868Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-preterite-tense-ar
  a curric:Misconception ;
  curric:statement """The present tense and the preterite tense of -ar verbs share the same endings
  for the 'I' form."""@en ;
  curric:correction """In Spanish, the 1st person of the present tense ends in -o and of the
  preterite ends in -é. These endings only apply to -AR verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152874Z"^^xsd:dateTime .

oakcurric:misconception-me-te-mean-my-your
  a curric:Misconception ;
  curric:statement "'Me' and 'te' mean 'my' and 'your' in Spanish."@en ;
  curric:correction """'Me' and 'te' are reflexive pronouns in Spanish and mean 'myself' and
  'yourself' respectively. 'Mi' and 'tu' are the possessive adjectives 'my' and 'your' in
  Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152879Z"^^xsd:dateTime .

oakcurric:misconception-say-someone-goes-la-al
  a curric:Misconception ;
  curric:statement "To say where someone goes, only 'a la/al' goes before the place."@en ;
  curric:correction "If the place is a city or a country, 'a' goes before the place."@en ;
  dcterms:modified "2026-06-07T15:30:15.153225Z"^^xsd:dateTime .

oakcurric:misconception-turn-statement-question-spanish-need
  a curric:Misconception ;
  curric:statement """To turn a statement into a question in Spanish you need to alter the order of
  the words as in English."""@en ;
  curric:correction """It is not necessary to alter word order when forming questions in Spanish. To
  turn a statement into a question, you can raise your voice at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155366Z"^^xsd:dateTime .

oakcurric:misconception-feminine-plural-refers-girls-women
  a curric:Misconception ;
  curric:statement """The feminine plural always refers to girls/women only and the masculine
  plural, to boys/men only."""@en ;
  curric:correction "The masculine plural is used to refer to groups of women and men too."@en ;
  dcterms:modified "2026-06-07T15:30:15.156373Z"^^xsd:dateTime .

oakcurric:misconception-indirect-object-pronoun-le-changes
  a curric:Misconception ;
  curric:statement """The indirect object pronoun 'le' changes to 'la' to match the gender of the
  person receiving the action."""@en ;
  curric:correction """'Le' means 'to him', 'to her' or 'to it' regardless of the person receiving
  the action, e.g. 'le doy un regalo a Lucía' or 'le doy un regalo a Daniel'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157396Z"^^xsd:dateTime .

oakcurric:misconception-necessary-use-pronouns-verbs-spanish
  a curric:Misconception ;
  curric:statement """It is necessary to use pronouns before verbs in Spanish to know who is
  performing an action."""@en ;
  curric:correction """It is not usually necessary to use pronouns before verbs in Spanish. You can
  tell who is performing an action by looking at the verb ending."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157727Z"^^xsd:dateTime .

oakcurric:misconception-verb-tener-translates
  a curric:Misconception ;
  curric:statement "The verb 'tener' always translates as 'to have, having'."@en ;
  curric:correction """The verb 'tener' does not always translates as 'to have, having'. For
  example, in idiomatic expressions it can mean 'to be, being', e.g. 'tuve éxito' - 'I was
  successful'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160687Z"^^xsd:dateTime .

oakcurric:misconception-verbs-including-er-ir-use
  a curric:Misconception ;
  curric:statement """All verbs (including -er and -ir) use -an in the present and -aron in the
  preterite to mean 'they'."""@en ;
  curric:correction """To conjugate -ar verbs for 'they', remove -ar and add -an for the present
  tense or -aron for the preterite tense. However, to conjugate -er/-ir verbs for 'they',
  remove -ar and add -en for the present tense or -ieron for the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161389Z"^^xsd:dateTime .

oakcurric:misconception-er-ir-verbs-same-verb
  a curric:Misconception ;
  curric:statement """-er and -ir verbs have the same verb ending in the 1st person plural, present
  tense."""@en ;
  curric:correction """-er and -ir verbs have different endings in the 1st person plural, present
  tense. For -er verbs, it is -emos and for -ir verbs, it is -imos."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161398Z"^^xsd:dateTime .

oakcurric:misconception-ar-er-ir-verbs-share
  a curric:Misconception ;
  curric:statement """-ar, -er, and -ir verbs all share the same endings in the present tense for
  'she, he, it' and 'they' forms."""@en ;
  curric:correction """-er and -ir verbs share the same endings for 'she, he, it' and 'they' forms,
  but -ar verbs have a different ending."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162568Z"^^xsd:dateTime .

oakcurric:misconception-spanish-personal-required-verbs-direct
  a curric:Misconception ;
  curric:statement """In Spanish the personal 'a' is required between verbs and all direct
  objects."""@en ;
  curric:correction """In Spanish you use the personal 'a' after the verb when the following direct
  object is a specific person or an animal we have a name for (a pet)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162573Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adverbs-made-simply-adding
  a curric:Misconception ;
  curric:statement """All Spanish adverbs are made by simply adding -mente to any adjective
  form."""@en ;
  curric:correction """When an adjective has masculine -o and feminine -a forms, you must use the -a
  form before adding -mente, e.g. 'rápido' - 'rápida' - 'rápidamente'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162581Z"^^xsd:dateTime .

oakcurric:misconception-esta-means
  a curric:Misconception ;
  curric:statement "'Esta' means both 'this' and 'she, he, it is'."@en ;
  curric:correction """‘Esta’ is a demonstrative adjective, it means ‘this’ and goes before a noun.
  ‘Está’ is a verb, means ‘she, he, it is’ and describes an state or location. As there is
  an accent, we must stress the last syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162610Z"^^xsd:dateTime .

oakcurric:misconception-impossible-non-native-pronounce-rr
  a curric:Misconception ;
  curric:statement "It is impossible for a non-native to pronounce the [rr] sound."@en ;
  curric:correction """The [r] and [rr] sounds need practice to produce them confidently. Even for
  native speakers, it is the last sound that children learn to produce."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163007Z"^^xsd:dateTime .

oakcurric:misconception-su-possessive-adjective-his-hers
  a curric:Misconception ;
  curric:statement "'Su' is the only possessive adjective for 'his' and 'hers' in Spanish."@en ;
  curric:correction """'Su' is his', 'hers' or 'its' before a singular noun. 'Sus' is 'his' 'hers',
  or 'its' before a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163293Z"^^xsd:dateTime .

oakcurric:misconception-translation-que
  a curric:Misconception ;
  curric:statement "The only translation of 'que' is 'that'."@en ;
  curric:correction """In Spanish, 'que' can mean different things depending on the context in which
  it's used. For example, it can mean 'who' or 'that' as a relative pronoun, or 'than'
  within a comparative structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164237Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-plurals-forms-like-english
  a curric:Misconception ;
  curric:statement "Adjectives do not have plurals forms, like English."@en ;
  curric:correction """In Spanish, adjectives match the nouns they describe. If the noun is
  singular, the adjective will be singular as well, and the same for plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164292Z"^^xsd:dateTime .

oakcurric:misconception-er-ir-verbs-different-endings
  a curric:Misconception ;
  curric:statement "-er and -ir verbs have different endings in the preterite."@en ;
  curric:correction """-er and -ir verbs share the same endings in the preterite. The 'I' form of
  both -er and -ir verbs is -í."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164904Z"^^xsd:dateTime .

oakcurric:misconception-pronounced-same-way-n
  a curric:Misconception ;
  curric:statement "[ñ] is pronounced the same way as [n]."@en ;
  curric:correction """[ñ] is pronounced differently to [n]. It is pronounced as in the word
  'español' and [n] as in the word 'mano'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164910Z"^^xsd:dateTime .

oakcurric:misconception-like-modal-verbs-estar-followed
  a curric:Misconception ;
  curric:statement """Just like modal verbs, 'estar' is followed by an infinitive to form the
  present continuous to express what is happening right now."""@en ;
  curric:correction """To form the present continuous, use a present tense form of 'estar' together
  with a present participle. To form this for -ar verbs, remove -ar from the infinitive and
  add -ando to the stem. For -er and -ir verbs, add -iendo to the verb stem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164919Z"^^xsd:dateTime .

oakcurric:misconception-gustar-type-verbs-agree-number
  a curric:Misconception ;
  curric:statement "Gustar-type verbs do not agree in number with the subject."@en ;
  curric:correction """Gustar-type verbs agree with the subject in number: -a for singular nouns and
  -an for plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165048Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-position-followed-de
  a curric:Misconception ;
  curric:statement "Adverbs of position are always followed by 'de'."@en ;
  curric:correction """Adverbs of position are followed by 'de' when they refer to a place/person,
  by 'del' when they refer to masculine nouns, and by 'de la' when they refer to feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165139Z"^^xsd:dateTime .

oakcurric:misconception-prenominal-adjectives-ending-o-drop
  a curric:Misconception ;
  curric:statement "All prenominal adjectives ending in -o drop the -o before masculine nouns."@en ;
  curric:correction """Not all prenominal adjectives ending in -o drop it before a masculine noun,
  although there are many common ones that do like 'bueno' and 'malo'. However 'segundo' and
  'último' do not, and there are others that hold on to their -o too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165144Z"^^xsd:dateTime .

oakcurric:misconception-spanish-uses-english-word-order
  a curric:Misconception ;
  curric:statement """Spanish always uses English word order when using indirect objects (subject +
  verb + object)."""@en ;
  curric:correction """In Spanish, the indirect object can go before or after the verb. Both 'le doy
  un regalo a mi hermano' and 'a mi hermano le doy un regalo' are correct - the second just
  adds emphasis to who receives the gift."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165186Z"^^xsd:dateTime .

oakcurric:misconception-word-si-means
  a curric:Misconception ;
  curric:statement "The word 'si' means both 'yes' and 'if'."@en ;
  curric:correction """In Spanish there is a difference between them: 'sí' with an accent means
  'yes', and 'si' without an accent means 'if'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165192Z"^^xsd:dateTime .

oakcurric:misconception-spanish-verb-forms-ar-verbs
  a curric:Misconception ;
  curric:statement "All Spanish verb forms for -ar verbs end in -ar."@en ;
  curric:correction """Spanish -ar verbs end in o-, -as, -a, -amos depending on who they refer to.
  -o for 'I', -as for 'you', -a for 'she, he, it' and -amos for 'we'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.165280Z"^^xsd:dateTime .

oakcurric:misconception-form-present-continuous-use-present
  a curric:Misconception ;
  curric:statement """To form the present continuous I use the present tense of 'estar' followed by
  an infinitive, as with other two-verb structures I know, i.e. modal verbs."""@en ;
  curric:correction """To form the present continuous you use the present tense of 'estar' followed
  by the present participle. For -ar verbs this is formed by removing the -ar ending and
  adding -ando, e.g. 'estoy saltando' ('I am jumping')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165286Z"^^xsd:dateTime .

oakcurric:misconception-plural-form-same-er-ir
  a curric:Misconception ;
  curric:statement "The plural 'you' form is the same for both -er and -ir verbs."@en ;
  curric:correction """To talk to more than one person ('you all') using -er verbs in the present
  tense, use the ending -éis, e.g. 'comprendéis' - 'you all understand'. For -ir verbs, use
  the ending -ís, e.g. 'escribís' - 'you all write'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165361Z"^^xsd:dateTime .

oakcurric:misconception-mi-tu-changes-according-whether
  a curric:Misconception ;
  curric:statement """'Mi' and 'tu' changes according to whether the noun is feminine or
  masculine."""@en ;
  curric:correction """In Spanish, the possessive adjectives do not change according to whether the
  noun is feminine or masculine. They stay the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165369Z"^^xsd:dateTime .

oakcurric:misconception-spanish-ending-singular-plural-ar
  a curric:Misconception ;
  curric:statement """In Spanish the ending for 'you singular' and 'you plural' for -ar verbs is the
  same."""@en ;
  curric:correction """To refer to 'you' for one person with a present tense -ar verb, use the verb
  ending -as, e.g. 'buscas'; to refer to 'you' for two or more people with a present tense
  -ar verb, use the verb ending -áis, e.g. 'buscáis'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165431Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-verb-used-its
  a curric:Misconception ;
  curric:statement "A present tense verb can be used on its own to talk about the future."@en ;
  curric:correction """When using the present tense to talk about the future, it is essential to
  include a temporal adverb (such as 'mañana', 'la próxima semana', 'el lunes', etc.) to
  make the future meaning clear."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165510Z"^^xsd:dateTime .

oakcurric:misconception-form-imperfect-continuous-instead-present
  a curric:Misconception ;
  curric:statement """To form the imperfect continuous instead of the present continuous both the
  form of 'estar' and the present participle need to change."""@en ;
  curric:correction """To form the imperfect continuous, only the form of 'estar' needs to change,
  into the imperfect tense. The present participle stays the same, it is formed by removing
  the infinitive ending and adding -ando for -ar verbs and -iendo for all other verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165757Z"^^xsd:dateTime .

oakcurric:misconception-indirect-object-pronoun-replaces-thing
  a curric:Misconception ;
  curric:statement """The indirect object pronoun replaces the thing being given, not the person
  receiving it."""@en ;
  curric:correction """The indirect object pronoun replaces the person who is receiving the action,
  not the thing being given. 'Le doy un regalo.' - 'I give a present to him, her.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.165848Z"^^xsd:dateTime .

oakcurric:misconception-doesnt-matter-whether-use-ser
  a curric:Misconception ;
  curric:statement """It doesn't matter whether we use 'ser' or 'estar' in Spanish as they both mean
  'to be, being.'"""@en ;
  curric:correction """Both verbs mean 'to be, being' but 'ser' is used to describe permanent traits
  and 'estar' to describe temporary states."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165854Z"^^xsd:dateTime .

oakcurric:misconception-sentence-such-puedo-participo-correct
  a curric:Misconception ;
  curric:statement """A sentence such as 'puedo participo' is correct and it means 'I can
  participate'. Both verbs are in the 'I' form."""@en ;
  curric:correction """The sentence 'Puedo participo' is not correct because the verb 'poder' is
  always followed by an infinitive. To say 'I can participate' we must say 'Puedo
  participar.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.165859Z"^^xsd:dateTime .

oakcurric:misconception-raro-means-rare
  a curric:Misconception ;
  curric:statement "'Raro' means 'rare'."@en ;
  curric:correction "'Raro' is a false friend and means 'strange'."@en ;
  dcterms:modified "2026-06-07T15:30:15.166046Z"^^xsd:dateTime .

oakcurric:misconception-use-ser-describe-weather-spanish
  a curric:Misconception ;
  curric:statement "We use 'ser' to describe the weather in Spanish."@en ;
  curric:correction """In English we use the verb 'to be' for the weather (e.g. 'it is cold'), but
  in Spanish the verb 'hacer' is used. For example, to say 'it is sunny' you would say 'hace
  sol'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166106Z"^^xsd:dateTime .

oakcurric:misconception-single-r-rolled
  a curric:Misconception ;
  curric:statement "A single 'r' is never rolled."@en ;
  curric:correction """When the [r] is at the beginning of a word, we do roll it. For example,
  'respeto', 'religión'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166542Z"^^xsd:dateTime .

oakcurric:misconception-nouns-spanish-used-article-word
  a curric:Misconception ;
  curric:statement """All nouns in Spanish are always used with an article, a word for 'a', 'some'
  or 'the'."""@en ;
  curric:correction """Some nouns are uncountable and have no plural. Use these without an article,
  as in English. For example, 'quiere dinero' means 'she, he wants money'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166658Z"^^xsd:dateTime .

oakcurric:misconception-singular-forms-estar-feminine-demonstrative
  a curric:Misconception ;
  curric:statement """Some singular forms of 'estar' and feminine demonstrative adjectives look and
  sound the same."""@en ;
  curric:correction """The feminine demonstrative adjectives 'esta' (this) and 'estas' (these) have
  no accent. The 2nd and 3rd person singular forms of 'estar' have an accent on the -a:
  'estás' (you are) and 'está' (she, he is). They are pronounced with stress on the -a."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166793Z"^^xsd:dateTime .

oakcurric:misconception-english-two-nouns-together-describe
  a curric:Misconception ;
  curric:statement """When in English there are two nouns together to describe a particular type of
  something, e.g. 'train ticket', in Spanish we translate them in the same order."""@en ;
  curric:correction """In Spanish, the word order changes and the preposition 'de' is used between
  the two nouns, e.g. 'train ticket' is 'billete de tren'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168232Z"^^xsd:dateTime .

oakcurric:misconception-one-word-your-spanish-tu
  a curric:Misconception ;
  curric:statement "There is only one word for 'your' in Spanish and that is 'tu'."@en ;
  curric:correction """In Spanish, if the possessive adjective 'your' comes before a singular or
  uncountable noun, we say 'tu', but if it comes before a plural noun we say 'tus'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168418Z"^^xsd:dateTime .

oakcurric:misconception-use-me-spanish-need-myself
  a curric:Misconception ;
  curric:statement "If you use 'me' in Spanish you need 'myself' in English."@en ;
  curric:correction """When the action of a verb is directed towards the self, Spanish always uses a
  reflexive pronoun. English does not always do this; for example, 'me levanto a las siete'
  - 'I get up at seven'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168424Z"^^xsd:dateTime .

oakcurric:misconception-3rd-person-endings-ir-verbs
  a curric:Misconception ;
  curric:statement """The 3rd person endings for -IR verbs include 'i', as -ER end in 'e' and 'en'
  and -AR verbs end in 'a' and 'an'."""@en ;
  curric:correction "-IR verbs have the same present tense endings as -ER verbs."@en ;
  dcterms:modified "2026-06-07T15:30:15.168532Z"^^xsd:dateTime .

oakcurric:misconception-first-noun-sentence-subject
  a curric:Misconception ;
  curric:statement "The first noun in a sentence is always the subject."@en ;
  curric:correction """If there is a personal 'a' before the first noun it is not the subject, it is
  the object (usually a person) receiving the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168760Z"^^xsd:dateTime .

oakcurric:misconception-word-pie-pronounced-like-english
  a curric:Misconception ;
  curric:statement "The word 'pie' is pronounced like the English word 'pie'."@en ;
  curric:correction """In Spanish 'pie' is also a 1-syllable word but we hear each letter
  distinctly, and Spanish 'i' is pronounced 'i' as in the Spanish word 'idea'. To say it
  correctly, enunciate each letter but quickly so that the word sounds as one syllable,
  'p-i-e'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168768Z"^^xsd:dateTime .

oakcurric:misconception-revisiting-vocabulary-using-leitner-system
  a curric:Misconception ;
  curric:statement """When revisiting vocabulary using the Leitner system, we need to revise all the
  words in the different boxes every day."""@en ;
  curric:correction """When learning vocabulary using the Leitner system, we use 4 boxes with words:
  words that need to be revised daily, words that need to be revised every 3 days, weekly
  and monthly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168796Z"^^xsd:dateTime .

oakcurric:misconception-words-ending-ci-n-ciones
  a curric:Misconception ;
  curric:statement "All the words ending in '-ción' and '-ciones' must have an accent."@en ;
  curric:correction """If a word ends in 'n' or 's' and has final syllable stress, it must have an
  accent, e.g. 'la opción'. However, if a word ending in 'n' or 's' has penultimate syllable
  stress, it does not need an accent, e.g. 'las opciones'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168801Z"^^xsd:dateTime .

oakcurric:misconception-easy-write-spanish-memory-know
  a curric:Misconception ;
  curric:statement "It is easy to write Spanish from memory if I know what the words mean."@en ;
  curric:correction """Knowing what words mean when you listen to or read them doesn't mean you can
  write them from memory. To write from memory, you need to practise writing from memory,
  especially verbs, as these need to be right to communicate your message clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168882Z"^^xsd:dateTime .

oakcurric:misconception-spanish-uses-subject-pronouns-verbs
  a curric:Misconception ;
  curric:statement "Spanish always uses subject pronouns with verbs, like English."@en ;
  curric:correction """Spanish rarely uses subject pronouns; they are used for contrast or emphasis
  only. The ending of the verb in Spanish tells you who the subject is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168887Z"^^xsd:dateTime .

oakcurric:misconception-pronouns-necessary-understand-subject-verb
  a curric:Misconception ;
  curric:statement """Pronouns are necessary to understand who the subject of a verb is in
  Spanish."""@en ;
  curric:correction """Pronouns are not necessary to understand who the subject of a verb is in
  Spanish. Verb endings tell us who the subject is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169259Z"^^xsd:dateTime .

oakcurric:misconception-peru-spanish-speaking-country
  a curric:Misconception ;
  curric:statement "Peru has always been a Spanish-speaking country."@en ;
  curric:correction """Spanish only arrived in Peru in 1532, when Francisco Pizarro reached the Inca
  Empire. The official language of the Inca Empire was Quechua, which is still spoken by
  more than 10 million people, mainly in Peru, Bolivia and Ecuador."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169387Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-continuous-tell-subject-verb
  a curric:Misconception ;
  curric:statement """In the imperfect continuous I can tell who the subject of the verb is by
  looking at the form of 'estar' being used."""@en ;
  curric:correction """The 'I' and 'he, she, it' forms of the imperfect tense of 'estar' are the
  same: 'estaba'. Therefore you have to use the context to work out who the subject of the
  verb is when this form is being used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169593Z"^^xsd:dateTime .

oakcurric:misconception-english-one-way-saying-your
  a curric:Misconception ;
  curric:statement "As in English, there is one way of saying 'your' in Spanish."@en ;
  curric:correction """Saying 'your' in Spanish depends on the number of people you are speaking to
  and the following noun. To mean ‘your’ for one person before a singular noun, use ‘tu’,
  and for more than one person, use 'vuestro' or 'vuestra'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169600Z"^^xsd:dateTime .

oakcurric:misconception-know-ir-present-tense-easy
  a curric:Misconception ;
  curric:statement """I know 'ir' in the present tense, so it will be easy to remember it in the
  preterite tense."""@en ;
  curric:correction """'Ir' is an irregular verb in both the present and the preterite tense. This
  verb is very common and therefore needs to be learnt off by heart."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169605Z"^^xsd:dateTime .

oakcurric:misconception-talk-past-action-use-preterite
  a curric:Misconception ;
  curric:statement "When I talk about a past action I must always use the preterite."@en ;
  curric:correction """The preterite is used for actions that are completed and finished in the
  past. The imperfect is used for ongoing, habitual, or background actions in the past -
  things that were happening or used to happen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170108Z"^^xsd:dateTime .

oakcurric:misconception-preparation-needed-read-spanish-aloud
  a curric:Misconception ;
  curric:statement "There is no preparation needed before I read Spanish aloud."@en ;
  curric:correction """Trickier sounds can trip us up when we read aloud in Spanish. Identifying any
  tricky sounds, then mentally rehearsing before we read aloud can help us read more
  accurately and fluently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170117Z"^^xsd:dateTime .

oakcurric:misconception-impossible-tell-whether-1st-person
  a curric:Misconception ;
  curric:statement """It is impossible to tell whether the 1st person plural of -ar verbs ('we') is
  in the present tense or the preterite tense because the verb endings are the same."""@en ;
  curric:correction """The verb ending of the 1st person plural of -ar verbs is the same in the
  present and the preterite tense. Therefore we rely on time markers to indicate which time
  frame it is, e.g. 'ayer jugamos al tenis' - 'yesterday we played tennis'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170169Z"^^xsd:dateTime .

oakcurric:misconception-describing-future-plans-ir-followed
  a curric:Misconception ;
  curric:statement "When describing future plans, 'ir' + a is followed by a conjugated verb."@en ;
  curric:correction """When describing future plans, 'ir' + a is followed by the infinitive form of
  a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170415Z"^^xsd:dateTime .

oakcurric:misconception-talk-completed-events-past-ar
  a curric:Misconception ;
  curric:statement """To talk about completed events in the past with -ar verbs you always take off
  the -ar ending and add -é in the 1st person singular ('I')."""@en ;
  curric:correction """For -ar verbs ending in -car, you remove the -car and add -qué in the 1st
  person singular, for example; 'sacar' - 'saqué' - 'I took out'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170430Z"^^xsd:dateTime .

oakcurric:misconception-spanish-compare-things-use-m
  a curric:Misconception ;
  curric:statement "In Spanish, to compare things, we use 'más, menos' + adjective + 'de'."@en ;
  curric:correction """In Spanish, when we're comparing two things using an adjective, we use 'más,
  menos' + adjective + 'que', e.g. 'más caro que', 'menos sano que'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170435Z"^^xsd:dateTime .

oakcurric:misconception-telling-story-past-event-keep
  a curric:Misconception ;
  curric:statement """When telling a story about a past event, I have to keep the full account in
  the same past tense."""@en ;
  curric:correction """Different past tenses describe different elements of a story. The imperfect
  continuous describes what was happening ('Estaba corriendo ...') then the preterite tense
  describes an interruption to that activity ('... cuando llegó una vaca'.)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170444Z"^^xsd:dateTime .

oakcurric:misconception-compare-two-things-spanish-change
  a curric:Misconception ;
  curric:statement """To compare two things in Spanish we can just change the adjective like in
  English, e.g. 'angry' becomes 'angrier.'"""@en ;
  curric:correction """To compare two nouns we use a comparative structure. To express 'more ...
  than' we use 'más ... que' and to say 'less ... than' we use 'menos ... que'. The
  adjective goes in the middle and still has to agree in gender and number with the first
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170520Z"^^xsd:dateTime .

oakcurric:misconception-conjugate-verb-add-ending-infinitive
  a curric:Misconception ;
  curric:statement "When we conjugate the verb we just add the ending to the infinitive."@en ;
  curric:correction """In Spanish when we conjugate a verb, first, we remove the -ar ending and then
  add the correct ending depending on who is doing the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170529Z"^^xsd:dateTime .

oakcurric:misconception-la-means-her
  a curric:Misconception ;
  curric:statement "'La' always means 'her' or 'it'."@en ;
  curric:correction """'La' means 'the' in front of a noun but 'her' or 'it' when it comes before a
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170766Z"^^xsd:dateTime .

oakcurric:misconception-numbers-13-19-begin-dieci
  a curric:Misconception ;
  curric:statement "All numbers from 13 to 19 begin with 'dieci-'."@en ;
  curric:correction """Numbers 16 to 19 begin with 'dieci-' + number, e.g. 'dieciséis',
  'diecisiete', but numbers 13 to 15 do not follow the same pattern, e.g. 'trece',
  'catorce', 'quince'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170771Z"^^xsd:dateTime .

oakcurric:misconception-english-one-way-say-am
  a curric:Misconception ;
  curric:statement "As in English, there is one way to say 'I am' in Spanish."@en ;
  curric:correction """There are two ways to say 'I am' in Spanish. These are 'estoy' (for location,
  mood and temporary state) and 'soy' (for general traits)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170777Z"^^xsd:dateTime .

oakcurric:misconception-stem-form-verb-poder-spelt
  a curric:Misconception ;
  curric:statement """The stem of the 'I, you, she/he/it' form of the verb 'poder' is spelt exactly
  the same as the infinitive."""@en ;
  curric:correction """The infinitive is 'poder' but when we conjugate the verb, the spelling
  changes for the 'I, you, she/he/it' form. 'Puedo' means 'I can', 'puedes' means 'you can'
  and 'puede' means 'she/he/it can.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.170782Z"^^xsd:dateTime .

oakcurric:misconception-one-way-translate-spanish-present
  a curric:Misconception ;
  curric:statement "There is only one way to translate the Spanish present tense into English."@en ;
  curric:correction """There are two ways of translating the Spanish present tense into English: the
  present simple (habit - 'I go') or the present continuous (ongoing action - 'I am going').
  The context or time adverbs can help to tell us which one to choose in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170790Z"^^xsd:dateTime .

oakcurric:misconception-words-ending-n-s-need
  a curric:Misconception ;
  curric:statement "All words ending in -n or -s need an accent."@en ;
  curric:correction """Words ending in -n, -s or a vowel generally have penultimate syllable stress
  and no accent. Words ending in -n, -s or a vowel with final syllable stress have an accent
  on the final vowel. Note the difference: 'canción', 'canciones'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170796Z"^^xsd:dateTime .

oakcurric:misconception-doesnt-matter-action-completed-repeated
  a curric:Misconception ;
  curric:statement """It doesn't matter if the action was completed or repeated - I can use any past
  tense verb."""@en ;
  curric:correction """In Spanish, we choose between the preterite and imperfect based on how the
  action happened in the past. Use the preterite to communicate an action that happened once
  and the imperfect for actions that were repeated over a period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170802Z"^^xsd:dateTime .

oakcurric:misconception-translate-keep-shoes-need-word
  a curric:Misconception ;
  curric:statement """To translate 'Where do you keep these shoes?' I need the word for 'do' in
  Spanish."""@en ;
  curric:correction """Spanish doesn't have a word for 'do' in questions. Only the main verb is used
  in the form that matches the subject of the question. So the translation would be '¿Dónde
  guardas estos zapatos?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170807Z"^^xsd:dateTime .

oakcurric:misconception-sounds-ci-si-z-pronounced
  a curric:Misconception ;
  curric:statement """The sounds [ci], [si] and [z] are pronounced the same in all the
  Spanish-speaking countries."""@en ;
  curric:correction """In Latin America, parts of southern Spain and the Canary Island, [ci], [si]
  and [z] are pronounced the same. In the rest of Spain, [ci], [si] and [z] have different
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170969Z"^^xsd:dateTime .

oakcurric:misconception-los-las-mean
  a curric:Misconception ;
  curric:statement "'Los' and 'las' always mean 'the'."@en ;
  curric:correction """'Los' and 'las' mean 'the' in front of a plural noun but 'them' when they
  come before a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170975Z"^^xsd:dateTime .

oakcurric:misconception-spanish-que-translates
  a curric:Misconception ;
  curric:statement "In Spanish, 'que' always translates as 'that'."@en ;
  curric:correction """In Spanish, 'que' does not always translate as 'that'. For example, the
  phrase 'tengo que' translates as 'I have to'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171125Z"^^xsd:dateTime .

oakcurric:misconception-preterite-tense-er-ir-verbs
  a curric:Misconception ;
  curric:statement "In the preterite tense, er and -ir verbs have different endings."@en ;
  curric:correction """-er and -ir verbs share the same endings in the preterite: -í for 'I', -iste
  for 'you' and -ió for 'she, he, it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171155Z"^^xsd:dateTime .

oakcurric:misconception-hab-means-used
  a curric:Misconception ;
  curric:statement "'Había' only means 'there used to be' or 'there was'."@en ;
  curric:correction "'Había' means 'there used to be', 'there was' or 'there were'."@en ;
  dcterms:modified "2026-06-07T15:30:15.171163Z"^^xsd:dateTime .

oakcurric:misconception-best-way-learn-vocabulary-repeat
  a curric:Misconception ;
  curric:statement """The best way to learn vocabulary is to repeat the words and their meaning in
  your mind."""@en ;
  curric:correction """A method like look, say, cover, write, check can be more effective when
  learning vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171343Z"^^xsd:dateTime .
