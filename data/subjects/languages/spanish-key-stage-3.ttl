oakcurric:priorknowledge-3145-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know modal verbs 'deber', 'poder', 'querer' in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.079989Z"^^xsd:dateTime .

oakcurric:priorknowledge-3145-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know singular and plural persons of 'ser' in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.079995Z"^^xsd:dateTime .

oakcurric:priorknowledge-3145-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use 'cuando' as a relative pronoun."@en ;
  dcterms:modified "2026-06-07T15:29:23.080001Z"^^xsd:dateTime .

oakcurric:priorknowledge-3145-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the difference between 'ser' and 'estar'."@en ;
  dcterms:modified "2026-06-07T15:29:23.080006Z"^^xsd:dateTime .

oakcurric:priorknowledge-3145-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that some adjectives come before a noun."@en ;
  dcterms:modified "2026-06-07T15:29:23.080011Z"^^xsd:dateTime .

oakcurric:priorknowledge-3145-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form the present participle."@en ;
  dcterms:modified "2026-06-07T15:29:23.080016Z"^^xsd:dateTime .

oakcurric:priorknowledge-3122-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know 'tener' in singular and plural persons in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.102318Z"^^xsd:dateTime .

oakcurric:priorknowledge-3122-2
