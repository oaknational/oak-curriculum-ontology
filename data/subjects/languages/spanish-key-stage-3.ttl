  rdfs:label "Pupils know singular forms of possessive adjective 'vuestro'."@en ;
  dcterms:modified "2026-06-07T15:29:26.886097Z"^^xsd:dateTime .

oakcurric:priorknowledge-3146-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that if stress is on the final syllable, and it ends in any consonant
  except ‘n’ or ‘s’, then there will be no accent."""@en ;
  dcterms:modified "2026-06-07T15:29:26.886101Z"^^xsd:dateTime .

oakcurric:priorknowledge-3146-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that if stress is on the final syllable and the word ends in a vowel or
  ‘n’ or ‘s’, then there will be an accent."""@en ;
  dcterms:modified "2026-06-07T15:29:26.886105Z"^^xsd:dateTime .

oakcurric:priorknowledge-3146-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know 'ser' describes traits."@en ;
  dcterms:modified "2026-06-07T15:29:26.886109Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know singular persons of -ar, -er, -ir verbs in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:26.889272Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know what an infinitive is."@en ;
  dcterms:modified "2026-06-07T15:29:26.889298Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use 'para' with an infinitive to mean 'in order to'."@en ;
  dcterms:modified "2026-06-07T15:29:26.889304Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know to use subject pronouns when comparing people."@en ;
  dcterms:modified "2026-06-07T15:29:26.889308Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know Spanish uses the same tense for routine and ongoing actions, and that
  adverbs and context help decide which English tense to use."""@en ;
  dcterms:modified "2026-06-07T15:29:26.889313Z"^^xsd:dateTime .

oakcurric:priorknowledge-3128-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know 'para' also means 'for'."@en ;
  dcterms:modified "2026-06-07T15:29:26.889317Z"^^xsd:dateTime .

