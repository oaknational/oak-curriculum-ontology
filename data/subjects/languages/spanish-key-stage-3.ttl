  rdfs:label "I can use the present tense of -ar verbs to talk about what I do with others."@en ;
  dcterms:modified "2026-06-07T15:30:41.119899Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25901
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use direct object pronouns to show who is doing the action and who is
  receiving it."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120044Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25880
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use the verb ‘tener’ to talk about what I and others have."@en ;
  dcterms:modified "2026-06-07T15:30:41.120048Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25794
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use 'soy', 'eres' and 'es' to describe general traits."@en ;
  dcterms:modified "2026-06-07T15:30:41.120053Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25830
  a curric:PupilLessonOutcome ;
  rdfs:label "I can talk about what I and a friend in another school are able to do."@en ;
  dcterms:modified "2026-06-07T15:30:41.120058Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25911
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the singular forms of -ar verbs to describe what I and others do on
  holiday."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120062Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25956
  a curric:PupilLessonOutcome ;
  rdfs:label """I can talk about where someone goes or went using the correct form of 'ir' in
  Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120067Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25984
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe what was happening and what happened at work using the preterite and
  imperfect."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120072Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25916
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use demonstrative adjectives 'este', 'esta', 'estos' and 'estas' to ask a
  range of questions in shops."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120076Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25851
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe what people have using the verb 'tener'."@en ;
  dcterms:modified "2026-06-07T15:30:41.120197Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25954
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use -ar verbs in the 2nd person to talk about what is happening now and
  correctly use the direct object pronouns 'los' and 'las' to describe weekend activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120202Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25972
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use singular forms of the verb 'tener' to talk about film-making."@en ;
  dcterms:modified "2026-06-07T15:30:41.120329Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25895
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use -er and -ir preterite verbs to talk about what I and other did to live
  sustainably."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120352Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25990
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use imperfect tense verbs to understand and discuss an important work of
  Spanish literature, such as Don Quijote."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120357Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25845
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and use -er and -ir verbs to talk about what someone else does and
  what it is good to do in everyday life."""@en ;
  dcterms:modified "2026-06-07T15:30:41.120507Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-imperfect-tense
  a curric:Keyword ;
  schema:name "imperfect tense"@en ;
  schema:description "tense used to describe how things were or used to be in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.347280Z"^^xsd:dateTime .

oakcurric:keyword-final-syllable-stress
  a curric:Keyword ;
  schema:name "final syllable stress"@en ;
  schema:description """pronouncing the last syllable more heavily than other syllables in a
  word"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347436Z"^^xsd:dateTime .

oakcurric:keyword-penultimate-syllable-stress
  a curric:Keyword ;
  schema:name "penultimate syllable stress"@en ;
  schema:description """pronouncing the second-to-last syllable more heavily than other syllables in
  a word"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347440Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-simple-present
  a curric:Keyword ;
  schema:name "simple present"@en ;
  schema:description "verb tense used to express habitual events in the present e.g. 'I do'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347450Z"^^xsd:dateTime .

oakcurric:keyword-preterite
  a curric:Keyword ;
  schema:name "preterite"@en ;
  schema:description "verb tense used to express completed actions in the past e.g. 'I did'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347454Z"^^xsd:dateTime .

oakcurric:keyword-ir-a-infinitive
  a curric:Keyword ;
  schema:name "ir a + infinitive"@en ;
  schema:description "2-verb structure meaning ‘going to + infinitive'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347459Z"^^xsd:dateTime .

oakcurric:keyword-irregular-verb
  a curric:Keyword ;
  schema:name "irregular verb"@en ;
  schema:description "a verb that does not follow the regular rules"@en ;
  dcterms:modified "2026-06-07T15:30:02.347466Z"^^xsd:dateTime .

oakcurric:keyword-dar
  a curric:Keyword ;
  schema:name "dar"@en ;
  schema:description "-ar irregular verb meaning 'to give, giving'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347473Z"^^xsd:dateTime .

oakcurric:keyword-idiom
  a curric:Keyword ;
  schema:name "idiom"@en ;
  schema:description """a phrase or expression whose meaning we don't translate word-for-word, e.g.
  'it's raining cats and dogs'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347478Z"^^xsd:dateTime .

oakcurric:keyword-ir-de-noun
  a curric:Keyword ;
  schema:name "ir de + noun"@en ;
  schema:description "expression usually translated in English by 'to go + -ing'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347672Z"^^xsd:dateTime .

oakcurric:keyword-para
  a curric:Keyword ;
  schema:name "para"@en ;
  schema:description "word meaning 'for' or 'in order to'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347680Z"^^xsd:dateTime .

oakcurric:keyword-prenominal-adjectives
  a curric:Keyword ;
  schema:name "prenominal adjectives"@en ;
  schema:description "adjectives that go before the noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.347727Z"^^xsd:dateTime .

oakcurric:keyword-present
  a curric:Keyword ;
  schema:name "present"@en ;
  schema:description "describes habitual events in the present, e.g. ‘I do’"@en ;
  dcterms:modified "2026-06-07T15:30:02.347769Z"^^xsd:dateTime .

oakcurric:keyword-suffix
  a curric:Keyword ;
  schema:name "suffix"@en ;
  schema:description """a letter or group of letters added to the end of a word to change its
  meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348096Z"^^xsd:dateTime .

oakcurric:keyword-adjective
  a curric:Keyword ;
  schema:name "adjective"@en ;
  schema:description "describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.348100Z"^^xsd:dateTime .

oakcurric:keyword-noun
  a curric:Keyword ;
  schema:name "noun"@en ;
  schema:description "a naming word for people, places or things"@en ;
  dcterms:modified "2026-06-07T15:30:02.348107Z"^^xsd:dateTime .

oakcurric:keyword-verb
  a curric:Keyword ;
  schema:name "verb"@en ;
  schema:description "a doing, being or having word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348112Z"^^xsd:dateTime .

oakcurric:keyword-vocabulary
  a curric:Keyword ;
  schema:name "vocabulary"@en ;
  schema:description "the use of specific words and phrases to convey a meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.348165Z"^^xsd:dateTime .

oakcurric:keyword-subject
  a curric:Keyword ;
  schema:name "subject"@en ;
  schema:description """the noun, noun phrase or pronoun that does or is the main verb in the active
  voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348319Z"^^xsd:dateTime .

oakcurric:keyword-object
  a curric:Keyword ;
  schema:name "object"@en ;
  schema:description """the noun, noun phrase or pronoun that receives the action of the main verb
  in the active voice"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348328Z"^^xsd:dateTime .

oakcurric:keyword-adverb
  a curric:Keyword ;
  schema:name "adverb"@en ;
  schema:description "describes a verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348399Z"^^xsd:dateTime .

oakcurric:keyword-possessive-adjective
  a curric:Keyword ;
  schema:name "possessive adjective"@en ;
  schema:description "shows who something belongs to"@en ;
  dcterms:modified "2026-06-07T15:30:02.348725Z"^^xsd:dateTime .

oakcurric:keyword-mi
  a curric:Keyword ;
  schema:name "mi"@en ;
  schema:description "possessve adjective meaning 'my'"@en ;
  dcterms:modified "2026-06-07T15:30:02.348731Z"^^xsd:dateTime .

oakcurric:keyword-tu
  a curric:Keyword ;
  schema:name "tu"@en ;
  schema:description "possessve adjective meaning 'your'"@en ;
  dcterms:modified "2026-06-07T15:30:02.348736Z"^^xsd:dateTime .

oakcurric:keyword-genre
  a curric:Keyword ;
  schema:name "genre"@en ;
  schema:description "A genre is a category used to group different types of literature."@en ;
  dcterms:modified "2026-06-07T15:30:02.348775Z"^^xsd:dateTime .

oakcurric:keyword-syllable
  a curric:Keyword ;
  schema:name "syllable"@en ;
  schema:description "a single sound or beat in a word that contains a vowel sound"@en ;
  dcterms:modified "2026-06-07T15:30:02.348919Z"^^xsd:dateTime .

oakcurric:keyword-present-tense
  a curric:Keyword ;
  schema:name "present tense"@en ;
  schema:description "tells the reader the action is happening now"@en ;
  dcterms:modified "2026-06-07T15:30:02.349371Z"^^xsd:dateTime .

oakcurric:keyword-ce
  a curric:Keyword ;
  schema:name "[ce]"@en ;
  schema:description "sound-symbol correspondence"@en ;
  dcterms:modified "2026-06-07T15:30:02.349902Z"^^xsd:dateTime .

oakcurric:keyword-grammatical-gender
  a curric:Keyword ;
  schema:name "grammatical gender"@en ;
  schema:description "nouns in Spanish are either masculine or feminine"@en ;
  dcterms:modified "2026-06-07T15:30:02.349907Z"^^xsd:dateTime .

oakcurric:keyword-indefinite-article
  a curric:Keyword ;
  schema:name "indefinite article"@en ;
  schema:description "the words ‘un’ and ‘una’, meaning ‘a’ and ‘an’"@en ;
  dcterms:modified "2026-06-07T15:30:02.349911Z"^^xsd:dateTime .

oakcurric:keyword-direct-object-pronoun
  a curric:Keyword ;
  schema:name "direct object pronoun"@en ;
  schema:description """replaces the noun receiving the action of the verb e.g. me, you, it,
  them"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349927Z"^^xsd:dateTime .

oakcurric:keyword-present-participle
  a curric:Keyword ;
  schema:name "present participle"@en ;
  schema:description """a verb form used to show how something happens, something that is happening
  at the same time, or to give a reason for something"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349950Z"^^xsd:dateTime .

oakcurric:keyword-1st-person-singular
  a curric:Keyword ;
  schema:name "1st person singular"@en ;
  schema:description "form of pronouns and verbs used to refer to 'I'"@en ;
  dcterms:modified "2026-06-07T15:30:02.350037Z"^^xsd:dateTime .

oakcurric:keyword-3rd-person-singular
  a curric:Keyword ;
  schema:name "3rd person singular"@en ;
  schema:description "form of pronouns and verbs used to refer to 'she, he, it'"@en ;
  dcterms:modified "2026-06-07T15:30:02.350041Z"^^xsd:dateTime .

oakcurric:keyword-stem
  a curric:Keyword ;
  schema:name "stem"@en ;
  schema:description "part of the verb that appears in all forms"@en ;
  dcterms:modified "2026-06-07T15:30:02.350048Z"^^xsd:dateTime .

oakcurric:keyword-strong-vowel
  a curric:Keyword ;
  schema:name "strong vowel"@en ;
  schema:description """vowels that are always fully pronounced and don't glide into other sounds;
  the strong vowels are [a], [e] and [o]"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350052Z"^^xsd:dateTime .

oakcurric:keyword-stress
  a curric:Keyword ;
  schema:name "stress"@en ;
  schema:description "pronouncing one syllable more heavily than other syllables in a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.350057Z"^^xsd:dateTime .

oakcurric:keyword-preterite-tense
  a curric:Keyword ;
  schema:name "preterite tense"@en ;
  schema:description "a tense used for events completed in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.350061Z"^^xsd:dateTime .

oakcurric:keyword-subject-pronoun
  a curric:Keyword ;
  schema:name "subject pronoun"@en ;
  schema:description """represents the person, people or thing(s) doing the verb e.g. I, we,
  they"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350066Z"^^xsd:dateTime .

oakcurric:keyword-diphthong
  a curric:Keyword ;
  schema:name "diphthong"@en ;
  schema:description "sound created by two vowels together in the same syllable"@en ;
  dcterms:modified "2026-06-07T15:30:02.350071Z"^^xsd:dateTime .

oakcurric:keyword-ser
  a curric:Keyword ;
  schema:name "ser"@en ;
  schema:description "verb meaning to be, being for general traits"@en ;
  dcterms:modified "2026-06-07T15:30:02.350075Z"^^xsd:dateTime .

oakcurric:keyword-ir
  a curric:Keyword ;
  schema:name "ir"@en ;
  schema:description "verb meaning to go, going"@en ;
  dcterms:modified "2026-06-07T15:30:02.350082Z"^^xsd:dateTime .

oakcurric:keyword-strong-vowels
  a curric:Keyword ;
  schema:name "strong vowels"@en ;
  schema:description "the letters [a], [e] and [o]"@en ;
  dcterms:modified "2026-06-07T15:30:02.350088Z"^^xsd:dateTime .

oakcurric:keyword-question-words
  a curric:Keyword ;
  schema:name "question words"@en ;
  schema:description """words used to ask for specific information in a question, e.g. 'what',
  'where', 'when'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350093Z"^^xsd:dateTime .

oakcurric:keyword-indirect-object-pronoun-iop
  a curric:Keyword ;
  schema:name "indirect object pronoun (IOP)"@en ;
  schema:description """replaces the person, people or thing(s) that the verb action is done to,
  when the action is to me, for you"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350200Z"^^xsd:dateTime .

oakcurric:keyword-infinitive
  a curric:Keyword ;
  schema:name "infinitive"@en ;
  schema:description """the basic form of the verb, with no particular subject or tense
  indicated"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350224Z"^^xsd:dateTime .

oakcurric:keyword-modal-verbs
  a curric:Keyword ;
  schema:name "modal verbs"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350378Z"^^xsd:dateTime .

oakcurric:keyword-indirect-object-pronoun
  a curric:Keyword ;
  schema:name "indirect object pronoun"@en ;
  schema:description """replaces the person, people or thing(s) that the verb action is done to,
  when the action is to me, from you, with them; takes the dative case"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350524Z"^^xsd:dateTime .

oakcurric:keyword-adjective-agreement
  a curric:Keyword ;
  schema:name "adjective agreement"@en ;
  schema:description """when the ending of an adjective matches the noun it describes in gender and
  number"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350555Z"^^xsd:dateTime .

oakcurric:keyword-intonation
  a curric:Keyword ;
  schema:name "intonation"@en ;
  schema:description "rise and fall of the voice in speaking"@en ;
  dcterms:modified "2026-06-07T15:30:02.350568Z"^^xsd:dateTime .

oakcurric:keyword-1st-person-plural
  a curric:Keyword ;
  schema:name "1st person plural"@en ;
  schema:description "form of pronouns and verbs used to refer to 'we'"@en ;
  dcterms:modified "2026-06-07T15:30:02.350788Z"^^xsd:dateTime .

oakcurric:keyword-hago
  a curric:Keyword ;
  schema:name "hago"@en ;
  schema:description "I do, part of the verb 'hacer' meaning to do and to make"@en ;
  dcterms:modified "2026-06-07T15:30:02.350802Z"^^xsd:dateTime .

oakcurric:keyword-haces
  a curric:Keyword ;
  schema:name "haces"@en ;
  schema:description "you do, part of the verb 'hacer' meaning to do and to make"@en ;
  dcterms:modified "2026-06-07T15:30:02.350809Z"^^xsd:dateTime .

oakcurric:keyword-hace
  a curric:Keyword ;
  schema:name "hace"@en ;
  schema:description "she, he, it does, part of the verb 'hacer' meaning to do and to make"@en ;
  dcterms:modified "2026-06-07T15:30:02.350816Z"^^xsd:dateTime .

oakcurric:keyword-v
  a curric:Keyword ;
  schema:name "[v]"@en ;
  schema:description "pronounced as in 'vor'"@en ;
  dcterms:modified "2026-06-07T15:30:02.350906Z"^^xsd:dateTime .

oakcurric:keyword-definite-article
  a curric:Keyword ;
  schema:name "definite article"@en ;
  schema:description "the words 'der', 'die', 'das', meaning 'the'"@en ;
  dcterms:modified "2026-06-07T15:30:02.350954Z"^^xsd:dateTime .

oakcurric:keyword-comparative
  a curric:Keyword ;
  schema:name "comparative"@en ;
  schema:description "form of adjective or adverb used to compare people, things or ideas"@en ;
  dcterms:modified "2026-06-07T15:30:02.351204Z"^^xsd:dateTime .

oakcurric:keyword-mejor-que
  a curric:Keyword ;
  schema:name "mejor que"@en ;
  schema:description "comparative structure in Spanish meaning 'better than'"@en ;
  dcterms:modified "2026-06-07T15:30:02.351211Z"^^xsd:dateTime .

oakcurric:keyword-peor-que
  a curric:Keyword ;
  schema:name "peor que"@en ;
  schema:description "comparative structure in Spanish meaning 'worse than'"@en ;
  dcterms:modified "2026-06-07T15:30:02.351216Z"^^xsd:dateTime .

oakcurric:keyword-de
  a curric:Keyword ;
  schema:name "de"@en ;
  schema:description """Spanish preposition meaning 'from' and 'of', also used to express
