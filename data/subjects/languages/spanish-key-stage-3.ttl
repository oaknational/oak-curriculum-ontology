# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-25985-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a single 'r' appears within or at the end of a word, it is usually not
  rolled."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25985-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word begins with a single 'r', it is rolled, just like 'rr'."@en ;
  dcterms:modified "2026-06-07T15:30:28.998861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25985-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that used to happen repeatedly in the past, we use the
  imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25985-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Dar' usually translates as 'to give' but it is also used to describe how something
  makes people feel."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25987-1
  a curric:KeyLearningPoint ;
  rdfs:label """The -y at the end of an English word often changes to -ía or -ia in Spanish. e.g.
  energy - energía."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25987-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ía stress the final syllable and need an accent to show that, e.g.
  energía."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25987-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ia stress the penultimate syllable and need no accent, e.g.
  ciencia."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25987-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'querer', 'poder' and 'deber' are modal verbs and are often followed by an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25987-5
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that used to happen repeatedly in the past, we use the
  imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25883-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'dar' means 'to give, giving'. It is an irregular verb in its 1st person
  singular 'I' form, 'doy'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25883-2
  a curric:KeyLearningPoint ;
  rdfs:label "The other present tense forms of 'dar' are regular."@en ;
  dcterms:modified "2026-06-07T15:30:28.999057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25883-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'dar' can also be used to describe how something makes people feel. English
  uses 'to be' + adjective for this."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25883-4
  a curric:KeyLearningPoint ;
  rdfs:label "These 'dar' + noun expressions are idioms, i.e. not translated word-for-word."@en ;
  dcterms:modified "2026-06-07T15:30:28.999066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25887-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [cua] is pronounced as in the word 'cuatro', [cue] as in 'escuela' and [cui]
  as in 'cuidar'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25887-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [que] is pronounced as in the word '¿por qué?' and [qui] as in 'equipo'."@en ;
  dcterms:modified "2026-06-07T15:30:28.999230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25887-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about an informal plan with a specific purpose, we use the expression 'ir de
  + noun'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25887-4
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about future plans we use the verb 'ir + a + infinitive', e.g.
  'voy/vas/va/vamos/van a estudiar'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25887-5
  a curric:KeyLearningPoint ;
  rdfs:label """The word 'para' if followed by a noun translates as 'for', but if followed by a
  verb, translates as 'in order to'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25877-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the final syllable is stressed and the word ends in a vowel or 'n' or 's' there
  is an accent on the final vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25877-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of -er and -ir verbs in preterite ends in -í, e.g.
  'elegí'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25877-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of -er and -ir verbs in present ends in -o, e.g.'
  elijo'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25877-4
  a curric:KeyLearningPoint ;
  rdfs:label """Usually Spanish adjectives come after the noun, except for prenominal adjectives
  which come before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25892-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound symbol correspondence [que] is pronounced as in the word '¿por qué? and
  [cue] as in 'cuerpo'."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25892-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Saber’ and ‘conocer’ are both used to mean ‘know’. ‘Saber’ means knowing facts or
  how to do something."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25892-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Conocer’ means being familiar with or getting to know a person, place or thing."@en ;
  dcterms:modified "2026-06-07T15:30:28.999386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25892-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular of -ER/-IR in the present tense ends in -e."@en ;
  dcterms:modified "2026-06-07T15:30:28.999391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25892-5
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular of -ER/-IR in the preterite ends in -ió."@en ;
  dcterms:modified "2026-06-07T15:30:28.999395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25931-1
  a curric:KeyLearningPoint ;
  rdfs:label """La Tomatina is an annual Spanish festival that celebrates the tomato harvest in
  Buñol, Valencia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25931-2
  a curric:KeyLearningPoint ;
  rdfs:label "Present tense -ar verbs in the 1st person singular end in -o."@en ;
  dcterms:modified "2026-06-07T15:30:29.002247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25931-3
  a curric:KeyLearningPoint ;
  rdfs:label "Preterite tense -ar verbs in the 3rd person singular end in -ó."@en ;
  dcterms:modified "2026-06-07T15:30:29.002251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25931-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'comenzar' is a stem-changing verb ('e' - 'ie') for 'I', 'you', 'she, he,
  it' and 'they' in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25865-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the SSC sounds [a], [e] and [o] appear together, they are pronounced
  separately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25865-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular preterite of -ar verbs ends in -é and 2nd person singular
  preterite in -aste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25865-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular present of -ar verbs ends in -as."@en ;
  dcterms:modified "2026-06-07T15:30:29.002335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25865-4
  a curric:KeyLearningPoint ;
  rdfs:label """Question words are used to ask for specific information, e.g. '¿dónde?,
  '¿cómo?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25886-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [cua] is pronounced as in the word 'cuatro', [cue] as in 'escuela' and [cui]
  as in 'cuidar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25886-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about future plans we use the verb 'ir' + a + infinitive, e.g. 'voy/vas/va a
  estudiar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25886-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ir' is often followed by 'al' or 'a la'. We use 'al' with masculine nouns
  and 'a la' with feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25915-1
  a curric:KeyLearningPoint ;
  rdfs:label """'More ... than' in Spanish is 'más' + adjective + 'que', e.g. 'Nadia está más feliz
  que Lucía'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25915-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Less ... than' is 'menos' + adjective + 'que', e.g. 'las tías están menos enojadas
  que Ana'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25915-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'better than', use 'mejor que', e.g. 'la segunda canción es mejor que la
  primera'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25915-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'worse than', use 'peor que', e.g. 'el vestido es peor que la camisa'."@en ;
  dcterms:modified "2026-06-07T15:30:29.004719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25915-5
  a curric:KeyLearningPoint ;
  rdfs:label """To show possession in Spanish, use possession + 'de' + owner, e.g. 'el amigo de
  Daniel' - 'Daniel's friend'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25900-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ñ] is pronounced as in 'español' and [n] as in
  'mano'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25900-2
  a curric:KeyLearningPoint ;
  rdfs:label "MAP is a useful strategy to learn vocabulary in a meaningful way."@en ;
  dcterms:modified "2026-06-07T15:30:29.005074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25900-3
  a curric:KeyLearningPoint ;
  rdfs:label "In sentences, the subject does the action and the object receives it."@en ;
  dcterms:modified "2026-06-07T15:30:29.005078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25900-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are two frequently used word orders in Spanish: subject + verb + object and
  object + verb + subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25900-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use the personal ‘a’ before the object if it’s a person or animal."@en ;
  dcterms:modified "2026-06-07T15:30:29.005086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25857-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding and composing sentences using familiar words helps to deepen
  vocabulary knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25857-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present tense of ‘ir’ to say where we routinely go, e.g. 'Voy a la
  plaza'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25857-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present tense of 'ir' followed by 'a' and a 2nd verb infinitive to
  express future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25857-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to pay attention to the difference between present and future
  meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25945-1
  a curric:KeyLearningPoint ;
  rdfs:label """If a word has a stress on the antepenultimate syllable there will always be an
  accent on the stressed vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25945-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gustar-type verbs are used with an indirect object pronoun because they show an
  effect on someone or something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25945-3
  a curric:KeyLearningPoint ;
  rdfs:label """Other gustar-type verbs are 'molestar', 'importar', 'interesar', 'preocupar',
  'alegrar', 'gustar' and 'encantar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25945-4
  a curric:KeyLearningPoint ;
  rdfs:label """When an infinitive is used as a subject, we refer to it as ‘it’, so we must use the
  '-a' ending for gustar-type verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25893-1
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' in the preterite with -er/-ir verbs, we remove -er/-ir and add -í, -iste
  for 'you' and -ió for 'she, he,it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25893-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish subject pronouns add emphasis or clarity when comparing different
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25893-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish singular subject pronouns are: 'yo' ('I'), 'tú' ('you'), 'él' ('he') and
  'ella' ('she')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25893-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives usually come after the noun; however, certain prenominal adjectives come
  before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25893-5
  a curric:KeyLearningPoint ;
  rdfs:label """Prenominal adjectives 'primero' and 'tercero' drop the -o before a masculine
  singular noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25939-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular (I) of regular -ar verbs like 'lavar' ends in -o, the 2nd
  person singular (you) ends in -as."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some Spanish verbs like 'despertar' have a stem change -e to -ie in some forms. For
  example: 'despierto' (I wake up)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25939-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say that I do something to myself in Spanish we use the reflexive pronoun 'me':
  'me presento' (I introduce myself)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25939-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say that you do something to yourself, use reflexive pronoun 'te' before the
  verb: 'te llamas' ('you call yourself')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25939-5
  a curric:KeyLearningPoint ;
  rdfs:label """The reflexive pronouns 'me' and 'te' look similar to the possessive pronouns 'mi'
  and 'tu' but they are different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25929-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a word has a stress on the antepenultimate syllable, it always has a written
  accent to show where the stress falls."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25929-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say what is happening right now, Spanish uses the present continuous which is a
  form of 'estar' + present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25929-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form -er/-ir verb present participles, remove -er/-ir from the infinitive and add
  -iendo, e.g. 'están traduciendo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25929-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'querer' is a modal verb and means 'to want' or 'to love'. To say 'they
  want', we use 'quieren'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25929-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Querer' is commonly used before an infinitive, to mean 'to want to', e.g. 'quieren
  conducir' ('they want to drive')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25925-1
  a curric:KeyLearningPoint ;
  rdfs:label """For words ending in a vowel, -n or -s, if the stress is on the final syllable, an
  accent is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25925-2
  a curric:KeyLearningPoint ;
  rdfs:label """For words ending in a vowel, -n or -s, if the stress is on the penultimate syllable,
  no accent is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple present verb endings change depending on who it refers to: -o ('I'), -as/-es
  ('you'), -amos/-emos/-imos ('we')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25925-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses the simple present for actions or plans happening today, while English
  uses the present continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25971-1
  a curric:KeyLearningPoint ;
  rdfs:label "Preterite-tense -ar verbs have the ending -amos in the 1st person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.255943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25971-2
  a curric:KeyLearningPoint ;
  rdfs:label "Preterite-tense -ar verbs have the ending -aron in the 3rd person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.255947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25971-3
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive adjective 'nuestro' means 'our' and agrees with the noun in gender
  and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25971-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Nuestro' refers to a singular masculine noun and 'nuestra' refers to a singular
  feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25971-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Nuestros' refers to a plural masculine noun and 'nuestras' refers to a plural
  feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25873-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rules about penultimate (syllable) stress tell us if we need to write an accent on
  the penultimate vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25873-2
  a curric:KeyLearningPoint ;
  rdfs:label """Applying knowledge about syllable stress helps to remember how to say words that we
  may have forgotten how to pronounce."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25873-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Deber' is a modal verb meaning 'to have to, must'. It is conjugated as a regular
  -er verb; the 'we' form is 'debemos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25873-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb deber is always followed by an infinitive, e.g. 'Siempre debemos decir la
  verdad.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.255999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25870-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the stress is on the final syllable of a word ending in 'n' or 's' or a vowel,
  there is an accent on the last vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25870-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in other consonants have final syllable stress and no accent, e.g.
  'genial'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25870-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hacer' means 'to do, make'. It is irregular in its 'I' form only; 'I do, I make' is
  'hago'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25870-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Hacer' combines with many nouns to make common verb-noun phrases, e.g. 'Hago un
  esfuerzo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25870-5
  a curric:KeyLearningPoint ;
  rdfs:label """Subject pronouns add emphasis or clarity in Spanish; they are often used to contrast
  the actions of different people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26008-1
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -er verbs, the verb ending -emos refers to 'we' in the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26008-2
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -er verbs, the verb ending -imos refers to 'we' in the preterite
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26008-3
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -ir verbs, the verb ending -imos refers to 'we' in the present and
  preterite tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26008-4
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -ar verbs, the verb ending -amos refers to 'we' in the present and
  preterite tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25996-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs ending in –cer or –cir have a spelling change in the 1st person
  singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25996-2
  a curric:KeyLearningPoint ;
  rdfs:label """IOPs indicate who is affected by the verb; 'le' for 'to, for him, her', and 'les'
  for 'to, for them'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25996-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gustar-type verbs use IOPs because they show an effect on someone or something."@en ;
  dcterms:modified "2026-06-07T15:30:29.258859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25996-4
  a curric:KeyLearningPoint ;
  rdfs:label """These verbs end in -a for singular subjects and -an for plural - 'el libro les
  interesa', 'los libros les interesan'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25996-5
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish an infinitive can be used as the subject in a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.258866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25941-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish words ending in a vowel, -n, or -s naturally have penultimate syllable
  stress, e.g. 'vamos' and 'mundo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25941-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a word ending in a different consonant has penultimate syllable stress, there is
  an accent on the stressed vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some Spanish verbs have a completely different meaning when used with a reflexive
  pronoun, e.g. 'quedar' and 'quedarse'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The reflexive pronoun 'se' means 'himself', 'herself' or 'itself' before a verb,
  e.g. 'se lava' ('he washes himself')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25941-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'his', 'her', 'its' before a noun we use the possessive adjectives 'su' (m, f
  singular) or 'sus' (m, f plural)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25812-1
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article is used to introduce a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.259086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25812-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular definite article in Spanish is 'el' with masculine nouns and 'la' with
  feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25816-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'querer' means 'want wanting' and it's used to talk about what things we
  want."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25816-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Quiero' means 'I want'; 'quieres' means 'you want'; 'quiere' means she, he, it
  wants'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25816-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'querer' is often followed by an indefinite article 'un/una/unos/unas'."@en ;
  dcterms:modified "2026-06-07T15:30:29.259540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25871-1
  a curric:KeyLearningPoint ;
  rdfs:label """Applying the two rules about final syllable stress enables correct use of accents
  when transcribing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25871-2
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to familiar language in new contexts and transcribing it deepens
  vocabulary knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25871-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hacer', irregular in its I form ‘hago’, is regular in other forms. We do, make is
  ‘hacemos’, they do, make is ‘hacen’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25871-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish subject pronouns add emphasis or clarity, e.g. nosotros hacemos los deberes,
  mientras que ellas hacen deporte."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25871-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘We’ is nosotros for boys/men or mixed gender groups, nosotras for girls/women;
  ‘they’ also has two forms, ellos, ellas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26001-1
  a curric:KeyLearningPoint ;
  rdfs:label """In sounds like [cua], [cue] and [cui] the 'u' is not silent, but it combines with
  the 'c' to make a 'kw' sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26001-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say ‘that’ for a singular masculine noun, use ‘ese’, e.g. 'ese libro'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26001-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say ‘those’ for a plural masculine noun, use ‘esos’, e.g. 'esos libros'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26001-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say ‘that’ for a singular feminine noun, use ‘esa’, e.g. 'esa bebida'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26001-5
  a curric:KeyLearningPoint ;
  rdfs:label "To say ‘those’ for a plural feminine noun, use ‘esas’, e.g. 'esas bebidas'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25936-1
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to express completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.260633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25936-2
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate singular forms of the preterite tense for regular -er/-ir verbs, remove
  -er/-ir and add -í, -iste, -ió."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25936-3
  a curric:KeyLearningPoint ;
  rdfs:label """Common interrogatives in Spanish are: '¿dónde?', '¿cuándo?', '¿cuánto?', '¿quién?',
  '¿qué?', '¿por qué?', '¿cómo?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25872-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to words with final and penultimate syllable stress helps to develop the
  ability to identify the stress."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25872-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making vocabulary links using antonyms or words with related meanings can enhance
  recall."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25872-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'poder' is a modal verb and means 'to be able to', 'can'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25872-4
  a curric:KeyLearningPoint ;
  rdfs:label """Most present tense forms of 'poder' have a vowel change in the stem, ('puedo');
  'podemos' (we can) has no vowel change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25872-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'poder' is always followed by an infinitive, e.g. 'Podemos participar en
  clase.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25938-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish words ending in consonants other than -n and -s naturally have final
  syllable stress."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25938-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a word has final syllable stress and ends in -n or -s or a vowel, there will be
  an accent on the final vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25938-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'my' before a singular noun, use 'mi', before a plural noun use 'mis', e.g.
  'mi revista' and 'mis zapatos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25938-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'your' before a singular noun, use 'tu', before a plural noun use 'tus', e.g.
  'tu familia' and 'tus amigos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25938-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of location are often followed by 'de'. For a singular masculine noun,
  change 'de' + 'el' to 'del'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25861-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the SSCs [ce], [ci], and [z] are pronounced differently in different
  parts of the Spanish-speaking world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25861-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ir + a + infinitive' is a 2-verb structure used to say what someone is
  going to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25861-3
  a curric:KeyLearningPoint ;
  rdfs:label "A question is ‘closed’ when its answer is either ‘yes’ or ‘no’."@en ;
  dcterms:modified "2026-06-07T15:30:29.260958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25861-4
  a curric:KeyLearningPoint ;
  rdfs:label """A statement is changed into an intonation question in Spanish simply by raising the
  tone of voice at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25835-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' is used to talk about location."@en ;
  dcterms:modified "2026-06-07T15:30:29.261544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25835-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person plural of the verb 'estar' is 'estamos' and it means 'we are'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25835-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person plural of the verb 'estar' is 'están' and it means 'they are'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25849-1
  a curric:KeyLearningPoint ;
  rdfs:label "Verb endings change depending on the person they refer to."@en ;
  dcterms:modified "2026-06-07T15:30:29.261557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25849-2
  a curric:KeyLearningPoint ;
  rdfs:label "3rd person singular -er and -ir verbs end in -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.261563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25849-3
  a curric:KeyLearningPoint ;
  rdfs:label "3rd person plural -er and -ir verbs end in -en."@en ;
  dcterms:modified "2026-06-07T15:30:29.261567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25849-4
  a curric:KeyLearningPoint ;
  rdfs:label """Turn any statement into a closed or yes/no question using raised intonation; the
  word order stays the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25894-1
  a curric:KeyLearningPoint ;
  rdfs:label """When revisiting vocabulary it's important to revise different parts of speech:
  verbs, nouns, adjectives, adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25894-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs communicate actions or states, e.g. -ar verbs - 'sacar', -er verbs -
  'recoger', -ir verbs - 'subir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25894-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives give information about a noun (person, place, thing). Prenominal
  adjectives go before the noun; most follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25894-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs describe a verb or an adjective, e.g. adverbs of frequency - 'por la tarde’
  or adverbs of place - ‘lejos (de)'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25894-5
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' for a preterite verb, we remove the -ar and add -é, for 'you' we add
  -aste, and for ‘she, he, it’ we add -ó."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25850-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the Canary Islands, Latin America and parts of Spain, the sounds [ci] and [si]
  are pronounced the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25850-2
  a curric:KeyLearningPoint ;
  rdfs:label "The definite articles 'el', 'la', 'los' and 'las' translate as 'the' in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.262730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25850-3
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite articles 'un', 'una', 'unos' and 'unas' translate as 'a/an' and
  'some' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25850-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are two ways to say 'they are': 'están' for location and temporary state/mood,
  and 'son' for permanent traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25799-1
  a curric:KeyLearningPoint ;
  rdfs:label """Raise your voice at the end of a statement to ask a yes/no question with 'tener'.
  ‘¿Tienes …?’ is ‘Do you have?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25799-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Qué' means 'what'; to ask ‘What do you have?’ use ‘¿Qué tienes?’."@en ;
  dcterms:modified "2026-06-07T15:30:29.264076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25799-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Unas' is 'some' for plural feminine nouns; 'unos' is ‘some’ for plural masculine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25799-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conversations involve careful listening and knowing vocabulary securely, especially
  key verbs 'estar', 'ser', 'tener'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25875-1
  a curric:KeyLearningPoint ;
  rdfs:label """Applying knowledge about syllable stress reminds us how to pronounce words we have
  not used for some time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25875-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recalling vocabulary with a partner is very effective, especially if we can support
  each other with accurate stress."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25875-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conjugated verbs in the present tense have different stress from their
  infinitives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25875-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses the simple present for habitual actions, e.g. 'Siempre hago' - 'I
  always do'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25875-5
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish also uses the simple present for today’s immediate plans, e.g. 'Hoy hago' -
  'Today I am doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25907-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter 'h' is silent in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.264109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25907-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two frequently used word orders in Spanish: subject + verb + object and
  object + verb + subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25907-3
  a curric:KeyLearningPoint ;
  rdfs:label "The personal 'a' appears before the object if it’s a person or an animal."@en ;
  dcterms:modified "2026-06-07T15:30:29.264118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25969-1
  a curric:KeyLearningPoint ;
  rdfs:label "Present-tense -er and -ir verbs have the ending -e in the 3rd person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.264975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25969-2
  a curric:KeyLearningPoint ;
  rdfs:label "Present-tense -er and -ir verbs have the ending -en in the 3rd person plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.264979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25969-3
  a curric:KeyLearningPoint ;
  rdfs:label "The possessive adjective 'mi' means 'my' and 'tu' means 'your'."@en ;
  dcterms:modified "2026-06-07T15:30:29.264982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25969-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Mi’ and ‘tu’ appear before a singular or uncountable noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.264986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25969-5
  a curric:KeyLearningPoint ;
  rdfs:label "‘Mis’ and ‘tus’ appear before a plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.264990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25904-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, r is pronounced differently depending on its position in the word and
  whether it is single or double."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word-initial 'r' is rolled and pronounced as in 'rojo'. It sounds identical to the
  'rr' in 'perro'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25904-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Gustar'-type verbs commonly appear after the indirect object pronoun 'me'."@en ;
  dcterms:modified "2026-06-07T15:30:29.265158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25904-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Gustar'-type verbs agree with the subject in number: -a for a singular noun and -an
  for a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25948-1
  a curric:KeyLearningPoint ;
  rdfs:label "2nd person verbs refer to 'you' (singular or plural)."@en ;
  dcterms:modified "2026-06-07T15:30:29.265620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25948-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form 2nd person singular -ar verbs in the present tense, use the verb
  ending -as."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25948-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form 2nd person plural -ar verbs in the present tense, use the verb
  ending -áis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25837-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence [ce] is pronounced as in 'cerca'."@en ;
  dcterms:modified "2026-06-07T15:30:29.267282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25837-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence [ci] is pronounced as in 'cierto'."@en ;
  dcterms:modified "2026-06-07T15:30:29.267286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25837-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means 'to be, being' and is used for permanent traits. 'Son' means
  'they are'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25837-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' means 'to be, being' and is used for temporary states. 'Están'
  means 'they are'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25837-5
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, adjectives must always agree in gender and number with the nouns they
  refer to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25889-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ce] is pronounced as in the word 'centro' and [ci]
  as in the word 'decir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25889-2
  a curric:KeyLearningPoint ;
  rdfs:label """The present simple of -AR verbs is used to talk about habits and routines, e.g.
  'trabajo', 'trabajas', 'trabaja'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25889-3
  a curric:KeyLearningPoint ;
  rdfs:label """The present continuous of -AR verbs is formed with the verb 'estar' + present
  participle (-ando)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25889-4
  a curric:KeyLearningPoint ;
  rdfs:label """The present continuous of -ER verbs is formed with the verb 'estar' + present
  participle (-iendo)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25889-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo we can include information such as who is in the photo, what
  they are doing and where they are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25960-1
  a curric:KeyLearningPoint ;
  rdfs:label """The [h] in Spanish is not pronounced. However, [ch] is always pronounced like the
  [ch] in 'coche' (car)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25960-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Spanish verb 'hacer' means 'to do, doing' or 'to make, making'."@en ;
  dcterms:modified "2026-06-07T15:30:29.267988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25960-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of 'hacer' are 'hago' ('I do/make'), 'haces' ('you do/make') and
  'hace' ('she, he does/makes')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25960-4
  a curric:KeyLearningPoint ;
  rdfs:label """The present tense is used in Spanish to indicate routine activities and immediate
  plans for today."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25960-5
  a curric:KeyLearningPoint ;
  rdfs:label """Time adverbs help to correctly translate, e.g. 'siempre' (always) for routines and
  'hoy' (today) for immediate plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25890-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ce], [ci] and [z] sound like the 'th' in 'think' in most of Spain, and 's' in Latin
  America and the Canary Islands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25890-2
  a curric:KeyLearningPoint ;
  rdfs:label """Listening deepens vocabulary knowledge and speeds up processing, supported by six
  pre-, in- and post-listening steps."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25890-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Mucho' and 'poco' are both adverbs and adjectives. Adverb endings don't change,
  adjective endings match the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish -ar verb endings change depending on who the verb refers to and when the
  action takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25890-5
  a curric:KeyLearningPoint ;
  rdfs:label """1st person singular present tense -ar verbs end in -o. 3rd person singular preterite
  verbs end in -ó."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25874-1
  a curric:KeyLearningPoint ;
  rdfs:label """Applying knowledge about syllable stress reminds us how to say words that we may
  have forgotten how to pronounce."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25874-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud accurately supports our own and others’ vocabulary learning."@en ;
  dcterms:modified "2026-06-07T15:30:29.269067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25874-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can say we know a verb when we can compose sentences of our own with its
  different persons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25874-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb endings for Spanish -er and -ir verbs are the same for 'I', 'you
  (singular)', 'she', 'he', 'it' and 'they'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25874-5
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person plural ‘we’ ending for -ir verbs is -imos; for -er verbs it
  is -emos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25970-1
  a curric:KeyLearningPoint ;
  rdfs:label """Preterite-tense -er and -ir verbs have the ending -ió in the 3rd person
  singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25970-2
  a curric:KeyLearningPoint ;
  rdfs:label """Preterite-tense -er and -ir verbs have the ending -ieron in the 3rd person
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25970-3
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive adjective 'nuestro' means 'our' and agrees with the noun in gender
  and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25970-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Nuestro' refers to a singular masculine noun and 'nuestra' refers to a singular
  feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25970-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Nuestros' refers to a plural masculine noun and 'nuestra' refers to a plural
  feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25932-1
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite is used for completed past events; two key irregular verbs are 'ir'
  and 'hacer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25932-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Fui', 'fuiste' and 'fue' mean 'I went, 'you went' and 'she, he, it went'
  respectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25932-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hice', 'hiciste' and 'hizo' mean 'I did, made', 'you did, made' and 'she, he, it
  did, made' respectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25932-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is no word in Spanish for ‘on’ before a day of the week. Instead, the definite
  articles 'el' and 'los' are used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25942-1
  a curric:KeyLearningPoint ;
  rdfs:label """We use direct object pronouns to avoid repeating nouns. In Spanish they usually go
  before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25942-2
  a curric:KeyLearningPoint ;
  rdfs:label "Masculine DOPs are ‘lo’, meaning ‘him' or 'it’, and ‘los’, meaning ‘them’."@en ;
  dcterms:modified "2026-06-07T15:30:29.270396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25942-3
  a curric:KeyLearningPoint ;
  rdfs:label "Feminine DOPs are ‘la’, meaning ‘her' or 'it’, and ‘las’, meaning ‘them’."@en ;
  dcterms:modified "2026-06-07T15:30:29.270400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25942-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs ‘probar’, ‘costar’ and ‘soler’ are stem changing verbs. When conjugated,
  their stem changes from 'o' to 'ue'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25949-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diphthong is a sound formed by the combination of two vowels in one syllable."@en ;
  dcterms:modified "2026-06-07T15:30:29.270869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25949-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say you (sg) are doing something with an -ar verb, use 'estás' + a verb ending in
  -ando."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25949-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say you (pl) are doing something with an -ar verb, use 'estáis' + a verb ending
  in -ando."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25797-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish alphabet has 27 letters, including the letter ñ which is not in the
  English alphabet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25797-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish alphabet letter names have patterns: letter + e, e + letter + e. There
  are eight irregular letter names."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25797-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular verb forms of 'tener' are: 'tengo' - I have, 'tienes' - you have,
  'tiene' - she, he, it has."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25796-1
  a curric:KeyLearningPoint ;
  rdfs:label """[l] sounds the same in English and Spanish, but [ll] sounds different in
  Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25796-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns and indefinite articles have grammatical gender in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.279331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25796-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most masculine nouns end in 'o' and most feminine nouns end in 'a'."@en ;
  dcterms:modified "2026-06-07T15:30:29.279335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25796-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Un' means a/an with masculine nouns, and 'una' is a/an with feminine nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.279338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25965-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular -ar verb ending in the present tense is -o, e.g. 'actaco' (I
  attack)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25965-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular ending in the preterite tense is very similar: -ó, e.g.
  'atacó' (he, she, it attacked)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25965-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person plural ending in the preterite is -aron, e.g. 'atacaron' (they
  attacked)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25965-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the Incas and the Spanish invaders first met there were communication problems
  which led to bloodshed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25965-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thousands of indigenous people were killed, as well as the last king Atahualpa, and
  the Incan empire was destroyed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25791-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [o] is pronounced as in 'yo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.286612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25791-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Estar' means 'to be, being' and is used for location."@en ;
  dcterms:modified "2026-06-07T15:30:29.286616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25791-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Estoy', 'estás' and 'está' are the 1st, 2nd and 3rd person singular forms of
  'estar.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.286620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25803-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ce] and [ci] are pronounced as in 'centro' and 'decir'."@en ;
  dcterms:modified "2026-06-07T15:30:29.302790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25803-2
  a curric:KeyLearningPoint ;
  rdfs:label "[cue], [cua] and [cui] are pronounced as in 'cuerpo', 'cuatro', and 'cuidar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.302794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25803-3
  a curric:KeyLearningPoint ;
  rdfs:label "Regular -ar verbs in the 2nd person singular end in -as."@en ;
  dcterms:modified "2026-06-07T15:30:29.302797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25803-4
  a curric:KeyLearningPoint ;
  rdfs:label "The stem is the part of the verb that appears in all forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.302801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25803-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use verb endings correctly when asking and answering information
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25867-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weak vowel [i] when next to  [a], [e] and [o] become a single syllable."@en ;
  dcterms:modified "2026-06-07T15:30:29.309431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25867-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means 'to, be, being' and it is used to describe permanent
  traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25867-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' means 'to, be, being' and it is used to describe temporary
  states/moods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25867-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, adjectives must agree with the nouns they accompany in gender and
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25854-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sounds [b] and [v] are pronounced the same in Spanish, as in 'celebrar' and
  'ver'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25854-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ir' is irregular and it means 'to go, going'."@en ;
  dcterms:modified "2026-06-07T15:30:29.309451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25854-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular 'I go' is 'voy'. The 3rd person singular 'she/he goes' is
  'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25854-4
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'a' means 'to'. 'To the' before masculine nouns is al (a + el); we
  use a la for feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25790-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [a] is pronounced as in 'alto'."@en ;
  dcterms:modified "2026-06-07T15:30:29.309949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25790-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Estar' means 'to be, being' and is used for location."@en ;
  dcterms:modified "2026-06-07T15:30:29.309953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25790-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Estoy' and 'está' are the 1st and 3rd person singular forms of 'estar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.309957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25790-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Hola' means 'hello' and 'hasta luego' means 'bye'."@en ;
  dcterms:modified "2026-06-07T15:30:29.309961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26006-1
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to describe completed events in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.313228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26006-2
  a curric:KeyLearningPoint ;
  rdfs:label "To mean 'she, he, it' remove the -er/-ir and add -ió. e.g. nació"@en ;
  dcterms:modified "2026-06-07T15:30:29.313234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26006-3
  a curric:KeyLearningPoint ;
  rdfs:label "To mean 'they' remove the -er/-ir and add -ieron. e.g. nacieron"@en ;
  dcterms:modified "2026-06-07T15:30:29.313239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26006-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the DOP 'lo' for him/it (masculine) and 'la' for her/it (feminine) – the thing
  or person receiving the action"""@en ;
  dcterms:modified "2026-06-07T15:30:29.313243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26006-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are irregular. Use fue, hizo and tuvo to say he/she went, did and had in
  the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25839-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [z] is pronounced as in the word 'zona'."@en ;
  dcterms:modified "2026-06-07T15:30:29.313479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25839-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular of -AR verbs ends in -a in the present tense, e.g.
  'canta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25839-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person plural of -AR verbs ends in -an in the present tense, e.g.
  'cantan'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25834-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [cue] is pronounced as in 'cuerpo', the SSC [cua] as in 'cuatro' and the SSC
  [cui] as in 'cuidar'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.319211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25834-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ce] is pronounced as in 'centro', the SSC [ci] as in 'decir'"@en ;
  dcterms:modified "2026-06-07T15:30:29.319215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25834-3
  a curric:KeyLearningPoint ;
  rdfs:label """An adverb of position provides information of the location of things. We often use
  'del' and 'de la' after them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25834-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the preposition de is followed by ‘el’ it becomes del."@en ;
  dcterms:modified "2026-06-07T15:30:29.319223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25834-5
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about where things are we use the verb 'estar' with 'estoy' meaning 'I am'
  and 'está' meaning 'she, he, it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25855-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ir is an irregular verb meaning 'to go, going'."@en ;
  dcterms:modified "2026-06-07T15:30:29.319571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Its singular forms are: 'voy' ('I go'), 'vas' ('you go') and 'va' ('she, he, it
  goes')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25855-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish closed (yes/no) questions use the same words in the same order as Spanish
  statements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25855-4
  a curric:KeyLearningPoint ;
  rdfs:label "To make a statement into a spoken Spanish, use raised intonation."@en ;
  dcterms:modified "2026-06-07T15:30:29.319586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25855-5
  a curric:KeyLearningPoint ;
  rdfs:label """To make a statement into a written question use two question marks; the one at the
  start is upside down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25859-1
  a curric:KeyLearningPoint ;
  rdfs:label """To pronounce words starting with [h] we ignore it and pronounce the vowel that
  follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25859-2
  a curric:KeyLearningPoint ;
  rdfs:label """'We' verb forms for -ar verbs end in -amos, as in 'miramos'. 'They' verb forms for
  -ar verbs end in -an, as in 'miran'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25859-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can use use texts, like a poem, to practise grammar or vocabulary or as
  inspiration for writing your own poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25868-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the stress is on the final syllable of a Spanish word ending in 'n' or 's', there
  is an accent on the last vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25868-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in others consonants have final syllable stress and no accent, e.g.
  'beber'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25868-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the surrounding words in a sentence helps to work out the meaning of
  unfamiliar words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25868-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person plural (we) ending for present tense -er verbs is -emos. The 1st
  person singular (I) ending is -o."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25798-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [ca], [co], [cu] are pronounced as in casa, coche, escuchar."@en ;
  dcterms:modified "2026-06-07T15:30:29.320879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25798-2
  a curric:KeyLearningPoint ;
  rdfs:label "Add 's' to make a Spanish word plural, if it ends in a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.320882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25798-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'some' for plural masculine nouns use 'unos'. For plural feminine nouns use
  'unas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25858-1
  a curric:KeyLearningPoint ;
  rdfs:label """To pronounce words starting with [h] we ignore it and pronounce the vowel that
  follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25858-2
  a curric:KeyLearningPoint ;
  rdfs:label """To identify the genre of a text focus on its key features. For example, rhyme,
  rhythm and verses suggest a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives mainly follow Spanish nouns and agree with them for gender and
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25858-4
  a curric:KeyLearningPoint ;
  rdfs:label """The surrounding words and grammar you know, and recognition of cognates, help you to
  work out unfamiliar word meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25888-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound symbol correspondence [ce] is pronounced as in the word 'centro' and [ci]
  as in the word 'decir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25888-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple present of -ar verbs is used to talk about habits and routines, e.g.
  'trabajo', 'trabajas', 'trabaja'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25888-3
  a curric:KeyLearningPoint ;
  rdfs:label "The present continuous is used to talk about actions happening now."@en ;
  dcterms:modified "2026-06-07T15:30:29.326044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25888-4
  a curric:KeyLearningPoint ;
  rdfs:label """The present continuous of -ar verbs is formed with the verb 'estar' ('estoy',
  'está', 'está') + -ando."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25888-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes we use adverbs of time to indicate clearly if the action we refer to is a
  habit or it is happening now."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25814-1
  a curric:KeyLearningPoint ;
  rdfs:label "[j] is pronounced as in 'ojo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.329643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25814-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plural definite article in Spanish is 'los' for masculine nouns and 'las' for
  feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25848-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [j] is pronounced as in 'ojo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.335092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25848-2
  a curric:KeyLearningPoint ;
  rdfs:label """Regular verbs whose infinitives end in -er/-ir end in -en for the 3rd person
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25848-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'responder', 'abrir' and 'recibir' are useful to describe what you and
  others do online."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25922-1
  a curric:KeyLearningPoint ;
  rdfs:label """One effective and enjoyable way to learn vocabulary is through games that challenge
  you to recall words from memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25922-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used for completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.341322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25922-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with an -ar verb, remove the ending and add -é. With an -er/-ir verb,
  add -í."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25922-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'you' with an -ar verb, remove the ending and add -aste. With an -er/-ir
  verb, add -iste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25922-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form questions in Spanish, use the same verb with a rising tone and write it
  between two question marks (¿ ?)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25862-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular preterite of -ar verbs ends in '-é'"@en ;
  dcterms:modified "2026-06-07T15:30:29.342096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25862-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular present of -ar verbs ends in '-o'"@en ;
  dcterms:modified "2026-06-07T15:30:29.342100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25862-3
  a curric:KeyLearningPoint ;
  rdfs:label "To make a sentence negative we put the negation word 'no' before the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.342104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25846-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence (SSC) [ge] is pronounced as in 'gente', [gi] as in
  'imaginar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25846-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some Spanish infinitives end in -er and -ir."@en ;
  dcterms:modified "2026-06-07T15:30:29.342348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25846-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb ending changes depending on who the verb refers to."@en ;
  dcterms:modified "2026-06-07T15:30:29.342355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25846-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with an -er/-ir verb, the ending is -o; this is called the first person
  singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25951-1
  a curric:KeyLearningPoint ;
  rdfs:label """A diphthong is created when a strong vowel appears next to a weak vowel, making a
  single syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25951-2
  a curric:KeyLearningPoint ;
  rdfs:label "To mean ‘you (all) are’ for location, state or mood, use ‘estáis’."@en ;
  dcterms:modified "2026-06-07T15:30:29.342591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25951-3
  a curric:KeyLearningPoint ;
  rdfs:label "To mean ‘you (all) are’ for general traits, use ‘sois’."@en ;
  dcterms:modified "2026-06-07T15:30:29.342595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25968-1
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -er and -ir verbs, the verb ending -imos refers to 'we' in the preterite
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25968-2
  a curric:KeyLearningPoint ;
  rdfs:label """For regular -ar verbs, the verb ending -amos refers to 'we' in the preterite
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25968-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb ‘huir’ has a stem change (i → y) in the present tense for 'I', you', 'he',
  'she' and 'they'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25815-1
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article in Spanish is 'el' and los' with masculine nouns and 'la' and
  'las' with feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25815-2
  a curric:KeyLearningPoint ;
  rdfs:label "When using 'es', we need to use the singular form of the adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.363914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25815-3
  a curric:KeyLearningPoint ;
  rdfs:label "When using 'son', we need to use the plural form of the adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.363918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25821-1
  a curric:KeyLearningPoint ;
  rdfs:label "To speak about what 'they have', 'tienen' is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.365926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25821-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives in Spanish always have to agree with the noun in grammatical gender and
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25825-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information questions start with a question word and have more information in the
  answer than yes/no."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25825-2
  a curric:KeyLearningPoint ;
  rdfs:label "The questions words ¿cuánto?, ¿quién? and ¿cuál? mean how much, who and which."@en ;
  dcterms:modified "2026-06-07T15:30:29.365956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25825-3
  a curric:KeyLearningPoint ;
  rdfs:label """¿Cuánto?, ¿quién? and ¿cuál? agree for number; they change spelling when referring
  to plural persons or things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25986-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting vocabulary often helps to move the words from your short-term to your
  long-term memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25986-2
  a curric:KeyLearningPoint ;
  rdfs:label """For something completed in the past, we use the preterite tense, e.g. 'serví '- 'I
  served', 'serviste' - 'you served'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25986-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that used to happen repeatedly in the past, we use the
  imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25986-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' remove the endings and add -ía. For 'you' add -ías and for 'she, he, it'
  add -ía."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25826-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ge, gi] are pronounced as in 'gente' and ‘imaginar’."@en ;
  dcterms:modified "2026-06-07T15:30:29.368510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25826-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' means ‘to be’ or ‘being’ and is used for moods or temporary states and
  location."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25826-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Ser' means ‘to be’ or ‘being’ and is used for general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.368518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25826-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective agreement is achieved often by masculine adjectives ending in -o and
  feminine adjectives ending in -a."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25808-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [qui] sounds as in 'equipo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.369108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25808-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Hay’ means ‘there is' and 'there are’, and like ‘tiene’ can be used to describe
  places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25808-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences with ‘hay’ often start with ‘en’."@en ;
  dcterms:modified "2026-06-07T15:30:29.369116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish [h] is silent, as in the word ‘hablar’."@en ;
  dcterms:modified "2026-06-07T15:30:29.369859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25822-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish adjective agreement is for gender and number."@en ;
  dcterms:modified "2026-06-07T15:30:29.369863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25822-3
  a curric:KeyLearningPoint ;
  rdfs:label "Singular adjectives ending in -e do not change for gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.369867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25822-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish adjectives mostly follow the noun. Adjective placement is different from
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25980-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the sounds [b] and [v] are the same, as in 'abuela' and 'verde', so we
  need to learn spellings by heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25980-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say what is happening now, we use the verb 'estar' with a present participle;
  this is called the present continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25980-3
  a curric:KeyLearningPoint ;
  rdfs:label """The present participle is formed by removing the infinitive ending and adding -ando
  for -ar verbs and -iendo for others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25980-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'these' for masculine nouns we use 'estos' and for feminine nouns 'estas';
  these are demonstrative adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25980-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative pronoun 'que' means 'who' or 'that'. 'Donde' means 'where'; there is no
  accent when it's a relative pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25805-1
  a curric:KeyLearningPoint ;
  rdfs:label "To read and understand a longer text in Spanish, reading techniques are useful."@en ;
  dcterms:modified "2026-06-07T15:30:29.374451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25805-2
  a curric:KeyLearningPoint ;
  rdfs:label "To write about school, 'tener' and no + 'tener' is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.374455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25804-1
  a curric:KeyLearningPoint ;
  rdfs:label "The [z] sound is pronounced as in 'bath' or 'thorn'."@en ;
  dcterms:modified "2026-06-07T15:30:29.374459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25804-2
  a curric:KeyLearningPoint ;
  rdfs:label "To use negation in Spanish, 'no' is widely used."@en ;
  dcterms:modified "2026-06-07T15:30:29.374463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25804-3
  a curric:KeyLearningPoint ;
  rdfs:label "To make a verb negative, 'no' is placed before the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.374468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25809-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Hay' means there is/are and is used in sentences that usually have 'en'."@en ;
  dcterms:modified "2026-06-07T15:30:29.378558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25809-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tiene' means she/he/it has."@en ;
  dcterms:modified "2026-06-07T15:30:29.378562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25809-3
  a curric:KeyLearningPoint ;
  rdfs:label "The masculine plural is used also when the group includes girls/women."@en ;
  dcterms:modified "2026-06-07T15:30:29.378566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25801-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish sounds [cue], [cua] and [cui] are pronounced as in 'cuerpo', 'cuatro'
  and 'cuidar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25801-2
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive verbs communicate the general meaning of an action and often end in -ar
  in Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25801-3
  a curric:KeyLearningPoint ;
  rdfs:label "Infinitive verbs can be used when expressing opinions about actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.383643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25801-4
  a curric:KeyLearningPoint ;
  rdfs:label "Regular infinitive verbs ending in -ar change to -a in the 3rd person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.383647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25918-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish words with final syllable stress ending in -n or -s ('según', 'quizás') need
  an accent on the last syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25918-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'hacer' means 'to do' or 'to make'. We use the preterite tense to describe
  completed events in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25918-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of 'hacer' in the preterite tense are 'hice' (I did), 'hiciste'
  (you did) and 'hizo' (she, he did)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25918-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses subject pronouns only for contrast or emphasis: 'yo' (I), 'tú' (you),
  'él' (he) and 'ella' (she)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25918-5
  a curric:KeyLearningPoint ;
  rdfs:label """'De' often comes after location adverbs like 'cerca'. 'De' + 'el' becomes 'del' and
  'de' + 'la' becomes 'de la'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25827-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'tener', 'estar', 'es' and 'hacer' are useful to ask and answer
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25827-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘I do’ or ‘I make’ say hago. To say ‘you do’ or ‘make’ say haces. To say
  she/he/it ‘does’ or ‘makes’ say hace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25827-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use information questions to ask more information than 'yes/no'."@en ;
  dcterms:modified "2026-06-07T15:30:29.402329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25806-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [que] sounds as in 'porque'."@en ;
  dcterms:modified "2026-06-07T15:30:29.403545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25806-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' means 'to be, being' and is used for location."@en ;
  dcterms:modified "2026-06-07T15:30:29.403549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25806-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Hola’ means ‘hello’ and ‘hasta luego’ means ‘bye’."@en ;
  dcterms:modified "2026-06-07T15:30:29.403556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25806-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in a consonant, ‘-es’ is added for plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.403560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25818-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [b] as in 'celebrar' and [v] as in 'ver' sound the same in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.403796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25818-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use the verb 'estar' to talk about the mood or tone of someone and something."@en ;
  dcterms:modified "2026-06-07T15:30:29.403800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25813-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ge] sounds like in 'gente'"@en ;
  dcterms:modified "2026-06-07T15:30:29.404770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25813-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [gi] sounds like in 'imaginar'"@en ;
  dcterms:modified "2026-06-07T15:30:29.404774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25813-3
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite article is used to introduce a noun and the definite article to refer
  to it again"""@en ;
  dcterms:modified "2026-06-07T15:30:29.404778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25844-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [ga], [go], [gu] are pronounced as in 'ganar', 'domingo', 'preguntar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.404783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25844-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some Spanish infinitives end in -er and -ir rather than -ar."@en ;
  dcterms:modified "2026-06-07T15:30:29.404787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25844-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular ending for -er and -ir verbs is -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.404791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25844-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular form of the verb refers to she, he or it."@en ;
  dcterms:modified "2026-06-07T15:30:29.404795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25838-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [z] is pronounced as in the word 'zona'."@en ;
  dcterms:modified "2026-06-07T15:30:29.406171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25838-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular of -AR verbs ends in -a in the present tense, e.g.
  'canta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25838-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person plural of -AR verbs ends in -an in the present tense, e.g.
  'cantan'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25810-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondences [ga], [go], [gu] can be practised by pronouncing words
  like 'ganar', 'gol' and 'preguntar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25810-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Es' means 'it is' to describe someone or something."@en ;
  dcterms:modified "2026-06-07T15:30:29.406507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25810-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Son' means 'they are' to describe two or more people or things."@en ;
  dcterms:modified "2026-06-07T15:30:29.406514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25810-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences with ‘hay’ usually begin with ‘en’. ‘Hay un(a)’ means ‘there is a/an’.
  ‘Hay unos/unas’ means ‘there are some.’"""@en ;
  dcterms:modified "2026-06-07T15:30:29.406518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25810-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Tiene' means 'she, he, it has'."@en ;
  dcterms:modified "2026-06-07T15:30:29.406522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25824-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [a] and [o] are as in the words ‘casa’ and
  ‘yo’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25824-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb ‘hacer’ means ‘to do, to make’."@en ;
  dcterms:modified "2026-06-07T15:30:29.406642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25824-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first person singular form of ‘hacer’ is ‘hago’, meaning ‘I do, I make’."@en ;
  dcterms:modified "2026-06-07T15:30:29.406646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25824-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Hacer’ is irregular in the 1st person singular, but 2nd and 3rd persons singular
  are regular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25824-5
  a curric:KeyLearningPoint ;
  rdfs:label "The question word   ‘cuándo?’ means ‘when’."@en ;
  dcterms:modified "2026-06-07T15:30:29.406662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25843-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC sound [ll] is pronounced as in 'llamar' and [l] as in 'libro'"@en ;
  dcterms:modified "2026-06-07T15:30:29.407210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25843-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of -ar verbs ends in -o, the 3rd person singular in -a, and
  the 1st person plural in -amos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25843-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of location are followed by 'del' if the noun is masculine or by 'de la' if
  the noun is feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25881-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' can also be translated as 'to be + adjective' when used as an
  idiom, 'tener + noun'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25881-2
  a curric:KeyLearningPoint ;
  rdfs:label """Its singular forms are: 'tengo', 'tienes', 'tiene' and its plural forms are:
  'tenemos' and 'tienen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25881-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish plural subject pronouns are: 'nosotros/as', 'ellos/as'. They add clarity
  about who the verb refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25905-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word-initial 'r' is rolled and pronounced as in 'rojo'. It sounds identical to the
  'rr' in 'perro'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25905-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gustar-type verbs commonly appear after an indirect object pronoun like 'me' or
  'le'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25905-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use the personal 'a' before the object if it's a person or animal."@en ;
  dcterms:modified "2026-06-07T15:30:29.415809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25905-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are two frequently used word orders in Spanish: subject + verb + object and
  object + verb + subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25869-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish suffix '-idad' is like '-ity' in English; use it to change adjectives
  into nouns, e.g. 'real' - 'realidad'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25869-2
  a curric:KeyLearningPoint ;
  rdfs:label "All Spanish nouns ending '-idad' are feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.418883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25869-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses the simple present to express immediate plans; instead, English uses
  the present continuous (-ing)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25869-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Qué' with an accent on the 'e' is the question word 'what'. 'Que' without an accent
  is a conjunction meaning 'that'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25952-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish there are two verbs for 'to be'. Use 'estar' for location, state or mood
  and 'ser' for permanent traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25952-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives can only be used with ‘estar’ because they only describe a state,
  not a permanent trait."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25952-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of 'estar' is 'estoy' and the plural is 'estamos'; for
  'ser', it is 'soy' and 'somos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25952-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular of 'estar' is 'está', and the plural is 'están'; for 'ser',
  it is 'es' and 'son'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25952-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'more … than' in Spanish, use 'más' + adjective + 'que'; to say 'less …
  than', use 'menos' + adjective + 'que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25923-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the stress is on the penultimate syllable and the word ends in a vowel, -n, or
  -s, an accent is not needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25923-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say the date in Spanish, we use cardinal numbers such as 'uno', 'dos', 'tres'.
  'First' is an exception."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25923-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'she, he, it' when using the preterite for past events, use '-ó' for -ar
  verbs, and '-ió' for -er/-ir verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25923-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'ir' and 'hacer' are irregular. Their 3rd person singular preterite forms
  are 'fue' and 'hizo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25989-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ser' is used to talk about traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.424830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25989-2
  a curric:KeyLearningPoint ;
  rdfs:label """Its simple present forms are: 'soy', 'eres', 'es' and its imperfect tense forms are:
  'era', 'eras', 'era'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25989-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most Spanish adjectives go after the noun. We use them to describe objective
  qualities (e.g. traits, origin, colours)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25989-4
  a curric:KeyLearningPoint ;
  rdfs:label """Prenominal adjectives go before the noun and are used to express subjective opinions
  or for emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25989-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives can come before or after the noun, but their meaning changes"@en ;
  dcterms:modified "2026-06-07T15:30:29.424849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25958-1
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about where someone goes or is going (present), use 'voy', 'vas', 'va',
  'vamos', 'vais', 'van'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25958-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what someone is going to do (future plans) use a present tense form of
  the verb 'ir' + a + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25958-3
  a curric:KeyLearningPoint ;
  rdfs:label """One meaning of the word 'para' is 'for'. When used in this way, it is followed by a
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25958-4
  a curric:KeyLearningPoint ;
  rdfs:label """Another meaning is 'in order to'. When used in this way, it is followed by an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26005-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word mastery includes recognising, understanding, and using a word in different
  contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26005-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to talk about events completed in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.426030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26005-3
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs, to say 'I', remove the -ar and -é. For 'you' add -aste, and for 'she,
  he, it' add -ó."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish doesn’t have a word for 'do' or 'did' in questions. When asking questions,
  only the main verb is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25935-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, syllables often contain consonant-vowel pairs, or a vowel with a
  consonant either side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25935-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to express completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.426597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25935-3
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate singular forms of the preterite tense for regular -ar verbs, remove the
  -ar and add -é, -aste, -ó."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25935-4
  a curric:KeyLearningPoint ;
  rdfs:label "Raise your voice at the end of a statement to form an intonation question."@en ;
  dcterms:modified "2026-06-07T15:30:29.426605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25999-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sounds [que] and [qui] are pronounced like a hard ‘k’ followed by ‘e’ or ‘i’.
  The 'u' is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25999-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sounds [gue] and [gui] are pronounced like a hard ‘g’ followed by ‘e’ or ‘i’.
  The ‘u’ is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25999-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means 'to be, being' for traits. Its forms are: 'I am' - 'soy', 'we
  are' - 'somos' and 'they are' - son'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25999-4
  a curric:KeyLearningPoint ;
  rdfs:label "The way to say 'you are' depends on how many people you are talking to."@en ;
  dcterms:modified "2026-06-07T15:30:29.427174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25999-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘you are’ to one person, use ‘eres’. To say ‘you are’ to two or more people,
  use ‘sois’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25823-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish adjective agreement is for gender and number."@en ;
  dcterms:modified "2026-06-07T15:30:29.427396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25823-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish adjectives mostly follow the noun, but the adjective ‘mucho’ goes before the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25823-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plural adjectives ending in -os describe masculine nouns. Adjectives ending in -as
  describe feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25823-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plural adjectives ending in -es do not change for gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.427411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25913-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is an accent on the final vowel of numbers 22, 23 and 26 because they have
  final-syllable stress and end in ‘s’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25913-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many jobs end in -o when they refer to a man and -a when they refer to a woman, e.g.
  'músico' and 'música' (musician)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25913-3
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite article ('un', 'una') is not used when stating what job someone does,
  e.g. 'mi padre es médico'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25913-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say the possessive adjective ‘our’ in Spanish, use 'nuestro'. 'Nuestro' needs to
  agree in gender with the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25913-5
  a curric:KeyLearningPoint ;
  rdfs:label """For singular masculine nouns use 'nuestro', for singular feminine nouns use
  'nuestra'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25832-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ca] is pronounced as in 'casa', [co] as in ‘comer’ and [cu] as in
  ‘cuerpo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25832-2
  a curric:KeyLearningPoint ;
  rdfs:label "The modal verb ‘deber’ means ‘must’ and we use it to talk about obligations."@en ;
  dcterms:modified "2026-06-07T15:30:29.430105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25832-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Debo’ means ‘I must’, ‘debes’ means ‘you must’ and ‘debe’ means ‘she, he,
  it must’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25832-4
  a curric:KeyLearningPoint ;
  rdfs:label "The modal verb ‘deber’ is followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.430115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25841-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [que] is pronounced as in the word '¿por qué?' and [qui] as in the word
  'equipo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25841-2
  a curric:KeyLearningPoint ;
  rdfs:label "Guessing the meaning is not a reliable strategy for most Spanish words."@en ;
  dcterms:modified "2026-06-07T15:30:29.430877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25841-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a paper dictionary, words are listed in alphabetical order."@en ;
  dcterms:modified "2026-06-07T15:30:29.430882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25841-4
  a curric:KeyLearningPoint ;
  rdfs:label """An online dictionary gives us the meaning(s) of the word, its word class, examples
  of usage, and pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25841-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both dictionaries give us the word class using abbreviations - often in italics and
  sometimes in a different colour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25864-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular preterite of -ar verbs ends in (-aste)."@en ;
  dcterms:modified "2026-06-07T15:30:29.430894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25864-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular preterite of -ar verbs ends in (-é)."@en ;
  dcterms:modified "2026-06-07T15:30:29.430898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25864-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is no Spanish equivalent for the English auxiliary 'did'."@en ;
  dcterms:modified "2026-06-07T15:30:29.430902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25793-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [i] is pronounced as in 'idea'."@en ;
  dcterms:modified "2026-06-07T15:30:29.430906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25793-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives in Spanish have masculine and feminine forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.430910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25793-3
  a curric:KeyLearningPoint ;
  rdfs:label "Masculine adjectives that end in -o change to an -a in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.430915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25793-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' means 'to be, being' and is used for moods and states."@en ;
  dcterms:modified "2026-06-07T15:30:29.430919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25842-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC sound [ll] is pronounced as in the word 'llamar'"@en ;
  dcterms:modified "2026-06-07T15:30:29.433710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25842-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC sound [l] is pronounced as in the word 'libro'"@en ;
  dcterms:modified "2026-06-07T15:30:29.433714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25842-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use the 1st and 2nd person singular of the verb 'ser' - 'soy' and 'eres' for
  traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25842-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use the 1st and 2nd person ingular of the verb 'estar' - 'estoy' and 'estás' for
  state/mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25842-5
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, adjectives must always agree with the noun they refer to in gender and
  number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25863-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the 2-verb future structure 'ir + a + infinitive' to state plans and
  predictions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25863-2
  a curric:KeyLearningPoint ;
  rdfs:label "A syllable is a single sound or 'beat' in a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.433735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25863-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular present of -ar verbs ends in '-o'."@en ;
  dcterms:modified "2026-06-07T15:30:29.433739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25863-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular preterite of -ar verbs ends in '-é'."@en ;
  dcterms:modified "2026-06-07T15:30:29.433746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25899-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ge] is pronounced as in ‘gente’ and [gi] as in ‘imaginar’."@en ;
  dcterms:modified "2026-06-07T15:30:29.433750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25899-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the subject and object of a verb are the same, in Spanish we use reflexive
  pronouns before the verb e.g. 'Me lavo.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.433754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25899-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say you do something to or for yourself, we use 'te' before the verb in Spanish
  e.g. 'Te pones un vestido.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.433760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25899-4
  a curric:KeyLearningPoint ;
  rdfs:label """In English we sometimes leave out reflexive pronouns, but we never do in
  Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25899-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Me' and 'te' look and sound similar to the possessive adjectives 'mi' and 'tu', but
  their meanings are different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25856-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Ir' is a high frequency irregular verb; it is important to learn and remember its
  singular forms: voy, vas, va."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25856-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Vamos' is the 1st person plural form of 'ir' and means 'we go'."@en ;
  dcterms:modified "2026-06-07T15:30:29.434508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25856-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'to the' in Spanish, we use 'a la' before feminine nouns, and the contraction
  'al' for masculine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25909-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Ser' is 'to be' for traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.434556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25909-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Estar' is 'to be' for states and locations."@en ;
  dcterms:modified "2026-06-07T15:30:29.434560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25909-3
  a curric:KeyLearningPoint ;
  rdfs:label "A common way to give opinions in Spanish is to use the verb ‘dar’ with a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.434564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25795-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish vowels are [a] as in 'alto', [o] as in 'yo', [e] as in elefante, [i] as
  in 'idea' and [u] as in 'universo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25795-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ser' is used to describe general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.587394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25795-3
  a curric:KeyLearningPoint ;
  rdfs:label "Masculine adjectives ending in -o change to -a in the feminine form."@en ;
  dcterms:modified "2026-06-07T15:30:29.587398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25795-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, you can change a statement into an intonation question by raising your
  voice at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25807-1
  a curric:KeyLearningPoint ;
  rdfs:label """The numbers 1-12 in Spanish are: uno, dos, tres, cuatro, cinco, seis, siete, ocho,
  nueve, diez, once, doce."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25807-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use masculine plural forms to refer to male only and mixed male and female
  groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25807-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Amigos’ can mean several male friends or several male and female friends."@en ;
  dcterms:modified "2026-06-07T15:30:29.590399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25807-4
  a curric:KeyLearningPoint ;
  rdfs:label """Practising and adding to your own 'vocabulario' will help you to make what you write
  and say more personalised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns (e.g. 'him', 'them') indicate the person or thing that is
  indirectly affected by the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25946-2
  a curric:KeyLearningPoint ;
  rdfs:label "To refer to one person or thing indirectly affected by an action, use 'le'."@en ;
  dcterms:modified "2026-06-07T15:30:29.593850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25946-3
  a curric:KeyLearningPoint ;
  rdfs:label "If more than one person or thing is indirectly affected, use 'les'."@en ;
  dcterms:modified "2026-06-07T15:30:29.593854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25946-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reading words aloud in Spanish, stress the penultimate syllable for any word
  ending in a vowel, -n or -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25946-5
  a curric:KeyLearningPoint ;
  rdfs:label "If the word has a written accent, stress the syllable with the accent."@en ;
  dcterms:modified "2026-06-07T15:30:29.593863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25800-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish sounds [cue], [cua] and [cui] are pronounced as in 'cuerpo', 'cuatro'
  and 'cuidar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25800-2
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine and feminine singular indefinite articles in Spanish are 'un' and
  'una'. They mean 'a' or 'an'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25800-3
  a curric:KeyLearningPoint ;
  rdfs:label "Infinitives give the general meaning of a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.594855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25800-4
  a curric:KeyLearningPoint ;
  rdfs:label "Regular infinitive verbs ending in -ar change to -a in the 3rd person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.594859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25866-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weak vowel [u] when next to [a], [e] and [o] becomes a single syllable."@en ;
  dcterms:modified "2026-06-07T15:30:29.600380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25866-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means 'to, be, being' and it is used to describe permanent
  traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25866-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' means 'to, be, being' and it is used to describe temporary
  states/moods."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25866-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives like 'listo' and 'malo' have different meanings depending on which verb
  is used: 'ser' or 'estar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25973-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'tener' has an irregular stem in the preterite tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.605551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25973-2
  a curric:KeyLearningPoint ;
  rdfs:label "The singular preterite forms of 'tener' are 'tuve', 'tuviste' and 'tuvo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.605556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25973-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Tener' does not always translate as 'having'. In idiomatic expressions it can mean
  'to be, being', e.g. 'tuve éxito'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26007-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the accent can change the meaning of a verb from the present to the
  past, e.g. 'hablo', 'habló'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26007-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, verb endings change depending on when the action takes place and who the
  verb refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26007-3
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate -ar verbs for 'they,' remove -ar and add -an for the present tense or
  -aron for the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26007-4
  a curric:KeyLearningPoint ;
  rdfs:label """For -er/-ir verbs, for 'they,' remove -er/-ir and add -en for the present tense or
  -ieron for the preterite tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25966-1
  a curric:KeyLearningPoint ;
  rdfs:label "For present-tense -ir verbs, the verb ending -imos refers to ‘we’."@en ;
  dcterms:modified "2026-06-07T15:30:29.607431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25966-2
  a curric:KeyLearningPoint ;
  rdfs:label "For present-tense -er verbs the verb ending -emos refers to ‘we’."@en ;
  dcterms:modified "2026-06-07T15:30:29.607435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25966-3
  a curric:KeyLearningPoint ;
  rdfs:label "For both -er and -ir verbs, the verb ending -en refers to ‘they’."@en ;
  dcterms:modified "2026-06-07T15:30:29.607439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25966-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Sentir’ and ‘oír’ are stem-changing verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.607444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25966-5
  a curric:KeyLearningPoint ;
  rdfs:label "Subject pronouns add emphasis or appear in comparisons."@en ;
  dcterms:modified "2026-06-07T15:30:29.607448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25924-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, the simple present tense is used for habitual actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.610937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25924-2
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs, the 'she, he, it' form ends in -a (e.g. 'estudia') and the 'they'
  form ends in -an (e.g. 'estudian')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25924-3
  a curric:KeyLearningPoint ;
  rdfs:label """For -er/-ir verbs, the 'she, he, it' form ends in -e (e.g. 'lee') and the 'they'
  form ends in -en (e.g. 'leen')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25896-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ga] is pronounced as in 'ganar', [go] is pronounced as in 'domingo' and
  [gu] is pronounced as in 'preguntar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25896-2
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object is the person, animal or thing that receives the action of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25896-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a direct object is a person or pet, Spanish uses the personal 'a' after the
  verb, e.g. 'cuido a mi gato'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25896-4
  a curric:KeyLearningPoint ;
  rdfs:label "For other direct objects it is not necessary, e.g 'cuido mi casa'."@en ;
  dcterms:modified "2026-06-07T15:30:29.610967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25957-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many English adverbs ending in -ly become -mente in Spanish, e.g. 'especial' -
  'especialmente'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25957-2
  a curric:KeyLearningPoint ;
  rdfs:label """If an adjective has -o/-a forms, use the -a form + -mente to make the adverb, e.g.
  'lento' - 'lenta' - 'lentamente'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25957-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -n or -s generally stress the penultimate syllable and do not need
  an accent, e.g. 'examen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25957-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding the plural ending -es shifts stress to the antepenultimate syllable, so an
  accent is needed, e.g. 'exámenes'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25957-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Voy', 'vas', 'va' are the simple present forms of the verb 'ir', and 'fui',
  'fuiste', 'fue' are the preterite forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26002-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘that’ for a singular masculine noun, use ‘ese’, and for a singular feminine
  noun, use ‘esa'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26002-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘this’ for a singular masculine noun, use ‘este’, and for a singular feminine
  noun, use ‘esta’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26002-3
  a curric:KeyLearningPoint ;
  rdfs:label "To talk about possessions we use possessive adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.611112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26002-4
  a curric:KeyLearningPoint ;
  rdfs:label """After a singular masculine noun, use 'mío' - 'mine', 'tuyo' - 'yours' and 'suyo' -
  'his, hers'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26002-5
  a curric:KeyLearningPoint ;
  rdfs:label """After a singular feminine noun, use 'mía' - 'mine', 'tuya' - 'yours' and 'suya' -
  'his, hers'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25820-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, 'r' is pronounced differently depending on its position in the word and
  whether it is single or double."""@en ;
  dcterms:modified "2026-06-07T15:30:29.612992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25820-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tenemos' is used to describe what 'we' have."@en ;
  dcterms:modified "2026-06-07T15:30:29.612996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25940-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mexico is famous for many things including its artists, its archaeology, its food,
  its customs and its unique history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25940-2
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives go before nouns to show belonging and ownership."@en ;
  dcterms:modified "2026-06-07T15:30:29.614061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25940-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Su' is 'his', 'hers' or 'its' before a singular noun, e.g. 'su país' - 'his, her,
  its country'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25940-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Sus' is 'his', 'hers', or 'its' before a plural noun, e.g. 'sus padres' - 'his,
  her, its parents'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25940-5
  a curric:KeyLearningPoint ;
  rdfs:label """As 'su' and 'sus' have different meanings, you will often need context to translate
  them accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25975-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'estar' to mean 'to be, being' for a mood, state or location."@en ;
  dcterms:modified "2026-06-07T15:30:29.616650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25975-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'estaba' to mean 'I was' for a mood, state or location in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.616654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25975-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'estabas' to mean 'you were' for a mood, state or location in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.616658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25975-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relative pronouns can be used to give extra information about someone or something
  e.g. 'who' or 'that'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25975-5
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, you can use the word 'que' to mean both 'who' and 'that'."@en ;
  dcterms:modified "2026-06-07T15:30:29.616667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25811-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish adjectives change depending on whether the noun is masculine o feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.616814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25811-2
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine adjectives change from -o to -a when the noun being described is
  feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25811-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish adjectives change depending on whether the noun is singular (one) or plural
  (more than one)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25811-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses 'es' to describe someone or something and 'son' to describe two or more
  people or things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25876-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the final syllable is stressed and the word ends in a vowel or 'n' or 's' there
  is an accent on the final vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25876-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of -er and -ir verbs in preterite ends in -í, e.g.
  'describí'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25876-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular of -er and -ir verbs in present ends in -o, e.g.'
  describo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25817-1
  a curric:KeyLearningPoint ;
  rdfs:label "the SSE [ñ] is pronounced as  in 'español'"@en ;
  dcterms:modified "2026-06-07T15:30:29.618585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25817-2
  a curric:KeyLearningPoint ;
  rdfs:label "the SSE [n] is pronounced as in 'mano'"@en ;
  dcterms:modified "2026-06-07T15:30:29.618589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25817-3
  a curric:KeyLearningPoint ;
  rdfs:label "the verb 'dar' is followed by indefinite articles"@en ;
  dcterms:modified "2026-06-07T15:30:29.618593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25928-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say what is happening right now, Spanish uses the present continuous, which is
  'estar' + present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25928-2
  a curric:KeyLearningPoint ;
  rdfs:label """For -er and -ir verbs the present participle is formed by removing -er/-ir from the
  verb infinitive and adding -iendo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25928-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'querer' is a modal verb and means 'to want' or 'to love'. To say 'we
  want', we use 'queremos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25928-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Querer' is commonly used before an infinitive to mean 'to want to', e.g. 'queremos
  conducir' - 'we want to drive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25928-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the present continuous, 'estar' cannot be followed by an infinitive. It is always
  followed by a present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25906-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter 'h' is silent in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.619013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25906-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gustar-type verbs commonly appear after an indirect object pronoun like 'me' or
  'le'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gustar-type verbs agree with the subject in number: -a for singular nouns and -an
  for plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25906-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns following a gustar-type verb appear with a definite article, even when it is
  not needed in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25891-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spain, the sound-symbol correspondence [z] is pronounced like the 'th' in
  'think', and [s] like an 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25891-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Latin America, the Canary Islands and parts of Spain, the sounds [z] and [s] are
  pronounced like an 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25891-3
  a curric:KeyLearningPoint ;
  rdfs:label "The present tense of -ar verbs in 1st person singular ends in -o."@en ;
  dcterms:modified "2026-06-07T15:30:29.619361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25891-4
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense of -ar verbs in 3rd person singular ends in -ó."@en ;
  dcterms:modified "2026-06-07T15:30:29.619365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25891-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of position are always followed by 'de', 'del' or 'de la' depending on what
  follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25897-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish we use a personal 'a' between the verb and the direct object if the
  object is a specific person or pet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25897-2
  a curric:KeyLearningPoint ;
  rdfs:label """The article 'el' ('the') refers to a singular masculine noun. If personal 'a' is
  followed by 'el', it becomes 'al'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25897-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives come before the noun in Spanish, these are called prenominal
  adjectives, e.g. 'mismo', 'propio'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25897-4
  a curric:KeyLearningPoint ;
  rdfs:label """Certain prenominal adjectives, 'bueno', 'primero', 'tercero' and 'malo', lose their
  -o ending before a masculine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25897-5
  a curric:KeyLearningPoint ;
  rdfs:label """These adjectives may appear in sentences with personal 'a' or 'al', e.g. 'conoces a
  un buen doctor'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25997-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Z' is added before the 'co' to keep the soft 'c' sound in verbs ending in '-cer' or
  '-cir', e.g. 'conocer' - 'conozco'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25997-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘you’, -er/-ir verbs end in -es. To mean ‘you all’, -er verbs end in -éis
  and -ir verbs end in -ís."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25997-3
  a curric:KeyLearningPoint ;
  rdfs:label """IOPs indicate the person or thing affected by the verb. Use 'le' to mean 'to, for
  him, her, it', and 'les' for 'them'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Two structures are possible: subject + verb + indirect object or indirect object +
  verb + subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25997-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use the personal ‘a’ before the object when it’s a person or a thing."@en ;
  dcterms:modified "2026-06-07T15:30:29.619526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25833-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ca] is pronounced as in 'casa', [co] as in ‘comer’ and [cu] as in
  ‘cuerpo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25833-2
  a curric:KeyLearningPoint ;
  rdfs:label "The modal verb ‘deber’ means ‘must’ and we use it to talk about obligations."@en ;
  dcterms:modified "2026-06-07T15:30:29.619534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25833-3
  a curric:KeyLearningPoint ;
  rdfs:label """The modal verb ‘poder’ means ‘can/be able to’ and we use it to talk about
  possibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25833-4
  a curric:KeyLearningPoint ;
  rdfs:label """The modal verb ‘querer’ means ‘to want, wanting’ and we use it to talk about what we
  want to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25833-5
  a curric:KeyLearningPoint ;
  rdfs:label "All modal verbs are followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.619550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25829-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [e] is pronounced as in 'elefante'"@en ;
  dcterms:modified "2026-06-07T15:30:29.619806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25829-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [i] is pronounced as in 'idea'"@en ;
  dcterms:modified "2026-06-07T15:30:29.619810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25829-3
  a curric:KeyLearningPoint ;
  rdfs:label """-ar verbs in the present tense end in o, -as, -a and -amos when refering to
  different people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25926-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a word has antepenultimate (third-last) syllable stress, it always has an
  accent on the vowel of that syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words with penultimate syllable stress ending in any consonant other than -n or -s
  have an accent on that syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25926-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of 'estar' in the present tense are 'estoy' ('I am'), 'estás'
  ('you are') and 'está' ('she, he is')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25926-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present continuous to express an ongoing event. It is formed by using
  'estar' + the present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25926-5
  a curric:KeyLearningPoint ;
  rdfs:label """The present particple of -ar verbs is formed by removing the -ar from the infinitive
  and adding -ando."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25995-1
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to 'you (singular)' simple present -er verbs, use the verb ending -es, and
  for 'you (plural)' use -éis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25995-2
  a curric:KeyLearningPoint ;
  rdfs:label """The modal verbs 'querer', 'poder', 'deber' and 'soler' are often followed by an
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25995-3
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to 'you (singular)' with simple present -ir verbs, use the verb ending -es,
  and for 'you (plural)' use -ís."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25995-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'your' for two or more people, use 'vuestros' + masculine nouns and
  'vuestras' + feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25852-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [n] is pronounced as in the word 'mano'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25852-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ñ] is pronounced as in the word 'español'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25852-3
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive adjective 'mi' is used before a singular or uncountable noun, and it
  it means 'my'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25852-4
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive adjective 'tu' is used before a singular or uncountable noun, and it
  means 'your'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25852-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Es' is part of the verb 'ser' and 'está' is part of the verb 'estar'. They both
  mean 'she, he, it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25992-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, we use the verb 'ser' to talk about traits, including jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.620062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25992-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'you are', use 'eres', and to say 'you all are', use 'sois'."@en ;
  dcterms:modified "2026-06-07T15:30:29.620066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25992-3
  a curric:KeyLearningPoint ;
  rdfs:label """The -ity at the end of an English word is often -idad in Spanish, e.g. 'tranquility'
  - 'tranquilidad'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25992-4
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to 'you' for one person with a present tense -ar verb, use the verb ending
  -as, e.g. 'buscas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25992-5
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to 'you' for two or more people with a present tense -ar verb, use the verb
  ending -áis, e.g. 'buscáis'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25993-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the stress is on the final syllable and the word ends in any consonant except ‘n’
  or ‘s’, there is no accent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25993-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the stress is on the final syllable and the word ends in a vowel or ‘n’ or ‘s’,
  there is an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25993-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about where someone goes (present tense), use the verb ‘ir’, e.g.
  'vais'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25993-4
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what you are going to do (future plans), use a present tense form of
  the verb 'ir' + a + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25993-5
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish we use the simple present to talk about scheduled plans in the future,
  e.g. 'organizáis una fiesta mañana'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25981-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can create nouns in Spanish by adding -idad to singular adjectives ending in a
  consonant. E.g. real to realidad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25981-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular forms of 'estar' in the imperfect tense are 'estaba' (I was or he, she,
  was) and 'estabas' (you were)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25981-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about ongoing events in the past we use 'estar' in the imperfect tense with
  a present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25981-4
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite is used for completed actions, remove the -ar verb ending and add -é
  (I), -aste (you) or -ó (he, she, it)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25981-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can combine these two tenses to describe events in the past: 'Estaba escuchando
  la radio cuando noté un olor raro.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.621293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25902-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [b] as in 'celebrar' and [v] as in 'ver' sound the same in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:29.621538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pronouns e.g. me, you, him, her replace nouns to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.621542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25902-3
  a curric:KeyLearningPoint ;
  rdfs:label "The direct object directly receives the action of the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.621546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25902-4
  a curric:KeyLearningPoint ;
  rdfs:label """The indirect object is indirectly affected by the action of the verb. In Spanish,
  IOPs go before a conjugated verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25902-5
  a curric:KeyLearningPoint ;
  rdfs:label """For '(to/for) me' we say 'me', for '(to/for) you' we say 'te' and for '(to/for) her,
  him, it' we say 'le'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25836-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence [ce] is pronounced as in 'cerca'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25836-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence [ci] is pronounced as in 'cierto'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25836-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means 'to be, being' and is used for permanent traits. 'Somos' means
  'we are'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25836-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' means 'to be, being' and is used for temporary states. 'Estamos'
  means 'we are'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.621571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25831-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [a] is as in 'casa', [e] as in 'elfante', [i] in 'idea', [o] as in 'dos' and
  [u] as in 'universo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25831-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Poder' means 'to be able to'. 'Puedo' means 'I can', 'puedes' means 'you can' and
  'puede' means 'she, he , it can.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.621579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25831-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'poder' is followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.621583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25792-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [e] is pronounced as in 'elefante'."@en ;
  dcterms:modified "2026-06-07T15:30:29.622081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25792-2
  a curric:KeyLearningPoint ;
  rdfs:label """'¿Cómo se dice ...?' means 'How do you say ...?' and can be used to ask for
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25792-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' means 'to be, being' and is used for moods and states."@en ;
  dcterms:modified "2026-06-07T15:30:29.622090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25792-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Estoy', 'estás' and 'está' are the 1st, 2nd, and 3rd person singular forms of
  'estar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25961-1
  a curric:KeyLearningPoint ;
  rdfs:label "To describe completed events in the past in Spanish we use the preterite tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.622285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25961-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular preterite forms of 'hacer' are 'hice' (I did/made), 'hiciste' (you
  did/made) and 'hizo' (she, he did/made)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25961-3
  a curric:KeyLearningPoint ;
  rdfs:label """When contrasting what different people do or did, we use subject pronouns in Spanish
  (e.g. 'yo', 'tú', 'él', 'ella')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25961-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chile is a Latin American country which has very varied weather because of its long,
  narrow shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25961-5
  a curric:KeyLearningPoint ;
  rdfs:label """In English we use the verb 'to be' for the weather but in Spanish we use the verb
  'hacer', e.g. 'hace sol' (it's sunny)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26009-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ir' ('to go, going') is irregular in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.623282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26009-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Voy’, ‘vas’ and ‘va’ mean ‘I go’, ‘you go’ and ‘she, he, it goes’ respectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.623286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26009-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Vamos’, ‘vais’ and ‘van’ mean ‘we go’, ‘you all go’ and ‘they go’."@en ;
  dcterms:modified "2026-06-07T15:30:29.623290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26009-4
  a curric:KeyLearningPoint ;
  rdfs:label """A present-tense form of 'ir' + a + infinitive means 'going to' + infinitive. It
  expresses future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26009-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Para' + infinitive means 'in order to' + infinitive. It describes a purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.623299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26004-1
  a curric:KeyLearningPoint ;
  rdfs:label "Regular review of vocabulary moves it into long-term memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.623831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26004-2
  a curric:KeyLearningPoint ;
  rdfs:label """We only roll the 'r' when it's written as [rr] or when the [r] is at the beginning
  of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26004-3
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to talk about events completed in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.623839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26004-4
  a curric:KeyLearningPoint ;
  rdfs:label "To mean ‘I’, remove -er/-ir and add -í, e.g. 'leer' - 'leí', 'vivir' - 'viví'."@en ;
  dcterms:modified "2026-06-07T15:30:29.623844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26004-5
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘you’, remove -er/-ir and add -iste, e.g. 'leer' - 'leiste', 'vivir' -
  'viviste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25819-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Hay’ or ‘tiene’ with an indefinite article introduces a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.624714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25819-2
  a curric:KeyLearningPoint ;
  rdfs:label "A definite article often refers back to a previously introduced noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.624718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25819-3
  a curric:KeyLearningPoint ;
  rdfs:label "To express what someone wants, use ‘querer’, and to give something, use ‘dar’."@en ;
  dcterms:modified "2026-06-07T15:30:29.624722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25927-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say what is happening right now, Spanish uses the present continuous which is
  'estar' + present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25927-2
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs the present participle is formed by removing -ar from the verb
  infinitive and adding -ando."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Demonstrative adjectives distinguish one thing from another. For masculine nouns use
  'este' (this) or 'estos' (these)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25927-4
  a curric:KeyLearningPoint ;
  rdfs:label """For feminine nouns it's 'esta' (this) or 'estas' (these), which are similar to
  'está' (he, she is), 'estás’ (you are)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25927-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accents avoid confusion in writing; stress on the final syllable distinguishes them
  in speaking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words with stress on the third-last syllable have a written accent on the stressed
  vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25879-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular of -er and -ir verbs ends in -es in the present."@en ;
  dcterms:modified "2026-06-07T15:30:29.627762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25879-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular of -er and -ir verbs in ends in -iste in the preterite."@en ;
  dcterms:modified "2026-06-07T15:30:29.627766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25879-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish we use 'de' between two nouns to describe a particular type of
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25853-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [n] is pronounced as in the word 'mano'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25853-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ñ] is pronounced as in the word 'español'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25853-3
  a curric:KeyLearningPoint ;
  rdfs:label "The possessive adjective 'mis' is used before plural nouns and it means 'my'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25853-4
  a curric:KeyLearningPoint ;
  rdfs:label "The possessive adjective 'tus' is used before plural nouns and it means 'your'."@en ;
  dcterms:modified "2026-06-07T15:30:29.630094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25898-1
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish verbs like ‘despertar’ have a stem change in some of their forms, e.g.
  ‘despierto’ is the 1st person singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25898-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word ‘demasiado’ can be both adjective and adverb. As an adverb it needs no
  agreement but as an adjective it does."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25898-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a direct object is a specific person or pet, in Spanish the personal ‘a’ goes
  after the verb, e.g. ‘veo a la niña'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25898-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes the subject and object of a verb are the same. Use a reflexive pronoun
  before the verb, e.g. 'me lavo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25898-5
  a curric:KeyLearningPoint ;
  rdfs:label """When subject and object of verbs are the same, Spanish always uses a reflexive
  pronoun. English does not always do this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25998-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'I am' for a location or state, use ‘estoy’ ('estar'), and for a trait, use
  ‘soy’ ('ser')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25998-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'you are' for a location or state, use ‘estás’ ('estar'), and for a trait,
  use ‘eres’ ('ser')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25998-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives can only be used with estar because they only describe a state, not
  a trait, e.g. 'enfermo', 'triste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25998-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives change meaning with 'ser' and 'estar', e.g. ‘aburrido’, ‘listo’,
  ‘moreno’ and ‘seguro’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25998-5
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a question in Spanish, you can simply raise your intonation at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25885-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [l] is pronounced as in the word 'libro' and [ll] as in the word
  'llamar'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25885-2
  a curric:KeyLearningPoint ;
  rdfs:label "The present tense of -er/-ir verbs in 3rd person singular ends in -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.630537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25885-3
  a curric:KeyLearningPoint ;
  rdfs:label "The present tense of -er/-ir verbs in 3rd person plural ends in -en."@en ;
  dcterms:modified "2026-06-07T15:30:29.630541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25955-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the 'doer' (subject) and 'receiver' (object) of an action are the same person
  we use a reflexive pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25955-2
  a curric:KeyLearningPoint ;
  rdfs:label "To mean 'herself' or 'himself' in Spanish, use 'se' before a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.630549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25955-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns (e.g. 'him', 'them') indicate the person or thing that is
  indirectly affected by the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25955-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the person affected by the action is 'me', use 'me'; if the person affected by
  the action is 'you', use 'te'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25955-5
  a curric:KeyLearningPoint ;
  rdfs:label """To refer to one person or thing indirectly affected by an action use 'le', for more
  than one person or thing use 'les'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25947-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns ('to, for him', 'them') indicate the person or thing that
  is indirectly affected by the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25947-2
  a curric:KeyLearningPoint ;
  rdfs:label "To refer to one person or thing indirectly affected by an action, use 'le'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25947-3
  a curric:KeyLearningPoint ;
  rdfs:label "If more than one person or thing is indirectly affected, use 'les'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25947-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish sentences can start with the subject ('doer') or the object
  ('receiver')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25947-5
  a curric:KeyLearningPoint ;
  rdfs:label """The personal 'a' is used before the object when it is a specific person or animal we
  have a name for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25878-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words with stress on the third-last syllable have an accent on the stressed
  vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25878-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person singular of -er and -ir verbs ends in (-í) in the preterite."@en ;
  dcterms:modified "2026-06-07T15:30:29.631312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25878-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 2nd person singular of -er and -ir verbs ends in (-iste) in the preterite."@en ;
  dcterms:modified "2026-06-07T15:30:29.631318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25884-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to try out a variety of different methods for remembering vocabulary
  to find those that work best for you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25884-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Es' is part of the verb 'ser' and it means 'she, he, it is'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25884-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tiene' is part of the verb 'tener' and it means 'she, he, it has'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25884-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Hay' is part of the verb 'haber' and it means 'there is, there are'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25882-1
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix '-tion' at the end of an English word is often '-ción' in Spanish; all
  '-ción' words are feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25882-2
  a curric:KeyLearningPoint ;
  rdfs:label """'-ción' words lose the accent in the plural form; this is because the stress now
  falls on the penultimate syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25882-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'dar' means 'to give, giving'; its plural 'we' form is 'damos'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25882-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'querer' means 'to want, wanting'; its plural 'we' form is 'queremos'."@en ;
  dcterms:modified "2026-06-07T15:30:29.631618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25847-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some Spanish infinitives end in -er and -ir; we call  them -er and -ir verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.631934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25847-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb ending changes depending on who the verb refers to; the second person
  singular 'you' ending is -es;"""@en ;
  dcterms:modified "2026-06-07T15:30:29.631938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25847-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing from memory, it is important to practise language thoroughly first,
  especially verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25847-4
  a curric:KeyLearningPoint ;
  rdfs:label """Second person singular verbs are useful for asking questions, when writing to
  someone else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25910-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice of sound-symbol correspondences is essential to ensure good
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25910-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish verb infinitives end in -ar, -er or -ir. The verb ending changes depending
  on who is doing the action and when."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25910-3
  a curric:KeyLearningPoint ;
  rdfs:label """This is conjugation; -er/-ir verbs follow the same present tense conjugation
  pattern: -o (I), -es (you), -e (she, he)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25910-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses subject pronouns for contrast or emphasis, whereas English always uses
  them with verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25910-5
  a curric:KeyLearningPoint ;
  rdfs:label """The singular subject pronouns in Spanish are 'yo' ('I'), 'tú' ('you singular'), 'él'
  ('he') and 'ella' ('she')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25802-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ce] and [ci] are pronounced as in 'centro' and 'decir'. These sounds differ accross
  the Spanish-speaking world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25802-2
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite articles in Spanish are 'un', 'una', 'unos' and 'unas'. They mean
  'a', 'an', and 'some'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25802-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish verb endings change depending on who the verb refers to."@en ;
  dcterms:modified "2026-06-07T15:30:29.633149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25802-4
  a curric:KeyLearningPoint ;
  rdfs:label "Regular -ar verbs in 1st person singular end in -o."@en ;
  dcterms:modified "2026-06-07T15:30:29.633154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25802-5
  a curric:KeyLearningPoint ;
  rdfs:label "Regular -ar verbs in 3rd person singular end in -a."@en ;
  dcterms:modified "2026-06-07T15:30:29.633158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Peru is on the west coast of South America; it has a rich history of indigenous
  cultures and Spanish colonisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25964-2
  a curric:KeyLearningPoint ;
  rdfs:label """Atahualpa was the last Inca king. Francisco Pizarro was the Spanish conquistador who
  invaded Peru in search of gold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25964-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses the preterite tense for completed actions. Preterite verb endings
  change depending on the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25964-4
  a curric:KeyLearningPoint ;
  rdfs:label """To express 'she, he, it' in the preterite, remove -ar and add -ó. This is the 3rd
  person singular form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25964-5
  a curric:KeyLearningPoint ;
  rdfs:label """To express 'they' (m,f) in the preterite tense, remove -ar and add -aron. This is
  the 3rd person plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25982-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-spelling correspondences [n] and [ñ] are pronounced differently: like the
  [n] in 'poner' and the [ñ] in 'año'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25982-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' means 'to be' and is used to express a state or location. 'You are' is
  'estás' and 'you were' is 'estabas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25982-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'estar' in the present + present participle to describe ongoing events. This
  is called the present continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25982-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'estar' in the imperfect + present participle to describe past ongoing
  events; this is the imperfect continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25982-5
  a curric:KeyLearningPoint ;
  rdfs:label """The present participle stays the same: remove the infinitive ending and add -ando
  for -ar verbs and -iendo for -er/-ir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25950-1
  a curric:KeyLearningPoint ;
  rdfs:label "To mean ‘your’ for one person before a singular noun, use ‘tu’."@en ;
  dcterms:modified "2026-06-07T15:30:29.634115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25950-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘your’ for more than one person before a masculine singular noun, use
  ‘vuestro’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25950-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘your’ for more than one person before a feminine singular noun, use
  ‘vuestra’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25950-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form 2nd person singular -ar verbs in the present tense, use the verb
  ending -as."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25950-5
  a curric:KeyLearningPoint ;
  rdfs:label """To form 2nd person plural -ar verbs in the present tense, use the verb
  ending -áis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25920-1
  a curric:KeyLearningPoint ;
  rdfs:label """If a Spanish word has final syllable stress, and ends in a vowel or -n/-s, there
  will be an accent on the last vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25920-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ir' is irregular and means 'to go'. 'I go' is 'voy', 'you go' is 'vas' and
  'she, he, it goes' is 'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25920-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the preterite tense the singular forms of 'ir' are: 'fui' (I went), 'fuiste' (you
  went) and 'fue' (she, he, it went)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25920-4
  a curric:KeyLearningPoint ;
  rdfs:label """'To' is 'a' in Spanish; before a feminine noun 'to the' is 'a la', before a
  masculine noun it is 'al'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25920-5
  a curric:KeyLearningPoint ;
  rdfs:label """To create some Spanish adverbs from adjectives you take the feminine form (ending in
  -a) and add -mente on the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25991-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words stressed on the penultimate syllable don’t have an accent if they end in a
  vowel, -n or -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25991-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect continuous describes what someone was doing, e.g. 'estaba(s) caminando
  por la montaña.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.634988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25991-3
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used for completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.634992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25991-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can give extra information about when something happened using the relative
  pronoun 'cuando'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25991-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'cuando' + preterite to show a short action interrupts a longer, ongoing
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25860-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before reading aloud, it is important to identify tricky sound-symbol
  correspondences (SSCs) and rehearse mentally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25860-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish modal verbs (e.g. 'can') change ending to match the person doing the action
  and are followed by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25860-3
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive 'my' in Spanish is 'mi' for one thing and 'mis' for more than one
  thing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25860-4
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive your’ in Spanish is 'tu' for one thing and 'tus' for more than one
  thing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25963-1
  a curric:KeyLearningPoint ;
  rdfs:label """Colombia is a country in the northwest of Latin America; its capital city is
  Bogotá."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25963-2
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs, the 1st person singular ('I') preterite tense ending is -é, e.g.
  'recaudé fondos' - 'I collected money'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25963-3
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs ending in -car, the 1st person singular ending is -qué and for those
  ending in -gar, the ending is -gué."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25963-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person plural ('we') ending -amos is the same in the present and preterite
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25963-5
  a curric:KeyLearningPoint ;
  rdfs:label """Time adverbs like 'normalmente' ('normally') or 'ayer' ('yesterday') help
  distinguish between past and present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25933-1
  a curric:KeyLearningPoint ;
  rdfs:label """The present-tense forms of 'ir' ('to go') for 'I', 'you' and 'she, he, it' are
  'voy', 'vas' and 'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25933-2
  a curric:KeyLearningPoint ;
  rdfs:label """A present-tense form of 'ir' + a + infinitive means 'going to' + infinitive. It
  expresses future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25933-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite-tense forms of 'ir' ('to go') for 'I', 'you' and 'she, he, it' are
  'fui', 'fuiste' and 'fue'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25933-4
  a curric:KeyLearningPoint ;
  rdfs:label """A preterite-tense form of 'ir' + a + infinitive means 'went to' + infinitive. It
  expresses what someone went to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25933-5
  a curric:KeyLearningPoint ;
  rdfs:label "[j] is pronounced as in 'ejemplo' and [gu] is pronounced as in 'pregunta'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25912-1
  a curric:KeyLearningPoint ;
  rdfs:label """The preterite is used to describe completed past events. For the 'I' form with -ar
  verbs, you remove the -ar and add -é."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25912-2
  a curric:KeyLearningPoint ;
  rdfs:label """For -ar verbs ending in -car, remove -car and add -qué for the 'I' form in the
  preterite, e.g. 'saqué' - 'I took out'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25912-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about a mixed-gender group of people, you use the masculine form of the
  noun, e.g. ‘mis hermanos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25912-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the possessive adjective 'my' is 'mi' before a singular noun, and 'mis'
  before a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25912-5
  a curric:KeyLearningPoint ;
  rdfs:label """The possessive adjective 'his', 'her' or 'its' is 'su' before a singular noun, and
  'sus' before a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26000-1
  a curric:KeyLearningPoint ;
  rdfs:label "The demonstrative adjective 'this' for a singular masculine noun is 'este'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26000-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'that' for a singular masculine noun, use 'ese', e.g. 'ese recuerdo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26000-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'this' for a singular feminine noun, use 'esta', e.g. 'esta cola'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26000-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'that' for a singular feminine noun, use 'esa', e.g. 'esa cola'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26000-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'more … than', use 'más' + adjective + 'que'. To say 'less … than', use
  'menos' + adjective + 'que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25983-1
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'de' joins two nouns to describe a type of something, e.g. ‘un
  billete de avión’ ('a plane ticket')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25983-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'estar' in the present tense + present participle to talk about ongoing
  events; this is the present continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25983-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' in the imperfect + present participle describes what someone was doing; this
  is the imperfect continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25983-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes an action interrupts what someone was doing. We use 'cuando' followed by
  the preterite to express this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25914-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [a], [e] and [o] are strong vowels which are pronounced as separate
  syllables when they appear together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25914-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say possessive adjective 'our' in Spanish, use 'nuestro'. 'Nuestro' needs to
  agree in gender with the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25914-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' is used to describe states. The adjective must agree with the noun
  in gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25914-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'more ... than', use 'más' + adjective + 'que': 'Ana está más feliz que
  Alex.' 'Ana is happier than Alex.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.636420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25914-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'less ... than', 'menos' + adjective + 'que': 'Jun está menos enfermo que
  Sam.' 'Jun is less ill than Sam.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.636424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25828-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [e] is pronounced as in 'elefante'"@en ;
  dcterms:modified "2026-06-07T15:30:29.636428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25828-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [i] is pronounced as in 'idea'"@en ;
  dcterms:modified "2026-06-07T15:30:29.636432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25828-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person plural of present tense -AR verbs ends in -amos."@en ;
  dcterms:modified "2026-06-07T15:30:29.636436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25828-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Junto' and 'solo' describe verbs like adverbs but agree for gender and number like
  adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25901-1
  a curric:KeyLearningPoint ;
  rdfs:label """In English, we can use words like 'him', 'her' or 'it' (direct object pronouns) to
  avoid repeating nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25901-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, we use 'lo' to mean 'him' or 'it' (for masculine objects)."@en ;
  dcterms:modified "2026-06-07T15:30:29.637003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25901-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use 'la' to mean 'her' or 'it' (for feminine objects)."@en ;
  dcterms:modified "2026-06-07T15:30:29.637008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25901-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish object pronouns go before the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.637012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25901-5
  a curric:KeyLearningPoint ;
  rdfs:label """'La' before a noun is an article and means 'the', but before a verb it is a DOP and
  means 'her' or 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25880-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [ca], [co] and [cu] are pronounced as in 'casa', 'comer', 'escuchar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25880-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' means 'to have, having' and we use it to talk about
  possessions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25880-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular persons of 'tener' are 'tengo' ('I have'), 'tienes' ('you have') and
  'tiene' ('she, he, it has')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25880-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Spanish singular subject pronouns are: 'yo', 'tú', 'él', 'ella'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25880-5
  a curric:KeyLearningPoint ;
  rdfs:label """We need numbers to talk about plural possessions; such sentences often contain
  'tener', numbers and plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25794-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [u] is ponounced as in 'universo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25794-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ser' is used to describe general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.637044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25794-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Soy', 'eres' and 'es' are the 1st, 2nd and 3rd person singular forms of 'ser'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25830-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound [u] is pronounced as in 'universo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25830-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'poder' means to be able/can'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25830-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Puedo' means 'I am able to/can' and 'puede' means she, he, it is able/can'."@en ;
  dcterms:modified "2026-06-07T15:30:29.637061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25830-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'poder' is followed by an infinitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.637065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25911-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ce] is pronounced as in 'centro', [ci] is pronounced as in 'decir' and [z]
  is pronounced as in 'zapato'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25911-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different ways to pronounce [ce], [ci] and [z] in the Canary Islands/Latin
  America and mainland Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25911-3
  a curric:KeyLearningPoint ;
  rdfs:label """When followed by a verb infinitive the Spanish preposition 'para' means 'in order
  to' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25911-4
  a curric:KeyLearningPoint ;
  rdfs:label """To conjugate -ar verbs in their singular forms, remove the -ar and add the verb
  ending: -o (I), -as (you), -a (she, he)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25911-5
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, we use the same verb for routine or current actions. In English it is
  either present simple or continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25956-1
  a curric:KeyLearningPoint ;
  rdfs:label """The -tion ending of an English word often changes to -ción in Spanish, e.g. 'nation'
  - 'nación'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25956-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a word ending in -n or -s has final syllable stress, use an accent, otherwise, no
  accent is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25956-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about where someone goes (present) use the verb ‘ir’, e.g. ‘voy’, ‘vas’,
  ‘va’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25956-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘to the’, use ‘a la’ for singular feminine nouns and ‘al’ for singular
  masculine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25956-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the preterite tense, the verb ‘ir’ does not follow general conjugation rules,
  e.g. ‘fui’, ‘fuiste’, ‘fue’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25984-1
  a curric:KeyLearningPoint ;
  rdfs:label """The two different [r] sounds sometimes change the meaning of a word, e.g. 'pero' -
  'but', 'perro' - 'dog'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25984-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about a completed event in the past, we use the preterite tense, e.g. 'mandé
  un correo ayer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25984-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that used to happen repeatedly in the past, we use the
  imperfect tense, e.g. 'mandaba'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25984-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the imperfect tense, the verb 'estar' can be translated with 'was, were' or 'used
  to', e.g. 'estaba feliz'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25916-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'parecer' means 'to seem, seeming'. After a modal verb like 'poder', we use
  it in its infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25916-2
  a curric:KeyLearningPoint ;
  rdfs:label """Demonstrative adjectives (e.g. ‘this’, ‘these’) are used to distinguish one thing
  from another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25916-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'this' for a singular masculine noun, use 'este', to say 'these' for a plural
  masculine noun, use 'estos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25916-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'this' for a singular feminine noun, use 'esta', to say 'these' for a plural
  feminine noun, use 'estas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25916-5
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish doesn't have a word for 'do' in questions like in English. Only the main
  verb is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25851-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ci] and [z] have different pronunciation to [si] in
  most parts of Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25851-2
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [ci], [si] and [z] are pronounced the same in Latin America, parts of
  southern Spain and the Canary Islands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25851-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'tener' is used to talk about possessions."@en ;
  dcterms:modified "2026-06-07T15:30:29.637586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25851-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ser' is used to talk about permanent traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.637590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25851-5
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' is used to talk about temporary states/moods and location."@en ;
  dcterms:modified "2026-06-07T15:30:29.637594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25954-1
  a curric:KeyLearningPoint ;
  rdfs:label """When strong vowels [a], [e] and [o] appear next to each other they are pronounced
  separately, in different syllables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25954-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second person singular of 'estar' is ‘estás’ and the 2nd person plural is
  ‘estáis’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25954-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use the present continuous to express an ongoing event. It is formed by using
  'estar' + the present participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25954-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘them’ when referring to a plural feminine object, use the direct object
  pronoun 'las' before a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25954-5
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘them’ for a plural masculine object, use the direct object pronoun 'los'
  before a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25972-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSCs [ce], [ci] and [z] are pronounced differently throughout the
  Spanish-speaking world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25972-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the demonstrative adjective 'este' to mean 'this' before a masculine noun, and
  'esta' before a feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25972-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'tener' means 'to have, having'."@en ;
  dcterms:modified "2026-06-07T15:30:29.638123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25972-4
  a curric:KeyLearningPoint ;
  rdfs:label "Singular forms of 'tener' are 'tengo', 'tienes' and 'tiene'."@en ;
  dcterms:modified "2026-06-07T15:30:29.638127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25972-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'tener que' to express obligation, meaning 'to have to'."@en ;
  dcterms:modified "2026-06-07T15:30:29.638131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25895-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [que] is pronounced as in the word '¿por qué?' and
  [qui] as in the word 'equipo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25895-2
  a curric:KeyLearningPoint ;
  rdfs:label "The preterite tense is used to describe completed actions in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.638209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25895-3
  a curric:KeyLearningPoint ;
  rdfs:label """For -er and -ir verbs, for 'I' we remove the ending and add -í, for 'you' we add
  -iste and for 'she, he, it' we add -ió."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25895-4
  a curric:KeyLearningPoint ;
  rdfs:label """Being able adapt a sentence creatively using linguistic knowledge is important for
  speaking, vocabulary and writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25990-1
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that used to happen in the past, we use the
  imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25990-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘there used to be’, ‘there was’ or ‘there were’, use ‘había’. Sentences with
  ‘había’ often start with ‘en’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25990-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say ‘I, she, he used to have’ or ‘I, she, he had’ in the imperfect tense, use
  ‘tenía’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25990-4
  a curric:KeyLearningPoint ;
  rdfs:label """With other -ar verbs, to talk about 'she' or 'he', add -aba to the stem of the verb.
  With -er and -ir verbs, add -ía."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25990-5
  a curric:KeyLearningPoint ;
  rdfs:label """Don Quijote de La Mancha, written by Miguel de Cervantes, is considered the first
  modern novel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25845-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting vocabulary frequently alone or with a partner deepens word knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.638798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25845-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular ending for -er and -ir verbs is -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.638802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25845-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 3rd person singular form of the verb refers to she, he or it."@en ;
  dcterms:modified "2026-06-07T15:30:29.638806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25845-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important when speaking to enunciate the difference between infinitive and 3rd
  person singular verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638810Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-25985
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use imperfect tense verbs to talk about what I and others used to do in the
  past."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063060Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25987
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use modal and imperfect tense verbs to describe my own and other people's past
  routines."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063091Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25883
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use the irregular verb 'dar' to say how something makes people feel."@en ;
  dcterms:modified "2026-06-07T15:30:41.063100Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25887
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say where people are going, what they are going to do and why."@en ;
  dcterms:modified "2026-06-07T15:30:41.063139Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25877
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the correct position of adjectives when talking about activities at
  school."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063158Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25892
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the present and preterite tense of -er/-ir verbs to talk about
  travelling."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063170Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25931
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and correctly pronounce -ar verbs in the preterite tense in the
  context of a Spanish festival."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063705Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25865
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions about summer holidays using the present and preterite
  tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063722Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25886
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what people are going to do and where."@en ;
  dcterms:modified "2026-06-07T15:30:41.064038Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25915
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the comparatives 'mejor que' and 'peor que' to compare feelings,
  experiences and singers at a music festival."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064147Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25900
  a curric:PupilLessonOutcome ;
  rdfs:label """I can change the positions of the subject and object in a sentence and use them
  correctly to show who is performing the action and who is receiving it."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064225Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25857
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my knowledge of 'ir' and 'ir + a + infinitive' together with other
  vocabulary to talk about routine actions and future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064241Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25945
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use gustar-type verbs to share opinions about activities on a school trip."@en ;
  dcterms:modified "2026-06-07T15:30:41.064374Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25893
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the preterite and subject pronouns to compare different people's past
  travel experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064533Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25939
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use reflexive pronouns 'me' and 'te' to describe my daily routine and ask you
  questions about yours."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064855Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25929
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the present continuous to describe what we or they are doing now, and
  'querer' + infinitive to say what we or they want to do, in the context of describing film
  scenes."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064859Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25925
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use present tense verbs to talk about what people celebrate at school."@en ;
  dcterms:modified "2026-06-07T15:30:41.065038Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25971
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use -ar verbs in the preterite tense to describe a languages festival at
  school."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065199Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25873
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use modal verbs 'deber' and 'poder' to understand and write about what I and
  others must and can do in class and at home."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065209Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25870
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use subject pronouns and singular forms of 'hacer' to contrast the activities
  I do with those you, she, or he does."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065494Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26008
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use -ar, -er and -ir verbs in the preterite tense to describe past holiday
  activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065713Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25996
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use indirect object pronouns and gustar-type verbs to talk about
  friendships."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066078Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25941
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the reflexive pronoun 'se' before a range of verbs in the context of
  describing the Mexican custom 'Day of the Dead'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066119Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25812
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use the singular definite article to talk about places in town."@en ;
  dcterms:modified "2026-06-07T15:30:41.066135Z"^^xsd:dateTime .

