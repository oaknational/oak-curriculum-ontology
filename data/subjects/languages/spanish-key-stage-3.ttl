oakcurric:priorknowledge-3122-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know singular forms of modal verb 'querer' and can use these with a second
  verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:29:23.102342Z"^^xsd:dateTime .

