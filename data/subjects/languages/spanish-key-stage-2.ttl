oakcurric:priorknowledge-3200-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that many Spanish adjectives follow the noun."@en ;
  dcterms:modified "2026-06-07T15:29:23.348783Z"^^xsd:dateTime .

oakcurric:priorknowledge-3200-4
  a curric:PriorKnowledgeRequirement ;
