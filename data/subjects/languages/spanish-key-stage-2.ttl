oakcurric:priorknowledge-3498-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a range of key sounds, including vowels and their combinations with 'g'
  and 'c'."""@en ;
  dcterms:modified "2026-06-07T15:29:23.374480Z"^^xsd:dateTime .

oakcurric:priorknowledge-3498-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form singular persons of -ar and -er verbs in the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.374490Z"^^xsd:dateTime .

oakcurric:priorknowledge-3498-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a range of nouns, adjectives and verbs for describing everyday
  actions."""@en ;
  dcterms:modified "2026-06-07T15:29:23.374496Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify what nouns are in English and know how they are used."@en ;
  dcterms:modified "2026-06-07T15:29:23.456089Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can identify what adjectives are in Spanish and English and how they are
  used."""@en ;
  dcterms:modified "2026-06-07T15:29:23.456102Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the sound-symbol correspondences: [ca] [co] [cu] [a] [o] [u] [e] [i]"@en ;
  dcterms:modified "2026-06-07T15:29:23.456107Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the phrases ¡Buenos días! ¡Buenas tardes! ¡Adiós!"@en ;
  dcterms:modified "2026-06-07T15:29:23.456112Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the question ¿Cómo estás? meaning 'How are you?'"@en ;
  dcterms:modified "2026-06-07T15:29:23.456117Z"^^xsd:dateTime .

oakcurric:priorknowledge-3195-6
