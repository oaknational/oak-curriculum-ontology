oakcurric:keylearningpoint-lesson-25667-1
  a curric:KeyLearningPoint ;
  rdfs:label "The possessives 'my' and 'your' are a type of determiner."@en ;
  dcterms:modified "2026-06-07T15:30:29.000470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25667-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'mi' to say ‘my’ in Spanish before a singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.000476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25667-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'tu' to say ‘your’ in Spanish before a singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.000481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25667-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish possessives 'mi' and 'tu' do not change for the gender of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.000485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25688-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying features of a voice message helps to revise key vocabulary and
  grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Composing a message yourself means selecting the nouns, adjectives and verbs you are
  going to use, then writing it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25688-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing what you are going to say helps you improve fluency, i.e. how smooth and
  natural speech your speech sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25688-4
  a curric:KeyLearningPoint ;
  rdfs:label """Repeated rehearsal improves your pronunciation, speed and intonation, some key
  components of fluency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25625-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ce] can be practised by pronouncing words such as
  'centro' and 'doce'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25625-2
  a curric:KeyLearningPoint ;
  rdfs:label "All nouns in Spanish have grammatical gender, masculine or feminine."@en ;
  dcterms:modified "2026-06-07T15:30:29.002072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25625-3
  a curric:KeyLearningPoint ;
  rdfs:label "The masculine word for 'a/an' is 'un', the feminine word for 'a/an' is 'una'."@en ;
  dcterms:modified "2026-06-07T15:30:29.002076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25625-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'to have' is 'tener'; 'I have' is 'tengo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.002080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25748-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting vocabulary helps us review important and useful Spanish words that we can
  confidently use in class."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25748-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, we can use the 1st person plural - the 'we' form - for classroom
  instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25748-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the 'we' form with regular -ar verbs, remove the -ar ending and add
  -amos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25748-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the 'we' form with regular -er verbs, remove the -er ending and add
  -emos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25748-5
  a curric:KeyLearningPoint ;
  rdfs:label """With Spanish verbs, we don't usually need to use the pronouns; the verb ending tells
  us who does the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25760-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, all words with last syllable stress that end in -n, -s or a vowel have
  an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25760-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'hacer' means 'to do' and 'to make'. It can also mean 'to go' with some
  sports."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25760-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'I' form is irregular. To say 'I do', use 'hago'; 'you do' is 'haces'; 'she, he,
  it does' is 'hace'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25760-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also use 'hago', 'haces', 'hace' to mean 'I am doing', 'you are doing', 'she,
  he, it is doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25760-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say the position of something, use 'a la derecha' to mean 'on the right' and 'a
  la izquierda' to mean 'on the left'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25704-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using known words, cognates and context can help you decipher the meaning of
  unfamiliar words like a word detective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25704-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ask someone who they are, use ¿quién eres?. To ask what they are like generally
  use ¿cómo eres?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.004857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25704-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'ser' meaning 'to be, being' is used for general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.004861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25704-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' meaning 'to be, being' is used for location and temporary
  states."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25650-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [qui] can be contrasted for practice with the key
  sound [ci]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25650-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before nouns to indicate how many there are. Numbers do not change
  their spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns ending in -o, -a or -e makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.253601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25650-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘¿Tienes?’ means ‘Do you have?’ There is no word for ‘do’ in intonation
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25769-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inti Raymi (Festival of the Sun) is an ancient festival celebrating the winter
  solstice and Inti, the Sun God."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25769-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Todo' means everything, all (of). When 'todo' is used before a noun, the spelling
  changes to match gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25769-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Todo el mundo' means 'everyone'."@en ;
  dcterms:modified "2026-06-07T15:30:29.254591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25769-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Mucho' means 'many', 'lots of'. When 'mucho' is used before a noun, the spelling
  changes to match gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25769-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Arriba' means 'above', 'abajo' is 'below', 'a la izquierda' means 'on the left', 'a
  la derecha' is 'on the right'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25714-1
  a curric:KeyLearningPoint ;
  rdfs:label "Short texts are useful to help revise vocabulary in a real-life context."@en ;
  dcterms:modified "2026-06-07T15:30:29.255216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25714-2
  a curric:KeyLearningPoint ;
  rdfs:label """'El' is used to mean 'on the' with specific dates. It is not used for
  today's date."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25714-3
  a curric:KeyLearningPoint ;
  rdfs:label """Days of the week, months of the year and numbers 1-31 are used to understand and
  communicate dates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25714-4
  a curric:KeyLearningPoint ;
  rdfs:label "To ask when a specific event is, use '¿Cuál es la fecha de ... ?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25746-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-spelling correspondences [r] and [rr] look similar and have the same letter;
  however, they make a different sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25746-2
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs communicate what I and others do or how they are."@en ;
  dcterms:modified "2026-06-07T15:30:29.255622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hacer is an irregular -er verb in the 'I' form. I do is hago."@en ;
  dcterms:modified "2026-06-07T15:30:29.255626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25746-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular verbs follow regular rules; we change the -ar and -er infinitives to match
  the person doing the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25746-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'she, he, it' with regular -er and -ar verbs, remove the -er / -ar. For -ar
  verbs, add -a, and for -er, add -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25624-1
  a curric:KeyLearningPoint ;
  rdfs:label """A range of familiar sound-symbol correspondences can be practised in a Christmas
  carol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25624-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singular ‘ser’ can be used to understand information about Christmas traditions in
  Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular ‘estar’ can be used to understand where things are and how people feel at
  this time of year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25646-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter ‘g’ before vowels ‘a’ and ‘o’ is a hard sound, as in ‘ganar’ (to win,
  winning) and ‘lago’ (lake)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25646-2
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article ‘the’ in Spanish is ‘el’ for masculine and ‘la’ for feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25646-3
  a curric:KeyLearningPoint ;
  rdfs:label "To mean ‘I’ with a verb, we remove -ar and add the the ending -o."@en ;
  dcterms:modified "2026-06-07T15:30:29.256538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25725-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can practise vowel sounds and the sound-spelling correspondences [ca], [co],
  [cu] by reading a poem aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25725-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about things in the plural, Spanish often adds 's' to the end of the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25725-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'some' before a masculine plural noun, we use 'unos'; to say 'some' before a
  feminine plural noun, we use 'unas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25725-4
  a curric:KeyLearningPoint ;
  rdfs:label "To turn a statement into a question, you raise your voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.256573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25725-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say, 'I have' or 'do I have' use 'tengo'; to say 'you have' or 'do you have', use
  tienes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25666-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [gue] gui] can be contrasted with [ge] and
  [gi]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25666-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two ways to say 'you are' in Spanish: 'eres' and 'estás'."@en ;
  dcterms:modified "2026-06-07T15:30:29.257990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25666-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are two ways to say 'I am' in Spanish: 'soy' and 'estoy'."@en ;
  dcterms:modified "2026-06-07T15:30:29.257994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25666-4
  a curric:KeyLearningPoint ;
  rdfs:label "The subject pronouns for 'I' and 'you' are 'yo' and 'tú'."@en ;
  dcterms:modified "2026-06-07T15:30:29.257998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25666-5
  a curric:KeyLearningPoint ;
  rdfs:label "Subject pronouns can be used for clarity and emphasis."@en ;
  dcterms:modified "2026-06-07T15:30:29.258002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25661-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondences [ge] and [gi] can be contrasted for practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.258271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25661-2
  a curric:KeyLearningPoint ;
  rdfs:label """These are soft sounds and sound similar to the sound-spelling correspondence
  [j]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reference resources develop independent writing. Resources, like dictionaries,
  indicate word class and gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25661-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree with the gender of the noun. Adjectives add detail to
  description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25740-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-spelling correspondences [ga], [go, [gu] can be contrasted with one
  another for practice and accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25740-2
  a curric:KeyLearningPoint ;
  rdfs:label "Learning new words is important and useful in the languages classroom."@en ;
  dcterms:modified "2026-06-07T15:30:29.258391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25740-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'she, he, it' with an -er verb, remove the -er ending and add -e."@en ;
  dcterms:modified "2026-06-07T15:30:29.258395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25740-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'we' with an -er verb, remove the -er ending and add -emos."@en ;
  dcterms:modified "2026-06-07T15:30:29.258399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25740-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the 3rd person singular and 1st person plural forms of verbs to say who
  does what."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25755-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-spelling correspondences [r] and [rr] are pronounced differently: [r] as
  in ‘armario’ and [rr] as in ‘perro’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25755-2
  a curric:KeyLearningPoint ;
  rdfs:label """The irregular verb ‘ir’ means ‘to go, going’. To say 'I go, I’m going' use 'voy'.
  'You go, you’re going' is 'vas'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25755-3
  a curric:KeyLearningPoint ;
  rdfs:label """With 'ir', use 'al' or 'a la' to say 'to the' depending on whether the following
  noun is masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25755-4
  a curric:KeyLearningPoint ;
  rdfs:label """When 'estar' is used for location it is often followed by the preposition 'en'; this
  can mean 'in', 'on' or 'at'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25779-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting vocabulary like numbers, colours and animals is important; it helps you
  remember previously learnt words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25779-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring a poem builds grammar, vocabulary and fluency."@en ;
  dcterms:modified "2026-06-07T15:30:29.259501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25779-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reference resources like dictionaries give word meaning, word class and gender, and
  develop independent writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25779-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives agree with the gender and number of the noun; they add detail to
  description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25635-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondence [ci] is pronounced differently in Spanish and English
  and benefits from frequent practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25635-2
  a curric:KeyLearningPoint ;
  rdfs:label """'tiene' is part of the verb 'tener' and means 'she, he, or it has' or just 'has'.
  E.g., Sofía tiene una bici."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25635-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cognates are words that are exactly or nearly the same in two or more languages."@en ;
  dcterms:modified "2026-06-07T15:30:29.260486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25753-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-spelling correspondences [b] and [v] sound the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.261125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25753-2
  a curric:KeyLearningPoint ;
  rdfs:label """The compass points, norte, sur, este and oeste can be used to say where places are
  in Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25753-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ir' means to go, going and is an irregular verb. To say 'I go' use 'voy'.
  To say 'she, he, it goes' use 'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25753-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish word 'a' means to. When used before a feminine noun, use 'a la'. When used
  before a masculine noun, use 'al'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25715-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel [i] is a weak vowel and it merges with [a], [e] and [o] to make a single
  syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25715-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two verbs 'to be, being' in Spanish: 'ser' and 'estar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25715-3
  a curric:KeyLearningPoint ;
  rdfs:label "From the verb ‘estar’, 'están' is 'they are' for location and temporary states."@en ;
  dcterms:modified "2026-06-07T15:30:29.261166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25715-4
  a curric:KeyLearningPoint ;
  rdfs:label "From the verb ‘ser’, 'son' is 'they are' for general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.261170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25715-5
  a curric:KeyLearningPoint ;
  rdfs:label """To describe more than one noun, plural masculine adjectives end in -os, feminine in
  -as; adjectives ending in -e add -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any vowel with a written accent is stressed. For words ending in vowels, -n or -s,
  stress the penultimate syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25745-2
  a curric:KeyLearningPoint ;
  rdfs:label "For all other words, stress the final syllable."@en ;
  dcterms:modified "2026-06-07T15:30:29.261184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25745-3
  a curric:KeyLearningPoint ;
  rdfs:label "Learning new vocabulary helps develop your understanding and comprehension."@en ;
  dcterms:modified "2026-06-07T15:30:29.261188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25745-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many Spanish infinitives end in -ar; they are called-ar verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.261192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25745-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'she, he' with -ar verbs, remove the -ar ending and add -a. To say 'they',
  remove the -ar ending and add -an."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25653-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowels [a] [e] [i] [o] [u] are pronounced differently in Spanish and in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25653-2
  a curric:KeyLearningPoint ;
  rdfs:label """When you know the sound-symbol correspondences (SSCs) you can read aloud words and
  short sentences correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25653-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of Spanish sound-spelling correspondences can be strengthed by joining in
  with a song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25653-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish verbs escuchar, escribir, leer and hablar are useful words to use in the
  classroom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25653-5
  a curric:KeyLearningPoint ;
  rdfs:label """Common instructions in Spanish lessons include escucha (listen), escribe (write),
  lee (read) and habla (speak)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25680-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [que] and [ce] have different initial sounds; hard
  and soft 'c' sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25680-2
  a curric:KeyLearningPoint ;
  rdfs:label "Revising vocabulary is important to develop confidence and improve recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.263680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25680-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'hacer' is irregular in its 1st person singular form; 'I do, make' is
  'hago'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25680-4
  a curric:KeyLearningPoint ;
  rdfs:label """'You do, make' is 'haces' and 'she, he, it does, makes' is 'hace'. These forms are
  regular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25674-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ga], [go] and [gu] have a hard ‘g’ sound; [ge] and [gi] have a softer ‘g’
  sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Symbols in a word list for reference provide with useful information about the type
  of word and noun gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25674-3
  a curric:KeyLearningPoint ;
  rdfs:label "A word list for reference is a useful tool for independent writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.264718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25674-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding symbols in a word list allows us to use correct indefinite articles
  and adjectival agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25749-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-spelling correspondences [que], [qui], [ce], [ci] can be usefully
  contrasted with one another for practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25749-2
  a curric:KeyLearningPoint ;
  rdfs:label """I have is 'tengo' and you have is 'tienes'. For questions, use sentence words but
  just raise your voice at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25749-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'I don’t have' or 'you don’t have', simply put 'no' before the verb. This
  works with any person of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25749-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'my' in Spanish before singular and uncountable nouns, use 'mi'. Before
  plural nouns, use 'mis'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25749-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'your' in Spanish before singular and uncountable nouns, use 'tu'. Before
  plural nouns, use 'tus'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25768-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fiestas Patrias in Peru, celebrated on July 28 and 29, marks the country's
  independence from Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25768-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud familiar and unfamiliar words improves pronunciation and develops
  knowledge of Fiestas Patrias."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25768-3
  a curric:KeyLearningPoint ;
  rdfs:label """When 'todo' is used before a noun to mean 'all (of)', the spelling changes to match
  gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25768-4
  a curric:KeyLearningPoint ;
  rdfs:label """When 'mucho' is used before a noun to mean 'lots (of)', the spelling changes to
  match gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25609-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [e] sounds like the 'e' in the Spanish word
  'elefante'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25609-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'estar' means to be, being when describing mood or temporary state."@en ;
  dcterms:modified "2026-06-07T15:30:29.266123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses two question marks; the one at the front of the question is upside
  down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25732-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising and revisiting vocabulary reinforces learning and develops communication
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25732-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tener' means 'to have, having'; to say 'she, he, it has', use 'tiene'."@en ;
  dcterms:modified "2026-06-07T15:30:29.266472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25732-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Tiene' combines with the definite article, nouns and adjectives to describe facial
  features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25732-4
  a curric:KeyLearningPoint ;
  rdfs:label """Definite articles are used when describing facial features in Spanish; they agree
  with the noun number and gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25732-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives often come after the noun; they agree with the number and gender of the
  noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25723-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, many adjectives follow the noun. They agree with the number and gender
  of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25723-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -e stay the same for singular masculine and feminine nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.266517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25723-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'tener' means 'to have, having'. It is an irregular verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.266521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25723-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'I have', use 'tengo'. To say 'she, he, it is', use 'tiene'."@en ;
  dcterms:modified "2026-06-07T15:30:29.266524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25766-1
  a curric:KeyLearningPoint ;
  rdfs:label """La Tomatina is a Spanish festival in Buñol, where participants throw tomatoes at
  each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25766-2
  a curric:KeyLearningPoint ;
  rdfs:label """To read and say words accurately, it is important to know where the stress falls and
  how accents change pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25766-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'she, he, it' with an -ar verb, remove the -ar ending and add -a. To mean
  'they', remove -ar and add -an."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25766-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'she, he, it' with an -er verb, remove the -er ending and add -e. To mean
  'they', remove -er and add -en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25703-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish vowels [a] [e] [i] [o] [u] are pronounced the same no matter where they
  appear in a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25703-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' (to be, being) is for location and temporary states. 'Estoy' means
  ‘I am’ and 'estás' means ‘you are’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25703-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in -o change to -a for girls, women and feminine nouns. Those
  ending in -e and -z don’t change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25703-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Estar' can be combined with adjectives to say how you and others are feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.268111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25645-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [ll] and [l] can be contrasted and secured in a
  pronunciation game."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25645-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with a verb, the -ar verb ending changes to -o, e.g. 'hablo', I
  speak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25645-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'she, he, it' with a verb, the -ar verb ending changes to -a, e.g. 'habla',
  she, he, it speaks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25681-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [r] is pronounced as in 'pero'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25681-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [rr] is pronounced as in 'perro'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25681-3
  a curric:KeyLearningPoint ;
  rdfs:label """The definite articles for 'the' are 'el' and 'la' for masculine and feminine
  singular nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25681-4
  a curric:KeyLearningPoint ;
  rdfs:label """The definite articles for 'the' are 'las' and 'los' for masculine and feminine
  plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25681-5
  a curric:KeyLearningPoint ;
  rdfs:label """The opinion verbs 'amar' and 'odiar' can be used to say what you and others like or
  dislike."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25659-1
  a curric:KeyLearningPoint ;
  rdfs:label """The [j] sound in Spanish is not pronounced the same way in English. In Spanish, it
  sounds like a harsh [h] sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25659-2
  a curric:KeyLearningPoint ;
  rdfs:label """The words for the (definite article) or a/an, (indefinite article) change according
  to gender unlinke English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25659-3
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article for masculine nouns is 'el'. The definite article for feminine
  nouns is 'la'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25659-4
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite article for masculine nouns is 'un'. The indefinite article for
  feminine nouns is 'una'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25659-5
  a curric:KeyLearningPoint ;
  rdfs:label """Poems use a structure to create a verse. We can use this structure to create our own
  poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25735-1
  a curric:KeyLearningPoint ;
  rdfs:label """The [ch] sound in Spanish is the same as the English sound in the word
  'chocolate'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25735-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, nouns for things as well as people and animals are either masculine or
  feminine. We say they have gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25735-3
  a curric:KeyLearningPoint ;
  rdfs:label """'El' and 'la' mean 'the' before a singular noun and 'los' and 'las' mean 'the'
  before plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25735-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, many adjectives follow the noun and agree with the number and gender of
  the noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25735-5
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the definite article is used for physical features. In English, we omit
  these or say 'a' e.g. a small nose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25686-1
  a curric:KeyLearningPoint ;
  rdfs:label """Secure knowledge of sound spelling correspondences helps when pronouncing unfamiliar
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using singular persons of -ar, -er, -ir present tense verbs allows me to say what I
  and others do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25686-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can use context and known vocabulary to help you work out the meaning of
  unfamiliar words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25686-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading texts in the target language supports learning new vocabulary in
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25770-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud known and unknown words improves pronunciation and knowledge of
  sound-spelling correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25770-2
  a curric:KeyLearningPoint ;
  rdfs:label """Revising and extending vocabulary improves comprehension and communication
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25770-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Muchos'/'muchas' means 'many', 'a lot', 'lots of'. These are used before plural
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25770-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling of 'muchos'/'muchas' changes to match gender and number."@en ;
  dcterms:modified "2026-06-07T15:30:29.271352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25743-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, we stress any vowel that has a written accent."@en ;
  dcterms:modified "2026-06-07T15:30:29.273019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25743-2
  a curric:KeyLearningPoint ;
  rdfs:label """When there is no written accent, stress the penultimate syllable for any word ending
  in a vowel, [n] or [s]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25743-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say s/he, it with an -er verb, remove -er ending and add -e. To say 'we', remove
  -er ending and add -emos."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25743-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you or others don't do, put 'no' before the verb. This makes a negative.
  This works for any verb and person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25676-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [ga], [go], [gu] can be contrasted for
  practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25676-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with an -ar verb, the ending changes to -o. For 'you', change to -as.
  For 'she, he, it', change to -a."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25676-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verb endings indicate the person doing the action. Pronouns are not often used."@en ;
  dcterms:modified "2026-06-07T15:30:29.273091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25707-1
  a curric:KeyLearningPoint ;
  rdfs:label """To read and say words accurately, it is important to practise the vowel sounds: [a],
  [e], [i], [o], [u]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25707-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two verbs to say ‘to be, being’ in Spanish: estar and ser."@en ;
  dcterms:modified "2026-06-07T15:30:29.273599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25707-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'we are' with 'estar', we use 'estamos'. This means 'we are' for location
  and temporary states."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25707-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'we are' with 'ser', we use 'somos'. This means 'we are' for general
  traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25707-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing more than one, the adjective ends in -os with masculine nouns and
  -as with feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25777-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-spelling correspondences can be practised through reading and cultural
  learning about Lanzarote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25777-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Querer' means to want, wanting. To say I want, use 'quiero'; you want, use
  'quieres'; she, he, it wants, use 'quiere'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25777-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say someone wants to do something, use the correct form of the verb 'querer' and
  follow with an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25777-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say I want to do something, use 'quiero' followed by an infinitive. To give an
  opinion, use 'es' and an adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25641-1
  a curric:KeyLearningPoint ;
  rdfs:label "[z] and [c] are pronounced differently in different Spanish-speaking countries."@en ;
  dcterms:modified "2026-06-07T15:30:29.274618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25641-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, many adjectives follow the noun. For example, un regalo pequeño."@en ;
  dcterms:modified "2026-06-07T15:30:29.274624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25641-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, a statement becomes an intonation question by raising the tone of voice
  at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25648-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of sound-symbol correspondences helps when pronouncing unfamiliar
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25648-2
  a curric:KeyLearningPoint ;
  rdfs:label """All Spanish nouns are masculine or feminine and the words for 'a/an' and 'the' are
  'un, una' and 'el, la'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives agree for gender and many follow the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.285439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verb endings indicate the person doing the action of the verb and pronouns are often
  not used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25678-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [ca], [co], [cu] can be contrasted with [ga], [go], [gu]."@en ;
  dcterms:modified "2026-06-07T15:30:29.292120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25678-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular talks about 'I'. To mean 'I' with an -er verb, the ending
  changes to -o."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25678-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 2nd person singular talks about 'you'. To mean 'you' with an -er verb, the
  ending changes to -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25678-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 2nd person singular talks about 'you'. To mean 'you' with an -er verb, the
  ending changes to -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25678-5
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish statements become questions by raising tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.292136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25717-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weak vowels [i] and [u] merge with strong vowels a, [o], and [e] to make a single
  syllable,"""@en ;
  dcterms:modified "2026-06-07T15:30:29.292437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25717-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Day of the Dead is a Mexican holiday. Families set up and decorate special
  tables called 'altares'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25717-3
  a curric:KeyLearningPoint ;
  rdfs:label """The question word cuánto agrees with the gender and number of the noun it refers to:
  cuánto, cuánta, cuántos, cuántas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25717-4
  a curric:KeyLearningPoint ;
  rdfs:label """To describe plural nouns, add -s to adjectives ending in -a, -e and -o. For those
  ending in -l, -s or -z, we add -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25679-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [que], [ca], [co] can be contrasted with one
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25679-2
  a curric:KeyLearningPoint ;
  rdfs:label "Learning new vocabulary improves understanding and communication skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.293749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25679-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the singular persons of -er verbs in the present tense to talk about breaktime
  activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25679-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singular persons of 'er' verbs in the present tense are -o (I), -es (you) and -e
  (she, he, it)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25754-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sounds [b] and [v] are the same, so practising the spelling of familiar words
  helps to remember which letter to use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ir' means 'to go, going'. To say 'I go', use 'voy'. To say 'she, he, it
  goes', use 'va'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25754-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish word 'a' means 'to'. 'To the' with singular masculine nouns is 'al';
  with singular feminine nouns, 'a la'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25617-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [u] sounds like the ‘u’ in the Spanish word
  ‘universo’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25617-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Estás’ means 'you are' when talking about location."@en ;
  dcterms:modified "2026-06-07T15:30:29.301133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25617-3
  a curric:KeyLearningPoint ;
  rdfs:label """A statement becomes a 'yes/no' question by raising your tone of voice at the
  end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25610-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [e] can be practised with words such as ‘tener’ and
  ‘papel’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25610-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish pronouns are often not used; the verb ending indicates the person who is
  carrying out the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25610-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish question word ‘¿cómo?’ combine with ‘estar’ to ask how someone is."@en ;
  dcterms:modified "2026-06-07T15:30:29.302003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25719-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ca], [co], [cu] are hard sounds whilst [ce], [ci], [z] and [ch] are soft
  sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25719-2
  a curric:KeyLearningPoint ;
  rdfs:label "[a], [e], [o] are strong vowels whilst [i] and [u] are weak vowels."@en ;
  dcterms:modified "2026-06-07T15:30:29.302415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25719-3
  a curric:KeyLearningPoint ;
  rdfs:label """'La lotería de Navidad' is an annual event taking place on 22nd December. It is a
  tradition for families to buy tickets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25719-4
  a curric:KeyLearningPoint ;
  rdfs:label "The big prize is called 'El Gordo' and is worth a lot of money."@en ;
  dcterms:modified "2026-06-07T15:30:29.302423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25719-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' means 'to have, having'. To say 'I have' we use 'tengo'. To say
  'she, he, it has', we use 'tiene'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25729-1
  a curric:KeyLearningPoint ;
  rdfs:label """[z] is always followed by [a], [o] or [u]; [z] sounds the same as [c] in front of
  [e] and [i]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25729-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Tener' means to have, having; to say 'they have', use 'tienen', to say 'we have'
  use 'tenemos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25729-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Un' and 'una' are used with singular nouns; 'unos' and 'unas' are used with plural
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25729-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Detrás (de)', 'debajo (de) ' and 'en' are used to say where something is; 'detrás'
  and 'debajo' are followed by 'de'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25613-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [a], [o] and [u] can be practised with many place
  names in Spanish-speaking countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25613-2
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine adjectives that end in ‘o’ change to an ‘a’ when the person or animal
  being described is female."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25613-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in –e or -z can describe a female and male person or animal; they
  do not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25657-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [qui] can be contrasted for practice with the key
  sound [ci]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25657-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite articles 'unos' and 'unas' mean 'some' before masculine and feminine
  plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25657-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means 'there is' or 'there are' depending whether it precedes a singular or
  plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25619-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Soy' means 'I am', 'es' means 'she, he, it is' when describing general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.305625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25619-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish pronouns are often not used; 'es' can therefore mean 'she, he, it is' or
  just 'is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25619-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs 'normalmente' and 'siempre' tend to come at the beginning or end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25763-1
  a curric:KeyLearningPoint ;
  rdfs:label """For making plurals, add -s to words ending in vowels, -es to consonants, and change
  -z to -c before adding -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25763-2
  a curric:KeyLearningPoint ;
  rdfs:label """The singular persons of 'hacer' are 'hago', 'haces' and 'hace'. 'Hacer' has multiple
  meanings - to do, to make, to go."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25763-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular persons of 'jugar' are 'juego', 'juegas', 'juega'. 'Jugar' is followed by
  al before a masculine singular noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25763-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'jugar' with a game or ball sport and 'hacer' for other activities or non-ball
  sports. They are not interchangeable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25763-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'cuando' + 'es' + season or 'cuando' + 'hace' + weather to extend your
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25614-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish statements become questions by raising tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.308601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25614-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses two question marks; the one at the front of the question is upside
  down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25614-3
  a curric:KeyLearningPoint ;
  rdfs:label """When an adjective ends in -e or -z it can describe a female and male person or
  animal; it does not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25614-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many cities in Spanish-speaking countries contain [a] [o] [u]."@en ;
  dcterms:modified "2026-06-07T15:30:29.308614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25774-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tapas are small Spanish dishes - practising their names is a useful way to revisit
  sound-symbol correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25774-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'we' with an -ar verb, remove the -ar ending and add -amos. To say 'they',
  remove -ar ending and add -an."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25774-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'love' or 'hate' doing something, use the correct form of the verbs 'amar'
  and 'odiar' and add the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25774-4
  a curric:KeyLearningPoint ;
  rdfs:label """In English, phrases like 'we love' and 'we hate' can be followed by the infinitive
  (to + verb) or the gerund (-ing)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25677-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising word recall often helps to secure word knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.316082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25677-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular talks about ‘I'; to mean 'I' with an -er verb, the ending
  changes to -o."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25677-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular talks about 'she, he, it'; to form this with an -er verb,
  the ending changes to -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25677-4
  a curric:KeyLearningPoint ;
  rdfs:label "New vocabulary and verb structures can be practised through playing a game."@en ;
  dcterms:modified "2026-06-07T15:30:29.316094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25711-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Spanish vowels [a], [e], [o] are strong vowels. When they appear next to each
  other, they are pronounced separately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 16-19 use 'dieci-' + the numbers 6, 7, 8 or 9, all in one word."@en ;
  dcterms:modified "2026-06-07T15:30:29.317357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25711-3
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 21-29 use 'veinti-' and a number from 1-9, all in one word."@en ;
  dcterms:modified "2026-06-07T15:30:29.317361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25711-4
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 31-39 use 'treinta' + 'y' + a number from 1-9, in three separate words."@en ;
  dcterms:modified "2026-06-07T15:30:29.317365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25711-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many months are cognates. Unlike in English, they start with lowercase letters,
  unless at the start of a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25675-1
  a curric:KeyLearningPoint ;
  rdfs:label "Learning new vocabulary helps you express yourself."@en ;
  dcterms:modified "2026-06-07T15:30:29.319606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25675-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person singular form of the verb talks about 'I'; to mean 'I' with an -ar
  verb, the ending changes to -o."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25675-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 2nd person singular form of the verb refers to 'you'; to mean 'you' with an -ar
  verb, the ending changes to -as."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25675-4
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition 'por' means 'in' when used before times of the day."@en ;
  dcterms:modified "2026-06-07T15:30:29.319621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25675-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can use 'por' and 'en' to give more details."@en ;
  dcterms:modified "2026-06-07T15:30:29.319625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25758-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish all words with antepenultimate (third-last) syllable stress have an
  accent, e.g. música."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25758-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'hacer' means to do, to make. It is an irregular verb; I do is 'hago', she,
  he, it does is 'hace'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25758-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make a sentence negative, add 'no' before the verb. This works with any verb and
  any person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pablo Picasso was a famous Spanish artist whose portraits show objects and people
  using geometric shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25733-2
  a curric:KeyLearningPoint ;
  rdfs:label """Frida Kahlo was a famous Mexican artist known for painting self-portraits using
  bright colours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25733-3
  a curric:KeyLearningPoint ;
  rdfs:label "Describing images is an effective way of revising and practising vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.323807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25733-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Tiene' means 'she, he, it has' and is used with the definite article, nouns and
  adjectives to describe facial features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25733-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means both 'there is' and 'there are'. Sentences with 'hay' usually start with
  or contain 'en'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25665-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [gue] and [gui] sound like in 'juguete' and
  'seguir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25665-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two ways to say 'is' in Spanish: 'es' and 'está'."@en ;
  dcterms:modified "2026-06-07T15:30:29.326022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25665-3
  a curric:KeyLearningPoint ;
  rdfs:label "The subject pronouns for 'he' and 'she' are 'él' and 'ella'."@en ;
  dcterms:modified "2026-06-07T15:30:29.326026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Subject pronouns can be used for clarity and emphasis."@en ;
  dcterms:modified "2026-06-07T15:30:29.326030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25741-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any vowel with a written accent (a symbol) is stressed (pronounced more heavily and
  with greater emphasis)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25741-2
  a curric:KeyLearningPoint ;
  rdfs:label "New vocabulary helps us talk about different subjects, like fundraising events."@en ;
  dcterms:modified "2026-06-07T15:30:29.326620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25741-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say she, he, it with an -er verb, remove -er ending and add -e. To say you,
  remove -er ending and add -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25741-4
  a curric:KeyLearningPoint ;
  rdfs:label """To change a statement into a question, you raise your voice at the end. This is
  called raised intonation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25741-5
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish uses two question marks - a regular one at the end, like in English and an
  upside down one at the start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25762-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words with penultimate syllable stress that end in any other consonant other than
  'n' and 's' need an accent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25762-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'hacer' can mean 'to do',  'to make' and 'to go'."@en ;
  dcterms:modified "2026-06-07T15:30:29.326725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25762-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'hacer' is also used to mean it is' when describing the weather."@en ;
  dcterms:modified "2026-06-07T15:30:29.326729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25762-4
  a curric:KeyLearningPoint ;
  rdfs:label """To work out the correct meaning of the verb, you often have to use the context to
  understand it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25670-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [n] and [ñ] are pronounced differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.326736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25670-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before the noun to indicate how many. Numbers don't change spelling
  for gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25670-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' means 'to have, having' and with certain nouns, it also means 'to
  be, being'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25670-4
  a curric:KeyLearningPoint ;
  rdfs:label "We combine 'tener + number + años' to talk about age."@en ;
  dcterms:modified "2026-06-07T15:30:29.326748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25670-5
  a curric:KeyLearningPoint ;
  rdfs:label "To ask someone's age, say '¿Cuántos años tienes?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.326752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25671-1
  a curric:KeyLearningPoint ;
  rdfs:label """A range of familiar sound spelling correspondences can be practised in a traditional
  Peruvian Christmas carol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singular 'ser' can be used to understand information about Christmas traditions in
  Peru."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25671-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Estar' can be used to understand where things are and how people feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.326934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25671-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Porque' can be used to connect ideas between clauses in a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.326938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25671-5
  a curric:KeyLearningPoint ;
  rdfs:label """A huayno is a genre of popular music and dance from Peru. 'Niño manuelito' is a
  Christmas huayno."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25727-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-spelling correspondences [ce] and [ci] are soft sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.327404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25727-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means 'there is' or 'there are' dependent on whether it's followed by a
  singular or plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25727-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' means 'to have, having'. 'Tiene' means 'she, he, it has'; 'tienen'
  means 'they have'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25727-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you or others don't have, put 'no' before the verb to make it negative;
  this works for any verb and person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25727-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using vocabulary in context helps improve reading and speaking skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.327423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25705-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Spanish, [e] is pronounced as in ‘elefante’ and [i] as in ‘idea’."@en ;
  dcterms:modified "2026-06-07T15:30:29.327880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25705-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practising vocabulary helps reinforce learning and improves communication
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25705-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the verb 'estar' (to be, being) for location and temporary states. 'Estoy' means
  I am and 'está' means she, he is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25705-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the verb 'ser' (to be, being) for general traits. 'Soy' means I am and 'es'
  means she, he is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25705-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' and 'ser' can be combined with adjectives to describe how someone is feeling
  and how someone is in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25706-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising vocabulary reinforces learning and improves communication. There are many
  ways to practise, including games."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25706-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Ser' ('to be, being') is used for general traits; 'soy' means 'I am' and 'es' means
  'she, he, it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25706-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' ('to be, being') is used for location and temporary states; 'estoy' means 'I
  am' and 'está' - 'she, he, it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25706-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Estar' and 'ser' can be combined with adjectives to say describe how someone is
  feeling and in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25706-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs 'normalmente', 'siempre', and 'hoy' add detail when differentiating between
  your feelings today and in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25655-1
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before the noun to indicate how many. Numbers don't change spelling
  for gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25655-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding-s to nouns ending in -o or -a makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.340313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25655-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'tener' can be used with numbers and nouns to say how many I and others
  have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25655-4
  a curric:KeyLearningPoint ;
  rdfs:label """Listening and writing sound-symbol correspondences [ce] and [ci] helps to learn
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25658-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means 'there is' or 'there are' depending whether it precedes a singular or
  plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25658-2
  a curric:KeyLearningPoint ;
  rdfs:label """The question words 'cuántos' and 'cuántas' meaning how many agree with the gender
  and number of noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25658-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using cuántos/cuántas and hay to ask and answer questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.347157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound spelling correspondences [ce] and [ci] have a softer 'c' sound than [ca] [co]
  and [cu]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25636-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising nouns helps us remember the word and the gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.358216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25636-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tienes' is part of the verb 'tener' and means 'you have'."@en ;
  dcterms:modified "2026-06-07T15:30:29.358221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no questions can be made by raising the tone of your voice at the end of any
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25636-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is no equivalent of the word 'do' in Spanish intonation questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.358228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25708-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, syllables often come in consonant-vowel pairs. Each syllable in a word
  is pronounced fully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25708-2
  a curric:KeyLearningPoint ;
  rdfs:label """When describing more than one, adjectives end in -os if the noun is masculine and
  -as if it's feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25708-3
  a curric:KeyLearningPoint ;
  rdfs:label """When an adjective ends in -es, it can describe a masculine or feminine
  plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25708-4
  a curric:KeyLearningPoint ;
  rdfs:label "To mean 'we are' for location and temporary state, use 'estamos'."@en ;
  dcterms:modified "2026-06-07T15:30:29.359471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25708-5
  a curric:KeyLearningPoint ;
  rdfs:label "To mean 'we are' for general traits, use 'somos'."@en ;
  dcterms:modified "2026-06-07T15:30:29.359475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25656-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ce] can be contrasted for practice with the key
  sound [ci]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25656-2
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before nouns to indicate how many there are. Numbers do not change
  their spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25656-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns ending in -o, -a or -e makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.362733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25656-4
  a curric:KeyLearningPoint ;
  rdfs:label """'¿Tienes?' means 'Do you have?' There is no word for 'do' in intonation
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25612-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [e] and [i] can be practised with many names of
  people from Spanish-speaking countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25612-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estoy' means 'I am' and 'está' means 'she, he, it is' or 'is' when talking about
  mood and temporary states."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25612-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the person or animal being described is male adjectives end in -o and -a for
  female."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25669-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [n] and [ñ] are pronounced differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.365351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25669-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'tener' can mean 'to have, having' but also 'to be, being'."@en ;
  dcterms:modified "2026-06-07T15:30:29.365355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25663-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ga], [ge], [gi], [go], [gu] can be contrasted for
  practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives change according to the gender of the noun and follow nouns in
  description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25663-3
  a curric:KeyLearningPoint ;
  rdfs:label "'¿Cómo es?' means what is something like generally."@en ;
  dcterms:modified "2026-06-07T15:30:29.365555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25623-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [ca] [co] [cu] can be practised with a tongue
  twister."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25623-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Es’ is part of the verb ‘ser’ and means ‘it is’ or ‘is’ and is used to say what day
  of the week it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25623-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Estoy’ is part of the verb ‘estar’ and means ‘I am’ when talking about states."@en ;
  dcterms:modified "2026-06-07T15:30:29.377959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25605-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [a] sounds like the 'a' in the Spanish word 'alto',
  meaning tall."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25605-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [o] sounds like 'o' in the Spanish word 'dos',
  meaning two."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25605-3
  a curric:KeyLearningPoint ;
  rdfs:label "The word 'hola' means hello; the 'h' is not pronounced."@en ;
  dcterms:modified "2026-06-07T15:30:29.379173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25605-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'estar' means to be, being when referring to location. ‘Estoy’ means ‘I am’
  and ‘está’ means she, he, it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25608-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [a] and [u] can be practised with source words
  'alto' and 'universo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25608-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many city names in the Spanish-speaking world contain the sounds [a] and [u]."@en ;
  dcterms:modified "2026-06-07T15:30:29.380111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25608-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Estás' means you are, 'está' means he, she, it is, when talking about location."@en ;
  dcterms:modified "2026-06-07T15:30:29.380115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25608-4
  a curric:KeyLearningPoint ;
  rdfs:label "A statement becomes a yes/no question by raising tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.380119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25712-1
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article 'el' can be used to mean 'on the' with birthdays. It is not
  used for today's date."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25712-2
  a curric:KeyLearningPoint ;
  rdfs:label "To ask someone's birthday, we use the question ¿Cuándo es tu cumpleaños?"@en ;
  dcterms:modified "2026-06-07T15:30:29.383035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25712-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say when your birthday is, use ‘mi cumpleaños es el…’."@en ;
  dcterms:modified "2026-06-07T15:30:29.383039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25712-4
  a curric:KeyLearningPoint ;
  rdfs:label "We combine the numbers 1-31 and the months of the year to talk about birthdays."@en ;
  dcterms:modified "2026-06-07T15:30:29.383043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25712-5
  a curric:KeyLearningPoint ;
  rdfs:label """Practising vocabulary regularly helps reinforce learning and improves
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25621-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel sounds [a] [e] [i] [o] and [u] can be practised by listening and
  distinguishing them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25621-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'ser' means to be, being when talking about general traits and where people
  are from."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25621-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Eres' means 'you are' when talking about general traits and where you are from."@en ;
  dcterms:modified "2026-06-07T15:30:29.386790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25621-4
  a curric:KeyLearningPoint ;
  rdfs:label """Raising the pitch of your voice makes statements into intonation or yes/no
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25738-1
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'we' with -ar verbs, remove the -ar ending and add -amos."@en ;
  dcterms:modified "2026-06-07T15:30:29.393757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25738-2
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'she, he, it' with -ar verbs, remove the -ar ending and add -a."@en ;
  dcterms:modified "2026-06-07T15:30:29.393761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25738-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Todo el mundo' means everyone'. This is used with the 3rd person singular form of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25738-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can connect and extend sentences by using the words 'también' and 'pero'."@en ;
  dcterms:modified "2026-06-07T15:30:29.393771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25738-5
  a curric:KeyLearningPoint ;
  rdfs:label """Las Fallas is a very famous festival that takes place every year in March, in
  Valencia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25639-1
  a curric:KeyLearningPoint ;
  rdfs:label "[z] before [a] [o] [u] is the same sound as [c] before [e] and [i]."@en ;
  dcterms:modified "2026-06-07T15:30:29.400100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25639-2
  a curric:KeyLearningPoint ;
  rdfs:label """In English, adjectives come before the noun. In Spanish, many adjectives follow the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25639-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -o change ending to -a to describe feminine nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.400108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25639-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives ending in -e or -z don't change for noun gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.400112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [a] and [o] can be practised with the source words
  'alto' and 'dos'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25606-2
  a curric:KeyLearningPoint ;
  rdfs:label "The irregular verb 'estar' means to be, being when referring to location."@en ;
  dcterms:modified "2026-06-07T15:30:29.404803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25606-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Estoy' means 'I am' and 'está' means she, he, it is."@en ;
  dcterms:modified "2026-06-07T15:30:29.404807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25606-4
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish pronouns are often not used; the verb ending indicates the person who is
  doing the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25626-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondence [ce] is different in Spanish and English and benefits
  from frequent practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25626-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising nouns helps us remember the word and the gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.407468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25626-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conjunction is a word that is used to connect words and phrases; the Spanish
  conjunction 'y' means 'and'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25626-4
  a curric:KeyLearningPoint ;
  rdfs:label "'y' can connect two nouns in a sentence. E.g., Tengo una mochila y un bolígrafo."@en ;
  dcterms:modified "2026-06-07T15:30:29.407477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25654-1
  a curric:KeyLearningPoint ;
  rdfs:label "The irregular verb 'estar' is used for location and states."@en ;
  dcterms:modified "2026-06-07T15:30:29.408422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25654-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Estoy' means 'I am'; 'estás' means 'you are' and 'está' means 'she, he, it is' when
  talking about location and states."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25654-3
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine adjectives that end in 'o' change to an 'a' when the person or animal
  being described is female."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25654-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in –e or -z can describe a female and male person or animal; they
  do not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25637-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening and writing sound-symbol correspondences [ce] and [ci] helps to learn
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Actively trying to recall words from memory is an effective way to know words
  better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25637-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish 'yes or no' questions don't have an equivalent word for 'do' or 'does'."@en ;
  dcterms:modified "2026-06-07T15:30:29.415614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25637-4
  a curric:KeyLearningPoint ;
  rdfs:label "A statement becomes a question by raising the tone of voice at the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.415618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25633-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound-symbol correspondence [ci] sounds different in Spanish and English and
  benefits from frequent practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25633-2
  a curric:KeyLearningPoint ;
  rdfs:label "'tiene' is part of the verb 'tener' and means 'she, he, or it has'."@en ;
  dcterms:modified "2026-06-07T15:30:29.418023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25633-3
  a curric:KeyLearningPoint ;
  rdfs:label """'tiene' is useful for communicating about the belongings someone else has. For
  example, 'tiene una bicicleta'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25622-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [ca] [co] [cu] can be practised with the source
  words 'cama', 'contar', 'cultura'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25622-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Es' is part of the verb 'ser' and means 'she, he, it is' or 'is' and is used to say
  what day of the week it is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25622-3
  a curric:KeyLearningPoint ;
  rdfs:label "'¿Qué?' is the question word 'what?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.425522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25642-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [l] sounds like the 'l' in l, luz, salir."@en ;
  dcterms:modified "2026-06-07T15:30:29.426083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25642-2
  a curric:KeyLearningPoint ;
  rdfs:label "The infinitive form of a verb gives its general meaning, e.g., to listen."@en ;
  dcterms:modified "2026-06-07T15:30:29.426087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish infinitives often end in -ar, e.g., escuchar."@en ;
  dcterms:modified "2026-06-07T15:30:29.426091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25611-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [i] sounds like the ‘i’ in the Spanish word
  ‘idea’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25611-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the person or animal being described is male, adjectives end in -o."@en ;
  dcterms:modified "2026-06-07T15:30:29.427269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25611-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the person or animal being described is female, adjectives end in -a."@en ;
  dcterms:modified "2026-06-07T15:30:29.427273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25611-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Está' means 'she, he, it is' or just 'is' when talking about mood and temporary
  states."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25684-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to pronounce [b] and [v] correctly; in Spanish the sounds [b] and
  [v] sound the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25684-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singular present tense forms of regular -ar verbs have endings -o, -as, -a. -er verb
  endings are -o, -es, -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25684-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Spain, at the end of the school year, there is a celebration called 'el festival
  de fin de curso'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25684-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use singular forms of regular -ar and -er verbs to describe some activities
  at the festival."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25647-1
  a curric:KeyLearningPoint ;
  rdfs:label """The key sounds [ga] and [go] can be contrasted for listening and read aloud
  practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25647-2
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'por' is often used with verbs of movement and can be translated
  'through', 'around' or 'along'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25647-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with a verb the ending is -o, to mean 'she, he, it' the ending
  is -a."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25647-4
  a curric:KeyLearningPoint ;
  rdfs:label """The definite article 'the' in Spanish is 'el' for masculine and la for feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25647-5
  a curric:KeyLearningPoint ;
  rdfs:label """The indefinite article 'a/an' in Spanish is 'un' for masculine and 'una' for
  feminine noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25668-1
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives are a type of determiner."@en ;
  dcterms:modified "2026-06-07T15:30:29.432431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25668-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'mi' to say 'my' before a singular Spanish noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.432435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25668-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'tu' to say 'your' before a singular Spanish noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.432439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25668-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish possessives 'mi' and 'tu' do not change for the gender of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.432445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25668-5
  a curric:KeyLearningPoint ;
  rdfs:label "When 'tú' has an accent, it is a subject pronoun and goes before the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.432450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25687-1
  a curric:KeyLearningPoint ;
  rdfs:label """To pronounce words starting with [h] we ignore it and pronounce the vowel that
  follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25687-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spanish infinitives end in -ar, -er or -ir."@en ;
  dcterms:modified "2026-06-07T15:30:29.435040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing a range of infinitives develops sentence building and allows pupils to
  recognise patterns when conjugating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25687-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singular persons of regular -ar, -er and -ir verbs are used to describe what I, you
  and she, he, it is doing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25687-5
  a curric:KeyLearningPoint ;
  rdfs:label """These verbs combine with nouns, adjectives and conjunctions to make a detailed
  description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25644-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [ll] and [l] can be contrasted for read aloud
  practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25644-2
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive form of a verb gives its general meaning, e.g., 'hablar', to
  speak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish infinitive verbs translate two ways into English, e.g., 'to sing' and
  'singing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25644-4
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'I' with a verb, the -ar verb ending changes to -o, e.g., 'hablo', I
  speak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25773-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and writing known and unknown words improves pronunciation and knowledge of
  sound-spelling correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25773-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'we' with an -ar verb, remove -ar ending and add -amos. To mean 'they',
  remove -ar ending and add -an."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25773-3
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'we' with an -er verb, remove -er ending and add -emos. To mean 'they',
  remove -er ending and add -en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25773-4
  a curric:KeyLearningPoint ;
  rdfs:label """To say we 'love, hate to do' something, use the 'we' form of 'amar' and 'odiar'
  followed by the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25773-5
  a curric:KeyLearningPoint ;
  rdfs:label """In English, phrases like 'we love' and 'we hate' can be followed by the infinitive
  (to + verb) or the gerund (-ing)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25718-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 1-31 and months of the year can be combined to give dates."@en ;
  dcterms:modified "2026-06-07T15:30:29.605525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25718-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Son' means 'they are'. It is often followed by an adjective to describe people or
  things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25718-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means 'there is' or 'there are'. 'It is often used to identify or locate
  people or things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25718-4
  a curric:KeyLearningPoint ;
  rdfs:label """To describe plural nouns, add - s to adjectives ending in -a, -e and -o. For those
  ending in -l , -s, or z. add -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25718-5
  a curric:KeyLearningPoint ;
  rdfs:label """On the Day of the Dead, Mexican families make special tables called 'altares' to
  remember their loved ones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25761-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, there are strong and weak vowels. The strong vowels are [a], [e] and
  [o]. These are pronounced separately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25761-2
  a curric:KeyLearningPoint ;
  rdfs:label """The weak vowels are [i] and [u]. They merge with [a], [e] and [o] to form a single
  syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25761-3
  a curric:KeyLearningPoint ;
  rdfs:label """Los Tres Reyes Mago is a very special celebration when children write letters to the
  Three Wise Men for gifts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25761-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plural nouns means more than one person, place or thing."@en ;
  dcterms:modified "2026-06-07T15:30:29.609567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25761-5
  a curric:KeyLearningPoint ;
  rdfs:label """If a word ends in a vowel, add -s; in a consonant, add -es and in -z, remove it and
  add -ces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25643-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [ll] is pronounced is pronounced differently in
  Spanish and English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25643-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spanish infinitive verbs translate into English in two ways, e.g., ‘to sing’ and
  ‘singing’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising word recall often helps to secure word knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.613307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25751-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-spelling correspondences [n] and [ñ] are pronounced differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.614327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25751-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Hay' means there is or there are depending on whether it's followed by a singular
  or plural noun. 'Tiene' means it has."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25751-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives agree with the number and gender of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.614335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25751-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, to say there isn’t or there aren’t, use 'no' before the verb 'hay'. This
  makes it a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25751-5
  a curric:KeyLearningPoint ;
  rdfs:label """The numbers 1-31 can be used in Spanish with 'hay' or 'tiene' to say how many of
  something there are or something has."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising and revisiting vocabulary helps reinforce learning and improves
  communication skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25716-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are two verbs 'to be, being' in Spanish: 'ser' and 'estar'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25716-3
  a curric:KeyLearningPoint ;
  rdfs:label "From the verb ‘estar’, 'están' is 'they are' for location and temporary states."@en ;
  dcterms:modified "2026-06-07T15:30:29.614356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25716-4
  a curric:KeyLearningPoint ;
  rdfs:label "From the verb ‘ser’, 'son' is 'they are' for general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.614360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25716-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives agree with the gender and number of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.614367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25682-1
  a curric:KeyLearningPoint ;
  rdfs:label """Testing yourself on vocabulary helps you remember words and identify which words
  need more practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25682-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Spanish, the definite article (the word for the), changes according to gender and
  number: el, la, los and las."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25682-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opinion verbs 'amar' and 'odiar' can be used to say what you and others like or
  dislike."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25682-4
  a curric:KeyLearningPoint ;
  rdfs:label """The endings for singular persons are -o for 'I', -as for 'you' and -a for 'she, he,
  it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25682-5
  a curric:KeyLearningPoint ;
  rdfs:label """Subject pronouns (yo, tú, él and ella) are useful for comparing one person with
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25713-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel [u] is a weak vowel and it merges with [a] [e] and [o] to make a single
  syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25713-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Cuál' and 'qué' can be used to ask about today's date; 'cuándo' is used to ask
  about specific dates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25713-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Cuál' and 'cuándo' are followed by 'es'; qué is followed by a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.621267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Days of the week, months of the year and numbers 1-31 are used to understand and
  communicate dates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25618-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [e] and [i] can be practised with a range of
  adjectives like ‘feliz’ and ‘interesante’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25618-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb ‘ser’ means 'to be, being' when describing general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.633047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25618-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Soy’ means ‘I am’, ‘es’ means ‘she, he, it is’ when describing general traits."@en ;
  dcterms:modified "2026-06-07T15:30:29.633051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25685-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sounds [b] and [v] in Spanish sound the same; reading aloud helps with
  pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25685-2
  a curric:KeyLearningPoint ;
  rdfs:label """Retrieval of vocabulary consolidates learnt words. Using them regularly in different
  contexts supports this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jugar is an irregular -ar verb: 'jug-' changes to 'jueg-'; the singular forms are:
  'juego', 'juegas', 'juega'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25685-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can use 'jugar' to describe end of term activities."@en ;
  dcterms:modified "2026-06-07T15:30:29.633068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25649-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [qui] is like a hard ‘c’ followed by [i], as in the
  word ‘equipo’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s to nouns ending in -o or -a makes them plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.636100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 go before nouns to indicate how many there are; numbers don’t change
  their spelling for gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25649-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb tener can be used with numbers and nouns to say how many I and
  others have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25620-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowel sounds [a] [e] [i] [o] and [u] can be practised by reading aloud short
  rhymes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25620-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb ‘ser’ means 'to be, being' when talking about where people are from."@en ;
  dcterms:modified "2026-06-07T15:30:29.637164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25620-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Eres’ means ‘you are’ when talking about where you are from."@en ;
  dcterms:modified "2026-06-07T15:30:29.637168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25778-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reciting tongue twisters is a good way of practising sound-spelling correspondences
  and pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25778-2
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting vocabulary helps develop confidence and communication."@en ;
  dcterms:modified "2026-06-07T15:30:29.638781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25778-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many adjectives follow the noun; they agree in gender and number wih the noun
  they're describing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25778-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Querer' means 'to want, wanting'. For 'I want', use 'quiero'; 'you want' -
  'quieres'; 'she, he, it wants' - 'quiere'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25778-5
  a curric:KeyLearningPoint ;
  rdfs:label """To say someone wants to do something, use the correct form of 'querer' plus the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638794Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-25667
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe what belongs to me and you using the possessive adjectives 'mi' and
  'tu'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063388Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25688
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compose and rehearse a voice message to improve fluency and deliver it with
  confidence and clarity."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063479Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25625
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use 'tengo' and 'un' and 'una' with nouns to say what belongings I have."@en ;
  dcterms:modified "2026-06-07T15:30:41.063666Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25748
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand classroom instructions."@en ;
  dcterms:modified "2026-06-07T15:30:41.063985Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25760
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions and give statements about a birthday party using the
  singular forms of hacer."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063993Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25704
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say how I and others are today and usually using 'estar' and 'ser'."@en ;
  dcterms:modified "2026-06-07T15:30:41.064175Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25650
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use numbers 1-12 with nouns and ‘tener’ to ask and answer about how many
  things I and others have."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064697Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25769
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand information about Inti Raymi."@en ;
  dcterms:modified "2026-06-07T15:30:41.064927Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25714
  a curric:PupilLessonOutcome ;
  rdfs:label "I can talk about dates for special events and festivals."@en ;
  dcterms:modified "2026-06-07T15:30:41.065050Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25746
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what I and others do in the summer."@en ;
  dcterms:modified "2026-06-07T15:30:41.065130Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25624
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'ser' and 'estar' to understand information about Christmas traditions in
  Spain."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065308Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25646
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use definite articles and a range of verbs in the 1st person singular to
  understand spoken and written language about outdoor activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065316Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25725
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions about what I and others have using 'tengo' and
  'tienes'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065324Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25666
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions about how someone is and what someone is like using
  'estar' and 'ser'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065691Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25661
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use reference resources to understand symbols for nouns and develop my
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065747Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25740
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what she, he, it does and what we do in the languages classroom."@en ;
  dcterms:modified "2026-06-07T15:30:41.065775Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25755
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the verbs ‘ir’ and ‘estar’ followed by the correct preposition to describe
  a trip to Barcelona."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066115Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25779
  a curric:PupilLessonOutcome ;
  rdfs:label "I can read, understand and adapt a Spanish poem."@en ;
  dcterms:modified "2026-06-07T15:30:41.066225Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25635
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use ‘tengo’ and ‘tiene’ with nouns to speak and write about belongings I and
  my friends have. I can distinguish between [ci] and [ca], [co], and [cu] sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066451Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25753
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use compass points and the verb 'ir' to say where I and others go."@en ;
  dcterms:modified "2026-06-07T15:30:41.066612Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25715
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe people using 'son' and 'estan'."@en ;
  dcterms:modified "2026-06-07T15:30:41.066621Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25745
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use -ar verbs to say what she, he and they are doing and describe a dream."@en ;
  dcterms:modified "2026-06-07T15:30:41.066625Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25653
  a curric:PupilLessonOutcome ;
  rdfs:label "I can recognise and understand instructions in the classroom."@en ;
  dcterms:modified "2026-06-07T15:30:41.066937Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25680
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what I and others do using singular persons of the verb 'hacer'."@en ;
  dcterms:modified "2026-06-07T15:30:41.067242Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25674
  a curric:PupilLessonOutcome ;
