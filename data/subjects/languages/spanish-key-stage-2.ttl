# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-possessive-adjectives-need-change-depending
  a curric:Misconception ;
  curric:statement "Possessive adjectives need to change depending on the gender of the noun."@en ;
  curric:correction """Possessive adjectives do not change to match the gender of the noun. 'Mi and
  'tu' are 'my' and 'your' for all singular nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084276Z"^^xsd:dateTime .

oakcurric:misconception-speaking-doesnt-require-rehearsal-practice
  a curric:Misconception ;
  curric:statement "Speaking doesn't require rehearsal or practice."@en ;
  curric:correction """To develop fluency, it is important to rehearse speaking and practise reading
  aloud. This helps you improve pronunciation, speed and intonation so you convey a clear
  message with confidence and without too many hesitations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084414Z"^^xsd:dateTime .

oakcurric:misconception-grammatical-gender-same-biological-gender
  a curric:Misconception ;
  curric:statement """Grammatical gender is the same as biological gender. If a word is feminine we
  think of it as a girl if it is masculine we think of it as a boy."""@en ;
  curric:correction """Grammatical gender is not the same as biological gender. Spelling clues help
  to identify Spanish grammatical gender: nouns ending in -o are usually masculine, nouns
  ending in -a are usually feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084676Z"^^xsd:dateTime .

oakcurric:misconception-using-verbs-spanish-need-use
  a curric:Misconception ;
  curric:statement """When using verbs in Spanish, we need to use pronouns, as we do in English to
  describe who is doing the action."""@en ;
  curric:correction """In Spanish, we don't usually need to use the pronoun as the verb ending tells
  us who is doing the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085030Z"^^xsd:dateTime .

oakcurric:misconception-th-verb-hacer-means-make
  a curric:Misconception ;
  curric:statement "Th verb 'hacer' only means 'to do' and 'to make'."@en ;
  curric:correction """The verb 'hacer' can be translated as 'to do' and 'to make' but it can also
  be translated as 'to go' when used with some sports such as 'natación' and 'ciclismo',
  e.g. 'hago natación' - 'I go swimming'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085041Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-english
  a curric:Misconception ;
  curric:statement "There is one verb for 'to be, being' as there is in English."@en ;
  curric:correction """In Spanish, there are two verbs for 'to be, being': 'estar' is used for
  location and temporary states and 'ser' is used for general traits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085440Z"^^xsd:dateTime .

oakcurric:misconception-sounds-qui-ci-pronounced-same
  a curric:Misconception ;
  curric:statement "The sounds [qui] and [ci] are pronounced the same in English and Spanish."@en ;
  curric:correction """The sound [qui] is pronounced like a hard 'c' followed by [i] or like the
  word 'key' in English. The sound [ci] is pronounced like 'thi' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086210Z"^^xsd:dateTime .

oakcurric:misconception-need-use-plural-form-todo
  a curric:Misconception ;
  curric:statement "You need to use the plural form of 'todo' or 'mucho' with 'gente'."@en ;
  curric:correction """'Gente' is a singular noun, so you use the 3rd person singular form of 'todo'
  and 'mucho' with 'gente'. Remember, these words also agree with the gender of the noun:
  'toda', 'mucha'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086508Z"^^xsd:dateTime .

oakcurric:misconception-el-used-dates
  a curric:Misconception ;
  curric:statement "'El' is used for all dates."@en ;
  curric:correction """'El' is used to mean 'on the' for specific dates. It is not used for today's
  date."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086701Z"^^xsd:dateTime .

oakcurric:misconception-sound-spelling-correspondences-r-rr
  a curric:Misconception ;
  curric:statement """The sound-spelling correspondences [r] and [rr] look similar so are pronounced
  the same way."""@en ;
  curric:correction """[r] and [rr] are pronounced differently. The [r] is a soft sound like a quick
  tap of your tongue and the [rr] is a rolling sound - your tongue vibrates or rolls, like
  when you make the sound of a telephone ring - brrrrring, brrrrring!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.086823Z"^^xsd:dateTime .

oakcurric:misconception-estoy-es-used-general-traits
  a curric:Misconception ;
  curric:statement """Both 'estoy' and 'es' can be used for general traits and feelings as it would
  be in English."""@en ;
  curric:correction "'Estoy' is used for feelings and 'es' for general traits."@en ;
  dcterms:modified "2026-06-07T15:30:15.087153Z"^^xsd:dateTime .

oakcurric:misconception-one-word-spanish-like-english
  a curric:Misconception ;
  curric:statement "There is one word for 'the' in Spanish, like in English."@en ;
  curric:correction """In Spanish, the definite article must match the gender of the noun. 'El' is
  the word for 'the' for masculine nouns (e.g., 'el uniforme') and 'la' is the word for
  'the' for feminine nouns (e.g., 'la tarta')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087164Z"^^xsd:dateTime .

oakcurric:misconception-one-word-masculine-feminine-nouns
  a curric:Misconception ;
  curric:statement "There is one word for 'some' for both masculine and feminine nouns."@en ;
  curric:correction """In Spanish, there are two words for some. For masculine plural nouns, use
  'unos'. For feminine plural nouns, use 'unas'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087178Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-spanish-english
  a curric:Misconception ;
  curric:statement "There is one way to say 'you are' in Spanish, as in English."@en ;
  curric:correction """There are two ways to say 'you are' in Spanish. 'Eres' is part of the verb
  'ser' and used for general traits. 'Estás' is part of the verb 'estar' and used for
  location and temporary states."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087663Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-come-noun-spanish-english
  a curric:Misconception ;
  curric:statement """Adjectives come before the noun in Spanish as they do in English. They do not
  need to change."""@en ;
  curric:correction """In Spanish, adjectives generally come after the noun. They agree with the
  number and gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087741Z"^^xsd:dateTime .

oakcurric:misconception-need-use-pronouns-talking
  a curric:Misconception ;
  curric:statement "We need to use pronouns when talking about she, he, it or we."@en ;
  curric:correction """We usually don't need pronouns because the verb ending indicates whether it
  is 'she, he, it' or 'we' doing the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087760Z"^^xsd:dateTime .

oakcurric:misconception-estar-followed-en
  a curric:Misconception ;
  curric:statement "'Estar' can be followed by 'en' or 'a'."@en ;
  curric:correction """The preposition 'en' is generally used with 'estar' and can mean 'in', 'on'
  or 'at'. The preposition 'a' is generally used with the verb 'ir'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087992Z"^^xsd:dateTime .

oakcurric:misconception-reference-resources-like-dictionaries-provide
  a curric:Misconception ;
  curric:statement """Reference resources, like dictionaries, only provide the definition of
  a word."""@en ;
  curric:correction """Reference resources, like dictionaries, also indicate word class and
  gender."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088292Z"^^xsd:dateTime .

oakcurric:misconception-cognates-exactly-same-languages
  a curric:Misconception ;
  curric:statement "Cognates are always exactly the same in both languages."@en ;
  curric:correction """Cognates might be written and/or pronounced differently. It is usually easier
  to recognise a cognate in the written form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088648Z"^^xsd:dateTime .

oakcurric:misconception-preposition-stays-same-regardless-noun
  a curric:Misconception ;
  curric:statement "The preposition 'a' stays the same regardless of the noun it precedes."@en ;
  curric:correction """In English the preposition 'to' stays the same. In Spanish, the word 'a'
  changes to 'al' before masculine nouns and to 'a la' before feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088961Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-spanish
  a curric:Misconception ;
  curric:statement "There is only one way to say 'they are' in Spanish."@en ;
  curric:correction """There are two verbs meaning to be, being. To say 'they are' for location and
  temporary state, we use 'estan' from the verb 'estar'. To say 'we are' for general traits,
  we use 'son' from the verb 'ser'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088973Z"^^xsd:dateTime .

oakcurric:misconception-syllables-words-written-accents-stressed
  a curric:Misconception ;
  curric:statement "Only syllables in words with written accents should be stressed."@en ;
  curric:correction """Any vowel with a written accent is stressed. For words ending in vowels, -n
  and -s, the penultimate syllable is stressed. For all other words, the final syllable is
  stressed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088978Z"^^xsd:dateTime .

oakcurric:misconception-vowels-sound-same-spanish-english
  a curric:Misconception ;
  curric:statement "Vowels sound the same in Spanish and English."@en ;
  curric:correction """Although the letters look the same, the vowel sounds are different in Spanish
  and English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089446Z"^^xsd:dateTime .

oakcurric:misconception-first-person-singular-form-hacer
  a curric:Misconception ;
  curric:statement "The first person singular form of 'hacer' is 'haco'."@en ;
  curric:correction """The first person singular form of 'hacer' is irregular. To mean 'I' with the
  verb 'hacer', use 'hago'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089845Z"^^xsd:dateTime .

oakcurric:misconception-word-list-dictionary-gives-word
  a curric:Misconception ;
  curric:statement "A word list or dictionary gives you just the word and the definition."@en ;
  curric:correction """Word lists and dictionaries use symbols to give information on the type of
  word and the noun gender."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090025Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjectives-my-mi-your
  a curric:Misconception ;
  curric:statement """The possessive adjectives 'my' - mi - and 'your' - tu - stay the same for both
  singular and plural nouns as they do in English."""@en ;
  curric:correction """In Spanish, the possessive adjectives change for singular and plural nouns;
  'mi' becomes 'mis' and 'tu' becomes 'tus' before plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090360Z"^^xsd:dateTime .

oakcurric:misconception-words-mucho-todo-stay-same
  a curric:Misconception ;
  curric:statement """The words 'mucho' and 'todo' stay the same when used with nouns as they do in
  English."""@en ;
  curric:correction """The words 'mucho' and 'todo' change when used before nouns to agree with the
  number and gender of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090375Z"^^xsd:dateTime .

oakcurric:misconception-use-estar-talk-location
  a curric:Misconception ;
  curric:statement "I can only use 'estar' to talk about location."@en ;
  curric:correction """The verb 'estar' can be used to talk about location as well as temporary
  states or moods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090490Z"^^xsd:dateTime .

oakcurric:misconception-spanish-doesnt-use-definite-article
  a curric:Misconception ;
  curric:statement """Spanish doesn't use the definite article 'the' when describing facial
  features."""@en ;
  curric:correction """In Spanish, the definite article 'the' is needed when describing facial
  features, e.g. 'tiene los ojos azules y la nariz pequeña'. In English, with plural
  features the article is omitted, e.g. 'she has blue eyes', or replaced by a/an; 'a small
  nose'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090606Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-spanish-appear-noun-english
  a curric:Misconception ;
  curric:statement "Adjectives in Spanish appear before the noun as they do in English."@en ;
  curric:correction """In Spanish, many adjectives appear after the noun and agree with the number
  and gender of the noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090619Z"^^xsd:dateTime .

oakcurric:misconception-word-people-spanish-la-gente
  a curric:Misconception ;
  curric:statement """The word for 'people' in Spanish - 'la gente' - uses the 3rd person plural
  form of the verb - 'they' - like in English."""@en ;
  curric:correction """'La gente' is a singular noun and therefore uses the 3rd person singular form
  of the verb - 'she, he, it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090780Z"^^xsd:dateTime .

oakcurric:misconception-vowels-same-sounds-spanish-english
  a curric:Misconception ;
  curric:statement "Vowels have the same sounds in Spanish and English."@en ;
  curric:correction """Vowels are pronounced differently in Spanish. In Spanish, vowels only have
  one sound and are pronounced in the same way no matter where they appear in a word."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091160Z"^^xsd:dateTime .

oakcurric:misconception-l-ll-sounds-pronounced-same
  a curric:Misconception ;
  curric:statement "The [l] and [ll] sounds are pronounced the same in Spanish."@en ;
  curric:correction """The [l] and [ll] sounds are pronounced differently in Spanish; the [ll] sound
  is pronounced as in 'amarillo' and 'llamar'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091166Z"^^xsd:dateTime .

oakcurric:misconception-sounds-r-rr-pronounced-same
  a curric:Misconception ;
  curric:statement "The sounds [r] and [rr] are pronounced the same."@en ;
  curric:correction """The single [r] sound is pronounced as in the words 'pero', 'abrir',
  'Francia'. The double [rr] sound is pronounced as in the words 'perro', 'correr',
  'correo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091409Z"^^xsd:dateTime .

oakcurric:misconception-definite-indefinite-articles-dont-change
  a curric:Misconception ;
  curric:statement """The definite and indefinite articles don't change. Thet stay the same like
  'the', 'a' or 'an' for whatever noun they precede, like they do in English."""@en ;
  curric:correction """In Spanish, nouns have gender. Definite and indefinite articles change
  according to the gender: 'el' and 'un' for masculine nouns; 'la' and 'una' for feminine
  nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091731Z"^^xsd:dateTime .

oakcurric:misconception-use-article-features-english-e
  a curric:Misconception ;
  curric:statement """You use the article [a] or [an] with features as you do in English, e.g. a
  small nose."""@en ;
  curric:correction """In Spanish, we always use the definite article ‘the’ when describing
  someone's physical features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091737Z"^^xsd:dateTime .

oakcurric:misconception-like-english-pronouns-needed-verbs
  a curric:Misconception ;
  curric:statement """Like in English, pronouns are needed with verbs to know who the verb refers
  to."""@en ;
  curric:correction """Pronouns are not often necessary in Spanish. Verb endings change to indicate
  the person who the verb refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092036Z"^^xsd:dateTime .

oakcurric:misconception-because-muchos-muchas-plural-dont
  a curric:Misconception ;
  curric:statement """Because 'muchos' and 'muchas' are plural, you don't need to pluralise the noun
  that follows them."""@en ;
  curric:correction """The agreement of 'muchos' and 'muchas' must be in both gender and number so
  the nouns must be pluralised too, e.g. 'muchas playas', 'muchos pueblos'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092388Z"^^xsd:dateTime .

oakcurric:misconception-word-doesnt-written-accent-doesnt
  a curric:Misconception ;
  curric:statement """If a word doesn't have a written accent, it doesn't matter where you put the
  stress."""@en ;
  curric:correction """When there is no written accent, you need to stress the penultimate syllable
  for any word ending in a vowel, [n] or [s]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092986Z"^^xsd:dateTime .

oakcurric:misconception-pronouns-need-used-indicate-person
  a curric:Misconception ;
  curric:statement "Pronouns need to be used to indicate the person doing the action."@en ;
  curric:correction """Pronouns are often unnecessary in Spanish as verb endings indicate the person
  doing the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093008Z"^^xsd:dateTime .

oakcurric:misconception-one-say-spanish-english
  a curric:Misconception ;
  curric:statement "There is only one to say 'we are' in Spanish as in English."@en ;
  curric:correction """There are two verbs meaning 'to be, being' in Spanish. To say 'we are' for
  location and temporary state, we use estamos from the verb estar and to say 'we are' for
  general traits, we use somos from the verb ser."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093179Z"^^xsd:dateTime .

oakcurric:misconception-need-use-word-meaning-querer
  a curric:Misconception ;
  curric:statement """You need to use the word 'a' meaning 'to' after querer to mean that someone
  wants to do something, as we do in English."""@en ;
  curric:correction """To say someone wants to do something, you use querer followed immediately by
  the infinitive. The preposition 'a' is not needed before the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093220Z"^^xsd:dateTime .

oakcurric:misconception-spanish-sound-symbol-correspondences-pronounced
  a curric:Misconception ;
  curric:statement """All Spanish sound-symbol correspondences are pronounced the same everywhere
  Spanish is spoken."""@en ;
  curric:correction """[z] and [c] are pronounced differently in different Spanish-speaking
  countries. In Latin America and the Canary islands, [z] sounds the same as [s]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093618Z"^^xsd:dateTime .

oakcurric:misconception-one-word-spanish-english
  a curric:Misconception ;
  curric:statement "There is one word for 'the' in Spanish as in English."@en ;
  curric:correction """'El' is the word for 'the' for masculine nouns; 'la' is the word for 'the'
  for feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097077Z"^^xsd:dateTime .

oakcurric:misconception-verbs-ver-visitar-used-same
  a curric:Misconception ;
  curric:statement """The verbs 'ver' and 'visitar' are used in the same way regardless of who or
  what you are visiting."""@en ;
  curric:correction """When seeing or visiting a person or a pet, you need to add in the preposition
  'a' after the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099159Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-many-spanish
  a curric:Misconception ;
  curric:statement "There is only one way to say 'how many' in Spanish: 'cuánto'."@en ;
  curric:correction """In Spanish, the question word 'cuánto' agrees with the gender and number of
  the noun it refers to. There are four forms: cuánto (m), cuánta (f), cuántos (mpl) and
  cuántas (fpl),"""@en ;
  dcterms:modified "2026-06-07T15:30:15.099252Z"^^xsd:dateTime .

oakcurric:misconception-verb-endings-stay-same-er
  a curric:Misconception ;
  curric:statement "The verb endings stay the same for I, you and she, he, it with -er verbs."@en ;
  curric:correction "The verb endings change for I, you and she, he, it with -er verbs."@en ;
  dcterms:modified "2026-06-07T15:30:15.099715Z"^^xsd:dateTime .

oakcurric:misconception-preposition-stays-same-regardless-gender
  a curric:Misconception ;
  curric:statement """The preposition 'a' stays the same regardless of the gender of the noun it
  precedes."""@en ;
  curric:correction """In English, the preposition 'to' before 'the' does not change. In Spanish,
  'a' + 'el' contracts to 'al' before masculine nouns (e.g., 'al parque' - 'to the park'),
  but stays as 'a la' before feminine nouns (e.g., 'a la playa' - 'to the beach')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099748Z"^^xsd:dateTime .

oakcurric:misconception-swap-words-around-make-questions
  a curric:Misconception ;
  curric:statement "You have to swap words around to make yes/no questions in Spanish."@en ;
  curric:correction """'You are' does not swap around to 'Are you ...?' in Spanish because 'you are'
  is one word, 'estás'. Spanish yes/no questions can be made simply by raising the tone of
  voice at the end of any statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103384Z"^^xsd:dateTime .

oakcurric:misconception-spanish-verbs-need-pronouns-like
  a curric:Misconception ;
  curric:statement """Spanish verbs always need pronouns, like in English, to convey the person
  doing the action."""@en ;
  curric:correction """Spanish verbs don't always need pronouns. The verb endings indicates the
  person doing the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103675Z"^^xsd:dateTime .

oakcurric:misconception-vowels-pronounced-separately
  a curric:Misconception ;
  curric:statement "All vowels are pronounced separately."@en ;
  curric:correction """[a], [e], [o] are strong vowels and are pronounced separately whilst [i] and
  [u] are weak vowels and merge with [a], [e] and [o] to make a single syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103814Z"^^xsd:dateTime .

oakcurric:misconception-spanish-words-detr-s-behind
  a curric:Misconception ;
  curric:statement """In Spanish, the words 'detrás' (behind) and 'debajo' (under) are used in the
  same way as in English, followed directly by an article and noun."""@en ;
  curric:correction """In Spanish, 'detrás' (behind) and 'debajo' (under) are folowed by 'de' in
  Spanish and then the article and the noun; used like this, they are known as prepositional
  phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104287Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-ending-e-z-change
  a curric:Misconception ;
  curric:statement """Adjectives ending in -e and -z change to -a when the person or animal
  described is female."""@en ;
  curric:correction """When an adjective ends in –e or -z , it can describe a female and male person
  or animal. It does not change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104522Z"^^xsd:dateTime .

oakcurric:misconception-hay-changes-followed-plural-english
  a curric:Misconception ;
  curric:statement """'Hay' changes when followed by a plural, as 'there is' does in English,
  changing to 'there are'."""@en ;
  curric:correction """'Hay' means 'there is' and 'there are'. The word stays the same but the
  meaning changes when followed by a plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104574Z"^^xsd:dateTime .

oakcurric:misconception-adverbs-normalmente-siempre-follow-english
  a curric:Misconception ;
  curric:statement """The adverbs 'normalmente' and 'siempre' always follow the English order when
  in a sentence."""@en ;
  curric:correction "In Spanish, adverbs tend to go at the start or end of the sentence."@en ;
  dcterms:modified "2026-06-07T15:30:15.105114Z"^^xsd:dateTime .

oakcurric:misconception-jugar-hacer-interchangeable-english-play
  a curric:Misconception ;
  curric:statement """'Jugar' and 'hacer' are interchangeable as they often are in English - 'I play
  football', 'I do football'."""@en ;
  curric:correction """In Spanish, you can't use 'hacer' for all activities you do in your free
  time. If it is a ball sport or a game, use 'jugar'. If it is an activity, non-ball sport,
  task or something that you're making, use 'hacer'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105447Z"^^xsd:dateTime .

oakcurric:misconception-questions-english-spanish-written-same
  a curric:Misconception ;
  curric:statement "Questions in English and Spanish are written in the same way."@en ;
  curric:correction """Questions in Spanish need an upside-down (inverted) question mark at the
  begininng and a regular question mark at the end. This is because the verb and person do
  not swap in Spanish questions, as they do in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106115Z"^^xsd:dateTime .

oakcurric:misconception-talking-like-hate-change-ending
  a curric:Misconception ;
  curric:statement """When talking about what we like and hate, we change the ending of ‘amar’ or
  ‘odiar’ to say who loves or hates and add the gerund (-ing) of the verb that follows, as
  in English."""@en ;
  curric:correction """We change the ending of ‘amar’ or ‘odiar’ to say who loves or hates, but the
  verb that follows is in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107900Z"^^xsd:dateTime .

oakcurric:misconception-endings-er-verbs-change-same
  a curric:Misconception ;
  curric:statement """The endings for -er verbs change in the same way that they do for -ar
  verbs."""@en ;
  curric:correction """Whilst the 'I' form changes to -o for both -ar and -er verbs, for 'she, he,
  it' the endings are different - it is -a for -ar verbs and -e for -er verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108443Z"^^xsd:dateTime .

oakcurric:misconception-months-year-capitalised-spanish-english
  a curric:Misconception ;
  curric:statement "Months of the year are capitalised in Spanish as they are in English."@en ;
  curric:correction """Months of the year are not capitalised in Spanish, unless they start a
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108656Z"^^xsd:dateTime .

oakcurric:misconception-translated-en-spanish
  a curric:Misconception ;
  curric:statement "'In' is always translated as 'en' in Spanish."@en ;
  curric:correction """When 'in' is followed by the time of day, it translates as 'por' in
  Spanish."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109408Z"^^xsd:dateTime .

oakcurric:misconception-like-english-spanish-uses-two
  a curric:Misconception ;
  curric:statement """Like English, Spanish uses two different words to make verbs negative — just
  as English uses 'do not/don't' and 'does not/doesn't.'"""@en ;
  curric:correction """In Spanish, simply use 'no' before the verb for all subjects (I, you, he,
  she, etc.) to make a negative, e.g. 'no hago' - I don't do, 'no hace' - she, he, it
  doesn't do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110695Z"^^xsd:dateTime .

oakcurric:misconception-tiene-hay-interchangeable
  a curric:Misconception ;
  curric:statement "'Tiene' and 'hay' are interchangeable."@en ;
  curric:correction """Both 'hay' and 'tiene' can be used to describe details. However, sentences
  with 'hay' usually start with or contain 'en'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110775Z"^^xsd:dateTime .

oakcurric:misconception-vowels-accents-dont-make-difference
  a curric:Misconception ;
  curric:statement "Vowels with accents don't make any difference in how we pronounce words."@en ;
  curric:correction """In Spanish, we stress any vowel that has a written accent. These show us the
  syllable in a word that is pronounced with greater emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111644Z"^^xsd:dateTime .

oakcurric:misconception-translate-weather-phrases-word-word
  a curric:Misconception ;
  curric:statement """We can translate weather phrases word for word from English and use the verb
  'es'."""@en ;
  curric:correction """When talking about the weather, we use 'hace' to mean 'it is'. We can’t
  translate weather phrases word for word from English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111686Z"^^xsd:dateTime .

oakcurric:misconception-verb-tener-one-meaning
  a curric:Misconception ;
  curric:statement "The verb 'tener' has one meaning, 'to have, having'."@en ;
  curric:correction """The verb 'tener' means 'to have, having' and with certain nouns, it also
  means 'to be, being'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111691Z"^^xsd:dateTime .

oakcurric:misconception-christmas-traditions-celebrations-same-peru
  a curric:Misconception ;
  curric:statement """Christmas traditions and celebrations are the same in Peru, Spain and Great
  Britain."""@en ;
  curric:correction """Each country has its own traditions and celebrations. Although there are
  similarities, each country has celebrations and traditions unique to its history and
  culture."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111729Z"^^xsd:dateTime .

oakcurric:misconception-make-verb-negative-spanish-add
  a curric:Misconception ;
  curric:statement """To make a verb negative in Spanish, you have to add an additional verb, like
  'do not' or 'does not', like in English."""@en ;
  curric:correction """In Spanish, no extra verb is necessary. You just add 'no' before the verb.
  This works for any verb and person."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111850Z"^^xsd:dateTime .

oakcurric:misconception-e-pronounced-same-spanish-english
  a curric:Misconception ;
  curric:statement "[e] and [i] are pronounced the same in Spanish and English."@en ;
  curric:correction "[e] is pronounced as in elefante and [i] is pronounced as in idea."@en ;
  dcterms:modified "2026-06-07T15:30:15.111972Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-spanish
  a curric:Misconception ;
  curric:statement "There is only one verb for 'to be, being' in Spanish."@en ;
  curric:correction """There are two verbs for to be in Spanish: 'estar' for location and temporary
  states and 'ser' for general traits."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115428Z"^^xsd:dateTime .

oakcurric:misconception-numbers-change-their-spelling-depending
  a curric:Misconception ;
  curric:statement "Numbers change their spelling depending on gender of the noun."@en ;
  curric:correction "Numbers do not change their spelling for gender."@en ;
  dcterms:modified "2026-06-07T15:30:15.116367Z"^^xsd:dateTime .

oakcurric:misconception-one-way-ask-many-like
  a curric:Misconception ;
  curric:statement "There is one way to ask 'how many' like in English."@en ;
  curric:correction "In Spanish, the words for 'how many' agree with the gender of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:15.118488Z"^^xsd:dateTime .

oakcurric:misconception-include-word-spanish-intonation-questions
  a curric:Misconception ;
  curric:statement "You have to include the word for 'do' in Spanish intonation questions."@en ;
  curric:correction """Spanish intonation (yes/no questions) can be made simply by raising the tone
  of voice at the end of any statement. There is no equivalent of the word 'do' in Spanish
  intonation questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123358Z"^^xsd:dateTime .

oakcurric:misconception-translating-spanish-need-translate-single
  a curric:Misconception ;
  curric:statement """When translating 'do you have' into Spanish, we need to translate every single
  word, including 'do'."""@en ;
  curric:correction "'Do you have?' translate as '¿tienes?' and we do not translate 'do'."@en ;
  dcterms:modified "2026-06-07T15:30:15.124507Z"^^xsd:dateTime .

oakcurric:misconception-english-spelling-spanish-adjectives-remains
  a curric:Misconception ;
  curric:statement """As in English, the spelling of Spanish adjectives remains the same regardless
  of the noun they are describing."""@en ;
  curric:correction """The spelling of Spanish adjectives changes from -o to -a when desciring a
  person or animal that is female."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124928Z"^^xsd:dateTime .

oakcurric:misconception-n-make-same-sound
  a curric:Misconception ;
  curric:statement "[n] and [ñ] make the same sound."@en ;
  curric:correction """The sounds [n] and [ñ] are pronounced differently. [ñ] is pronounced as in
  'español'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125353Z"^^xsd:dateTime .

oakcurric:misconception-sound-spelling-correspondences-ga-ge
  a curric:Misconception ;
  curric:statement """The sound-spelling correspondences [ga], [ge], [gi], [go], [gu] sound the same
  in English and Spanish."""@en ;
  curric:correction """The sound-spelling correspondences [ga], [go], [gu] are hard sounds and are
  similar in English. [Ge] and [gi] have a soft [g] sound and sound very different in
  Spanish and English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125409Z"^^xsd:dateTime .

oakcurric:misconception-es-estoy-part-same-verb
  a curric:Misconception ;
  curric:statement "‘Es’ and ‘estoy’ are part of the same verb."@en ;
  curric:correction """‘Es’ is from the verb ‘ser’, ‘estoy’ is from the verb ‘estar’. In this lesson
  we bring together ser and estar so that pupils can contrast ‘es’ plus days of the week and
  ‘estoy’ to express their state or mood on that day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131641Z"^^xsd:dateTime .

oakcurric:misconception-letter-h-hola-pronounced-english
  a curric:Misconception ;
  curric:statement "The letter 'h' in hola is pronounced as it would be in English."@en ;
  curric:correction "In Spanish, the letter 'h' is not pronounced in the word 'hola'."@en ;
  dcterms:modified "2026-06-07T15:30:15.132083Z"^^xsd:dateTime .

oakcurric:misconception-need-swap-word-order-verb
  a curric:Misconception ;
  curric:statement """You need to swap word order (the verb and the pronoun) when asking questions
  in Spanish, like in English."""@en ;
  curric:correction """There is no change to word order when we turn a statement into a question.
  Instead, you raise your voice at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132432Z"^^xsd:dateTime .

oakcurric:misconception-say-date-use-definite-article
  a curric:Misconception ;
  curric:statement """To say what the date is, you always use the definite article 'the' as in
  English."""@en ;
  curric:correction """In Spanish, the definite article is used with specific dates, like birthdays.
  Unlike in English, 'the' is not used for today's date."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133603Z"^^xsd:dateTime .

oakcurric:misconception-eres-eres-de-mean-same
  a curric:Misconception ;
  curric:statement "'Eres' and 'eres de' mean the same thing."@en ;
  curric:correction """'Eres' means 'you are' and it is usually followed by a name or an adjective.
  'Eres de' means 'you are from' and it is followed by a country."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134777Z"^^xsd:dateTime .

oakcurric:misconception-say-ar-verbs-add-amos
  a curric:Misconception ;
  curric:statement "To say 'we' with -ar verbs, we add -amos to the infinitive."@en ;
  curric:correction """To say 'we' with -ar verbs, we first remove the -ar ending and then add
  -amos."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138140Z"^^xsd:dateTime .

oakcurric:misconception-spanish-adjectives-come-noun-like
  a curric:Misconception ;
  curric:statement "In Spanish, adjectives come before the noun just like in English."@en ;
  curric:correction """In English, adjectives come before the noun. In Spanish, many adjectives
  follow the noun. Practice in first identifying the object and then what it is like helps
  to embed the Spanish noun-adjective pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140266Z"^^xsd:dateTime .

oakcurric:misconception-english-spanish-sound-spelling-links
  a curric:Misconception ;
  curric:statement "English and Spanish sound-spelling links are the same."@en ;
  curric:correction """Sound-symbol correspondence [ce] is different in Spanish and English and
  reading aloud Spanish words with [ce] leads to more secure knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142883Z"^^xsd:dateTime .

oakcurric:misconception-est-s-means
  a curric:Misconception ;
  curric:statement "Estás means she, he, it is."@en ;
  curric:correction "Estás means you are. Está means she, he, it is."@en ;
  dcterms:modified "2026-06-07T15:30:15.143230Z"^^xsd:dateTime .

oakcurric:misconception-spanish-questions-include-spanish-word
  a curric:Misconception ;
  curric:statement """Spanish 'yes and 'no' questions have to include the Spanish word for 'do' or
  'does'."""@en ;
  curric:correction """There is no equivalent of the word 'do' in Spanish intonation questions.
  Moving between Spanish and English is an effective way to embed this knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147134Z"^^xsd:dateTime .

oakcurric:misconception-spanish-days-week-start-capital
  a curric:Misconception ;
  curric:statement "Spanish days of the week start with a capital letter as in English."@en ;
  curric:correction "Spanish does not capitalise the days of the week."@en ;
  dcterms:modified "2026-06-07T15:30:15.150387Z"^^xsd:dateTime .

oakcurric:misconception-spanish-infinitives-like-english-two
  a curric:Misconception ;
  curric:statement """Spanish infinitives, like English, have two words: 'to + verb' like the
  infinitive 'to eat'."""@en ;
  curric:correction """In English, infinites are often written as 'to + verb' whereas in Spanish
  infinitives often end in -ar."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150553Z"^^xsd:dateTime .

oakcurric:misconception-sounds-b-v-pronounced-differently
  a curric:Misconception ;
  curric:statement "The sounds [b] and [v] are pronounced differently, as in English."@en ;
  curric:correction "The sounds [b] and [v] are pronounced the same in Spanish."@en ;
  dcterms:modified "2026-06-07T15:30:15.150973Z"^^xsd:dateTime .

oakcurric:misconception-tu-t-mean-same-thing
  a curric:Misconception ;
  curric:statement "'Tu' and 'tú' mean the same thing."@en ;
  curric:correction """'Tu' is a possessive adjective used to say 'your' in Spanish. 'Tú' is a
  subject pronoun meaning 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152471Z"^^xsd:dateTime .

oakcurric:misconception-sounds-spelling-correspondence-h-pronounced
  a curric:Misconception ;
  curric:statement "The sounds spelling correspondence [h] is pronounced as it is in English."@en ;
  curric:correction """In Spanish, to pronounce words starting with [h], we ignore it and pronounce
  the vowel that follows."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153507Z"^^xsd:dateTime .

oakcurric:misconception-l-ll-same-sound-other
  a curric:Misconception ;
  curric:statement "[l] and [ll] have the same sound as each other."@en ;
  curric:correction """[l] and [ll] sound different from each other in Spanish. The [l] is like the
  'l' in 'libro'; the [ll] is pronounced as in the 'll' in amarillo."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155428Z"^^xsd:dateTime .

oakcurric:misconception-use-son-talk-e-g
  a curric:Misconception ;
  curric:statement """I can use 'son' to talk about what there are where, e.g. 'son tres libros en
  la mesa'."""@en ;
  curric:correction """'Son' means 'they are', is a form of the verb 'ser' ('to be') and is used to
  describe things, people or places. 'Hay' means 'there is' or 'there are' and it is often
  used to identify or locate people or things, e.g. 'hay dos libros y son grandes'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160681Z"^^xsd:dateTime .

oakcurric:misconception-make-nouns-plurals-spanish-add
  a curric:Misconception ;
  curric:statement "To make nouns plurals in Spanish, add -s or -es as in English."@en ;
  curric:correction """To make nouns plurals in Spanish, add -s if the noun ends in a vowel, add -es
  if the noun ends in a consonant and add -ces if the noun ends in z."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162172Z"^^xsd:dateTime .

oakcurric:misconception-infinitives-spanish-translated-verb
  a curric:Misconception ;
  curric:statement "Infinitives in Spanish can only be translated as 'to + verb'."@en ;
  curric:correction "Infinitives in Spanish can be translated as 'to + verb' or '...ing'."@en ;
  dcterms:modified "2026-06-07T15:30:15.163106Z"^^xsd:dateTime .

oakcurric:misconception-form-negative-spanish-need-translate
  a curric:Misconception ;
  curric:statement """To form a negative in Spanish, you need to translate the word 'any' in plural
  sentences as well as making the verb negative, as in 'there are not any beaches'."""@en ;
  curric:correction """There is no Spanish word for 'any' in plural sentences. The word 'no' is used
  before the verb to form a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163365Z"^^xsd:dateTime .

oakcurric:misconception-use-opinion-verbs-without-definite
  a curric:Misconception ;
  curric:statement """We use opinion verbs without the definite article in Spanish as in English,
  e.g. I love Spanish."""@en ;
  curric:correction """In Spanish, opinion verbs always use the definite article before nouns, e.g.
  Amo el español."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164260Z"^^xsd:dateTime .

oakcurric:misconception-qu-cu-l-interchangeable-asking
  a curric:Misconception ;
  curric:statement """'¿Qué?' and '¿cuál?' are always interchangeable when asking for dates: '¿Qué
  es la fecha?' and '¿Cuál es la fecha?' are both correct."""@en ;
  curric:correction """The natural way to ask the date in Spanish is '¿Cuál es la fecha de hoy?'.
  'Cuál' is followed by ‘es’ and 'qué' is followed by a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165751Z"^^xsd:dateTime .

oakcurric:misconception-word-serious-follows-same-pattern
  a curric:Misconception ;
  curric:statement """The word 'serious' follows the same pattern as the word 'nervous', resulting
  in 'nervioso' and 'serioso'."""@en ;
  curric:correction """In Spanish, the word 'serious' is 'serio'. It does not follow the same
  pattern as the word 'nervioso' that translates as 'nervous'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169227Z"^^xsd:dateTime .

oakcurric:misconception-ar-verbs-conjugated-same-way
  a curric:Misconception ;
  curric:statement """All -ar verbs are conjugated in the same way. This includes the verb
  'jugar'."""@en ;
  curric:correction """Some -ar verbs, like 'jugar', are irregular. There is an extra 'e': 'Jug-'
  changes to 'jueg-'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169233Z"^^xsd:dateTime .

oakcurric:misconception-sound-qui-pronounced-same-spanish
  a curric:Misconception ;
  curric:statement "The sound [qui] is pronounced the same in Spanish and English."@en ;
  curric:correction """[qui] is pronounced differently in Spanish and English. [qui] is pronounced
  like a hard 'c' followed by [i] or like the word 'key' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170424Z"^^xsd:dateTime .

oakcurric:misconception-sounds-e-pronounced-same-english
  a curric:Misconception ;
  curric:statement "The sounds [e] and [i] are pronounced the same as in English."@en ;
  curric:correction """The sound [e] is pronounced as in 'elefante' and the sound [i] is pronounced
  as in 'idea'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170813Z"^^xsd:dateTime .

oakcurric:misconception-describing-something-adjectives-come-noun
  a curric:Misconception ;
  curric:statement """When describing something, adjectives come before the noun as they do in
  English."""@en ;
  curric:correction """In Spanish, adjectives mainly come after the noun and agree with the gender
  and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171337Z"^^xsd:dateTime .
