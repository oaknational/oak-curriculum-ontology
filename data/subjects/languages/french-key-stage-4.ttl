    oakcurric:thread-the-future-and-conditional ,
    oakcurric:thread-questions .

oakcurric:unit-2874
  a curric:Unit ;
  rdfs:label "People and lifestyle: Au collège"@en ;
  curric:slug "people-and-lifestyle-au-college" ;
  rdfs:comment """This unit secures understanding of both regular and irregular comparative
  adjectives and adverbs, and then introduces pupils to regular and irregular superlative
  adjectives and adverbs. Pupils learn to use these in the context of expressing preferences
  and strengths at school."""@en ;
  curric:whyThisWhyNow """Following consolidation of adjective agreement and positioning, this unit
  aims to deepen understanding of comparative adjectives and adverbs, and moves on to develop
  mastery of superlative adjectives and adverbs. Pupils will be able to confidently use these
  two types of structures in writing and speaking to communicate their own and others'
  strengths and preferences, which will also prepare them well for upcoming KS4 contexts, such
  as the world of work.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2874-1 ,
    oakcurric:priorknowledge-2874-2 ,
    oakcurric:priorknowledge-2874-3 ,
    oakcurric:priorknowledge-2874-4 ,
    oakcurric:priorknowledge-2874-5 ,
    oakcurric:priorknowledge-2874-6 ;
  curric:id "2874"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.324448Z"^^xsd:dateTime ;
