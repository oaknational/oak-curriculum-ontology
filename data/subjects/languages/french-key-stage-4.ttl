    oakcurric:priorknowledge-2869-5 ,
    oakcurric:priorknowledge-2869-6 ,
    oakcurric:priorknowledge-2869-7 ;
  curric:id "2869"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.390056Z"^^xsd:dateTime ;
