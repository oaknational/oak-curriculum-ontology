# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-develop-my-answers-much-possible
  a curric:Misconception ;
  curric:statement """I should develop my answers as much as possible for all parts of the speaking
  exam."""@en ;
  curric:correction """It is not necessary to develop your answers extensively for all parts of the
  speaking exam. Remember to keep your answers short and succinct in the role-play section."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083811Z"^^xsd:dateTime .

oakcurric:misconception-one-word-french
  a curric:Misconception ;
  curric:statement "There is only one word for \"it\" in French."@en ;
  curric:correction """Nouns are either masculine or feminine. \"It\", when replacing a noun, also
  has a masculine and feminine form. Use 'le' for masculine nouns and 'la' for femnine
  nouns. 'Le' and 'la' shorten to 'l'' when the next word starts with a vowel sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084687Z"^^xsd:dateTime .

oakcurric:misconception-present-participles-preceeded-en
  a curric:Misconception ;
  curric:statement "Present participles are always preceeded by 'en'."@en ;
  curric:correction """The present participles 'ayant', 'étant' and 'faisant de' can be used without
  the preposition 'en' e.g. 'Ayant une grand-mère musulmane, je sais beaucoup sur l'Islam' -
  having a muslim grandmother, I know a lot about Islam."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084701Z"^^xsd:dateTime .

oakcurric:misconception-il-elle-ils-elles-refer
  a curric:Misconception ;
  curric:statement """'Il', 'elle', 'ils' and 'elles' only refer to people and not things. 'Il'
  therefore only means 'he' and 'elle' only means 'she'."""@en ;
  curric:correction """It is useful to keep in mind that 'il, elle' and 'ils, elles' can refer to
  things as well as people. In this case, 'il, elle' means 'it' rather than 'he, she'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084808Z"^^xsd:dateTime .

oakcurric:misconception-words-stick-my-memory-read
  a curric:Misconception ;
  curric:statement "Words will stick in my memory if I read them enough times."@en ;
  curric:correction """It is the act of reaching for words that roots them deeper in memory, so
  testing oneself or working in pairs to try to recall words from memory is the most
  effective learning strategy for holding on to words in your long term memory."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084916Z"^^xsd:dateTime .

oakcurric:misconception-words-ending-ment-adverbs
  a curric:Misconception ;
  curric:statement "All words ending in -ment are adverbs."@en ;
  curric:correction """Whilst many words ending in -ment are adverbs where the feminine form of the
  adjective has been taken and -ment added to create the adverb, not all words ending in
  -ment are adverbs. Some nouns end in -ment e.g. 'le règlement' rule, regulation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084927Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronoun-used-verb-make
  a curric:Misconception ;
  curric:statement "The subject pronoun is used with the verb to make an imperative."@en ;
  curric:correction """Imperative instructions do not include the subject pronoun e.g. Écoute !
  Écoutez !"""@en ;
  dcterms:modified "2026-06-07T15:30:15.085189Z"^^xsd:dateTime .

oakcurric:misconception-words-le-la-l-mean
  a curric:Misconception ;
  curric:statement "The words 'le', 'la' and 'l'' can only mean 'the' in French."@en ;
  curric:correction """The meaning of 'le', 'la', and 'l'' depends on where they are in the
  sentence. When before a noun, they mean 'the', but when before a verb, they mean 'him',
  'her' or 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085200Z"^^xsd:dateTime .

oakcurric:misconception-verbs-refuser-demander-essayer-laisser
  a curric:Misconception ;
  curric:statement """The verbs 'refuser', 'demander', 'essayer', 'laisser' and 'éviter' are
  followed directly by an infinitive, e.g. 'éviter faire' ('to avoid doing'), 'refuser
  faire' ('to refuse to do')."""@en ;
  curric:correction """These verbs are followed by 'de' plus an infinitive, e.g. 'éviter de faire'
  ('to avoid doing'), 'refuser de faire' ('to refuse to do')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085217Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronoun-il-means
  a curric:Misconception ;
  curric:statement "The subject pronoun 'il' always means 'he'."@en ;
  curric:correction """There are a number of impersonal verbs such as 'il faut', 'il neige' and 'il
  pleut'. Verbs such as 'il fait' and 'il est' can also be used in an impersonal sense. In
  these cases, the English meaning is 'it' or impersonal 'you', 'we' as appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085470Z"^^xsd:dateTime .

oakcurric:misconception-make-comparative-adjective-french-add
  a curric:Misconception ;
  curric:statement """To make a comparative adjective in French, add the suffix -er to an
  adjective."""@en ;
  curric:correction """Most comparatives are formed using 'plus ... que' (more ... than), 'moins ...
  que' (less ... than), and 'aussi ... que' (as ... as). The adjective to compare goes in
  the middle and agrees with gender and number of the noun being compared."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085479Z"^^xsd:dateTime .

oakcurric:misconception-using-venir-de-next-word
  a curric:Misconception ;
  curric:statement """When using 'venir de' (to have just), the next word needs to be a past
  participle, like in English."""@en ;
  curric:correction """In French, 'venir de' is like every other French verb followed by 'de'. It is
  always followed by a second verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085593Z"^^xsd:dateTime .

oakcurric:misconception-use-ne-pas-mean-one
  a curric:Misconception ;
  curric:statement "Use 'ne ... pas' to mean 'no, not one, not any'."@en ;
  curric:correction """The structure 'ne ... pas' is used to negative a verb. To say that there was
  'no, not one, not any' of a noun, use the structure 'ne ... aucun/aucune', e.g. 'il n'y a
  aucun fruit ici'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085616Z"^^xsd:dateTime .

oakcurric:misconception-using-depuis-since-sentences-framed
  a curric:Misconception ;
  curric:statement """When using 'depuis' (for, since), sentences are framed in the past in
  French."""@en ;
  curric:correction """In French, when using 'depuis' to describe an action that started in the past
  but continues today, frame the sentence in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085643Z"^^xsd:dateTime .

oakcurric:misconception-irregular-verbs-such-faire-avoir
  a curric:Misconception ;
  curric:statement """Only irregular verbs such as 'faire' and 'avoir' have unusual past
  participles."""@en ;
  curric:correction """Verbs like 'ouvrir', 'traduire' and 'écrire' form their past participles
  differently to regular IR and RE verbs and should be seen as different types of verb when
  learning verb patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085694Z"^^xsd:dateTime .

oakcurric:misconception-isnt-much-prepare-french-listening
  a curric:Misconception ;
  curric:statement "There isn't much I can do to prepare for the French listening exam."@en ;
  curric:correction """Students with a firm knowledge of French SSCs and strong vocabulary recall
  will find the listening exam less daunting. It is important to listen actively and use
  strategies for success such as awareness of distractors and synonyms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085724Z"^^xsd:dateTime .

oakcurric:misconception-answers-listening-comprehension-questions-usually
  a curric:Misconception ;
  curric:statement "Answers in listening comprehension questions are usually obvious."@en ;
  curric:correction """Listening comprehension passages do not always make answers obvious, often
  containing synonyms and distractors to test your attention to detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085738Z"^^xsd:dateTime .

oakcurric:misconception-one-word-french-translate-mine
  a curric:Misconception ;
  curric:statement """There is only one word in French to translate 'mine', 'yours', 'his',
  'hers'."""@en ;
  curric:correction """In French, possessive pronouns match the gender and number of the noun they
  replace in a sentence. They are formed of the definite article and the pronoun, for
  example: 'les chocolats, ce sont les miens,' meaning 'the chocolates, they are mine'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085849Z"^^xsd:dateTime .

oakcurric:misconception-ending-aient-pronounced-differently-ais
  a curric:Misconception ;
  curric:statement "The ending -aient is pronounced differently to -ais and -ait."@en ;
  curric:correction """Although the third person plural ending of the imperfect tense contains a lot
  of letters, it is pronounced the same way as -ais and -ait. Students will need a lot of
  practice saying the -aient ending out loud to become confident with this verb form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085857Z"^^xsd:dateTime .

oakcurric:misconception-imperative-used-tu-vous-forms
  a curric:Misconception ;
  curric:statement """The imperative can only be used in the 'tu' and 'vous' forms in French, to
  instruct others to do something."""@en ;
  curric:correction """The imperative can be used in the 'nous' form in French. In this case, the
  imperative is suggesting what we should do, and is translated as 'let's' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085913Z"^^xsd:dateTime .

oakcurric:misconception-cognates-pronounced-same-way-english
  a curric:Misconception ;
  curric:statement "Cognates are pronounced the same way in English and French."@en ;
  curric:correction """Cognates often sound very different in French. Students must carefully
  practise the French pronunciation of these words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086015Z"^^xsd:dateTime .

oakcurric:misconception-relative-pronouns-qui-que-used
  a curric:Misconception ;
  curric:statement """The relative pronouns 'qui' and 'que' can be used interchangeably to translate
  'that', 'which' or 'who/whom'."""@en ;
  curric:correction """Use 'qui' to introduce a subject-relative clause. Use 'que' to introduce an
  object-relative clause."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086026Z"^^xsd:dateTime .

oakcurric:misconception-verbs-french-used-infinitive-without
  a curric:Misconception ;
  curric:statement """All verbs in French can be used before an infinitive without a
  preposition."""@en ;
  curric:correction """Certain verbs require 'à' or 'de' before a an infinitive. Learning which
  verbs this applies to is helpful. Teachers might like to point out the more frequently
  occurring verbs of this type to help students develop their confidence in using them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086101Z"^^xsd:dateTime .

oakcurric:misconception-plural-possessive-adjectives-agree-gender
  a curric:Misconception ;
  curric:statement "Plural possessive adjectives agree with gender."@en ;
  curric:correction "Plural possessive adjectives only agree with number."@en ;
  dcterms:modified "2026-06-07T15:30:15.086248Z"^^xsd:dateTime .

oakcurric:misconception-reading-listening-texts-useful-developing
  a curric:Misconception ;
  curric:statement """Reading or listening texts are only useful for developing general
  comprehension skills."""@en ;
  curric:correction """Careful use of reading and listening texts to enrich topic-specific
  vocabulary is beneficial for students."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086439Z"^^xsd:dateTime .

oakcurric:misconception-start-transcribing-soon-dictation-begins
  a curric:Misconception ;
  curric:statement "I should start transcribing as soon as the dictation begins."@en ;
  curric:correction """It is useful to listen to the full sentence once before transcribing to get
  an idea of its meaning. This will help you write the sentence down and check it during the
  second and third times that the audio is played."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086445Z"^^xsd:dateTime .

oakcurric:misconception-devoir-pouvoir-require-second-verb
  a curric:Misconception ;
  curric:statement """'Devoir' (must) and 'pouvoir' (can) do not require the second verb to be in
  the infinitive form because an infinitive is not required in English."""@en ;
  curric:correction """'Devoir' means to have (to) and 'pouvoir' means to be able. Therefore, when
  followed by a second verb, this verb must always be in the infinitive form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086453Z"^^xsd:dateTime .

oakcurric:misconception-french-word-order-same-english
  a curric:Misconception ;
  curric:statement """French word order is the same as English to express something being
  missing."""@en ;
  curric:correction """Take care to model 'il manque' with students. 'Il manque' is followed by a
  noun and the English translation is inverted. 'Il manque une personne' means 'a person is
  missing'. 'Il manque' is also used with plural nouns and translates as 'are missing'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086918Z"^^xsd:dateTime .

oakcurric:misconception-agent-nouns-formed-adding-either
  a curric:Misconception ;
  curric:statement """All agent nouns are formed by adding either -eur or -ateur to the stem of the
  verb."""@en ;
  curric:correction """Most agent nouns follow this rule but there are exceptions, for example
  'éduquer' - 'to educate', becomes 'éducateur' - 'educator'. A stem change is needed here."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087050Z"^^xsd:dateTime .

oakcurric:misconception-two-present-tenses-french-simple
  a curric:Misconception ;
  curric:statement """There are two present tenses in French, simple present and present continuous,
  like English."""@en ;
  curric:correction """There is only one present tense in French, which is used to communicate both
  English present tenses. For example, 'je joue au foot' can be translated as both I play
  football and I am playing football."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087082Z"^^xsd:dateTime .

oakcurric:misconception-create-antonyms-french-add-prefix
  a curric:Misconception ;
  curric:statement """To create antonyms in French, always add the prefix in- to the start of an
  adjective or adverb e.g. 'utile' becomes 'inutile'."""@en ;
  curric:correction """Some antonyms are formed by adding the prefix im-. This is when the original
  word begins with p, b or m: possible become impossible; buvable (drinkable) becomes
  imbuvable (undrinkable); 'mature' becomes 'immature'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087123Z"^^xsd:dateTime .

oakcurric:misconception-past-participle-agreement-occurs-perfect
  a curric:Misconception ;
  curric:statement "Past participle agreement only occurs in the perfect tense."@en ;
  curric:correction """In the passive voice, all past participles are combined with a form of
  'être'. As such, past participle agreement rules apply to all verbs, e.g. 'la scène est
  critiquée par le journaliste'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087209Z"^^xsd:dateTime .

oakcurric:misconception-silent-final-consonants-silent
  a curric:Misconception ;
  curric:statement "Silent final consonants are always silent."@en ;
  curric:correction """The liaison rule means that Silent Final Consonants are pronounced when the
  next word starts with a vowel sound (including silent h)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087219Z"^^xsd:dateTime .

oakcurric:misconception-need-include-pas-using-negative
  a curric:Misconception ;
  curric:statement "You need to include 'pas' when using a negative subject pronoun."@en ;
  curric:correction """The whole negative meaning is contained in the negative subject pronoun (rien
  or personne) with 'ne' before the following verb. An additional negative element is not
  necessary e.g. Personne ne mange sainement - nobody eats healthily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087226Z"^^xsd:dateTime .

oakcurric:misconception-letter-o-consistently-pronounced-french
  a curric:Misconception ;
  curric:statement "The letter 'o' is consistently pronounced in French words."@en ;
  curric:correction """An 'o' sound can be open or closed. 'O' is open when it is followed by a
  consonant (votre). 'O' is closed when it is written with a circumflex (ô), it is the last
  sound in a syllable (trop) or is followed by a 'z' sound (rose)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087258Z"^^xsd:dateTime .

oakcurric:misconception-verbs-ending-aitre-form-perfect
  a curric:Misconception ;
  curric:statement "All verbs ending 'aitre' form the perfect tense in the same way."@en ;
  curric:correction """Whilst this group of verbs behaves very similarly, the verb 'naitre' is
  irregular in the perfect tense. Students should be aware that it uses 'être' to form the
  perfect tense and its past participle is 'né'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087269Z"^^xsd:dateTime .

oakcurric:misconception-french-object-pronouns-go-verb
  a curric:Misconception ;
  curric:statement """French object pronouns go after the verb in place of the object, just as in
  English, e.g. 'the museum interests me'."""@en ;
  curric:correction """French object pronouns go before the verb, e.g. 'le musée m'intéresse'. When
  speaking and writing French we have to take care to use the correct word, especially for
  object pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087275Z"^^xsd:dateTime .

oakcurric:misconception-similar-looking-french-english-words
  a curric:Misconception ;
  curric:statement "All similar looking French and English words have the same meaning."@en ;
  curric:correction """Often, French words have multiple meanings and it is important to choose the
  right one for the given context e.g. 'durable' means durable and sustainable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087387Z"^^xsd:dateTime .

oakcurric:misconception-expression-jai-mal-means-pain
  a curric:Misconception ;
  curric:statement "The expression 'j'ai mal' only means 'I have a pain'."@en ;
  curric:correction """The French expression 'avoir mal' covers a number of symptoms which might be
  variously translated into English as an ache, a pain and sore or hurting body parts.
  Students should think about what sounds most natural when translating into English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087408Z"^^xsd:dateTime .

oakcurric:misconception-include-much-detail-possible-role
  a curric:Misconception ;
  curric:statement "I should include as much detail as possible in role-play answers."@en ;
  curric:correction """When performing a role-play, answers should contain one verb and be concise.
  Do not add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087553Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-one-translation-e
  a curric:Misconception ;
  curric:statement "The imperfect tense only has one translation e.g. 'used to'."@en ;
  curric:correction """Students must be aware that the imperfect tense can be translated differently
  according to context and intended meaning e.g. 'used to', 'was doing' or 'did'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087584Z"^^xsd:dateTime .

oakcurric:misconception-nouns-ending-ion-ation-masculine
  a curric:Misconception ;
  curric:statement "Some nouns ending in -ion or -ation are masculine."@en ;
  curric:correction """Every noun ending in -ion and -ation is feminine. There are no
  exceptions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087589Z"^^xsd:dateTime .

oakcurric:misconception-direct-object-pronouns-used-verbs
  a curric:Misconception ;
  curric:statement """Direct object pronouns can be used with verbs followed by 'à' like 'demander'
  and 'donner'."""@en ;
  curric:correction """Indirect object pronouns should be used with these verbs because you ask 'of'
  and give 'to' someone in French. In English, the 'to' is often dropped with these kinds of
  verbs, e.g. 'je lui donne un cadeau' - 'I give (to) him, her a present'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087595Z"^^xsd:dateTime .

oakcurric:misconception-nous-means
  a curric:Misconception ;
  curric:statement "'Nous' always means 'we'."@en ;
  curric:correction """'Nous' means 'we' when used as a subject pronoun, but it means 'us' when used
  as a direct object pronoun and '(to) us' when used as an indirect object pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087676Z"^^xsd:dateTime .

oakcurric:misconception-writing-talking-someone-done-using
  a curric:Misconception ;
  curric:statement """When writing, talking about what someone does, has done using a text written
  in the first person for information, only the subject pronoun needs to be changed in each
  sentence."""@en ;
  curric:correction """When writing, talking in the third person using a text in the first person
  for information, change the subject pronoun, verb, object pronouns and possessive
  adjectives (words like 'my', 'your', 'his', 'her')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087771Z"^^xsd:dateTime .

oakcurric:misconception-regular-verbs-past-participle-ending
  a curric:Misconception ;
  curric:statement "All regular verbs have a past participle ending in 'é', 'u' or 'i'."@en ;
  curric:correction """There are other groups of regular verbs with different endings to the main
  -er, -re, -ir groups. These verbs are very commonly used and students should practise them
  regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087906Z"^^xsd:dateTime .

oakcurric:misconception-using-verb-rappeler-need-suitable
  a curric:Misconception ;
  curric:statement """When using the verb 'rappeler', you need to have a suitable word for 'about',
  e.g., 'I am reminding you about the party'."""@en ;
  curric:correction """When using the verb 'rappeler', there is no need to include a word for
  'about'. 'Rappeler' contains this idea within the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087912Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-translated-english-e
  a curric:Misconception ;
  curric:statement """The imperfect tense is only translated by 'was doing' in English e.g. I was
  listening to the radio."""@en ;
  curric:correction """The imperfect tense has more than one translation in English according to its
  use in French. Students need to be aware of the different meanings that might be conveyed
  when they encounter the imperfect tense e.g. I listened, I used to listen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088149Z"^^xsd:dateTime .

oakcurric:misconception-letter-x-words-sixi-me
  a curric:Misconception ;
  curric:statement """The letter x in the words 'sixième' and 'dixième' is pronounced the same as in
  English."""@en ;
  curric:correction """The letter x is pronounced as z due to liaison in these words and should be
  carefully practised to develop an authentic pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088225Z"^^xsd:dateTime .

oakcurric:misconception-different-words-french-indirect-object
  a curric:Misconception ;
  curric:statement """There are different words in French for the indirect object pronouns 'to him'
  and 'to her'."""@en ;
  curric:correction """There is just one third person singular indirect object pronoun in French,
  'lui' , which means both 'to him' and 'to her'. It follows the same rule as other object
  pronouns - it precedes the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088234Z"^^xsd:dateTime .

oakcurric:misconception-france-famous-painting-called-mona
  a curric:Misconception ;
  curric:statement "In France, the famous painting is called Mona Lisa, just like in English."@en ;
  curric:correction """The French have their own name for the Mona Lisa, 'la Joconde', taken from
  the name of the lady in the painting - 'la Gioconda' in Italian."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088346Z"^^xsd:dateTime .

oakcurric:misconception-french-translated-literally-english-e
  a curric:Misconception ;
  curric:statement """In French, 'to you' is translated literally from English e.g. I say to you 'je
  dis à toi'."""@en ;
  curric:correction """In French indirect object pronouns to me and to you are translated by single
  words: 'me' and 'te'. They go before the verb, not at the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088668Z"^^xsd:dateTime .

oakcurric:misconception-three-types-regular-verbs-form
  a curric:Misconception ;
  curric:statement """There are only three types of regular verbs and they form their past
  participles in the same way."""@en ;
  curric:correction """There are distinct groups of 'ir' and 're' verbs which form their past
  participles differently from the regular pattern (-i, -u). Students will find it
  beneficial to learn these verbs together as a group."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089049Z"^^xsd:dateTime .

oakcurric:misconception-make-comparatives-superlatives-french-add
  a curric:Misconception ;
  curric:statement """To make comparatives and superlatives in French, add suffixes -er and -est to
  adjectives."""@en ;
  curric:correction """Suffixes -er and -est do not exist in French. To form comparatives, use the
  forms 'more', 'less ... than' - 'plus ... que' and 'moins ... que'. To form superlatives,
  use the forms 'the most', 'the least' - 'le, la, les plus' and 'le, la, les moins'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089055Z"^^xsd:dateTime .

oakcurric:misconception-idioms-same-different-languages
  a curric:Misconception ;
  curric:statement "Idioms are the same in different languages."@en ;
  curric:correction """Idioms can be specific to a language, culture or group of people. They are
  often impossible to translate directly. Their use adds variety and authenticity to
  students' work but it is necessary to discuss the idiom carefully when it is taught."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089078Z"^^xsd:dateTime .

oakcurric:misconception-two-present-tenses-french
  a curric:Misconception ;
  curric:statement "There are two present tenses in French."@en ;
  curric:correction """There is only one present tense in French which translates both the simple
  present (I do) and the present continous (I am doing)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089259Z"^^xsd:dateTime .

oakcurric:misconception-subject-sentence-precedes-verb-object
  a curric:Misconception ;
  curric:statement """The subject of a sentence precedes the verb and the object of a sentence
  always follows the verb."""@en ;
  curric:correction "When using direct object pronouns, the object precedes the verb."@en ;
  dcterms:modified "2026-06-07T15:30:15.089267Z"^^xsd:dateTime .

oakcurric:misconception-making-suggestions-lets-needs-said
  a curric:Misconception ;
  curric:statement """When making suggestions, 'let's' needs to be said in French as a separate
  idea."""@en ;
  curric:correction """In French, use the imperative in the 'nous' form to create the phrase 'let's
  + verb', e.g. 'allons ...' means 'let's go ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089362Z"^^xsd:dateTime .

oakcurric:misconception-il-y-means
  a curric:Misconception ;
  curric:statement "'Il y a' always means 'there is'."@en ;
  curric:correction """'Il y a' can mean 'there is' or 'there are' and can be used with singular or
  plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089545Z"^^xsd:dateTime .

oakcurric:misconception-verb-jouer-followed-preposition
  a curric:Misconception ;
  curric:statement "The verb jouer is always followed by the preposition à."@en ;
  curric:correction "Use jouer à for sports but use jouer de for instruments."@en ;
  dcterms:modified "2026-06-07T15:30:15.089693Z"^^xsd:dateTime .

oakcurric:misconception-vous-form-address-used-plural
  a curric:Misconception ;
  curric:statement "The 'vous' form of address is only used for plural situations."@en ;
  curric:correction """In formal situations, it is essential to address somebody as 'vous' in order
  to be polite and to show respect. Careful consideration of the context of a conversation
  is very important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089712Z"^^xsd:dateTime .

oakcurric:misconception-prepare-listening-exam-learning-vocabulary
  a curric:Misconception ;
  curric:statement """I can only prepare for the listening exam by learning vocabulary and
  grammar."""@en ;
  curric:correction """While a strong grasp of grammar and excellent recall of vocabulary is
  essential, there are also strategies to help students achieve success in the listening
  exam. Prediction of words and phrases is one method to actively engage with listening."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090161Z"^^xsd:dateTime .

oakcurric:misconception-subject-sentence-noun-pronoun
  a curric:Misconception ;
  curric:statement "The subject of a sentence can only be a noun or pronoun."@en ;
  curric:correction """A verb can be used as the subject of a sentence. In French, it must be in its
  infinitive form. When translated to English, use the -ing form of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090844Z"^^xsd:dateTime .

oakcurric:misconception-cognates-pronounced-same-way-french
  a curric:Misconception ;
  curric:statement "Cognates are pronounced the same way in French as they are in English."@en ;
  curric:correction """Cognates are often pronounced very differently in French. Students should not
  overlook the importance of practising pronunciation of cognates in order to better respond
  to listening stimuli as well as to develop a more authentic pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090959Z"^^xsd:dateTime .

oakcurric:misconception-acceptable-give-short-answers-conversation
  a curric:Misconception ;
  curric:statement """It is acceptable to only give short answers in the conversation element of the
  speaking exam."""@en ;
  curric:correction """Students should focus on giving answers in conversation that include at least
  three verb clauses. They should also regularly practise developing their answers with
  different verb tenses, subjects, opinions and reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091715Z"^^xsd:dateTime .

oakcurric:misconception-french-indirect-object-pronouns-same
  a curric:Misconception ;
  curric:statement """French indirect object pronouns are all the same as direct object
  pronouns."""@en ;
  curric:correction """While some object pronouns are the same when used both indirectly and
  directly (e.g. me, te), there are some differences that students need to learn. It is a
  good idea to provide plenty of practice in this area to help students gain confidence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095744Z"^^xsd:dateTime .

oakcurric:misconception-verbs-change-their-spelling-agree
  a curric:Misconception ;
  curric:statement "Verbs never change their spelling to agree for gender or number."@en ;
  curric:correction """Past participles with 'être' verbs do agree for gender and number. Embedding
  this knowledge requires practice, a component of which can be practice of sound-symbol
  correspondences [i], [u], [é], [SFC], and [SFE]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106013Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-one-possible-translation
  a curric:Misconception ;
  curric:statement "Adjectives only have one possible translation."@en ;
  curric:correction """In French, adjectives can be used as a noun. When preceded by a definite
  article, they are often translated as the (adjective) one e.g. le bleu is translated as
  the blue one, not blue or the blue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106415Z"^^xsd:dateTime .

oakcurric:misconception-qu-pronounced-same-way-french
  a curric:Misconception ;
  curric:statement "[qu] is pronounced the same way in French as in English."@en ;
  curric:correction """In French, [qu] is always a hard sound and must be carefully practised in
  order to ensure clear communication with French speakers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107022Z"^^xsd:dateTime .

oakcurric:misconception-saying-like-french-word-needed
  a curric:Misconception ;
  curric:statement """When saying what you would like to do, a French word for 'would' is needed
  before the verb 'aimer' to like."""@en ;
  curric:correction """In French, to say what you would like to do, use the conditional stem of the
  verb vouloir together with the appropriate ending - -ais for 'je' and 'tu', -ait for 'il'
  and 'elle'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107399Z"^^xsd:dateTime .

oakcurric:misconception-use-french-present-participle-ant
  a curric:Misconception ;
  curric:statement "I use the French present participle -ant to translate -ing in English."@en ;
  curric:correction """The present participle -ant is not the only way to translate -ing in English.
  Sometimes the French infinitive is needed, where English uses the -ing form as a noun,
  e.g., 'visiter le Maroc aide à mieux connaître sa culture'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107555Z"^^xsd:dateTime .

oakcurric:misconception-want-avoid-using-object-pronouns
  a curric:Misconception ;
  curric:statement """I want to avoid using object pronouns because my writing will be longer and
  therefore better if I just repeat all the nouns."""@en ;
  curric:correction """Although object pronouns use fewer words, it is much better style to use them
  to avoid repeating nouns. Appropriate use of object pronouns is also positively rewarded
  in exams as an example of complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107892Z"^^xsd:dateTime .

oakcurric:misconception-que-used-subject-relative-clause
  a curric:Misconception ;
  curric:statement """Que can be used in a subject relative clause e.g. le prof que s'appelle M.
  Jones est sympa."""@en ;
  curric:correction """When the relative clause introduces a verb to describe a subject, 'qui' must
  be used and not 'que'. E.g. le prof qui s'appelle M. Jones est sympa."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108572Z"^^xsd:dateTime .

oakcurric:misconception-il-means-english
  a curric:Misconception ;
  curric:statement "'Il' always means 'he' in English."@en ;
  curric:correction """Impersonal verbs nearly always have the subject 'il'. This translates as 'it'
  instead of 'he', e.g. 'il fait beau' - 'it is nice weather'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108586Z"^^xsd:dateTime .

oakcurric:misconception-negative-structure-ne-personne-formed
  a curric:Misconception ;
  curric:statement """The negative structure ne ... personne is formed the same way as ne ... pas
  and ne ... jamais in the perfect tense."""@en ;
  curric:correction """Ne ... personne is unusual in that the second component (personne) comes
  after the past participle in the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108608Z"^^xsd:dateTime .

oakcurric:misconception-answer-conversation-questions-same-tense
  a curric:Misconception ;
  curric:statement """I can only answer conversation questions in the same tense as the
  question."""@en ;
  curric:correction """After responding appropriately to the initial question, it is a good idea to
  use different tenses in your answer to develop your response and to give interesting
  detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110020Z"^^xsd:dateTime .

oakcurric:misconception-indefinite-partitive-articles-used-negative
  a curric:Misconception ;
  curric:statement "Indefinite and partitive articles are used after negative structures."@en ;
  curric:correction """After a negative structure has been used, indefinite and partitive articles
  replaced by 'de', e.g. 'je n'ai pas de pain'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110416Z"^^xsd:dateTime .

oakcurric:misconception-ch-pronounced-same-french-english
  a curric:Misconception ;
  curric:statement "[ch] is pronounced the same in French as it is in English."@en ;
  curric:correction """[ch] is a softer sound in French and students will need directed practice in
  order to pronounce it correctly. It is more like the sound 'sh' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110801Z"^^xsd:dateTime .

oakcurric:misconception-forming-questions-need-translate-english
  a curric:Misconception ;
  curric:statement """When forming yes/no questions, we need to translate the English 'do' or 'does'
  into French."""@en ;
  curric:correction """There is no equivalent to 'do' or 'does' in French. Use inversion, intonation
  or 'est-ce que' to form yes/no questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112933Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-verbs-pronouns-used-physical
  a curric:Misconception ;
  curric:statement """Reflexive verbs and pronouns are only used when a physical action is done to
  oneself."""@en ;
  curric:correction """Reflexive verbs and pronouns indicate that the subject and object are the
  same person, but do not always represent a physical action. Sometimes there is no direct
  translation for the French reflexive pronoun in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112939Z"^^xsd:dateTime .

oakcurric:misconception-second-element-negative-structure-goes
  a curric:Misconception ;
  curric:statement """The second element of the negative structure goes after the past participle
  when forming past tense phrases."""@en ;
  curric:correction """The second element of the negative structure is always placed after the
  auxiliary verb and before the past participle. This requires practice as students are
  likely to misapply the negative structure learned with present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114094Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-used-describe-things
  a curric:Misconception ;
  curric:statement """The imperfect tense is only used to describe how things were or used to be in
  the past."""@en ;
  curric:correction """The imperfect tense is also used to say what was happening when another thing
  occurred where it is used in combination with the perfect tense e.g. il regardait la télé
  quand son portable a sonné."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115291Z"^^xsd:dateTime .

oakcurric:misconception-same-number-words-used-translating
  a curric:Misconception ;
  curric:statement """There are always the same number of words used when translating between
  languages."""@en ;
  curric:correction """As languages are complex, many ideas are expressed differently in different
  languages. When translating, more or fewer words might be needed to convey the information
  e.g. avant de passer un examan - before sitting an exam."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116440Z"^^xsd:dateTime .

oakcurric:misconception-apr-s-avoir-past-participle
  a curric:Misconception ;
  curric:statement "The 'après avoir' + past participle structure applies to all verbs."@en ;
  curric:correction """Verbs which take 'être' in the perfect tense use the structure 'après être' +
  past participle. The past participle must agree with the subject of the sentence, e.g.
  'après être arrivée, elle a fait ses devoirs'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116756Z"^^xsd:dateTime .

oakcurric:misconception-french-verbs-use-avoir-auxiliary
  a curric:Misconception ;
  curric:statement "All French verbs use 'avoir' as the auxiliary to form the perfect tense."@en ;
  curric:correction """Verbs expressing changes of state, location or condition often use 'être' to
  form the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118537Z"^^xsd:dateTime .

oakcurric:misconception-pronouns-ils-elles-refer-people
  a curric:Misconception ;
  curric:statement "The pronouns ils and elles can only refer to people."@en ;
  curric:correction """Ils and elles can refer to things as well as people. They are still
  translated as 'they'. We must use context and surrounding language to work out who or what
  they are referring to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118543Z"^^xsd:dateTime .

oakcurric:misconception-qui-means-question
  a curric:Misconception ;
  curric:statement "'Qui' always means the question 'who?'."@en ;
  curric:correction """When used in an interrogative sense, 'qui ?' means 'who?'. As a relative
  pronoun, 'qui' introduces more information about the subject in the main clause and can be
  translated as 'who', 'which' or 'that'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118634Z"^^xsd:dateTime .

oakcurric:misconception-french-uses-present-participle-preposition
  a curric:Misconception ;
  curric:statement "French uses the present participle after the preposition 'sans'."@en ;
  curric:correction """'Sans' is followed by an infinitive in French where in English the present
  participle would be used, e.g. 'without knowing', 'without looking'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118640Z"^^xsd:dateTime .

oakcurric:misconception-use-verbs-same-tense-task
  a curric:Misconception ;
  curric:statement """You must only use verbs in the same tense as the task question in your
  answer."""@en ;
  curric:correction """Students should practise combining different tenses of verbs when giving
  their answers (ensuring they give a relevant response to the task) in order to demonstrate
  a wider knowledge of language and to give a richer response."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118957Z"^^xsd:dateTime .

oakcurric:misconception-verbs-french-relate-personal-actions
  a curric:Misconception ;
  curric:statement """Verbs in French that relate to personal actions are only composed the same as
  in English."""@en ;
  curric:correction """Many verbs relating to daily routine are reflexive in French and require a
  reflexive pronoun to be used, e.g., 'je me lève'. This reflexive pronoun is not always
  used in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118963Z"^^xsd:dateTime .

oakcurric:misconception-infinitive-verbs-used-follow-conjugated
  a curric:Misconception ;
  curric:statement "Infinitive verbs are only used when they follow a conjugated verb."@en ;
  curric:correction """When an infinitive is used at the start of a clause, it becomes a noun, e.g.
  'Étudier est un bon moyen de trouver un meilleur emploi.'. ('Studying is a good way to
  find a better job.')"""@en ;
  dcterms:modified "2026-06-07T15:30:15.120560Z"^^xsd:dateTime .

oakcurric:misconception-use-same-articles-nouns-negative
  a curric:Misconception ;
  curric:statement "Use the same articles for nouns after negative structures."@en ;
  curric:correction """After a negative structure (e.g. 'je n'ai pas'), indefinite and partitive
  articles change to 'de', e.g. 'je n'ai pas d'information' - 'I don't have any
  information'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120839Z"^^xsd:dateTime .

oakcurric:misconception-cant-use-imperfect-perfect-tenses
  a curric:Misconception ;
  curric:statement "I can't use the imperfect and perfect tenses together."@en ;
  curric:correction """The two past tenses work together well to give a full description of past
  events. Use the perfect tense for completed actions and the imperfect to describe what
  things were like."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120877Z"^^xsd:dateTime .

oakcurric:misconception-choose-bullet-points-answer-essay
  a curric:Misconception ;
  curric:statement """I can choose which bullet points I answer for the essay questions in the
  writing paper."""@en ;
  curric:correction """You must answer all bullet points for the essay questions in the writing
  paper."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120963Z"^^xsd:dateTime .

oakcurric:misconception-verbs-use-their-infinitive-form
  a curric:Misconception ;
  curric:statement "All verbs use their infinitive to form the stem in the future tense."@en ;
  curric:correction """There are key irregular verb stems to learn for the future tense. Confident
  use of these verbs will add greatly to overall accuracy and help students to express
  themselves confidently in the future tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.121026Z"^^xsd:dateTime .

oakcurric:misconception-masculine-nouns-made-feminine-adding
  a curric:Misconception ;
  curric:statement """All masculine nouns are made feminine by adding 'e' and plural by
  adding 's'."""@en ;
  curric:correction """A masculine noun can be made feminine by changing the article, adding 'e',
  changing 'eur' to 'ice' or 'n' to 'nne'. Nouns can be made plural by adding 's' or 'aux'.
  Nouns ending in 's' or 'x' don't have a plural form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122876Z"^^xsd:dateTime .

oakcurric:misconception-way-adjective-made-feminine-adding
  a curric:Misconception ;
  curric:statement """The only way an adjective is made feminine is by adding the letter 'e' to a
  masculine adjective."""@en ;
  curric:correction """Although many feminine adjectives are formed by adding 'e' to a masculine
  adjective, there are other feminine endings and rules governing these, e.g. -se, -elle,
  -enne, -ve, -ère."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122913Z"^^xsd:dateTime .

oakcurric:misconception-present-continous-english-direct-translation
  a curric:Misconception ;
  curric:statement "The present continous in English has a direct translation in French."@en ;
  curric:correction """Students need to take care to translate both the simple present and the
  present continous with the present tense in French e.g. I listen and I am listening are
  translated exactly the same way: j'écoute."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122953Z"^^xsd:dateTime .

oakcurric:misconception-use-infinitive-translate-ing-verb
  a curric:Misconception ;
  curric:statement "Always use the infinitive to translate the '-ing' verb form into French."@en ;
  curric:correction """The infinitive used as a noun in French translates the idea of 'doing'
  something, e.g. 'fumer est mauvais' ('smoking is bad'). The present participle translates
  the present continuous in English, e.g. 'étant célèbre' ('being famous')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123151Z"^^xsd:dateTime .

oakcurric:misconception-times-read-text-better-ill
  a curric:Misconception ;
  curric:statement "The more times I read the text, the better I’ll understand it."@en ;
  curric:correction """Simply re-reading without purpose doesn’t necessarily lead to better
  comprehension. Strategies such as reading through the text and questions, using each
  question to find the relevant part of the text, avoiding distractors, etc., are more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123327Z"^^xsd:dateTime .

oakcurric:misconception-word-actuellement-means-actually
  a curric:Misconception ;
  curric:statement "The word 'actuellement' means 'actually'."@en ;
  curric:correction "The word 'actuellement' means 'currently'."@en ;
  dcterms:modified "2026-06-07T15:30:15.123385Z"^^xsd:dateTime .

oakcurric:misconception-isnt-much-prepare-french-reading
  a curric:Misconception ;
  curric:statement "There isn't much I can do to prepare for the French reading exam."@en ;
  curric:correction """Regularly revising vocabulary is an excellent method of preparation for the
  reading exam as well as being mindful of strategies such as spotting distractors and using
  synonyms to find the correct answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123411Z"^^xsd:dateTime .

oakcurric:misconception-describing-photo-writing-exam-develop
  a curric:Misconception ;
  curric:statement """When describing the photo in the writing exam, I should develop my sentences
  with justified opinions and a range of verb tenses."""@en ;
  curric:correction """You should keep photo description sentences short and simple in the writing
  exam."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123464Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-go-noun-french
  a curric:Misconception ;
  curric:statement "All adjectives go after the noun in French."@en ;
  curric:correction """While the majority of adjectives are placed after the noun, certain types of
  adjective go in front. Students should be aware of which adjectives go where in order to
  speak and write with greater accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123851Z"^^xsd:dateTime .

oakcurric:misconception-superlative-sentences-same-word-order
  a curric:Misconception ;
  curric:statement "Superlative sentences have the same word order in English and French."@en ;
  curric:correction """Take care when writing or translating superlative sentences as the French
  word order differs quite significantly from English, e.g., 'the most interesting lesson' >
  'the lesson the most interesting'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124663Z"^^xsd:dateTime .

oakcurric:misconception-french-adjectives-come-noun-describing
  a curric:Misconception ;
  curric:statement "French adjectives always come after the noun they are describing."@en ;
  curric:correction """There are five categories of adjectives which come before the noun: beauty,
  rank, age, good/bad, size/quantity. Practise using these before the noun alongside other
  adjectives which come after the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124944Z"^^xsd:dateTime .

oakcurric:misconception-french-verb
  a curric:Misconception ;
  curric:statement "There is a French verb 'to can'."@en ;
  curric:correction """The English idea of 'can' is translated in French by the verb 'pouvoir'
  meaning 'to be able to'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125071Z"^^xsd:dateTime .

oakcurric:misconception-s-silent-final-consonant
  a curric:Misconception ;
  curric:statement "[s] is always a silent final consonant."@en ;
  curric:correction """[s] is usually a silent final consonant, but is pronounced when between two
  vowels. It's helpful to look out for verbs that start with a vowel. With such verbs in the
  third person plural, the 's' on 'ils' and 'elles' is pronounced."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125187Z"^^xsd:dateTime .

oakcurric:misconception-translated
  a curric:Misconception ;
  curric:statement "'à' is always translated as 'to' or 'at'."@en ;
  curric:correction """'à' can be translated as 'to', 'at', 'in', 'on' or 'about', depending on the
  context. Particular care should be taken with verbs followed by 'à', e.g., 'réfléchir à'
  could be translated as 'to think about' or 'to reflect on'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125503Z"^^xsd:dateTime .

oakcurric:misconception-noun-un-tre-meaning-changes
  a curric:Misconception ;
  curric:statement """The noun 'un être', meaning 'a being', changes to 'une être' when referring to
  a girl or woman. 'Un être humain' changes to 'une être humaine' in the feminine."""@en ;
  curric:correction """The noun 'être' is masculine, even when referring to a girl or a woman. The
  phrase 'un être humain', 'a human being', refers to both genders."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125843Z"^^xsd:dateTime .

oakcurric:misconception-easy-predict-past-participles-irregular
  a curric:Misconception ;
  curric:statement "It is easy to predict the past participles of irregular verbs."@en ;
  curric:correction """The past participles of irregular verbs must be learnt carefully. There are,
  however, similarities that are worth noting e.g. many irregular past participles end -u
  e.g. pu, voulu, cru, su."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126481Z"^^xsd:dateTime .

oakcurric:misconception-pronouns-y-en-go-verb
  a curric:Misconception ;
  curric:statement """The pronouns 'y' and 'en' go after the verb, as 'there' and 'of it/them' do in
  English."""@en ;
  curric:correction """'Y' and 'en' go before the verb in a present tense sentence e.g. 'elle y va'
  and 'elle en boit'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134657Z"^^xsd:dateTime .

oakcurric:misconception-learn-set-sentences-heart-produce
  a curric:Misconception ;
  curric:statement """You can just learn set sentences by heart and produce them mechanically when
  requested."""@en ;
  curric:correction """Both writing and speaking must be adapted to the question and have a level of
  personalisation and spontaneity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137872Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-ending-al-take-s
  a curric:Misconception ;
  curric:statement "Adjectives ending in -al take -s to create the masculine plural form."@en ;
  curric:correction """Adjectives ending in -al need a spelling change to create the masculine
  plural form. Remove the -l and add -ux for example 'familial' - 'familiaux' in the
  masculine plural form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138313Z"^^xsd:dateTime .

oakcurric:misconception-french-idea-best-worst-translated
  a curric:Misconception ;
  curric:statement """In French the idea of 'best' and 'worst' is translated as 'plus bon' or 'plus
  mauvais'."""@en ;
  curric:correction """Just as in English, the French for 'best' and 'worst' are irregular
  adjectives and need to be learned carefully to avoid misunderstanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140034Z"^^xsd:dateTime .

oakcurric:misconception-answers-conversation-questions-given-same
  a curric:Misconception ;
  curric:statement """Answers to conversation questions should only be given in the same tense as
  the question."""@en ;
  curric:correction """Students should develop answers to conversation questions in order to give
  additional information and detail. Using different tenses allows students to give a more
  detailed and complex answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140690Z"^^xsd:dateTime .

oakcurric:misconception-same-amount-words-used-translating
  a curric:Misconception ;
  curric:statement """The same amount of words are used when translating between French and
  English."""@en ;
  curric:correction """Due to the nature of the languages, there may be differences in how some
  words or ideas are translated e.g. I need is 'j'ai besoin de' in French. More or fewer
  words might be necessary to complete an accurate translation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142479Z"^^xsd:dateTime .

oakcurric:misconception-reflexive-pronouns-used-talk-actions
  a curric:Misconception ;
  curric:statement "Reflexive pronouns are only used to talk about actions done to oneself."@en ;
  curric:correction """Reflexive pronouns are also used with verbs to indicate a reciprocal (shared)
  action between two or more subjects. Verbs can only be reciprocal with plural subjects,
  i.e. 'nous', 'vous' and 'ils/elles'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142986Z"^^xsd:dateTime .

oakcurric:misconception-verbs-using-reflexive-pronouns-reflexive
  a curric:Misconception ;
  curric:statement "All verbs using reflexive pronouns are reflexive."@en ;
  curric:correction """Reciprocal verbs use the reflexive pronouns 'se', 'nous' and 'vous'. They are
  used to express actions that two or more people perform with, or for, each other, e.g.
  'nous nous écrivons souvent' - 'we often write to each other'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.146550Z"^^xsd:dateTime .

oakcurric:misconception-mieux-plus-mal-moins-bien
  a curric:Misconception ;
  curric:statement """'Mieux' and 'plus mal/moins bien' can be used interchangeably with 'le mieux'
  and 'le plus mal' or ''le moins bien'."""@en ;
  curric:correction """'Le mieux' and 'le plus mal'/'le moins bien' are superlative adverbs to
  describe actions as '(the) best' or '(the) worst'. 'Mieux' and 'moins bien'/'plus mal'
  describe actions as 'better' or 'less well'/'worse' and are comparative adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148791Z"^^xsd:dateTime .

oakcurric:misconception-better-give-long-answers-role
  a curric:Misconception ;
  curric:statement """It is better to give long answers in the role-play task than short
  responses."""@en ;
  curric:correction """The role-play task is a short exercise requiring relevant answers to each
  bullet point that contain a verb. Longer answers are not appropriate to this task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149519Z"^^xsd:dateTime .

oakcurric:misconception-extended-150-word-writing-task
  a curric:Misconception ;
  curric:statement "An extended 150-word writing task should be planned as one complete task."@en ;
  curric:correction """It is helpful to break down an extended writing task into two paragraphs and
  then to further break down those paragraphs. This allows students to manage the length of
  the task by treating it as four smaller connected tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149802Z"^^xsd:dateTime .

oakcurric:misconception-doesnt-matter-address-stranger-france
  a curric:Misconception ;
  curric:statement """It doesn't matter if you address a stranger in France as 'tu' or as
  'vous'."""@en ;
  curric:correction """Using the correct register of address is very important for students.
  Practising role-plays in both formal and informal settings allows students to understand
  when to use the appropriate form of 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152297Z"^^xsd:dateTime .

oakcurric:misconception-longer-written-tasks-require-careful
  a curric:Misconception ;
  curric:statement "Longer written tasks do not require careful planning and structuring."@en ;
  curric:correction """It is essential to carefully plan and structure longer written tasks to avoid
  students writing off the topic and their work becoming unwieldy. The use of the acronym
  BORDER helps students to plan and review a relevant response."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152584Z"^^xsd:dateTime .

oakcurric:misconception-ir-verbs-follow-same-pattern
  a curric:Misconception ;
  curric:statement """All -ir verbs follow the same pattern in the present tense, like -er
  verbs."""@en ;
  curric:correction """-ir verbs can be grouped into verbs like 'choisir', verbs like 'partir',
  verbs like 'venir' and verbs like 'ouvrir'. By learning the stem formation and endings for
  these four verbs, students should be able to use wide range of -ir verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155499Z"^^xsd:dateTime .

oakcurric:misconception-simple-future-stem-aller-its
  a curric:Misconception ;
  curric:statement "The simple future stem of 'aller' is its infinitive, like most -er verbs."@en ;
  curric:correction """'Aller' is an irregular verb and its stem in the simple future is ir-. The
  normal simple future endings are added to this stem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156010Z"^^xsd:dateTime .

oakcurric:misconception-qu-pronounced-same-french-english
  a curric:Misconception ;
  curric:statement "[qu] is pronounced the same in French and in English."@en ;
  curric:correction """[qu] is pronounced differently in French and in English. It is important to
  to recognise and pronounce sound-spelling links correctly to understand and be understood
  by other French speakers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157036Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-pronouns-y-en
  a curric:Misconception ;
  curric:statement "In the perfect tense, the pronouns y and en go before the past participle."@en ;
  curric:correction """Both y and en go before the auxiliary verb in the perfect tense e.g. il y est
  allé, il en a mangé."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157042Z"^^xsd:dateTime .

oakcurric:misconception-words-meilleur-mieux-used-interchangeably
  a curric:Misconception ;
  curric:statement """The words 'meilleur' and 'mieux' can be used interchangeably as they both
  translate the English word 'better'."""@en ;
  curric:correction """'Meilleur' is an adjective and can only be used to describe nouns. 'Mieux' is
  an adverb and can only be used to describe verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157572Z"^^xsd:dateTime .

oakcurric:misconception-agreement-needed-avoir-verb-past
  a curric:Misconception ;
  curric:statement """There is no agreement needed with 'avoir' verb past participles in the passive
  voice."""@en ;
  curric:correction """Because the passive voice uses 'être', all past participles used must agree
  in number and gender with the noun subject, including 'avoir' verbs. E.g. La fille est
  choisie par le réalisateur."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157578Z"^^xsd:dateTime .

oakcurric:misconception-french-word-questions
  a curric:Misconception ;
  curric:statement "In French there is a word for 'do/does' in yes/no questions."@en ;
  curric:correction """The English verb 'do/does' isn't translated directly into French when asking
  a yes/no question. Instead, use intonation, inversion or 'est-ce que' to ask yes/no
  questions, e.g. 'Aimes-tu les réseaux sociaux ?' - 'Do you like social media?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157624Z"^^xsd:dateTime .

oakcurric:misconception-saying-french-separate-word-needed
  a curric:Misconception ;
  curric:statement """When saying what you will do in French, a separate word is needed for
  'will'."""@en ;
  curric:correction """The simple future in French is a simple tense because it is made of one word.
  The idea of 'will' is created through the correct verb stem and ending. Most -er verbs use
  the infinitive as stem for the simple future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157638Z"^^xsd:dateTime .

oakcurric:misconception-conditional-used-its-own-without
  a curric:Misconception ;
  curric:statement """The conditional can always be used on its own without a prior conditional
  being described."""@en ;
  curric:correction """Apart from the verbs 'aimer' and 'vouloir', always use the conditional form
  of verb with a 'si' + imperfect sentence. It is not logical to say in French 'I would buy
  a villa' without an accompanying condition e.g. if I had lots of money."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157646Z"^^xsd:dateTime .

oakcurric:misconception-separate-word-needs-translated-french
  a curric:Misconception ;
  curric:statement """A separate word for 'will' and 'would' needs to be translated into French when
  using future or conditional verbs."""@en ;
  curric:correction """The 1-verb future and conditional verb forms express 'will' and 'would' in
  their spellings. No separate word is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157657Z"^^xsd:dateTime .

oakcurric:misconception-say-am-french-use-present
  a curric:Misconception ;
  curric:statement """To say 'I am doing' in French, use the present tense of 'être' as part of the
  verb phrase."""@en ;
  curric:correction """There is only one present tense in French. It translates both simple present
  and present continuous in English. To say 'I am doing' use the French for 'I do' ('je
  fais')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157752Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronoun-noun-required-using
  a curric:Misconception ;
  curric:statement "A subject pronoun or noun is always required when using a verb in French."@en ;
  curric:correction """When using the imperative, neither subject pronoun nor noun is required.
  Match the spelling of the verb to the person or people who are being instructed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157767Z"^^xsd:dateTime .

oakcurric:misconception-saying-plus-pronounce-s
  a curric:Misconception ;
  curric:statement "When saying 'plus' always pronounce the 's'."@en ;
  curric:correction """'Plus' can mean 'plus' or 'more'. Then, the 's' should be pronounced.
  However, 'plus' can also mean 'no longer' as part of the negative phrase 'ne ... plus'.
  When used in this way, the 's' is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157996Z"^^xsd:dateTime .

oakcurric:misconception-nous-means-french
  a curric:Misconception ;
  curric:statement "'Nous' always means 'we' in French."@en ;
  curric:correction """'Nous' means 'we' when used as a subject pronoun. 'Nous' means 'us' when used
  as an emphatic pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158002Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-translated-happened-french
  a curric:Misconception ;
  curric:statement "The perfect tense can only be translated as what happened in French."@en ;
  curric:correction """The perfect tense refers to the past in two ways: what happened and what has
  happened. Context tells us the intended meaning. 'Hier, je suis allé en ville' - yesterday
  I went to town. 'Je suis déjà allé à Paris' - I have already been to Paris."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158207Z"^^xsd:dateTime .

oakcurric:misconception-isnt-important-answer-bullet-points
  a curric:Misconception ;
  curric:statement """It isn't important to answer both bullet points in the longer writing task
  equally."""@en ;
  curric:correction """Students should plan carefully to address both bullet points in an equal
  manner, giving detailed answers and using a rich selection of language. Using the BORDER
  acronym helps students to fully answer the task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158458Z"^^xsd:dateTime .

oakcurric:misconception-english-phrase-am-going-translated
  a curric:Misconception ;
  curric:statement "The English phrase 'I am going' is translated as 'je suis' + 'aller'."@en ;
  curric:correction """'I am going' can only be translated as 'je vais' in French. This is
  particularly important for students to understand when using the future structure 'aller'
  + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158470Z"^^xsd:dateTime .

oakcurric:misconception-preposition-used-mean-cities-countries
  a curric:Misconception ;
  curric:statement """The preposition 'à' is used to mean 'to' or 'in' for both cities and
  countries."""@en ;
  curric:correction """Prepositions can be tricky to master. Students must practise them carefully
  and thoroughly. Use 'à' before a city or town. Use 'en' before a feminine country or
  region. Use 'au' before a masculine country or region and 'aux' before a plural country."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158478Z"^^xsd:dateTime .

oakcurric:misconception-french-internet-linternet
  a curric:Misconception ;
  curric:statement "The French for 'the Internet' is 'l'Internet'."@en ;
  curric:correction """In common usage, the Internet is translated as 'internet' in French. It does
  not require a capital letter as it counts as a common noun. It is one of very few common
  nouns that doesn't require a determiner in common usage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158861Z"^^xsd:dateTime .

oakcurric:misconception-negative-structure-ne-personne-used
  a curric:Misconception ;
  curric:statement """The negative structure 'ne ... personne' is used in the same way as 'ne ...
  pas' and 'ne ... jamais' in the perfect tense."""@en ;
  curric:correction """'Personne' goes after the past participle instead of after the auxiliary
  verb. Careful study and practice is required to master this structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158866Z"^^xsd:dateTime .

oakcurric:misconception-direct-translation-french-english-verbs
  a curric:Misconception ;
  curric:statement """There is a direct translation in French of the English verbs 'must'
  and 'can'."""@en ;
  curric:correction """The idea of 'must' is conveyed by the verb 'devoir' (to have to do
  something). 'Can' is expressed with 'pouvoir' (to be able to do something)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159010Z"^^xsd:dateTime .

oakcurric:misconception-verbs-de-e-g-persuader
  a curric:Misconception ;
  curric:statement """Verbs with 'de' e.g. 'persuader de', 'conseiller de' do not need to be
  followed by a second verb in its infinitive form."""@en ;
  curric:correction """All French verbs with 'de' are always followed by a second verb in its
  infinitive form. There may be a preposition or an object pronoun between the two verbs but
  a second verb in its infinitive form will always follow."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159019Z"^^xsd:dateTime .

oakcurric:misconception-elle-means-elles-means-naming
  a curric:Misconception ;
  curric:statement """'Elle' only means 'she' and 'elles' only means 'they', when naming a group of
  girls or women."""@en ;
  curric:correction """When used as emphatic pronouns, 'elle' means 'her' and 'elles' means
  'them'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159178Z"^^xsd:dateTime .

oakcurric:misconception-sentences-such-little-shopping-my
  a curric:Misconception ;
  curric:statement """Sentences such as 'when I was little, I would do the shopping with my mother'
  can be translated by using both the imperfect tense and the conditional mood."""@en ;
  curric:correction """In French, when writing or translating sentences about what used to happen,
  all verbs should be in the imperfect tense. 'Used to' and 'would' (meaning habitually) are
  translated by the imperfect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159388Z"^^xsd:dateTime .

oakcurric:misconception-acronym-palm-used-help-structure
  a curric:Misconception ;
  curric:statement """In the acronym PALM used to help structure a response to a picture, M for Mood
  only includes how people are feeling."""@en ;
  curric:correction """In PALM, Mood can be both people's emotions and the surrounding conditions,
  such as weather, time of day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159659Z"^^xsd:dateTime .

oakcurric:misconception-er-verbs-use-infinitive-stem
  a curric:Misconception ;
  curric:statement "All -er verbs use the infinitive as the stem for the simple future tense."@en ;
  curric:correction """Some -er verbs require a small change to the stem before adding the correct
  simple future ending, for example 'acheter', 'compléter' and 'protéger'. For each verb,
  the first -e changes to -è."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159664Z"^^xsd:dateTime .

oakcurric:misconception-changing-positive-negative-statement-words
  a curric:Misconception ;
  curric:statement """When changing a positive to a negative statement, words like 'un', 'une',
  'du', 'de la' and 'des' stay the same, e.g. 'je mange du gateau' - 'je ne mange pas du
  gâteau'."""@en ;
  curric:correction """When making a sentence negative, 'un', 'une', 'du', 'de la' and 'des' change
  to 'de', e.g. 'je mange du gâteau' - 'je ne mange pas de gâteau'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159670Z"^^xsd:dateTime .

oakcurric:misconception-letter-combinations-en-pronounced-differently
  a curric:Misconception ;
  curric:statement """The letter combinations [en] and [an] are pronounced differently in
  French."""@en ;
  curric:correction """The letter combinations [en] and [an] make the same sound in French, as can
  be heard in the word 'enfant'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159801Z"^^xsd:dateTime .

oakcurric:misconception-speaking-writing-regularly-past-use
  a curric:Misconception ;
  curric:statement """When speaking or writing about what you did regularly in the past, use the
  perfect tense to state the action of the sentence."""@en ;
  curric:correction """When speaking or writing about what you did regularly in the past, use the
  imperfect tense to state the action. This is because you are talking about something that
  didn't have a clear start and end point. Perfect tense is not appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159807Z"^^xsd:dateTime .

oakcurric:misconception-french-stress-placed-first-syllable
  a curric:Misconception ;
  curric:statement """In French, the stress is placed on the first syllable of a word, like in
  English."""@en ;
  curric:correction """In French, the stress is ususally placed on the final syllable of a word,
  although stress is not as strong in French as it is in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159812Z"^^xsd:dateTime .

oakcurric:misconception-way-form-singular-feminine-noun
  a curric:Misconception ;
  curric:statement """The only way to form the singular of a feminine noun is to add -e. The only
  way to form the plural of a noun is to add -s."""@en ;
  curric:correction """There are 4 ways to form feminine nouns which need careful practice.
  Similarly, there is more than one way to form plural nouns depending upon the final letter
  of the singular noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159905Z"^^xsd:dateTime .

oakcurric:misconception-distinct-words-required-french-translate
  a curric:Misconception ;
  curric:statement """There are distinct words required in French to translate 'will' and
  'would'."""@en ;
  curric:correction """The 1-verb future tense describes 'will + verb'. The conditional describes
  'would + verb'. Students should be aware that both verb forms are 'simple' forms as all
  the meaning is contained within a single word."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159918Z"^^xsd:dateTime .

oakcurric:misconception-separate-word-french-talking-future
  a curric:Misconception ;
  curric:statement """There is a separate word for 'will' in French when talking about the
  future."""@en ;
  curric:correction """The spelling of a verb in the 1-verb future form contains the idea of 'will'
  + verb e.g. il visitera = he will visit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160344Z"^^xsd:dateTime .

oakcurric:misconception-superlative-french-goes-noun-describes
  a curric:Misconception ;
  curric:statement """The superlative in French always goes before the noun it describes, like in
  English."""@en ;
  curric:correction """Superlatives may go before or after the noun they describe. The rule that
  applies is BRAGS - if an adjective goes before the noun according to the BRAGS rule, its
  superlative form will also go before the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160578Z"^^xsd:dateTime .

oakcurric:misconception-tre-used-translate-phrase-used
  a curric:Misconception ;
  curric:statement "'Être' is used to translate the phrase 'there used to be'."@en ;
  curric:correction """Although in English, 'there used to be' has the idea of 'being', this is not
  the case in French. The phrase 'il y a' means there is but the verb is 'a' which comes
  from 'avoir'. It's the same with 'there used to be' - 'il y avait'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160869Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-required-performing-photo
  a curric:Misconception ;
  curric:statement """Only the present tense is required when performing the photo
  description task."""@en ;
  curric:correction """The present tense will mostly be used to describe a photo; however, other
  tenses are required for the follow-up questions based on the topic of the photo. Students
  should be able to use future and conditional verbs to discuss future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161451Z"^^xsd:dateTime .

oakcurric:misconception-talking-hungry-thirsty-right-wrong
  a curric:Misconception ;
  curric:statement """When talking about being hungry, thirsty, right, wrong or afraid, use 'être'
  as the verb."""@en ;
  curric:correction """In French, ideas like being hungry and thirsty are expressed using 'avoir'
  plus a noun. In French, 'j'ai faim' is correct. It translates literally as 'I have
  hunger'. Ideas like being thirsty and afraid are expressed the same way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161559Z"^^xsd:dateTime .

oakcurric:misconception-french-separate-word-used-infinitive
  a curric:Misconception ;
  curric:statement """In French, there is a separate word for 'would' that is used with an
  infinitive to express what someone 'would' do."""@en ;
  curric:correction """The conditional form of verbs expresses 'would' + verb e.g. je visiterais - I
  would visit. There is no word for 'would' in French."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161603Z"^^xsd:dateTime .

oakcurric:misconception-use-present-tense-si-conditional
  a curric:Misconception ;
  curric:statement """Use the present tense after 'si' and before the conditional to say what you
  would do."""@en ;
  curric:correction """French uses the combination of 'si' + imperfect + conditional to express what
  would happen if a certain condition occurred e.g. If I won the lottery, I would move to
  France."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161633Z"^^xsd:dateTime .

oakcurric:misconception-near-future-future-tenses-used
  a curric:Misconception ;
  curric:statement "Only the near future and future tenses can be used to refer fo the future."@en ;
  curric:correction """It is possible to refer to the future using the conditional mood: phrases
  like 'je voudrais' and 'il voudrait' which are followed by an infinitive. This creates the
  idea of what someone would like to do, clearly referring to possible future events."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161770Z"^^xsd:dateTime .

oakcurric:misconception-french-separate-word
  a curric:Misconception ;
  curric:statement "In French, there is a separate word for 'would'."@en ;
  curric:correction """The conditional verb form expresses the idea of 'would + verb' in its
  spelling. Students should be encouraged to used the conditional form of verbs instead of
  being over reliant on 'vouloir' in the conditional."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161776Z"^^xsd:dateTime .

oakcurric:misconception-verbs-french-end-er-ir
  a curric:Misconception ;
  curric:statement "All verbs in French end in -er, -ir or -re."@en ;
  curric:correction """Only infinitive verbs end in -er, -ir, or -re. When categorising words
  according to word class in Task A, draw attention to the different verb endings and
  discuss the possible subjects of each verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162301Z"^^xsd:dateTime .

oakcurric:misconception-ir-verbs-same-verb-endings
  a curric:Misconception ;
  curric:statement "-ir verbs have the same verb endings in the present tense as -er verbs."@en ;
  curric:correction """Only verbs like 'ouvrir' have the same endings in the present tense as -er
  verbs. There are also verbs like 'choisir', verbs like 'partir' and verbs like 'venir'
  which have different endings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164695Z"^^xsd:dateTime .

oakcurric:misconception-separate-indirect-object-pronouns-french
  a curric:Misconception ;
  curric:statement """There are separate indirect object pronouns in French to replace masculine and
  feminine nouns."""@en ;
  curric:correction """French indirect object pronouns make no distinction for gender (unlike direct
  object pronouns). 'Lui' means both '(to) him' and '(to) her'. 'Leur' means '(to) them' and
  can refer to both masculine and feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164700Z"^^xsd:dateTime .

oakcurric:misconception-plusieurs-chaque-singular-plural-forms
  a curric:Misconception ;
  curric:statement "'Plusieurs' and 'chaque' have singular and plural forms."@en ;
  curric:correction """'Plusieurs' is always written with an 's' and introduces a plural noun e.g.
  plusieurs problèmes. 'Chaque' is always written in the singular and introduces a singular
  noun e.g. chaque problème."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165068Z"^^xsd:dateTime .

oakcurric:misconception-chaque-plusieurs-change-form-written
  a curric:Misconception ;
  curric:statement """'Chaque' and 'plusieurs' change form and can be written as 'chaques' and
  'plusieur'."""@en ;
  curric:correction """The indefinite adjectives 'chaque' and 'plusieurs' are invariable and only
  have the one form. As they are highly useful, encourage students to use them frequently in
  their work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165629Z"^^xsd:dateTime .

oakcurric:misconception-students-develop-their-answers-role
  a curric:Misconception ;
  curric:statement "Students should develop their answers in role play tasks."@en ;
  curric:correction """In role play tasks, students should concentrate on clearly communicating the
  stated information in a complete phrase and with conjugated verbs. There is no advantage
  to developing their answer further than is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165709Z"^^xsd:dateTime .

oakcurric:misconception-same-imperative-form-verb-used
  a curric:Misconception ;
  curric:statement "The same imperative form of a verb is used for both 'tu' and 'vous'."@en ;
  curric:correction """There are separate imperative forms for 'tu' and 'vous' which must be used in
  exactly the same way as in conversation i.e. formal or information situations and singular
  and plural subjects."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166186Z"^^xsd:dateTime .

oakcurric:misconception-re-verbs-follow-same-pattern
  a curric:Misconception ;
  curric:statement """All -re verbs follow the same pattern in the present tense, just like regular
  -er verbs."""@en ;
  curric:correction """-re verbs can be divided into four groups, following the patterns of
  entendre, prendre, traduire and écrire. Encourage learners to be able to categorise -re
  verbs and to draw comparisons between the groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166191Z"^^xsd:dateTime .

oakcurric:misconception-agent-nouns-french-end-eur
  a curric:Misconception ;
  curric:statement "All agent nouns in French end in -eur, e.g. 'joueur'."@en ;
  curric:correction """Many French agent nouns have the '-ateur' ending, for example 'consommateur',
  which means 'consumer'. This is because these agent nouns are linked to the original Latin
  forms that French has maintained today."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166278Z"^^xsd:dateTime .

oakcurric:misconception-negative-structures-go-around-short
  a curric:Misconception ;
  curric:statement """All negative structures go around the short form of the verb only in two-verb
  structures."""@en ;
  curric:correction """Most negatives, such as 'ne...pas', 'ne...jamais' and 'ne...rien', go around
  the short form of the verb in two-verb structures. 'Ne...personne', however, goes around
  both verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169265Z"^^xsd:dateTime .

oakcurric:misconception-ideas-same-translation-french
  a curric:Misconception ;
  curric:statement "The ideas 'to', 'in', 'of' always have the same translation in French."@en ;
  curric:correction """Prepositions are tricky to master in another language. Students should be
  given plenty of practice of 'à', 'en' and 'de' to see how their use varies according to
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169340Z"^^xsd:dateTime .

oakcurric:misconception-indefinite-partitive-articles-used-structure
  a curric:Misconception ;
  curric:statement """The indefinite and partitive articles are used with the structure 'ne ... ni
  ... ni', e.g. 'Tu n'as ni des pommes ni du fromage'."""@en ;
  curric:correction """When using 'ne ... ni ... ni', the nouns do not require an indefinite or
  partitive article, e.g. 'Tu n'as ni pommes ni fromage'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169345Z"^^xsd:dateTime .
