oakcurric:priorknowledge-2879-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the verb 'aller' in the present tense in all persons of the verb."@en ;
  dcterms:modified "2026-06-07T15:29:26.815268Z"^^xsd:dateTime .

oakcurric:priorknowledge-2879-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use aller + infinitive to express the near future."@en ;
  dcterms:modified "2026-06-07T15:29:26.815279Z"^^xsd:dateTime .

oakcurric:priorknowledge-2879-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the present tense of the verbs avoir, être and faire in all persons."@en ;
  dcterms:modified "2026-06-07T15:29:26.815284Z"^^xsd:dateTime .

oakcurric:priorknowledge-2879-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that 'avoir + noun' can be used to express the English 'Be+ adjective'
  e.g. j'ai faim."""@en ;
  dcterms:modified "2026-06-07T15:29:26.815288Z"^^xsd:dateTime .

oakcurric:priorknowledge-2879-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to use ne...pas and ne...jamais to negate sentences in all
  tenses."""@en ;
  dcterms:modified "2026-06-07T15:29:26.815293Z"^^xsd:dateTime .

oakcurric:priorknowledge-2884-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form the future tense of regular verbs like parler in all
  persons."""@en ;
  dcterms:modified "2026-06-07T15:29:26.843258Z"^^xsd:dateTime .

oakcurric:priorknowledge-2884-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form the conditional with vouloir in the 1st, 2nd and 3rd person
  singular."""@en ;
  dcterms:modified "2026-06-07T15:29:26.843269Z"^^xsd:dateTime .

oakcurric:priorknowledge-2884-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the irregular future tense forms of the verbs aller, être, faire and
  avoir."""@en ;
  dcterms:modified "2026-06-07T15:29:26.843275Z"^^xsd:dateTime .

oakcurric:priorknowledge-2884-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use 'en' with transport."@en ;
  dcterms:modified "2026-06-07T15:29:26.843279Z"^^xsd:dateTime .

oakcurric:priorknowledge-2884-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a range of word pattern rules to help them form adverbs from adjectives,
  nouns from verbs, ordinal numbers and antonyms."""@en ;
  dcterms:modified "2026-06-07T15:29:26.843284Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form the imperfect tense of regular verbs in all persons."@en ;
  dcterms:modified "2026-06-07T15:29:26.850560Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that the imperfect tense can be used to translate what we 'used
  to' do."""@en ;
  dcterms:modified "2026-06-07T15:29:26.850571Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that the imperfect can be used to describe what we 'were doing' when
  something else happened."""@en ;
  dcterms:modified "2026-06-07T15:29:26.850576Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can recognise the imperfect tense of être, avoir and faire in the 1st, 2nd
  and 3rd person singular."""@en ;
  dcterms:modified "2026-06-07T15:29:26.850581Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the emphatic pronouns moi and toi."@en ;
  dcterms:modified "2026-06-07T15:29:26.850586Z"^^xsd:dateTime .

oakcurric:priorknowledge-2878-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the prepositions sans, pour and avant."@en ;
  dcterms:modified "2026-06-07T15:29:26.850590Z"^^xsd:dateTime .

