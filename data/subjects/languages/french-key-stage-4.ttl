oakcurric:unit-2889
  a curric:Unit ;
  rdfs:label "Communication and the world around us: Révisions: En ligne"@en ;
  curric:slug "communication-and-the-world-around-us-revisions-en-ligne" ;
  rdfs:comment """This unit continues the focus on known grammar and vocabulary, with a spotlight on
  the formation of questions in a range of tenses, impersonal verbs, and modal verbs."""@en ;
  curric:whyThisWhyNow """In this unit, pupils revisit their previous knowledge in the context of
  social media and technology in everyday life. Pupils apply their knowledge across a range of
  common threads, including asking and answering spoken questions, listening and responding to
  longer passages and creating extended writing using a range of verbs in past, present and
  future tenses.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2889-1 ,
    oakcurric:priorknowledge-2889-2 ,
    oakcurric:priorknowledge-2889-3 ;
  curric:id "2889"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.305470Z"^^xsd:dateTime ;
