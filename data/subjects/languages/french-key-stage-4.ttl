    oakcurric:thread-adjectives ,
    oakcurric:thread-read-and-respond-to-texts ,
    oakcurric:thread-extend-written-and-spoken-production .

oakcurric:unit-2879
  a curric:Unit ;
  rdfs:label "Studying and my future/ Travel and Tourism: Mes projets"@en ;
  curric:slug "people-and-lifestyle-mes-projets" ;
  rdfs:comment """This unit contrasts the near future (aller + infinitive) with the simple future of
  regular and common irregular verbs. In addition there is a focus on negation, introducing
  ne...plus and ne ...pas encore, and a revisit of the use of avoir + noun where the English
  equivalent is 'BE + adjective'."""@en ;
  curric:whyThisWhyNow """This unit builds upon knowledge of the near future, taught at KS3, and
  introduces the simple future tense, enabling pupils to talk about immediate and distant
  future plans. Within this grammatical context, pupils learn to express plans for study and
  travel, and plan a trip to Marche des Fiertés; here pupils are able to explore the subject of
  identity within the context of a cultural event. Pupils extend their knowledge of negative
  structures to express negative statements with far more subtlety, distinguishing between not,
  never, nothing, no longer and not yet, and apply these in all tenses.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2879-1 ,
    oakcurric:priorknowledge-2879-2 ,
    oakcurric:priorknowledge-2879-3 ,
    oakcurric:priorknowledge-2879-4 ,
    oakcurric:priorknowledge-2879-5 ;
  curric:id "2879"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.815318Z"^^xsd:dateTime ;
