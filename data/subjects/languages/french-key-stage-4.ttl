    oakcurric:thread-extend-written-and-spoken-production .

oakcurric:unit-2884
  a curric:Unit ;
  rdfs:label "Communication and the world around us: À l'avenir"@en ;
  curric:slug "studying-and-my-future-a-lavenir" ;
  rdfs:comment """This unit is firmly set in the future in a range of different contexts. It
  revisits the use of the simple future tense and the conditional with vouloir, alongside
  introducing the conditional forms of regular -er verbs and of the four most common
  irregular verbs: aller, être, faire and avoir."""@en ;
  curric:whyThisWhyNow """Prior learning about future plans from the KS4 course is revisited and
  built upon in this unit, as pupils learn to embrace the conditional mood and combine it with
  their use of the simple future and the conditional with vouloir. They will explore future
  plans related to family and relationships, places to live, and travel, learning to talk about
  others as well as themselves. Being able to use the future and conditional, in addition to
  the present and past tenses, are key skills at KS4 and this unit offers plentiful
  opportunities to embed this knowledge.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2884-1 ,
    oakcurric:priorknowledge-2884-2 ,
    oakcurric:priorknowledge-2884-3 ,
    oakcurric:priorknowledge-2884-4 ,
    oakcurric:priorknowledge-2884-5 ;
  curric:id "2884"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.843308Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-languages-key-stage-4 ;
  curric:includesThread
