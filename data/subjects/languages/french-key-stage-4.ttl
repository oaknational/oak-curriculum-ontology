oakcurric:unit-3641
  a curric:Unit ;
  rdfs:label "People and lifestyle: Faire de bons choix"@en ;
  curric:slug "people-and-lifestyle-faire-de-bons-choix" ;
  rdfs:comment """In this unit pupils apply previous knowledge of irregular verbs, impersonal verbs,
  indefinite adjectives, interrogative adjectives and demonstrative adjectives. They will
  also meet personne ne...+ verb, rien ne...+ verb and the negative adjective determiner
  aucun."""@en ;
  curric:whyThisWhyNow """This unit revisits grammar essential to all at KS4, whilst also
  challenging with the introduction of complex structures such as negative subject pronouns.
  Pupils learn these in the context of health and lifestyle matters, describing health issues
  in the present, offering suggestions for exercise or dietary improvement using impersonal
  verbs, and using the negative pronouns and adjectives to talk about others. In addition
  pupils will think about their own lifestyle choices for a healthy future. Pupils will be able
  to write comprehensively using a range of tenses and grammatical structures.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-3641-1 ,
    oakcurric:priorknowledge-3641-2 ,
    oakcurric:priorknowledge-3641-3 ,
    oakcurric:priorknowledge-3641-4 ,
    oakcurric:priorknowledge-3641-5 ;
  curric:id "3641"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.755829Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-languages-key-stage-4 ;
