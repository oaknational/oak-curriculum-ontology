# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-25599-1
  a curric:KeyLearningPoint ;
  rdfs:label """You should answer role-play prompts with a short phrase or sentence. Do not add
  unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25599-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm understanding of sound-spelling correspondences to
  accurately read aloud in French."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25599-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the PALM acronym to structure photo descriptions."@en ;
  dcterms:modified "2026-06-07T15:30:28.998929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25599-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the conversation following the photo description, you should aim to develop
  answers using at least 3 verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:28.998934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21657-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct object pronouns are: me, te, le/la/l', nous, vous, les. They go before the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21657-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word for 'it' in French changes according to whether the noun it replaces is
  masculine or feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21657-3
  a curric:KeyLearningPoint ;
  rdfs:label """When 'you' (singular formal or plural) is the 'receiver' (object) of the verb, we
  use vous. It goes before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21657-4
  a curric:KeyLearningPoint ;
  rdfs:label """When 'us' and 'them' are the 'receivers' (object) of the verb, we use nous
  and les."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25531-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some regular present participles are: partant, venant, ouvrant, choisissant,
  entendant, prenant, connaissant, écrivant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25531-2
  a curric:KeyLearningPoint ;
  rdfs:label """The present participle of faire is 'faisant'; 'faisant de' + noun means making
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25531-3
  a curric:KeyLearningPoint ;
  rdfs:label "The irregular present participles of être and avoir are 'étant' and 'ayant'."@en ;
  dcterms:modified "2026-06-07T15:30:29.002155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25531-4
  a curric:KeyLearningPoint ;
  rdfs:label """Extended reading texts can be exploited to enrich our thematic vocabulary and use of
  complex structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most final consonants and final letter 'e' are silent, [-er/-ez/-é] all make the
  same sound and [on] is a nasal sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21630-2
  a curric:KeyLearningPoint ;
  rdfs:label """-er verbs take the following endings in the present tense: je-e, tu-es,
  il/elle/on-e, nous-ons, vous-ez, ils/elles-ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21630-3
  a curric:KeyLearningPoint ;
  rdfs:label """'on' can mean 'we' or you/people and 'vous' can be informal plural as well as
  formal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21630-4
  a curric:KeyLearningPoint ;
  rdfs:label """'il(s)' and 'elle(s)' can be used for things (as well as people) and mean 'it' or
  'they'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21630-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two-verb constructions with 'aimer' are used to say what we like doing."@en ;
  dcterms:modified "2026-06-07T15:30:29.002535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21681-1
  a curric:KeyLearningPoint ;
  rdfs:label "[en/an] sound like 'enfant', [è] sounds like 'tête' and [i] sounds like 'midi'."@en ;
  dcterms:modified "2026-06-07T15:30:29.003076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some adverbs are formed by adding -ment to the feminine form of adjectives when the
  English adverb equivalent is -ly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21681-3
  a curric:KeyLearningPoint ;
  rdfs:label """Where the adjective ends in e in the masculine form, add -ment to form the adverb
  e.g. rapide - rapidement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21681-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some adverbs are formed by dropping -ant(e)/-ent (e) and adding -(am)ment/-(em)ment
  when the English equivalent is -ly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21691-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperative is used to tell somebody to do something, give commands and
  advice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21691-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperative is the ‘tu’, ‘nous’ and ‘vous’ present tense verb; for -er verbs, it
  is the ‘tu’ form minus the -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21691-3
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun is not used e.g. Parle ! Negative elements go around the
  imperative verb e.g. Ne parle pas !"""@en ;
  dcterms:modified "2026-06-07T15:30:29.004456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21691-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to distinguish between informal (tu) and formal (vous) situations
  when using the imperative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21648-1
  a curric:KeyLearningPoint ;
  rdfs:label """To replace a noun that is the object, use direct object pronouns le/la/l' before the
  verb to mean 'him', 'her' or 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21648-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to pay attention to the gender of a noun when replacing it with a
  direct object pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21648-3
  a curric:KeyLearningPoint ;
  rdfs:label """[c] is soft before e, i and y or if it has a cedilla [ç]: merci, ça va. Before all
  other letters [c] is a hard sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21648-4
  a curric:KeyLearningPoint ;
  rdfs:label """[ch] sounds like 'sh' in the word 'shoe', e.g. chien, charmant. [t] before -ion
  makes a soft [c] sound, e.g. attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21671-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense, the imperfect tense and the present tense can be usefully
  combined to describe family events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a checklist for range of language to use can enhance the quality of
  extended writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21671-3
  a curric:KeyLearningPoint ;
  rdfs:label "Creating a checklist for accuracy can enhance the quality of extended writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.004524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21696-1
  a curric:KeyLearningPoint ;
  rdfs:label """An impersonal verb is a verb and subject that don't refer to a particular person or
  thing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21696-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say what time it is use impersonal verb il est + number + heure (s) +
  minutes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Il est + adjective + de + infinitive can be used to express it is
  difficult/easy/forbidden to + a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Il fait (with weather expressions), il y a (there is/are) and il faut (it is
  necessary) are useful impersonal verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21696-5
  a curric:KeyLearningPoint ;
  rdfs:label "[y] and [i] sounds like 'midi' and 'physique'."@en ;
  dcterms:modified "2026-06-07T15:30:29.004942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25532-1
  a curric:KeyLearningPoint ;
  rdfs:label """To make adjectives feminine add -e, change -x to -se, -el to -elle, -en to -enne, -f
  to -ve, -er to -ère, or no change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25532-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form plural adjectives we add -s, unless the adjective ends in -x or -s. -al and
  -eau change to -aux and -eaux."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25532-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make comparisons in French we use 'plus ... que', 'moins ... que' and 'aussi ...
  que' with adjectives and adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21664-1
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that is 'in the process of' happening, we can use 'être en
  train de' + infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21664-2
  a curric:KeyLearningPoint ;
  rdfs:label """The phrase 'être en train de' is usually translated using the -ing form of the verb
  in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21664-3
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that has just happened, we can use 'venir de' +
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21664-4
  a curric:KeyLearningPoint ;
  rdfs:label """The English past participle translates the French infinitive when using 'venir de' +
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27601-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nasal vowel sounds occur when one or more vowels precede a nasal consonant, e.g. an,
  un, ain, on, en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27601-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a nasal sound such as [an] is followed by a vowel, it is no longer a nasal
  sound, e.g. 'aucune'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27601-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ne ... aucun' is a negative structure meaning 'not any' or 'no' before a singular
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27601-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Aucun/aucune' must agree in gender with the noun it refers to."@en ;
  dcterms:modified "2026-06-07T15:30:29.251276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21661-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Depuis' can mean 'since' or 'for' in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.251280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21661-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something that started in the past but continues today, we use the
  present tense + 'depuis'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21661-3
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [ui] in 'depuis' sounds like 'huit'."@en ;
  dcterms:modified "2026-06-07T15:30:29.251290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21661-4
  a curric:KeyLearningPoint ;
  rdfs:label """It's important to pay attention to French sounds and pronunciation rules such as
  liaison as you read aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21653-1
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of verbs like ouvrir become ouvert, e.g. je découvre in the
  perfect tense becomes j'ai découvert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21653-2
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of verbs like traduire become traduit, e.g. tu détruis in the
  perfect tense becomes tu as détruit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21653-3
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of verbs like écrire become écrit, e.g. elle décrit becomes in
  the perfect tense elle a décrit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21653-4
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles used with être must agree in gender and number with the subject of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25582-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of French sounds (SSCs) in order to
  accurately transcribe spoken French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25582-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen out for synonyms and distractors when answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29159-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a broad vocabulary to be successful at answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29159-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen out for synonyms and distractors when answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25539-1
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives agree in number and sometimes gender with the thing that is
  owned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25539-2
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive pronouns can replace a possessive adjective + noun. Start with a definite
  article e.g. le mien, la mienne."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25539-3
  a curric:KeyLearningPoint ;
  rdfs:label """Moi, toi, lui, elle, nous, vous, eux, elles are used to mean me, you, him, her, us,
  you and them as emphatic pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25539-4
  a curric:KeyLearningPoint ;
  rdfs:label """An open [o] is pronounced as in 'porte' and a closed [o/ô] is pronounced as in
  'photo'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21699-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to describe what was happening or what you were doing
  when something else happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21699-2
  a curric:KeyLearningPoint ;
  rdfs:label """For imperfect of regular verbs remove -ons from 'nous' present tense and add: -ais,
  -ais, -ait, -ions, -iez, -aient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21699-3
  a curric:KeyLearningPoint ;
  rdfs:label """[ai] sounds like 'vrai', [on] is a nasal sound like 'non', and [ez] sounds like
  'écrire'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21752-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperative only exists in second person singular (tu), second person plural
  (vous), and first person plural (nous)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21752-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 'tu' form of the imperative is the same as the present tense 'je' form; er verbs
  end with -e, other verbs with -s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21752-3
  a curric:KeyLearningPoint ;
  rdfs:label """When giving directions or instructions to a friend, use the informal imperative ‘tu’
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21752-4
  a curric:KeyLearningPoint ;
  rdfs:label "[oi] sounds like 'trois' and [oy] sounds like 'envoyer'."@en ;
  dcterms:modified "2026-06-07T15:30:29.252416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21752-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Être’ is irregular in the imperative. The 'tu' form is 'sois' and the 'vous' form
  is 'soyez'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29409-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many cognates in this topic which can be used to infer meaning of
  surrounding words and understand context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29409-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading texts can be exploited to enrich our vocabulary on current issues."@en ;
  dcterms:modified "2026-06-07T15:30:29.252912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29409-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates may look very similar to English but sound quite different so attention
  must be paid to pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21689-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being able to ask questions in different tenses, as well as answer them, is key to
  successful communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21689-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using qui, que, où and quand in relative clauses provides more information and adds
  complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21689-3
  a curric:KeyLearningPoint ;
  rdfs:label """[qu] sounds like 'question' or 'quatre', [en/an] sound like 'enfant' and [e] sounds
  like 'je'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25517-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'jouer à' to talk about playing sports and 'jouer de' to talk about playing
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25517-2
  a curric:KeyLearningPoint ;
  rdfs:label """'À' combines with 'le'/'les' to form 'au'/'aux' and 'de' combines with 'le'/'les' to
  form 'du'/'des.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.253170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25517-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'x' at the end of 'aux' creates liaison before a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.253175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25517-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs require 'à' or 'de' before an infinitive, e.g. 'aider à',
  'arrêter de'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21667-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gender and number determine the  words for 'a', 'the' and 'some' in French."@en ;
  dcterms:modified "2026-06-07T15:30:29.253689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21667-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Un, une' (indefinite article) describe ‘whole’ things, and 'du, de la, de l’'
  (partitive article) ‘parts’ of things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use possessive adjectives (mon, ma, mes, ton, ta, tes, son, sa, ses, notre, etc)
  with nouns to say who things belong to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21667-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a final [s] or [n] is followed by a vowel, a liaison is created and we hear the
  [s] or [n]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening and reading texts can be exploited to enrich our topic-specific
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27631-2
  a curric:KeyLearningPoint ;
  rdfs:label """Listening and reading texts can be exploited to enrich our use of complex
  structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27631-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to include rich and specific vocabulary when presenting arguments
  for or against something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29156-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of French SSCs in order to accurately
  transcribe spoken French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21678-1
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] is pronounced as in 'deux', [oi] as in 'voir', and [ou] as in 'nous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.254390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21678-2
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what you can, know how to, have to, or want to do, use modal verbs:
  pouvoir, savoir, devoir, vouloir."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21678-3
  a curric:KeyLearningPoint ;
  rdfs:label "If modal verbs are followed by another verb it must be in the infinitive form."@en ;
  dcterms:modified "2026-06-07T15:30:29.254399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21678-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'pouvoir' to talk about ability or permission; use 'savoir' to talk about skills
  or things you have learned to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21697-1
  a curric:KeyLearningPoint ;
  rdfs:label """t- liaison is common after impersonal verbs il est, il faut so it's important to
  look out for vowels following these."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21697-2
  a curric:KeyLearningPoint ;
  rdfs:label """il est + adjective + de + infinitive can be used to express it is
  difficult/easy/forbidden to + a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21697-3
  a curric:KeyLearningPoint ;
  rdfs:label """Impersonal verbs il vaut mieux (it's better) and il vaut la peine de (it's worth)
  are followed by the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Impersonal verb 'il manque' is used with a noun to express that something 'is
  missing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29144-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of French sounds (SSCs) in order to
  accurately transcribe spoken French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29144-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen out for synonyms and distractors when answering listening
  comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25536-1
  a curric:KeyLearningPoint ;
  rdfs:label """[eu] is pronounced closed as in 'deux' and [eu/œu] is pronounced open as in 'cœur',
  and [r] is pronounced as in 'rue'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25536-2
  a curric:KeyLearningPoint ;
  rdfs:label """An agent noun is a noun describing a person or object doing the action of a
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25536-3
  a curric:KeyLearningPoint ;
  rdfs:label """Agent nouns can be created by adding -eur or -ateur to the verb stem, e.g.
  'consommer' - 'consommateur'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25529-1
  a curric:KeyLearningPoint ;
  rdfs:label "The three infinitive endings in French are -er, -ir and -re."@en ;
  dcterms:modified "2026-06-07T15:30:29.256248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25529-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular verbs follow a common and consistent pattern when conjugated."@en ;
  dcterms:modified "2026-06-07T15:30:29.256252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25529-3
  a curric:KeyLearningPoint ;
  rdfs:label """The four groups of -re verbs are: verbs like 'entendre', like 'prendre', like
  'traduire' and verbs like 'écrire'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25529-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Connaitre' is conjugated in the present tense as: connais, connais, connait,
  connaissons, connaissez, connaissent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21683-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pre-rehearsal, focusing on range of language and accuracy of pronunciation, improves
  performance in speaking tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being able to apply word patterns, such as creating antonyms or adverbs from
  adjectives, expands our vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21683-3
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to texts and identifying sound-spelling links is crucial to good
  pronunciation of trickier sounds e.g. im/in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25564-1
  a curric:KeyLearningPoint ;
  rdfs:label "The passive is used to say what is done to someone or something."@en ;
  dcterms:modified "2026-06-07T15:30:29.256652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25564-2
  a curric:KeyLearningPoint ;
  rdfs:label """The passive is formed using part of 'être' and a past participle. The participle
  must agree with the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25564-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Par' (by) is used to say who or what the action is being done by."@en ;
  dcterms:modified "2026-06-07T15:30:29.256660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21658-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns met are: me, te, lui, and vous. They replace the indirect
  receiver of the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21658-2
  a curric:KeyLearningPoint ;
  rdfs:label """When somebody or something receives the action of a verb indirectly, we use me to
  mean ‘to me’ and te to mean ‘to you’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21658-3
  a curric:KeyLearningPoint ;
  rdfs:label """When somebody or something receives the action of a verb indirectly, we use lui to
  mean ‘to him’ or ‘to her’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21658-4
  a curric:KeyLearningPoint ;
  rdfs:label """An [-s] which is normally an SFC will be pronounced when followed by a vowel. This
  is called liaison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27599-1
  a curric:KeyLearningPoint ;
  rdfs:label "[-ien] is pronounced as in 'bien'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Negative subject pronouns act as the subject of a sentence and carry a negative
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27599-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Personne ne' and 'rien ne' are always followed by a verb in the il/elle/on
  form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use a range of strategies to prepare for read aloud tasks like mental rehearsal and
  noticing cognates or tricky sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21693-1
  a curric:KeyLearningPoint ;
  rdfs:label """Connaitre is conjugated as follows in the present tense: connais, connais, connait,
  connaissons, connaissez, connaissent"""@en ;
  dcterms:modified "2026-06-07T15:30:29.256770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21693-2
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs like connaitre are disparaitre, apparaitre, paraitre, naitre."@en ;
  dcterms:modified "2026-06-07T15:30:29.256774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21693-3
  a curric:KeyLearningPoint ;
  rdfs:label """An [o] sound can be open, as in 'porte', or closed, as in 'photo'. An [ô] is a
  closed sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21694-1
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of most verbs like connaitre are formed with a 'u' ending e.g.
  connu, disparu, paru."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21694-2
  a curric:KeyLearningPoint ;
  rdfs:label "The past participle of 'naitre' is 'né(e)(s)'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles used with être must agree in gender and number with the subject of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21694-4
  a curric:KeyLearningPoint ;
  rdfs:label "[u] sounds like 'tu' and [é] sounds like 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use me and te when 'me' or 'you' is indirectly receiving the action of the verb:
  elle me donne un cadeau (gives to me)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21647-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct and indirect object pronouns are very useful when expressing opinions: 'ça me
  surprend', 'l'idée m'intéresse' ..."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21647-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some museums in France and other countries which had colonies are taking steps to
  decolonise their exhibitions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21665-1
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitives used as nouns, en train de and venir de can be combined in discussion
  about issues such as climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Care must be taken when translating infinitives as nouns, venir de and en train de
  into English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reading texts can be exploited to enrich our vocabulary on challenging and current
  issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21665-4
  a curric:KeyLearningPoint ;
  rdfs:label """Immediate repetition of a speaking task, with reduced support, improves
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27597-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs voir (to see), boire (to drink), croire (to believe) and faire (to do,
  make) are irregular in the present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27597-2
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronouns 'il' and 'elle' can be used for things as well as people, and
  can be translated as 'it' ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27597-3
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun 'on' can be translated as 'we', 'you', 'one' or can refer to
  people in general."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27597-4
  a curric:KeyLearningPoint ;
  rdfs:label "'avoir mal' is followed by the preposition 'à' and a body part."@en ;
  dcterms:modified "2026-06-07T15:30:29.257207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive pronouns are: 'me', 'te', 'se', 'nous', 'vous', 'se'. They precede the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25575-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb parts of regular reflexive verbs are conjugated in the same way as regular
  -er, -ir and -re verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive verbs form the perfect tense with 'être' and past participles must
  agree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25575-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Cannes film festival is one of Europe's biggest film festivals."@en ;
  dcterms:modified "2026-06-07T15:30:29.257696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21701-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to describe what you 'used to' do and what 'was
  happening' or you 'were doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21701-2
  a curric:KeyLearningPoint ;
  rdfs:label """When translating the imperfect tense, think carefully about which English meaning
  would make most sense for the context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21701-3
  a curric:KeyLearningPoint ;
  rdfs:label """Combining the imperfect tense and the present tense is a useful way to contrast past
  and present activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25535-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs can sometimes be created from adjectives, and nouns and adjectives can
  sometimes be created from verb stems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25535-2
  a curric:KeyLearningPoint ;
  rdfs:label """[i] is pronounced as in 'midi', [on] is pronounced as in 'non !' and [tion] is
  pronounced as in 'attention !'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25535-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns can sometimes be created by adding -ion or -ation to the verb stem, e.g.
  'manifester' - 'manifestation'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25540-1
  a curric:KeyLearningPoint ;
  rdfs:label """Including a range of direct object, indirect object and emphatic pronouns and
  possessive adjectives adds complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25540-2
  a curric:KeyLearningPoint ;
  rdfs:label "When describing a picture mention: people, action, location, mood and season."@en ;
  dcterms:modified "2026-06-07T15:30:29.257791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25540-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to listen carefully for question type and tense in conversation
  questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25538-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use possessive adjectives with nouns to say who things belong to."@en ;
  dcterms:modified "2026-06-07T15:30:29.258030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25538-2
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an '-s' or '-n' at the end of a possessive, and a vowel follows,
  liaison occurs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25538-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct object pronouns are: 'me', 'te', 'le', 'la', 'l'', 'nous', 'vous', 'les'.
  They go before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25538-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns are: 'me', 'te', 'lui', 'nous', 'vous', 'leur'. They go
  before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21662-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense and present tense + 'depuis' can usefully be combined to talk
  about completed and ongoing events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21662-2
  a curric:KeyLearningPoint ;
  rdfs:label "[e] sounds like 'je' and [ui] sounds like 'huit'."@en ;
  dcterms:modified "2026-06-07T15:30:29.258431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21662-3
  a curric:KeyLearningPoint ;
  rdfs:label """When talking or writing about someone else, change pronouns, verbs and possessive
  adjectives from first to third person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21662-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to carefully plan use of tenses when creating a longer text."@en ;
  dcterms:modified "2026-06-07T15:30:29.258438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25600-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of French SSCs in order to accurately
  transcribe spoken French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25563-1
  a curric:KeyLearningPoint ;
  rdfs:label "The past participles of -er verbs like 'parler' end in -é."@en ;
  dcterms:modified "2026-06-07T15:30:29.258787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25563-2
  a curric:KeyLearningPoint ;
  rdfs:label "The past participles of -re verbs like 'entendre' end in -u."@en ;
  dcterms:modified "2026-06-07T15:30:29.258791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25563-3
  a curric:KeyLearningPoint ;
  rdfs:label "The past participles of -ir verbs like 'choisir' end in -i."@en ;
  dcterms:modified "2026-06-07T15:30:29.258795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25563-4
  a curric:KeyLearningPoint ;
  rdfs:label """[é] is pronounced as in 'écrire', [u] is pronounced as in 'tu' and [i] is pronounced
  as in 'midi'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21649-1
  a curric:KeyLearningPoint ;
  rdfs:label """When someone or something receives the action of a verb indirectly, use 'lui' to
  mean 'to him/her': 'je lui parle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21649-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the indirect receiver of the action of the verb is formal 'you', use 'vous' to
  mean 'to you': 'elle vous parle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns are also used after verbs followed by 'à', e.g., 'il lui
  parle, nous vous téléphonons'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21700-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to describe what you 'used to' do when you were
  younger/in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21700-2
  a curric:KeyLearningPoint ;
  rdfs:label """For imperfect of regular verbs remove -ons from 'nous' present tense and add:-ais,
  -ais, -ait, -ions, -iez, -aient"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21700-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most final consonants are silent, and this is important in imperfect verb endings
  e.g. -ais, -ait"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21682-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ordinal numbers are created by (removing -e and) adding -ième to a number: deuxième,
  onzième."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21682-2
  a curric:KeyLearningPoint ;
  rdfs:label """in- or im- can be added to adjectives, adverbs or nouns to give the opposite
  meaning. English equivalent is un- or in-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21682-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter [x] can be heard before a vowel. This is called liaison and is common in
  ordinal numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21682-4
  a curric:KeyLearningPoint ;
  rdfs:label "[in] sounds like 'train' and [im] sounds like 'faim': incorrect, impossible."@en ;
  dcterms:modified "2026-06-07T15:30:29.259285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21650-1
  a curric:KeyLearningPoint ;
  rdfs:label """The direct object pronouns are: me, te, le/la/l', nous, vous, les. They precede the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21650-2
  a curric:KeyLearningPoint ;
  rdfs:label """The indirect object pronouns met are: me, te, lui, & vous. They replace the indirect
  receiver of the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Indirect object pronouns also precede the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.259299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21650-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although 'me' and 'te' are both direct and indirect object pronouns, their meanings
  can be different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use me and te when 'me' or 'you' is indirectly receiving the action of the verb:
  elle me donne un cadeau (gives to me)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21646-2
  a curric:KeyLearningPoint ;
  rdfs:label "Me and te are used frequently in dialogue between two people."@en ;
  dcterms:modified "2026-06-07T15:30:29.259625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21646-3
  a curric:KeyLearningPoint ;
  rdfs:label """[gn] is pronounced like 'ligne', [th] like 'thé', j like [jour] and [r] like
  'rue'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21646-4
  a curric:KeyLearningPoint ;
  rdfs:label """When transcribing, use your knowledge of French sounds to carefully write down what
  you hear. Check spelling carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21645-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use me and te before the verb when 'me' or 'you' is the object of the verb: elle me
  trouve (she finds me)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use me and te when 'me' or 'you' is indirectly receiving the action of the verb:
  elle me donne un cadeau (gives to me)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21645-3
  a curric:KeyLearningPoint ;
  rdfs:label "Me and te are used frequently in dialogue between two people."@en ;
  dcterms:modified "2026-06-07T15:30:29.260531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25573-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed by combining part of 'avoir' or 'être' (the auxiliary
  verb) and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25573-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'prendre' and 'entendre' in the present also form their past participles
  in the same way: pris, entendu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25573-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like choisir, partir, venir in the present also form their past participles in
  the same way: choisi, parti, venu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25573-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'traduire' and 'écrire' form their past participles in the same way:
  traduit, écrit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some common irregular verbs and their past participles are: avoir (eu), faire
  (fait), boire (bu)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25533-1
  a curric:KeyLearningPoint ;
  rdfs:label """Present participles can be used as adjectives to describe a noun. e.g. 'une victoire
  surprenante'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25533-2
  a curric:KeyLearningPoint ;
  rdfs:label """As adjectives, present participles agree in number and gender with the noun they are
  describing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25533-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some comparative adjective forms are irregular: 'bon' becomes 'meilleur' (better)
  and 'mauvais' becomes 'pire' (worse)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25533-4
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives describe something as the best, the most or the least e.g: le/la/les +
  plus/moins + adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25533-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some superlative forms are irregular: le/la/les + meilleur(e) (s) = the best;
  le/la/les + pire(s) = the worst."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29134-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed by combining part of 'avoir' or 'être' (the auxiliary
  verb) and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29134-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'prendre' and 'entendre' in the present also form their past participles
  in the same way: 'pris', 'entendu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29134-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like choisir, partir, venir in the present also form their past participles in
  the same way: choisi, parti, venu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29134-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'traduire' and 'écrire' form their past participles in the same way:
  'traduit', 'écrit'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29134-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some common irregular verbs and their past participles are: 'avoir' ('eu'), 'faire'
  ('fait'), 'boire' ('bu')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21698-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of impersonal verbs to your writing and speaking adds variety and
  complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21698-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plan a speaking task answer carefully, pre-rehearse, and immediately repeat the task
  to improve performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21698-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a speaking scenario involves talking to a single friend, use the 'tu' form of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21695-1
  a curric:KeyLearningPoint ;
  rdfs:label """Extended reading texts can be exploited to enrich our vocabulary and use of complex
  structures in familiar topics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21695-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to plan the use of tenses and the inclusion of regular and irregular
  verbs when creating a longer text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21695-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use of reference sources can help to create a personal response."@en ;
  dcterms:modified "2026-06-07T15:30:29.261989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21695-4
  a curric:KeyLearningPoint ;
  rdfs:label """One present tense in French translates the simple present and the present
  continuous; important when describing a photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21695-5
  a curric:KeyLearningPoint ;
  rdfs:label """Careful planning, pre-rehearsal and immediate repetition help to improve performance
  in speaking tasks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21643-1
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object pronoun replaces a noun that is the object of the verb. It comes
  before the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21643-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use 'vous' for the singular formal 'you' direct object pronoun: il vous aide (he
  helps you)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21643-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plural direct object pronouns are nous (us), vous (you) and les (them) e.g. elle
  nous aide (she helps us)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21643-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a negative sentence, the direct object goes after ne and before the verb: je ne
  le vends pas (I don't sell it)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25528-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using the imperative in conversation enables the speaker to give instructions and
  advice, or to make suggestions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25528-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play it's important to work out whether you will be addressed as ‘vous’
  (formal) or ‘tu’ (informal)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25528-3
  a curric:KeyLearningPoint ;
  rdfs:label """You need to use the correct 'please': 's'il vous plait' in a formal setting, and
  's'il te plait' for a friend."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21637-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in a consonant + -re(s) stress the vowel before the consonant and the
  -r is said very softly e.g. 'ouvres'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21637-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Il y a un/une/des' is used to say ‘there is’ or ‘there are’. The article agrees
  with the gender and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21637-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'there isn't' or 'there aren't' we use il n'y a pas. After this, all articles
  change to de or d' before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21640-1
  a curric:KeyLearningPoint ;
  rdfs:label """When the next word begins with a vowel, -s and -t are pronounced, rather than being
  silent final consonants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add a 't' in an inversion question when the verb ends in a vowel and the pronoun
  begins in a vowel: A-t-il une voiture?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.263180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21640-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say what doesn't happen, we use ne...pas around the verb. To say what never
  happens, use ne...jamais."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21640-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use jouer à to talk about playing sports and jouer de to talk about playing
  instruments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21640-5
  a curric:KeyLearningPoint ;
  rdfs:label """À combines with le/les to form au/aux and de combines with le/les to form
  du/des."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21692-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperative is used in a wide range of scenarios such as recipe instructions, job
  adverts and giving commands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the imperative in conversation enables the speaker to give instructions and
  advice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21692-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play scenario it is important to consider who you are talking to, and
  whether to use the 'tu' or 'vous' form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a speaking task answer carefully, pre-rehearsal, and immediate repetition
  of the task improve performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29150-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use your knowledge of French sounds to carefully write down what you hear. Check
  spelling carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29150-2
  a curric:KeyLearningPoint ;
  rdfs:label """After dictation, use your knowledge of grammar to check what you've written makes
  sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before you listen, use the English title and words provided to predict which French
  words you might hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29136-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive pronouns are: 'me', 'te', 'se', 'nous', 'vous', 'se'. They precede the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29136-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb parts of regular reflexive verbs are conjugated in the same way as regular
  -er, -ir and -re verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29136-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive verbs form the perfect tense with 'être' and past participles must
  agree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29136-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Cannes film festival is one of Europe's biggest film festivals."@en ;
  dcterms:modified "2026-06-07T15:30:29.266786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21663-1
  a curric:KeyLearningPoint ;
  rdfs:label "[é], [er], and [ez] all sound like 'écrire'."@en ;
  dcterms:modified "2026-06-07T15:30:29.267142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21663-2
  a curric:KeyLearningPoint ;
  rdfs:label "An infinitive can be used as the subject of a sentence to express an activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.267145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21663-3
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive functions like a noun in such sentences: ‘être poli, c’est important’
  - 'being polite is important'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21663-4
  a curric:KeyLearningPoint ;
  rdfs:label """We normally translate French infinitives used as nouns with the -ing form of the
  verb in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25523-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening and reading texts can be exploited to enrich our topic-specific
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25523-2
  a curric:KeyLearningPoint ;
  rdfs:label "France and other Francophone countries are religiously diverse."@en ;
  dcterms:modified "2026-06-07T15:30:29.267478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates may look very similar to English but sound quite different so attention
  must be paid to pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25523-4
  a curric:KeyLearningPoint ;
  rdfs:label """Time adverbials and verb forms can be used to distinguish between past, present and
  future actions and events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25574-1
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs which express a change of state, place or condition often use être as the
  auxiliary verb in the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25574-2
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles used with être must agree in gender and number with the subject of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25574-3
  a curric:KeyLearningPoint ;
  rdfs:label """A well-developed or extended response in conversation has at least three verb
  clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25519-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns replace the person, people or thing(s) that the verb action
  is done to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25519-2
  a curric:KeyLearningPoint ;
  rdfs:label "The singular indirect object pronouns are: me, te, lui, and vous."@en ;
  dcterms:modified "2026-06-07T15:30:29.281288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25519-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'e' in me/te sounds like the 'e' in 'cheval'; the 'ui' in lui like 'huit' and
  the [ou] in vous sounds like 'nous'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25519-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns precede the conjugated verb. In the perfect tense, they
  precede both parts of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21652-1
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs which express a change of state, place or condition often use 'être' as the
  auxiliary verb in the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles used with 'être' must agree in gender and number with the subject
  of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21652-3
  a curric:KeyLearningPoint ;
  rdfs:label """[i] like 'midi', [u] like 'tu' and [é/ez/er] like 'écrire', SFC and SFE are common
  endings to past participles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21670-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many adjectives also function as nouns when preceded by a definite article (le, la,
  les)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21670-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is common to hear adjectives used as nouns to mean ''the [adjective] one'' e.g Je
  veux la verte!"""@en ;
  dcterms:modified "2026-06-07T15:30:29.309520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives that come before the noun fit into five categories: BRAGS (Beauty, Rank,
  Age, Good/Bad and Size/quantity)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21684-1
  a curric:KeyLearningPoint ;
  rdfs:label """To ask perfect tense questions using question words, add question word before the
  inverted auxiliary verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21684-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use interrogative adjectives quel, quelle, quels, quelles to ask 'which?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.311610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21684-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use demonstrative adjectives ce, cet, cette, ces to mean 'this/that/those' They
  often answer the question 'which?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21684-4
  a curric:KeyLearningPoint ;
  rdfs:label "[qu] sounds like 'question' or 'quatre'. [c/ç] sound like 'ici'."@en ;
  dcterms:modified "2026-06-07T15:30:29.311619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21679-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound [ai] sounds like 'vrai'."@en ;
  dcterms:modified "2026-06-07T15:30:29.312832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21679-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs state necessity or possibility and are commonly followed by a second
  verb as an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21679-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb vouloir can be used in the conditional to express a wish. It can be
  followed by a noun or an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21679-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st, 2nd, 3rd person forms of vouloir in the conditional all sound the same: je
  voudrais, tu voudrais, il voudrait."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25530-1
  a curric:KeyLearningPoint ;
  rdfs:label """Diversity in Morocco's language, culture, and food is a result of blending Berber,
  Arab, French and Spanish influences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25530-2
  a curric:KeyLearningPoint ;
  rdfs:label """Four groups of -ir verbs are: verbs like 'choisir', verbs like 'partir', verbs like
  'venir' and verbs like 'ouvrir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25530-3
  a curric:KeyLearningPoint ;
  rdfs:label """For present participles, remove -ons from the present tense 'nous' form and add
  -ant: 'écrire '- écrivons' - 'écrivant'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25530-4
  a curric:KeyLearningPoint ;
  rdfs:label """'En' + present participle can be used when two actions happen together, e.g. 'il
  prépare le dîner en chantant'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25522-1
  a curric:KeyLearningPoint ;
  rdfs:label """An indirect object pronoun replaces the person, people or thing(s) that the verb
  action is done to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25522-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct and indirect object pronouns avoid repetition of nouns and add
  sophistication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25522-3
  a curric:KeyLearningPoint ;
  rdfs:label """Object pronouns can be used in your speaking, e.g. when describing a photo, or in
  your writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25522-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is interesting and useful to know about some popular customs and celebrations in
  different Francophone countries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21687-1
  a curric:KeyLearningPoint ;
  rdfs:label """Questions are formed by subject-verb inversion, adding est-ce que or intonation.
  Question words can be added to start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21687-2
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause provides more information about a noun or pronoun from the
  previous clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Qui means 'who?' in a question, but it also means 'who', 'which', or 'that' in the
  middle of a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27598-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Il est', 'il fait', 'il y a' and 'il faut' are common impersonal verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.317138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Impersonal verbs are usually only used with the pronoun 'il'."@en ;
  dcterms:modified "2026-06-07T15:30:29.317143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27598-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Il est' + adjective + 'de' + infinitive can be used to express 'it is
  difficult/easy/forbidden to' + a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Impersonal verbs 'valoir mieux' ('to be better') and 'valoir la peine de' ('to be
  worth') are followed by an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21655-1
  a curric:KeyLearningPoint ;
  rdfs:label """[on] and [om] are nasal sounds but become non-nasal before a vowel or when part of a
  double consonant: [onne] or [omme]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21655-2
  a curric:KeyLearningPoint ;
  rdfs:label """ne ... rien, like ne ... pas and ne ... jamais, wraps around the auxiliary verb in
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21655-3
  a curric:KeyLearningPoint ;
  rdfs:label """ne ... personne is different to other negatives in the past tense. Personne comes
  after the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21655-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sports successful in francophone nations include skiing, football, tennis, swimming,
  judo and ice dancing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29142-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combining the perfect tense and the present tense is a useful way to contrast past
  and present activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29142-2
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, it's important to pay attention to the gender and number of nouns
  and alter endings accordingly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29142-3
  a curric:KeyLearningPoint ;
  rdfs:label """In conversation, it is useful to combine tenses when giving an answer to develop the
  conversation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21722-1
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite articles (un, une, des) and partitive articles (du, de la, de l', des)
  change to 'de' after a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21722-2
  a curric:KeyLearningPoint ;
  rdfs:label "[i] sounds like midi."@en ;
  dcterms:modified "2026-06-07T15:30:29.322761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21722-3
  a curric:KeyLearningPoint ;
  rdfs:label "The negative structure 'ne ... ni ... ni ...' means 'neither ... nor'."@en ;
  dcterms:modified "2026-06-07T15:30:29.322765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21686-1
  a curric:KeyLearningPoint ;
  rdfs:label """[au/eau] sounds like 'gauche', [ou] sounds like 'nous', [u] sounds like 'tu', [ch]
  sounds like 'chercher'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Extended reading texts can be exploited to enrich our vocabulary and use of complex
  structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writing task instructions must be read carefully and answers planned to ensure
  coverage of all the main points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21639-1
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no questions can be formed by raising the intonation at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21639-2
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no questions can be formed by inversion, which means swapping the position of
  the subject and the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no questions can also be formed by adding est-ce que to a statement. Est-ce que
  becomes est-ce qu' before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21639-4
  a curric:KeyLearningPoint ;
  rdfs:label "In French there is no word for 'do/does' in yes/no questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.329663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use reflexive pronouns (me, te, se...) before the verb when subject and object of
  the verb are the same person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs use reflexive pronouns in French when their English translation doesn't
  include a reflexive idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21642-3
  a curric:KeyLearningPoint ;
  rdfs:label """To replace a noun that is the object, use direct object pronouns le/la/l' before the
  verb to mean 'him', 'her' or 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21642-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct object pronouns are positioned before the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.329682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21642-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive pronouns me, te and se are shortened to m', t' and s' before a vowel or
  silent 'h'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21654-1
  a curric:KeyLearningPoint ;
  rdfs:label """Yes/no questions in the past tense are formed by inversion, asking 'est-ce que' or
  using intonation, as in the present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21654-2
  a curric:KeyLearningPoint ;
  rdfs:label """To negate in the perfect tense, put 'ne' and 'pas/jamais' around the auxiliary verb
  (part of 'avoir' or 'être')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21654-3
  a curric:KeyLearningPoint ;
  rdfs:label """T-liaison is common in inversion questions in the perfect tense, e.g., 'A-t-il gagné
  ?'. This eases pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21654-4
  a curric:KeyLearningPoint ;
  rdfs:label """When transcribing, it's important to think about liaison and where one word ends and
  another begins."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25555-1
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to describe what 'was happening' or what you 'were
  doing' when something else happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form the imperfect by removing -ons from 'nous' present tense and adding:-ais, -ais,
  -ait, -ions, -iez, -aient"""@en ;
  dcterms:modified "2026-06-07T15:30:29.336907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25555-3
  a curric:KeyLearningPoint ;
  rdfs:label """Où and quand can be used in relative clauses to detail where or when something was
  happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25555-4
  a curric:KeyLearningPoint ;
  rdfs:label """For 'neither...nor', ne precedes the verb and each ni precedes one of the negated
  qualities/nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25555-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ne ... que means 'only'. 'Que' follows the verb and precedes the noun that is
  limited."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25562-1
  a curric:KeyLearningPoint ;
  rdfs:label """Including structures such as avant de + infinitive and après avoir + past participle
  enhances complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25562-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates help us understand the context of longer texts. Be aware of 'false friends'
  which don't carry the same meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pay attention to 'little words' when translating into French, e.g. avant must be
  followed by 'de' before the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Account for every word when translating from French, but remember there might be a
  different number of words in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25561-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Après avoir' is used with a past participle to translate the English 'after doing'
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25561-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the verb takes 'être' in the perfect tense, use 'après être' instead of 'après
  avoir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25561-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the verb used takes 'être' in the perfect tense, the past participle must agree
  with the subject of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25561-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reflexive verbs place the reflexive pronoun in front of 'être'."@en ;
  dcterms:modified "2026-06-07T15:30:29.341517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21651-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed by combining part of 'avoir' or 'être' (the auxiliary
  verb) and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21651-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'prendre' and 'entendre' in the present form their past participles in
  the same way: 'pris', 'entendu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21651-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like choisir, partir and venir in the present form their past participles in
  the same way: choisi, parti, venu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Three common irregular verbs and their past participles are: 'avoir' (eu), 'faire'
  (fait), 'boire' (bu)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21636-1
  a curric:KeyLearningPoint ;
  rdfs:label """All syllables are sounded fairly equally in French words, but there is usually a
  slight emphasis on the last syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21636-2
  a curric:KeyLearningPoint ;
  rdfs:label """-ir verbs like ouvrir have the same present tense verb endings as regular -er verbs:
  e, es, e, ons, ez, ent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21636-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pronouns 'ils' and 'elles', meaning 'they', can refer to people or things."@en ;
  dcterms:modified "2026-06-07T15:30:29.347309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21636-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pronoun 'vous', meaning 'you', can refer to one person (formally) or more than
  one person (formally or informally)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21636-5
  a curric:KeyLearningPoint ;
  rdfs:label """Context and surrounding lanuage clarify the correct meaning of ils, elles
  and vous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed by combining part of 'avoir' or 'être' (the auxiliary
  verb) and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25554-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Qui' means ‘who?’ in a question, but it is the relative pronoun ‘who’, ‘which’, ‘or
  ‘that’ in the middle of a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25554-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the relative pronoun relates to the object of the sentence, we use 'que'
  (who/whom, that or which), not 'qui'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25554-4
  a curric:KeyLearningPoint ;
  rdfs:label """In most negative phrases in the perfect tense, the negative structure goes around
  the part of 'avoir' or 'être'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25560-1
  a curric:KeyLearningPoint ;
  rdfs:label """[j] sounds like 'jour', [th] sounds like 'thé', [gn] sounds like 'ligne' and [h]
  sounds like 'heure.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.347609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25560-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Sans' ('without') and 'pour' ('for') are prepositions which can be followed
  immediately by the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25560-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Avant' ('before') is followed by 'de' and the infinitive, and is translated as
  'before doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25559-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding modal verbs to your written and spoken work broadens communication and adds
  complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25559-2
  a curric:KeyLearningPoint ;
  rdfs:label """The irregular past participles of the four modal verbs are: dû, pu, voulu
  and su."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25559-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to practise moving between present and past tense modals e.g je peux-
  j'ai pu; je veux- j'ai voulu."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25551-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use reflexive pronouns (me, te, se ...) before the verb when subject and object of
  the verb are the same person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25551-2
  a curric:KeyLearningPoint ;
  rdfs:label "[e] is pronounced as in 'je' and [ou] is pronounced as in 'nous'."@en ;
  dcterms:modified "2026-06-07T15:30:29.348651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25551-3
  a curric:KeyLearningPoint ;
  rdfs:label """The singular reflexive pronouns are: 'me', 'te', 'se'. They are shortened to m', t'
  and s' before a silent letter/vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25551-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plural reflexive pronouns are: 'nous', 'vous', 'se'. 'Se' is shortened to s'
  before a vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25583-1
  a curric:KeyLearningPoint ;
  rdfs:label """An infinitive can be used as the subject of a sentence to express an activity. It
  works like a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25583-2
  a curric:KeyLearningPoint ;
  rdfs:label """We normally translate infinitives as nouns using the -ing form of the verb in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25583-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conditional has the same stem as the future tense and the same endings as the
  imperfect, e.g. 'j'aimerais'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25583-4
  a curric:KeyLearningPoint ;
  rdfs:label """The future and the conditional can be usefully combined to express plans and hopes
  for the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29155-1
  a curric:KeyLearningPoint ;
  rdfs:label """You should answer role-play prompts with a short phrase or sentence. Do not add
  unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29155-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm understanding of sound-spelling correspondences to
  accurately read aloud in French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29155-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the PALM acronym to structure photo descriptions."@en ;
  dcterms:modified "2026-06-07T15:30:29.354223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29155-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the conversation following the photo description, you should aim to develop
  answers using at least 3 verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use le/la/les (definite articles) to mean 'the' and un/une/des (indefinite articles)
  to mean 'a' or 'some' in plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29137-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use un/une (indefinite article) to describe 'whole' things, and du/de la/de l'
  (partitive article) for 'parts' of things"""@en ;
  dcterms:modified "2026-06-07T15:30:29.354255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29137-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indefinite articles (un, une, des) and partitive articles (du, de la, de l', des)
  change to 'de' after a negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29137-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is used to describe what 'was happening' or what you 'were
  doing' or what you 'used to' do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29137-5
  a curric:KeyLearningPoint ;
  rdfs:label """Quebec is the largest of the thirteen provinces of Canada and its official language
  is French."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25588-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use your knowledge of French sounds to carefully write down what you hear. Check
  spelling carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25588-2
  a curric:KeyLearningPoint ;
  rdfs:label """After dictation, use your knowledge of grammar to check what you've written makes
  sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before you listen, use the English title and words provided to predict which French
  words you might hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29140-1
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause provides more information about a noun from the previous clause
  without beginning a new sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29140-2
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses can be formed using 'qui', 'que', 'quand' and 'où'."@en ;
  dcterms:modified "2026-06-07T15:30:29.354447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29140-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the perfect tense and imperfect tense together enables us to express ongoing
  and isolated events in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29140-4
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25604-1
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29143-1
  a curric:KeyLearningPoint ;
  rdfs:label """To form the 2-verb future, use part of the verb 'aller' in the present tense plus
  the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29143-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conjugate the 1-verb future of -er verbs by adding the endings -ai, -as, -a, -ons,
  -ez, -ont to the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29143-3
  a curric:KeyLearningPoint ;
  rdfs:label """The future stems for ‘aller’, ‘avoir’, ‘être’ and ‘faire’ are: ir-, aur-, ser- and
  fer-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29143-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs require 'à' or 'de' before an infinitive, e.g. 'arriver à',
  'éviter de'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29145-1
  a curric:KeyLearningPoint ;
  rdfs:label """An infinitive can be used as the subject of a sentence to express an activity. It
  works like a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29145-2
  a curric:KeyLearningPoint ;
  rdfs:label """We normally translate infinitives as nouns using the -ing form of the verb in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29145-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conditional has the same stem as the future tense and the same endings as the
  imperfect, e.g. 'j'aimerais'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29145-4
  a curric:KeyLearningPoint ;
  rdfs:label """The future and the conditional can be usefully combined to express plans and hopes
  for the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29160-1
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29141-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are 4 ways to turn a masculine noun into a feminine noun: add an e, change
  article, -n to -nne, -eur to -rice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29141-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a masculine noun ends in -e, there's no change for feminine; if it ends in -s or
  -x, there's no change for plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29141-3
  a curric:KeyLearningPoint ;
  rdfs:label """We usually make nouns plural by adding -s. Nouns ending in -eu, -(e)au, or -al make
  their plurals with -x."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355954Z"^^xsd:dateTime .

