    oakcurric:thread-listen-and-respond-to-longer-passages ,
    oakcurric:thread-questions ,
    oakcurric:thread-read-and-respond-to-texts ,
    oakcurric:thread-extend-written-and-spoken-production .

oakcurric:unit-2878
  a curric:Unit ;
  rdfs:label "My neighbourhood: Là où j'habite"@en ;
  curric:slug "communication-and-the-world-around-us-la-ou-jhabite" ;
  rdfs:comment """This unit develops knowledge of the imperfect tense by focusing on the irregular
  verbs avoir, être and faire. The prepositions sans, pour and avant are also revisited,
  along with the use of emphatic pronouns (such as moi, toi, lui) after prepositions."""@en ;
  curric:whyThisWhyNow """This unit continues the focus on the imperfect tense, broadening its use
  to new contexts and incorporating irregular verbs alongside regular verbs. Pupils learn to
  talk about changes in their town over time, contrasting past and present, before moving on to
  compare life in different countries. Pupils are exposed to a range of listening activities
  and reading texts to widen their vocabulary and their cultural knowledge. They learn to
  describe photos in detail, which is a vital skill for examination at KS4, and to write longer
  descriptive texts.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2878-1 ,
    oakcurric:priorknowledge-2878-2 ,
    oakcurric:priorknowledge-2878-3 ,
    oakcurric:priorknowledge-2878-4 ,
    oakcurric:priorknowledge-2878-5 ,
    oakcurric:priorknowledge-2878-6 ;
  curric:id "2878"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.850616Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-languages-key-stage-4 ;
  curric:includesThread
    oakcurric:thread-the-past ,
    oakcurric:thread-nouns-and-determiners ,
    oakcurric:thread-adjectives ,
    oakcurric:thread-listen-and-respond-to-longer-passages ,
    oakcurric:thread-read-and-respond-to-texts ,
    oakcurric:thread-extend-written-and-spoken-production .

