    oakcurric:thread-the-present ,
    oakcurric:thread-negation ,
    oakcurric:thread-the-future-and-conditional ,
    oakcurric:thread-adjectives .

oakcurric:unit-2871
  a curric:Unit ;
  rdfs:label "Lifestyle and wellbeing: Des personnalités francophones"@en ;
  curric:slug "popular-culture-des-personnalites-francophones" ;
  rdfs:comment """This unit focuses on communicating in the perfect tense, revisiting regular and
  irregular past participle formation, verbs with être and past participle agreement. Pupils
  will meet the past participles of verbs like ouvrir, écrire and traduire, and revisit
  perfect tense questions and negation."""@en ;
  curric:whyThisWhyNow """In this unit pupils will secure and further develop their knowledge of the
  perfect tense, communicating within the new contexts of Francophone writing and sport. Having
  already revisited the present tense, pupils now ensure mastery of the perfect tense,
  essential for successful communication at KS4. They will respond to perfect tense texts and
  extend their own written and spoken production in this tense, whilst expanding their cultural
  knowledge of Francophone countries and personalities.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2871-1 ,
    oakcurric:priorknowledge-2871-2 ,
    oakcurric:priorknowledge-2871-3 ,
    oakcurric:priorknowledge-2871-4 ,
    oakcurric:priorknowledge-2871-5 ,
    oakcurric:priorknowledge-2871-6 ;
  curric:id "2871"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.784442Z"^^xsd:dateTime ;
