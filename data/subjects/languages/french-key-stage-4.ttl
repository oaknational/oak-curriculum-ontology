# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-imperfect-tense
  a curric:Keyword ;
  schema:name "imperfect tense"@en ;
  schema:description "tense used to describe how things were or used to be in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.347280Z"^^xsd:dateTime .

oakcurric:keyword-sound-symbol-correspondence
  a curric:Keyword ;
  schema:name "sound-symbol correspondence"@en ;
  schema:description "relationship between letters and their sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.347335Z"^^xsd:dateTime .

oakcurric:keyword-palm
  a curric:Keyword ;
  schema:name "PALM"@en ;
  schema:description """acronym for photo description (people and objects, action, location,
  mood)"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347340Z"^^xsd:dateTime .

oakcurric:keyword-verb-clause
  a curric:Keyword ;
  schema:name "verb clause"@en ;
  schema:description "a piece of information that contains a subject and a verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.347348Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-simple-present
  a curric:Keyword ;
  schema:name "simple present"@en ;
  schema:description "verb tense used to express habitual events in the present e.g. 'I do'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347450Z"^^xsd:dateTime .

oakcurric:keyword-irregular-verb
  a curric:Keyword ;
  schema:name "irregular verb"@en ;
  schema:description "a verb that does not follow the regular rules"@en ;
  dcterms:modified "2026-06-07T15:30:02.347466Z"^^xsd:dateTime .

oakcurric:keyword-idiom
  a curric:Keyword ;
  schema:name "idiom"@en ;
  schema:description """a phrase or expression whose meaning we don't translate word-for-word, e.g.
  'it's raining cats and dogs'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347478Z"^^xsd:dateTime .

oakcurric:keyword-adjective
  a curric:Keyword ;
  schema:name "adjective"@en ;
  schema:description "describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.348100Z"^^xsd:dateTime .

oakcurric:keyword-noun
  a curric:Keyword ;
  schema:name "noun"@en ;
  schema:description "a naming word for people, places or things"@en ;
  dcterms:modified "2026-06-07T15:30:02.348107Z"^^xsd:dateTime .

oakcurric:keyword-verb
  a curric:Keyword ;
  schema:name "verb"@en ;
  schema:description "a doing, being or having word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348112Z"^^xsd:dateTime .

oakcurric:keyword-auxiliary-verb
  a curric:Keyword ;
  schema:name "auxiliary verb"@en ;
  schema:description "the helping verb that is always paired with the main verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348256Z"^^xsd:dateTime .

oakcurric:keyword-synonym
  a curric:Keyword ;
  schema:name "synonym"@en ;
  schema:description "a word that has the same or similar meaning to another word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348296Z"^^xsd:dateTime .

oakcurric:keyword-passive-voice
  a curric:Keyword ;
  schema:name "passive voice"@en ;
  schema:description "a spoken or written voice in which the subject is acted upon by the verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348337Z"^^xsd:dateTime .

oakcurric:keyword-adverb
  a curric:Keyword ;
  schema:name "adverb"@en ;
  schema:description "describes a verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348399Z"^^xsd:dateTime .

oakcurric:keyword-perfect-tense
  a curric:Keyword ;
  schema:name "perfect tense"@en ;
  schema:description """2-verb tense that describes completed actions in the past e.g., 'I said',
  'she played'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348412Z"^^xsd:dateTime .

oakcurric:keyword-first-person
  a curric:Keyword ;
  schema:name "first person"@en ;
  schema:description """the point of view where the narrator of the story is the ‘I’ character,
  providing a personal account of events or experiences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348459Z"^^xsd:dateTime .

oakcurric:keyword-prendre
  a curric:Keyword ;
  schema:name "prendre"@en ;
  schema:description "French -re verb meaning 'to take'"@en ;
  dcterms:modified "2026-06-07T15:30:02.348514Z"^^xsd:dateTime .

oakcurric:keyword-possessive-adjective
  a curric:Keyword ;
  schema:name "possessive adjective"@en ;
  schema:description "shows who something belongs to"@en ;
  dcterms:modified "2026-06-07T15:30:02.348725Z"^^xsd:dateTime .

oakcurric:keyword-distractor
  a curric:Keyword ;
  schema:name "distractor"@en ;
  schema:description """incorrect but plausible answer option in reading and listening tasks,
  designed to test your attention to detail"""@en ;
