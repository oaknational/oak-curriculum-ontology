oakcurric:priorknowledge-3494-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar to describing
  photos."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091549Z"^^xsd:dateTime .

oakcurric:priorknowledge-3494-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar to transcribing
  language and listening comprehension."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091567Z"^^xsd:dateTime .

oakcurric:priorknowledge-3494-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar in translation
  and free writing."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091574Z"^^xsd:dateTime .

oakcurric:priorknowledge-3494-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar in role-play and
  conversation practice."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091580Z"^^xsd:dateTime .

oakcurric:priorknowledge-3494-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar to longer
  written answers."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091587Z"^^xsd:dateTime .

oakcurric:priorknowledge-3494-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can apply their knowledge of phonics, vocabulary and grammar to understanding
  a range of reading texts."""@en ;
  dcterms:modified "2026-06-07T15:29:23.091593Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use direct object pronouns in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.460681Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use indirect object pronouns in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.460692Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form the perfect tense using an auxiliary verb (avoir or être)
  and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:29:23.460698Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form past participles of verbs like prendre, choisir, entendre,
  partir, venir, ouvrir, écrire and traduire."""@en ;
  dcterms:modified "2026-06-07T15:29:23.460703Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know to form questions using intonation, inversion and by using est-ce que in
  the perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.460709Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use negation in the perfect tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.460713Z"^^xsd:dateTime .

oakcurric:priorknowledge-2872-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that the perfect tense can be used as the equivalent of the present
  perfect."""@en ;
  dcterms:modified "2026-06-07T15:29:23.460717Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all subject pronouns: je, tu, il(s), elle(s), on, nous and vous."@en ;
  dcterms:modified "2026-06-07T15:29:23.469178Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to conjugate regular verbs in the present tense in all persons."@en ;
  dcterms:modified "2026-06-07T15:29:23.469194Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form the informal and formal imperative of regular verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.469201Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that adjectives agree in gender and number with the noun they are
  describing."""@en ;
  dcterms:modified "2026-06-07T15:29:23.469207Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form comparative adjectives and adverbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.469212Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the possessive adjectives: mon/ma/mes, ton/ta/tes, son/sa/ses,
  notre/nos, votre/vos, and leur/leurs."""@en ;
  dcterms:modified "2026-06-07T15:29:23.469216Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know to position direct and indirect object pronouns before the verb."@en ;
  dcterms:modified "2026-06-07T15:29:23.469221Z"^^xsd:dateTime .

oakcurric:priorknowledge-2883-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can recognise the emphatic pronouns: moi, toi, lui, elle, nous, vous, eux,
  elles."""@en ;
  dcterms:modified "2026-06-07T15:29:23.469225Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know: SSC [-er/-ez/-é], SFe (Silent Final 'e'), SFC (Silent Final Consonant),
  [on]"""@en ;
  dcterms:modified "2026-06-07T15:29:23.510625Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all persons of present tense regular -er verbs (like parler)"@en ;
  dcterms:modified "2026-06-07T15:29:23.510638Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all subject pronouns (je, tu, il(s), elle(s), on, nous, vous)"@en ;
  dcterms:modified "2026-06-07T15:29:23.510644Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know both meanings of 'on' and 'vous'"@en ;
  dcterms:modified "2026-06-07T15:29:23.510650Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use 'il(s)' and 'elle(s)' for things (as well as people)"@en ;
  dcterms:modified "2026-06-07T15:29:23.510655Z"^^xsd:dateTime .

oakcurric:priorknowledge-2868-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use two-verb constructions with aimer"@en ;
  dcterms:modified "2026-06-07T15:29:23.510660Z"^^xsd:dateTime .

oakcurric:priorknowledge-2875-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can recognise the modal verbs devoir, pouvoir, savoir and vouloir in all
  persons of the present tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.552837Z"^^xsd:dateTime .

oakcurric:priorknowledge-2875-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the 'je' form of the modal verbs devoir, pouvoir, savoir and vouloir in
  the present tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.552851Z"^^xsd:dateTime .

oakcurric:priorknowledge-2875-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that modal verbs are combined with another verb in the infinitive."@en ;
  dcterms:modified "2026-06-07T15:29:23.552858Z"^^xsd:dateTime .

oakcurric:priorknowledge-2875-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can turn adjectives into adverbs by adding -ment to the feminine form where
  the English equivalent is -ly."""@en ;
  dcterms:modified "2026-06-07T15:29:23.552863Z"^^xsd:dateTime .

oakcurric:priorknowledge-2875-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can create ordinal numbers by (removing -e and) adding ième to numbers."@en ;
  dcterms:modified "2026-06-07T15:29:23.552869Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the question words que ?, qui ?, quand ?, où ?, comment ?, quoi ?,
  pourquoi ? and combien ?."""@en ;
  dcterms:modified "2026-06-07T15:29:23.675754Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can form questions in the present and past tense using question words,
  intonation and inversion."""@en ;
  dcterms:modified "2026-06-07T15:29:23.675767Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use the relative pronoun 'qui' in subject relative clauses."@en ;
  dcterms:modified "2026-06-07T15:29:23.675773Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the irregular verbs boire, voir and croire in the present tense singular
  forms."""@en ;
  dcterms:modified "2026-06-07T15:29:23.675779Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the irregular verb faire in all persons of the verb in the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.675784Z"^^xsd:dateTime .

oakcurric:priorknowledge-2876-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use the interrogative adjective quel (le) (es) in its different
  forms."""@en ;
  dcterms:modified "2026-06-07T15:29:23.675789Z"^^xsd:dateTime .

oakcurric:priorknowledge-2870-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all subject pronouns (je, tu, il(s), elle(s), on, nous, vous)."@en ;
  dcterms:modified "2026-06-07T15:29:23.680941Z"^^xsd:dateTime .

oakcurric:priorknowledge-2870-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know verb endings for regular -er, -re and -ir verbs in the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.680956Z"^^xsd:dateTime .

oakcurric:priorknowledge-2870-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the direct object pronouns me, te, le, la and l' and their meanings."@en ;
