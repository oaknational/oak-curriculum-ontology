  dcterms:modified "2026-06-07T15:30:29.356025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25587-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make an adjective feminine we add -e; -x → -se, -el → -elle, -en → -enne, -f →
  -ve, -er → -ère, or no change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356029Z"^^xsd:dateTime .

