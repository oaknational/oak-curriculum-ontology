oakcurric:keyword-ieren-verbs
  a curric:Keyword ;
  schema:name "-ieren verbs"@en ;
  schema:description "verbs which end in ‘ieren’; for example, 'fotografieren', 'studieren'"@en ;
  dcterms:modified "2026-06-07T15:30:02.427315Z"^^xsd:dateTime .

oakcurric:keyword-wenig-wenige
  a curric:Keyword ;
  schema:name "wenig, wenige"@en ;
  schema:description "little, few"@en ;
  dcterms:modified "2026-06-07T15:30:02.427404Z"^^xsd:dateTime .

oakcurric:keyword-simple-past-or-imperfect-tense
  a curric:Keyword ;
  schema:name "simple past or imperfect tense"@en ;
  schema:description """German single-word past tense used mainly to narrate past events in writing,
  e.g., 'war', 'hatte', 'gab', 'fand'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427425Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-like-role-play-keep-my
  a curric:Misconception ;
  curric:statement """Like in a role-play, I should keep my answers short and concise in a
  conversation."""@en ;
  curric:correction """Conversation answers should be developed and extended with at least three
  verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083849Z"^^xsd:dateTime .

oakcurric:misconception-german-w-pronounced-like-english
  a curric:Misconception ;
  curric:statement """The German [w] is pronounced like the English 'w'; the German [v] is
  pronounced like the English 'v'."""@en ;
  curric:correction """The German [w] is pronounced like the English 'v'; the German [v] is
  pronounced like the English 'f'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085095Z"^^xsd:dateTime .

oakcurric:misconception-definite-indefiniete-articles-used-same
  a curric:Misconception ;
  curric:statement """Definite and indefiniete articles are used the same way in German as in
  English."""@en ;
  curric:correction """Differences occur with some country names, some abstract nouns and
  professions: e.g., 'die Schweiz' (Switzerland), 'die Freiheit' (freedom). It's 'Er ist
  Arzt' (He is a doctor), but an article is needed before the adjective - 'Er ist ein guter
  Arzt'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085138Z"^^xsd:dateTime .

oakcurric:misconception-es-ist-means
  a curric:Misconception ;
  curric:statement "'Es ist' means 'there is'."@en ;
  curric:correction """Use 'es gibt' to translate 'there is, there are' when making a general
  statement that something exists. Use 'da ist' when referring to a particular thing in a
  particular place at a particular time; for instance, in a photograph: 'Da ist die
  Kirche.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085144Z"^^xsd:dateTime .

oakcurric:misconception-verbs-second-infinitive-need-zu
  a curric:Misconception ;
  curric:statement "All verbs with a second infinitive need 'zu'."@en ;
  curric:correction """Although some verbs do need 'zu' when used with a second verb in the
  infinitive (e.g., 'versuchen', 'planen', 'vergessen', 'hoffen'), modal verbs never use
  'zu'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085267Z"^^xsd:dateTime .

oakcurric:misconception-verbs-reflexive-english-reflexive-german
  a curric:Misconception ;
  curric:statement """Verbs that are reflexive in English must be reflexive in German and vice
  versa."""@en ;
  curric:correction """Different verbs are reflexive in different languages. For example, 'sich
  erinnern' is not reflexive in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085302Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-modal-verb-m
  a curric:Misconception ;
  curric:statement """The imperfect tense of the modal verb 'mögen' is formed like other modal
  verbs."""@en ;
  curric:correction """The stem of 'mögen' in the imperfect tense is 'moch-'. It is normally
  followed by a noun rather than a second verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085732Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-followed-either-accusative-dative
  a curric:Misconception ;
  curric:statement "All prepositions are followed by either the accusative or the dative."@en ;
  curric:correction """The prepositions ‘hinter’, ‘neben’, ‘unter’, ‘über’, ‘vor’, ‘zwischen’ and
  ‘in’ are used with the accusative case when there is movement but the dative case when
  there is no movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085835Z"^^xsd:dateTime .

oakcurric:misconception-german-subject-pronoun-man-translated
  a curric:Misconception ;
  curric:statement """The German subject pronoun 'man' must always be translated using the English
  subject pronoun 'one'."""@en ;
  curric:correction """'Man' has a range of possible translations, including 'people' and 'you'. It
  can also be used to say what 'is done' or 'was done' by people in general."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086063Z"^^xsd:dateTime .

oakcurric:misconception-verb-stems-ending-el-remove
  a curric:Misconception ;
  curric:statement """For verb stems ending in ‘-el’, remove the 'e' from the stem in all present
  tense forms."""@en ;
  curric:correction """For verb stems ending in ‘-el’, remove the 'e' from the stem in the first
  person singular of the present tense only."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086068Z"^^xsd:dateTime .

oakcurric:misconception-use-same-word-order-german
  a curric:Misconception ;
  curric:statement "I should use the same word order in German as in English."@en ;
  curric:correction """German word order is different from English word order. In word order 2, the
  subject and verb are inverted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086365Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-follow-either-strong
  a curric:Misconception ;
  curric:statement "All past participles follow either the strong or weak verb rules."@en ;
  curric:correction """Some past participles are irregular and need to be learned as vocabulary
  items. Practise them with the infinitive so that the students learns the sound as well as
  the spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087087Z"^^xsd:dateTime .

oakcurric:misconception-nicht-means-negating-german-sentences
  a curric:Misconception ;
  curric:statement "'Nicht' means 'not' when negating in all German sentences."@en ;
  curric:correction """'Nicht' negates in many sentences, but 'kein' replaces the indefinite article
  'a/an' to negate nouns. For example, 'I have no car', and 'I haven't got a car' are both
  'Ich habe kein Auto' in German."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087093Z"^^xsd:dateTime .

oakcurric:misconception-many-english-superlatives-use-need
  a curric:Misconception ;
  curric:statement """Many English superlatives use 'most', so you need to use 'meist' in
  German."""@en ;
  curric:correction """German superlatives use 'am -sten'. 'Most interesting' ist 'am
  interessantesten', and 'most difficult' is 'am schwierigsten'. No additional German word
  is required for 'most'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087281Z"^^xsd:dateTime .

oakcurric:misconception-saying-writing-years-german-same
  a curric:Misconception ;
  curric:statement """Saying or writing years in German is the same as in English, e.g., 1066 is
  'zehn sechsundsechzig'."""@en ;
  curric:correction """Block the numbers in pairs as in English, but in German you must use
  'hundert' or 'tausend'. 1066 is 'zehnhundertsechsundsechszig'. 2025 is
  'zweitausendfünfundzwanzig'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087465Z"^^xsd:dateTime .

oakcurric:misconception-include-much-detail-possible-role
  a curric:Misconception ;
  curric:statement "I should include as much detail as possible in role-play answers."@en ;
  curric:correction """When performing a role-play, answers should contain one verb and be concise.
  Do not add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087553Z"^^xsd:dateTime .

oakcurric:misconception-adapting-question-different-form-change
  a curric:Misconception ;
  curric:statement """When adapting a question to a different form of 'you', just change the
  pronoun, e.g., from 'du' to 'Sie'."""@en ;
  curric:correction """When adapting a question from 'du' to a different form of you ('ihr' or
  'Sie'), it's important to also change the verb form. With strong verbs, this can also
  involve a stem vowel change e.g., 'isst du?' becomes 'essen Sie?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087642Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-ever-written
  a curric:Misconception ;
  curric:statement "The imperfect tense is only ever written."@en ;
  curric:correction """Whilst the imperfect tense is mainly used to narrate past events in written
  German, some forms are regularly used in spoken German, such as 'es gab', 'war' and
  'hatte'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087648Z"^^xsd:dateTime .

oakcurric:misconception-checking-written-work-isnt-important
  a curric:Misconception ;
  curric:statement "Checking written work isn't important."@en ;
  curric:correction """Using a checklist can ensure pupils use a range of language and know what to
  look for when checking for accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087788Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-add-ge-imperfect
  a curric:Misconception ;
  curric:statement "Modal verbs must add ge- in the imperfect tense."@en ;
  curric:correction """Modal verbs are normally used in the imperfect to describe past events. The
  imperfect is a different tense from the perfect and is formed differently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087794Z"^^xsd:dateTime .

oakcurric:misconception-use-w-rd-2nd-infinitive
  a curric:Misconception ;
  curric:statement """Always use 'würd-' and a 2nd (infinitive) verb at the end of the sentence to
  mean 'would'."""@en ;
  curric:correction """This works for many verbs, but 'haben' and 'sein' have their own forms -
  'hätte' ('would have') and 'wäre' ('would be'). No second infinitive is required."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088203Z"^^xsd:dateTime .

oakcurric:misconception-asking-questions-past-much-complicated
  a curric:Misconception ;
  curric:statement """Asking yes/no questions in the past is much more complicated than the present
  tense, as the rules are different. You need to translate 'did'."""@en ;
  curric:correction """The English 'did' isn't needed. Swap subject and verb for a yes/no question.
  'Er sprach' (imperfect) becomes 'Sprach er?'. In the perfect tense, the past participle
  stays at the end of the sentence: 'Er hat gesprochen' - 'Hat er gesprochen?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088240Z"^^xsd:dateTime .

oakcurric:misconception-ich-german-means-english
  a curric:Misconception ;
  curric:statement "'Ich will' in German means 'I will' in English."@en ;
  curric:correction """'Ich will' (from the verb 'wollen') means 'I want to', but is a common false
  friend. The future tense in German needs 'werden' with a 2nd verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088460Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-german-dont-endings
  a curric:Misconception ;
  curric:statement "Adjectives in German don't have endings."@en ;
  curric:correction """Adjectives have endings when they precede a noun. Compare 'der Hund ist groß'
  with 'der große Hund ist schwarz'. Adjective endings agree in case, gender and number with
  nouns. There are useful tables that can be learned to support correct usage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088540Z"^^xsd:dateTime .

oakcurric:misconception-use-zu-mean
  a curric:Misconception ;
  curric:statement "Always use 'zu' to mean 'to'."@en ;
  curric:correction """'To' is expressed in different ways in German. 'In' and 'nach' also mean
  'to'. 'Zu' can also mean 'shut', 'closed' or 'off'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088546Z"^^xsd:dateTime .

oakcurric:misconception-use-word-order-two-phrases
  a curric:Misconception ;
  curric:statement "I should use word order two after phrases of opinion."@en ;
  curric:correction """Use word order two after 'meiner Meinung nach' and word order three after
  'ich denke, dass' and 'ich glaube, dass'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089096Z"^^xsd:dateTime .

oakcurric:misconception-use-imperfect-tense-translate-english
  a curric:Misconception ;
  curric:statement """Always use the imperfect tense to translate the English simple past, e.g., 'I
  chatted online.'"""@en ;
  curric:correction """The perfect tense is far more common in German, used for past events in
  speaking and informal writing. The imperfect is used mainly to narrate past events in more
  formal writing. However, 'hatte', 'war' and 'es gab' are used in speaking too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089561Z"^^xsd:dateTime .

oakcurric:misconception-question-word-wer-used-whenever
  a curric:Misconception ;
  curric:statement "The question word 'wer' is used whenever we want to say 'who'."@en ;
  curric:correction """'Wer' means 'who' in the nominative case only. It changes to 'wen' in
  accusative and 'wem' in the dative case. In English, 'wen' and 'wem' also mean 'whom',
  although this word is used less frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090001Z"^^xsd:dateTime .

oakcurric:misconception-rely-strategies-like-prediction-avoiding
  a curric:Misconception ;
  curric:statement """I can rely on strategies like prediction and avoiding distractors to
  successfully complete all listening comprehension questions."""@en ;
  curric:correction """Whilst strategies such as prediction and avoiding distractors are very
  helpful, the single most important factor in successfuly answering listening questions is
  having a secure knowledge of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090659Z"^^xsd:dateTime .

oakcurric:misconception-lieber-means-love
  a curric:Misconception ;
  curric:statement "'Lieber' means 'love'."@en ;
  curric:correction """It is easy to confuse the words 'Liebe', 'liebe' and 'lieber', particularly
  in spoken German. Pay careful attention to pronunciation and listen out for [er]. 'Liebe'
  is a noun (love), 'liebe' is a verb (love) and 'lieber' is an adverb (more gladly)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090805Z"^^xsd:dateTime .

oakcurric:misconception-know-usual-meanings-prepositions-choosing
  a curric:Misconception ;
  curric:statement """If you know the usual meanings of prepositions, choosing which preposition to
  use with each verb is straightforward, as we translate the preposition directly from
  English."""@en ;
  curric:correction """Verb and preposition combinations need to be learnt. The prepositions often
  lose their usual meaning when combined with verbs, and we often use different prepositions
  after verbs in English and in German."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091287Z"^^xsd:dateTime .

oakcurric:misconception-sentences-wenn-use-word-order
  a curric:Misconception ;
  curric:statement "All sentences with 'wenn' use word order 3 and send the verb to the end."@en ;
  curric:correction """Distinguish between a clause and a sentence. 'Wenn' clauses need a second
  clause to complete a sentence. A clause starting with 'wenn' sends the verb to the end. If
  the 'wenn' clause is first, the second clause (after the comma) uses inversion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092335Z"^^xsd:dateTime .

oakcurric:misconception-k-nnen-d-rfen-translate
  a curric:Misconception ;
  curric:statement "'Können' and 'dürfen' both translate as 'can' in English."@en ;
  curric:correction """'Können' and 'dürfen' are often used incorrectly in both German and English.
  'Dürfen' refers to permission - 'may I/am I allowed to?'. 'Können' refers to the ability
  to do something - 'can I/am I able to?', whether or not permission is given."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092341Z"^^xsd:dateTime .

oakcurric:misconception-form-imperative-simply-remove-subject
  a curric:Misconception ;
  curric:statement """To form the imperative, simply remove the subject pronoun and say the present
  tense verb form on its own."""@en ;
  curric:correction """To use the 'ihr' form of the imperative, simply remove the pronoun 'ihr' and
  say the verb form, e.g., 'Kommt!'. To use the 'du' form of the imperative, remove the
  pronoun 'du' but also remove the '-st' verb ending, e.g., 'Komm!'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092432Z"^^xsd:dateTime .

oakcurric:misconception-verbs-followed-dative-case-translate
  a curric:Misconception ;
  curric:statement """Verbs are only followed by the dative case if we translate the verb with 'to'
  or 'for' in English."""@en ;
  curric:correction """There are several impersonal verbs in German which require the dative case,
  e.g., 'gelingen' (to succeed)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092444Z"^^xsd:dateTime .

oakcurric:misconception-say-german-use-es
  a curric:Misconception ;
  curric:statement "To say 'it' in German, always use 'es'."@en ;
  curric:correction """As a pronoun, 'es' only replaces a neuter noun. 'Das Buch? Ich lese es gern.'
  ('A book? I like reading it.'). Use 'ihn' or 'sie' for masculine and feminine nouns. 'Der
  neue Film? Ich finde ihn (it) toll.'. 'Berlin? Ich besuche sie (it) gern.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092467Z"^^xsd:dateTime .

oakcurric:misconception-vor-bevor-nach-nachdem-interchangeable
  a curric:Misconception ;
  curric:statement """Vor' and 'bevor' and 'nach' and 'nachdem' are interchangeable because they
  mean 'before' and 'after'."""@en ;
  curric:correction """'Vor' and 'nach' are prepositions and are followed by a noun, 'bevor' and
  'nachdem' are conjunctions which link clauses and trigger word order 3."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092645Z"^^xsd:dateTime .

oakcurric:misconception-damit-means-them
  a curric:Misconception ;
  curric:statement "'Damit' always means 'with it' or 'with them'."@en ;
  curric:correction """'Damit' has a double identity! It can be used as a conjunction meaning 'so
  that' as well as a da-compound meaning 'with it' or 'with them'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095204Z"^^xsd:dateTime .

oakcurric:misconception-answer-role-play-question-one
  a curric:Misconception ;
  curric:statement "I can answer a role-play question with one or two words."@en ;
  curric:correction """Role-play questions need to be answered in full sentences with at least one
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103030Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjectives-dont-need-endings
  a curric:Misconception ;
  curric:statement "Possessive adjectives don't need endings."@en ;
  curric:correction "Possessive adjectives take the same endings as 'ein'."@en ;
  dcterms:modified "2026-06-07T15:30:15.105877Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-adverbs-identical-german-translated
  a curric:Misconception ;
  curric:statement """Adjectives and adverbs which are identical in German can be translated
  identically into English."""@en ;
  curric:correction """English adjectives and adverbs differ, often with the adverb ending in '-ly',
  so care must be taken when translating German adjectives used as adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106484Z"^^xsd:dateTime .

oakcurric:misconception-da-compounds-used-refer-back
  a curric:Misconception ;
  curric:statement "Da-compounds can be used to refer back to any noun already mentioned."@en ;
  curric:correction """Da-compounds can only be used with inanimate nouns. For people and animals,
  use object pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106564Z"^^xsd:dateTime .

oakcurric:misconception-dont-dictionary-exam-wont-able
  a curric:Misconception ;
  curric:statement """If I don't have a dictionary in an exam, I won't be able to work out the
  meaning of unfamiliar words."""@en ;
  curric:correction """If you cannot use a dictionary, look at the surrounding words. Is the word
  part of a compound noun? Is it a cognate? Using the words and grammar you know, generate a
  working translation and try to fill the gap. Consider the topic of the text, too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106859Z"^^xsd:dateTime .

oakcurric:misconception-bis-means-until
  a curric:Misconception ;
  curric:statement "'Bis' always means 'until'."@en ;
  curric:correction """'Bis' has several meanings and uses. As a preposition it can mean 'until',
  'up to' or 'by'. As a conjunction it usually means 'until'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106953Z"^^xsd:dateTime .

oakcurric:misconception-written-dictation-german-thing-matters
  a curric:Misconception ;
  curric:statement """In a written dictation in German, the only thing that matters is the correct
  sound-symbol correspondences (SSCs)."""@en ;
  curric:correction """SSCs are important, but the text needs to make sense grammatically. Check for
  correct spelling of known words, verb forms and tenses, and singular or plural nouns.
  Encourage students to check the details and to read back the texts in their head."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107464Z"^^xsd:dateTime .

oakcurric:misconception-whenever-two-verb-structures-used
  a curric:Misconception ;
  curric:statement """Whenever two-verb structures are used, the second verb - the infinitive or the
  past participle - always goes to the end of the clause or sentence."""@en ;
  curric:correction """The second verb goes to the end with normal word order and WO1 conjunctions
  like 'und', 'aber', 'oder' and 'sondern'. But with WO3 conjunctions, the main or finite
  verb is sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107489Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-followed-one-case-example
  a curric:Misconception ;
  curric:statement """All prepositions are followed by only one case - for example, the accusative
  or the dative."""@en ;
  curric:correction """The prepositions 'an, 'auf', 'in', ‘über’, 'unter', ‘vor’, 'hinter', 'neben'
  and ‘zwischen’ are used with the accusative case when there is movement, but the dative
  case when there is no movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107716Z"^^xsd:dateTime .

oakcurric:misconception-subject-verb-zu-clause-match
  a curric:Misconception ;
  curric:statement """The subject and verb in a 'zu' clause must match the subject and tense of the
  linked clause."""@en ;
  curric:correction """We always use the infinitive and never a subject and finite verb in
  constructions with 'zu'. This applies to all tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107956Z"^^xsd:dateTime .

oakcurric:misconception-developing-conversation-future-plans-important
  a curric:Misconception ;
  curric:statement """When developing a conversation about future plans, it is important to
  consistently use the future time frame in answers."""@en ;
  curric:correction """Whilst it is important to be able to refer to the future confidently, it is
  also helpful to add in different time frames to give more detail and to develop your
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107967Z"^^xsd:dateTime .

oakcurric:misconception-succeed-listening-comprehension-know-vocabulary
  a curric:Misconception ;
  curric:statement """You can only succeed in listening comprehension if you know all the
  vocabulary."""@en ;
  curric:correction """Whilst vocabulary knowledge is the most important element for success, other
  strategies can help, for example, close pre-reading of the questions, predicting
  vocabulary, avoiding distractors and checking answers carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108231Z"^^xsd:dateTime .

oakcurric:misconception-questions-german-invert-subject-verb
  a curric:Misconception ;
  curric:statement """All questions in German invert the subject and verb. Apart from that the word
  order is the same as English."""@en ;
  curric:correction """Subject and verb are inverted, but word order differs from English for a verb
  with a preposition - 'What are you talking about?'. In German, a preposition never ends a
  question. Use 'wo(r)' + preposition to start the question - 'Worüber redest du?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108672Z"^^xsd:dateTime .

oakcurric:misconception-time-manner-place-rule-means
  a curric:Misconception ;
  curric:statement """The time-manner-place rule means that all sentences must have time before
  manner before place."""@en ;
  curric:correction """German sentences can start with any adverb to emphasise that element. The TMP
  order is then retained for any other adverbs in that sentence. For example, 'Mit dem Zug
  (M) fahren wir morgen (T) nach Liechtenstein (P).'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109916Z"^^xsd:dateTime .

oakcurric:misconception-nouns-german-change-plural-like
  a curric:Misconception ;
  curric:statement "Nouns in German only change for the plural, like in English."@en ;
  curric:correction """Adjectival nouns, weak masculine nouns and dative plural nouns all change
  their spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110450Z"^^xsd:dateTime .

oakcurric:misconception-present-continuous-german-different-simple
  a curric:Misconception ;
  curric:statement "The present continuous in German is different to the simple present."@en ;
  curric:correction """The present continuous in German is the same as the simple present, so 'sie
  essen' means 'they eat' and 'they are eating'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111582Z"^^xsd:dateTime .

oakcurric:misconception-nouns-ending-n-dative-case
  a curric:Misconception ;
  curric:statement "All nouns ending '-n' must be in the dative case."@en ;
  curric:correction """The definite article 'den' shows the dative plural form as well as the '-n'
  added to the end of the dative plural. However, a number of nouns form their plural by
  adding '-(e)n' and are not in the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116224Z"^^xsd:dateTime .

oakcurric:misconception-z-pronounced-same-way-english
  a curric:Misconception ;
  curric:statement "'z' is pronounced the same way in both English and German."@en ;
  curric:correction """German [z] sounds like the English 'ts'. German [s-] is pronounced like the
  English 'z'. Use example words to remind you of the difference, e.g., 'Zug' (train) and
  'Suche' (search)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117178Z"^^xsd:dateTime .

oakcurric:misconception-like-role-play-keep-answers
  a curric:Misconception ;
  curric:statement """Like in a role-play, I should keep answers short and concise in a
  conversation."""@en ;
  curric:correction """Conversation answers should be developed and extended with at least three
  verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120708Z"^^xsd:dateTime .

oakcurric:misconception-like-picture-description-conversation-develop
  a curric:Misconception ;
  curric:statement """Like in a picture description and conversation, I should develop my role-play
  answers as much as possible."""@en ;
  curric:correction """When performing a role-play, answers should be a short phrase or sentence.
  Pupils should not add too much unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.121061Z"^^xsd:dateTime .

oakcurric:misconception-translating-english-german-need-understand
  a curric:Misconception ;
  curric:statement """When translating into English from German, I only need to understand the gist
  of the sentences."""@en ;
  curric:correction """When translating, it's important to ensure that you have accounted for the
  meaning of every German word, even though you might not translate word-for-word into
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.121108Z"^^xsd:dateTime .

oakcurric:misconception-infinitive-past-participle-comes-end
  a curric:Misconception ;
  curric:statement """The infinitive or past participle always comes at the end of the clause when
  using two-verb structures."""@en ;
  curric:correction """In standard word order (word order 1), the infinitive or past participle
  always comes at the end of the clause. However, after certain conjunctions (word order 3),
  the conjugated verb is sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122651Z"^^xsd:dateTime .

oakcurric:misconception-conjunctions-cause-verb-sent-end
  a curric:Misconception ;
  curric:statement "All conjunctions cause the verb to be sent to the end of the clause."@en ;
  curric:correction """Subordinating conjunctions, such as 'weil', 'dass', 'ob' and 'obwohl' send
  the verb to the end of the clause. Coordinating conjunctions, such as 'und', 'aber',
  'denn' and 'oder' are followed by word order 1 (standard subject-verb-object word order)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122858Z"^^xsd:dateTime .

oakcurric:misconception-rely-strategies-like-recognising-synonyms
  a curric:Misconception ;
  curric:statement """I can rely on strategies like recognising synonyms and avoiding distractors to
  successfully complete all reading comprehension questions."""@en ;
  curric:correction """Whilst strategies such as recognising synonyms and avoiding distractors are
  very helpful, they are only possible with a really secure and broad knowledge of the
  vocabulary list. Consolidating vocabulary is therefore the most important preparation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122882Z"^^xsd:dateTime .

oakcurric:misconception-like-role-play-pupils-keep
  a curric:Misconception ;
  curric:statement """Like in a role-play, pupils should keep their answers short and concise in a
  conversation."""@en ;
  curric:correction """Conversation answers should be developed and extended with at least three
  verb clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123071Z"^^xsd:dateTime .

oakcurric:misconception-closed-questions-german-require-translation
  a curric:Misconception ;
  curric:statement """Closed questions in German require a translation of ‘do you …’ or ‘are you …’,
  as in English."""@en ;
  curric:correction """Swap the position of the verb and the subject to create a closed question in
  German. Do not use translations of ‘do you …’ or ‘are you …’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123159Z"^^xsd:dateTime .

oakcurric:misconception-one-way-form-plural-german
  a curric:Misconception ;
  curric:statement "There is only one way to form the plural in German."@en ;
  curric:correction """German has several rules for forming plurals. The best way to correctly form
  plurals is to learn the rules, use an example for each rule as a guide, and frequently
  practise them. As in English, some nouns are used without plurals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123222Z"^^xsd:dateTime .

oakcurric:misconception-german-past-participles-start-ge
  a curric:Misconception ;
  curric:statement "All German past participles start with 'ge-'."@en ;
  curric:correction """Verbs starting with inseparable prefixes like 'be-', 'er-', 'ent-' and 'ver-'
  do not need 'ge'. Neither do verbs ending in '-ieren', e.g., 'interessiert'. Separable
  prefixes appear before 'ge-' in the perfect tense, e.g., 'aufgemacht', 'eingeführt'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123273Z"^^xsd:dateTime .

oakcurric:misconception-way-extend-my-sentences-add
  a curric:Misconception ;
  curric:statement """The only way to extend my sentences to add complexity is to add a subordinate
  clause with 'weil'."""@en ;
  curric:correction """There are many ways to add complexity, including using subordinate clauses
  with a wide range of conjunctions, as well as adding relative clauses or infinitive
  constructions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123548Z"^^xsd:dateTime .

oakcurric:misconception-german-past-participlies-start-ge
  a curric:Misconception ;
  curric:statement "All German past participlies start with 'ge-'"@en ;
  curric:correction """Verbs starting with inseparable prefixes like 'be-', 'er-', 'ent-' and 'ver-'
  do not need 'ge'. Neither do verbs ending in '-ieren', e.g., 'interessiert'. Separable
  prefixes appear before 'ge-' in the perfect tense, e.g., 'aufgemacht', 'eingeführt'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123630Z"^^xsd:dateTime .

oakcurric:misconception-use-werden-2nd-verb-infinitive
  a curric:Misconception ;
  curric:statement """Always use 'werden' and a 2nd verb in the infinitive to express future
  ideas."""@en ;
  curric:correction """In German future ideas can be expressed by the present tense with a future
  time phrase. They can also be expressed by 'werden' plus a 2nd verb, or by 'möcht-' to say
  what you would like to do in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124059Z"^^xsd:dateTime .

oakcurric:misconception-adjectival-nouns-require-capital-letter
  a curric:Misconception ;
  curric:statement """Adjectival nouns do not require a capital letter because they come from
  adjectives."""@en ;
  curric:correction "Adjectival nouns require a capital letter, just like all nouns in German."@en ;
  dcterms:modified "2026-06-07T15:30:15.125378Z"^^xsd:dateTime .

oakcurric:misconception-alll-german-words-foreign-origin
  a curric:Misconception ;
  curric:statement "Alll German words of foreign origin form their plural by adding 's'."@en ;
  curric:correction """Inanimate nouns add 's': 'Interviews', 'Songs'. Person nouns ending in -er
  (e.g., 'Reporter') do not change in the masculine plural. Weak masculine nouns (e.g.,
  'Journalist') add -en in the plural. Feminine plurals add -nen (e.g., 'Journalistinnen')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126007Z"^^xsd:dateTime .

oakcurric:misconception-english-verbs-followed-prepositions-directly
  a curric:Misconception ;
  curric:statement """English verbs followed by prepositions can be directly translated into
  German."""@en ;
  curric:correction """Whilst many of the same verbs are followed by prepositions in both languages,
  different prepositions are often used, so these must be learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126250Z"^^xsd:dateTime .

oakcurric:misconception-use-w-rd-whenever-want
  a curric:Misconception ;
  curric:statement "Use 'würd-' whenever you want to say 'would'."@en ;
  curric:correction """'Würd-' works for very many cases and is easy to remember because it sounds
  like the English 'would'. But 'haben' and 'sein' are important exceptions, especially in
  spoken German. 'Hätte' means 'I would have' and 'wäre' means 'I would be'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133787Z"^^xsd:dateTime .

oakcurric:misconception-one-way-say-german
  a curric:Misconception ;
  curric:statement "There is only one way to say 'there is' in German."@en ;
  curric:correction """In German, we use 'es gibt' to talk about something more generally, and 'da
  ist' and 'da sind' to point out what there is in a specific place at a specific moment in
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137123Z"^^xsd:dateTime .

oakcurric:misconception-plural-adjectival-nouns-end-en
  a curric:Misconception ;
  curric:statement "Plural adjectival nouns always end in '-en'."@en ;
  curric:correction """All plural adjectival nouns preceded by 'die' and all in the dative end in
  '-en', but for plural adjectival nouns without articles, use '-e' in the nominative and
  accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138908Z"^^xsd:dateTime .

oakcurric:misconception-verbs-prefixes-separable
  a curric:Misconception ;
  curric:statement "All verbs with prefixes are separable."@en ;
  curric:correction """Some prefixes are separable in some verbs but inseparable in others. For
  example, 'wieder' in 'wiedersehen' is separable, but not in 'wiederholen'. The stress
  always falls on the separable prefix."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139260Z"^^xsd:dateTime .

oakcurric:misconception-see-reflexive-pronoun-e-g
  a curric:Misconception ;
  curric:statement """If we see a reflexive pronoun, e.g., 'uns' or 'sich', this always means that
  the subject (doer) and object (receiver) of the verb are the same."""@en ;
  curric:correction """Some plural reflexive verbs are reciprocal, meaning the action of the verb is
  done 'to each other' rather than 'to oneself'. The word 'gegenseitig' can be used to
  emphasise reciprocal use. Otherwise, use context to work out which meaning is intended."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139466Z"^^xsd:dateTime .

oakcurric:misconception-german-vowel-sounds-o-u
  a curric:Misconception ;
  curric:statement "The German vowel sounds [a], [o] and [u] are the same as in English."@en ;
  curric:correction """German vowel sounds can be either long or short. Pronouncing them correctly
  ensure more authentic pronunciation, more accurate transcription and better understanding.
  Keep the simple rules in mind and practise reading aloud regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140509Z"^^xsd:dateTime .

oakcurric:misconception-verbs-expressing-change-state-take
  a curric:Misconception ;
  curric:statement "Only verbs expressing a change of state take 'sein' in the perfect tense."@en ;
  curric:correction """Verbs referring to motion, which don't require a direct object (e.g.,
  'gehen'), take 'sein' in the perfect tense. Most verbs meaning 'happen' (e.g.,
  'geschehen', 'passieren') and the verbs 'bleiben' and 'sein' also use 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141428Z"^^xsd:dateTime .

oakcurric:misconception-compound-nouns-completely-different-words
  a curric:Misconception ;
  curric:statement """Compound nouns are completely different words that cannot be understood or
  pronounced unless they have been met before."""@en ;
  curric:correction """Compound nouns are made up of two (or more) nouns, one or more of which
  pupils may already know. Knowledge of formation and read aloud can promote recognition as
  can activities where pupils produce compounds from known words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143734Z"^^xsd:dateTime .

oakcurric:misconception-use-welche-translate-relative-clause
  a curric:Misconception ;
  curric:statement "Use 'welche' to translate 'which' in a relative clause."@en ;
  curric:correction """Do not use a question word to translate 'which' when adding information about
  the noun in the main clause. ‘Was’ can be used as a relative pronoun meaning ‘that' or
  'which’ when referring to a whole clause, not a specific noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149412Z"^^xsd:dateTime .

oakcurric:misconception-verbs-german-followed-accusative-case
  a curric:Misconception ;
  curric:statement """All verbs in German are followed by the accusative case, apart from 'sein'
  which takes the nominative case."""@en ;
  curric:correction """A number of verbs are followed by the dative case. These must be learnt and
  carefully identified when translating into German."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149421Z"^^xsd:dateTime .

oakcurric:misconception-use-comparative-form-adjective-starting
  a curric:Misconception ;
  curric:statement """Always use the comparative form of an adjective as the starting point for
  forming the superlative."""@en ;
  curric:correction """Superlatives can change in the same way as comparatives, such as adding an
  umlaut, (alt, älter, der/die/das älteste). Where the comparative removes ‘e’, use the
  original adjective to form the superlative (teuer, teurer, der/die/das teuerste)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149526Z"^^xsd:dateTime .

oakcurric:misconception-strong-verbs-follow-different-pattern
  a curric:Misconception ;
  curric:statement """Strong verbs follow a different pattern to weak verbs in every person of the
  verb."""@en ;
  curric:correction """Strong verbs only change their stem vowel in the 'du' and 'er, sie, es' forms
  of the verb. Otherwise they follow the regular pattern of weak verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149566Z"^^xsd:dateTime .

oakcurric:misconception-german-nouns-form-their-plural
  a curric:Misconception ;
  curric:statement "All German nouns form their plural by adding 's'."@en ;
  curric:correction """Plural rules in German are complex and need to be learnt. Pronunciation is
  also important, as umlauts [ä], [ö] and [ü] can change meaning; for example, Vater, Väter.
  Accurate pronounciation can help with vocabulary, reading aloud and transcription."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149655Z"^^xsd:dateTime .

oakcurric:misconception-bei-means
  a curric:Misconception ;
  curric:statement "'Bei' always means 'at (the)' or 'with (the)'."@en ;
  curric:correction """'Bei' can mean 'at (the)' or 'with (the)' when followed by a noun, but it can
  also be used to mean 'whilst' or 'in the process of' before a nominalised infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149840Z"^^xsd:dateTime .

oakcurric:misconception-present-tense-german-used-refer
  a curric:Misconception ;
  curric:statement "The present tense in German can only be used to refer to the present."@en ;
  curric:correction """The present tense can also be used with appropriate adverbs of time to refer
  to the near future, e.g., 'Am Samstag spiele ich Tennis.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149848Z"^^xsd:dateTime .

oakcurric:misconception-use-accusative-reflexive-pronouns-mich
  a curric:Misconception ;
  curric:statement """We always use accusative reflexive pronouns ('mich', 'dich', etc.) with
  reflexive verbs."""@en ;
  curric:correction """If there is already an accusative object in the sentence, we use dative
  reflexive pronouns ('mir', 'dir', etc.) instead, e.g., 'Ich wasche mir die Hände'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150226Z"^^xsd:dateTime .

oakcurric:misconception-verbs-same-meaning-whether-used
  a curric:Misconception ;
  curric:statement """Verbs have the same meaning whether they are used reflexively or
  non-reflexively."""@en ;
  curric:correction """Some verbs have the same or similar meanings when used reflexively and
  non-reflexively, e.g. nennen, to call, sich nennen, to call oneself. However, some verbs
  completely change their meaning e.g. anziehen, to attract, sich anziehen, to get dressed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150584Z"^^xsd:dateTime .

oakcurric:misconception-german-sentences-word-order-changes
  a curric:Misconception ;
  curric:statement """In German sentences, the word order changes every time you use a
  conjunction."""@en ;
  curric:correction """Word order does not change after common co-ordinating conjunctions. 'Und',
  'aber', 'oder', 'denn' just join two standard sentences together. 'Subordinating'
  conjuctions send the verb to the end of the sentence. Practise with 'weil', 'wenn',
  'dass'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150631Z"^^xsd:dateTime .

oakcurric:misconception-aber-sondern-mean-same-thing
  a curric:Misconception ;
  curric:statement "'Aber' and 'sondern' mean the same thing and can be used interchangeably."@en ;
  curric:correction """Use 'aber' to contradict a preceding statement that does not contain a
  negative. Use 'sondern' to mean 'but' or 'rather' following a negative statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151137Z"^^xsd:dateTime .

oakcurric:misconception-sentence-contains-direct-object-indirect
  a curric:Misconception ;
  curric:statement """When a sentence contains both a direct object and an indirect object, the
  indirect object always comes first."""@en ;
  curric:correction """When a sentence contains both a direct object noun and an indirect object
  noun, the indirect object always comes first. When a pronoun is used to replace either
  noun, the pronoun comes first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151143Z"^^xsd:dateTime .

oakcurric:misconception-add-er-form-comparative-adverbs
  a curric:Misconception ;
  curric:statement "Add -er to form all comparative adverbs."@en ;
  curric:correction "Some comparative adverbs are irregular."@en ;
  dcterms:modified "2026-06-07T15:30:15.151271Z"^^xsd:dateTime .

oakcurric:misconception-cognates-pronounced-same-english-words
  a curric:Misconception ;
  curric:statement "Cognates are pronounced the same as the English words."@en ;
  curric:correction """Cognates may share similar spelling and meanings, but it is important to
  remember German pronunciation rules."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151838Z"^^xsd:dateTime .

oakcurric:misconception-da-compounds-translated-literally-preposition
  a curric:Misconception ;
  curric:statement """Da-compounds can always be translated literally, with the preposition
  retaining its usual meaning."""@en ;
  curric:correction """German verb and preposition combinations need to be learnt. We often use
  different prepositions after verbs in English and in German. Some da-compounds have also
  taken on slightly different meanings when used as adverbs or in idiomatic phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152636Z"^^xsd:dateTime .

oakcurric:misconception-important-say-much-possible-carrying
  a curric:Misconception ;
  curric:statement """It is important to say as much as possible when carrying out any speaking
  task."""@en ;
  curric:correction """When completing a role-play exam task, it is important to use at least one
  verb for each prompt. However, this is not the time to show off extended and developed
  sentences; it's more important to get the message across accurately and succinctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152644Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-dont-capital-letters-german
  a curric:Misconception ;
  curric:statement """Adjectives don’t have capital letters in German, so to say ‘the green ones’ in
  German, no capital letter is needed."""@en ;
  curric:correction """Whilst adjectives don't have capital letters, adjectival nouns always have
  capital letters; ‘die Grünen’ - 'the green ones'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155518Z"^^xsd:dateTime .

oakcurric:misconception-german-says-double-digits-same
  a curric:Misconception ;
  curric:statement "German says double digits the same way as English."@en ;
  curric:correction "In German, we say units first and then tens."@en ;
  dcterms:modified "2026-06-07T15:30:15.155525Z"^^xsd:dateTime .

oakcurric:misconception-nouns-created-verbs-formed-infinitive
  a curric:Misconception ;
  curric:statement """Nouns created from verbs are always formed from the infinitive and are always
  neuter."""@en ;
  curric:correction """Nouns can be formed from the infintive and those nouns are always neuter.
  However, other nouns can be formed from the verb stem rather than the infinitive. Nouns
  ending in the suffix '-ung' are always feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156247Z"^^xsd:dateTime .

oakcurric:misconception-darum-da-compound-its-meaning
  a curric:Misconception ;
  curric:statement """'Darum' is a da-compound and its meaning is always directly related to the
  preposition 'um'."""@en ;
  curric:correction """'Darum' can be used as a da-compund, meaning 'around it' or 'about it' but it
  is also a conjunction meaning 'therefore' or 'that's why'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156715Z"^^xsd:dateTime .

oakcurric:misconception-questions-formed-same-way-german
  a curric:Misconception ;
  curric:statement "Questions are formed in the same way in both German and English."@en ;
  curric:correction """English uses 'do you ... ?' or 'are you ... ?' when forming questions. German
  inverts the position of the subject and verb in a statement to form a closed question. Add
  a question word at the start to change it into an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156946Z"^^xsd:dateTime .

oakcurric:misconception-leave-subject-pronoun-using-imperative
  a curric:Misconception ;
  curric:statement "You always leave out the subject pronoun when using the imperative."@en ;
  curric:correction """The 'du' and 'ihr' forms of the imperative omit the subject pronoun, but the
  'Sie' form retains it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157110Z"^^xsd:dateTime .

oakcurric:misconception-like-english-german-uses-subject
  a curric:Misconception ;
  curric:statement """Like English, German uses 'it' and 'they' as subject pronouns to replace
  nouns."""@en ;
  curric:correction """In German, subject pronouns 'er', 'sie', 'es', 'sie' mean 'it' and 'they' and
  match the grammatical gender and number of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157303Z"^^xsd:dateTime .

oakcurric:misconception-future-tense-other-2-verb
  a curric:Misconception ;
  curric:statement """In the future tense and other 2-verb structures, the 2nd (infinitive) verb
  always comes at the end of the sentence."""@en ;
  curric:correction """The 2nd (infinitive) verb always comes at the end of the sentence in WO1 and
  2. In WO3, where the main verb goes to the end of the sentence, the 2nd (infinitive) verb
  is in 2nd-last place - 'Ich weiß, dass du nächste Woche nach Berlin fahren wirst.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157702Z"^^xsd:dateTime .

oakcurric:misconception-german-forms-comparatives-same-way
  a curric:Misconception ;
  curric:statement "German forms comparatives in the same way as English."@en ;
  curric:correction """Use 'als' to compare things that are different and 'so ... wie' to compare
  things that are the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158218Z"^^xsd:dateTime .

oakcurric:misconception-tense-verb-tell-us-whether
  a curric:Misconception ;
  curric:statement """Only the tense of the verb can tell us whether a sentence is referring to
  present, past or future events."""@en ;
  curric:correction """Adverbs of time are also very important in helping us to identify time
  frames, particularly when the present tense is used for future meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158464Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-used-spoken-german
  a curric:Misconception ;
  curric:statement "The imperfect tense is never used in spoken German."@en ;
  curric:correction """The most common irregular verbs 'haben' and 'sein' are very common in
  speaking, along with 'es gab'. Other verbs in the imperfect mainly appear in written
  texts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158767Z"^^xsd:dateTime .

oakcurric:misconception-questions-words-fixed-spellings
  a curric:Misconception ;
  curric:statement "Questions words all have fixed spellings."@en ;
  curric:correction """'Wer', meaning 'who', changes spelling according to its case. This also used
  to be the case in English, but the 'whom' form is often not used nowadays."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158775Z"^^xsd:dateTime .

oakcurric:misconception-use-wer-german-whenever-want
  a curric:Misconception ;
  curric:statement "Use 'wer' in German whenever you want to say 'who'."@en ;
  curric:correction """There are 3 different forms of 'who' in German, which should be used
  correctly to match the case required in each sentence. There are different forms in
  English (who, whom), but we don't often use 'whom'. The rules in German are stricter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159232Z"^^xsd:dateTime .

oakcurric:misconception-solange-sobald-used-als-translate
  a curric:Misconception ;
  curric:statement """'Solange' and 'sobald' have to be used with 'als' to translate the 'as' in 'as
  long/soon as'."""@en ;
  curric:correction """The single word 'solange' is the translation for three English words - 'as
  long as' - and the same for 'sobald' - 'as soon as'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159549Z"^^xsd:dateTime .

oakcurric:misconception-writing-german-accuracy-important-thing
  a curric:Misconception ;
  curric:statement """When writing in German, accuracy is the most important thing, so it's best to
  keep sentences short and clear."""@en ;
  curric:correction """When producing written work in German, try to develop and extend your
  sentences to demonstrate grammatical complexity. This must, of course, be balanced with
  accuracy, which enables you to communicate your ideas clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159751Z"^^xsd:dateTime .

oakcurric:misconception-use-wann-say
  a curric:Misconception ;
  curric:statement "We use 'wann' to say what we did, do or will do 'when'."@en ;
  curric:correction """'Wann' is a question word and means 'when' in questions and indirect
  questions. Use 'als' for 'when' when referring to specific past events or points in time
  and 'wenn' for repeated actions or conditions in the present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159823Z"^^xsd:dateTime .

oakcurric:misconception-qu-sounds-same-english-german
  a curric:Misconception ;
  curric:statement "[qu] sounds the same in English and German."@en ;
  curric:correction """In German, the SSC [qu] is pronounced 'k' then 'w' (which in German is like
  the English 'v' sound). Avoid confusion with English - for example, 'Qualität' vs
  'quality'. In German, 'kw' appears only in complound words, e.g., 'Trinkwasser'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159851Z"^^xsd:dateTime .

oakcurric:misconception-adjective-follows-ein-add-en
  a curric:Misconception ;
  curric:statement "When an adjective follows 'ein', always add 'en'."@en ;
  curric:correction """Adjective endings reflect the case and gender of the word they refer to.
  Dative case adjectives end in -en. In nominative and accusative, use -e for feminine and
  -es for neuter. Masculine -er and -en match (d)er (nominative) and (d)en (accusative)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160359Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjectives-dont-change-their
  a curric:Misconception ;
  curric:statement "Possessive adjectives don't change their endings, like in English."@en ;
  curric:correction """German possessive adjectives change their endings based on case and
  gender."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160661Z"^^xsd:dateTime .

oakcurric:misconception-capital-b-sounds-like-b
  a curric:Misconception ;
  curric:statement "[ß] is a capital B and sounds like [b]."@en ;
  curric:correction """[ß] sounds the same as [ss]. [ß] is used after long vowels, [ss] after short
  vowels. In words with 's' as the final sound, the spelling [-s] or [ß] needs to be learnt;
  for example, 'Glas' or 'Spaß'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160745Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronouns-er-sie-object
  a curric:Misconception ;
  curric:statement """Subject pronouns 'er' and 'sie' and object pronouns 'ihn' and 'sie' can only
  refer to people."""@en ;
  curric:correction """Subject pronouns 'er' and 'sie' can mean 'he' and 'she' or they can refer to
  masculine and feminine nouns, meaning 'it'. The same is true for the object pronouns 'ihn'
  and 'sie', which can mean 'him' and 'her' but also 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160883Z"^^xsd:dateTime .

oakcurric:misconception-phrase-zu-hause-means-home
  a curric:Misconception ;
  curric:statement "The phrase 'zu Hause' means 'to home' because 'zu' means 'to'."@en ;
  curric:correction """'Zu Hause' means 'at home' and 'nach Hause' is used for 'going (to)
  home'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160971Z"^^xsd:dateTime .

oakcurric:misconception-um-means-used-clock-times
  a curric:Misconception ;
  curric:statement "'Um' always means 'at' and is used with clock times."@en ;
  curric:correction """Whilst 'um' is used commonly with clock times to mean 'at', it can also mean
  'around' when referring to places, e.g., 'around the corner', or 'about, approximately'
  with numbers, e.g., 'about 10km'. It also follows some verbs, e.g., 'es geht um'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161233Z"^^xsd:dateTime .

oakcurric:misconception-verb-infinitives-ever-mean-something
  a curric:Misconception ;
  curric:statement "Verb infinitives only ever mean 'to do' something."@en ;
  curric:correction """Verb infinitives can be 'nouned' or nominalised by capitalising the first
  letter. These words are 'neuter' and can be used with or without 'das'. They do not need
  an ending (like the '-ing' in English) and are useful for extending vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161486Z"^^xsd:dateTime .

oakcurric:misconception-verbs-inseparable-prefixes-change-forming
  a curric:Misconception ;
  curric:statement """Verbs with inseparable prefixes do not change when forming their past
  participle."""@en ;
  curric:correction """Verbs with inseparable prefixes do not add 'ge-' when forming their past
  participle, but many do have vowel changes, e.g., 'vermeiden' becomes 'vermieden',
  'empfehlen' becomes 'empfohlen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163721Z"^^xsd:dateTime .

oakcurric:misconception-use-mehr-adjectives-adverbs-make
  a curric:Misconception ;
  curric:statement "Use 'mehr' with adjectives and adverbs to make comparisons."@en ;
  curric:correction """Use the comparative form of adjectives and adverbs to make comparisons, e.g.,
  'interessanter als', not 'mehr interessant als'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164406Z"^^xsd:dateTime .

oakcurric:misconception-intonation-doesnt-make-much-difference
  a curric:Misconception ;
  curric:statement "Intonation doesn't make much difference when reading aloud."@en ;
  curric:correction """Using correct intonation can also help you correctly pronounce German sounds
  and help you communicate clearly, such as pausing briefly when you see commas or full
  stops, or the rising pitch of your voice when asking questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164745Z"^^xsd:dateTime .

oakcurric:misconception-answering-question-yourself-change-verb
  a curric:Misconception ;
  curric:statement """When answering a question about yourself, just change the verb form in the
  question to a 1st person verb."""@en ;
  curric:correction """It is important to change the verb form, but it might also be necessary to
  change other language, such as subject pronouns, possessive adjectives and reflexive
  pronouns in order to change the 2nd person question into a 1st person answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164795Z"^^xsd:dateTime .

oakcurric:misconception-word-laut-means-loud-loudly
  a curric:Misconception ;
  curric:statement "The word 'laut' always means 'loud' or 'loudly'."@en ;
  curric:correction """As an adjective, 'laut' means 'loud', and as an adverb it means 'loudly'.
  However, when used as a preposition followed by the dative case, it means 'according to'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164819Z"^^xsd:dateTime .

oakcurric:misconception-strong-verbs-keep-their-stem
  a curric:Misconception ;
  curric:statement """Strong verbs never keep their stem changes in the 'du' form of the
  imperative."""@en ;
  curric:correction """Strong verbs keep stem vowel changes, e.g. 'e' to 'i', 'e' to 'ie', but omit
  the umlaut ('ä') in the imperative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164831Z"^^xsd:dateTime .

oakcurric:misconception-wissen-kennen-interchangeable
  a curric:Misconception ;
  curric:statement "'Wissen' and 'kennen' are interchangeable."@en ;
  curric:correction """Use 'wissen' with facts (e.g., 'Ich weiß nicht!') and 'kennen' with people or
  things you are familiar with ('Ich kenne deinen Freund.')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165102Z"^^xsd:dateTime .

oakcurric:misconception-like-english-german-uses-adjectives
  a curric:Misconception ;
  curric:statement "Like English, German uses adjectives to describe nationality."@en ;
  curric:correction "German uses nouns to describe nationality."@en ;
  dcterms:modified "2026-06-07T15:30:15.165107Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-german-start-ge
  a curric:Misconception ;
  curric:statement "All past participles in German start with 'ge-'."@en ;
  curric:correction """Verbs beginning with 'be-', 'ent-' or 'er-' do not require 'ge-' at the
  beginning. Past participles of separable verbs have the prefix first then the past
  participle of the main verb. They are written as one word, e.g., 'eingeladen',
  'ausgegangen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165197Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjective-match-whoever-possesses
  a curric:Misconception ;
  curric:statement """A possessive adjective must match whoever possesses the noun in gender, number
  and case."""@en ;
  curric:correction """A possessive adjective matches the gender, number and case of the noun it
  describes, not the person possessing it, e.g., 'his school' - 'seine Schule'. The
  possessor is male but the noun they possess is feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165540Z"^^xsd:dateTime .

oakcurric:misconception-adjectival-nouns-behave-like-adjectives
  a curric:Misconception ;
  curric:statement "Adjectival nouns behave like adjectives in every way."@en ;
  curric:correction """Adjectival nouns, like adjectives, change endings according to gender, case
  and the article used with them. However, like nouns, they have a grammatical gender and a
  capital letter. Abstract adjectival nouns are neuter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165552Z"^^xsd:dateTime .

oakcurric:misconception-denn-triggers-word-order-3
  a curric:Misconception ;
  curric:statement "'Denn' triggers word order 3."@en ;
  curric:correction """Not all conjunctions trigger word order 3. 'Denn' means 'because' and is
  followed by word order 1. 'Weil' also means 'because', but triggers word order 3."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165683Z"^^xsd:dateTime .

oakcurric:misconception-infinitives-nominalised-infinitives-look-exactly
  a curric:Misconception ;
  curric:statement "Infinitives and nominalised infinitives look exactly the same."@en ;
  curric:correction """Infinitives can be turned into nouns by capitalising the first letter, so
  although they sound the same, they look different. They are always neuter. Use surrounding
  words, such as 'beim' and 'am' to identify nominalised infinitives when listening."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165692Z"^^xsd:dateTime .

oakcurric:misconception-time-manner-place-adverbs-used
  a curric:Misconception ;
  curric:statement "Time, manner, place adverbs must always be used in the order TMP."@en ;
  curric:correction """When using WO1, the order TMP applies. However, each of the elements can be
  used at the beginning of a sentence for emphasis. In that case, use WO2 and put the
  remaining elements in the order time before manner before place."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165698Z"^^xsd:dateTime .

oakcurric:misconception-german-numbers-said-same-way
  a curric:Misconception ;
  curric:statement """German numbers are said in the same way as English numbers, i.e., tens then
  units."""@en ;
  curric:correction """The unit is said before the ten in German, e.g., 'neunundvierzig' = '9 and
  40' = 49. It is helpful to write from right to left when taking down numbers so that you
  produce them in the correct order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165746Z"^^xsd:dateTime .

oakcurric:misconception-producing-written-work-german-stick
  a curric:Misconception ;
  curric:statement """When producing written work in German, I should stick to short simple
  sentences."""@en ;
  curric:correction """When producing written work in German, you should try to develop and extend
  your sentences to demonstrate grammatical complexity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165865Z"^^xsd:dateTime .

oakcurric:misconception-verb-m-gen-takes-regular
  a curric:Misconception ;
  curric:statement "The verb 'mögen' takes regular verb endings."@en ;
  curric:correction """The verb 'mögen' is irregular in the singular present tense forms, and the
  first and third person singular are identical: 'ich mag', 'er mag'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166081Z"^^xsd:dateTime .

oakcurric:misconception-german-use-m-ssen-say
  a curric:Misconception ;
  curric:statement "In German, you always use 'müssen' to say what you have to do."@en ;
  curric:correction """The verb 'sollen' is another way of expressing an obligation, something you
  have to do. It has several uses, including strong commands (e.g. 'you should ring the
  doctor straightaway'), which are similar to the 'have to, must' meaning of 'müssen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166089Z"^^xsd:dateTime .

oakcurric:misconception-conjunction-obwohl-same-effect-word
  a curric:Misconception ;
  curric:statement """The conjunction 'obwohl' has the same effect on word order whether it starts
  the sentence or a second clause in a sentence."""@en ;
  curric:correction """The conjunction 'obwohl' always triggers word order 3 in a clause. However,
  if the sentence starts with the 'obwohl' clause, we then use the verb-comma-verb rule,
  meaning the second clause starts with the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166139Z"^^xsd:dateTime .

oakcurric:misconception-need-use-present-continuous-german
  a curric:Misconception ;
  curric:statement "We need to use the present continuous in German when describing photos."@en ;
  curric:correction """There is only one present tense in German. The present continuous in German
  is the same as the simple present, so 'sie essen' means 'they eat' and 'they are eating'.
  When translating English present continuous sentences, use the simple present."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166147Z"^^xsd:dateTime .

oakcurric:misconception-german-question-words-like-english
  a curric:Misconception ;
  curric:statement "German question words, like English, do not change their spelling."@en ;
  curric:correction """Whilst most question words, such as 'wo', 'was' and 'warum' have a fixed
  spelling, 'welch-' changes according the gender and case of the noun that follows."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166155Z"^^xsd:dateTime .

oakcurric:misconception-question-words-replace-definite-articles
  a curric:Misconception ;
  curric:statement """Question words can replace definite articles as relative pronouns in relative
  clauses."""@en ;
  curric:correction """Question words, such as 'wo', can be used as pronouns in relative clauses,
  but they should not be used to translate 'who' or 'which' when adding information about
  the noun in the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166298Z"^^xsd:dateTime .

oakcurric:misconception-indirect-object-nouns-preceded-words
  a curric:Misconception ;
  curric:statement """Indirect object nouns are always preceded by the words 'to' or 'for' in
  English, and this tells us we need to use the dative case for the indirect object in
  German."""@en ;
  curric:correction """Whilst the inclusion of 'to' or 'for' in English can be a helpful indicator
  that the dative case is needed in German, not all verbs require this in English, and many
  can use the same word order as German."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166304Z"^^xsd:dateTime .

oakcurric:misconception-german-forms-present-continuous-tense
  a curric:Misconception ;
  curric:statement """German forms the present continuous tense by using sein with a verb e.g. \"ich
  bin spielen\" to say \"I am playing\"."""@en ;
  curric:correction "German only has one present tense and does not use sein with a verb."@en ;
  dcterms:modified "2026-06-07T15:30:15.168994Z"^^xsd:dateTime .

oakcurric:misconception-one-set-adjective-endings-german
  a curric:Misconception ;
  curric:statement "There is one set of adjective endings in German."@en ;
  curric:correction """Adjective endings agree in case, gender and number with nouns, and there are
  different sets of adjective endings, depending on what word comes before the adjective.
  There are useful tables that can be learned to support correct usage."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168999Z"^^xsd:dateTime .

oakcurric:misconception-answering-conversation-questions-its-good
  a curric:Misconception ;
  curric:statement """When answering conversation questions, it’s good to keep answers as short as
  possible, as in a role-play task."""@en ;
  curric:correction """To give strong answers in conversation, it’s important to answer in full
  sentences and give details in our answers, including opinions and reasons, where
  appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169005Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-ieren-verbs-start
  a curric:Misconception ;
  curric:statement """Past participles of -ieren verbs start with 'ge-' like most other past
  participles."""@en ;
  curric:correction """Unlike most other past participles, most German -'ieren' verbs act like some
  other weak German verbs, meaning that they do not have 'ge' at the beginning of their
  participles (for example, verbs beginning with 'be', 'er', and 'ver')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169208Z"^^xsd:dateTime .

oakcurric:misconception-viel-viele-wenig-wenige-interchangeable
  a curric:Misconception ;
  curric:statement "'Viel' and 'viele' and 'wenig' and 'wenige' are interchangeable."@en ;
  curric:correction """Use 'viel' and 'wenig' with uncountable nouns (i.e., you cannot put a number
  in front of it) and use 'viele' and 'wenige' with countable nouns (i.e., you can put a
  number in front of it)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169281Z"^^xsd:dateTime .

oakcurric:misconception-k-nnen-d-rfen-mean
  a curric:Misconception ;
  curric:statement "'Können' and 'dürfen' both mean 'can' in English."@en ;
  curric:correction """Whilst we often use 'can' to translate both verbs in English, they are
  different in meaning. 'Dürfen' refers to permission - 'may I/am I allowed to?'. 'Können'
  refers to the ability to do something - 'can I/am I able to?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169356Z"^^xsd:dateTime .

oakcurric:misconception-verbs-use-auxiliary-verb-haben
  a curric:Misconception ;
  curric:statement "All verbs use the auxiliary verb 'haben' to form the perfect tense."@en ;
  curric:correction """A small number of verbs use the auxiliary verb 'sein' to form the perfect
  tense. These verbs usually refer to movement or a change of physical state."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169362Z"^^xsd:dateTime .

oakcurric:misconception-use-w-rde-whenever-want
  a curric:Misconception ;
  curric:statement "Use 'würde' whenever you want to say 'would'."@en ;
  curric:correction """'Würde' works in most cases, but for the conditional with 'haben' and 'sein',
  we usually use 'hätte' ('I would have') and 'wäre' ('I would be')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169367Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-used-speaking-simple
  a curric:Misconception ;
  curric:statement """The perfect tense is used only in speaking and the simple past only in
  writing."""@en ;
  curric:correction """The perfect tense can be used in informal writing and to describe a past
  event which has relevance to the present. The simple past is normally for writing, but
  'war', 'hatte', 'gab' and modal verbs ('musste', 'wollte') are commonly used in speech."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169373Z"^^xsd:dateTime .
