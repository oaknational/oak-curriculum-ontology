  dcterms:modified "2026-06-07T15:30:29.360775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29180-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
