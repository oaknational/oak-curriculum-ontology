oakcurric:keyword-genitive-case
  a curric:Keyword ;
  schema:name "genitive case"@en ;
  schema:description """case used to indicate possession and also used after certain
  prepositions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424697Z"^^xsd:dateTime .

oakcurric:keyword-am-liebsten
  a curric:Keyword ;
  schema:name "am liebsten"@en ;
  schema:description "superlative adverb meaning 'most preferably', 'most of all'"@en ;
  dcterms:modified "2026-06-07T15:30:02.424703Z"^^xsd:dateTime .

oakcurric:keyword-mssen
  a curric:Keyword ;
  schema:name "müssen"@en ;
  schema:description "modal verb meaning 'to have to', 'must'"@en ;
  dcterms:modified "2026-06-07T15:30:02.424921Z"^^xsd:dateTime .

oakcurric:keyword-sollte
  a curric:Keyword ;
  schema:name "sollte"@en ;
  schema:description "form of 'sollen' expressing obligation in a softer, more polite way"@en ;
  dcterms:modified "2026-06-07T15:30:02.424926Z"^^xsd:dateTime .

oakcurric:keyword-obwohl
  a curric:Keyword ;
