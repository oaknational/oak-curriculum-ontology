  schema:description """a small set of masculine nouns that add '-(e)n' in all forms apart from the
  nominative singular"""@en ;
  dcterms:modified "2026-06-07T15:30:02.389831Z"^^xsd:dateTime .

oakcurric:keyword-2nd-person
  a curric:Keyword ;
  schema:name "2nd person"@en ;
  schema:description "language used to refer to ‘you’, singular or plural"@en ;
  dcterms:modified "2026-06-07T15:30:02.393532Z"^^xsd:dateTime .

oakcurric:keyword-nichts
  a curric:Keyword ;
  schema:name "nichts"@en ;
  schema:description "word meaning 'nothing' or 'not anything'"@en ;
  dcterms:modified "2026-06-07T15:30:02.393739Z"^^xsd:dateTime .

oakcurric:keyword-nie
  a curric:Keyword ;
  schema:name "nie"@en ;
  schema:description "word meaning 'never'"@en ;
  dcterms:modified "2026-06-07T15:30:02.393743Z"^^xsd:dateTime .

oakcurric:keyword-plural-rules
  a curric:Keyword ;
  schema:name "plural rules"@en ;
  schema:description """rules applied to noun categories to support accurate use of plurals in
  German - rules 1 - 5 of 9 are covered here"""@en ;
  dcterms:modified "2026-06-07T15:30:02.394208Z"^^xsd:dateTime .

oakcurric:keyword-weak-verb-perfect-tense
  a curric:Keyword ;
  schema:name "weak verb (perfect tense)"@en ;
  schema:description "verb whose past participle sandwiches the stem with 'ge-' and '-t'"@en ;
  dcterms:modified "2026-06-07T15:30:02.394344Z"^^xsd:dateTime .

oakcurric:keyword-strong-verb-perfect-tense
  a curric:Keyword ;
  schema:name "strong verb (perfect tense)"@en ;
  schema:description """verb whose past participle sandwiches the stem with 'ge-' and ‘-en’ and
  often changes the stem vowel"""@en ;
  dcterms:modified "2026-06-07T15:30:02.394352Z"^^xsd:dateTime .

oakcurric:keyword-infinitive-construction
  a curric:Keyword ;
  schema:name "infinitive construction"@en ;
  schema:description "a verb in the infinitive preceded by 'zu'"@en ;
  dcterms:modified "2026-06-07T15:30:02.394541Z"^^xsd:dateTime .

oakcurric:keyword-infinitive-contstruction
  a curric:Keyword ;
  schema:name "infinitive contstruction"@en ;
  schema:description "a verb in the infinitive preceded by 'zu'"@en ;
  dcterms:modified "2026-06-07T15:30:02.394720Z"^^xsd:dateTime .

oakcurric:keyword-2-verb-rule
  a curric:Keyword ;
  schema:name "2-verb rule"@en ;
  schema:description "where the 2nd (infinitive) verb comes at the end of 2-verb sentences"@en ;
  dcterms:modified "2026-06-07T15:30:02.395068Z"^^xsd:dateTime .

oakcurric:keyword-abstract-adjectival-noun
  a curric:Keyword ;
  schema:name "abstract adjectival noun"@en ;
  schema:description """noun that takes the same endings as an adjective, and refers to an abstract
  idea, e.g., 'etwas Interessantes'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396296Z"^^xsd:dateTime .

oakcurric:keyword-etwas
  a curric:Keyword ;
  schema:name "etwas"@en ;
  schema:description """indefinite pronoun meaning ‘something’, often followed by an abstract
  adjectival noun"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396304Z"^^xsd:dateTime .

oakcurric:keyword-alles
  a curric:Keyword ;
  schema:name "alles"@en ;
  schema:description """indefinite pronoun meaning ‘everything’, often followed by an abstract
  adjectival noun"""@en ;
  dcterms:modified "2026-06-07T15:30:02.396309Z"^^xsd:dateTime .

oakcurric:keyword-wrd
  a curric:Keyword ;
  schema:name "würd-"@en ;
  schema:description """form of 'werden' meaning 'would', used with a 2nd infinitive to express a
  conditional idea"""@en ;
  dcterms:modified "2026-06-07T15:30:02.401008Z"^^xsd:dateTime .

oakcurric:keyword-separable-verbs
  a curric:Keyword ;
  schema:name "separable verbs"@en ;
  schema:description "a two-part verb, with a prefix and a main verb, e.g., 'einladen'"@en ;
  dcterms:modified "2026-06-07T15:30:02.404032Z"^^xsd:dateTime .

oakcurric:keyword-keit
  a curric:Keyword ;
  schema:name "-keit"@en ;
  schema:description """suffix added to adjectives or adverbs to form a noun; often corresponding to
  English '-ty', '-ness'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.404205Z"^^xsd:dateTime .

oakcurric:keyword-wissen
  a curric:Keyword ;
  schema:name "wissen"@en ;
  schema:description "irregular verb meaning 'to know' something"@en ;
  dcterms:modified "2026-06-07T15:30:02.405886Z"^^xsd:dateTime .

oakcurric:keyword-lieblings
  a curric:Keyword ;
  schema:name "'Lieblings-'"@en ;
  schema:description "a prefix added to nouns to mean 'favourite'"@en ;
  dcterms:modified "2026-06-07T15:30:02.407720Z"^^xsd:dateTime .

oakcurric:keyword-haupt
  a curric:Keyword ;
  schema:name "'Haupt-'"@en ;
  schema:description "a prefix added to nouns to mean 'main'"@en ;
  dcterms:modified "2026-06-07T15:30:02.407725Z"^^xsd:dateTime .

oakcurric:keyword-als
  a curric:Keyword ;
  schema:name "als"@en ;
  schema:description """conjunction meaning ‘when’, referring to specific past events, which
  triggers word order 3"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410079Z"^^xsd:dateTime .

oakcurric:keyword-viel
  a curric:Keyword ;
  schema:name "viel"@en ;
  schema:description "word meaning 'much, a lot (of)'"@en ;
  dcterms:modified "2026-06-07T15:30:02.410146Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-5
  a curric:Keyword ;
  schema:name "plural rule 5"@en ;
  schema:description """add -s to nouns borrowed from other languages; for example,
  'Interviews'."""@en ;
  dcterms:modified "2026-06-07T15:30:02.410187Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-6
  a curric:Keyword ;
  schema:name "plural rule 6"@en ;
  schema:description "add -nen to all female person nouns; for example, 'Lehrerinnen'."@en ;
  dcterms:modified "2026-06-07T15:30:02.410192Z"^^xsd:dateTime .

oakcurric:keyword-word-order-1
  a curric:Keyword ;
  schema:name "word order 1"@en ;
  schema:description """(WO1) subject - verb - object; the standard word order in a German sentence,
  e.g., 'Ich lerne Deutsch.'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.410957Z"^^xsd:dateTime .

oakcurric:keyword-sondern
  a curric:Keyword ;
  schema:name "sondern"@en ;
  schema:description "conjunction used after a negative, meaning ‘but’ or ‘rather’"@en ;
  dcterms:modified "2026-06-07T15:30:02.411356Z"^^xsd:dateTime .

oakcurric:keyword-mgen
  a curric:Keyword ;
  schema:name "mögen"@en ;
  schema:description "an irregular verb, meaning 'to like, liking'"@en ;
  dcterms:modified "2026-06-07T15:30:02.412029Z"^^xsd:dateTime .

oakcurric:keyword-es-gab
  a curric:Keyword ;
  schema:name "es gab"@en ;
