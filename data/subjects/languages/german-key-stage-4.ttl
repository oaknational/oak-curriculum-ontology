  dcterms:modified "2026-06-07T15:30:41.077787Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26477
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use ‘bis’ as a preposition and as a conjunction to talk about school this
