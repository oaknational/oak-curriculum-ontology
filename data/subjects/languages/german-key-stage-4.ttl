  Germany."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064139Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26472
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use reflexive verbs and adverbs in the perfect and imperfect tenses in the
  context of studies and work."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064159Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26473
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use irregular verbs in the perfect tense and ‘mochte’ in the imperfect tense
  in the context of career choices."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064354Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29183
  a curric:PupilLessonOutcome ;
  rdfs:label """I can confidently complete a role-play, photo description and follow-up conversation
  in the style of the speaking exam."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064362Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26486
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use prepositions with the accusative and dative to describe where people and
