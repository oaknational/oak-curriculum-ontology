  dcterms:modified "2026-06-07T15:30:02.420059Z"^^xsd:dateTime .

oakcurric:keyword-laut
  a curric:Keyword ;
  schema:name "laut"@en ;
  schema:description "a preposition meaning 'according to' which is followed by the dative"@en ;
  dcterms:modified "2026-06-07T15:30:02.420505Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-7
  a curric:Keyword ;
  schema:name "plural rule 7"@en ;
  schema:description """add 'e' and an umlaut where possible to single syllable feminine nouns; for
  example, 'die Städte'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.421087Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-8
  a curric:Keyword ;
  schema:name "plural rule 8"@en ;
  schema:description "add '-se' to nouns ending in '-is'; for example, 'die Ereignisse'"@en ;
  dcterms:modified "2026-06-07T15:30:02.421092Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-9
