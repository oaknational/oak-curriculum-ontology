  dcterms:modified "2026-06-07T15:30:29.360779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26590-1
  a curric:KeyLearningPoint ;
  rdfs:label """Future ideas can be expressed in German using the present tense with a future time
  phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26590-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the future tense, use the present tense of 'werden' to mean 'will, going to'
  and an infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26590-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-', the conditional of 'mögen', is used with a 2nd verb in the infinitive to
  express future wishes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26590-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the 2-verb rule, the 2nd (infnitive) verb is at the end of the sentence;
  second-last place in subordinate clauses"""@en ;
  dcterms:modified "2026-06-07T15:30:29.361331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26590-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26591-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to categorise vocabulary by theme when revisiting large numbers of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26591-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form a closed question by swapping the position of the verb and subject. Add a
  question word for an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26591-3
  a curric:KeyLearningPoint ;
  rdfs:label """In questions with reflexive verbs, only subject and verb swap position, and the
  reflexive pronoun follows the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26591-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal (2-verb) questions swap the subject and 1st verb; the infinitive remains at
  the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26591-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs form the imperfect tense by adding these endings to the verb stem: -te,
  -test, -te, -ten, -tet, -ten."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have irregular stems in the imperfect tense, with vowel changes and
  endings: -, st, -, en, t, en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26587-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense of ‘sein’, ‘haben’, modal verbs and 'es gab' are commonly used
  in spoken as well as written German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26587-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use ‘früher’ with a past tense to mean ‘in the past’ or ‘used to’."@en ;
  dcterms:modified "2026-06-07T15:30:29.361600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26587-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26602-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26602-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look out for tricky sounds and cognates, and mentally rehearse before
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26602-3
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26602-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26602-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29169-1
  a curric:KeyLearningPoint ;
  rdfs:label """Future ideas can be expressed in German using the present tense with a future time
  phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29169-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the future tense, use the present tense of 'werden' to mean 'will, going to'
  and an infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29169-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-', the conditional of 'mögen', is used with a 2nd verb in the infinitive to
  express future wishes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29169-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the 2-verb rule, the 2nd (infnitive) verb is at the end of the sentence;
  second-last place in subordinate clauses"""@en ;
  dcterms:modified "2026-06-07T15:30:29.361667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29169-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26595-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26595-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look out for tricky sounds and cognates, and mentally rehearse before
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26595-3
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26595-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26595-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26596-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective endings change depending on the gender, case and number of the noun they
  describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26596-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective endings also depend on whether they follow the definite article, the
  indefinite article or no article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26596-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjective agreement only occurs when the adjective comes before the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.362019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26596-4
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed response has at least three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.362023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26596-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extend your answers by using a different tense, a different subject, or opinions and
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29173-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nicht' before definite articles to mean ‘not the’ and 'kein' instead of the
  indefinite article to mean 'not a, no'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29173-2
  a curric:KeyLearningPoint ;
  rdfs:label """Place 'nicht' before adjectives, adverbs, possessives and proper nouns. Place
  'nicht' after verbs and whole phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29173-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nichts' to mean 'nothing' or 'not anything', e.g., 'ich sehe nichts.' Use 'nie'
  to mean 'never'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29173-4
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29173-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to categorise vocabulary by theme when revisiting large numbers of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26560-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use your linguistic knowledge to break down language in longer texts and aid your
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Abstract adjectival nouns refer to abstract ideas, such as 'important',
  'interesting'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26560-3
  a curric:KeyLearningPoint ;
  rdfs:label """After 'etwas', capitalise the adjective and add '-es' to make a neuter abstract
  adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26560-4
  a curric:KeyLearningPoint ;
  rdfs:label """After 'alles', capitalise the adjective and add '-e' to make a neuter abstract
  adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26560-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use dictation tasks to reinforce your understanding of sound-symbol
  correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26470-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some masculine nouns, most of them referring to people or animals, add –(e)n to form
  the plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26470-2
  a curric:KeyLearningPoint ;
  rdfs:label """To change a masculine noun into a feminine noun, add '-in'; add 'nen' to make
  feminine nouns ending 'in' plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26470-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some nouns, often of foreign origin, add 's' in the plural; this does not apply to
  person nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26470-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is commonly used to recount past events in writing. Irregular
  verb stems need to be learned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26451-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some prepositions are always followed by the accusative case: 'durch', 'für',
  'ohne', 'gegen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26451-2
  a curric:KeyLearningPoint ;
  rdfs:label "Masculine definite article 'der' changes to 'den' in the accusative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.368071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26451-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some verbs are followed by prepositions which take the accusative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.368075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26451-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs which are followed by prepositions often use different prepositions in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26463-1
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about something something you would or might do, use 'würd-' to mean ‘would’
  and an infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26463-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'gern' and 'lieber' with 'würde' to talk about what we would like or would
  prefer to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26463-3
  a curric:KeyLearningPoint ;
  rdfs:label "To say  'would have', use 'hätte'."@en ;
  dcterms:modified "2026-06-07T15:30:29.383592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26463-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say  'would be', use 'wäre'."@en ;
  dcterms:modified "2026-06-07T15:30:29.383596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26434-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Es gibt' means ‘there is’ and ‘there are’. It is a general statement that something
  exists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26434-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'es ist' and 'da ist' to point out what there is in a specific place at a
  specific moment in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26434-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in a main clause without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26434-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the indefinite pronouns 'jemand' (someone) and 'niemand' (no-one) instead of a
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26465-1
  a curric:KeyLearningPoint ;
  rdfs:label """The German [ch] can be soft or hard. Soft [ch] should not be confused with
  [sch]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26465-2
  a curric:KeyLearningPoint ;
  rdfs:label "Certain verbs are dative verbs and use indirect object (dative) pronouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.393496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26465-3
  a curric:KeyLearningPoint ;
  rdfs:label "The dative pronouns are 'mir', 'dir', 'ihm', 'ihn', 'uns', 'euch', 'ihnen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.393500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26465-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some dative verbs are also impersonal like 'gefallen', 'gelingen' and 'genügen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.393504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26484-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be turned into neuter nouns to express abstract concepts, e.g., ‘das
  Gute’ - 'the good thing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26484-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form an abstract adjectival noun, use 'das', capitalise the adjective, and add
  '-e' in nominative and accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26484-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using abstract adjectival nouns can help to vary and extend opinions, e.g., ‘das
  Beste (daran) ist, dass ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26484-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plural adjectival nouns end in '-en' when used after 'die'."@en ;
  dcterms:modified "2026-06-07T15:30:29.395721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26484-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plural adjectival nouns used without articles end in 'e' in nominative and
  accusative and 'en' in dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26479-1
  a curric:KeyLearningPoint ;
  rdfs:label "The stress falls on the separable prefix of separable verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.396746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26479-2
  a curric:KeyLearningPoint ;
  rdfs:label "Separable verbs are made up of two parts: a prefix and the main verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.396750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26479-3
  a curric:KeyLearningPoint ;
  rdfs:label "In the present tense, the prefix moves to the end of the clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.396754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26479-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the perfect tense, the past participle is made up of the prefix and the base past
  participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26479-5
  a curric:KeyLearningPoint ;
  rdfs:label "In word order three clauses, the prefix and verb join up in separable verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.396766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26574-1
  a curric:KeyLearningPoint ;
  rdfs:label """We usually use accusative reflexive pronouns with reflexive verbs: 'mich', 'dich',
  'sich', 'uns', 'euch', 'sich'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26574-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are used with dative reflexive pronouns. 'Mir' and 'dir' are used instead
  of 'mich' and 'dich'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26574-3
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, such as with modal verbs, the reflexive pronoun comes
  directly after the first verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26574-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two pronouns, the object pronoun comes before the dative reflexive
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26574-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the action of the verb is two-way, plural reflexive pronouns can mean ‘each
  other’. This is called reciprocal use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.397720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26439-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning to write involves organising ideas and selecting language."@en ;
  dcterms:modified "2026-06-07T15:30:29.400708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26439-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a checklist helps to ensure an appropriate range of language is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.400717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26439-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a text aloud helps practise prounciation and supports understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.400721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26439-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and understanding an extended text needs attention to vocabulary, structures
  and a focus on required details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26439-5
  a curric:KeyLearningPoint ;
  rdfs:label "Accuracy in reading and writing is  enchanced by careful checking."@en ;
  dcterms:modified "2026-06-07T15:30:29.400729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26561-1
  a curric:KeyLearningPoint ;
  rdfs:label """Form the perfect tense using 'sein' with verbs referring to a change of state, e.g.,
  'ist eingeschlafen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26561-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form the superlative by adding '-ste' to the end of the adjective if it comes before
  a noun, e.g., 'billigste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26561-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some superlative forms are irregular, e.g., 'beste', 'höchste', 'meiste'. Others
  have umlauts as in the comparative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26561-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 1905, Bertha von Suttner was the first woman to receive the Nobel Peace
  Prize."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26586-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26586-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look out for tricky sounds and cognates, and mentally rehearse before
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26586-3
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26586-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26586-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26428-1
  a curric:KeyLearningPoint ;
  rdfs:label "Combine two or more words to create a compound noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.409940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26428-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Lieblings-' creates compound nouns to mean 'favourite'."@en ;
  dcterms:modified "2026-06-07T15:30:29.409944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26428-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Haupt-' creates compound nouns to mean 'main'."@en ;
  dcterms:modified "2026-06-07T15:30:29.409948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26428-4
  a curric:KeyLearningPoint ;
  rdfs:label """A literal translation of a compound noun into English can aid understanding but is
  not always accurate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26563-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in the main clause, without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26563-2
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause starts with a relative pronoun - the definite article ('der',
  'die', 'das') that matches the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26563-3
  a curric:KeyLearningPoint ;
  rdfs:label "Question words such as ‘wo’ can also be used as pronouns in relative clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.422279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26563-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Was’ can be used as a relative pronoun meaning ‘that' or 'which’ when referring to
  a whole clause, not a specific noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26563-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many famous German figures continue to be influential in today’s world."@en ;
  dcterms:modified "2026-06-07T15:30:29.422288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26454-1
  a curric:KeyLearningPoint ;
  rdfs:label "The long German [e] can be written 'e', 'eh' or ‘ee’."@en ;
  dcterms:modified "2026-06-07T15:30:29.422292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26454-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Jed-' has different endings in the nominative, accusative and dative cases."@en ;
  dcterms:modified "2026-06-07T15:30:29.422296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26454-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some verbs take indirect objects. They are also called ‘dative verbs’."@en ;
  dcterms:modified "2026-06-07T15:30:29.422301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26454-4
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] can be written as 'eu' like in 'neu' and 'äu' like in 'Häuser'."@en ;
  dcterms:modified "2026-06-07T15:30:29.422305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26520-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Wenn' means ‘when’, ‘whenever’ or ‘if’, used for repeated actions or conditions in
  the present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26520-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Als' means ‘when’ to refer to a specific past event or point in time. 'Als' and
  'wenn' both trigger word order 3."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26520-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the superlative to express the highest degree of something, e.g., 'the most
  beautiful', 'the best'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26520-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form superlatives, add '-st' to the adjective before a noun. Use ‘am’ and add
  ‘-sten’ to the adjective after a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26520-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives and adverbs have irregular comparative and superlative forms."@en ;
  dcterms:modified "2026-06-07T15:30:29.422698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs in the present tense follow a regular pattern of changes, like
  ‘lernen’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26545-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs in the present tense change their stem vowel in the ‘du’ and ‘er, sie,
  es’ forms: e→i, e→ie, and a→ä."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26545-3
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26545-4
  a curric:KeyLearningPoint ;
  rdfs:label """Translate the English present continuous using the German simple present when
  describing what is happening in a photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26430-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some masculine and neuter nouns add '-er' with an umlaut, where possible, to form
  the plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26430-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns borrowed from other langauges usually add '-s' to form the plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.423107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26430-3
  a curric:KeyLearningPoint ;
  rdfs:label "Female person nouns add '-nen' to form the plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.423113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26430-4
  a curric:KeyLearningPoint ;
  rdfs:label """The German short [a] sounds like the 'a' in 'Blatt'. The short [ä] is as in the
  plural 'Blätter'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26430-5
  a curric:KeyLearningPoint ;
  rdfs:label """The German short [u] sounds like the 'u' in 'Unterschied'; the long [u] is as in
  'Uhr'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26541-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Bei' means 'at' or 'with' and takes the dative. When used with masculine or neuter
  nouns, 'bei dem' becomes 'beim'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26541-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean ‘whilst’ or ‘in the process of’ doing something, use 'beim' before a
  nominalised infinitive, e.g., ‘beim Lesen’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26541-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'am' as an alternative to 'beim' to mean ‘in the process of’, but only when a
  single activity is being done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26541-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of 'beim' or 'am' plus the nominalised verb indicates the activity is, or
  was, ongoing or unfinished."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26541-5
  a curric:KeyLearningPoint ;
  rdfs:label """In conversation, develop answers by adding opinions and reasons, varying the
  subject, and adding different time frames."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26510-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates are words that have the same meaning and look the same or very similar to
  English words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26510-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates are very useful in reading tasks, as they can help us to quickly identify
  the overall theme of a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26510-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use adverbs of time and verb tenses to distinguish between past, present and
  future actions and events"""@en ;
  dcterms:modified "2026-06-07T15:30:29.423657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26510-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a role play, you are required to say a short phrase in response to each
  prompt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26510-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a role play, it is important to include at least one verb in each phrase. You
  must also ask one question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26457-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most reflexive verbs use accusative reflexive pronouns: 'mich', 'dich', 'sich',
  'uns', 'euch', 'sich'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26457-2
  a curric:KeyLearningPoint ;
  rdfs:label """If sentences already have an accusative object, the reflexive pronoun must be in the
  dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26457-3
  a curric:KeyLearningPoint ;
  rdfs:label "The dative reflexive pronouns are 'mir', 'dir', 'sich', 'uns', 'euch', 'sich'."@en ;
  dcterms:modified "2026-06-07T15:30:29.425085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26457-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of 'welch-' depends on the gender and case of the noun that follows. It
  follows the same pattern as 'dies-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26456-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are reflexive in German but their English translation does not have a
  reflexive meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26456-2
  a curric:KeyLearningPoint ;
  rdfs:label """The meaning of a verb can change depending on its reflexive or non-reflexive
  use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26456-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive use means the subject (doer) and object (receiver) of the action are the
  same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26456-4
  a curric:KeyLearningPoint ;
  rdfs:label """With plural verbs, reflexive pronouns can also mean 'each other', if the action is
  reciprocal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26432-1
  a curric:KeyLearningPoint ;
  rdfs:label "Word order one conjunctions do not change word order."@en ;
  dcterms:modified "2026-06-07T15:30:29.426299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26432-2
  a curric:KeyLearningPoint ;
  rdfs:label "Word order three conjunctions like 'weil' send the verb to the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.426303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26432-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most German adjectives can be used as adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.426307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs in the present tense change the stem vowel in the 2nd and 3rd person
  singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26548-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nicht' before definite articles to mean ‘not the’ and 'kein' instead of the
  indefinite article to mean 'not a, no'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26548-2
  a curric:KeyLearningPoint ;
  rdfs:label """Place 'nicht' before adjectives, adverbs, possessives and proper nouns. Place
  'nicht' after verbs and whole phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26548-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nichts' to mean 'nothing' or 'not anything', e.g., 'ich sehe nichts.' Use 'nie'
  to mean 'never'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26548-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'sondern' to mean 'but' or 'rather' when contradicting a preceding negative."@en ;
  dcterms:modified "2026-06-07T15:30:29.428156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26548-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the conjunction 'entweder … oder ...' to mean 'either … or ...' and 'weder …
  noch ...' to mean 'neither … nor ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26540-1
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object pronoun replaces a noun that is the object of the verb and is in the
  accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26540-2
  a curric:KeyLearningPoint ;
  rdfs:label """An indirect object pronoun replaces the noun that the verb action is done ‘to’ or
  ‘for’ and is in the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26540-3
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two object nouns, the indirect object noun always comes before the
  direct object noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26540-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two objects where there is one noun and one pronoun, the pronoun
  always comes first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26446-1
  a curric:KeyLearningPoint ;
  rdfs:label """When [er] is the stressed syllable, it usually sounds like two short syllables:
  'e-uh'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26446-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the syllable is unstressed, [-er] sounds like ‘uh’, most often at the end of
  the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26446-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use a verb with 'gern' to mean 'like'."@en ;
  dcterms:modified "2026-06-07T15:30:29.428604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26446-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use a verb with 'lieber' to mean 'prefer'."@en ;
  dcterms:modified "2026-06-07T15:30:29.428608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26446-5
  a curric:KeyLearningPoint ;
  rdfs:label "Add –er to turn adverbs into comparatives."@en ;
  dcterms:modified "2026-06-07T15:30:29.428612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26526-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add the prefix 'Lieblings-' to nouns to mean 'favourite', e.g., 'die
  Lieblingsfarbe'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26526-2
  a curric:KeyLearningPoint ;
  rdfs:label "Add the prefix 'Haupt-' to nouns to mean 'main', e.g., 'die Hauptstraße'."@en ;
  dcterms:modified "2026-06-07T15:30:29.430406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26526-3
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun 'man' means 'one, you'. Its accusative form is 'einen' and its
  dative form is 'einem'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26526-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'man + verb' to translate English phrases that do not specify a particular
  subject, e.g., 'It is said that ... '."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26580-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are followed by prepositions and the accusative case, and some are
  followed by prepositions and the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26580-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use different prepositions after verbs in English and German, so verb and
  preposition combinations must be learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26580-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'da(r)-' can be added to prepositions to refer to something already
  mentioned. This is called a da-compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26580-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some da-compounds have different meanings in common usage as adverbs. Some idiomatic
  phrases include a da-compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26580-5
  a curric:KeyLearningPoint ;
  rdfs:label """A developed response to a question has at least 3 clauses. Include a different
  tense, subject, or opinion and reason."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26551-1
  a curric:KeyLearningPoint ;
  rdfs:label """Break compound words down into two or more individual words to work out their
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26551-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form questions with 'Sie' for formal 'you'. The 'Sie' form of the verb is usually
  the same as the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26551-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'dessen' and 'deren' as relative pronouns to mean 'whose'."@en ;
  dcterms:modified "2026-06-07T15:30:29.432963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26551-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play, you are required to say a short phrase in response to each prompt.
  You will be addressed using 'Sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26551-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play, it is important to include at least one verb in each phrase. You
  must also ask one question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26475-1
  a curric:KeyLearningPoint ;
  rdfs:label "[j] sounds like 'ja'."@en ;
  dcterms:modified "2026-06-07T15:30:29.432978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26475-2
  a curric:KeyLearningPoint ;
  rdfs:label """Determiners 'jed-' ‘nächst-’ and ‘letzt-’ change their endings according to gender
  and case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26475-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Sondern' means 'but' or 'rather' and contradicts a preceding negative."@en ;
  dcterms:modified "2026-06-07T15:30:29.432986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26537-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Viel' means ‘a lot’ or ‘much’. The opposite is 'wenig', which means ‘little’."@en ;
  dcterms:modified "2026-06-07T15:30:29.587885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26537-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectival nouns, like adjectives, change according to gender, case and the article
  used with them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26537-3
  a curric:KeyLearningPoint ;
  rdfs:label """Following 'wenig' or 'viel', capitalise an adjective and add '-es' to turn it into a
  neuter adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26537-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use dictogloss tasks to reinforce your grammatical understanding in different
  contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26425-1
  a curric:KeyLearningPoint ;
  rdfs:label "Subject and verb are inverted in Word Order 2 (WO2)."@en ;
  dcterms:modified "2026-06-07T15:30:29.587903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26425-2
  a curric:KeyLearningPoint ;
  rdfs:label "German numbers are written as one word."@en ;
  dcterms:modified "2026-06-07T15:30:29.587908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26425-3
  a curric:KeyLearningPoint ;
  rdfs:label "Say single digits before tens in German numbers."@en ;
  dcterms:modified "2026-06-07T15:30:29.587915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26524-1
  a curric:KeyLearningPoint ;
  rdfs:label """When two or more adverbs are in a sentence, the word order is time before manner
  before place (TMP)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26524-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subject and verb invert in questions and in word order 2, where a sentence starts
  with a TMP adverb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26524-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wh- question words focus on time, manner, place, and TMP adverbs can start a
  sentence in reply."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26524-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud benefits from initial silent rehearsal to focus on the sound-spelling
  correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26524-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud also requires focus on cognates with different stress patterns from
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26501-1
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive verbs can be turned into nouns and correspond to English '-ing' nouns,
  e.g., 'das Lesen' - 'reading'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26501-2
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitives as nouns are capitalised and are always neuter. They can be used with or
  without 'das'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26501-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix '-ung' is added to the stem of some verbs to form nouns, e.g., 'die
  Entscheidung'. They are always feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26501-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns ending in '-ung' have the equivalent and transparent meaning of the verb,
  e.g., 'lösen' becomes 'Lösung'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26493-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some verbs are followed by the preposition 'um' and the accusative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.591631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26493-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'wor-' can be added to 'um' to make a question, usually meaning 'what
  about' or 'around what'?"""@en ;
  dcterms:modified "2026-06-07T15:30:29.591636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26493-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix 'dar-' can be added to 'um' to mean 'about it' or 'around it'."@en ;
  dcterms:modified "2026-06-07T15:30:29.591640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26493-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Darum' can also be a conjunction meaning 'therefore' or 'that's why'."@en ;
  dcterms:modified "2026-06-07T15:30:29.591644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26493-5
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions 'trotz', 'statt', 'während' and 'wegen' are followed by the genitive.
  Masculine and neuter nouns gain 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26532-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowels [a], [o] and [e] can be pronounced long as in 'gezogen' or short as in
  'gewonnen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26532-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs form past participles by adding 'ge-' and '-en' around the verb stem,
  e.g. 'gelesen'. Others are irregular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26532-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form a closed question in the perfect tense, swap the position of 'haben' or
  'sein' with the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26532-4
  a curric:KeyLearningPoint ;
  rdfs:label """For open questions in the perfect tense, place a question word before 'haben' or
  'sein'; the subject follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26532-5
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles 'gefallen' and 'gemocht' both mean 'liked'. Use indirect object
  pronouns with 'gefallen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26547-1
  a curric:KeyLearningPoint ;
  rdfs:label "Imperative verbs are used to give instructions, directions, or advice."@en ;
  dcterms:modified "2026-06-07T15:30:29.592789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26547-2
  a curric:KeyLearningPoint ;
  rdfs:label """For the ‘du’ imperative of weak and strong verbs, remove the ‘-st’ and the 'du'.
  Omit umlauts added as a stem change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26547-3
  a curric:KeyLearningPoint ;
  rdfs:label """To use the 'ihr' form of the imperative of weak and strong verbs, just remove the
  pronoun 'ihr'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26547-4
  a curric:KeyLearningPoint ;
  rdfs:label """To use the formal 'Sie' form of the imperative, swap the position of the verb and
  subject pronoun 'Sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26547-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' is irregular in the 'du' and 'Sie' forms of the imperative. Use 'sei', 'seid'
  and 'Seien Sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26435-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in a main clause, without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26435-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some relative clauses are embedded in a main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.593446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26435-3
  a curric:KeyLearningPoint ;
  rdfs:label """Match subject pronouns 'er', 'sie', 'es', 'sie' with the gender and number of a noun
  to mean 'it' and 'they'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26435-4
  a curric:KeyLearningPoint ;
  rdfs:label """The historic present narrates events in the past to make them feel more
  immediate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26523-1
  a curric:KeyLearningPoint ;
  rdfs:label """The future tense uses 'werden' in the present tense with a 2nd (infinitive) verb at
  the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26523-2
  a curric:KeyLearningPoint ;
  rdfs:label "The present tense with a time adverbial can be used to express future meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.594773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Time adverbials modify the time frame for a verb, for example 'this week', 'next
  month'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26523-4
  a curric:KeyLearningPoint ;
  rdfs:label """2-verb structures send the 2nd (infinitive) verb to the end of the sentence in WO1 &
  2, and to second-last place in WO3."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26523-5
  a curric:KeyLearningPoint ;
  rdfs:label """In reading, use title and picture clues, close reading, translation, and
  comprehension questions to aid understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26489-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Vor' and 'nach' are prepositions used with nouns to express 'before' and 'after'.
  They take the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26489-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Bevor' and 'nachdem' are conjunctions meaning 'before' and 'after' and link two
  clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26489-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Bevor' and 'nachdem' are followed by word order 3 and send the verb to the end of
  the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26489-4
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, the finite verb, not the past participle or infinitive verb,
  are sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26489-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Bevor’ and ‘nachdem’ can also start a sentence, creating verb-comma-verb word
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26542-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs in the present tense follow a regular pattern of changes, like
  'lernen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26542-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs in the present tense change their vowel in the verb stem in the 'du'
  and 'er, sie, es' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26542-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strong verb stem changes in the present tense are: e to i, e to ie, and a to ä."@en ;
  dcterms:modified "2026-06-07T15:30:29.596326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26542-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use reflexive pronouns with reflexive verbs. They often relate the action to the
  subject of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26542-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs have a different meaning when they are used as reflexive verbs, e.g.,
  ‘anziehen’ and ‘sich anziehen’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26494-1
  a curric:KeyLearningPoint ;
  rdfs:label """A closed question is formed by swapping the position of the verb and subject in a
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26494-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add a question word in front of the verb to change a closed question into an open
  one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26494-3
  a curric:KeyLearningPoint ;
  rdfs:label """In questions with reflexive verbs, only subject and verb swap position, and the
  reflexive pronoun follows the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26494-4
  a curric:KeyLearningPoint ;
  rdfs:label """Future or modal (2-verb) questions swap the subject and 1st verb; the infinitive
  remains at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26494-5
  a curric:KeyLearningPoint ;
  rdfs:label """Varied intonation and accurate pronunciation matter in speaking and reading aloud;
  punctuation and understanding help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26444-1
  a curric:KeyLearningPoint ;
  rdfs:label "Turn an adjective into a comparative adjective by adding 'er'."@en ;
  dcterms:modified "2026-06-07T15:30:29.596714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26444-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some comparative adjectives are irregular."@en ;
  dcterms:modified "2026-06-07T15:30:29.596718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26444-3
  a curric:KeyLearningPoint ;
  rdfs:label "Add ‘-keit’ to adjectives to mean '–ty' or '-ness'."@en ;
  dcterms:modified "2026-06-07T15:30:29.596722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26444-4
  a curric:KeyLearningPoint ;
  rdfs:label "Add ‘-heit’ to adjectives to mean '–ty' or '–ness'."@en ;
  dcterms:modified "2026-06-07T15:30:29.596726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26498-1
  a curric:KeyLearningPoint ;
  rdfs:label """Future plans can be expressed by using the present tense with a future adverb of
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26498-2
  a curric:KeyLearningPoint ;
  rdfs:label """The adjective ‘nächst-’ takes different endings depending on the gender of the noun
  it is describing ('nächstes Jahr')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26498-3
  a curric:KeyLearningPoint ;
  rdfs:label """We translate the German present tense for future meaning into English using the
  present continuous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26498-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to plan carefully and to be able to write in three different time
  frames when writing a longer text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26498-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using the acronym BORDER is a good way to make sure you successfully cover every
  aspect of a writing task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26529-1
  a curric:KeyLearningPoint ;
  rdfs:label """German uses the simple present tense, formed by removing the '-en' from the
  infinitive and adding verb endings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26529-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separable verbs are made up of a prefix and a main verb. In the present, the prefix
  moves to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26529-3
  a curric:KeyLearningPoint ;
  rdfs:label """In word order three (WO3) clauses, the prefix and verb join up in separable
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26529-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives are used with nouns to show ownership or belonging. They must
  agree with the noun which follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26529-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the possessive adjective 'sein' with masculine or neuter nouns to mean 'its';
  use 'ihr' with feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26438-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the imperfect forms 'hatte', 'war', 'gab' to talk about the past instead of the
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26438-2
  a curric:KeyLearningPoint ;
  rdfs:label "Imperfect weak verbs are formed like 'lernen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.599235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26438-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imperfect strong verbs take the same endings as 'liegen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.599239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26505-1
  a curric:KeyLearningPoint ;
  rdfs:label """A direct object pronoun replaces a noun that is the object of the verb and is in the
  accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26505-2
  a curric:KeyLearningPoint ;
  rdfs:label """An indirect object pronoun replaces the noun that the verb action is done ‘to’ or
  ‘for’ and is in the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26505-3
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two objects that are nouns, the indirect object noun comes before
  the direct object noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26505-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two objects where there is one noun and one pronoun, the pronoun
  always comes first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26505-5
  a curric:KeyLearningPoint ;
  rdfs:label """The long [i] in ‘ihr’, ‘ihm’, ‘Ihnen’ sounds like ‘wir’, and the [eu] in ‘euch’
  sounds like ‘Deutschland’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The interrogative pronoun 'wer' becomes 'wen' when it is a direct object in the
  accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26458-2
  a curric:KeyLearningPoint ;
  rdfs:label """The interrogative pronoun 'wer' becomes 'wem' when it is an indirect object in the
  dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26458-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use a long [e] sound with 'wer', 'wen' and 'wem'."@en ;
  dcterms:modified "2026-06-07T15:30:29.599272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26458-4
  a curric:KeyLearningPoint ;
  rdfs:label """In questions with reflexive verbs, only subject and verb swap position. The
  reflexive pronoun now follows the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26458-5
  a curric:KeyLearningPoint ;
  rdfs:label """Where a verb is usually followed by a preposition, this comes before the question
  word, e.g., 'Mit wem?', 'Für wen?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26466-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Sie' is the polite way of saying 'you' and is a subject pronoun."@en ;
  dcterms:modified "2026-06-07T15:30:29.600847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26466-2
  a curric:KeyLearningPoint ;
  rdfs:label """The direct object pronoun for 'Sie' is also 'Sie'. The indirect object pronoun is
  'Ihnen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26466-3
  a curric:KeyLearningPoint ;
  rdfs:label "The interrogative pronoun 'wer' becomes 'wen' in the accusative."@en ;
  dcterms:modified "2026-06-07T15:30:29.600855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26466-4
  a curric:KeyLearningPoint ;
  rdfs:label "The interrogative pronoun 'wer' becomes 'wem' in the dative."@en ;
  dcterms:modified "2026-06-07T15:30:29.600859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26464-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Sobald' means 'as soon as' and 'solange' means 'as long as'."@en ;
  dcterms:modified "2026-06-07T15:30:29.601961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26464-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Sobald', 'solange' and 'wenn' are all WO3 conjunctions, sending the verb to the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Present, future and conditional tenses ('würd-' plus infinitive and 'möchte') can be
  used to talk about future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26464-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'wenn', 'sobald' and 'solange', plus 'würd- gern' and 'würd- lieber', to extend
  answers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26452-1
  a curric:KeyLearningPoint ;
  rdfs:label """To refer back to something inanimate already mentioned, add da- or dar- to the
  beginning of a preposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26452-2
  a curric:KeyLearningPoint ;
  rdfs:label """As a da-compound, 'damit' means ‘with it/them’. As a conjunction, 'damit' means 'so
  that'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26452-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use direct or indirect object pronouns, not da-compounds, to replace animate nouns
  (people or animals)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26452-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use wo- compounds to ask questions by adding wo- or wor- before the preposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.602337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26578-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and understanding texts needs attention to vocabulary, structures and a
  focus on required details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26578-2
  a curric:KeyLearningPoint ;
  rdfs:label """A distractor is a misleading detail in a text or question option which tests your
  understanding of the detail of a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26578-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use time phrases and verb tenses to distinguish between past, present and
  future actions and events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26578-4
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26578-5
  a curric:KeyLearningPoint ;
  rdfs:label """To develop answers, you can add information about another person, add a contrast or
  add another time frame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26488-1
  a curric:KeyLearningPoint ;
  rdfs:label "German [ch] can be soft or hard. The sound [ei] is pronounced like ‘frei’."@en ;
  dcterms:modified "2026-06-07T15:30:29.602926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26488-2
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -chen and -lein are added to make diminutive nouns. They often gain an
  umlaut and are always neuter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26488-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Wenn' means ‘when’, ‘whenever’ of ‘if’ and is used for repeated actions or
  conditions in the present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26488-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Als' means ‘when’ to refer to a specific past event or point in time."@en ;
  dcterms:modified "2026-06-07T15:30:29.602939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26488-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'als' and 'wenn' trigger word order 3, sending the finite verb to the end of
  the sentence or clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26480-1
  a curric:KeyLearningPoint ;
  rdfs:label "[qu] sounds like in 'bequem'."@en ;
  dcterms:modified "2026-06-07T15:30:29.603013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26480-2
  a curric:KeyLearningPoint ;
  rdfs:label "[w] sounds like in 'Antwort'."@en ;
  dcterms:modified "2026-06-07T15:30:29.603017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26480-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter combination 'kw' in German sounds like [qu], but only occurs in compound
  nouns, e.g., 'Trinkwasser'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26480-4
  a curric:KeyLearningPoint ;
  rdfs:label "Certain nouns are always followed by particular prepositions and cases."@en ;
  dcterms:modified "2026-06-07T15:30:29.603026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26480-5
  a curric:KeyLearningPoint ;
  rdfs:label "Certain adjectives are always followed by particular prepositions and cases."@en ;
  dcterms:modified "2026-06-07T15:30:29.603030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26579-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'Sie' for formal 'you' in statements, questions and the imperative."@en ;
  dcterms:modified "2026-06-07T15:30:29.603133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26579-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a closed question swap the position of 'Sie' and the verb. For open
  questions, add a question word at the start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26579-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the formal imperative, swap the position of 'Sie' and the verb. 'Sein' is
  irregular: 'Seien Sie!'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26579-4
  a curric:KeyLearningPoint ;
  rdfs:label """Intonation can help to make it clear whether you are asking a question, making a
  statement or giving an instruction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26579-5
  a curric:KeyLearningPoint ;
  rdfs:label """The imperative can be softened by adding 'bitte', 'mal', 'doch' or 'schon'. These
  help us to recognise instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26468-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following 'etwas', capitalise an adjective and add '-es' to turn it to a neuter
  adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26468-2
  a curric:KeyLearningPoint ;
  rdfs:label """Following 'alles', capitalise an adjective and add '-e' to turn it to a neuter
  adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26468-3
  a curric:KeyLearningPoint ;
  rdfs:label "German verbs can be nominalised as neuter nouns, and used with or without 'das'."@en ;
  dcterms:modified "2026-06-07T15:30:29.604328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26468-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives change spelling depending on case and gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.604332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26445-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ei] is pronounced like 'mein'."@en ;
  dcterms:modified "2026-06-07T15:30:29.605464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26445-2
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives describe who a noun belongs to."@en ;
  dcterms:modified "2026-06-07T15:30:29.605468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26445-3
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives change endings depending on gender and case."@en ;
  dcterms:modified "2026-06-07T15:30:29.605472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26445-4
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition ‘laut’ is followed by the dative."@en ;
  dcterms:modified "2026-06-07T15:30:29.605476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26431-1
  a curric:KeyLearningPoint ;
  rdfs:label "The SSCs [-ss-] and [-ß-] sound the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.605939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26431-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wissen' means to know with facts."@en ;
  dcterms:modified "2026-06-07T15:30:29.605946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26431-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Kennen' means to know someone or be familiar with something."@en ;
  dcterms:modified "2026-06-07T15:30:29.605950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26431-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Können' means to be able to, to know how to do something."@en ;
  dcterms:modified "2026-06-07T15:30:29.605955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26449-1
  a curric:KeyLearningPoint ;
  rdfs:label """We use direct object pronouns to replace a noun that is the object or 'receiver' of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26449-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct object pronouns are: mich-me, dich-you, ihn-him, it, sie-she,it, es-it,
  uns-us, euch-you, Sie-you and sie-them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26449-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consonantal [r] makes a rolling sound at the beginning of a word or syllable and
  after a consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26449-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vocalic [r] has a gentle ‘ah’ sound after after a long vowel sound, in prefixes -er
  and -ver, and at the end of words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26487-1
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'in' is followed by the accusative case if there is movement, and by
  the dative if there is no movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26487-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prepositions 'zu', 'nach' and 'in' can all mean 'to'."@en ;
  dcterms:modified "2026-06-07T15:30:29.606692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26487-3
  a curric:KeyLearningPoint ;
  rdfs:label """'In das' contracts to 'ins' and 'in dem' contracts to 'im'. 'Zu dem' contracts to
  'zum' and 'zu der' contracts to 'zur'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26487-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Zu Hause’ means ‘at home’ and ‘nach Hause’ is used for 'going (to) home'."@en ;
  dcterms:modified "2026-06-07T15:30:29.606702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use wo-compounds to ask questions with prepositions. Wo- becomes wor- before a
  vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26490-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the 12 hour or the 24 hour clock to tell the time in German. Use 'um' to say
  ‘at’ with clock times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26490-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Um' can also mean ‘around’ or ‘approximately’ when used with numbers, and is
  normally followed by the definite article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26490-3
  a curric:KeyLearningPoint ;
  rdfs:label """When referring to a place, 'um' means ‘around’ and is always followed by the
  accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26490-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Seit' is used with present tense to express an unfinished action started in the
  past. It can mean ‘since’ or ‘for’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26490-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Vor' + length of time is used with past tense to say how long ago something
  happened. Use the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26433-1
  a curric:KeyLearningPoint ;
  rdfs:label """To make single syllable feminine nouns plural, add '–e' and an umlaut where
  possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26433-2
  a curric:KeyLearningPoint ;
  rdfs:label "To make nouns ending in  '–nis' plural, add –se."@en ;
  dcterms:modified "2026-06-07T15:30:29.607710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26433-3
  a curric:KeyLearningPoint ;
  rdfs:label "To make some neuter nouns plural, add  '-(e)n'."@en ;
  dcterms:modified "2026-06-07T15:30:29.607714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26433-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use any German infinitive as a noun by nominalising it as a neuter noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.607718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26433-5
  a curric:KeyLearningPoint ;
  rdfs:label "To turn noun-verb phrases to nouns, create compound nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.607723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29165-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29165-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look out for tricky sounds and cognates, and mentally rehearse before
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29165-3
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29165-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29165-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26539-1
  a curric:KeyLearningPoint ;
  rdfs:label "Strong verbs form past participles with 'ge-' and '-en' in the perfect tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.614929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26539-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs have a vowel change in their past participle, such as 'ei' → 'ie', 'ie' →
  'o', 'i' → 'u' or 'e' → 'o'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26539-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form a closed question in the perfect tense, swap the position of 'haben' or
  'sein' with the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26539-4
  a curric:KeyLearningPoint ;
  rdfs:label """For open questions in the perfect tense, place a question word before 'haben' or
  'sein'; the subject follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26427-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add '-e', with or without an umlaut, to make most masculine nouns and some neuter
  nouns plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26427-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending  '-el', '-en' or '-er' may not change in the plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.614993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26427-3
  a curric:KeyLearningPoint ;
  rdfs:label "To make most feminine nouns plural, add '-n' or '-en'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26531-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pronunciation is important for clear communication. Pay particular attention to the
  pronunciation of cognates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26531-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the future tense, use the present tense of werden to mean 'will/going to’
  and an infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26531-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use a future time phrase with the present tense to mean 'going to' or ‘-ing’, e.g.,
  'tomorrow I’m doing my homework'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26531-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Ich will' (from the verb 'wollen') means 'I want to', but is a false friend; 'ich
  werde' is 'I will'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26559-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the comparative to make comparisons. Add '-er' to adjectives or adverbs to form
  the comparative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26559-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'als' to say 'than', e.g., 'die Maus ist kleiner als die Katze'."@en ;
  dcterms:modified "2026-06-07T15:30:29.617239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26559-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the superlative to express the highest degree of something, e.g., 'the most
  interesting', 'the best'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26559-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'am' and add '-sten' to the adjective/adverb if used after a verb or noun, e.g.,
  'ich spiele am liebsten Fußball'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26552-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nicht' before definite articles to mean ‘not the’ and 'kein' instead of the
  indefinite article to mean 'not a, no'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26552-2
  a curric:KeyLearningPoint ;
  rdfs:label """Place 'nicht' before adjectives, adverbs, possessives and proper nouns. Place
  'nicht' after verbs and whole phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26552-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'nichts' to mean 'nothing' or 'not anything', e.g., 'ich sehe nichts'."@en ;
  dcterms:modified "2026-06-07T15:30:29.618300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use word order two if starting a sentence with something other than the subject,
  e.g., an adverb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26552-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use your knowledge of German pronunciation and punctuation to support your
  intonation when reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26544-1
  a curric:KeyLearningPoint ;
  rdfs:label """A closed question, also known as a yes/no question, is formed by swapping the
  position of the verb and subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26544-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'du' questions for informal singular ‘you’, 'ihr' questions for informal plural
  ‘you’, and 'Sie' for formal 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26544-3
  a curric:KeyLearningPoint ;
  rdfs:label """When responding to questions about yourself, change the 2nd person language to 1st
  person language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26544-4
  a curric:KeyLearningPoint ;
  rdfs:label """When answering questions, you may need to change subject pronouns, verbs, possessive
  adjectives and reflexive pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26550-1
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition ‘laut’ means 'according to' and is followed by the dative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.618331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26550-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dative definite articles are: 'dem', 'der', 'dem', 'den'. 'Dies-' follows the
  same pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26550-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dative indefinite articles are: 'einem', 'einer', 'einem'. Possessives follow
  the same pattern as these articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26550-4
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'laut' can be used to report what we have understood from texts,
  pictures, or from other people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26550-5
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [au], as in 'laut', sounds like 'Haus'."@en ;
  dcterms:modified "2026-06-07T15:30:29.618350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26497-1
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs in the present tense change the stem vowel in the 2nd and 3rd person
  singular: e - i, e - ie, or a - ä."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'du' questions for informal singular ‘you’, and 'ihr' questions for informal
  plural ‘you’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26497-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs retain the present tense stem vowel change in the 'du' form of the
  imperative but they omit the umlaut."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26497-4
  a curric:KeyLearningPoint ;
  rdfs:label """To use the 'ihr' form of the imperative of weak and strong verbs, just remove the
  pronoun 'ihr'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26497-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' is irregular in the 'du' form of the imperative. Use 'sei' for the 'du' form
  and 'seid' for the 'ihr' form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26535-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Wissen' means to 'to know' facts. 'Kennen' means 'to know' someone or to be
  familiar with something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26535-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect verb stem of 'wissen' is 'wuss-'; 'kennen' is 'kann-'. Use weak
  imperfect endings with both verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26535-3
  a curric:KeyLearningPoint ;
  rdfs:label """The past participle of 'wissen' is 'gewusst'; 'kennen' is 'gekannt'. Both form the
  perfect tense with 'haben'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26535-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reading an extended text, notice tenses and vocabulary. Focus on questions
  carefully to identify required details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26422-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some nouns behave like adjectives and take the same endings."@en ;
  dcterms:modified "2026-06-07T15:30:29.619234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26422-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sein' is irregular in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.619238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26422-3
  a curric:KeyLearningPoint ;
  rdfs:label "Present tense weak verbs are formed like 'lernen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26478-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some nouns such as 'Physik' do not have plurals."@en ;
  dcterms:modified "2026-06-07T15:30:29.619554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26478-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs that start in 'be-', 'ent-' or 'er-' have inseparable prefixes in the perfect
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26478-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Gehen' can be combined with other infinitives such as 'schwimmen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.619562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26478-4
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles of separable verbs are one word - prefix first then the past
  participle of main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26527-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are 16 Bundesländer (states) in Germany, 9 in Austria and 26 Kantone (states)
  in Switzerland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26527-2
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives are used with nouns to show ownership or belonging. They must
  agree with the noun which follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26527-3
  a curric:KeyLearningPoint ;
  rdfs:label """To translate 'its', use 'sein' with masculine or neuter nouns, and 'ihr' with
  feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26527-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs express ideas of necessity or possibility. Use them with a 2nd verb in
  the infinitive at the sentence's end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26527-5
  a curric:KeyLearningPoint ;
  rdfs:label """Apply the two-verb rule if there are two verbs in a sentence. The second verb goes
  to the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26507-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectival nouns, like adjectives, change according to gender, case and the article
  used with them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26507-2
  a curric:KeyLearningPoint ;
  rdfs:label """Following 'wenig' or 'viel' , capitalise an adjective and add '-es' to turn it to a
  neuter adjectival noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26507-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix '-los' to nouns to create adjectives meaning '-less' or
  'without -'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26507-4
  a curric:KeyLearningPoint ;
  rdfs:label """[v] in 'viel' is pronounced like English 'f' as in 'Vater', [w] in 'wenig' is
  pronounced like English 'v' as in 'Welt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26507-5
  a curric:KeyLearningPoint ;
  rdfs:label """[ig] at the end of a word is pronounced as in 'richtig' and a final [s] sounds like
  the English 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26518-1
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs form past participles with 'ge-' and '-en'. Some have a vowel change,
  such as 'ei' to 'ie' or 'ie' to 'o'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26518-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is usually used in written texts for narration. The perfect
  tense is much more common in speaking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26518-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense forms ‘hatte’, ‘war’, and ‘es gab’ are often used in spoken as
  well as written German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26518-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'gerade' with the perfect tense to mean 'just (now)'."@en ;
  dcterms:modified "2026-06-07T15:30:29.620983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'gerade' with the imperfect tense to express that the action was taking place
  when something else happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26549-1
  a curric:KeyLearningPoint ;
  rdfs:label """Turn an adjective into a comparative adjective by adding '-er', e.g.,
  'schneller'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26549-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'than' when making a comparison, use 'als', e.g., 'meine Stadt ist größer als
  dein Dorf'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26549-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives also gain an umlaut in the comparative form, e.g., 'jünger'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26549-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending -el or -er remove the penultimate ‘e’, e.g., 'teurer',
  'dunkler'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26549-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparatives can be useful for developing opinions, reasons and ideas when writing
  descriptions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26533-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use word order one with the conjunctions 'und', 'oder', 'aber', 'denn'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26533-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use word order three with the conjunctions 'weil', 'obwohl', 'dass', 'wenn', 'ob',
  'da'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26533-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use word order two if starting a sentence with something other than the subject,
  e.g., an adverb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26533-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives are used before a noun to show ownership or belonging. They
  agree with the noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26533-5
  a curric:KeyLearningPoint ;
  rdfs:label """The genitive case form of possessive adjectives means 'of...', e.g., 'meines Vaters'
  means 'of my father'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26519-1
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive verbs can be turned into nouns and correspond to English '-ing' nouns,
  e.g., 'das Lesen' - 'reading'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26519-2
  a curric:KeyLearningPoint ;
  rdfs:label """To mean 'while' or 'in the process of' doing something, use 'beim' before a
  nominalised infinitive, e.g., 'beim Lesen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26519-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'am' as an alternative to 'beim' before a nominalised verb, but only when a
  single activity is being done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26519-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of 'beim' or 'am' plus the nominalised verb indicates the activity is, or
  was, ongoing or unfinished."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26519-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Deutschrap’ is a form of hip-hop which originates from the 1980s. ‘Rock am Ring’ is
  a famous music festival in Germany."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs follow the order time, manner, place; using TMP with all tenses can work
  well to describe sequences of events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26485-2
  a curric:KeyLearningPoint ;
  rdfs:label """Any adverb can start a sentence for emphasis. In this case, use word order 2 and
  order the remaining adverbs using TMP."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26485-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use a verb with ‘gern’ to mean ‘like’, ‘lieber’ to mean ‘prefer’ and ‘am liebsten’
  to mean ‘most preferably of all’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the adverbs gern, lieber, am liebsten to develop and extend opinions on a range
  of themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26517-1
  a curric:KeyLearningPoint ;
  rdfs:label """[sch] is pronounced like English 'sh', as in 'schreiben' and [sp] sounds like
  English 'sh' before 'p', as in 'spielen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26517-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the start of a word, and in compound nouns and some verbs, [st] sounds like the
  English 'sht', as in ‘stark'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26517-3
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26517-4
  a curric:KeyLearningPoint ;
  rdfs:label """To develop answers, you can add information about another person, add a contrast or
  add another time frame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26517-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can extend written answers by adding a subordinate clause, a relative clause, or
  an infinitive construction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26511-1
  a curric:KeyLearningPoint ;
  rdfs:label """To talk about what you like in the present tense, use the irregular verb
  'mögen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26511-2
  a curric:KeyLearningPoint ;
  rdfs:label """The forms of 'mögen' are: 'ich mag', 'du magst', 'er, sie, es mag', 'wir mögen',
  'ihr mögt', 'Sie, sie mögen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26511-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conditional form of 'mögen' is 'möcht-' and this is used to talk about what you
  would like or would like to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26511-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-' can be used without a second verb, to express what you would like: for
  example, in a café or when shopping."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26511-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-' is also commonly used with a second verb in the infinitive to express
  future wishes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26459-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs express necessity, possibility, expectation or obligation and are used
  with a 2nd verb in the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26459-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Müssen' means ‘to have to, must’ and expresses necessity."@en ;
  dcterms:modified "2026-06-07T15:30:29.622226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26459-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Sollen' translates as ‘should’ and conveys strong obligation or command but also
  expresses probability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26459-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Sollte' expresses a softer style of obligation and may be translated as
  ‘ought to’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26577-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'obwohl', meaning 'although', triggers word order 3, sending the
  verb to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26577-2
  a curric:KeyLearningPoint ;
  rdfs:label """If 'obwohl' starts the sentence, use verb-comma-verb word order when linking to the
  next clause or sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26577-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Obwohl' can be used to develop and extend ideas by linking two sentences
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26577-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play, you are required to say a short phrase in response to each
  prompt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26577-5
  a curric:KeyLearningPoint ;
  rdfs:label """You must include at least one verb in each role-play answer, and you have to ask at
  least one question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26581-1
  a curric:KeyLearningPoint ;
  rdfs:label """A strong knowledge of vocabulary is key to all language skills. It can be helpful to
  categorise words by theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26581-2
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26581-3
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo in German, translate the English present continuous with the
  German simple present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26581-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make a photo description more interesting and complex, add your own impressions
  (opinions, thoughts and reasons)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26513-1
  a curric:KeyLearningPoint ;
  rdfs:label """The determiner 'welch-' means 'which'. Its ending changes according to the gender
  and case of the noun that follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26513-2
  a curric:KeyLearningPoint ;
  rdfs:label """The determiner 'dies-' means ‘this’. Its ending changes in the same way as 'welch-'
  ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26513-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Welch-' and 'dies-' are very helpful for identifying items when shopping."@en ;
  dcterms:modified "2026-06-07T15:30:29.622514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26513-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play, it is important to include at least one verb in each short phrase.
  You must also ask one question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26513-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Sowohl...als auch...' means 'both...and...', 'derselbe, dieselbe, dasselbe' mean
  'the same' and 'jene(r)' means 'that'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26576-1
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs form the imperfect tense by adding these endings to the verb stem: -te,
  -test, -te, -ten, -tet, -ten."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26576-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have irregular stems in the imperfect tense, with vowel changes and
  endings: -, st, -, en, t, en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26576-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs ‘sein’, ‘haben’, modal verbs and 'es gab' are commonly used in spoken as
  well as written German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26576-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'es gibt' to mean 'there is, are' and 'es gab' to mean 'there was, were',
  followed by the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26576-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'es gibt' and 'es gab' to contrast present and past."@en ;
  dcterms:modified "2026-06-07T15:30:29.622548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26516-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in a main clause, without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26516-2
  a curric:KeyLearningPoint ;
  rdfs:label """German uses definite articles as the relative pronouns, preceded by a comma and
  followed by word order 3."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26516-3
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb clauses, the finite (conjugated) verb goes to the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26516-4
  a curric:KeyLearningPoint ;
  rdfs:label """Question words, such as 'wo', 'warum' and 'wann' can also be used as pronouns in
  relative clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26516-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'was' to mean 'that' or 'which' when referring to a whole clause, rather than to
  a specific noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26504-1
  a curric:KeyLearningPoint ;
  rdfs:label """Grouping new vocabulary by word class and exploring word families is a useful tool
  for committing vocabulary to memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26504-2
  a curric:KeyLearningPoint ;
  rdfs:label """The accusative case is used for the direct object of a verb; the person or thing
  receiving the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26504-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dative case is used for the indirect object of a verb; the person or thing to or
  for whom something is done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26504-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with two object nouns, the indirect object noun always comes before the
  direct object noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26504-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating into English, some but not all verbs need ‘to’ or ‘for’ before the
  indirect object noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26423-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is just one present tense in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.632187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26423-2
  a curric:KeyLearningPoint ;
  rdfs:label "Time adverbs help to translate German present tense accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.632193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26423-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subject and verb swap to make yes/no questions in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.632198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26553-1
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring relationships between words supports your understanding of language in
  different contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26553-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective agreement occurs when adjectives precede a noun. Do not add endings to
  adjectives after a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26553-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective endings change depending on the gender, case and number of the noun they
  describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26553-4
  a curric:KeyLearningPoint ;
  rdfs:label """Neuter adjectival nouns express abstract concepts and use the ending '-e' in
  nominative and accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26553-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plural adjectival nouns end in '-en' after 'die'. Without articles, use '-e' in
  nominative and accusative; '-en' dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26448-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use possessive adjectives frequently when talking about friends and family."@en ;
  dcterms:modified "2026-06-07T15:30:29.632223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26448-2
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb ‘gern’ is used with a verb to mean ‘like’; ‘lieber’ with a verb means
  ‘prefer’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26448-3
  a curric:KeyLearningPoint ;
  rdfs:label "Add –er to turn adverbs into comparatives."@en ;
  dcterms:modified "2026-06-07T15:30:29.632234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26448-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense in German is used most often to narrate past events in writing,
  so is often used in stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26448-5
  a curric:KeyLearningPoint ;
  rdfs:label """When answering conversation questions, strong answers are full sentences including
  extra detail, opinions and reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26512-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cardinal numbers are numbers used for counting or expressing quantity. Ordinal
  numbers tell us the order of something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26512-2
  a curric:KeyLearningPoint ;
  rdfs:label """For numbers 13-99, say the 2nd digit first e.g., 'vierundzwanzig' = '24'. For 21-99,
  add ‘und’ between the two numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26512-3
  a curric:KeyLearningPoint ;
  rdfs:label """For prices, place the € after the numbers and separate euros and cents with a comma.
  Always say 'Euro' in the singular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26512-4
  a curric:KeyLearningPoint ;
  rdfs:label """For ordinal numbers, add -te for numbers 1-19 and -ste for 20+. To say 'on' a date,
  use 'am' and add -n to the number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26512-5
  a curric:KeyLearningPoint ;
  rdfs:label """KaDeWe is short for 'Kaufhaus des Westens' and is a famous large department store in
  Berlin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26543-1
  a curric:KeyLearningPoint ;
  rdfs:label "Imperative verbs are used to give instructions, directions, or advice."@en ;
  dcterms:modified "2026-06-07T15:30:29.632939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26543-2
  a curric:KeyLearningPoint ;
  rdfs:label """For the ‘du’ imperative of weak and strong verbs, remove the ‘-st’ and the 'du'.
  Omit umlauts added as a stem change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26543-3
  a curric:KeyLearningPoint ;
  rdfs:label """To use the 'ihr' form of the imperative of weak and strong verbs, just remove the
  pronoun 'ihr'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26543-4
  a curric:KeyLearningPoint ;
  rdfs:label """To use the formal 'Sie' form of the imperative, swap the position of the verb and
  subject pronoun 'Sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26543-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' is irregular in the 'du' and 'Sie' forms of the imperative. Use 'sei', 'seid'
  and 'Seien Sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26440-1
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of '-ieren' verbs don't start with 'ge-'. They end with
  '-iert'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26440-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use adverbs like 'nie', 'schon', and 'noch nicht' with the perfect tense to provide
  more information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26440-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many '-ieren' verbs are near cognates."@en ;
  dcterms:modified "2026-06-07T15:30:29.632970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26509-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are nine rules for forming plurals in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.633204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26509-2
  a curric:KeyLearningPoint ;
  rdfs:label "Uncountable nouns do not have a plural form."@en ;
  dcterms:modified "2026-06-07T15:30:29.633208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26509-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the quantifiers 'viel' and 'wenig' for uncountable nouns, use 'viele' and
  'wenige' for countable nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26509-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Viel' and 'wenig' do not change according to gender or case, but plural 'viele' and
  'wenige' do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26509-5
  a curric:KeyLearningPoint ;
  rdfs:label """When reading aloud it is helpful to identify and correctly pronounce umlauts, which
  are common in plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26573-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs express necessity or possibility. Use them with a 2nd verb in the
  infinitive at the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26573-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Dürfen' refers to permission required from another person. 'Können' refers to the
  ability to do something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26573-3
  a curric:KeyLearningPoint ;
  rdfs:label """The stems of modal verbs are irregular, with vowel changes in most singular forms.
  'Sollen' is the exception."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26573-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are mostly used in the imperfect tense when they describe past events.
  Remove any umlauts in the imperfect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26573-5
  a curric:KeyLearningPoint ;
  rdfs:label """[w] sounds like 'Welt', [qu] is pronounced the same as [kw] and sounds like
  'bequem', and [zw] sounds like 'zwanzig'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26530-1
  a curric:KeyLearningPoint ;
  rdfs:label """German uses the perfect tense to describe most past events, but English uses simple
  past for specific, completed events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26530-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form the perfect tense with a present tense of 'haben' or 'sein', plus a past
  participle at the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26530-3
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs form past participles by sandwiching the verb stem with 'ge-' and '-t'.
  '-ieren' verbs don't add 'ge-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26530-4
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs form past participles with 'ge-' and '-en'. Separable prefixes go
  before 'ge-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26530-5
  a curric:KeyLearningPoint ;
  rdfs:label """The order of adverbs in a sentence is time ('um 6 Uhr'), manner ('mit Freunden'),
  place ('im Haus')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26508-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say what you would do, use 'würde' to mean ‘would’ and an infinitive verb at the
  end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26508-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'würde' plus 'gern' to talk about what you would like to do and 'würde' plus
  'lieber' to say what you would prefer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26508-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'hätte' to mean ‘would have’, and 'wäre' to mean ‘would be’. No infinitive verb
  is needed, unlike with 'würde'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26508-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Sollte' is the conditional form of the modal verb ‘sollen’. It is used to convey
  what we ‘ought to’ or ‘should’ do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26491-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive pronouns relate the action of the verb back to the subject, so subject and
  object are the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26491-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the action of the verb is reciprocal, or two-way, reflexive pronouns can also
  mean ‘each other’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26491-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the perfect tense, the reflexive pronoun usually comes after the first
  (auxiliary) verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26491-4
  a curric:KeyLearningPoint ;
  rdfs:label """To change a noun into an adverb to describe regular events, remove its capital
  letter and add '-s' to the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26491-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a role play, say a short phrase in response to each prompt and include at least
  one verb in each phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26555-1
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense uses the present tense of 'sein' or 'haben' plus a past
  participle, and is used in speech and writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26555-2
  a curric:KeyLearningPoint ;
  rdfs:label """The single-verb simple past or imperfect tense in German is used most often to
  narrate past events in writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26555-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Seit', with dative and present tense, expresses an unfinished action started in the
  past. It can mean ‘since’ or ‘for'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26555-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Vor' + length of time is used with past tense to say how long ago something
  happened. Use the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26555-5
  a curric:KeyLearningPoint ;
  rdfs:label """These structures provide a framework for discussing the history and developments in
  international human rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633517Z"^^xsd:dateTime .

