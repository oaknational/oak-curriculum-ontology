  dcterms:modified "2026-06-07T15:30:41.119113Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26530
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form the perfect tense of different types of verbs and describe a past trip
  using adverbs of time, manner and place."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119118Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26508
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the conditional with 'würde' alongside 'hätte', 'wäre' and 'sollte' to
  discuss choices related to health."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119123Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26491
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use reflexive verbs in the past and present, form time adverbs of time from
  nouns and prepare role play answers in the context of meeting up with friends."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119127Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26555
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the simple past and perfect tenses and 'seit' and 'vor' to understand the
  historical context and recent changes relating to international human rights."""@en ;
  dcterms:modified "2026-06-07T15:30:41.119132Z"^^xsd:dateTime .

