  dcterms:modified "2026-06-07T15:30:41.075701Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26443
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use possessive adjectives to talk about family."@en ;
  dcterms:modified "2026-06-07T15:30:41.077091Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26506
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use adjectives as adverbs and create ‘-keit’ and ‘-heit’ nouns from adjectives
