  dcterms:modified "2026-06-07T15:30:41.075327Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26583
  a curric:PupilLessonOutcome ;
  rdfs:label """I can transcribe and understand German speakers tolking in a range of contexts about
