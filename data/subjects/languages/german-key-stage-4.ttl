oakcurric:keylearningpoint-lesson-26599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix -ung to a verb stem to form a feminine noun with equivalent meaning,
  e.g., 'lösen' - 'die Lösung'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add suffix -er to a verb stem to form a male agent noun with equivalent meaning,
  e.g., 'übersetzen' - 'der Übersetzer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix -keit / -heit to adjectives to form feminine nouns meaning -ty or
  -ness, e.g., 'krank' - 'die Krankheit'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix -chen or -lein to a noun to mean 'little'. These diminutive nouns are
  neuter and often gain an umlaut."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26599-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extend answers in conversation to 3 clauses by using a different tense, a different
