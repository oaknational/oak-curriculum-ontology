  dcterms:modified "2026-06-07T15:30:41.077861Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26442
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my knowledge of various grammar features to translate a text about a
  famous German speaker."""@en ;
  dcterms:modified "2026-06-07T15:30:41.078805Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26565
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use word order 1 and 3 with two-verb structures when talking about the
  challenges of daily life for people with illnesses whose symptoms are often unseen."""@en ;
  dcterms:modified "2026-06-07T15:30:41.078821Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26571
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use articles after prepositions and da-compounds to understand and describe
  where people are and what they are doing in the context of biodiversity."""@en ;
  dcterms:modified "2026-06-07T15:30:41.078939Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26500
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a range of infinitive 'zu' clauses and compound conjunctions to discuss
  post-16 options and plans."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079108Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26502
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use modal verbs to talk about what I want, must, and can do, describe a photo
  and develop my answers in conversation about future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079116Z"^^xsd:dateTime .

