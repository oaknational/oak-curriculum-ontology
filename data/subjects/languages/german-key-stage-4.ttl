  dcterms:modified "2026-06-07T15:30:29.360771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29180-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
