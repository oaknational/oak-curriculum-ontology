  dcterms:modified "2026-06-07T15:30:41.069069Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26568
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use da-compounds and the conjunction 'damit' when discussing examples of
