oakcurric:unit-2958
  a curric:Unit ;
  rdfs:label "Communication and the world around us: Wiederholung: Online Leben"@en ;
  curric:slug "communication-and-the-world-around-us-online-leben" ;
  rdfs:comment """This unit continues to revisit known grammar and vocabulary from the entire
  course, this time focusing on question formation and application of knowledge in extended
  speaking."""@en ;
  curric:whyThisWhyNow """In this unit, pupils revisit their previous knowledge in the context of
  social media and technology in everyday life. Pupils apply their knowledge across a range of
  common threads, including asking and answering spoken questions, transcription, listening and
  responding to longer passages and describing pictures.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2958-1 ,
    oakcurric:priorknowledge-2958-2 ,
    oakcurric:priorknowledge-2958-3 ,
