  dcterms:modified "2026-06-07T15:30:02.423067Z"^^xsd:dateTime .

oakcurric:keyword-viel-viele
  a curric:Keyword ;
  schema:name "viel, viele"@en ;
  schema:description "a lot, many"@en ;
  dcterms:modified "2026-06-07T15:30:02.424136Z"^^xsd:dateTime .

oakcurric:keyword-kennen
  a curric:Keyword ;
  schema:name "kennen"@en ;
  schema:description "verb meaning 'to know' someone or to be familiar with something"@en ;
