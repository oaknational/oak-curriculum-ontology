  dcterms:modified "2026-06-07T15:30:41.077529Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26450
  a curric:PupilLessonOutcome ;
  rdfs:label "I can ask and answer questions using da- and wo-compounds."@en ;
  dcterms:modified "2026-06-07T15:30:41.077579Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26538
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a variety of strategies to decipher the meaning of unfamiliar vocabulary
