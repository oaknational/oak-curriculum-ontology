  a curric:Keyword ;
  schema:name "lernen"@en ;
  schema:description """an example of a weak verb in the present tense, meaning ‘to learn,
  learning'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424314Z"^^xsd:dateTime .

oakcurric:keyword-strong-verb-imperfect-tense
  a curric:Keyword ;
  schema:name "strong verb (imperfect tense)"@en ;
  schema:description "verb which changes the stem vowel in the imperfect tense, e.g., ‘blieb’"@en ;
  dcterms:modified "2026-06-07T15:30:02.424676Z"^^xsd:dateTime .

oakcurric:keyword-gerade
  a curric:Keyword ;
  schema:name "gerade"@en ;
  schema:description "adverb meaning 'just (now)'"@en ;
