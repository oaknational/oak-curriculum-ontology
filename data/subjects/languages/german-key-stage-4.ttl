    oakcurric:thread-the-future-and-conditional ,
    oakcurric:thread-word-order ,
    oakcurric:thread-extend-written-and-spoken-production .

oakcurric:unit-2951
  a curric:Unit ;
  rdfs:label "Communication and the world around us: mein Wohnort"@en ;
  curric:slug "communication-and-the-world-around-us-mein-wohnort" ;
  rdfs:comment """This unit consolidates known grammar and vocabulary, including past and present
  tenses, direct and indirect object pronouns, and comparatives, as pupils explore new
  places. Pupils also learn the imperative in the formal 'Sie' form."""@en ;
  curric:whyThisWhyNow """Pupils apply previously taught grammar in a number of different contexts,
  including gap years and volunteering, and exploring places and customs. Pupils revisit the
  past and present tenses, ask and answer spoken questions, and develop confidence in listening
  and responding to longer passages.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2951-1 ,
    oakcurric:priorknowledge-2951-2 ,
    oakcurric:priorknowledge-2951-3 ,
