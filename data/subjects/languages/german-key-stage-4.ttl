  schema:description "case used to indicate possession and after certain prepositions"@en ;
  dcterms:modified "2026-06-07T15:30:02.416600Z"^^xsd:dateTime .

oakcurric:keyword-historic-present
  a curric:Keyword ;
  schema:name "historic present"@en ;
