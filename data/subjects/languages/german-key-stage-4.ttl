    oakcurric:priorknowledge-2946-5 ,
    oakcurric:priorknowledge-2946-6 ,
    oakcurric:priorknowledge-2946-7 ;
  curric:id "2946"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.272784Z"^^xsd:dateTime ;
  curric:isUnitOf
    oakcurric:scheme-languages-key-stage-4 ;
