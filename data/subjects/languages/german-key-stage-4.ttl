# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-26426-1
  a curric:KeyLearningPoint ;
  rdfs:label "The German [v] sounds like the English [f]."@en ;
  dcterms:modified "2026-06-07T15:30:29.003839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26426-2
  a curric:KeyLearningPoint ;
  rdfs:label "The German [w] sounds like the English [v]."@en ;
  dcterms:modified "2026-06-07T15:30:29.003843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26426-3
  a curric:KeyLearningPoint ;
  rdfs:label "Open questions use a question word before the verb followed by the subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.003847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26482-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries and some abstract nouns use the definite article."@en ;
  dcterms:modified "2026-06-07T15:30:29.004280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26482-2
  a curric:KeyLearningPoint ;
  rdfs:label "The indefinite article is not used in German for professions or nationalities."@en ;
  dcterms:modified "2026-06-07T15:30:29.004284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26482-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the indefinite article with professsions if there is an adjective before the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26482-4
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26482-5
  a curric:KeyLearningPoint ;
  rdfs:label """In conversation, develop answers by adding opinions and reasons, varying the
  subject, and adding different time frames."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26534-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Es gibt' means ‘there is’ and ‘there are’. It is a general statement that something
  exists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26534-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'da ist' and 'da sind' to point out what there is in a specific place, at a
  specific moment in time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26534-3
  a curric:KeyLearningPoint ;
  rdfs:label """Determiners such as 'jed-', 'letzt-' and 'nächst-' change their endings according to
  gender and case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26534-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use dative endings after the preposition 'bei', e.g., 'bei dem (beim)
  nächsten Mal'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26534-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the correct case after dual-case prepositions such as 'in', 'an', 'auf' to
  ensure the intended meaning is clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26556-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'obwohl' triggers word order 3, which sends the verb to the end of
  the sentence or clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26556-2
  a curric:KeyLearningPoint ;
  rdfs:label """When combined with a second verb in the infinitive, some verbs require the addition
  of 'zu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26556-3
  a curric:KeyLearningPoint ;
  rdfs:label "Infinitive constructions are separated from other clauses with a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.004678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26556-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'um … zu' + infinitive to mean 'in order to, 'statt ... zu' for 'instead of',
  'ohne ... zu' for 'without'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26472-1
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, the reflexive pronoun normally comes after the first
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26472-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the perfect tense, it is more common to use the simple past versions of ‘haben’,
  ‘sein’, and ‘es gibt’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26472-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use ‘früher’ in the perfect and imperfect tenses to mean ‘used to’."@en ;
  dcterms:modified "2026-06-07T15:30:29.004784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26472-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use ‘gern’, ‘lieber’, ‘am liebsten’ in the perfect and imperfect tenses to talk
  about likes and preferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26473-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some past participles are irregular."@en ;
  dcterms:modified "2026-06-07T15:30:29.251738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26473-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the imperfect tense, the stem of 'mögen' is 'moch-'. It still takes the regular
  imperfect tense endings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26473-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Mochte' is normally followed by a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.251748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26473-4
  a curric:KeyLearningPoint ;
  rdfs:label "In the perfect tense, ‘mögen’ becomes 'gemocht' and means ‘liked’."@en ;
  dcterms:modified "2026-06-07T15:30:29.251753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26473-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'gefallen' in the perfect tense to mean ‘liked’. Use indirect object pronouns
  with 'gefallen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29183-1
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29183-2
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29183-3
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed response in conversation has at least three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.251783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29183-4
  a curric:KeyLearningPoint ;
  rdfs:label """Extend your answers by using a different tense, a different subject, or opinions and
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26486-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prepositions hinter, neben, unter, über, vor, zwischen and in are used with the
  accusative when there is movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26486-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prepositions hinter, neben, unter, über, vor, zwischen and in are used with the
  dative when there is no movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26486-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Vor' can mean 'before', 'in front of' or 'ago'."@en ;
  dcterms:modified "2026-06-07T15:30:29.252110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26486-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use da-compounds for inanimate nouns already mentioned. Use direct or indirect
  object pronouns for animate nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix '-los' to nouns to create adjectives meaning '-less' or
  'without -'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some '-los' adjectives can be translated directly, but some have other English
  adjectives with equivalent meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26575-3
  a curric:KeyLearningPoint ;
  rdfs:label "The subject pronoun 'man' is used to mean 'people' or 'you' as well as 'one'."@en ;
  dcterms:modified "2026-06-07T15:30:29.253048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26575-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'man + verb' to translate English phrases that do not specify a particular
  subject, e.g., 'It is said that ... '."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26575-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Man' is used far more commonly in German than the English subject pronoun
  ‘one’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26566-1
  a curric:KeyLearningPoint ;
  rdfs:label "Weak verbs follow a regular pattern of changes in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.253062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26566-2
  a curric:KeyLearningPoint ;
  rdfs:label """For verbs stems ending in 'd', ‘t', 'm' or 'n', add 'e' before the ending in the
  'du', 'er, sie, es' and 'ihr' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26566-3
  a curric:KeyLearningPoint ;
  rdfs:label """For verb stems ending in 's', 'ß', 'x' or 'z', add just 't' instead of 'st' in the
  'du' form, e.g., 'du tanzt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26566-4
  a curric:KeyLearningPoint ;
  rdfs:label """For verb stems ending in '-el', remove the 'e' in the first person singular of the
  present tense, e.g., 'ich lächle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26566-5
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26474-1
  a curric:KeyLearningPoint ;
  rdfs:label """To make a yes/no question in the perfect tense, swap the form of ‘sein’ or ‘haben’
  with the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26474-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ask an information question in the perfect tense, use a question word followed by
  ‘sein’ or ‘haben’ then the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26474-3
  a curric:KeyLearningPoint ;
  rdfs:label "In word order 2, invert the subject and verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.254101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26496-1
  a curric:KeyLearningPoint ;
  rdfs:label "Weak verbs follow a regular pattern of changes in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.254457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26496-2
  a curric:KeyLearningPoint ;
  rdfs:label """For verbs stems ending in 'd', ‘t', 'm' or 'n', add 'e' before the ending in the
  'du', 'er/sie/es' and 'ihr' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26496-3
  a curric:KeyLearningPoint ;
  rdfs:label """For verb stems ending in 's', 'ß', 'x' or 'z', add just 't' instead of 'st' in the
  'du' form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26496-4
  a curric:KeyLearningPoint ;
  rdfs:label """For stems ending in -el, remove the 'e' in the first person singular of the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26437-1
  a curric:KeyLearningPoint ;
  rdfs:label "The past participles of some verbs do not follow a pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.256268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26437-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ch] can be soft as in 'ich' or hard as in 'Buch'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26437-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense for actions completed in the past and the present for curret
  acctions and circumstances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26437-4
  a curric:KeyLearningPoint ;
  rdfs:label "The German perfect tense has two English translations."@en ;
  dcterms:modified "2026-06-07T15:30:29.256281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26437-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use simple past for past experiences and present perfect to emphaise ongoing effects
  of past actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26429-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nominative case is for nouns with sein, heißen and werden; accusative case is for
  object nouns with all other verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26429-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'haben' is irregular."@en ;
  dcterms:modified "2026-06-07T15:30:29.256296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26429-3
  a curric:KeyLearningPoint ;
  rdfs:label "Present tense weak verbs are formed like 'lernen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.256303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26429-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Nicht' negates before the definite article (meaning 'not the'), adjectives,
  possessives, proper nouns and after verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26429-5
  a curric:KeyLearningPoint ;
  rdfs:label """For negation before nouns, 'kein' replaces the indefinite article to mean 'not a',
  'no'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26483-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the superlative to express the highest degree of something, e.g., 'the
  most'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26483-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the superlative use ‘am’ before the adjective/adverb, and then add
  ‘-sten’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26483-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prenominal superlative adjectives use the definite article then add '-st' plus the
  appropriate ending to the adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26483-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some superlatives are irregular."@en ;
  dcterms:modified "2026-06-07T15:30:29.256843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26483-5
  a curric:KeyLearningPoint ;
  rdfs:label "Superlatives can be used to develop writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.256847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26606-1
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26606-2
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26606-3
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed response in conversation has at least three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.257219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26606-4
  a curric:KeyLearningPoint ;
  rdfs:label """Extend your answers by using a different tense, a different subject, or opinions and
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26525-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use ordinal numbers (e.g., 'first', 'second', 'third') for calendar dates."@en ;
  dcterms:modified "2026-06-07T15:30:29.257418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26525-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form ordinal numbers 1-19 add '-te', e.g., 'fünfte'; for ordinals 20 and over add
  '-ste', e.g., 'einundzwanzigste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26525-3
  a curric:KeyLearningPoint ;
  rdfs:label """For 'on the' with dates', use 'am' and add '-n' to the ordinal number, e.g., 'am
  zweiten März'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26525-4
  a curric:KeyLearningPoint ;
  rdfs:label """For years, separate the digits into two pairs, for century and year, and place
  'hundert' or 'tausend' between the pairs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26525-5
  a curric:KeyLearningPoint ;
  rdfs:label """To infer the meaning of unknown words, examine the surrounding words, review given
  definitions and select the best fit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26546-1
  a curric:KeyLearningPoint ;
  rdfs:label """The consonantal [r] makes a rolling sound at the back of the throat and the vocalic
  [r] has a gentle ‘ah’ sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26546-2
  a curric:KeyLearningPoint ;
  rdfs:label """A closed question is formed by swapping the position of the verb and subject in a
  statement. This is called inversion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26546-3
  a curric:KeyLearningPoint ;
  rdfs:label """An open question is formed by adding a question word before the verb at the start of
  a closed question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26546-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'du' questions for informal singular ‘you’, 'ihr' questions for informal plural
  ‘you’, and 'Sie' for formal ‘you’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26546-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use rising intonation, as well as correct word order, to make it clear that you are
  asking a question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26536-1
  a curric:KeyLearningPoint ;
  rdfs:label """Form the perfect tense with ‘haben’ or ‘sein’, plus a past participle, placed at the
  end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26536-2
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is a single-word past tense, using endings attached to the verb
  stem. It is mostly written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26536-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have irregular stems in the imperfect tense. The past participles of
  some verbs are also irregular."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26536-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense forms ‘hatte’, ‘war’, and ‘es gab’ are often used in spoken as
  well as written German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26536-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use ‘früher’ with a past tense to mean ‘in the past’ or ‘used to’."@en ;
  dcterms:modified "2026-06-07T15:30:29.257965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26436-1
  a curric:KeyLearningPoint ;
  rdfs:label """Planning to write involves organising ideas & selecting key structures, e.g., 'da
  ist', 'es gibt', 'jemand', 'niemand'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26436-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a checklist helps to ensure an appropirate range of language is used, e.g.,
  relative clauses, historic present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26436-3
  a curric:KeyLearningPoint ;
  rdfs:label "Accuracy is enchanced by careful checking."@en ;
  dcterms:modified "2026-06-07T15:30:29.258477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26471-1
  a curric:KeyLearningPoint ;
  rdfs:label "[o] and [ö] are long when followed by no consonants or only one consonant."@en ;
  dcterms:modified "2026-06-07T15:30:29.258480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26471-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperfect of singular modal verbs, remove -en and add -te for ‘ich’,
  -test for ‘du’, -te for ‘sie/er/es’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26471-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperfect of plural modal verbs, remove -en and add -ten for ‘wir’, -tet
  for ‘ihr’, -ten for ‘sie’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26471-4
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with modal verbs, the second verb is in the infinitive at the end of
  the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26570-1
  a curric:KeyLearningPoint ;
  rdfs:label """To form the future tense, use the present tense of werden to mean 'will, going to’
  and an infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26570-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form the conditional, use the conditional form of 'werden' ('würd-') meaning
  'would' and an infinitive at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26570-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the 2-verb rule the 2nd (infinitive) verb is at the end of the sentence;
  second-last place in subordinate clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26570-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Haben' and 'sein' are 'hätte' (would have) and 'wäre' (would be) in the conditional
  and don't need a 2nd infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26441-1
  a curric:KeyLearningPoint ;
  rdfs:label "[er] at the end of a word is unstressed and sounds like the English ‘uh’."@en ;
  dcterms:modified "2026-06-07T15:30:29.259309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26441-2
  a curric:KeyLearningPoint ;
  rdfs:label """The [r] in female people nouns is consonantal and is rolled at the back of the
  throat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26441-3
  a curric:KeyLearningPoint ;
  rdfs:label "Change verbs to male person nouns by adding –er to a verb stem."@en ;
  dcterms:modified "2026-06-07T15:30:29.259316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26441-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form a yes/no question in the perfect tense, swap the subject and the verb and
  send the past participle to the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26441-5
  a curric:KeyLearningPoint ;
  rdfs:label "To form a yes/no question in the imperfect tense, swap the subject and the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.259324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26462-1
  a curric:KeyLearningPoint ;
  rdfs:label """To form the future tense, use the present tense of 'werden' to mean ‘will’ and an
  infinitive verb at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26462-2
  a curric:KeyLearningPoint ;
  rdfs:label """To ask an open question in the future, use a question word followed by a form of
  'werden', followed by the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26462-3
  a curric:KeyLearningPoint ;
  rdfs:label """To ask an open question with 'möcht-', use a question word followed by a form of
  'möcht-', followed by the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26481-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjective agreement occurs when adjectives precede nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.260165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26481-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjective endings depend on case, gender and number."@en ;
  dcterms:modified "2026-06-07T15:30:29.260169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26481-3
  a curric:KeyLearningPoint ;
  rdfs:label "[-d] sounds like 'Hemd'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26481-4
  a curric:KeyLearningPoint ;
  rdfs:label "[-d-] sounds like 'Kleider'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26481-5
  a curric:KeyLearningPoint ;
  rdfs:label """Listening needs close reading of questions, attention to detail and vocabulary
  knowledge for gap-fill questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26528-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cardinal numbers (e.g., 'one') are used for counting or quantities. Ordinal numbers
  (e.g., ‘first’) show order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26528-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add '-te' to numbers 1-19 and '-ste' to numbers 20 and above to create ordinal
  numbers, e.g., 'fünfte' ('fifth')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26528-3
  a curric:KeyLearningPoint ;
  rdfs:label """For dates, use 'am' to say 'on the' and add '-n' to the ordinal number, e.g., 'am
  fünften August' (on the 5th August)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26528-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'in' with the dative case to say 'in' and with the accusative case to mean
  'into', e.g., 'ich gehe in die Schule'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26528-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Nach' means 'to' with place names and most countries. Use 'zu' plus dative for
  places with articles, people and events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26447-1
  a curric:KeyLearningPoint ;
  rdfs:label "Add ‘un’ to adjectives for their negative or opposite meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.261526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use word order two after 'meiner Meinung nach', and adverbs of time, manner,
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26447-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use the superlative to express the highest degree of something, e.g., the most."@en ;
  dcterms:modified "2026-06-07T15:30:29.261533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26447-4
  a curric:KeyLearningPoint ;
  rdfs:label """To form the superlative, use ‘am’ before the adjective/adverb, and then add
  ‘-sten’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26447-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use word order three after 'ich denke, dass' and 'ich glaube, dass'."@en ;
  dcterms:modified "2026-06-07T15:30:29.261541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26554-1
  a curric:KeyLearningPoint ;
  rdfs:label """Confidence in forming the perfect tense is important for communicating past events.
  Revisit key verbs often."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26554-2
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is more common in spoken German than the imperfect. Both can be
  used when writing in the past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26554-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense forms ‘hatte’, ‘war’, and ‘es gab’ are often used in spoken as
  well as written German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Learning imperfect tense endings, and the verb stems of strong verbs, will broaden
  your use of language in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26554-5
  a curric:KeyLearningPoint ;
  rdfs:label """Being familiar with a range of past tense verb forms will support your comprehension
  of written and spoken German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26557-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learning and revisiting vocabulary benefits from read-aloud pratice to cement
  sound-spelling correspondences"""@en ;
  dcterms:modified "2026-06-07T15:30:29.264158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26557-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud needs initial practice focussing on SSCs, compound and unknown words
  prior to whole text practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26557-3
  a curric:KeyLearningPoint ;
  rdfs:label "The interrogative pronoun 'wer' becomes 'wen' in the accusative."@en ;
  dcterms:modified "2026-06-07T15:30:29.264166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26557-4
  a curric:KeyLearningPoint ;
  rdfs:label "The interrogative pronoun 'wer' become 'wem' in the dative."@en ;
  dcterms:modified "2026-06-07T15:30:29.264172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26592-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of sound-symbol correspondance to
  transcribe spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26592-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26592-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26558-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'gern', 'lieber' and 'früher' with a past tense to mean 'liked', 'rather', 'in
  the past, used to'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26558-2
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs form their past participles by sandwiching the verb stem with 'ge-' and
  '-t', e.g., 'gespielt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26558-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with separable prefixes add 'ge-' after the separable prefix, e.g.,
  'aufgemacht'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26558-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with inseparable prefixes do not add 'ge-' to form their past participle,
  e.g., 'erlebt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26558-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs ending '-ieren' do not add 'ge-' to form the past participle. They add the
  suffix '-iert', e.g., 'ausprobiert'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26515-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are followed by prepositions and the accusative case, and some are
  followed by prepositions and the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26515-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use different prepositions after verbs in English and German, so verb and
  preposition combinations must be learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26515-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'da(r)-' can be added to prepositions to refer to something already
  mentioned. This is called a da- compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26515-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'wo-' compounds to ask questions with verbs that take prepositions."@en ;
  dcterms:modified "2026-06-07T15:30:29.268472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26515-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Dazu' can be used as a 'da-' compound, but can also be used to mean ‘in addition’
  or ‘furthermore’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26461-1
  a curric:KeyLearningPoint ;
  rdfs:label "Word order three conjunctions like 'wenn' send the verb to the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.271214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26461-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subject and verb are inverted in word order two."@en ;
  dcterms:modified "2026-06-07T15:30:29.271218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26461-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are many ways to form the plural in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.271224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26460-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Dürfen' refers to permission required from another person to do something."@en ;
  dcterms:modified "2026-06-07T15:30:29.271228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26460-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Können' refers to the ability to do something or the possibiity of doing
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26460-3
  a curric:KeyLearningPoint ;
  rdfs:label "Open questions use a question word before the verb, followed by the subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.271235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26460-4
  a curric:KeyLearningPoint ;
  rdfs:label """In open questions using a modal verb, the 2nd verb in the infinitive is at the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26492-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is just one present tense in German, used to translate the simple present and
  the present continuous in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26492-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imperative verbs are used to give instructions or advice, or to tell someone to do
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26492-3
  a curric:KeyLearningPoint ;
  rdfs:label """To form the imperative ‘du’ form of weak verbs, remove the ‘st’ ending from the
  normal present tense form and the 'du'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26492-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make the 'ihr' form of the imperative of weak verbs, just remove the 'ihr'. The
  verb stays the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26492-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with stems ending in ‘-d’ or ‘-t’ add an ‘-e’ to the 'du' form of the
  imperative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26453-1
  a curric:KeyLearningPoint ;
  rdfs:label """The indirect object pronouns are 'mir', 'dir, 'ihm', 'ihr', 'einem', 'uns', 'euch',
  'Ihnen' and 'ihnen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26453-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some verbs, called dative verbs, take indirect objects."@en ;
  dcterms:modified "2026-06-07T15:30:29.271516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26453-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some dative verbs are impersonal verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.271520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26453-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Bei' means 'at' or 'with'. When used with masculine or neuter nouns, 'bei dem'
  becomes 'beim'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26453-5
  a curric:KeyLearningPoint ;
  rdfs:label "The biggest ‘Karneval’ celebrations in Germany take place in Cologne."@en ;
  dcterms:modified "2026-06-07T15:30:29.271528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26469-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Uhr' means 'o'clock'. 'Halb' means 'half to the next hour'."@en ;
  dcterms:modified "2026-06-07T15:30:29.271560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26469-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Es' can be used as a pronoun to replace a neuter noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.271564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26469-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Es' can refer back or forward to a fact or idea, epxressed in a clause or
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26469-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Es' can be used with impersonal verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.271571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26564-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Vor' and 'nach' are prepositions used with nouns to express 'before' and 'after'.
  They take the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26564-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Bevor' and 'nachdem' are conjunctions meaning 'before' and 'after' and link two
  clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26564-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Bevor' and 'nachdem' are followed by word order 3 and send the verb to the end of
  the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26564-4
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, the finite verb, not the past participle or infinitive verb,
  is sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26564-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26568-1
  a curric:KeyLearningPoint ;
  rdfs:label """To refer back to something inanimate already mentioned, add da- or dar- to the
  beginning of a preposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26568-2
  a curric:KeyLearningPoint ;
  rdfs:label """As a da-compound, 'damit' means 'with it/them'; as a word order 3 conjunction,
  'damit' means 'so that'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26568-3
  a curric:KeyLearningPoint ;
  rdfs:label """In reading, use title and picture clues, close reading, translation and
  comprehension questions to aid understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26476-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use time adverbials 'schon', '(noch) nie', 'noch', 'schon einmal' with the perfect
  tense to provide more information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26476-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a role play, the response to each prompt should contain at least one verb, but
  still be relatively brief."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26476-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a role play, the response should match the tense of the prompt."@en ;
  dcterms:modified "2026-06-07T15:30:29.300189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26583-1
  a curric:KeyLearningPoint ;
  rdfs:label """A firm knowledge of German sound-symbol correspondence is important to transcribe
  spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26583-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26583-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29177-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of sound-symbol correspondences to
  transcribe spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29177-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29177-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26443-1
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives describe who a noun belongs to."@en ;
  dcterms:modified "2026-06-07T15:30:29.308012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26443-2
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives change endings depending on gender and case."@en ;
  dcterms:modified "2026-06-07T15:30:29.308016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26443-3
  a curric:KeyLearningPoint ;
  rdfs:label "An unstressed ‘er’ sounds like the English ‘uh’."@en ;
  dcterms:modified "2026-06-07T15:30:29.308020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26443-4
  a curric:KeyLearningPoint ;
  rdfs:label "A vocalic ‘r’ sounds like the English ‘a’ or ‘ah’."@en ;
  dcterms:modified "2026-06-07T15:30:29.308024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26443-5
  a curric:KeyLearningPoint ;
  rdfs:label "The consonantal ‘r’ is rolled at the back of the throat."@en ;
  dcterms:modified "2026-06-07T15:30:29.308030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26506-1
  a curric:KeyLearningPoint ;
  rdfs:label "Add ‘-keit’ or '-heit' to adjectives to make feminine nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.309687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26506-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns ending in '-heit' or '-keit' are usually translated into equivalent English
  nouns ending in '-ty' or '-ness'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26506-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most German adjectives can be used as adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.309694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26506-4
  a curric:KeyLearningPoint ;
  rdfs:label """English adjectives and adverbs differ, so care must be taken when translating German
  adjectives used as adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26506-5
  a curric:KeyLearningPoint ;
  rdfs:label """In extended writing, it is important to reference three different time frames: past,
  present, and future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26450-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'da-' is added to prepositions to refer back to something already
  mentioned and avoid repetition of the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26450-2
  a curric:KeyLearningPoint ;
  rdfs:label """We use da-compounds for inanimate nouns. We use direct object pronouns for people
  and animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26450-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use wo-compounds to ask questions with verbs that take prepositions."@en ;
  dcterms:modified "2026-06-07T15:30:29.309937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26450-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Wo' and 'da' become 'wor' and 'dar' before prepositions starting with a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.309941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26450-5
  a curric:KeyLearningPoint ;
  rdfs:label """The consonantal [r] makes a rolling sound at the back of the throat and the vocalic
  [r] has a gentle ‘ah’ sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26538-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates are words that have the same meaning and look the same or very similar to
  English words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26538-2
  a curric:KeyLearningPoint ;
  rdfs:label """Break compound words down into two or more individual words to work out their
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26538-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use previous knowledge and contextual clues from a text to help you work out the
  meanings of unfamiliar words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26538-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a role-play, you respond to each prompt with a short phrase. You will be
  addressed using the 'Sie' form of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26538-5
  a curric:KeyLearningPoint ;
  rdfs:label "In a role-play, you will need to ask at least one question."@en ;
  dcterms:modified "2026-06-07T15:30:29.311103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26477-1
  a curric:KeyLearningPoint ;
  rdfs:label "When [th] is in the same syllable, it sounds like English ‘t’."@en ;
  dcterms:modified "2026-06-07T15:30:29.311413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26477-2
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'bis' indicates an end-point in time and means ‘until’, ‘up to’ or
  ‘by’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26477-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use a preposition (‘zu’, ‘an’, ‘in’) with the preposition 'bis' when the following
  noun has an article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26477-4
  a curric:KeyLearningPoint ;
  rdfs:label "With days of the week, months and dates, use 'bis' with or without 'zu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.311425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26477-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use conjunction ‘bis’ with word order three (sending the verb to the end) to mean
  ‘until’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26442-1
  a curric:KeyLearningPoint ;
  rdfs:label """The past participles of '-ieren' verbs don't start with 'ge-'. They end with
  '-iert'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26442-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use adverbs like 'nie', 'schon', and 'noch nicht' with the perfect tense to provide
  more information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26442-3
  a curric:KeyLearningPoint ;
  rdfs:label "To form a yes/no question in the perfect tense, swap the subject and the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.313009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26442-4
  a curric:KeyLearningPoint ;
  rdfs:label """In dictation, check for grammatical accuracy as well as correct sound-symbol
  correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26565-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some conjunctions trigger word order 3 and send the verb to the end of the
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26565-2
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures with WO3, the finite verb, not past participle or infinitive,
  is sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Two-verb structures occur with modal verbs, the future tense with 'werden' and the
  perfect tense with 'haben' or 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26565-4
  a curric:KeyLearningPoint ;
  rdfs:label """Useful WO3 conjunctions include 'weil', 'dass', 'obwohl', 'solange', 'sobald' and
  'falls'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26571-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prepositions 'durch, für, gegen, um' are used with the accusative. 'Aus, bei,
  mit, nach, von, zu' use the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26571-2
  a curric:KeyLearningPoint ;
  rdfs:label """'An, auf, in, über, unter, vor, hinter, neben, zwischen' use the accusative for
  movement or the dative for no movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26571-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the prepositions and their cases ensures that the correct form of definite
  and indefinite articles is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26571-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use da-compounds for inanimate nouns already mentioned, including with verbs taking
  prepositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26571-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use accusative or dative pronouns for animate nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.313642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26500-1
  a curric:KeyLearningPoint ;
  rdfs:label """When combined with a second verb in the infinitive, some verbs require the addition
  of ‘zu’ before the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26500-2
  a curric:KeyLearningPoint ;
  rdfs:label "Infinitive constructions are separated from other clauses with a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.314374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26500-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'ohne … zu' + infinitive to mean 'without’, '(an)statt ... zu' for 'instead of',
  'um ... zu' to mean 'in order to'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26500-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the conjunction 'entweder … oder ...' to mean 'either … or ...' and 'weder …
  noch ...' to mean 'neither … nor ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26500-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Entweder ... oder ...' and 'weder ... noch...' are useful for expressing options
  and possibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26502-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are usually used with a second verb in the infinitive at the end of the
  sentence or clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26502-2
  a curric:KeyLearningPoint ;
  rdfs:label """The stems of some modal verbs are irregular, with vowel changes in most singular
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26502-3
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26502-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to predict follow-up questions on a theme for developing conversation
  after describing a photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26502-5
  a curric:KeyLearningPoint ;
  rdfs:label """In conversation, develop answers by adding opinions and reasons, varying the
  subject, and adding different time frames."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26569-1
  a curric:KeyLearningPoint ;
  rdfs:label """When tackling listening questions, knowledge of vocabulary is the most important
  element of success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26569-2
  a curric:KeyLearningPoint ;
  rdfs:label """Before a listening task, read the questions carefully and predict relevant
  voabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26569-3
  a curric:KeyLearningPoint ;
  rdfs:label "During listening, avoid distractors by not rushing to select the answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.315123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26569-4
  a curric:KeyLearningPoint ;
  rdfs:label "On completion of the listening, check answers against the questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.315127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26569-5
  a curric:KeyLearningPoint ;
  rdfs:label """In conversation, develop answers by adding opinions and reasons, varying the
  subject, and adding different time frames."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26572-1
  a curric:KeyLearningPoint ;
  rdfs:label """Closed questions where the answer is yes/no are formed by inverting the subject and
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26572-2
  a curric:KeyLearningPoint ;
  rdfs:label """Open questions, which seek more information than yes/no, start with a question word
  followed by the verb then subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26572-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use wo- and wor- prefixes with prepositions to ask questions. Prepositions do not
  stand alone at the end of a question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26572-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many verbs take prepositions and require a wo-compound when asking questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.317426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26605-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of sound-symbol correspondance to
  transcribe spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26605-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26605-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26424-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectival nouns behave like adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.322871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26424-2
  a curric:KeyLearningPoint ;
  rdfs:label """Weak masculine nouns such as ‘Name’ add (e)n in every form except singular
  nominative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26424-3
  a curric:KeyLearningPoint ;
  rdfs:label "All dative plural nouns add-n, except plurals ending in -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.322881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26424-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Seit' with the present tense communicates how long unfinished actions have been
  happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26455-1
  a curric:KeyLearningPoint ;
  rdfs:label """The acronym PALM is useful for describing photos. It stands for People, Action,
  Location, Mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26455-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to add opinions to personalise photo descriptions."@en ;
  dcterms:modified "2026-06-07T15:30:29.326429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26455-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is only one present tense in German. This is important to remember when
  describing what is happening in a photo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29182-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of sound-symbol correspondance to
  transcribe spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29182-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29182-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26567-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Bis' as a preposition means 'until, 'up to', by'. As a conjunction sending the verb
  to the end it means 'until'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26567-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Bis' can be used on its own with adverbs and simple time phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.335065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26567-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the noun following 'bis' has an article, use an appropriate preposition - 'zu',
  'an', 'in' - and the correct case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26567-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Wenn' means ‘when’, ‘whenever’ of ‘if’ and is used for repeated actions or
  conditions in the present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26567-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'bis' and 'wenn' trigger word order 3, sending the verb to the end of the
  sentence or clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26562-1
  a curric:KeyLearningPoint ;
  rdfs:label """Not all nouns form their plural in the same way, but there are helpful patterns we
  can learn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26562-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some nouns add an umlaut to the vowel in their plural form, e.g., 'Bäume'. Pay
  attention to the change in pronunciation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some masculine nouns referring to people and weak masculine nouns form their plural
  by adding '-(e)n'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26562-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plural nouns add '-n' in their dative plural forms, e.g., 'den Brüdern'."@en ;
  dcterms:modified "2026-06-07T15:30:29.339954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26562-5
  a curric:KeyLearningPoint ;
  rdfs:label """Die Brüder Grimm published a world-famous collection of fairy tales in 1812, which
  was called 'Kinder- und Hausmärchen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26467-1
  a curric:KeyLearningPoint ;
  rdfs:label "German [s-] sounds like English 'z'. German [z] sounds like English 'ts'."@en ;
  dcterms:modified "2026-06-07T15:30:29.342699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26467-2
  a curric:KeyLearningPoint ;
  rdfs:label """German cognates ending in ‘-tion’ have this ‘ts’ sound plus long vowel [o]n, as in
  'Information'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26467-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add -er to verb stems to create male agent nouns; for example, 'Arbeiter', 'Helfer'.
  Add -in for the feminine form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26467-4
  a curric:KeyLearningPoint ;
  rdfs:label """Develop writing with: different tenses, a range of vocabulary, and functions, e.g.,
  opinions and reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29172-1
  a curric:KeyLearningPoint ;
  rdfs:label """To form a question in the perfect tense, swap the auxiliary verb 'haben' or 'sein'
  with the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29172-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form a question in the future tense, swap the part of 'werden' with the subject.
  The infinitive stays at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29172-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a conversation, you can usually use the question to start your answer. Change 2nd
  person language to 1st person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29172-4
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed response has at least three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.353846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29172-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extend your answers by using a different tense, a different subject, or opinions and
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29164-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are always followed by a 2nd infinitive verb which normally comes at the
  end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29164-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are irregular in the first, 2nd and 3rd person singular, but regular in
  plural forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29164-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are mostly used in the imperfect tense when they describe past events.
  Remove any umlauts in the imperfect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29164-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense endings for modal verbs (-te, -test, -te, -ten, -tet, -ten) are
  the same as for weak verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29164-5
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29167-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are followed by prepositions and the accusative case, and some are
  followed by prepositions and the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29167-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some nouns and adjectives are followed by set prepositions and cases, which, like
  the verbs, need to be learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29167-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'da(r)-' can be added to prepositions to refer to something already
  mentioned. This is called a da- compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29167-4
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29167-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to categorise vocabulary by theme when revisiting large number of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26598-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a firm knowledge of sound-symbol correspondences to
  transcribe spoken German in a dictation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26598-2
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful listening is a secure knowledge of
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26598-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as a broad vocabulary, prediction and being aware of distractors and
  synonyms are useful listening strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26594-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nicht' before definite articles to mean ‘not the’ and 'kein' instead of the
  indefinite article to mean 'not a, no'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Place 'nicht' before adjectives, adverbs, possessives and proper nouns. Place
  'nicht' after verbs and whole phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26594-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'nichts' to mean 'nothing' or 'not anything', e.g., 'ich sehe nichts.' Use 'nie'
  to mean 'never'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26594-4
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26594-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is helpful to categorise vocabulary by theme when revisiting large numbers of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29186-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to have a good knowledge of sound-symbol correspondences to
  accurately read aloud in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look out for tricky sounds and cognates, and mentally rehearse before
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29186-3
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29186-4
  a curric:KeyLearningPoint ;
  rdfs:label "Choose words you know how to pronounce well, so that your responses are clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.354827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29185-1
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29185-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29185-3
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29176-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combine two or more words to create a compound noun. Add 'Lieblings' to mean
  'favourite' and 'Haupt' to mean 'main'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29176-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add the prefix 'un' to an adjective to mean 'un' or 'im' in English, e.g.,
  'unmöglich' - 'impossible'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29176-3
  a curric:KeyLearningPoint ;
  rdfs:label "To form ordinal numbers, add the suffix -te for numbers 1-19 and -ste for 20+."@en ;
  dcterms:modified "2026-06-07T15:30:29.355106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29176-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add the suffix 's' and remove the capital letter for days and times of day to change
  them from nouns into adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29176-5
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a role-play, answers should be a short phrase or sentence. Do not
  add unnecessary detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29181-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two-verb structures occur with modal verbs, the future tense with ‘werden’ and the
  perfect tense with ‘haben’ or ‘sein’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29181-2
  a curric:KeyLearningPoint ;
  rdfs:label """In standard or inverted word order, (WO1, 2) with 2-verb structures, the infinitive
  or past participle comes at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29181-3
  a curric:KeyLearningPoint ;
  rdfs:label """After conjunctions (WO3), the finite verb, not the past participle or infinitive, is
  sent to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29181-4
  a curric:KeyLearningPoint ;
  rdfs:label """The BORDER acronym is a useful tool to respond fully and accurately to bullet point
  writing prompts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29181-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating into German, translate the verb first - endings must match the
  tense and person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26608-1
  a curric:KeyLearningPoint ;
  rdfs:label """The most important thing for successful reading comprehension is a secure knowledge
  of vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26608-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is also very helpful to look out for synonyms and distractors when answering
  reading comprehension questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26608-3
  a curric:KeyLearningPoint ;
  rdfs:label """When translating, 'zoom in' to translate individual words and 'zoom out' to check
  the meaning of the whole sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26610-2
  a curric:KeyLearningPoint ;
  rdfs:label "A well-developed response in conversation has at least three verb clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.355552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26610-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extend your answers by using a different tense, a different subject, or opinions and
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29179-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 1 is the standard word order: subject-verb-object. Use WO1 after
  conjunctions 'und', 'oder', 'aber', 'denn'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29179-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 2 (inversion) is when subject and verb swap position so the verb is
  always the second idea in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29179-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 3 (subordination) is when the verb is sent to the end of the clause. Use
  WO3 after some conjunctions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29179-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use WO3 after: 'weil', 'obwohl', 'dass', 'wenn', 'ob', 'da', ‘bevor’, ‘als’,
  ‘nachdem’, ‘sobald’ and ‘falls’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29179-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a photo, use the acronym PALM. It stands for People, Action,
  Location, Mood. Add your own opinions too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355861Z"^^xsd:dateTime .

