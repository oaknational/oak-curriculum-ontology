    oakcurric:thread-word-order ,
    oakcurric:thread-adjectives ,
    oakcurric:thread-read-and-respond-to-texts ,
    oakcurric:thread-extend-written-and-spoken-production .

oakcurric:unit-2952
  a curric:Unit ;
  rdfs:label "Communication and the world around us: Geschichte"@en ;
  curric:slug "communication-and-the-world-around-us-geschichte" ;
  rdfs:comment """This unit revisits known grammar in the context of German and Austrian history.
  Pupils revise perfect tense and simple past, negation, word order and adjective agreement."""@en ;
  curric:whyThisWhyNow """In this unit pupils revisit simple past and the perfect tense as they are
  introduced to important aspects of German and Austrian history. They also practise negation,
  word order 2, adjective agreements and adjectival nouns. They practise these and expand their
  vocabulary in reading extended texts and in writing on subjects including the Habsburgs, Otto
  von Bismarck and the 1936 Berlin Olympics.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2952-1 ,
    oakcurric:priorknowledge-2952-2 ,
    oakcurric:priorknowledge-2952-3 ,
    oakcurric:priorknowledge-2952-4 ,
    oakcurric:priorknowledge-2952-5 ;
  curric:id "2952"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.428847Z"^^xsd:dateTime ;
