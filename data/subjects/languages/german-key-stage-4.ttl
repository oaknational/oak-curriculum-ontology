oakcurric:pupillessonoutcome-lesson-26426
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use wh- questions to ask about German culture."@en ;
  dcterms:modified "2026-06-07T15:30:41.064025Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26482
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use definite and indefinite articles when their German usage is different from
  English to understand a German text and hold a conversation about school uniforms."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064055Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26534
  a curric:PupilLessonOutcome ;
  rdfs:label """I understand when to use 'da sind' or 'es gibt' in the context of discussing holiday
