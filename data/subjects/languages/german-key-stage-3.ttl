oakcurric:priorknowledge-2913-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the perfect tense of weak and strong verbs with haben and sein."@en ;
  dcterms:modified "2026-06-07T15:29:23.299130Z"^^xsd:dateTime .

oakcurric:priorknowledge-2913-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all the German sound-symbol correspondences."@en ;
  dcterms:modified "2026-06-07T15:29:23.299155Z"^^xsd:dateTime .

oakcurric:priorknowledge-2913-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know a good range of previously taught high-frequency vocabulary."@en ;
  dcterms:modified "2026-06-07T15:29:23.299165Z"^^xsd:dateTime .

oakcurric:priorknowledge-2909-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the German perfect tense of weak and some strong verbs with haben plus
  past participle."""@en ;
  dcterms:modified "2026-06-07T15:29:23.405686Z"^^xsd:dateTime .

oakcurric:priorknowledge-2909-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know most German sound-symbol correspondences, including [ai], and hard and
  soft [ch]."""@en ;
  dcterms:modified "2026-06-07T15:29:23.405698Z"^^xsd:dateTime .

oakcurric:priorknowledge-2909-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the verb 'sein' in the present tense (ich, du, er/sie/es, wir, sie,
  Sie)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.405704Z"^^xsd:dateTime .

oakcurric:priorknowledge-2912-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know a range of weak and strong verbs in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.508435Z"^^xsd:dateTime .

oakcurric:priorknowledge-2912-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the proposition 'von' with the dative case."@en ;
  dcterms:modified "2026-06-07T15:29:23.508448Z"^^xsd:dateTime .

oakcurric:priorknowledge-2912-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know verbs of opinion, for example 'denken' and 'glauben'."@en ;
  dcterms:modified "2026-06-07T15:29:23.508454Z"^^xsd:dateTime .

oakcurric:priorknowledge-2912-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know word order 3 used with 'weil'."@en ;
  dcterms:modified "2026-06-07T15:29:23.508460Z"^^xsd:dateTime .

oakcurric:priorknowledge-2912-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know all the German sound-symbol correspondences apart from [pf] and [kn]"@en ;
  dcterms:modified "2026-06-07T15:29:23.508465Z"^^xsd:dateTime .

oakcurric:priorknowledge-2926-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know determiners (definite articles, dies-, jed-, alle welch-) in nominative
  and accusative cases."""@en ;
  dcterms:modified "2026-06-07T15:29:23.545285Z"^^xsd:dateTime .

oakcurric:priorknowledge-2926-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know comparative adjectives and adverbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.545298Z"^^xsd:dateTime .

oakcurric:priorknowledge-2926-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know two-verb structures with modal verbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.545305Z"^^xsd:dateTime .

oakcurric:priorknowledge-2926-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know and can use separable verbs in the present tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.545311Z"^^xsd:dateTime .

oakcurric:priorknowledge-2926-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know prepositions which taking the accusative (for example für and gegen) or
  the dative (for example mit and von)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.545317Z"^^xsd:dateTime .

oakcurric:priorknowledge-2907-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know definite and indefinite articles in the nominative and
  accusative cases."""@en ;
  dcterms:modified "2026-06-07T15:29:23.547529Z"^^xsd:dateTime .

oakcurric:priorknowledge-2907-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the verb 'mögen' with a noun to express an opinion."@en ;
  dcterms:modified "2026-06-07T15:29:23.547543Z"^^xsd:dateTime .

oakcurric:priorknowledge-2907-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know a range of high frequency nouns and adjectives."@en ;
  dcterms:modified "2026-06-07T15:29:23.547550Z"^^xsd:dateTime .

oakcurric:priorknowledge-2897-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a range of weak verbs in the infinitive and present tense singular
  forms."""@en ;
  dcterms:modified "2026-06-07T15:29:23.726187Z"^^xsd:dateTime .

oakcurric:priorknowledge-2897-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know a range of high frequency nouns, adjectives and adverbs."@en ;
  dcterms:modified "2026-06-07T15:29:23.726204Z"^^xsd:dateTime .

oakcurric:priorknowledge-2897-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how to form verb-subject-object questions with and without question
  words."""@en ;
  dcterms:modified "2026-06-07T15:29:23.726210Z"^^xsd:dateTime .

oakcurric:priorknowledge-2897-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know a range of question words."@en ;
  dcterms:modified "2026-06-07T15:29:23.726215Z"^^xsd:dateTime .

oakcurric:priorknowledge-2897-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know a range of sound-symbol correspondences, including [äu], [sch]
  and [sp]."""@en ;
  dcterms:modified "2026-06-07T15:29:23.726221Z"^^xsd:dateTime .

oakcurric:priorknowledge-2931-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to form plural nouns."@en ;
  dcterms:modified "2026-06-07T15:29:23.786638Z"^^xsd:dateTime .

oakcurric:priorknowledge-2931-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know numbers in German."@en ;
  dcterms:modified "2026-06-07T15:29:23.786651Z"^^xsd:dateTime .

oakcurric:priorknowledge-2931-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know the present tense of high-frequency verbs, including those with indirect
  objects."""@en ;
  dcterms:modified "2026-06-07T15:29:23.786657Z"^^xsd:dateTime .

oakcurric:priorknowledge-2931-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how to use the present tense with 'gern' and 'lieber'."@en ;
  dcterms:modified "2026-06-07T15:29:23.786662Z"^^xsd:dateTime .

oakcurric:priorknowledge-2931-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the perfect tense in German."@en ;
  dcterms:modified "2026-06-07T15:29:23.786668Z"^^xsd:dateTime .

oakcurric:priorknowledge-2924-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the present tense of weak and strong verbs in all forms."@en ;
  dcterms:modified "2026-06-07T15:29:23.788769Z"^^xsd:dateTime .

oakcurric:priorknowledge-2924-2
  a curric:PriorKnowledgeRequirement ;
