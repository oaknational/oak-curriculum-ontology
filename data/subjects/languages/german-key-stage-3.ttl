    oakcurric:thread-negation ,
    oakcurric:thread-questions ,
    oakcurric:thread-word-order ,
    oakcurric:thread-verb-to-have-having .

oakcurric:unit-2895
  a curric:Unit ;
  rdfs:label "Christmas: singular and plural nouns"@en ;
  curric:slug "christmas-singular-and-plural-nouns" ;
  rdfs:comment """This unit introduces pupils to 4 rules for forming plural nouns in German and
  provides opportunities for practice with the use of 'es gibt'. It will also teach pupils
  how to use plurals with 'sein' 3rd person plural, and 'sie' meaning 'they'. They practise
  sound-symbol correspondence [ü] and [ä]."""@en ;
  curric:whyThisWhyNow """In this unit, pupils consolidate their knowledge of 'sein' and 'haben' in
  the context of Christmas traditions and songs in German speaking countries. Throughout the
  unit, they will extend their ability to label and describe items with plural nouns (using 4
  of the 9 German rules for plurals) and numbers. They will also extend their range of
  questions.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-2895-1 ,
    oakcurric:priorknowledge-2895-2 ,
    oakcurric:priorknowledge-2895-3 ,
    oakcurric:priorknowledge-2895-4 ;
  curric:id "2895"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.066071Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-languages-key-stage-3 ;
